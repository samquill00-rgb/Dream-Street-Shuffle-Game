// --- RIGHT: Pink/brown brick building (right of pub) ---
var rightBuilding = new THREE.Group();
var rightBody = new THREE.Mesh(new THREE.BoxGeometry(5, 13, 7),
  new THREE.MeshStandardMaterial({ color: 0x7a5848, roughness: 0.92 }));
rightBody.position.set(7, 6.5, -3.5);
rightBuilding.add(rightBody);
// Windows facing +Z — raised above shop front (3 rows starting at y=4.5)
var rightWinYs = [4.5, 7.5, 10.5];
var rightRedMap = [[true, false], [false, true], [true, false]];
var redShadesR = [0xbb1515, 0xcc2828, 0xd43535, 0xaa1a1a];
for (var row = 0; row < 3; row++) {
  for (var col = 0; col < 2; col++) {
    var rwx = 5.5 + col * 1.8;
    var rwy = rightWinYs[row];
    var isRedR = rightRedMap[row][col];
    var redShadeR = redShadesR[(row * 2 + col) % redShadesR.length];
    var rwGlassMat = isRedR
      ? new THREE.MeshBasicMaterial({ color: redShadeR, transparent: true, opacity: 0.5 })
      : darkGlass;
    var rw = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.06), rwGlassMat);
    rw.position.set(rwx, rwy, 0.05);
    rightBuilding.add(rw);
    var rwf = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.4, 0.08), windowFrame);
    rwf.position.set(rwx, rwy, 0.04);
    rightBuilding.add(rwf);
    // Sill
    var rws = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.06, 0.12), sillMat);
    rws.position.set(rwx, rwy - 0.72, 0.08);
    rightBuilding.add(rws);
    // Lintel (brick arch hint)
    var rwl = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.1, 0.06),
      new THREE.MeshStandardMaterial({ color: 0x7a5040, roughness: 0.85 }));
    rwl.position.set(rwx, rwy + 0.72, 0.06);
    rightBuilding.add(rwl);
    // Red light spill
    if (isRedR) {
      var redLightR = new THREE.PointLight(redShadeR, 0.2, 3.5);
      redLightR.position.set(rwx, rwy, 0.8);
      rightBuilding.add(redLightR);
    }
  }
}
