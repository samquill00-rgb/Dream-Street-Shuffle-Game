placeMesh(pub, new THREE.BoxGeometry(0.06, 2.45, 0.1), whiteTrim, -0.08, 1.22, 0.32);
placeMesh(pub, new THREE.BoxGeometry(0.06, 2.45, 0.1), whiteTrim, -0.92, 1.22, 0.32);
// Fanlight above door
var fanlightGlass = new THREE.Mesh(new THREE.PlaneGeometry(0.78, 0.2),
new THREE.MeshBasicMaterial({ color: 0xffcc66, transparent: true, opacity: 0.5 }));
fanlightGlass.position.set(-0.5, 2.55, 0.34);
pub.add(fanlightGlass);
placeMesh(pub, new THREE.BoxGeometry(0.78, 0.02, 0.02), whiteTrim, -0.5, 2.45, 0.36);
// Door handle (brass)
