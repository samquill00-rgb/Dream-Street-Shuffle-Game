(set: _nb to '<div class="nb-page"><div class="nb-left"><div class="nb-section"><strong class="nb-heading">HAUNTS</strong>')\
(if: $haunts contains $haunt1)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt1 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Sketch</div>')]\
(if: $haunts contains $haunt2)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt2 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Refusal</div>')]\
(if: $haunts contains $haunt3)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt3 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Beast</div>')]\
(if: $haunts contains $haunt4)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt4 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Debt</div>')]\
(if: $haunts contains $haunt5)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt5 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Game</div>')]\
(if: $haunts contains $haunt6)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt6 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Delivery</div>')]\
(if: $haunts contains $haunt7)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt7 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Head</div>')]\
(if: $haunts contains $haunt8)[(set: _nb to _nb + '<div class="nb-item">⬖ ' + $haunt8 + '</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ The Wound</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-section"><strong class="nb-heading">PASSWORDS</strong>')\
(if: $knowsCopperWord is true)[(set: _nb to _nb + '<div class="nb-item">⚿ "I said hello" — for Copper</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A word for Copper</div>')]\
(if: $knowsCopperSecret is true)[(set: _nb to _nb + '<div class="nb-item">⚿ "Valletta" — Lackland&#39;s back room</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A word for Lackland</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-section"><strong class="nb-heading">OBJECTS</strong>')\
(if: $hasTrishaMatchbook is true)[(set: _nb to _nb + '<div class="nb-item">◈ Trisha&#39;s matchbook (an invitation)</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A matchbook</div>')]\
(if: $knowsCecilCourt is true)[(set: _nb to _nb + '<div class="nb-item">◈ A beer mat — Cecil Court scrawled on the back</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A beer mat</div>')]\
(if: $hasMissingPage is true and $returnedPage is not true)[(set: _nb to _nb + '<div class="nb-item">◈ Page 47 (for O&#39;Flatterly)</div>')](else-if: $returnedPage is true)[(set: _nb to _nb + '<div class="nb-grey">◈ Page 47 (returned)</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A missing page</div>')]\
(if: $returnedPage is true)[(set: _nb to _nb + '<div class="nb-item">◈ A vial — Shelley&#39;s liver. Swallow it near the end.</div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ A gift from the antiquarian</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-section nb-alba-section"><strong class="nb-heading nb-alba-heading">THE ALBA</strong>')\
(if: $alba contains $alba1)[(set: _nb to _nb + '<div class="nb-item nb-alba-line">✦ <em>' + (text: $alba1) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(if: $alba contains $alba2)[(set: _nb to _nb + '<div class="nb-item nb-alba-line">✦ <em>' + (text: $alba2) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(if: $alba contains $alba3)[(set: _nb to _nb + '<div class="nb-item nb-alba-line">✦ <em>' + (text: $alba3) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '</div><div class="nb-right">' + _m + '</div></div>')\
(dialog: _nb, " ")

