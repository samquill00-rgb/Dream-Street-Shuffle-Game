#caa890" stroke-width="0.55"/><ellipse cx="37" cy="86" rx="2.8" ry="3.8" fill="rgba(228,204,176,0.30)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="42" cy="108" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.28)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="32" cy="60" rx="1.0" ry="1.4" fill="rgba(244,224,196,0.30)"/><ellipse cx="36" cy="84" rx="0.9" ry="1.2" fill="rgba(244,224,196,0.25)"/><circle cx="84" cy="78" r="1.3" fill="#e4c4a4" opacity="0.55"/></svg><svg class="dawn-corner dawn-corner-bl" viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg"><path d="M 0,12 Q 22,12 38,28 Q 56,48 60,80" stroke="#caa890" stroke-width="1.1" fill="none" opacity="0.7"/><path d="M 0,4 Q 14,4 26,16" stroke="#caa890" stroke-width="0.45" fill="none" opacity="0.4"/><path d="M 38,28 Q 30,58 36,90 Q 44,108 38,120" stroke="#caa890" stroke-width="0.55" fill="none" opacity="0.4"/><path d="M 60,80 Q 78,86 84,78 Q 84,68 74,72 Q 72,82 80,82" stroke="#caa890" stroke-width="0.55" fill="none" opacity="0.4"/><path d="M 26,16 Q 18,22 14,32 Q 22,28 28,22 Z" fill="rgba(168,148,116,0.30)" stroke="#caa890" stroke-width="0.4"/><ellipse cx="33" cy="62" rx="3.0" ry="4" fill="rgba(228,204,176,0.32)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="37" cy="86" rx="2.8" ry="3.8" fill="rgba(228,204,176,0.30)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="42" cy="108" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.28)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="32" cy="60" rx="1.0" ry="1.4" fill="rgba(244,224,196,0.30)"/><ellipse cx="36" cy="84" rx="0.9" ry="1.2" fill="rgba(244,224,196,0.25)"/><circle cx="84" cy="78" r="1.3" fill="#e4c4a4" opacity="0.55"/></svg><svg class="dawn-corner dawn-corner-br" viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg"><path d="M 0,12 Q 22,12 38,28 Q 56,48 60,80" stroke="#caa890" stroke-width="1.1" fill="none" opacity="0.7"/><path d="M 0,4 Q 14,4 26,16" stroke="#caa890" stroke-width="0.45" fill="none" opacity="0.4"/><path d="M 38,28 Q 30,58 36,90 Q 44,108 38,120" stroke="#caa890" stroke-width="0.55" fill="none" opacity="0.4"/><path d="M 60,80 Q 78,86 84,78 Q 84,68 74,72 Q 72,82 80,82" stroke="#caa890" stroke-width="0.55" fill="none" opacity="0.4"/><path d="M 26,16 Q 18,22 14,32 Q 22,28 28,22 Z" fill="rgba(168,148,116,0.30)" stroke="#caa890" stroke-width="0.4"/><ellipse cx="33" cy="62" rx="3.0" ry="4" fill="rgba(228,204,176,0.32)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="37" cy="86" rx="2.8" ry="3.8" fill="rgba(228,204,176,0.30)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="42" cy="108" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.28)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="32" cy="60" rx="1.0" ry="1.4" fill="rgba(244,224,196,0.30)"/><ellipse cx="36" cy="84" rx="0.9" ry="1.2" fill="rgba(244,224,196,0.25)"/><circle cx="84" cy="78" r="1.3" fill="#e4c4a4" opacity="0.55"/></svg></div><div class="dawn-rule-top">(if: _albaComplete)[(display: "Dawn Rule SVG top")](else:)[(display: "Dawn Rule SVG eclipse")]</div>
<div class="dawn-title">THE DAWN</div>
<div class="dawn-bookname">// (print: $bookTitle) //</div>
You have been awake for so long.

Yes, maybe tomorrow but till then you'll lie with Aoife and she'll lie with you, and together you'll raise a daughter.

Better not tomorrow.

(if: _albaComplete)[<div class="alba-final">
(after: 2s)[<span class="alba-line dawn-line-fade">$alba1</span>]
(after: 3.5s)[<span class="alba-line dawn-line-fade">$alba2</span>]
(after: 5s)[<span class="alba-line dawn-line-fade">$alba3</span>]
</div>
(after: 6.5s)[<span class="alba-credit dawn-line-fade">'Alba' by Ezra Pound</span>]]

<span id="dawn-petal-trigger">And the last weight peeled from the dawn is breathlike as a petal of the lily-of-the-valley which, caught on a thermal, is rising plum into the childbearing sun, till the days settles up and it's lost. You've forgotten the name of that flower.</span>

<div class="dawn-flowering">(display: "Lily SVG")</div>

<div class="dawn-rule-bottom">(display: "Dawn Rule SVG bottom")</div>

<div class="dawn-colophon">By Three Blue Posts</div>
<div class="dawn-credits">Closing music by Sam Quill and Patrick Davidson Roberts, arr. and piano by Eoin Roe.</div>

(set: _hauntCount to $haunts's length)\
(set: _lilyDone to 0)\
(if: $tookLily1 is true)[(set: _lilyDone to _lilyDone + 1)]\
(if: $tookLily2 is true)[(set: _lilyDone to _lilyDone + 1)]\
(if: $tookLily3 is true)[(set: _lilyDone to _lilyDone + 1)]\
(if: $tookLily4 is true)[(set: _lilyDone to _lilyDone + 1)]\
(if: $tookLily5 is true)[(set: _lilyDone to _lilyDone + 1)]\
(after: 13s)[<div class="dawn-summary">
<div class="dawn-summary-row"><span class="dawn-summary-label">HAUNTS</span><span class="dawn-summary-count">(print: _hauntCount) of 12</span></div>
<div class="dawn-summary-row"><span class="dawn-summary-label">FLOWERS</span><span class="dawn-summary-count">(print: _lilyDone) of 5</span></div>
</div>]
(after: 20s)[<div class="dawn-play-again">
<button class="dawn-restart-btn" onclick="(function(){try{localStorage.clear();}catch(e){}try{sessionStorage.clear();}catch(e){}window.location.href=window.location.pathname;})()">Play again</button>
</div>]

</div>

:: Dean Street [hub] {"position":"900,400","size":"100,100"}
(if: $pendingLilyBreath is true)[(set: $pendingLilyBreath to false)(go-to: "After the call")]\
(if: $hadPhoneCall is true and $metCritic is true and $sawAoifeReflection is false)[(set: $sawAoifeReflection to true)(go-to: "After Aoife")]\
(set: $awaitingLacklandPwd to false)\
<svg id="dean-lamp-svg" xmlns="http://www.w3.org/2000/svg" width="145" height="400" style="float:right;margin:0.3em -0.5em 1em 0.8em;overflow:hidden;"><defs><radialGradient id="dslamp" cx="55%" cy="5%" r="65%"><stop offset="0%" stop-color="#d4a060" stop-opacity="0.7"/><stop offset="25%" stop-color="#c89060" stop-opacity="0.35"/><stop offset="60%" stop-color="#c89060" stop-opacity="0.12"/><stop offset="100%" stop-color="#c89060" stop-opacity="0"/></radialGradient></defs><rect x="-40" y="-80" width="240" height="340" fill="url(#dslamp)"/><g fill="none" stroke="#c8a86a" stroke-linecap="round" stroke-linejoin="round"><line x1="90" y1="32" x2="90" y2="38" stroke-width="1.8"/><circle cx="90" cy="42" r="4" stroke-width="2.0"/><line x1="90" y1="46" x2="90" y2="56" stroke-width="1.8"/><line x1="90" y1="56" x2="68" y2="68" stroke-width="2.5"/><line x1="90" y1="56" x2="112" y2="68" stroke-width="2.5"/><line x1="66" y1="68" x2="114" y2="68" stroke-width="2.3"/><line x1="68" y1="68" x2="68" y2="104" stroke-width="2.3"/><line x1="112" y1="68" x2="112" y2="104" stroke-width="2.3"/><line x1="66" y1="104" x2="114" y2="104" stroke-width="2.3"/><line x1="90" y1="68" x2="90" y2="104" stroke-width="1.4"/><line x1="68" y1="86" x2="112" y2="86" stroke-width="1.4"/><path d="M90,104 L72,178 L100,238" stroke-width="3.0"/><ellipse cx="100" cy="240" rx="13" ry="4" stroke-width="1.8"/><line x1="100" y1="246" x2="100" y2="9999" stroke-width="3.8"/><ellipse cx="100" cy="385" rx="13" ry="4" stroke-width="1.8"/><ellipse cx="100" cy="530" rx="13" ry="4" stroke-width="1.8"/><rect x="84" y="692" width="32" height="8" rx="2" stroke-width="1.8"/></g></svg>
<h1 class="game-title" style="font-size:1.7em;">DREAM STREET<span style="display:block;height:0.15em;"></span>SHUFFLE</h1>
{<!-- BOOLEAN GUARDS: ensure vars are correct types on first visit (added §1.1) -->
(unless: $alba is an array)[(set: $alba to (a:))]
(unless: $haunts is an array)[(set: $haunts to (a:))]
(unless: $bookTitle is a string)[(set: $bookTitle to "Untitled Manuscript")]
(if: $bookTitle is "")[(set: $bookTitle to "Untitled Manuscript")]
(unless: $metCritic is a boolean)[(set: $metCritic to false)]
(unless: $hauntExplained is a boolean)[(set: $hauntExplained to false)]
(unless: $afterMidnight is a boolean)[(set: $afterMidnight to false)]
<!-- BACK-FILL: older saves may have $metCritic=true but $knowsCecilCourt=false
     because the (set:) was added later. Heal them on every Dean Street visit. -->
(if: $metCritic is true and $knowsCecilCourt is false)[(set: $knowsCecilCourt to true)]
<!-- BACK-FILL: $visited datamap was initialized with only French/Pillars/Colony.
     Add Ronnies so the Ronnie Scott's link condition doesn't throw a "no such
     data name" error on $visited's Ronnies. -->
(unless: $visited is a datamap)[(set: $visited to (dm: "French", false, "Pillars", false, "Colony", false, "Ronnies", false))]
(unless: $visited contains "Ronnies")[(set: $visited's Ronnies to false)]
<!-- VISIT COUNTER -->
(set: $returns to $returns + 1)
<!-- HUB ATTRITION: morale wears down with each lap of Soho. The first
     return is free; subsequent returns drag a little harder, scaling
     gently with how far into the night you are. Ten returns ≈ -28
     confidence in passive drag, which the venue gains keep ahead of
     unless the player is genuinely circling. -->
(if: $returns is 2 or $returns is 3)[(set: $confidence to ($statLoss: $confidence, 3))(set: $sobriety to ($statLoss: $sobriety, 1))]
(else-if: $returns is 4 or $returns is 5)[(set: $confidence to ($statLoss: $confidence, 5))(set: $sobriety to ($statLoss: $sobriety, 2))]
(else-if: $returns >= 6)[(set: $confidence to ($statLoss: $confidence, 8))(set: $sobriety to ($statLoss: $sobriety, 3))]
<!-- STAT CLAMPS: 0..100 belt-and-braces. The asymptotic $statGain curve
     already prevents stats from sitting on the ceiling, so we no longer
     need an artificial morale ceiling at 90. -->
(if: $confidence > 100)[(set: $confidence to 100)]
(if: $confidence < 0)[(set: $confidence to 0)]
(if: $sobriety > 100)[(set: $sobriety to 100)]
(if: $sobriety < 0)[(set: $sobriety to 0)]
(if: $sobriety <= 0 and $haunts's length >= 10)[(set: $coachUrgent to true)](else-if: $sobriety <= 0)[(set: $sobriety to 5)]
<!-- DERIVED FLAGS: computed each visit -->
(set: _towerReady to ($alba contains $alba1) and ($alba contains $alba2) and ($alba contains $alba3))\
(set: _albaCount to 0)(if: $alba contains $alba1)[(set: _albaCount to _albaCount + 1)](if: $alba contains $alba2)[(set: _albaCount to _albaCount + 1)](if: $alba contains $alba3)[(set: _albaCount to _albaCount + 1)]\
<!-- FETCH GLIMPSE — DISABLED 2026-05-11. Felt arbitrary, and the alba=3 line repeats what The Fetch passage already says. Restore by removing the (if: false) wrapper. -->
(if: false)[(if: $wasBeaten is true and $visitedInterval is true)[(if: _albaCount >= 3)[<span class="fetch-glimpse">You see him then, your double, your fetch, walking your walk down or else up Greek Street. Centre Point is there, where you're going together.</span>](else-if: _albaCount is 2)[<span class="fetch-glimpse">You see him then: yourself, walking ahead of you down Greek Street toward Centre Point. He does not look back. He walks the way a man walks when he has made a decision. You know where he is going. You have always known.</span>](else:)[<span class="fetch-glimpse">Someone's at the other end of Greek Street, looking just like you. Before you look, he's gone.</span>]]]
(if: $tookLily5 is true and $visited contains "Pillars" and $visited's Pillars is true and $afterMidnight is false)[(set: $afterMidnight to true)(set: $midnightJustPassed to true)]
}
<!-- Date moved out of the hub header — the 3D scenes (Approach passages)
     carry the diegetic datestamp now, so the hub strap reads cleaner.
     Midnight transition is still triggered here so the chime fires when the
     player first returns to the hub after midnight; the flip span itself
     only renders during the brief flare so the animation isn't lost. -->
(if: $midnightJustPassed is true)[<span class="scene-date scene-date-flip">(if: $afterMidnight)[24.11.73](else:)[23.11.73]</span>(set: $midnightJustPassed to false)]
(if: $justAteChippy is true)[(set: $justAteChippy to false)<script>setTimeout(function(){if(window.showEatPopup)window.showEatPopup('chips');},250);</script>]
<span class="scene-location">Dean Street, Soho, London.</span>

(if: $returns is 2 and $hasCoin is false)[(set: $hasCoin to true)<div id="coin-overlay"><div class="coin-overlay-box"><div class="coin-overlay-stage"><div class="coin-overlay-disc" id="coin-overlay-disc"><div class="cp-face cp-heads"></div><div class="cp-face cp-tails"></div></div></div><p class="coin-overlay-text">You found a coin on the pavement; a rare one, called a &#39;Donkey&#39;. There&#39;s only one. Toss it and pocket it. You&#39;ll want it later.</p><span class="inventory-note">&#9734; COIN ACQUIRED</span><button class="coin-overlay-btn" id="coin-toss-btn">Toss it</button><span class="coin-overlay-result" id="coin-overlay-result"></span><button class="coin-overlay-btn coin-overlay-dismiss" id="coin-keep-btn" style="visibility:hidden">Pocket it</button></div></div><script>(function(){var tossCount=0,maxToss=2,stage=document.querySelector(".coin-overlay-stage");var sequence=[false,true];var pocketed=false;function sparks(){for(var i=0;12>i;i++){var s=document.createElement("div");s.className="cp-spark";var a=Math.random()*360,dist=60+Math.random()*40;s.style.setProperty("--sx",(Math.cos(a*Math.PI/180)*dist)+"px");s.style.setProperty("--sy",(Math.sin(a*Math.PI/180)*dist)+"px");s.style.animationDelay=(Math.random()*0.3)+"s";s.style.animationDuration=(0.5+Math.random()*0.5)+"s";stage.appendChild(s);setTimeout(function(el){el.remove();},(1200),s);}}document.getElementById("coin-toss-btn").addEventListener("click",function(){var d=document.getElementById("coin-overlay-disc"),r=document.getElementById("coin-overlay-result"),b=this,o=document.getElementById("coin-overlay");if(pocketed)return;if(d.classList.contains("cp-flipping"))return;if(window.dssAudio)window.dssAudio.coinFlip();var heads=sequence[tossCount];tossCount++;var endDeg=heads?"1440deg":"1620deg";var restDeg=heads?"0deg":"180deg";d.style.setProperty("--cp-end",endDeg);d.classList.remove("cp-flipping");void d.offsetWidth;d.classList.add("cp-flipping");sparks();r.textContent="";b.classList.add("coin-btn-hidden");setTimeout(function(){if(pocketed)return;r.textContent=heads?"Heads.":"Tails.";d.style.transform="rotateX("+restDeg+")";d.classList.remove("cp-flipping");if(tossCount>=maxToss){setTimeout(function(){if(pocketed)return;o.classList.add("coin-overlay-fade");setTimeout(function(){o.remove();},800);},1800);}else{setTimeout(function(){if(pocketed)return;r.textContent="";b.classList.remove("coin-btn-hidden");b.textContent="Toss again";b.classList.add("coin-overlay-dismiss");var kb=document.getElementById("coin-keep-btn");if(kb){kb.style.visibility="visible";kb.classList.remove("coin-overlay-dismiss");kb.classList.add("coin-overlay-primary");}},2200);}},2000);});var keepBtn=document.getElementById("coin-keep-btn");if(keepBtn){keepBtn.addEventListener("click",function(){if(pocketed)return;pocketed=true;var o=document.getElementById("coin-overlay");var box=o&&o.querySelector(".coin-overlay-box");if(!o||!box)return;var tb=document.getElementById("coin-toss-btn");if(tb){tb.classList.add("coin-btn-hidden");tb.style.pointerEvents="none";}for(var k=1;k<=12;k++){var m=document.createElement("span");m.className="item-mote item-mote-"+k;box.appendChild(m);}this.style.display="none";setTimeout(function(){o.classList.add("coin-overlay-fade");setTimeout(function(){o.remove();},800);},1600);});}var ov=document.getElementById("coin-overlay");if(ov){ov.addEventListener("click",function(e){if(e.target===ov&&tossCount>0){ov.classList.add("coin-overlay-fade");setTimeout(function(){ov.remove();},800);}});}})();</script>]\
|deanIntro>[A heavy afternoon lingers in rainfall on the pavements though the sky has cleared now and the newborn night is cut with moonshine.

There is an atmosphere of the silver screen: as if Brando might emerge in a tight and sodden T-shirt, from any door or alleyway, anytime.]

(if: $returns is 1)[In your bag, you have your novel, in manuscript. It will help you find the things you need.](else:)[In your bag, you have //(print: $bookTitle)//, your novel, in manuscript. It will help you find the things you need.]
(if: $returns > 1)[(enchant: ?deanIntro, (text-colour: "#4a4a4a") + (css: "opacity:0.6"))]\

(if: $metRed is false and $coachUrgent is false)[Someone's on the corner.

[[See who's there|Approach The Ginger Light]]]\
(if: $metRed is true)[\
(if: _towerReady)[<div class="choice-box"><span class="guided-link">[[The dawn is coming|The Fetch]]</span></div>]\
(if: $coachUrgent is true and _towerReady is false)[<div class="choice-box">'[Noises off. Blackout.]'

<span class="guided-link">[[The Coach and Horses|Approach The Coach]]</span></div>]\
(if: $coachUrgent is false)[Where now?

(if: $returns >= 2 and $visited's French is true and $shownVenueHint is false)[(set: $shownVenueHint to true)<script>setTimeout(function(){ if(window.venueHintPopup) window.venueHintPopup(); }, 300);</script>]
(if: $returns >= 3 and $confidence < 30 and $sobriety < 30 and ($hadChippy is false or $hadBreather is false))[(if: $shownLowBoth is false)[(set: $shownLowBoth to true)<span id="wtw-msg-low-both" style="display:none">(if: $hadChippy is false and $hadBreather is false)[You're in a bad way. Get some grub at the chippy. Find a doorway. Catch your breath.](else-if: $hadChippy is false)[You're in a bad way. Get some grub at the chippy.](else:)[You're in a bad way. Step into a doorway. Catch your breath.]</span><script>setTimeout(function(){var el=document.getElementById('wtw-msg-low-both');if(window.wordToTheWisePopup&&el)window.wordToTheWisePopup(el.textContent);},300);</script>]
(if: $hadChippy is false)[[[Get some grub|Approach Chinese Fish and Chips]]
](if: $hadBreather is false)[[[Step into a doorway|A Doorway on Dean Street]]]
](else-if: $returns >= 3 and $confidence < 40 and $hadChippy is false)[(if: $shownLowConf is false)[(set: $shownLowConf to true)<script>setTimeout(function(){if(window.wordToTheWisePopup)window.wordToTheWisePopup("You seem hungry. Get some grub at the chippy.");},300);</script>]
[[Get some grub|Approach Chinese Fish and Chips]]
](else-if: $returns >= 3 and $sobriety < 40 and ($hadBreather is false or $hadChippy is false))[(if: $shownLowSobr is false)[(set: $shownLowSobr to true)<span id="wtw-msg-low-sob" style="display:none">(if: $hadBreather is false)[You should have gone to the gents earlier.](else:)[You should have gone to the gents earlier. Get some grub at the chippy.]</span><script>setTimeout(function(){var el=document.getElementById('wtw-msg-low-sob');if(window.wordToTheWisePopup&&el)window.wordToTheWisePopup(el.textContent);},300);</script>]
(if: $hadBreather is false)[[[Step into a doorway|A Doorway on Dean Street]]](else-if: $hadChippy is false)[[[Get some grub|Approach Chinese Fish and Chips]]]
]]
(if: $coachUrgent is false and not (($haunts contains $haunt4) and ($haunts contains $haunt1) and ($haunts contains $haunt2)))[[[To The French|Approach The French]] (if: $haunts contains $haunt4)[<span class="hp hp-done">◆</span>](else:)[(if: $hauntExplained is true)[<span class="hp">◇</span>]](if: $haunts contains $haunt1)[<span class="hp hp-done">◆</span>](else:)[(if: $hauntExplained is true)[<span class="hp">◇</span>]](if: $haunts contains $haunt2)[<span class="hp hp-done">◆</span>](else:)[(if: $hauntExplained is true)[<span class="hp">◇</span>]] (if: $tookLily5 is true)[<span class="lp lp-done">❀</span>](else-if: $lilyHintShown is true)[<span class="lp">❁</span>]
