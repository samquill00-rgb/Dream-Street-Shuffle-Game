 font-style='italic' letter-spacing='2' style='filter: drop-shadow(0 0 2px rgba(10,9,8,0.9));'>and in the Column stands the six-rayed Star.</text></g>")]\
(set: _m to _m + "<rect width='560' height='700' fill='url(#fg)' pointer-events='none'/><rect width='560' height='700' fill='url(#fg2)' pointer-events='none'/><rect width='560' height='700' fill='none' stroke='rgba(10,9,8,0.85)' stroke-width='15' pointer-events='none'/>")(set: _m to _m + "</svg></div>")\
(set: _lo1 to (cond: $lilyCount >= 1, 'nb-lily-gathered', 'nb-lily-empty'))\
(set: _lo2 to (cond: $lilyCount >= 2, 'nb-lily-gathered', 'nb-lily-empty'))\
(set: _lo3 to (cond: $lilyCount >= 3, 'nb-lily-gathered', 'nb-lily-empty'))\
(set: _lo4 to (cond: $lilyCount >= 4, 'nb-lily-gathered', 'nb-lily-empty'))\
(set: _lo5 to (cond: $lilyCount >= 5, 'nb-lily-gathered', 'nb-lily-empty'))\
(set: _queue to '')\
(if: $lilyCount >= 5 and $sawPentangle is false)[(set: _queue to 'lily,map')]\
(set: _nb to '<div class="nb-page">')\
(if: _queue is not '')[(set: _nb to '<div class="nb-page" data-pentangle-queue="' + _queue + '">')]\
(set: _nb to _nb + '<div class="nb-tabs"><div class="nb-tab nb-tab-active" data-tab="notes" onclick="window.nbSwitchTab(this)">FINDS</div><div class="nb-tab" data-tab="inventory" onclick="window.nbSwitchTab(this)">EFFECTS</div><div class="nb-tab" data-tab="lily" onclick="window.nbSwitchTab(this)">LILIES</div><div class="nb-tab" data-tab="alba" onclick="window.nbSwitchTab(this)">POEM</div><div class="nb-tab" data-tab="map" onclick="window.nbSwitchTab(this)">MAP</div></div>')\
(set: _nb to _nb + '<div class="nb-panel nb-panel-notes nb-panel-active">')\
(set: _nb to _nb + '<div class="nb-key"><span class="nb-key-item"><span class="hp hp-done">◆</span> haunt caught &middot; <span class="hp">◇</span> still to catch</span><span class="nb-key-item"><span class="pp pp-done">▲</span> word learned &middot; <span class="pp">△</span> still to learn</span><span class="nb-key-item"><span class="al al-done">✦</span> alba line &middot; <span class="al">✧</span> still to find</span><span class="nb-key-item"><span class="qp qp-done">★</span> quest done &middot; <span class="qp">☆</span> still to do</span></div>')\
(set: _nb to _nb + '<div class="nb-section"><strong class="nb-heading">HAUNTS</strong>')\
(if: $haunts contains $haunt1)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt1 + ' <span class="haunt-stage">(Calcinatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Sketch</div>')]\
(if: $haunts contains $haunt2)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt2 + ' <span class="haunt-stage">(Solutio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Refusal</div>')]\
(if: $haunts contains $haunt3)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt3 + ' <span class="haunt-stage">(Putrefactio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Beast</div>')]\
(if: $haunts contains $haunt4)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt4 + ' <span class="haunt-stage">(Coniunctio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Debt</div>')]\
(if: $haunts contains $haunt5)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt5 + ' <span class="haunt-stage">(Fermentatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Game</div>')]\
(if: $haunts contains $haunt6)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt6 + ' <span class="haunt-stage">(Sublimatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Delivery</div>')]\
(if: $haunts contains $haunt7)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt7 + ' <span class="haunt-stage">(Congelatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Head</div>')]\
(if: $haunts contains $haunt8)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt8 + ' <span class="haunt-stage">(Projectio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Wound</div>')]\
(if: $haunts contains $haunt9)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt9 + ' <span class="haunt-stage">(Separatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Sorting</div>')]\
(if: $haunts contains $haunt10)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt10 + ' <span class="haunt-stage">(Cibatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Feeding</div>')]\
(if: $haunts contains $haunt11)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt11 + ' <span class="haunt-stage">(Multiplicatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Spread</div>')]\
(if: $haunts contains $haunt12)[(set: _nb to _nb + '<div class="nb-item"><span class="hp hp-done">◆</span> ' + $haunt12 + ' <span class="haunt-stage">(Exaltatio)</span></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="hp">◇</span> The Crown</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-section"><strong class="nb-heading">PASSWORDS</strong>')\
(if: $knowsCopperWord is true)[(if: $awaitingCopperPwd is true)[(set: _nb to _nb + '<div class="nb-item"><span class="pp pp-done">▲</span> "I said hello" — for Copper <button class="nb-deploy-btn" onclick="window.deployPwd(\'copper\')">Deploy</button></div>')](else:)[(set: _nb to _nb + '<div class="nb-item"><span class="pp pp-done">▲</span> "I said hello" — for Copper</div>')]](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="pp">△</span> A word for Copper</div>')]\
(if: $knowsCopperSecret is true)[(if: $awaitingLacklandPwd is true)[(set: _nb to _nb + '<div class="nb-item"><span class="pp pp-done">▲</span> "Valletta" — Lackland&#39;s back room <button class="nb-deploy-btn" onclick="window.deployPwd(\'lackland\')">Deploy</button></div>')](else:)[(set: _nb to _nb + '<div class="nb-item"><span class="pp pp-done">▲</span> "Valletta" — Lackland&#39;s back room</div>')]](else:)[(set: _nb to _nb + '<div class="nb-grey"><span class="pp">△</span> A word for Lackland</div>')]\
(set: _nb to _nb + '</div>')\
(if: $knowsAboutPage is true)[(set: _nb to _nb + '<div class="nb-section"><strong class="nb-heading">QUESTS</strong>')\
(if: $returnedPage is true)[(set: _nb to _nb + '<div class="nb-grey"><span class="qp qp-done">★</span> Page 93 returned to O&#39;Flatterly</div>')]\
(else-if: $hasMissingPage is true)[(set: _nb to _nb + '<div class="nb-item"><span class="qp qp-done">★</span> Bring Page 93 back to Inis O&#39;Flatterly in Cecil Court</div>')]\
(else:)[(set: _nb to _nb + '<div class="nb-item"><span class="qp">☆</span> Find Page 93 for Inis O&#39;Flatterly. Leave Soho to look.</div>')]\
(set: _nb to _nb + '</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-panel nb-panel-lily">')\
(set: _nb to _nb + '<div class="nb-section nb-lily-section">')\
(set: _nb to _nb + '<svg class="nb-lily-row" viewBox="0 0 300 135" xmlns="http://www.w3.org/2000/svg"><path d="M 30,18 C 60,6 120,2 160,4 C 200,6 240,10 268,20" fill="none" stroke="#6d8f52" stroke-width="1.0" stroke-linecap="round" opacity="0.55"/><path d="M 30,18 C 27,30 22,52 20,78" fill="none" stroke="#6d8f52" stroke-width="0.8" stroke-linecap="round" opacity="0.35"/><path d="M 24,38 C 14,32 6,24 4,14 C 10,20 18,28 24,38 Z" fill="#7a9a5a" opacity="0.18" stroke="#6d8f52" stroke-width="0.3"/><path d="M 24,38 C 16,44 8,54 6,66 C 12,56 20,46 24,38 Z" fill="#7a9a5a" opacity="0.14" stroke="#6d8f52" stroke-width="0.3"/><path d="M 24,38 C 16,30 10,22 6,14" fill="none" stroke="#6d8f52" stroke-width="0.2" opacity="0.25"/><path d="M 24,38 C 16,46 10,56 6,66" fill="none" stroke="#6d8f52" stroke-width="0.2" opacity="0.20"/><polygon class="nb-pentagram-star" points="150,28 178.5,116.4 105.2,61.4 194.8,61.4 121.5,116.4" fill="none" stroke="#9a8a68" stroke-width="0.7" opacity="0"/>')\
(set: _nb to _nb + '<g class="nb-lily nb-lily-1 ' + _lo1 + '" transform="translate(32,18) rotate(-12) scale(0.821)">' + _bell + '</g>')\
(set: _nb to _nb + '<g class="nb-lily nb-lily-2 ' + _lo2 + '" transform="translate(90,9) rotate(-5) scale(0.893)">' + _bell + '</g>')\
(set: _nb to _nb + '<g class="nb-lily nb-lily-3 ' + _lo3 + '" transform="translate(150,5) rotate(1)">' + _bell + '</g>')\
(set: _nb to _nb + '<g class="nb-lily nb-lily-4 ' + _lo4 + '" transform="translate(210,9) rotate(5) scale(0.857)">' + _bell + '</g>')\
(set: _nb to _nb + '<g class="nb-lily nb-lily-5 ' + _lo5 + '" transform="translate(268,20) rotate(10) scale(0.714)">' + _bell + '</g>')\
(set: _nb to _nb + '</svg><div class="nb-lily-label">The bells of the lily-of-the-valley</div></div>')\
(if: $lilyCallCount > 0)[(set: _nb to _nb + '<div class="nb-section nb-calls-section"><strong class="nb-heading">CALLS</strong>')\
(if: $hadLilyCall1 is true)[(set: _nb to _nb + '<div class="nb-item nb-call-lily">☎ Lily</div>')]\
(if: $hadDualRing is true)[(set: _nb to _nb + '<div class="nb-item nb-call-aoife">☎ Aoife</div><div class="nb-item nb-call-lily">☎ Lily</div>')]\
(set: _nb to _nb + '</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-panel nb-panel-alba">')\
(set: _nb to _nb + '<div class="nb-section nb-alba-section"><strong class="nb-heading nb-alba-heading">ALBA</strong>')\
(if: $alba contains $alba1)[(set: _nb to _nb + '<div class="nb-item nb-alba-line"><em>' + (text: $alba1) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(if: $alba contains $alba2)[(set: _nb to _nb + '<div class="nb-item nb-alba-line"><em>' + (text: $alba2) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(if: $alba contains $alba3)[(set: _nb to _nb + '<div class="nb-item nb-alba-line"><em>' + (text: $alba3) + '</em></div>')](else:)[(set: _nb to _nb + '<div class="nb-grey">○ · · ·</div>')]\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-alba-note">Three lines of a poem for the dawn, gathered in the night.</div>')\
(set: _nb to _nb + '<div class="nb-alba-kiss">Alas, I kiss you Jane</div>')\
(set: _nb to _nb + '</div>')\
(set: _nb to _nb + '<div class="nb-panel nb-panel-inventory">')\
(set: _nb to _nb + '<div class="nb-section nb-inv-section"><strong class="nb-heading nb-inv-heading">EFFECTS</strong>')\
(if: $hasCoin is true)[(set: _nb to _nb + '<div class="nb-inv-item"><div class="nb-inv-name nb-item">◈ A &#39;Donkey&#39; Coin</div><div class="nb-coin-display"><img src="__DSS_COIN_HEADS_DATA_URI__" alt="The Donkey" class="nb-coin-img"/></div><div class="nb-inv-btn" onclick="window.flipCoinPopup()">Toss it</div></div>')](else:)[(set: _nb to _nb + '<div class="nb-inv-item nb-inv-locked"><div class="nb-grey">○ A &#39;Donkey&#39; coin</div></div>')]\
(set: _nb to _nb + '<div class="nb-inv-divider"></div>')\
(if: $hasLiver is true)[(set: _nb to _nb + '<div class="nb-inv-item"><div class="nb-inv-name nb-item">◈ Shelley&#39;s Liver</div><div class="nb-inv-vial-wrap"><svg class="nb-inv-vial" viewBox="0 0 80 160" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="vialGlass" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="rgba(180,160,130,0.18)"/><stop offset="30%" stop-color="rgba(220,210,190,0.32)"/><stop offset="70%" stop-color="rgba(200,185,155,0.15)"/><stop offset="100%" stop-color="rgba(150,135,110,0.22)"/></linearGradient><linearGradient id="vialLiq" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(140,60,20,0.75)"/><stop offset="100%" stop-color="rgba(90,28,8,0.88)"/></linearGradient></defs><rect x="26" y="10" width="28" height="10" rx="3" fill="rgba(160,140,110,0.4)" stroke="rgba(130,110,80,0.6)" stroke-width="1.2"/><rect x="29" y="8" width="22" height="5" rx="2" fill="rgba(200,180,150,0.5)" stroke="rgba(150,130,100,0.5)" stroke-width="1"/><path d="M24 20 L18 45 L18 140 Q18 148 25 150 L55 150 Q62 148 62 140 L62 45 L56 20 Z" fill="url(#vialGlass)" stroke="rgba(160,140,110,0.55)" stroke-width="1.5"/><path d="M20 90 L20 140 Q20 147 26 149 L54 149 Q60 147 60 140 L60 90 Z" fill="url(#vialLiq)" opacity="0.82"/><ellipse cx="40" cy="90" rx="20" ry="4" fill="rgba(160,70,25,0.35)"/><path d="M26 48 Q27 120 27 140" fill="none" stroke="rgba(230,220,200,0.28)" stroke-width="2.5" stroke-linecap="round"/><path d="M32 45 Q33 80 33 100" fill="none" stroke="rgba(230,220,200,0.15)" stroke-width="1.2" stroke-linecap="round"/></svg></div><div class="nb-inv-btn nb-inv-eat">(link: "Eat it")[(set: $liverReturnTo to (passage:)\'s name)(go-to: "Eat Shelleys Liver")]</div></div>')](else:)[(set: _nb to _nb + '<div class="nb-inv-item nb-inv-locked"><div class="nb-grey">○ Shelley&#39;s liver</div></div>')]\
(set: _nb to _nb + '<div class="nb-inv-divider"></div>')\
(if: $hasDrawing is true)[(set: _nb to _nb + '<div class="nb-inv-item"><div class="nb-inv-name nb-item">◈ A Napkin Portrait</div><div class="nb-napkin-display"><img class="nb-napkin-img" alt="The painter, sketched on a napkin"/></div><div class="nb-napkin-caption">Sketched at The French.</div><div class="nb-inv-btn" onclick="if(window.showNapkinPopup)window.showNapkinPopup();">Work on it</div></div>')](else:)[(set: _nb to _nb + '<div class="nb-inv-item nb-inv-locked"><div class="nb-grey">○ A napkin portrait</div></div>')]\
