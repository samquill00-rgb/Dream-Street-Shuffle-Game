    0.5, 11.15, 0.15);

  // ---- EXTRACTOR VENT (chippy essential!) ----
  placeMesh(shop, new THREE.BoxGeometry(0.5, 0.35, 0.2),
    new THREE.MeshStandardMaterial({ color: 0x4a4a48, roughness: 0.5, metalness: 0.2 }),
    2.8, 4.85, 0.3);
  // Vent grille lines
  for (var vli = -0.12; vli <= 0.12; vli += 0.06) {
    placeMesh(shop, new THREE.BoxGeometry(0.45, 0.015, 0.02), chromeMat, 2.8, 4.85 + vli, 0.42);
  }

  // ---- HANGING SIGN (projecting from bracket) ----
  var hangSignTex = makeCanvasTexture(96, 128, function(cx, w, h) {
    // Red background
    cx.fillStyle = '#8a1818'; cx.fillRect(4, 4, w - 8, h - 8);
    cx.strokeStyle = '#c8a840'; cx.lineWidth = 3;
    cx.strokeRect(6, 6, w - 12, h - 12);
    // Gold text
    cx.fillStyle = '#d8b840'; cx.font = 'bold 14px Georgia'; cx.textAlign = 'center';
    cx.fillText('FISH', w / 2, 35);
    cx.fillText('&', w / 2, 55);
    cx.fillText('CHIPS', w / 2, 75);
    // Small fish icon
    cx.strokeStyle = '#c8a840'; cx.lineWidth = 1.5;
    cx.beginPath();
    cx.moveTo(25, 100); cx.quadraticCurveTo(48, 88, 65, 100);
    cx.quadraticCurveTo(48, 112, 25, 100); cx.stroke();
    cx.beginPath(); cx.moveTo(65, 100); cx.lineTo(75, 92); cx.lineTo(75, 108); cx.closePath(); cx.stroke();
  });
  var hangSign = new THREE.Mesh(new THREE.PlaneGeometry(0.55, 0.7),
    new THREE.MeshStandardMaterial({ map: hangSignTex, roughness: 0.5, side: THREE.DoubleSide }));
  hangSign.position.set(-2.8, 4.0, 1.3);
  shop.add(hangSign);
  // Bracket arm
  placeMesh(shop, new THREE.BoxGeometry(1.0, 0.04, 0.04), ironMat, -2.6, 4.4, 0.7);
  placeMesh(shop, new THREE.BoxGeometry(0.03, 0.45, 0.03), ironMat, -2.8, 4.2, 1.3);
  // Scroll detail
  placeMesh(shop, new THREE.BoxGeometry(0.35, 0.03, 0.03), ironMat, -2.45, 4.3, 0.5);

  // ---- WINDOW SHELF DETAIL (inside, visible through glass) ----
  // Sauce bottles on counter
  for (var sbi = -0.5; sbi <= 1.5; sbi += 0.35) {
    placeMesh(shop, new THREE.CylinderGeometry(0.025, 0.02, 0.15, 5),
      new THREE.MeshStandardMaterial({ color: 0x6a2a2a, roughness: 0.4 }),
