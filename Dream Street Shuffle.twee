      });
      // Metallic clapper-tap noise transient
      var nLen = Math.floor(ac.sampleRate * 0.003);
      var nbuf = ac.createBuffer(1, nLen, ac.sampleRate);
      var nd = nbuf.getChannelData(0);
      for (var k = 0; k < nLen; k++) nd[k] = (Math.random()*2-1) * Math.exp(-k/nLen * 8);
      var nsrc = ac.createBufferSource(); nsrc.buffer = nbuf;
      var nf = ac.createBiquadFilter(); nf.type='highpass';
