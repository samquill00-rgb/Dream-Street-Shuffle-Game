  // String courses
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.08), whiteTrim, -5, 5.5, 0.08);
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.08), whiteTrim, -5, 8.0, 0.08);
  // Cornice
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.6, 0.14, 0.25),
    new THREE.MeshStandardMaterial({ color: 0xb8a888, roughness: 0.75 }), -5, 12.05, 0.12);
  // Drainpipe
  placeMesh(leftBuilding, new THREE.CylinderGeometry(0.03, 0.03, 12, 6), pipeMat, -2.85, 6, 0.15);
  scene.add(leftBuilding);

  var farLeft = new THREE.Mesh(new THREE.BoxGeometry(5, 13, 6),
    new THREE.MeshStandardMaterial({ color: 0xb0a080, roughness: 0.9 }));
  farLeft.position.set(-9.5, 6.5, -3);
  scene.add(farLeft);

  // --- RIGHT: Darker building ---
  var rightBuilding = new THREE.Group();
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.5, 13, 6),
    new THREE.MeshStandardMaterial({ color: 0x8a6858, roughness: 0.85 }), 5.5, 6.5, -3);
  // Dark red shop front
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.5, 3.5, 0.25),
    new THREE.MeshStandardMaterial({ color: 0x6a1a1a, roughness: 0.7 }), 5.5, 1.75, 0.35);
  // Red awning
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.0, 0.06, 0.6), redPaint, 5.5, 3.5, 0.6);
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.0, 0.2, 0.04), redPaint, 5.5, 3.38, 0.88);
  // Window glow (dimmer — contrast with chippy brightness)
  placeMesh(rightBuilding, new THREE.PlaneGeometry(3.5, 2.2),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.1 }), 5.5, 1.5, 0.5);
  // Upper windows
  for (var row = 0; row < 3; row++) {
    for (var col = 0; col < 2; col++) {
      var rwx = 4.5 + col * 1.6;
      var rwy = 5.5 + row * 2.8;
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.7, 1.2, 0.06), windowFrame, rwx, rwy, 0.04);
      placeMesh(rightBuilding, new THREE.PlaneGeometry(0.6, 1.1),
        new THREE.MeshBasicMaterial({ color: 0x334466, transparent: true, opacity: 0.1 }), rwx, rwy, 0.08);
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.8, 0.05, 0.1), sillMat, rwx, rwy - 0.62, 0.08);
    }
  }
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.55, 0.12, 0.2),
    new THREE.MeshStandardMaterial({ color: 0x7a5848, roughness: 0.8 }), 5.5, 13.0, 0.1);
  placeMesh(rightBuilding, new THREE.CylinderGeometry(0.03, 0.03, 13, 6), pipeMat, 7.7, 6.5, 0.12);
  scene.add(rightBuilding);

  var farRight = new THREE.Mesh(new THREE.BoxGeometry(5, 12, 6),
    new THREE.MeshStandardMaterial({ color: 0x7a5840, roughness: 0.9 }));
  farRight.position.set(10, 6, -3);
  scene.add(farRight);

