    cx.fillText('SPECIAL', w / 2, 25);
    cx.font = '11px Arial';
    cx.fillText('Cod & Chips', w / 2, 50);
    cx.fillText('+ Tea', w / 2, 68);
    cx.fillStyle = '#ff6060'; cx.font = 'bold 16px Arial';
    cx.fillText('40p', w / 2, 95);
    cx.fillStyle = '#e0d080'; cx.font = '9px Arial';
    cx.fillText('Open til 2am', w / 2, 118);
  });
  var aBoardFace = new THREE.Mesh(new THREE.PlaneGeometry(0.35, 0.48),
    new THREE.MeshBasicMaterial({ map: aBoardTex }));
  aBoardFace.position.set(2.8, 0.38, 1.5);
  shop.add(aBoardFace);

  // ---- LITTER (newspaper on pavement — period detail) ----
  var litterMat = new THREE.MeshStandardMaterial({ color: 0xd0c8a0, roughness: 0.8 });
  var litter1 = new THREE.Mesh(new THREE.PlaneGeometry(0.2, 0.15), litterMat);
  litter1.rotation.x = -Math.PI / 2; litter1.rotation.z = 0.3;
  litter1.position.set(1.5, 0.02, 2.5);
  shop.add(litter1);
  var litter2 = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 0.1),
    new THREE.MeshStandardMaterial({ color: 0xd8d0b0, roughness: 0.8 }));
  litter2.rotation.x = -Math.PI / 2; litter2.rotation.z = -0.5;
  litter2.position.set(-1.2, 0.02, 2.8);
  shop.add(litter2);

  // ---- STEAM / WARM AIR rising from vent ----
  // (Animated later — sprite-based warm mist)

  scene.add(shop);

  // ============================================================
  // NEIGHBOURING BUILDINGS
  // ============================================================

  // ===========================================================
  // --- LEFT: Anonymous orange-painted shopfront with full
  //     brick + grime detail. Same material vocabulary as the
  //     chippy itself.
  // ===========================================================
  // Cream-brown brick variant for left building
  var leftBrickTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#9a8068'; cx.fillRect(0, 0, w, h);
    var bH = 14, bW = 32;
    for (var by = 0; by < h; by += bH) {
      var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var bx = -bW; bx < w + bW; bx += bW) {
        var px = bx + rowOff;
        var r = 145 + Math.floor(Math.random() * 45);
        var g = 115 + Math.floor(Math.random() * 35);
        var b = 88 + Math.floor(Math.random() * 30);
        if (Math.random() > 0.95) { r -= 35; g -= 30; b -= 22; }
        cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
      }
    }
    cx.fillStyle = 'rgba(180, 160, 130, 0.32)';
    for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
    for (var ss = 0; ss < 4; ss++) {
      var sx = Math.random() * w; var sxw = 14 + Math.random() * 28;
      var sg = cx.createLinearGradient(sx, 0, sx, h);
      sg.addColorStop(0, 'rgba(15, 12, 8, 0.5)');
      sg.addColorStop(0.4, 'rgba(20, 15, 10, 0.22)');
      sg.addColorStop(1, 'rgba(25, 20, 12, 0)');
      cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
    }
    // Damp patches
    for (var d = 0; d < 4; d++) {
      var dx = Math.random() * w, dy = h * 0.5 + Math.random() * h * 0.5;
      var dr = 35 + Math.random() * 45;
      var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
      dg2.addColorStop(0, 'rgba(60, 70, 55, 0.28)');
      dg2.addColorStop(1, 'rgba(50, 60, 45, 0)');
      cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
    }
    // Lichen
    for (var lp = 0; lp < 10; lp++) {
      cx.fillStyle = 'rgba(100, 110, 65, ' + (0.10 + Math.random() * 0.18).toFixed(3) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h, 5 + Math.random() * 10, 3 + Math.random() * 6, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Heavy top soot
    var topG = cx.createLinearGradient(0, 0, 0, h * 0.45);
    topG.addColorStop(0, 'rgba(18, 12, 8, 0.4)');
    topG.addColorStop(1, 'rgba(18, 12, 8, 0)');
    cx.fillStyle = topG; cx.fillRect(0, 0, w, h * 0.45);
  });
  leftBrickTex.wrapS = leftBrickTex.wrapT = THREE.RepeatWrapping;
  leftBrickTex.repeat.set(1.5, 3);
  var leftBrickMat = new THREE.MeshStandardMaterial({ map: leftBrickTex, roughness: 0.92 });

  var leftBuilding = new THREE.Group();
  // Building body — textured brick
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.5, 12, 6), leftBrickMat, -5, 6, -3);
  // Facade panel (slightly darker tone)
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.51, 12, 0.05), leftBrickMat, -5, 6, 0.02);

  // Shop front — warm orange painted
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.5, 3.5, 0.25),
    new THREE.MeshStandardMaterial({ color: 0xd88020, roughness: 0.6 }), -5, 1.75, 0.35);
  // Stallriser (dark wood band at bottom of shopfront)
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.5, 0.5, 0.28),
    new THREE.MeshStandardMaterial({ color: 0x2a1a10, roughness: 0.8 }), -5, 0.25, 0.36);
  // Left shop fascia — K. WEST Manufacturers + MKUltra subline.
  // Narrow plaque-style sign, two stacked lines, hand-painted period
  // industrial typography on weathered orange ground.
  var leftFascTex = makeCanvasTexture(640, 360, function(cx, w, h) {
    cx.fillStyle = '#b86818'; cx.fillRect(0, 0, w, h);
    var washGrad = cx.createLinearGradient(0, 0, 0, h);
    washGrad.addColorStop(0, 'rgba(40,28,10,0.32)');
    washGrad.addColorStop(0.5, 'rgba(40,28,10,0)');
    washGrad.addColorStop(1, 'rgba(40,28,10,0.24)');
    cx.fillStyle = washGrad; cx.fillRect(0, 0, w, h);
    // Gold inner border
    cx.strokeStyle = 'rgba(220, 200, 140, 0.85)';
    cx.lineWidth = 3; cx.strokeRect(10, 10, w - 20, h - 20);
    cx.strokeStyle = 'rgba(60, 40, 14, 0.8)';
    cx.lineWidth = 1; cx.strokeRect(16, 16, w - 32, h - 32);
    // Line 1: K. WEST (very large)
    cx.fillStyle = '#f4e8c8';
    cx.shadowColor = 'rgba(20,10,4,0.7)'; cx.shadowBlur = 4; cx.shadowOffsetY = 2;
    cx.font = 'bold 96px "Playfair Display", "Times New Roman", Georgia, serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('K. WEST', w / 2, h * 0.27);
    // Line 2: MANUFACTURERS (medium)
    cx.font = 'bold 46px "Playfair Display", "Times New Roman", Georgia, serif';
    cx.fillText('MANUFACTURERS', w / 2, h * 0.55);
    cx.shadowBlur = 0; cx.shadowOffsetY = 0;
    // Hairline rule
    cx.strokeStyle = 'rgba(220, 200, 140, 0.45)'; cx.lineWidth = 1.2;
    cx.beginPath();
    cx.moveTo(w * 0.22, h * 0.74); cx.lineTo(w * 0.78, h * 0.74); cx.stroke();
    // Line 3: subline italic
    cx.fillStyle = '#f0e0b8';
    cx.font = 'italic 30px "Crimson Text", "Times New Roman", Georgia, serif';
    cx.fillText('Part of MKUltra Ltd.', w / 2, h * 0.86);
    // Weathering — peeling paint
    cx.fillStyle = 'rgba(70, 42, 14, 0.42)';
    for (var pp = 0; pp < 16; pp++) {
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h, 4 + Math.random() * 12, 2 + Math.random() * 4, 0, 0, Math.PI * 2);
      cx.fill();
    }
    // Soot streak right edge
    cx.fillStyle = 'rgba(10, 6, 4, 0.32)';
    cx.fillRect(w * 0.93, 0, 18, h);
    // Bird splat top-left
    cx.fillStyle = 'rgba(245, 240, 215, 0.45)';
    cx.beginPath();
    cx.ellipse(w * 0.10, h * 0.10, 6, 3, 0.3, 0, Math.PI * 2);
    cx.fill();
  });
  // Subtle bracket/mount (thin dark batten behind the sign) — set
  // back at z=0.42 so it sits cleanly behind the sign plane.
  placeMesh(leftBuilding, new THREE.BoxGeometry(2.55, 1.42, 0.04),
    new THREE.MeshStandardMaterial({ color: 0x2a1a10, roughness: 0.85 }),
    -5, 4.20, 0.42);
  // Sign mesh — pushed forward to z=0.50 (well in front of the
  // batten at z=0.42–0.44). MeshBasicMaterial (unlit, fully opaque,
  // no `transparent` flag — the texture has no alpha).
  placeMesh(leftBuilding, new THREE.PlaneGeometry(2.4, 1.30),
    new THREE.MeshBasicMaterial({ map: leftFascTex }), -5, 4.20, 0.50);
  // Shop windows (two panes, slightly dim warm interior)
  placeMesh(leftBuilding, new THREE.PlaneGeometry(1.6, 2.2),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.18 }), -4.3, 1.5, 0.5);
  placeMesh(leftBuilding, new THREE.PlaneGeometry(1.6, 2.2),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.15 }), -5.7, 1.5, 0.5);
  // Window dividers / mullions
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.05, 2.2, 0.04),
    new THREE.MeshStandardMaterial({ color: 0xc07018, roughness: 0.6 }), -5.0, 1.5, 0.52);
  // Horizontal transom
  placeMesh(leftBuilding, new THREE.BoxGeometry(3.4, 0.06, 0.05),
    new THREE.MeshStandardMaterial({ color: 0xc07018, roughness: 0.6 }), -5.0, 2.2, 0.52);
  // Door
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.7, 2.3, 0.06),
    new THREE.MeshStandardMaterial({ color: 0x6a3a18, roughness: 0.7 }), -5.0, 1.15, 0.48);
  // Door panels (decorative)
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.5, 0.4, 0.02),
    new THREE.MeshStandardMaterial({ color: 0x5a2a10, roughness: 0.75 }), -5.0, 1.75, 0.51);
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.5, 0.4, 0.02),
    new THREE.MeshStandardMaterial({ color: 0x5a2a10, roughness: 0.75 }), -5.0, 1.15, 0.51);
  // Brass door handle
  placeMesh(leftBuilding, new THREE.SphereGeometry(0.04, 8, 6), goldTrim, -4.75, 1.15, 0.52);

  // ---- Decorative pilasters flanking the shopfront ----
  var pilasterMat = new THREE.MeshStandardMaterial({ color: 0x3a2010, roughness: 0.7 });
  // Left pilaster
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.18, 3.6, 0.20), pilasterMat, -7.15, 1.8, 0.42);
  // pilaster cap (corbel)
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.26, 0.10, 0.24),
    new THREE.MeshStandardMaterial({ color: 0xc8a060, roughness: 0.4, metalness: 0.3 }),
    -7.15, 3.55, 0.43);
  // pilaster base block
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.26, 0.18, 0.24), pilasterMat, -7.15, 0.10, 0.43);
  // Right pilaster
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.18, 3.6, 0.20), pilasterMat, -2.85, 1.8, 0.42);
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.26, 0.10, 0.24),
    new THREE.MeshStandardMaterial({ color: 0xc8a060, roughness: 0.4, metalness: 0.3 }),
    -2.85, 3.55, 0.43);
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.26, 0.18, 0.24), pilasterMat, -2.85, 0.10, 0.43);

  // ---- Iron security grilles (vertical bars) over both windows ----
  var grilleMat = new THREE.MeshStandardMaterial({ color: 0x0e0e0e, roughness: 0.5, metalness: 0.5 });
  // Left window grille — 8 vertical bars
  for (var gb = 0; gb < 8; gb++) {
    var gbx = -5.05 + (gb - 3.5) * 0.18;
    placeMesh(leftBuilding, new THREE.BoxGeometry(0.025, 2.0, 0.025), grilleMat, gbx, 1.4, 0.54);
  }
  // grille top/bottom rails (left window)
  placeMesh(leftBuilding, new THREE.BoxGeometry(1.5, 0.04, 0.04), grilleMat, -5.05, 2.35, 0.54);
  placeMesh(leftBuilding, new THREE.BoxGeometry(1.5, 0.04, 0.04), grilleMat, -5.05, 0.45, 0.54);
  // Right window grille — 8 vertical bars
  for (var gb2 = 0; gb2 < 8; gb2++) {
    var gb2x = -3.45 + (gb2 - 3.5) * 0.18;
    placeMesh(leftBuilding, new THREE.BoxGeometry(0.025, 2.0, 0.025), grilleMat, gb2x, 1.4, 0.54);
  }
  placeMesh(leftBuilding, new THREE.BoxGeometry(1.5, 0.04, 0.04), grilleMat, -3.45, 2.35, 0.54);
  placeMesh(leftBuilding, new THREE.BoxGeometry(1.5, 0.04, 0.04), grilleMat, -3.45, 0.45, 0.54);

  // ---- Behind-glass display: stacked fabric / textile bolts ----
  // (dim warm interior — we suggest contents through colour blocks)
  var boltColors = [0x6a3018, 0x8a4828, 0x4a2010, 0x7a3a18, 0x5a2818];
  for (var bk = 0; bk < 6; bk++) {
    var bkx = -5.7 + bk * 0.22;
    var bky = 0.7 + (bk % 3) * 0.35;
    placeMesh(leftBuilding, new THREE.BoxGeometry(0.18, 0.30, 0.08),
      new THREE.MeshStandardMaterial({ color: boltColors[bk % boltColors.length], roughness: 0.85 }),
      bkx, bky, 0.46);
  }
  for (var bk2 = 0; bk2 < 6; bk2++) {
    var bk2x = -4.1 + bk2 * 0.22;
    var bk2y = 0.7 + (bk2 % 3) * 0.35;
    placeMesh(leftBuilding, new THREE.BoxGeometry(0.18, 0.30, 0.08),
      new THREE.MeshStandardMaterial({ color: boltColors[(bk2 + 2) % boltColors.length], roughness: 0.85 }),
      bk2x, bk2y, 0.46);
  }

  // ---- Hooded shop lamp above the door ----
  var hoodedLampMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.5 });
  // Bracket out from facade
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.04, 0.04, 0.32), hoodedLampMat, -5.0, 3.4, 0.66);
  // Hood (truncated cone — shade pointing down)
  var hoodGeo = new THREE.CylinderGeometry(0.18, 0.10, 0.16, 12);
  var hood = new THREE.Mesh(hoodGeo, hoodedLampMat);
  hood.position.set(-5.0, 3.30, 0.82);
  leftBuilding.add(hood);
  // Bulb visible underneath
  var bulb = new THREE.Mesh(new THREE.SphereGeometry(0.05, 8, 6),
    new THREE.MeshBasicMaterial({ color: 0xfff0c8, transparent: true, opacity: 0.95 }));
  bulb.position.set(-5.0, 3.18, 0.82);
  leftBuilding.add(bulb);
  // Light from hooded lamp (downward, warm)
  var hoodLight = new THREE.PointLight(0xffe5a0, 0.45, 4);
  hoodLight.position.set(-5.0, 3.0, 0.85);
  scene.add(hoodLight);

  // ---- "TRADE ONLY" enamel notice on left window glass ----
  var tradeTex = makeCanvasTexture(128, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.fillStyle = '#0e0a06'; cx.fillRect(0, 0, w, h);
    cx.strokeStyle = '#d4b048'; cx.lineWidth = 2; cx.strokeRect(3, 3, w - 6, h - 6);
    cx.fillStyle = '#f4e6c0';
    cx.font = 'bold 16px "Helvetica Neue", Arial, sans-serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('TRADE', w / 2, h * 0.36);
    cx.fillText('ONLY', w / 2, h * 0.68);
  });
  placeMesh(leftBuilding, new THREE.PlaneGeometry(0.30, 0.18),
    new THREE.MeshBasicMaterial({ map: tradeTex, transparent: true }),
    -5.5, 1.0, 0.55);

  // ---- Mail slot in door ----
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.30, 0.04, 0.02),
    new THREE.MeshStandardMaterial({ color: 0x4a3220, roughness: 0.6, metalness: 0.4 }),
    -5.0, 1.95, 0.52);
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.32, 0.06, 0.015),
    new THREE.MeshStandardMaterial({ color: 0xc8a060, roughness: 0.45, metalness: 0.35 }),
    -5.0, 1.95, 0.51);

  // ---- Door number plate ----
  var doorNumTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.fillStyle = '#1a0a06'; cx.fillRect(0, 0, w, h);
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 38px Georgia, serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('11', w / 2, h / 2);
  });
  placeMesh(leftBuilding, new THREE.PlaneGeometry(0.16, 0.16),
    new THREE.MeshBasicMaterial({ map: doorNumTex, transparent: true }),
    -5.0, 2.45, 0.515);

  // ---- Crate stacked outside (against pilaster) ----
  var crateMat = new THREE.MeshStandardMaterial({ color: 0x5a3a1c, roughness: 0.95 });
  var crate = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.4, 0.4), crateMat);
  crate.position.set(-3.20, 0.20, 0.80);
  leftBuilding.add(crate);
  // crate plank strapping
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.46, 0.05, 0.41),
    new THREE.MeshStandardMaterial({ color: 0x3a2410, roughness: 0.9 }),
    -3.20, 0.32, 0.80);
  placeMesh(leftBuilding, new THREE.BoxGeometry(0.46, 0.05, 0.41),
    new THREE.MeshStandardMaterial({ color: 0x3a2410, roughness: 0.9 }),
    -3.20, 0.08, 0.80);

  // Windows above (3 rows × 2 cols, with fuller detail)
  for (var lrow = 0; lrow < 3; lrow++) {
    for (var lcol = 0; lcol < 2; lcol++) {
      var lwx = -4.3 - lcol * 1.5;
      var lwy = 5.5 + lrow * 2.5;
      // Brick reveal
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.78, 1.3, 0.04),
        new THREE.MeshStandardMaterial({ color: 0x3a2418, roughness: 0.9 }), lwx, lwy, 0.03);
      // Frame outer
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.7, 1.2, 0.05), windowFrame, lwx, lwy, 0.05);
      // Frame inner
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.6, 1.12, 0.03), windowFrame, lwx, lwy, 0.07);
      // Lit/unlit logic — bottom-left and top-right are warm-lit
      var leftLit = (lrow === 0 && lcol === 0) || (lrow === 2 && lcol === 1);
      var leftCurtain = (lrow === 1 && lcol === 0);
      // Glass
      if (leftCurtain) {
        // Drawn curtain (faint warm leak around edges)
        placeMesh(leftBuilding, new THREE.PlaneGeometry(0.58, 1.08),
          new THREE.MeshBasicMaterial({ color: 0x4a2a18, transparent: true, opacity: 0.7 }), lwx, lwy, 0.08);
        placeMesh(leftBuilding, new THREE.PlaneGeometry(0.62, 1.12),
          new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.12 }), lwx, lwy, 0.078);
      } else {
        placeMesh(leftBuilding, new THREE.PlaneGeometry(0.58, 1.08),
          new THREE.MeshBasicMaterial({
            color: leftLit ? 0xffd699 : 0x2a3a55,
            transparent: true,
            opacity: leftLit ? 0.30 : 0.12
          }), lwx, lwy, 0.08);
      }
      // Vertical glazing bar (sash centre)
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.02, 1.10, 0.02), windowFrame, lwx, lwy, 0.09);
      // Horizontal sash bar at top half
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.6, 0.03, 0.03), windowFrame, lwx, lwy + 0.08, 0.09);
      // Sill — sits below the window (frame bottom at lwy-0.60)
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.85, 0.07, 0.15), sillMat, lwx, lwy - 0.68, 0.10);
      // Lintel
      placeMesh(leftBuilding, new THREE.BoxGeometry(0.85, 0.10, 0.05),
        new THREE.MeshStandardMaterial({ color: 0x8a5a48, roughness: 0.8 }), lwx, lwy + 0.68, 0.06);
    }
  }
  // String courses
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.08), whiteTrim, -5, 5.5, 0.08);
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.08), whiteTrim, -5, 8.0, 0.08);
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.52, 0.04, 0.10), whiteTrim, -5, 5.45, 0.10);

  // Cornice (multi-layer, heavier than before)
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.6, 0.14, 0.25),
    new THREE.MeshStandardMaterial({ color: 0xa89878, roughness: 0.78 }), -5, 12.05, 0.12);
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.65, 0.08, 0.32),
    new THREE.MeshStandardMaterial({ color: 0x988868, roughness: 0.8 }), -5, 12.15, 0.16);
  // Parapet
  placeMesh(leftBuilding, new THREE.BoxGeometry(4.5, 0.4, 0.18),
    new THREE.MeshStandardMaterial({ color: 0x7a6048, roughness: 0.85 }), -5, 12.32, 0.10);

  // Drainpipe + stained band running down beneath it
  placeMesh(leftBuilding, new THREE.CylinderGeometry(0.04, 0.04, 12, 8), pipeMat, -2.85, 6, 0.15);
  // pipe brackets
  for (var lpb = 1.5; lpb < 12; lpb += 3.5) {
    placeMesh(leftBuilding, new THREE.BoxGeometry(0.10, 0.04, 0.10), pipeMat, -2.85, lpb, 0.10);
  }
  // dark soot streak beneath the pipe
  placeMesh(leftBuilding, new THREE.PlaneGeometry(0.18, 11),
    new THREE.MeshBasicMaterial({ color: 0x0a0805, transparent: true, opacity: 0.32 }), -2.85, 6, 0.13);

  scene.add(leftBuilding);

  // Far-left background building — same brick family as the rest,
  // with a few lit windows + cornice so it doesn't sit blank in the
  // frame.
  var farLeftBrickTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#6e5444'; cx.fillRect(0, 0, w, h);
    var bH = 14, bW = 32;
    for (var by = 0; by < h; by += bH) {
      var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var bx = -bW; bx < w + bW; bx += bW) {
        var px = bx + rowOff;
        var r = 100 + Math.floor(Math.random() * 38);
        var g = 70 + Math.floor(Math.random() * 30);
        var b = 55 + Math.floor(Math.random() * 25);
        if (Math.random() > 0.94) { r -= 30; g -= 24; b -= 18; }
        cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
      }
    }
    cx.fillStyle = 'rgba(160, 130, 100, 0.28)';
    for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
    // Soot streaks
    for (var ss = 0; ss < 4; ss++) {
      var sx = Math.random() * w, sxw = 12 + Math.random() * 30;
      var sg = cx.createLinearGradient(sx, 0, sx, h);
      sg.addColorStop(0, 'rgba(10, 8, 5, 0.5)');
      sg.addColorStop(0.5, 'rgba(15, 12, 8, 0.22)');
      sg.addColorStop(1, 'rgba(22, 18, 10, 0)');
      cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
    }
    // Top soot wash
    var topG = cx.createLinearGradient(0, 0, 0, h * 0.4);
    topG.addColorStop(0, 'rgba(15, 10, 6, 0.42)');
    topG.addColorStop(1, 'rgba(15, 10, 6, 0)');
    cx.fillStyle = topG; cx.fillRect(0, 0, w, h * 0.4);
  });
  farLeftBrickTex.wrapS = farLeftBrickTex.wrapT = THREE.RepeatWrapping;
  farLeftBrickTex.repeat.set(1.8, 3.5);
  var farLeftMat = new THREE.MeshStandardMaterial({ map: farLeftBrickTex, roughness: 0.92 });

  var farLeftGroup = new THREE.Group();
  var farLeft = new THREE.Mesh(new THREE.BoxGeometry(5, 13, 6), farLeftMat);
  farLeft.position.set(-9.5, 6.5, -3);
  farLeftGroup.add(farLeft);

  // Sash windows scattered up the facade (closed Soho residential)
  var farLeftWindow = function(wx, wy, lit) {
    // brick reveal
    var rev = new THREE.Mesh(new THREE.BoxGeometry(0.78, 1.30, 0.04),
      new THREE.MeshStandardMaterial({ color: 0x2e1c12, roughness: 0.9 }));
    rev.position.set(wx, wy, 0.02);
    farLeftGroup.add(rev);
    // frame
    var fr = new THREE.Mesh(new THREE.BoxGeometry(0.66, 1.18, 0.04), windowFrame);
    fr.position.set(wx, wy, 0.04);
    farLeftGroup.add(fr);
    // glass
    var gl = new THREE.Mesh(new THREE.PlaneGeometry(0.58, 1.10),
      new THREE.MeshBasicMaterial({
        color: lit ? 0xffd699 : 0x2a3a55,
        transparent: true,
        opacity: lit ? 0.30 : 0.13
      }));
    gl.position.set(wx, wy, 0.06);
    farLeftGroup.add(gl);
    // sash bars
    var vbar = new THREE.Mesh(new THREE.BoxGeometry(0.02, 1.10, 0.02), windowFrame);
    vbar.position.set(wx, wy, 0.07); farLeftGroup.add(vbar);
    var hbar = new THREE.Mesh(new THREE.BoxGeometry(0.58, 0.03, 0.02), windowFrame);
    hbar.position.set(wx, wy + 0.08, 0.07); farLeftGroup.add(hbar);
    // sill
    var sill = new THREE.Mesh(new THREE.BoxGeometry(0.84, 0.06, 0.13), sillMat);
    sill.position.set(wx, wy - 0.68, 0.08); farLeftGroup.add(sill);
  };
  // 3 rows × 2 cols of windows; some lit
  var flLit = [[true, false], [false, true], [false, false]];
  for (var flr = 0; flr < 3; flr++) {
    for (var flc = 0; flc < 2; flc++) {
      farLeftWindow(-10.3 + flc * 1.6, 4 + flr * 2.8, flLit[flr][flc]);
    }
  }
  // Top cornice
  placeMesh(farLeftGroup, new THREE.BoxGeometry(5.15, 0.16, 0.25),
    new THREE.MeshStandardMaterial({ color: 0x6a4a30, roughness: 0.82 }), -9.5, 13.05, 0.12);
  placeMesh(farLeftGroup, new THREE.BoxGeometry(5.2, 0.08, 0.32),
    new THREE.MeshStandardMaterial({ color: 0x5a3a24, roughness: 0.84 }), -9.5, 13.15, 0.16);
  // Drainpipe + soot streak (between farLeft and K.West)
  placeMesh(farLeftGroup, new THREE.CylinderGeometry(0.04, 0.04, 13, 8), pipeMat, -7.10, 6.5, 0.13);
  placeMesh(farLeftGroup, new THREE.PlaneGeometry(0.18, 12),
    new THREE.MeshBasicMaterial({ color: 0x0a0805, transparent: true, opacity: 0.35 }), -7.10, 6.5, 0.115);
  // A small dark blank shopfront at street level (closed for the night)
  placeMesh(farLeftGroup, new THREE.BoxGeometry(4.6, 2.6, 0.20),
    new THREE.MeshStandardMaterial({ color: 0x1e1410, roughness: 0.75 }), -9.5, 1.3, 0.32);
  // shutter slats
  for (var ssl = 0; ssl < 13; ssl++) {
    placeMesh(farLeftGroup, new THREE.BoxGeometry(4.4, 0.16, 0.04),
      new THREE.MeshStandardMaterial({ color: 0x2a1a14, roughness: 0.8 }),
      -9.5, 0.25 + ssl * 0.19, 0.43);
  }
  // small fascia bar above shutters
  placeMesh(farLeftGroup, new THREE.BoxGeometry(4.6, 0.35, 0.10),
    new THREE.MeshStandardMaterial({ color: 0x3a2418, roughness: 0.85 }), -9.5, 2.75, 0.40);

  scene.add(farLeftGroup);

  // ===========================================================
  // --- RIGHT: 紅曉 (The Red Dawn) — Chinese shop, fully detailed.
  //     Black-lacquered ground floor with gold-lettered fascia,
  //     red paper lantern by the door, green-glazed tile dado,
  //     bilingual handpainted window text, residential rooms above.
  // ===========================================================
  // Dark Soho brick — same family as the chippy front
  var rightBrickTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#5e4034'; cx.fillRect(0, 0, w, h);
    var bH = 14, bW = 32;
    for (var by = 0; by < h; by += bH) {
      var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var bx = -bW; bx < w + bW; bx += bW) {
        var px = bx + rowOff;
        var r = 92 + Math.floor(Math.random() * 38);
        var g = 58 + Math.floor(Math.random() * 28);
        var b = 45 + Math.floor(Math.random() * 25);
        if (Math.random() > 0.94) { r -= 32; g -= 26; b -= 18; }
        cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
      }
    }
    cx.fillStyle = 'rgba(160, 130, 100, 0.28)';
    for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
    // Soot streaks
    for (var ss = 0; ss < 5; ss++) {
      var sx = Math.random() * w; var sxw = 12 + Math.random() * 30;
      var sg = cx.createLinearGradient(sx, 0, sx, h);
      sg.addColorStop(0, 'rgba(10, 8, 5, 0.55)');
      sg.addColorStop(0.3, 'rgba(15, 12, 8, 0.32)');
      sg.addColorStop(1, 'rgba(22, 18, 10, 0)');
      cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
    }
    // Damp + lichen
    for (var d = 0; d < 4; d++) {
      var dx = Math.random() * w, dy = h * 0.4 + Math.random() * h * 0.6;
      var dr = 28 + Math.random() * 45;
      var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
      dg2.addColorStop(0, 'rgba(60, 70, 55, 0.30)');
      dg2.addColorStop(1, 'rgba(50, 60, 45, 0)');
      cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
    }
    var topG = cx.createLinearGradient(0, 0, 0, h * 0.45);
    topG.addColorStop(0, 'rgba(15, 10, 6, 0.42)');
    topG.addColorStop(1, 'rgba(15, 10, 6, 0)');
    cx.fillStyle = topG; cx.fillRect(0, 0, w, h * 0.45);
  });
  rightBrickTex.wrapS = rightBrickTex.wrapT = THREE.RepeatWrapping;
  rightBrickTex.repeat.set(1.5, 3.3);
  var rightBrickMat = new THREE.MeshStandardMaterial({ map: rightBrickTex, roughness: 0.93 });

  var rightBuilding = new THREE.Group();
  // Body
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.5, 13, 6), rightBrickMat, 5.5, 6.5, -3);
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.51, 13, 0.05), rightBrickMat, 5.5, 6.5, 0.02);

  // ---- Ground floor: black-lacquered shopfront ----
  var lacquerMat = new THREE.MeshStandardMaterial({ color: 0x1a0a0a, roughness: 0.35, metalness: 0.25 });
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.5, 3.5, 0.25), lacquerMat, 5.5, 1.75, 0.35);

  // Green-glazed tile dado (band along the bottom — common on Chinese shops)
  var greenTileTex = makeCanvasTexture(256, 64, function(cx, w, h) {
    cx.fillStyle = '#2a4a3a'; cx.fillRect(0, 0, w, h);
    var tw = 24, th = h;
    for (var tx = 0; tx < w; tx += tw) {
      var g = 70 + Math.floor(Math.random() * 30);
      cx.fillStyle = 'rgb(' + Math.floor(g * 0.55) + ',' + g + ',' + Math.floor(g * 0.75) + ')';
      cx.fillRect(tx + 1, 1, tw - 2, th - 2);
      // gloss highlight
      cx.fillStyle = 'rgba(220, 240, 220, 0.18)';
      cx.fillRect(tx + 2, 2, tw - 4, 4);
    }
    // dark grout
    cx.fillStyle = 'rgba(8, 12, 8, 0.55)';
    for (var gx = 0; gx <= w; gx += tw) cx.fillRect(gx, 0, 1.4, h);
  });
  greenTileTex.wrapS = greenTileTex.wrapT = THREE.RepeatWrapping;
  greenTileTex.repeat.set(2, 1);
  placeMesh(rightBuilding, new THREE.PlaneGeometry(4.5, 0.55),
    new THREE.MeshStandardMaterial({ map: greenTileTex, roughness: 0.32, metalness: 0.18 }),
    5.5, 0.32, 0.49);

  // ---- Fascia: 紅曉 in gold Chinese characters on lacquer ----
  var redDawnFascTex = makeCanvasTexture(512, 80, function(cx, w, h) {
    // Black lacquer base with subtle sheen
    cx.fillStyle = '#0e0608'; cx.fillRect(0, 0, w, h);
    // Gold border lines (Chinese shop convention)
    cx.strokeStyle = '#b8902a'; cx.lineWidth = 2;
    cx.strokeRect(6, 6, w - 12, h - 12);
    cx.strokeStyle = '#d4b048'; cx.lineWidth = 1;
    cx.strokeRect(10, 10, w - 20, h - 20);
    // Gold characters 紅 曉
    cx.shadowColor = '#c8a040'; cx.shadowBlur = 6;
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 56px "PingFang TC", "Heiti TC", "Microsoft JhengHei", "Songti TC", serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('紅', w * 0.35, h / 2 + 2);
    cx.fillText('曉', w * 0.65, h / 2 + 2);
    cx.shadowBlur = 0;
    // tiny weathering chips
    cx.fillStyle = 'rgba(180, 140, 50, 0.10)';
    for (var wf = 0; wf < 6; wf++) {
      cx.beginPath();
      cx.ellipse(20 + Math.random() * (w - 40), 15 + Math.random() * (h - 30), 2, 1, 0, 0, Math.PI * 2);
      cx.fill();
    }
  });
  placeMesh(rightBuilding, new THREE.PlaneGeometry(4.2, 0.7),
    new THREE.MeshBasicMaterial({ map: redDawnFascTex }), 5.5, 3.85, 0.5);

  // ---- Two big windows flanking the door ----
  // Frames
  placeMesh(rightBuilding, new THREE.BoxGeometry(1.6, 2.4, 0.05),
    new THREE.MeshStandardMaterial({ color: 0x4a0808, roughness: 0.5, metalness: 0.2 }),
    4.4, 1.7, 0.49);
  placeMesh(rightBuilding, new THREE.BoxGeometry(1.6, 2.4, 0.05),
    new THREE.MeshStandardMaterial({ color: 0x4a0808, roughness: 0.5, metalness: 0.2 }),
    6.6, 1.7, 0.49);
  // Glass (warm dim red-tinted interior glow)
  placeMesh(rightBuilding, new THREE.PlaneGeometry(1.45, 2.25),
    new THREE.MeshBasicMaterial({ color: 0xb84028, transparent: true, opacity: 0.42 }),
    4.4, 1.7, 0.51);
  placeMesh(rightBuilding, new THREE.PlaneGeometry(1.45, 2.25),
    new THREE.MeshBasicMaterial({ color: 0xb84028, transparent: true, opacity: 0.42 }),
    6.6, 1.7, 0.51);
  // Window glazing bars (Chinese-style lattice — quartered)
  placeMesh(rightBuilding, new THREE.BoxGeometry(1.5, 0.03, 0.03),
    new THREE.MeshStandardMaterial({ color: 0x2a0a0a, roughness: 0.5 }), 4.4, 1.7, 0.52);
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.03, 2.3, 0.03),
    new THREE.MeshStandardMaterial({ color: 0x2a0a0a, roughness: 0.5 }), 4.4, 1.7, 0.52);
  placeMesh(rightBuilding, new THREE.BoxGeometry(1.5, 0.03, 0.03),
    new THREE.MeshStandardMaterial({ color: 0x2a0a0a, roughness: 0.5 }), 6.6, 1.7, 0.52);
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.03, 2.3, 0.03),
    new THREE.MeshStandardMaterial({ color: 0x2a0a0a, roughness: 0.5 }), 6.6, 1.7, 0.52);
  // Handpainted Chinese window characters (gold, smaller — single chars)
  var winChar1 = makeCanvasTexture(64, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.shadowColor = '#c8a040'; cx.shadowBlur = 4;
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 42px "PingFang TC", "Heiti TC", serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('茶', w / 2, h / 2);
    cx.shadowBlur = 0;
  });
  var winChar2 = makeCanvasTexture(64, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.shadowColor = '#c8a040'; cx.shadowBlur = 4;
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 42px "PingFang TC", "Heiti TC", serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('餅', w / 2, h / 2);
    cx.shadowBlur = 0;
  });
  placeMesh(rightBuilding, new THREE.PlaneGeometry(0.55, 0.55),
    new THREE.MeshBasicMaterial({ map: winChar1, transparent: true }),
    4.4, 2.5, 0.53);
  placeMesh(rightBuilding, new THREE.PlaneGeometry(0.55, 0.55),
    new THREE.MeshBasicMaterial({ map: winChar2, transparent: true }),
    6.6, 2.5, 0.53);

  // ---- Door (centre — dark lacquered with gold trim) ----
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.85, 2.6, 0.06),
    new THREE.MeshStandardMaterial({ color: 0x0a0405, roughness: 0.4, metalness: 0.2 }),
    5.5, 1.3, 0.48);
  // gold door rails
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.85, 0.04, 0.04), goldTrim, 5.5, 0.5, 0.51);
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.85, 0.04, 0.04), goldTrim, 5.5, 1.3, 0.51);
  placeMesh(rightBuilding, new THREE.BoxGeometry(0.85, 0.04, 0.04), goldTrim, 5.5, 2.1, 0.51);
  // upper door glass panel (red glow leaks through)
  placeMesh(rightBuilding, new THREE.PlaneGeometry(0.55, 0.45),
    new THREE.MeshBasicMaterial({ color: 0xc02818, transparent: true, opacity: 0.55 }),
    5.5, 1.95, 0.515);
  // brass handle
  placeMesh(rightBuilding, new THREE.SphereGeometry(0.045, 8, 6), goldTrim, 5.9, 1.3, 0.52);

  // ---- Red paper lantern hanging by the door ----
  var lanternGroup = new THREE.Group();
  // Lantern body (cylinder bulging in middle — approximated by 2 cones meeting)
  var lanternMat = new THREE.MeshStandardMaterial({
    color: 0x4a0606, roughness: 0.55, emissive: 0xc01010, emissiveIntensity: 0.55
  });
  var lBody = new THREE.Mesh(new THREE.SphereGeometry(0.22, 16, 12), lanternMat);
  lBody.scale.set(1, 0.85, 1);
  lanternGroup.add(lBody);
  // Caps (top + bottom black with gold accent)
  var lCapMat = new THREE.MeshStandardMaterial({ color: 0x1a0808, roughness: 0.5 });
  var lCapTop = new THREE.Mesh(new THREE.CylinderGeometry(0.10, 0.14, 0.05, 12), lCapMat);
  lCapTop.position.y = 0.20;
  lanternGroup.add(lCapTop);
  var lCapBot = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.10, 0.05, 12), lCapMat);
  lCapBot.position.y = -0.20;
  lanternGroup.add(lCapBot);
  // Hanging cord
  var cordMat = new THREE.MeshStandardMaterial({ color: 0x080404, roughness: 0.8 });
  var lCord = new THREE.Mesh(new THREE.CylinderGeometry(0.005, 0.005, 0.5, 6), cordMat);
  lCord.position.y = 0.47;
  lanternGroup.add(lCord);
  // Gold tassel
  var lTassel = new THREE.Mesh(new THREE.ConeGeometry(0.025, 0.10, 6),
    new THREE.MeshStandardMaterial({ color: 0xc8a030, roughness: 0.45, metalness: 0.35 }));
  lTassel.position.y = -0.30;
  lanternGroup.add(lTassel);
  // Gold tiny character on lantern (福)
  var lFuTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 36px "PingFang TC", "Heiti TC", serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('福', w / 2, h / 2);
  });
  var lFu = new THREE.Mesh(new THREE.PlaneGeometry(0.22, 0.22),
    new THREE.MeshBasicMaterial({ map: lFuTex, transparent: true }));
  lFu.position.z = 0.22;
  lanternGroup.add(lFu);
  // Position lantern outside, beside the door
  lanternGroup.position.set(6.15, 3.0, 0.85);
  rightBuilding.add(lanternGroup);
  // Point light from lantern
  var lanternLight = new THREE.PointLight(0xff4020, 0.55, 5);
  lanternLight.position.set(6.15, 3.0, 0.85);
  scene.add(lanternLight);

  // ---- Upper-floor windows: 3 rows × 2 cols, residential ----
  for (var rrow = 0; rrow < 3; rrow++) {
    for (var rcol = 0; rcol < 2; rcol++) {
      var rwx = 4.7 + rcol * 1.6;
      var rwy = 5.9 + rrow * 2.6;
      // Brick reveal
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.85, 1.35, 0.04),
        new THREE.MeshStandardMaterial({ color: 0x2a1810, roughness: 0.9 }), rwx, rwy, 0.03);
      // Frame
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.75, 1.25, 0.05), windowFrame, rwx, rwy, 0.05);
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.65, 1.15, 0.03), windowFrame, rwx, rwy, 0.07);
      // Curtained / lit logic
      var rRedTopRight = (rrow === 2 && rcol === 1);
      var rWarmLit = (rrow === 0 && rcol === 0);
      if (rRedTopRight) {
        // Red-curtained upper window — different kind of red than the brothel
        placeMesh(rightBuilding, new THREE.PlaneGeometry(0.62, 1.10),
          new THREE.MeshBasicMaterial({ color: 0x6a1818, transparent: true, opacity: 0.65 }), rwx, rwy, 0.08);
      } else if (rWarmLit) {
        placeMesh(rightBuilding, new THREE.PlaneGeometry(0.62, 1.10),
          new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.28 }), rwx, rwy, 0.08);
      } else {
        // dim curtain or unlit
        var curtainDraw = Math.random() > 0.5;
        placeMesh(rightBuilding, new THREE.PlaneGeometry(0.62, 1.10),
          new THREE.MeshBasicMaterial({
            color: curtainDraw ? 0x3a2818 : 0x2a3a55,
            transparent: true,
            opacity: curtainDraw ? 0.55 : 0.13
          }), rwx, rwy, 0.08);
      }
      // Glazing bars
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.02, 1.10, 0.02), windowFrame, rwx, rwy, 0.09);
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.65, 0.03, 0.02), windowFrame, rwx, rwy + 0.08, 0.09);
      // Sill (below window) + lintel (above)
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.92, 0.07, 0.15), sillMat, rwx, rwy - 0.72, 0.10);
      placeMesh(rightBuilding, new THREE.BoxGeometry(0.92, 0.10, 0.05),
        new THREE.MeshStandardMaterial({ color: 0x8a5a48, roughness: 0.8 }), rwx, rwy + 0.72, 0.06);
    }
  }

  // String courses
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.09), whiteTrim, 5.5, 5.5, 0.08);
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.52, 0.06, 0.09), whiteTrim, 5.5, 8.4, 0.08);

  // Cornice (multi-layer)
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.6, 0.14, 0.25),
    new THREE.MeshStandardMaterial({ color: 0x6a4838, roughness: 0.8 }), 5.5, 13.05, 0.12);
  placeMesh(rightBuilding, new THREE.BoxGeometry(4.65, 0.08, 0.32),
    new THREE.MeshStandardMaterial({ color: 0x5a3828, roughness: 0.82 }), 5.5, 13.15, 0.16);

  // Drainpipe with brackets + soot streak
  placeMesh(rightBuilding, new THREE.CylinderGeometry(0.04, 0.04, 13, 8), pipeMat, 7.7, 6.5, 0.13);
  for (var rpb = 1.5; rpb < 13; rpb += 3.5) {
    placeMesh(rightBuilding, new THREE.BoxGeometry(0.10, 0.04, 0.10), pipeMat, 7.7, rpb, 0.10);
  }
  placeMesh(rightBuilding, new THREE.PlaneGeometry(0.18, 12),
    new THREE.MeshBasicMaterial({ color: 0x0a0805, transparent: true, opacity: 0.35 }), 7.7, 6.5, 0.115);

  // Small "OPEN" placard hanging behind the door glass
  var rdOpenTex = makeCanvasTexture(64, 32, function(cx, w, h) {
    cx.fillStyle = '#1a0808'; cx.fillRect(0, 0, w, h);
    cx.fillStyle = '#d4b048';
    cx.font = 'bold 18px "PingFang TC", serif';
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText('營業中', w / 2, h / 2 + 1);
  });
  placeMesh(rightBuilding, new THREE.PlaneGeometry(0.5, 0.18),
    new THREE.MeshBasicMaterial({ map: rdOpenTex, transparent: true }),
    5.5, 1.85, 0.516);

  scene.add(rightBuilding);

  var farRight = new THREE.Mesh(new THREE.BoxGeometry(5, 12, 6),
    new THREE.MeshStandardMaterial({ color: 0x7a5840, roughness: 0.9 }));
  farRight.position.set(10, 6, -3);
  scene.add(farRight);

  // Opposite side
  var oppSide = new THREE.Mesh(new THREE.BoxGeometry(30, 12, 4),
    new THREE.MeshStandardMaterial({ color: 0x403830, roughness: 0.9 }));
  oppSide.position.set(0, 6, 22);
  scene.add(oppSide);
  // Dim windows opposite
  for (var owi = -8; owi < 10; owi += 3) {
    if (Math.random() > 0.5) {
      placeMesh(scene, new THREE.PlaneGeometry(0.7, 1.0),
        new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.06 }), owi, 4 + Math.random() * 4, 19.98);
    }
  }

  // ============================================================
  // PAVEMENTS & STREET DETAIL
  // ============================================================
  var kerbMat = new THREE.MeshStandardMaterial({ color: 0x666666, roughness: 0.8 });
  var paveMat2 = new THREE.MeshStandardMaterial({ color: 0x4a4a4a, roughness: 0.85 });

  var pubPave = new THREE.Mesh(new THREE.BoxGeometry(30, 0.15, 3), paveMat2);
  pubPave.position.set(0, 0.075, 2);
  pubPave.receiveShadow = true;
  scene.add(pubPave);
  var pubKerb = new THREE.Mesh(new THREE.BoxGeometry(30, 0.18, 0.12), kerbMat);
  pubKerb.position.set(0, 0.09, 3.5);
  scene.add(pubKerb);

  // Paving slab grid
  for (var psx = -8; psx < 12; psx += 0.8) {
    placeMesh(scene, new THREE.PlaneGeometry(0.015, 3),
      new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.9, transparent: true, opacity: 0.25 }),
      psx, 0.16, 2);
    scene.children[scene.children.length - 1].rotation.x = -Math.PI / 2;
  }

  var oppPave = new THREE.Mesh(new THREE.BoxGeometry(30, 0.15, 3), paveMat2);
  oppPave.position.set(0, 0.075, 11);
  scene.add(oppPave);
  var oppKerb = new THREE.Mesh(new THREE.BoxGeometry(30, 0.18, 0.12), kerbMat);
  oppKerb.position.set(0, 0.09, 9.5);
  scene.add(oppKerb);

  // Puddles (extra reflective near the chippy to pick up that bright glow)
  var puddleMat = new THREE.MeshStandardMaterial({
    color: 0x1a1a2a, roughness: 0.08, metalness: 0.7, transparent: true, opacity: 0.4
  });
  var puddlePos = [[0.5, 4.5, 2.5, 1.5], [-2, 6, 1.5, 0.8], [3, 7, 1.8, 1.0], [-1, 9, 2.0, 1.2], [2, 5.5, 1.0, 0.6]];
  for (var pi = 0; pi < puddlePos.length; pi++) {
    var pp = puddlePos[pi];
    var puddle = new THREE.Mesh(new THREE.PlaneGeometry(pp[2], pp[3]), puddleMat);
    puddle.rotation.x = -Math.PI / 2;
    puddle.position.set(pp[0], 0.02, pp[1]);
    scene.add(puddle);
  }

  // Drain grate
  var grateMat = new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.6, metalness: 0.3 });
  placeMesh(scene, new THREE.BoxGeometry(0.4, 0.02, 0.3), grateMat, -1, 0.08, 3.3);
  for (var gbi = -0.12; gbi <= 0.12; gbi += 0.06) {
    placeMesh(scene, new THREE.BoxGeometry(0.35, 0.025, 0.015), grateMat, -1, 0.09, 3.3 + gbi);
  }

  // Bollard
  placeMesh(scene, new THREE.CylinderGeometry(0.06, 0.08, 0.7, 8), ironMat, -2.2, 0.35, 3.2);
  placeMesh(scene, new THREE.SphereGeometry(0.07, 6, 6), ironMat, -2.2, 0.72, 3.2);

  // Dustbin — moved to the chippy side of the pavement (used to sit
  // outside the Red Dawn). Sits to the left of the chippy door, near
  // the chalkboard-side cluster of streetfurniture.
  placeMesh(scene, new THREE.CylinderGeometry(0.18, 0.16, 0.55, 8),
    new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.7 }), -1.8, 0.28, 1.6);
  placeMesh(scene, new THREE.CylinderGeometry(0.2, 0.2, 0.03, 8),
    new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.7 }), -1.8, 0.57, 1.6);

  // Bicycle leaning against wall (like Fryer's Delight)
  var bikeMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5, metalness: 0.3 });
  // Frame (simple triangular suggestion)
  placeMesh(scene, new THREE.BoxGeometry(0.8, 0.02, 0.02), bikeMat, -1.8, 0.55, 1.2);
  placeMesh(scene, new THREE.BoxGeometry(0.02, 0.45, 0.02), bikeMat, -2.15, 0.35, 1.2);
  placeMesh(scene, new THREE.BoxGeometry(0.02, 0.5, 0.02), bikeMat, -1.45, 0.38, 1.2);
  placeMesh(scene, new THREE.BoxGeometry(0.5, 0.02, 0.02), bikeMat, -1.8, 0.32, 1.2);
  // Wheels
  placeMesh(scene, new THREE.CylinderGeometry(0.25, 0.25, 0.02, 16),
    new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.4, metalness: 0.3 }),
    -2.15, 0.25, 1.2);
  scene.children[scene.children.length - 1].rotation.x = Math.PI / 2;
  placeMesh(scene, new THREE.CylinderGeometry(0.25, 0.25, 0.02, 16),
    new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.4, metalness: 0.3 }),
    -1.45, 0.25, 1.2);
  scene.children[scene.children.length - 1].rotation.x = Math.PI / 2;
  // Handlebars
  placeMesh(scene, new THREE.BoxGeometry(0.35, 0.02, 0.02), bikeMat, -2.15, 0.7, 1.2);

  // ============================================================
  // STREETLAMPS
  // ============================================================
  var streetLampLights = [];

  // Victorian cast-iron gas-lamp — stepped base, fluted shaft,
  // mid-band, ladder rest, capital, 4-sided glass lantern,
  // pyramidal cap, crown finial.
  function createLamp(x, z) {
    var g = new THREE.Group();
    var castIron = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.78, metalness: 0.22 });
    var darkIron = new THREE.MeshStandardMaterial({ color: 0x121212, roughness: 0.7, metalness: 0.3 });
    var brassish = new THREE.MeshStandardMaterial({ color: 0x6a4a1a, roughness: 0.6, metalness: 0.35 });

    // ---- Stepped base / plinth ----
    placeMesh(g, new THREE.CylinderGeometry(0.24, 0.28, 0.10, 16), castIron, 0, 0.05, 0);  // ground flange
    placeMesh(g, new THREE.CylinderGeometry(0.20, 0.24, 0.18, 16), castIron, 0, 0.19, 0);  // base drum
    placeMesh(g, new THREE.CylinderGeometry(0.17, 0.20, 0.05, 16), darkIron, 0, 0.31, 0);  // collar
    placeMesh(g, new THREE.BoxGeometry(0.32, 0.32, 0.32), castIron, 0, 0.50, 0);           // dado block
    placeMesh(g, new THREE.CylinderGeometry(0.11, 0.16, 0.06, 16), darkIron, 0, 0.69, 0);  // taper out of dado

    // ---- Fluted main shaft (subtle taper) ----
    placeMesh(g, new THREE.CylinderGeometry(0.058, 0.10, 3.9, 16), castIron, 0, 2.65, 0);

    // Mid-shaft decorative band
    placeMesh(g, new THREE.CylinderGeometry(0.082, 0.082, 0.06, 16), darkIron, 0, 1.55, 0);
    placeMesh(g, new THREE.CylinderGeometry(0.090, 0.090, 0.02, 16), darkIron, 0, 1.58, 0);
    placeMesh(g, new THREE.CylinderGeometry(0.090, 0.090, 0.02, 16), darkIron, 0, 1.52, 0);

    // ---- Ladder rest (horizontal cross-bar near top, for the lamplighter) ----
    placeMesh(g, new THREE.BoxGeometry(0.52, 0.018, 0.018), castIron, 0, 4.45, 0);
    placeMesh(g, new THREE.BoxGeometry(0.018, 0.018, 0.52), castIron, 0, 4.45, 0);
    // tiny finial blobs at the rod ends
    placeMesh(g, new THREE.SphereGeometry(0.024, 6, 4), castIron,  0.26, 4.45, 0);
    placeMesh(g, new THREE.SphereGeometry(0.024, 6, 4), castIron, -0.26, 4.45, 0);
    placeMesh(g, new THREE.SphereGeometry(0.024, 6, 4), castIron, 0, 4.45,  0.26);
    placeMesh(g, new THREE.SphereGeometry(0.024, 6, 4), castIron, 0, 4.45, -0.26);

    // ---- Capital ring (transition from shaft to lantern) ----
    placeMesh(g, new THREE.CylinderGeometry(0.085, 0.062, 0.08, 16), castIron, 0, 4.66, 0);
    placeMesh(g, new THREE.CylinderGeometry(0.105, 0.085, 0.04, 16), darkIron, 0, 4.72, 0);
    placeMesh(g, new THREE.CylinderGeometry(0.045, 0.045, 0.14, 12), castIron, 0, 4.81, 0);

    // ---- LANTERN: 4-sided glass box (4 brightly-lit emissive panes) ----
    // Base plate
    placeMesh(g, new THREE.BoxGeometry(0.34, 0.04, 0.34), darkIron, 0, 4.91, 0);
    // 4 emissive glow panes — one for each face of the lantern.
    // Solid unlit (MeshBasic) so they read as glowing windows, not
    // dark transparent glass.
    var paneMat = new THREE.MeshBasicMaterial({ color: 0xfff0c8 });
    var paneFront = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneFront.position.set(0, 5.16, 0.134);
    g.add(paneFront);
    var paneBack = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneBack.position.set(0, 5.16, -0.134);
    paneBack.rotation.y = Math.PI;
    g.add(paneBack);
    var paneLeft = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneLeft.position.set(-0.134, 5.16, 0);
    paneLeft.rotation.y = Math.PI / 2;
    g.add(paneLeft);
    var paneRight = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneRight.position.set(0.134, 5.16, 0);
    paneRight.rotation.y = -Math.PI / 2;
    g.add(paneRight);
    // 4 vertical corner posts
    var cornerXZ = [[0.135, 0.135], [-0.135, 0.135], [0.135, -0.135], [-0.135, -0.135]];
    for (var cp = 0; cp < 4; cp++) {
      placeMesh(g, new THREE.BoxGeometry(0.028, 0.44, 0.028), darkIron, cornerXZ[cp][0], 5.16, cornerXZ[cp][1]);
    }
    // Mid horizontal frame
    placeMesh(g, new THREE.BoxGeometry(0.28, 0.018, 0.018), darkIron, 0, 5.16,  0.135);
    placeMesh(g, new THREE.BoxGeometry(0.28, 0.018, 0.018), darkIron, 0, 5.16, -0.135);
    placeMesh(g, new THREE.BoxGeometry(0.018, 0.018, 0.28), darkIron,  0.135, 5.16, 0);
    placeMesh(g, new THREE.BoxGeometry(0.018, 0.018, 0.28), darkIron, -0.135, 5.16, 0);

    // ---- Top plate ----
    placeMesh(g, new THREE.BoxGeometry(0.36, 0.045, 0.36), darkIron, 0, 5.40, 0);

    // ---- Pyramidal cap ----
    var capMesh = new THREE.Mesh(new THREE.ConeGeometry(0.24, 0.20, 4), castIron);
    capMesh.position.set(0, 5.52, 0);
    capMesh.rotation.y = Math.PI / 4;
    g.add(capMesh);

    // ---- Crown finial: ball + spike + small ball ----
    placeMesh(g, new THREE.SphereGeometry(0.034, 8, 6), darkIron, 0, 5.66, 0);
    placeMesh(g, new THREE.CylinderGeometry(0.008, 0.008, 0.12, 8), darkIron, 0, 5.74, 0);
    placeMesh(g, new THREE.SphereGeometry(0.018, 6, 4), brassish,  0, 5.82, 0);

    // ---- Faint point light: just enough to feel real, doesn't
    //      flood the scene. The lantern panes carry the visible glow.
    var light = new THREE.PointLight(0xffd6a0, 0.5, 10);
    light.position.set(0, 5.16, 0);
    light.castShadow = true;
    g.add(light);
    streetLampLights.push(light);

    // ---- Tight halo sprite around the lantern itself ----
    var glowTex = makeCanvasTexture(128, 128, function(cx, w, h) {
      var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
      grad.addColorStop(0, 'rgba(255, 220, 150, 0.85)');
      grad.addColorStop(0.25, 'rgba(255, 200, 110, 0.40)');
      grad.addColorStop(0.6, 'rgba(220, 160, 70, 0.08)');
      grad.addColorStop(1, 'rgba(180, 120, 50, 0)');
      cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
    });
    var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.7 }));
    glowSprite.position.set(0, 5.16, 0);
    glowSprite.scale.set(2.2, 2.2, 1);
    g.add(glowSprite);

    // ---- Bright inner-core sprite (small, hot centre) ----
    var innerGlowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
      var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
      grad.addColorStop(0, 'rgba(255, 245, 200, 1)');
      grad.addColorStop(0.3, 'rgba(255, 220, 140, 0.55)');
      grad.addColorStop(1, 'rgba(255, 200, 110, 0)');
      cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
    });
    var innerGlow = new THREE.Sprite(new THREE.SpriteMaterial({ map: innerGlowTex, transparent: true, opacity: 0.9 }));
    innerGlow.position.set(0, 5.16, 0);
    innerGlow.scale.set(0.9, 0.9, 1);
    g.add(innerGlow);

    g.position.set(x, 0, z);
    scene.add(g);
  }

  createLamp(-4, 3.5);
  createLamp(5, 3.5);
  createLamp(1, 10);
  createLamp(-5, 10);

  // ============================================================
  // SILHOUETTES IN CHIPPY WINDOWS (people at counter)
  // ============================================================
  var silhouettes = [];

  function makeChippySilhouette(seed) {
    return makeCanvasTexture(256, 256, function(cx, w, h) {
      // Bright warm interior background
      var bg = cx.createRadialGradient(w / 2, h * 0.4, 10, w / 2, h * 0.5, w);
      bg.addColorStop(0, 'rgba(255, 220, 140, 0.5)');
      bg.addColorStop(0.4, 'rgba(240, 190, 100, 0.35)');
      bg.addColorStop(0.8, 'rgba(200, 150, 70, 0.15)');
      bg.addColorStop(1, 'rgba(150, 100, 40, 0.05)');
      cx.fillStyle = bg;
      cx.fillRect(0, 0, w, h);

      var figureCount = 1 + Math.floor(seed * 2);
      for (var f = 0; f < figureCount; f++) {
        var fx = (w / (figureCount + 1)) * (f + 1);
        var baseY = h * 0.98;
        var headR = 12 + seed * 5;
        var shoulderW = 30 + seed * 12;

        cx.fillStyle = 'rgba(10, 5, 0, 0.8)';
        // Body
        cx.beginPath();
        cx.moveTo(fx - shoulderW / 2, baseY - h * 0.3);
        cx.lineTo(fx + shoulderW / 2, baseY - h * 0.3);
        cx.lineTo(fx + shoulderW / 2 + 5, baseY);
        cx.lineTo(fx - shoulderW / 2 - 5, baseY);
        cx.closePath(); cx.fill();
        // Shoulders
        cx.beginPath();
        cx.ellipse(fx, baseY - h * 0.33, shoulderW / 2 + 3, 12, 0, 0, Math.PI, true);
        cx.fill();
        // Neck
        cx.fillRect(fx - 5, baseY - h * 0.42, 10, h * 0.09);
        // Head
        cx.beginPath();
        cx.arc(fx + (f - 1) * 3, baseY - h * 0.47, headR, 0, Math.PI * 2);
        cx.fill();

        // Person leaning on counter / eating
        if (f === 0 && seed > 0.3) {
          // Arm reaching forward (to counter)
          cx.fillStyle = 'rgba(10, 5, 0, 0.75)';
          cx.beginPath();
          cx.moveTo(fx - shoulderW / 2, baseY - h * 0.32);
          cx.lineTo(fx - shoulderW / 2 - 15, baseY - h * 0.2);
          cx.lineTo(fx - shoulderW / 2 - 10, baseY - h * 0.18);
          cx.lineTo(fx - shoulderW / 2 + 5, baseY - h * 0.3);
          cx.closePath(); cx.fill();
        }
      }

      // Counter silhouette at bottom (the serving counter seen through glass)
      cx.fillStyle = 'rgba(60, 40, 20, 0.4)';
      cx.fillRect(0, h * 0.75, w, h * 0.25);
    });
  }

  // Silhouettes in both large windows
  var chipWinXs = [-0.7, 1.7];
  var chipSeeds = [0.7, 0.5];
  for (var i = 0; i < chipWinXs.length; i++) {
    var sTex = makeChippySilhouette(chipSeeds[i]);
    var sMat = new THREE.MeshBasicMaterial({
      map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
    });
    var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(2.0, 2.3), sMat);
    sPlane.position.set(chipWinXs[i], 1.9, 0.32);
    shop.add(sPlane);
    silhouettes.push({
      mesh: sPlane, baseX: chipWinXs[i],
      swayPhase: Math.random() * Math.PI * 2,
      swaySpeed: 0.25 + Math.random() * 0.3,
      swayAmt: 0.01 + Math.random() * 0.015
    });
  }

  // ============================================================
  // STEAM SPRITES (from extractor vent — chippy steam!)
  // ============================================================
  var steamSprites = [];
  var steamTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
    grad.addColorStop(0, 'rgba(220, 210, 190, 0.25)');
    grad.addColorStop(0.4, 'rgba(200, 190, 170, 0.1)');
    grad.addColorStop(1, 'rgba(180, 170, 150, 0)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });
  for (var si = 0; si < 8; si++) {
    var steamMat = new THREE.SpriteMaterial({ map: steamTex, transparent: true, opacity: 0.15 + Math.random() * 0.1 });
    var steam = new THREE.Sprite(steamMat);
    steam.position.set(2.8 + (Math.random() - 0.5) * 0.5, 5.5 + Math.random() * 2, 0.5 + Math.random() * 0.5);
    var ss = 1.0 + Math.random() * 1.5;
    steam.scale.set(ss, ss * 1.2, 1);
    shop.add(steam);
    steamSprites.push({
      sprite: steam,
      baseY: steam.position.y,
      baseX: steam.position.x,
      rise: 0.003 + Math.random() * 0.005,
      drift: (Math.random() - 0.5) * 0.002,
      sway: Math.random() * Math.PI * 2,
      resetY: 5.0
    });
  }

  // ============================================================
  // LIGHTING
  // ============================================================
  scene.add(new THREE.AmbientLight(0x121218, 0.25));
  var moonLight = new THREE.DirectionalLight(0x4455aa, 0.08);
  moonLight.position.set(5, 20, 10);
  moonLight.castShadow = true;
  scene.add(moonLight);
  // Blue fill
  var fillLight = new THREE.DirectionalLight(0x2233aa, 0.04);
  fillLight.position.set(-5, 10, -5);
  scene.add(fillLight);

  // ============================================================
  // FOG VOLUMES (4 layers — the chippy glow cuts through the fog)
  // ============================================================
  var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
    grad.addColorStop(0, 'rgba(180, 170, 155, 0.22)');
    grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.1)');
    grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });
  var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
    grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
    grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
    grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });
  var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
    grad.addColorStop(0, 'rgba(255, 220, 140, 0.1)');
    grad.addColorStop(0.5, 'rgba(240, 190, 100, 0.04)');
    grad.addColorStop(1, 'rgba(200, 150, 60, 0)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });

  var fogSprites = [];

  // Layer 1: Ground-hugging
  for (var i = 0; i < 50; i++) {
    var fogMat = new THREE.SpriteMaterial({ map: thickFogTex, transparent: true, opacity: 0.16 + Math.random() * 0.16 });
    var fogSprite = new THREE.Sprite(fogMat);
    fogSprite.position.set(Math.random() * 40 - 15, 0.3 + Math.random() * 2, Math.random() * 30 - 5);
    var s = 5 + Math.random() * 12;
    fogSprite.scale.set(s, s * 0.35, 1);
    scene.add(fogSprite);
    fogSprites.push({ sprite: fogSprite, baseX: fogSprite.position.x, drift: 0.002 + Math.random() * 0.006, sway: Math.random() * Math.PI * 2, swaySpeed: 0.001 + Math.random() * 0.004, swayAmt: 0.4 + Math.random() * 1.0 });
  }

  // Layer 2: Mid-height
  for (var i = 0; i < 28; i++) {
    var midFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.1 + Math.random() * 0.1 });
    var midFog = new THREE.Sprite(midFogMat);
    midFog.position.set(Math.random() * 35 - 12, 2 + Math.random() * 6, Math.random() * 30 - 5);
    var ms = 6 + Math.random() * 14;
    midFog.scale.set(ms, ms * 0.3, 1);
    scene.add(midFog);
    fogSprites.push({ sprite: midFog, baseX: midFog.position.x, drift: 0.001 + Math.random() * 0.004, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0008 + Math.random() * 0.003, swayAmt: 0.5 + Math.random() * 1.5 });
  }

  // Layer 3: Warm fog near chippy (picks up the bright glow)
  for (var i = 0; i < 18; i++) {
    var warmFogMat = new THREE.SpriteMaterial({ map: warmFogTex, transparent: true, opacity: 0.1 + Math.random() * 0.12 });
    var warmFog = new THREE.Sprite(warmFogMat);
    warmFog.position.set(Math.random() * 10 - 3, 0.5 + Math.random() * 3, 1 + Math.random() * 6);
    var ws = 4 + Math.random() * 8;
    warmFog.scale.set(ws, ws * 0.3, 1);
    scene.add(warmFog);
    fogSprites.push({ sprite: warmFog, baseX: warmFog.position.x, drift: 0.001 + Math.random() * 0.003, sway: Math.random() * Math.PI * 2, swaySpeed: 0.001 + Math.random() * 0.003, swayAmt: 0.3 + Math.random() * 0.8 });
  }

  // Layer 4: High wisps
  for (var i = 0; i < 12; i++) {
    var highFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.06 + Math.random() * 0.07 });
    var highFog = new THREE.Sprite(highFogMat);
    highFog.position.set(Math.random() * 30 - 10, 8 + Math.random() * 8, Math.random() * 20 - 5);
    var hs = 10 + Math.random() * 15;
    highFog.scale.set(hs, hs * 0.2, 1);
    scene.add(highFog);
    fogSprites.push({ sprite: highFog, baseX: highFog.position.x, drift: 0.003 + Math.random() * 0.005, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0005 + Math.random() * 0.002, swayAmt: 1.0 + Math.random() * 2.0 });
  }

  // ============================================================
  // ANIMATION LOOP
  // ============================================================
  var clock = new THREE.Clock();
  var neonFlickerPhase = 0;

  function fcAnimate() {
    fcAnimId = requestAnimationFrame(fcAnimate);
    var t = clock.getElapsedTime();

    // Fog drift
    for (var i = 0; i < fogSprites.length; i++) {
      var f = fogSprites[i];
      f.sway += f.swaySpeed;
      f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
      f.baseX += f.drift;
      if (f.baseX > 25) f.baseX = -25;
    }

    // Fascia spotlight flicker (slight)
    for (var i = 0; i < fasciaLamps.length; i++) {
      var fl = fasciaLamps[i];
      fl.intensity = fl.userData.baseIntensity + Math.sin(t * 4 + i * 1.5) * 0.06;
    }

    // Street lamp flicker
    for (var i = 0; i < streetLampLights.length; i++) {
      streetLampLights[i].intensity = 0.5 + Math.sin(t * 2 + i * 1.5) * 0.05;
    }

    // Interior glow pulse (subtle — bright and steady, comforting)
    interiorLight1.intensity = 1.5 + Math.sin(t * 1.2) * 0.12;
    interiorLight2.intensity = 1.0 + Math.sin(t * 1.5 + 0.5) * 0.08;
    interiorLight3.intensity = 1.0 + Math.sin(t * 1.8 + 1.0) * 0.08;
    doorSpill.intensity = 0.8 + Math.sin(t * 1.3) * 0.1;
    pavementSpill.intensity = 0.6 + Math.sin(t * 1.0) * 0.08;

    // Neon flicker (the "FISH & CHIPS" neon and fish shapes)
    neonFlickerPhase += 0.05;
    var neonPulse = 0.85 + Math.sin(t * 6) * 0.1 + Math.sin(t * 13) * 0.05;
    // Occasional random flicker
    if (Math.random() > 0.995) neonPulse *= 0.4;
    neonFish.material.opacity = neonPulse;
    neonBlueLight.intensity = 0.3 * neonPulse;
    neonFishL.material.opacity = neonPulse * 0.9;
    neonFishR.material.opacity = neonPulse * 0.9;
    neonRedL.intensity = 0.15 * neonPulse;
    neonRedR.intensity = 0.15 * neonPulse;

    // OPEN sign pulse
    openSign.material.opacity = 0.8 + Math.sin(t * 4) * 0.15;

    // Silhouette sway
    for (var i = 0; i < silhouettes.length; i++) {
      var s = silhouettes[i];
      s.mesh.position.x = s.baseX + Math.sin(t * s.swaySpeed + s.swayPhase) * s.swayAmt;
    }

    // Steam rise and drift
    for (var i = 0; i < steamSprites.length; i++) {
      var st = steamSprites[i];
      st.sprite.position.y += st.rise;
      st.sprite.position.x += st.drift + Math.sin(t * 0.5 + i) * 0.001;
      st.sprite.material.opacity *= 0.9995;
      // Reset when too high or faded
      if (st.sprite.position.y > st.resetY + 4 || st.sprite.material.opacity < 0.02) {
        st.sprite.position.y = st.resetY;
        st.sprite.position.x = st.baseX + (Math.random() - 0.5) * 0.3;
        st.sprite.material.opacity = 0.12 + Math.random() * 0.1;
      }
    }

    // Hanging sign sway
    hangSign.rotation.z = Math.sin(t * 0.9) * 0.04;

    // Fluorescent light very subtle flicker
    fluoro.material.color.setHex(Math.random() > 0.998 ? 0xe0e0d0 : 0xf0f0e8);

    renderer.render(scene, camera);
  }


  // ── ENTER BUTTON ──
  var fcBtn = document.createElement('div');
  fcBtn.textContent = 'ENTER THE CHIPPY';
  // Ginger-Light style: transparent dark background, coloured text +
  // border, no infill. Hover just brightens the border/text.
  fcBtn.style.cssText = [
    'position:fixed', 'bottom:60px', 'left:50%', 'transform:translateX(-50%)',
    'font:13px "Courier New",monospace',
    'color:rgba(232,180,80,0.85)',
    'letter-spacing:4px', 'cursor:pointer', 'padding:12px 28px',
    'border:1px solid rgba(232,180,80,0.3)',
    'background:rgba(0,0,0,0.4)',
    'z-index:9004', 'white-space:nowrap',
    'opacity:0', 'transition:opacity 1.5s ease, color 0.3s ease, border-color 0.3s ease'
  ].join(';');
  setTimeout(function() { fcBtn.style.opacity = '1'; }, 1800);
  fcBtn.addEventListener('mouseenter', function() {
    this.style.color = 'rgba(255,210,120,0.95)';
    this.style.borderColor = 'rgba(232,180,80,0.6)';
  });
  fcBtn.addEventListener('mouseleave', function() {
    this.style.color = 'rgba(232,180,80,0.85)';
    this.style.borderColor = 'rgba(232,180,80,0.3)';
  });
  fcBtn.addEventListener('click', function() {
    fcWrap.style.transition = 'opacity 1.5s ease';
    fcWrap.style.opacity = '0';
    setTimeout(function() {
      if (fcWrap && fcWrap.parentNode) fcWrap.parentNode.removeChild(fcWrap);
      var TARGET = 'Chinese Fish and Chips';
      if (window.Engine && Engine.go) { Engine.go(TARGET); }
      else {
        var links = document.querySelectorAll('tw-link, .enchantment-link');
        for (var i = 0; i < links.length; i++) {
          if (links[i].textContent.trim() === '\u00b7') { links[i].click(); break; }
        }
      }
    }, 1500);
  });
  fcWrap.appendChild(fcBtn);
  document.body.appendChild(fcWrap);
  fcAnimate();
}

setInterval(function() {
  var container = document.getElementById('fc-container');
  if (container && !fcActive) { initFc(); }
  else if (!container) {
    fcActive = false;
    if (fcAnimId) { cancelAnimationFrame(fcAnimId); fcAnimId = null; }
    window._dssDisposeWrap('fc-wrap');
  }
}, 300);
})();

// ====== PILLARS SCENE LAYOUT FIX ======
(function() {
  var DECO_DIVS = ['pillars-light','pillars-smoke','pillars-dust'];

  function isDecorative(node) {
    if (node.nodeType === 3) return node.textContent.trim() === '';
    if (node.nodeType !== 1) return true;
    var tag = node.tagName.toUpperCase();
    if (tag === 'SVG') return true; // pillars + lattice are all SVGs
    if (tag === 'STYLE' || tag === 'BR') return true;
    if (tag === 'TW-EXPRESSION' || tag === 'TW-HOOK' || tag === 'TW-MACRO') {
      return node.textContent.trim() === '';
    }
    var cn = typeof node.className === 'string' ? node.className : '';
    for (var i = 0; i < DECO_DIVS.length; i++) {
      if (cn.indexOf(DECO_DIVS[i]) >= 0) return true;
    }
    return false;
  }

  function fixScene(scene) {
    if (scene.dataset.pFixed) return;
    var parent = scene.parentNode;
    if (!parent) return;
    var kids = Array.prototype.slice.call(scene.childNodes);
    var toMove = [];
    for (var i = 0; i < kids.length; i++) {
      if (!isDecorative(kids[i])) toMove.push(kids[i]);
    }
    if (toMove.length === 0) return; // Harlowe hasn't added text yet — wait
    scene.dataset.pFixed = '1';
    var wrapper = document.createElement('div');
    wrapper.style.cssText = 'padding: 0 2.4em;';
    for (var j = 0; j < toMove.length; j++) { wrapper.appendChild(toMove[j]); }
    parent.insertBefore(wrapper, scene);
  }

  var pillarsObs = new MutationObserver(function(muts) {
    for (var i = 0; i < muts.length; i++) {
      var target = muts[i].target;
      var scene = null;
      if (target.className && typeof target.className === 'string' &&
          target.className.indexOf('pillars-scene') >= 0) { scene = target; }
      else if (target.closest) { scene = target.closest('.pillars-scene'); }
      if (scene && !scene.dataset.pFixed) fixScene(scene);
      var added = muts[i].addedNodes;
      for (var j = 0; j < added.length; j++) {
        var n = added[j];
        if (n.nodeType !== 1) continue;
        var cn = typeof n.className === 'string' ? n.className : '';
        if (cn.indexOf('pillars-scene') >= 0 && !n.dataset.pFixed) { fixScene(n); continue; }
        if (n.querySelectorAll) {
          var found = n.querySelectorAll('.pillars-scene');
          for (var k = 0; k < found.length; k++) {
            if (!found[k].dataset.pFixed) fixScene(found[k]);
          }
        }
      }
    }
  });

  pillarsObs.observe(document.body, { childList: true, subtree: true });
})();

// ====== PHONE CALL FADE-IN ======
// The bell now plays on a separate ringing passage, so dialogue can
// start immediately on the call passage with no extra offset.
(function() {
  var PHONE_FADE_OFFSET_MS = 0;
  function runPhoneFades(els) {
    for (var i = 0; i < els.length; i++) {
      (function(el) {
        var dStr = el.style.getPropertyValue('--d') || '0s';
        var tStr = el.style.getPropertyValue('--t') || '1s';
        var delay = parseFloat(dStr) * 1000 + PHONE_FADE_OFFSET_MS;
        setTimeout(function() {
          el.style.transition = 'opacity ' + tStr + ' ease';
          el.style.opacity = '1';
        }, delay);
      })(els[i]);
    }
  }

  var phoneObserver = new MutationObserver(function(mutations) {
    for (var i = 0; i < mutations.length; i++) {
      var added = mutations[i].addedNodes;
      for (var j = 0; j < added.length; j++) {
        var node = added[j];
        if (node.nodeType === 1 && node.querySelectorAll) {
          var phoneEls = node.querySelectorAll('.phone-type');
          if (phoneEls.length > 0) {
            runPhoneFades(phoneEls);
          }
        }
      }
    }
  });

  phoneObserver.observe(document.body, { childList: true, subtree: true });
})();

// ====== STAT BARS LIFT ======
// Move .stat-bars out of tw-passage immediately after Harlowe creates it.
// tw-passage runs a passageFadeIn animation (opacity 0→1); because opacity
// compositing in CSS applies to ALL descendants regardless of position:fixed,
// the stat bars would fade in and out on every navigation.  By reparenting
// .stat-bars directly onto document.body, it is no longer a descendant of
// tw-passage and is completely unaffected by the animation.
(function() {
  new MutationObserver(function() {
    var bars = document.querySelector('tw-passage .stat-bars');
    if (!bars) return;
    // Remove any stale copy left from the previous passage
    var old = document.getElementById('stat-bars-lifted');
    if (old) old.parentNode.removeChild(old);
    // Mark and move to tw-story (not body — links must stay inside tw-story
    // for Harlowe's event delegation to reach them, e.g. the NOTEBOOK link)
    bars.id = 'stat-bars-lifted';
    (document.querySelector('tw-story') || document.body).appendChild(bars);
  }).observe(document.body, { childList: true, subtree: true });
})();

// LORE BOX PERSISTENCE removed 2026-05-20 per Dr Quill — the auto-expand
// behaviour was making the Watkins lore (and others) open on subsequent
// visits without the click. Reverted to click-to-open every time. If
// re-enabling later: see git history for the localStorage + auto-click
// MutationObserver implementation. Also clear any stale storage:
//   localStorage.removeItem('dss-lores-opened')
// is run below so existing playthroughs don't carry the saved set.
(function(){
  try { localStorage.removeItem('dss-lores-opened'); } catch(e) {}
})();

// ====== PASSWORD MECHANIC ======
window.checkCopperPwd = function() {
  var val = (document.getElementById('copper-pwd-input').value || '').trim().toLowerCase().replace(/\s+/g, ' ');
  var yes = document.querySelector('#go-copper-yes tw-link') || document.querySelector('#go-copper-yes a');
  var no  = document.querySelector('#go-copper-no tw-link')  || document.querySelector('#go-copper-no a');
  if (val === 'i said hello') {
    if (window.dssAudio && window.dssAudio.passwordSuccess) window.dssAudio.passwordSuccess();
    if (yes) yes.click();
  } else {
    if (no) no.click();
  }
};

window.checkLacklandPwd = function() {
  var val = (document.getElementById('lackland-pwd-input').value || '').trim().toLowerCase();
  var yes = document.querySelector('#go-lackland-yes tw-link') || document.querySelector('#go-lackland-yes a');
  if (val === 'valletta') {
    if (window.dssAudio && window.dssAudio.passwordSuccess) window.dssAudio.passwordSuccess();
    if (yes) yes.click();
  } else {
    var hint = document.getElementById('lackland-pwd-hint');
    if (hint) { hint.textContent = "That's not it."; hint.style.color = '#c04040'; }
    var inp = document.getElementById('lackland-pwd-input');
    if (inp) inp.value = '';
  }
};

window.deployPwd = function(type) {
  var TEXT = (type === 'copper') ? 'I said hello'
           : (type === 'lackland') ? 'Valletta'
           : null;
  if (!TEXT) return;
  // Close the notebook dialog
  var closeLink = document.querySelector('tw-dialog-links tw-link');
  if (closeLink) closeLink.click();
  // After dialog teardown, fill the input and trigger the check
  var attempts = 0;
  var fill = function() {
    if (document.querySelector('tw-dialog') && ++attempts < 40) {
      setTimeout(fill, 50);
      return;
    }
    if (type === 'copper') {
      var inp = document.getElementById('copper-pwd-input');
      if (inp) { inp.value = TEXT; if (window.checkCopperPwd) window.checkCopperPwd(); }
    } else if (type === 'lackland') {
      var inp = document.getElementById('lackland-pwd-input');
      if (inp) { inp.value = TEXT; if (window.checkLacklandPwd) window.checkLacklandPwd(); }
    }
  };
  setTimeout(fill, 80);
};

document.addEventListener('click', function(e) {
  if (e.target && e.target.id === 'copper-pwd-btn')  window.checkCopperPwd();
  if (e.target && e.target.id === 'lackland-pwd-btn') window.checkLacklandPwd();
});

document.addEventListener('keydown', function(e) {
  if (e.key !== 'Enter') return;
  if (document.activeElement && document.activeElement.id === 'copper-pwd-input')  window.checkCopperPwd();
  if (document.activeElement && document.activeElement.id === 'lackland-pwd-input') window.checkLacklandPwd();
});

// ===== DAWN PETALS =====
(function() {
  var petalObserver = null;

  function startPetalStorm() {
    // Let the piano theme play out to its real coda — disable looping
    // on the source so the current pass finishes naturally and then
    // stops, instead of being cut by a fade in the middle of a phrase.
    if (window.dssAudio && window.dssAudio.letBedFinish) {
      try { window.dssAudio.letBedFinish('piano-eoin'); } catch(e) {}
    }
    var wrap = document.createElement('div');
    wrap.className = 'dawn-petal-wrap';
    document.body.appendChild(wrap);

    // Create THE END directly on body (root stacking context) so z-index beats petals
    var finisEl = document.createElement('div');
    finisEl.className = 'ending-finis';
    finisEl.textContent = 'THE END';
    finisEl.style.cssText = [
      'position:fixed', 'bottom:7vh', 'left:50%', 'transform:translateX(-50%)',
      'z-index:20', 'white-space:nowrap', 'color:#c4ae88', 'font-size:1.7em',
      'letter-spacing:0.55em', 'font-family:Playfair Display,Georgia,serif',
      'text-shadow:0 0 24px rgba(196,158,108,0.6),0 0 8px rgba(220,196,160,0.4)',
      'margin:0', 'padding-top:1.2em',
      'opacity:0', 'transition:opacity 2.5s 2s ease-in'
    ].join(';');
    document.body.appendChild(finisEl);
    setTimeout(function() { finisEl.style.opacity = '1'; }, 50);

    var elapsed    = 0;    // seconds since storm began
    var spawnRate  = 220;  // ms between batches — already brisk at the start, decreases further
    var active     = 0;
    var maxPetals  = 650;  // dense storm — petals near-fill the viewport

    function spawnOne() {
      if (active >= maxPetals) return;
      active++;

      // Probability of settling (accumulating) grows from 0 to 70% over ~55s
      var settlePct = Math.min(0.70, elapsed / 55);
      var settles   = Math.random() < settlePct;

      var p = document.createElement('div');
      p.className = settles ? 'dawn-petal settles' : 'dawn-petal';

      var w   = settles ? (9 + Math.random() * 13) : (7 + Math.random() * 9);
      var h   = w * (1.4 + Math.random() * 0.5);
      var dur = settles
        ? (7 + Math.random() * 7)      // 7–14s to settle
        : (3 + Math.random() * 2.5);   // 3–5.5s to rise off-screen
      var spinDir = Math.random() > 0.5 ? 1 : -1;
      var spin    = spinDir * (60 + Math.random() * 220);
      var r0      = (Math.random() * 360).toFixed(0);
      var sx      = ((Math.random() - 0.5) * 120).toFixed(1) + 'px';
      var sx2     = ((Math.random() - 0.5) * 80).toFixed(1)  + 'px';
      var sx3     = ((Math.random() - 0.5) * 50).toFixed(1)  + 'px';

      var styles = [
        'width:'  + w.toFixed(1) + 'px',
        'height:' + h.toFixed(1) + 'px',
        'left:'   + (Math.random() * 100).toFixed(1) + '%',
        '--dur:'  + dur.toFixed(2) + 's',
        '--r0:'   + r0 + 'deg',
        '--r1:'   + (parseFloat(r0) + spin * 0.25).toFixed(0) + 'deg',
        '--r2:'   + (parseFloat(r0) + spin * 0.50).toFixed(0) + 'deg',
        '--r3:'   + (parseFloat(r0) + spin * 0.75).toFixed(0) + 'deg',
        '--r4:'   + (parseFloat(r0) + spin).toFixed(0)        + 'deg',
        '--sx:'   + sx, '--sx2:' + sx2, '--sx3:' + sx3
      ];

      if (settles) {
        // Peak height: low settlers cluster near bottom, later ones float higher
        var peakVh = (12 + Math.random() * 58).toFixed(1);
        styles.push('--peak:-' + peakVh + 'vh');
        // Settlers linger then slowly fade
        var lifeMs = (dur + 18 + Math.random() * 20) * 1000;
        setTimeout(function() {
          if (!p.parentNode) { active--; return; }
          p.style.transition = 'opacity 4s ease-out';
          p.style.opacity    = '0';
          setTimeout(function() {
            if (p.parentNode) p.parentNode.removeChild(p);
            active--;
          }, 4000);
        }, lifeMs);
      } else {
        styles.push('--rise:' + (105 + Math.random() * 15).toFixed(0) + 'vh');
        setTimeout(function() {
          if (p.parentNode) p.parentNode.removeChild(p);
          active--;
        }, (dur + 0.5) * 1000);
      }

      p.style.cssText = styles.join(';');
      wrap.appendChild(p);
    }

    function spawnBatch() {
      elapsed += spawnRate / 1000;
      // Batch size starts at ~5 and grows quickly to 18 — dense from the off.
      var batch = Math.min(18, Math.ceil(5 + elapsed / 3));
      for (var i = 0; i < batch; i++) {
        (function(ii) {
          setTimeout(spawnOne, ii * (spawnRate / batch) + Math.random() * 60);
        })(i);
      }
      spawnRate = Math.max(60, spawnRate - 12); // accelerates fast
      setTimeout(spawnBatch, spawnRate);
    }

    spawnBatch();
  }

  function setupPetalObserver() {
    if (petalObserver) { petalObserver.disconnect(); petalObserver = null; }
    var trigger = document.getElementById('dawn-petal-trigger');
    if (!trigger) return;
    var fired = false;
    var fallbackTimer = null;
    var fireOnce = function(delayMs) {
      if (fired) return;
      fired = true;
      setTimeout(startPetalStorm, delayMs);
      if (petalObserver) { petalObserver.disconnect(); petalObserver = null; }
      if (fallbackTimer) { clearTimeout(fallbackTimer); fallbackTimer = null; }
    };
    petalObserver = new IntersectionObserver(function(entries) {
      // Scrolled-in path: hold 5s so the player can read the alba poem
      // and the petal-trigger line before the storm starts rising.
      if (entries[0].isIntersecting) fireOnce(5000);
    }, { threshold: 0.3 });
    petalObserver.observe(trigger);
    // Fallback: if the player never scrolls to the trigger (slow read of
    // the dawn text, paused mid-page, etc.), fire petals automatically
    // 45s after the Dawn passage loads. This guarantees the petal-storm
    // begins — and with it, letBedFinish on the piano — before the
    // looping piano-eoin bed has played past its natural coda too many
    // times. The ending always plays out, no matter how slow the
    // click-through to Dawn was.
    fallbackTimer = setTimeout(function() { fireOnce(0); }, 45000);
  }

  var dawnMO = new MutationObserver(function() {
    if (document.getElementById('dawn-petal-trigger')) setupPetalObserver();
  });
  dawnMO.observe(document.body, { childList: true, subtree: true });
})();


