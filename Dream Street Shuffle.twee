function addBuzzerRow(yPos, labelText) {
var btn = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 0.02, 12), brassMat);
btn.rotation.x = Math.PI / 2;
btn.position.set(1.35, yPos, 0.1);
