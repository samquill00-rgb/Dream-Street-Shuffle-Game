  // Right drainpipe
  placeMesh(shop, new THREE.CylinderGeometry(0.035, 0.035, 11, 6), pipeMat, 3.3, 5.5, 0.12);
  for (var pbh = 3; pbh < 11; pbh += 2.5) {
