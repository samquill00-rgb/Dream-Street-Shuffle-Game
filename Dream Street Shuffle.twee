 x="32.5" y="36" width="8" height="1.2"/><rect x="42" y="36" width="13" height="1.2"/><rect x="56.5" y="36" width="6.5" height="1.2"/><rect x="20" y="41" width="6" height="1.2"/><rect x="27.5" y="41" width="12" height="1.2"/><rect x="41" y="41" width="9" height="1.2"/><rect x="51.5" y="41" width="11.5" height="1.2"/><rect x="20" y="46" width="14" height="1.2"/><rect x="35.5" y="46" width="7" height="1.2"/><rect x="44" y="46" width="9" height="1.2"/><rect x="23.5" y="54" width="8" height="1.2"/><rect x="33" y="54" width="11" height="1.2"/><rect x="45.5" y="54" width="13" height="1.2"/><rect x="20" y="59" width="10" height="1.2"/><rect x="31.5" y="59" width="14" height="1.2"/><rect x="47" y="59" width="6" height="1.2"/><rect x="54.5" y="59" width="8.5" height="1.2"/><rect x="20" y="64" width="11" height="1.2"/><rect x="32.5" y="64" width="9" height="1.2"/><rect x="43" y="64" width="13" height="1.2"/><rect x="57.5" y="64" width="5.5" height="1.2"/><rect x="20" y="69" width="8" height="1.2"/><rect x="29.5" y="69" width="11" height="1.2"/><rect x="42" y="69" width="10" height="1.2"/><rect x="20" y="74" width="12" height="1.2"/><rect x="33.5" y="74" width="9" height="1.2"/><rect x="44" y="74" width="13" height="1.2"/><rect x="58.5" y="74" width="4.5" height="1.2"/><rect x="20" y="79" width="7" height="1.2"/><rect x="28.5" y="79" width="11" height="1.2"/><rect x="41" y="79" width="14" height="1.2"/></g><path d="M15.5,85 Q26,89 36,86 Q46,90 56,87 Q63,91 66.5,88 L66.5,93 L15.5,93 Z" fill="#2a1408" opacity="0.55"/><path d="M15.5,89 Q26,91 36,90 Q46,92 56,90 Q63,92 66.5,91 L66.5,93 L15.5,93 Z" fill="#0c0502" opacity="0.7"/><path d="M19,89 Q22,93 24,91 Q20,94 19,89 Z" fill="#180802"/><path d="M32,90 Q36,93 38,91 Q33,94 32,90 Z" fill="#180802"/><path d="M49,89 Q53,93 54,90 Q50,94 49,89 Z" fill="#180802"/><path d="M60,90 Q63,93 64,91 Q61,94 60,90 Z" fill="#180802"/></g></svg>
<div class="page-found-header">⟡ PAGE 93 ⟡</div>
<div class="page-found-body">You have Page 93. Return it to Inis O'Flatterly in Cecil Court.</div>
