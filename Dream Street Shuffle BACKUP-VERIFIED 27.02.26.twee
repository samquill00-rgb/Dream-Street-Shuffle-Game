        <line x1="5.3" y1="110" x2="28.7" y2="110" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="132" x2="28.5" y2="132" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="154" x2="28.5" y2="154" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="176" x2="28.5" y2="176" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="198" x2="28.5" y2="198" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="220" x2="28.5" y2="220" stroke="url(#pf)" stroke-width="0.65"/>
        <line x1="5.5" y1="242" x2="28.5" y2="242" stroke="url(#pf)" stroke-width="0.65"/>
        <!-- Faint fluting -->
        <line x1="10" y1="88" x2="10" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/>
        <line x1="14" y1="88" x2="14" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/>
        <line x1="17" y1="88" x2="17" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/>
        <line x1="20" y1="88" x2="20" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/>
        <line x1="24" y1="88" x2="24" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/>
        <!-- Echinus (curved capital swell) -->
        <path d="M6,88 Q5,78 3,72 L31,72 Q29,78 28,88" fill="none" stroke="url(#pf)" stroke-width="1.1"/>
        <!-- Abacus slab — CRACKED, left portion collapsed inward -->
        <!-- Right surviving portion: tilting down-left -->
        <path d="M12,72 L32,68 L33,63 L13,66 Z" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.6"/>
        <!-- Left fallen piece: a slab lying at an angle, partly off the shaft -->
        <path d="M2,74 L-2,70 L8,67 L11,72 Z" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.45"/>
        <!-- Fracture line across shaft top -->
        <path d="M6,88 L9,83 L13,87 L17,80 L21,86 L25,79 L28,88" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.55"/>
        <!-- A fallen drum section leaning against the shaft at ~1/3 height -->
        <path d="M1,168 L3,160 L9,162 L9,170 L3,172 Z" fill="none" stroke="#8ac8dc" stroke-width="0.85" opacity="0.32"/>
        <!-- Crack on shaft face -->
        <path d="M13,130 L15,142 L12,150" fill="none" stroke="#8ac8dc" stroke-width="0.5" opacity="0.28"/>
        <!-- Rubble at base -->
        <path d="M3,255  L9,255  L10,260 L2,260 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.8" opacity="0.28"/>
        <path d="M21,257 L28,257 L29,262 L20,261 Z" fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.22"/>
