:: StoryTitle
Dream Street Shuffle

:: UserScript [script]

// ====== NOTEBOOK LAYOUT FORCE ======
// Harlowe wraps dialog content in elements that break CSS layout.
// This polls for the dialog and forces layout with inline styles.
setInterval(function() {
var nbPage = document.querySelector('.nb-page');
if (!nbPage) return;

// Always find tw-dialog and force it full-screen (Harlowe sets max-width:50vw which we must override every tick)
var el = nbPage.parentElement;
while (el && el.tagName !== 'TW-DIALOG') {
el.style.cssText = 'display:block !important;width:100% !important;max-width:none !important;overflow:visible !important;';
el = el.parentElement;
}
if (el && el.tagName === 'TW-DIALOG') {
el.style.cssText = 'position:fixed !important;top:0 !important;left:0 !important;width:100vw !important;max-width:none !important;height:100vh !important;display:flex !important;align-items:flex-start !important;justify-content:center !important;padding-top:4vh !important;background:transparent !important;border:none !important;z-index:9999 !important;overflow:hidden !important;';
}

// Always force the two-panel layout
nbPage.style.cssText = 'display:block;position:relative;width:96vw;max-width:1400px;height:84vh;overflow:hidden;background:transparent;border:none;padding:0;z-index:10001;';

var left = nbPage.querySelector('.nb-left');
if (left) {
left.style.cssText = 'position:absolute;top:0;left:0;width:55%;height:100%;overflow-y:auto;padding:0.8em 2em 2em 2em;box-sizing:border-box;background:#f4edd8;background-image:linear-gradient(rgba(120,100,80,0.15) 1px, transparent 1px);background-size:100% 2em;background-position:0 0.8em;font-family:Special Elite,monospace;font-size:1.05em;line-height:1.6;color:#3a3028;';
}

var right = nbPage.querySelector('.nb-right');
if (right) {
right.style.cssText = 'position:absolute;top:0;left:55%;right:0;height:100%;overflow:hidden;padding:0;';
}

var map = nbPage.querySelector('.soho-map');
if (map) {
map.style.cssText = 'width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(20,18,15,0.95);border:1px solid #5a4a3a;padding:8px;box-sizing:border-box;margin:0;line-height:0;';
}

var svg = nbPage.querySelector('svg');
if (svg) {
svg.style.cssText = 'width:100%;height:100%;display:block;';
}

// One-time setup: close button and backdrop click (guard with dataset flag on dialog)
if (el && el.tagName === 'TW-DIALOG' && !el.dataset.nbGuarded) {
el.dataset.nbGuarded = 'true';
var closeBtn = document.createElement('div');
closeBtn.textContent = '\u2715';
closeBtn.style.cssText = 'position:fixed;top:1.2em;right:1.5em;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#a09080;cursor:pointer;border:1px solid rgba(160,128,96,0.3);border-radius:50%;background:rgba(14,12,10,0.8);z-index:100000;transition:all 0.3s ease;';
closeBtn.addEventListener('mouseenter', function() {
this.style.color = '#d4a574';
this.style.borderColor = 'rgba(212,165,116,0.5)';
this.style.background = 'rgba(14,12,10,0.95)';
});
closeBtn.addEventListener('mouseleave', function() {
this.style.color = '#a09080';
this.style.borderColor = 'rgba(160,128,96,0.3)';
this.style.background = 'rgba(14,12,10,0.8)';
});
closeBtn.addEventListener('click', function() {
var link = document.querySelector('tw-dialog-links tw-link');
if (link) link.click();
});
el.appendChild(closeBtn);
el.addEventListener('click', function(e) {
var clickedNb = e.target.closest('.nb-page');
var clickedClose = e.target.closest('div[style*="z-index:100000"]');
if (!clickedNb && !clickedClose) {
var link = document.querySelector('tw-dialog-links tw-link');
if (link) link.click();
}
});
}
}, 200);

// ====== BAR GAME CLASS ======
window.BarGame = class BarGame {
constructor(canvasId, sobriety) {
this.canvas = document.getElementById(canvasId);
this.ctx = this.canvas.getContext('2d');
this.sobriety = sobriety;
this.phase = 'selecting';
this.currentRound = 0;
this.selections = [null, null, null, null];
this.correct = [0, 1, 0, 1];
this.isAnimating = false;
this.mouseX = 0; this.mouseY = 0;
this.hoveredItem = null; this.selectedItem = null;
this.bottles = [
{ name: 'Wild Turkey', x: 80, w: 50, h: 120, color: '#8b4513', label: 'bird' },
{ name: "Jack Daniel's", x: 220, w: 45, h: 130, color: '#1a1a1a', label: 'square' },
{ name: "Maker's Mark", x: 360, w: 48, h: 125, color: '#9d3d2a', label: 'wax' }
];
this.glasses = [
{ name: 'Tumbler', x: 80, w: 50, h: 80, shape: 'tumbler' },
{ name: 'Tulip', x: 220, w: 35, h: 95, shape: 'tulip' },
{ name: 'Highball', x: 360, w: 40, h: 110, shape: 'highball' }
];
this.limes = [
{ name: 'Fresh Lime', x: 140, w: 60, h: 60, type: 'fresh' },
{ name: 'Bottled Lime Juice', x: 360, w: 50, h: 90, type: 'bottled' }
];
this.scotches = [
{ name: 'Johnnie Walker', x: 60, w: 48, h: 130, color: '#1a1a1a', label: 'JW', accent: '#c9a961' },
{ name: 'The Macallan', x: 190, w: 50, h: 120, color: '#5a2d0c', label: 'Mac', accent: '#d4a574' },
{ name: 'Glenfiddich', x: 330, w: 46, h: 125, color: '#2d5a0c', label: 'Glen', accent: '#8bc34a' }
];
this.canvas.addEventListener('mousemove', (e) => this.handleMouseMove(e));
this.canvas.addEventListener('click', (e) => this.handleClick(e));
document.getElementById('bar-round-display').textContent = '\uD83C\uDFB8 Guitarist\u2019s bourbon? \uD83C\uDFB8';
document.getElementById('bar-narrative').innerHTML = '';
document.getElementById('bar-end').innerHTML = '';
this.animate();
}
handleMouseMove(e) {
var rect = this.canvas.getBoundingClientRect();
var scaleX = this.canvas.width / rect.width;
var scaleY = this.canvas.height / rect.height;
this.mouseX = (e.clientX - rect.left) * scaleX;
this.mouseY = (e.clientY - rect.top) * scaleY;
this.updateHoveredItem();
}
handleClick(e) {
if (this.phase !== 'selecting' || this.isAnimating) return;
var rect = this.canvas.getBoundingClientRect();
var scaleX = this.canvas.width / rect.width;
var scaleY = this.canvas.height / rect.height;
this.mouseX = (e.clientX - rect.left) * scaleX;
this.mouseY = (e.clientY - rect.top) * scaleY;
var items = this.getCurrentRoundItems();
var self = this;
items.forEach(function(item, idx) {
var bounds = self.getItemBounds(item);
if (self.mouseX >= bounds.x && self.mouseX <= bounds.x + bounds.w &&
self.mouseY >= bounds.y && self.mouseY <= bounds.y + bounds.h) {
self.selectItem(idx);
}
});
}
updateHoveredItem() {
if (this.phase !== 'selecting') { this.hoveredItem = null; return; }
var items = this.getCurrentRoundItems();
var hovered = null; var self = this;
items.forEach(function(item, idx) {
var bounds = self.getItemBounds(item);
if (self.mouseX >= bounds.x && self.mouseX <= bounds.x + bounds.w &&
self.mouseY >= bounds.y && self.mouseY <= bounds.y + bounds.h) { hovered = idx; }
});
this.hoveredItem = hovered;
}
getCurrentRoundItems() {
if (this.currentRound === 0) return this.bottles;
if (this.currentRound === 1) return this.glasses;
if (this.currentRound === 2) return this.limes;
return this.scotches;
}
getItemBounds(item) { return { x: item.x, y: 240, w: item.w, h: item.h }; }
selectItem(idx) {
this.selections[this.currentRound] = idx;
this.selectedItem = idx;
this.isAnimating = true;
var isCorrect = idx === this.correct[this.currentRound];
var narrativeDiv = document.getElementById('bar-narrative');
if (isCorrect) {
narrativeDiv.innerHTML = '<em style="color:#4CFF00;">Right.</em>';
} else {
var wrongMsgs = ['"The bird. I said the bird."','"The tulip. I said the tulip."','"Fresh lime. Not bottled."','"The Macallan. I said The Macallan."'];
narrativeDiv.innerHTML = '<em style="color:#FF6B6B;">' + wrongMsgs[this.currentRound] + '</em>';
}
var self = this;
setTimeout(function() {
narrativeDiv.innerHTML = '';
self.currentRound++;
if (self.currentRound < 4) {
self.isAnimating = false; self.selectedItem = null; self.hoveredItem = null;
var hints = ['Guitarist\u2019s bourbon?','Guitarist\u2019s glass?','Moe\u2019s lime?','Pianist\u2019s scotch?'];
document.getElementById('bar-round-display').textContent = '\uD83C\uDFB8 ' + hints[self.currentRound] + ' \uD83C\uDFB8';
} else {
self.phase = 'feedback'; self.showResult();
}
}, 1000);
}
showResult() {
var score = 0;
for (var i = 0; i < 4; i++) { if (this.selections[i] === this.correct[i]) score++; }
var narrativeDiv = document.getElementById('bar-narrative');
var roundDisplay = document.getElementById('bar-round-display');
if (score === 4) {
this.canvas.classList.add('success-flash');
roundDisplay.textContent = '\u2605 PERFECT \u2605';
narrativeDiv.innerHTML = '<em>\u201CFresh lime,\u201D says Moe. \u201CTulip,\u201D nods the guitarist. The pianist raises his Macallan.</em>';
narrativeDiv.style.color = '#4CFF00';
} else if (score >= 3) {
this.canvas.classList.add('error-flash');
roundDisplay.textContent = '\u2606 CLOSE \u2606';
narrativeDiv.innerHTML = '<em>' + score + ' out of 4. Nearly had it.</em>';
narrativeDiv.style.color = '#d4a574';
} else {
this.canvas.classList.add('error-flash');
roundDisplay.textContent = '\u2717 WRONG \u2717';
narrativeDiv.innerHTML = '<em>' + score + ' out of 4. They look at you like you\u2019ve never been in a bar.</em>';
narrativeDiv.style.color = '#FF6B6B';
}
setTimeout(function() {
var link = score === 4 ? document.querySelector('#bar-win-link tw-link') : document.querySelector('#bar-lose-link tw-link');
if (link) link.click();
}, 2500);
this.phase = 'result';
}
stop() { this.stopped = true; }
animate() {
if (this.stopped) return;
requestAnimationFrame(() => this.animate());
this.draw();
}
draw() {
this.ctx.fillStyle = '#0c0814';
this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
if (this.sobriety < 50 && this.phase === 'selecting') {
this.ctx.save();
var wa = (this.sobriety < 30) ? 4 : 2;
var wb = Math.sin(Date.now() / 200) * wa;
this.ctx.translate(wb, wb * 0.5);
}
this.drawBar(this.ctx);
if (this.phase === 'selecting') {
if (this.currentRound === 0) this.drawBottles(this.ctx);
else if (this.currentRound === 1) this.drawGlasses(this.ctx);
else if (this.currentRound === 2) this.drawLimes(this.ctx);
else this.drawScotches(this.ctx);
for (var i = 0; i < 4; i++) {
this.ctx.beginPath(); this.ctx.arc(245 + i * 25, 75, 4, 0, Math.PI * 2);
this.ctx.fillStyle = i < this.currentRound ? '#4CFF00' : i === this.currentRound ? '#d4a574' : '#3a2a22';
this.ctx.fill();
}
if (this.hoveredItem !== null) {
var items = this.getCurrentRoundItems();
this.ctx.fillStyle = '#8a7aaa'; this.ctx.font = 'bold 14px Georgia'; this.ctx.textAlign = 'center';
this.ctx.fillText(items[this.hoveredItem].name, this.canvas.width / 2, 380);
}
}
if (this.sobriety < 50 && this.phase === 'selecting') this.ctx.restore();
}
drawBar(ctx) {
ctx.fillStyle = '#2a1a12'; ctx.fillRect(0, 180, this.canvas.width, 220);
ctx.fillStyle = '#4a3a32'; ctx.fillRect(0, 178, this.canvas.width, 4);
ctx.fillStyle = '#1a1008'; ctx.fillRect(0, 0, this.canvas.width, 180);
var g = ctx.createLinearGradient(0, 0, 0, 180);
g.addColorStop(0, 'rgba(212,165,116,0.05)'); g.addColorStop(1, 'rgba(138,122,170,0.08)');
ctx.fillStyle = g; ctx.fillRect(0, 0, this.canvas.width, 180);
}
drawBottleShape(ctx, x, y, w, h, color) {
ctx.fillStyle = color;
var nW = 10, nH = 25, cx = x + w/2;
ctx.beginPath(); ctx.moveTo(cx-nW/2, y); ctx.lineTo(cx-nW/2, y+nH);
ctx.quadraticCurveTo(x, y+nH+5, x+3, y+nH+15); ctx.lineTo(x+3, y+h-5);
ctx.quadraticCurveTo(x+3, y+h, x+8, y+h); ctx.lineTo(x+w-8, y+h);
ctx.quadraticCurveTo(x+w-3, y+h, x+w-3, y+h-5); ctx.lineTo(x+w-3, y+nH+15);
ctx.quadraticCurveTo(x+w, y+nH+5, cx+nW/2, y+nH); ctx.lineTo(cx+nW/2, y);
ctx.closePath(); ctx.fill();
ctx.fillStyle = '#555'; ctx.fillRect(cx-nW/2-1, y-3, nW+2, 5);
}
drawBottles(ctx) {
var self = this;
this.bottles.forEach(function(b, idx) {
var isH = self.hoveredItem === idx, isS = self.selectedItem === idx, isC = idx === self.correct[0];
ctx.save();
if (isH) { ctx.shadowColor = 'rgba(212,165,116,0.6)'; ctx.shadowBlur = 20; }
if (self.selectedItem !== null && !isS) ctx.globalAlpha = 0.3;
var x = b.x, y = 240;
self.drawBottleShape(ctx, x, y, b.w, b.h, b.color);
ctx.fillStyle = b.label==='bird'?'#c9a961':b.label==='square'?'#2a2a2a':'#8b0000';
var lY = y+b.h/3, lH = b.h/3;
ctx.fillRect(x+5, lY, b.w-10, lH);
ctx.fillStyle = '#d4a574'; ctx.font = 'bold 9px Georgia'; ctx.textAlign = 'center';
if (b.label==='bird') self.drawBirdLabel(ctx, x+b.w/2, lY+lH/2);
else if (b.label==='square') ctx.fillText('JD', x+b.w/2, lY+lH/2+2);
else { ctx.fillStyle='#8b0000'; ctx.beginPath(); ctx.ellipse(x+b.w/2,y-8,7,5,0,0,Math.PI*2); ctx.fill(); ctx.fillStyle='#d4a574'; ctx.fillText('MM',x+b.w/2,lY+lH/2+2); }
if (isS) { ctx.strokeStyle=isC?'#4CFF00':'#FF4444'; ctx.lineWidth=3; ctx.strokeRect(x-5,y-20,b.w+10,b.h+25); }
ctx.restore();
});
}
drawBirdLabel(ctx, x, y) {
ctx.save(); ctx.fillStyle = '#1a1a1a';
var tX=x-6, tY=y+2;
for (var i=-2;i<=2;i++) { ctx.beginPath(); ctx.moveTo(tX,tY); var a=-Math.PI/2+i*0.35; ctx.lineTo(tX+Math.cos(a)*10,tY+Math.sin(a)*10); ctx.lineTo(tX+Math.cos(a+0.15)*9,tY+Math.sin(a+0.15)*9); ctx.closePath(); ctx.fill(); }
ctx.beginPath(); ctx.ellipse(x+1,y+2,5,4,0.2,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.moveTo(x+4,y); ctx.quadraticCurveTo(x+7,y-3,x+6,y-6); ctx.lineTo(x+4.5,y-5); ctx.quadraticCurveTo(x+5.5,y-2,x+3,y+1); ctx.closePath(); ctx.fill();
ctx.beginPath(); ctx.arc(x+5.5,y-7,2,0,Math.PI*2); ctx.fill();
ctx.beginPath(); ctx.moveTo(x+7.5,y-7.5); ctx.lineTo(x+10,y-7); ctx.lineTo(x+7.5,y-6.5); ctx.closePath(); ctx.fill();
ctx.fillStyle='#8b0000'; ctx.beginPath(); ctx.ellipse(x+6.5,y-5.5,0.8,1.2,0,0,Math.PI*2); ctx.fill();
ctx.strokeStyle='#1a1a1a'; ctx.lineWidth=0.8; ctx.beginPath(); ctx.moveTo(x,y+5); ctx.lineTo(x-1,y+8); ctx.moveTo(x+2,y+5); ctx.lineTo(x+3,y+8); ctx.stroke();
ctx.restore();
}
drawGlasses(ctx) {
var self = this;
this.glasses.forEach(function(g, idx) {
var isH=self.hoveredItem===idx, isS=self.selectedItem===idx, isC=idx===self.correct[1];
ctx.save();
if (isH) { ctx.shadowColor='rgba(212,165,116,0.6)'; ctx.shadowBlur=20; }
if (self.selectedItem!==null&&!isS) ctx.globalAlpha=0.3;
var x=g.x, y=240;
ctx.strokeStyle='#d4a574'; ctx.lineWidth=2; ctx.fillStyle='rgba(212,165,116,0.1)';
if (g.shape==='tumbler') { ctx.beginPath(); ctx.moveTo(x+8,y); ctx.lineTo(x+8,y+g.h-5); ctx.quadraticCurveTo(x+g.w/2,y+g.h,x+g.w-8,y+g.h-5); ctx.lineTo(x+g.w-8,y); ctx.closePath(); ctx.fill(); ctx.stroke(); }
else if (g.shape==='tulip') { ctx.beginPath(); ctx.moveTo(x+8,y+15); ctx.quadraticCurveTo(x+5,y+20,x+10,y+g.h-5); ctx.lineTo(x+g.w-10,y+g.h-5); ctx.quadraticCurveTo(x+g.w-5,y+20,x+g.w-8,y+15); ctx.quadraticCurveTo(x+g.w/2,y,x+g.w/2,y); ctx.closePath(); ctx.fill(); ctx.stroke(); }
else { ctx.beginPath(); ctx.moveTo(x+10,y); ctx.lineTo(x+10,y+g.h-5); ctx.quadraticCurveTo(x+g.w/2,y+g.h,x+g.w-10,y+g.h-5); ctx.lineTo(x+g.w-10,y); ctx.closePath(); ctx.fill(); ctx.stroke(); }
ctx.strokeStyle='rgba(212,165,116,0.5)'; ctx.lineWidth=1; ctx.beginPath(); ctx.ellipse(x+g.w/2,y+2,g.w/2-2,2,0,0,Math.PI); ctx.stroke();
if (isS) { ctx.strokeStyle=isC?'#4CFF00':'#FF4444'; ctx.lineWidth=3; ctx.strokeRect(x-5,y-10,g.w+10,g.h+20); }
ctx.restore();
});
}
drawLimes(ctx) {
var self = this;
this.limes.forEach(function(l, idx) {
var isH=self.hoveredItem===idx, isS=self.selectedItem===idx, isC=idx===self.correct[2];
ctx.save();
if (isH) { ctx.shadowColor='rgba(212,165,116,0.6)'; ctx.shadowBlur=20; }
if (self.selectedItem!==null&&!isS) ctx.globalAlpha=0.3;
var x=l.x, y=240;
if (l.type==='fresh') {
ctx.fillStyle='#2d8659'; ctx.beginPath(); ctx.moveTo(x+l.w/2,y); ctx.lineTo(x+l.w,y+20); ctx.quadraticCurveTo(x+l.w,y+l.h,x+l.w/2,y+l.h+10); ctx.quadraticCurveTo(x,y+l.h,x,y+20); ctx.closePath(); ctx.fill();
ctx.fillStyle='#4CAF50'; ctx.beginPath(); ctx.ellipse(x+l.w/3,y+l.h/3,8,5,0.3,0,Math.PI*2); ctx.fill();
ctx.strokeStyle='#1a5a3a'; ctx.lineWidth=1; for(var i=0;i<5;i++){ctx.beginPath();ctx.moveTo(x+l.w/2-i*5,y);ctx.lineTo(x+i*5,y+l.h);ctx.stroke();}
} else {
ctx.fillStyle='#2a2a2a'; ctx.beginPath(); ctx.moveTo(x+5,y); ctx.lineTo(x+l.w-5,y); ctx.lineTo(x+l.w-5,y+l.h-8); ctx.quadraticCurveTo(x+l.w/2,y+l.h,x+5,y+l.h-8); ctx.closePath(); ctx.fill();
ctx.strokeStyle='rgba(212,165,116,0.3)'; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(x+8,y+5); ctx.lineTo(x+8,y+l.h-10); ctx.stroke();
ctx.fillStyle='#2d8659'; ctx.fillRect(x+3,y+l.h/3,l.w-6,l.h/4);
ctx.fillStyle='#d4a574'; ctx.font='bold 7px Georgia'; ctx.textAlign='center'; ctx.fillText('LIME',x+l.w/2,y+l.h/2+1);
ctx.fillStyle='#c9a961'; ctx.beginPath(); ctx.ellipse(x+l.w/2,y-3,l.w/2-2,3,0,0,Math.PI*2); ctx.fill();
}
if (isS) { ctx.strokeStyle=isC?'#4CFF00':'#FF4444'; ctx.lineWidth=3; ctx.strokeRect(x-5,y-10,l.w+10,l.h+20); }
ctx.restore();
});
}
drawScotches(ctx) {
var self = this;
this.scotches.forEach(function(s, idx) {
var isH=self.hoveredItem===idx, isS=self.selectedItem===idx, isC=idx===self.correct[3];
ctx.save();
if (isH) { ctx.shadowColor='rgba(212,165,116,0.6)'; ctx.shadowBlur=20; }
if (self.selectedItem!==null&&!isS) ctx.globalAlpha=0.3;
var x=s.x, y=240;
self.drawBottleShape(ctx, x, y, s.w, s.h, s.color);
var lY=y+s.h/3, lH=s.h/3;
ctx.fillStyle=s.accent; ctx.fillRect(x+5,lY,s.w-10,lH);
ctx.fillStyle=s.color; ctx.font='bold 9px Georgia'; ctx.textAlign='center';
ctx.fillText(s.label, x+s.w/2, lY+lH/2+3);
if (isS) { ctx.strokeStyle=isC?'#4CFF00':'#FF4444'; ctx.lineWidth=3; ctx.strokeRect(x-5,y-20,s.w+10,s.h+25); }
ctx.restore();
});
}
};

window.startBarGame = function() {
if (window.currentBarGame) window.currentBarGame.stop();
document.getElementById('pre-bar').classList.add('hidden');
var sobriety = parseInt(document.getElementById('sob-data-bar').textContent) || 55;
var canvas = document.getElementById('bar-canvas');
canvas.classList.remove('success-flash', 'error-flash');
window.currentBarGame = new window.BarGame('bar-canvas', sobriety);
};

/* ===== FIGHT MINIGAME ENGINE ===== */
window.FightGame = class FightGame {
constructor(canvasId, sobriety) {
this.canvas = document.getElementById(canvasId);
this.ctx = this.canvas.getContext('2d');
this.W = this.canvas.width;
this.H = this.canvas.height;
this.sobriety = sobriety;

this.score = 0;
this.round = 0;
this.gameOver = false;
this.phase = 'idle';
this.phaseTimer = 0;
this.punchType = '';
this.resultText = '';
this.resultClass = '';
this.narrativeText = '';
this.clickable = false;
this.acted = false;

this.copperBaseX = this.W / 2;
this.copperBaseY = 80;
this.telegraphT = 0;
this.punchT = 0;
this.resultFlash = 0;
this.hoveredZone = '';

this.baseTelegraphDuration = 2000;
this.telegraphDuration = this.baseTelegraphDuration;

this.roundPunches = ['right_cross', 'left_hook', 'uppercut', 'right_cross', 'left_hook', 'uppercut'];

this.practiceIntros = [
"Watch his RIGHT glove. It glows and a curved trail shows where the punch is heading. Dodge away from it.",
"Now his LEFT glove. Follow the trail — it shows where the fist lands. Dodge the other way.",
"This time he crouches. The glove drops low for an uppercut. Dodge either side."
];

this.realIntros = [
"Copper feints left. You clock it; he clocks you clocking it. The right cross comes.",
"Copper works behind the jab until he steps in: a straight right to your nose.",
"You both breathe heavy as sports. An uppercut emits straight from his stomach."
];

this.practiceNarr = [
{ clean: "Good. You read it.", block: "Blocked it. Safe, but dodging scores more.", caught: "He pulls the punch. Watch the glowing glove next time." },
{ clean: "Quick feet. You've got it.", block: "Covered up. Try dodging away for more points.", caught: "Wrong side. Dodge AWAY from the glowing fist." },
{ clean: "Sidestepped it clean.", block: "Absorbed it. Either side works for an uppercut.", caught: "Too slow. Step sideways when he crouches." }
];

this.realDodgeNarr = [
{ clean: "You slip under it so as to suggest a vacuum.",
block: "You shell up and take a hit, with the general grace of the crayfish.",
caught: "You give ground and feel the wall behind you. No room. A hook finds your shoulder." },
{ clean: "Your neck rolls. His knuckles are pinking your cheek.",
block: "You parry at the wrist. A jab goes wide.",
caught: "'Careful, clever cunt,' says Copper." },
{ clean: "You swerve it and he stumbles.",
block: "You smother him on the inside. The uppercut dies on your shoulder.",
caught: "His experienced punch,\nTakes you to lunch,\nAnd hey, nonnie, nonie!" }
];

this.practiceCounterNarr = [
{ success: "You swing and Copper leans back. He grins.", fail: "Copper catches your wrist. 'Timing,' he says." },
{ success: "Copper nods. 'Not bad.'", fail: "He swats your hand away. 'Watch the glove first.'" },
{ success: "You step inside. Copper grunts approval.", fail: "He rides it. 'Patience.'" }
];

this.realCounterNarr = [
{ success: "You let the right come. Your own left hook finds the unclaimed territory of his diaphragm.",
fail: "You swing — Copper saw it coming a street away." },
{ success: "You step inside his reach and land one clean to the ribs.",
fail: "'Careful, clever cunt,' says Copper." },
{ success: "Your forehead to his nose, which powders like a shingle under its force.",
fail: "His experienced punch,\nTakes you to lunch,\nAnd hey, nonnie, nonie!" }
];

this.setupInput();
this.startRound();
this.loop();
}

isPractice() { return this.round < 3; }
realRoundIndex() { return this.round - 3; }

setupInput() {
this.canvas.addEventListener('mousemove', (e) => {
if (!this.clickable) { this.hoveredZone = ''; return; }
var rect = this.canvas.getBoundingClientRect();
var mx = (e.clientX - rect.left) * (this.W / rect.width);
var my = (e.clientY - rect.top) * (this.H / rect.height);
this.hoveredZone = this.getZone(mx, my);
this.canvas.style.cursor = this.hoveredZone ? 'pointer' : 'crosshair';
});

this.canvas.addEventListener('click', (e) => {
if (!this.clickable || this.acted) return;
var rect = this.canvas.getBoundingClientRect();
var mx = (e.clientX - rect.left) * (this.W / rect.width);
var my = (e.clientY - rect.top) * (this.H / rect.height);
var zone = this.getZone(mx, my);
if (zone) this.handleAction(zone);
});
}

getZone(mx, my) {
if (mx < 130 && my > 120 && my < 350) return 'dodge_left';
if (mx > this.W - 130 && my > 120 && my < 350) return 'dodge_right';
if (mx > 150 && mx < this.W - 150 && my > 330) return 'block';
if (mx > 210 && mx < this.W - 210 && my > 80 && my < 280) return 'counter';
return '';
}

startRound() {
this.phase = 'intro';
this.phaseTimer = Date.now();
this.telegraphT = 0;
this.punchT = 0;
this.resultFlash = 0;
this.clickable = false;
this.acted = false;
this.hoveredZone = '';

if (this.isPractice()) {
this.showNarrative(this.practiceIntros[this.round]);
this.telegraphDuration = 3200;
} else {
this.showNarrative(this.realIntros[this.realRoundIndex()]);
var sobPenalty = (100 - this.sobriety) * 5;
this.telegraphDuration = Math.max(1000, this.baseTelegraphDuration - sobPenalty);
}

this.updateRoundDisplay();
var introDelay = this.isPractice() ? 3200 : 2500;

setTimeout(() => {
if (this.gameOver) return;
this.phase = 'telegraph';
this.phaseTimer = Date.now();
this.punchType = this.roundPunches[this.round];
this.clickable = true;
if (!this.isPractice()) this.clearNarrative();
}, introDelay);
}

getCorrectDodge() {
if (this.punchType === 'right_cross') return 'dodge_right';
if (this.punchType === 'left_hook') return 'dodge_left';
if (this.punchType === 'uppercut') return 'either';
return 'dodge_left';
}

handleAction(zone) {
this.acted = true;
this.clickable = false;
var practice = this.isPractice();
var ni = practice ? this.round : this.realRoundIndex();

if (zone === 'counter') {
var chance = practice ? 0.8 : 0.45 + (this.sobriety / 285);
if (Math.random() < chance) {
if (!practice) this.score += 3;
this.resultText = '★ COUNTER ★';
this.resultClass = 'win';
this.narrativeText = practice ? this.practiceCounterNarr[ni].success : this.realCounterNarr[ni].success;
} else {
this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceCounterNarr[ni].fail : this.realCounterNarr[ni].fail;
}
} else if (zone === 'block') {
if (!practice) this.score += 1;
this.resultText = 'ABSORBED';
this.resultClass = 'neutral';
this.narrativeText = practice ? this.practiceNarr[ni].block : this.realDodgeNarr[ni].block;
} else {
var correct = this.getCorrectDodge();
var isCorrect = (zone === correct) || (correct === 'either');
if (isCorrect) {
if (!practice) this.score += 2;
this.resultText = 'CLEAN';
this.resultClass = 'win';
this.narrativeText = practice ? this.practiceNarr[ni].clean : this.realDodgeNarr[ni].clean;
} else {
this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceNarr[ni].caught : this.realDodgeNarr[ni].caught;
}
}

this.phase = 'punching';
this.phaseTimer = Date.now();

setTimeout(() => {
this.phase = 'result';
this.phaseTimer = Date.now();
this.resultFlash = 1;
this.showResult(this.resultText, this.resultClass);
this.showNarrative(this.narrativeText);
this.updateRoundDisplay();

setTimeout(() => {
if (practice && this.round === 2) {
this.showNarrative("Practice over. Now it counts. Dodge: 2 points. Block: 1. Counter: 3 (risky). You need 4 to win.");
setTimeout(() => { this.round = 3; this.startRound(); }, 3500);
} else if (!practice && this.round >= 5) {
this.endGame();
} else {
this.round++;
this.startRound();
}
}, 2500);
}, 500);
}

timeOut() {
this.acted = true;
this.clickable = false;
var practice = this.isPractice();
var ni = practice ? this.round : this.realRoundIndex();

this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceNarr[ni].caught : this.realDodgeNarr[ni].caught;

this.phase = 'punching';
this.phaseTimer = Date.now();

setTimeout(() => {
this.phase = 'result';
this.phaseTimer = Date.now();
this.resultFlash = 1;
this.showResult(this.resultText, this.resultClass);
this.showNarrative(this.narrativeText);
this.updateRoundDisplay();

setTimeout(() => {
if (practice && this.round === 2) {
this.showNarrative("Practice over. Now it counts. Dodge: 2 points. Block: 1. Counter: 3 (risky). You need 4 to win.");
setTimeout(() => { this.round = 3; this.startRound(); }, 3500);
} else if (!practice && this.round >= 5) {
this.endGame();
} else {
this.round++;
this.startRound();
}
}, 2500);
}, 500);
}

endGame() {
this.gameOver = true;
var won = this.score >= 4;
var endEl = document.getElementById('fight-end');
var inst = document.getElementById('fight-instructions');
if (inst) inst.style.display = 'none';

if (won) {
endEl.innerHTML = '<span style="color:#aaffaa;text-shadow:0 0 15px rgba(170,255,170,0.6);">🤜 STANDING 🤜</span>';
this.showNarrative("'It's alright,' says Copper, 'Alright. Tell whoever sent you that I know that they sent you.'");
} else {
endEl.innerHTML = '<span style="color:#ffaaaa;text-shadow:0 0 10px rgba(255,170,170,0.4);">🤜 DOWN 🤜</span>';
this.showNarrative("'You're lucky that Quiet Frankie hasn't killed you. He would have if I wanted him to. Now, fuck off.'");
}

setTimeout(function() {
var btn = document.createElement('button');
btn.id = 'fight-continue-btn';
btn.textContent = won ? 'Get out' : 'Try to get up';
btn.onclick = function() {
var targetId = won ? 'go-fight-victory' : 'go-fight-defeat';
var link = document.querySelector('#' + targetId + ' tw-link');
if (link) link.click();
};
endEl.appendChild(document.createElement('br'));
endEl.appendChild(btn);
}, 2000);
}

updateRoundDisplay() {
var el = document.getElementById('round-display');
if (!el) return;
if (this.isPractice()) {
el.textContent = '🤜 PRACTICE ' + (this.round + 1) + '/3 🤜';
} else {
var r = this.realRoundIndex() + 1;
el.textContent = '🤜 ROUND ' + r + ' — Score: ' + this.score + '/4 🤜';
}
}

showNarrative(text) {
var el = document.getElementById('fight-narrative');
if (el) { el.style.opacity = '1'; el.textContent = text; }
}

clearNarrative() {
var el = document.getElementById('fight-narrative');
if (el) el.style.opacity = '0';
}

showResult(text, cls) {
var el = document.getElementById('round-display');
if (!el) return;
var col = cls === 'win' ? '#aaffaa' : cls === 'lose' ? '#ffaaaa' : '#eeddaa';
if (this.isPractice()) {
el.innerHTML = '🤜 <span style="color:' + col + ';">' + text + '</span> — PRACTICE 🤜';
} else {
el.innerHTML = '🤜 <span style="color:' + col + ';">' + text + '</span> — Score: ' + this.score + '/4 🤜';
}
}

draw() {
var ctx = this.ctx;
var W = this.W, H = this.H;

ctx.fillStyle = '#0e0808';
ctx.fillRect(0, 0, W, H);

ctx.strokeStyle = '#1e1212';
ctx.lineWidth = 0.5;
for (var row = 0; row < H; row += 30) {
ctx.beginPath(); ctx.moveTo(0, row); ctx.lineTo(W, row); ctx.stroke();
var off = (Math.floor(row / 30) % 2) * 35;
for (var col = off; col < W; col += 70) {
ctx.beginPath(); ctx.moveTo(col, row); ctx.lineTo(col, row + 30); ctx.stroke();
}
}

var lg = ctx.createRadialGradient(W / 2, -20, 10, W / 2, -20, 350);
lg.addColorStop(0, 'rgba(180, 140, 80, 0.10)');
lg.addColorStop(1, 'rgba(0, 0, 0, 0)');
ctx.fillStyle = lg;
ctx.fillRect(0, 0, W, H);

this.drawCopper(ctx);

if (this.phase === 'telegraph' && this.clickable) {
this.drawPunchPath(ctx);
this.drawZones(ctx);
this.drawTimerBar(ctx);
}

if (this.phase === 'result' && this.resultFlash > 0) {
this.resultFlash -= 0.02;
if (this.resultClass === 'win') ctx.fillStyle = 'rgba(170, 255, 170, ' + (this.resultFlash * 0.08) + ')';
else if (this.resultClass === 'lose') ctx.fillStyle = 'rgba(255, 100, 100, ' + (this.resultFlash * 0.1) + ')';
else ctx.fillStyle = 'rgba(220, 200, 120, ' + (this.resultFlash * 0.06) + ')';
ctx.fillRect(0, 0, W, H);
}

if (this.sobriety < 35) {
var str = (35 - this.sobriety) / 35;
var vig = ctx.createRadialGradient(W/2, H/2, H*0.2, W/2, H/2, H*0.6);
vig.addColorStop(0, 'rgba(0,0,0,0)');
vig.addColorStop(1, 'rgba(0,0,0,' + (str * 0.45) + ')');
ctx.fillStyle = vig;
ctx.fillRect(0, 0, W, H);
}
}

drawCopper(ctx) {
ctx.save();
var cx = this.copperBaseX;
var cy = this.copperBaseY;
var lean = 0, crouch = 0, fistPull = 0;

if (this.phase === 'telegraph') {
var t = Math.min((Date.now() - this.phaseTimer) / this.telegraphDuration, 1);
this.telegraphT = t;
if (this.punchType === 'right_cross') { lean = -35 * t; fistPull = t; }
else if (this.punchType === 'left_hook') { lean = 35 * t; fistPull = t; }
else if (this.punchType === 'uppercut') { crouch = 30 * t; fistPull = t; }
if (t >= 1 && !this.acted) this.timeOut();
}

if (this.phase === 'punching') {
var pt = Math.min((Date.now() - this.phaseTimer) / 500, 1);
this.punchT = pt;
cy += 40 * pt;
fistPull = 1 - pt;
}

cx += lean;
cy += crouch;

ctx.fillStyle = 'rgba(0,0,0,0.25)';
ctx.beginPath(); ctx.ellipse(this.copperBaseX, 340, 80, 18, 0, 0, Math.PI * 2); ctx.fill();

ctx.fillStyle = '#2e2018'; ctx.strokeStyle = '#4a3028'; ctx.lineWidth = 1.5;
ctx.beginPath();
ctx.moveTo(cx - 55, cy + 70); ctx.lineTo(cx - 60, cy + 230);
ctx.lineTo(cx + 60, cy + 230); ctx.lineTo(cx + 55, cy + 70);
ctx.closePath(); ctx.fill(); ctx.stroke();

ctx.fillStyle = '#2e2018';
ctx.beginPath(); ctx.ellipse(cx, cy + 75, 68, 22, 0, 0, Math.PI * 2); ctx.fill(); ctx.stroke();

// ═══ COPPER COLOUR CONSTANTS ═══
var SKIN = '#d4ac90', SKIN_SHADOW = '#b89078', SKIN_OUTLINE = '#a07a65', SKIN_DARK = '#907060';
var HAIR = '#2a1e14', HAIR_HI = '#3e3020';

// ═══ NECK ═══
ctx.fillStyle = SKIN; ctx.fillRect(cx - 14, cy + 38, 28, 38);

// ═══ HEAD — larger, more detailed ═══
ctx.fillStyle = SKIN;
ctx.beginPath(); ctx.ellipse(cx, cy + 15, 35, 40, 0, 0, Math.PI * 2); ctx.fill();
ctx.strokeStyle = SKIN_OUTLINE; ctx.lineWidth = 1; ctx.stroke();
// Jaw definition
ctx.strokeStyle = SKIN_OUTLINE; ctx.lineWidth = 1.5;
ctx.beginPath();
ctx.moveTo(cx - 34, cy + 10);
ctx.lineTo(cx - 34, cy + 30);
ctx.quadraticCurveTo(cx - 30, cy + 44, cx - 18, cy + 44);
ctx.lineTo(cx + 18, cy + 44);
ctx.quadraticCurveTo(cx + 30, cy + 44, cx + 34, cy + 30);
ctx.lineTo(cx + 34, cy + 10);
ctx.stroke();

// ═══ HAIR — short-back-and-sides with quiff, M-shaped receding hairline ═══
ctx.fillStyle = HAIR;
ctx.beginPath();
ctx.moveTo(cx - 36, cy + 22);
ctx.lineTo(cx - 37, cy + 6); ctx.lineTo(cx - 37, cy - 4);
ctx.quadraticCurveTo(cx - 36, cy - 18, cx - 24, cy - 26);
ctx.quadraticCurveTo(cx - 10, cy - 30, cx, cy - 30);
ctx.quadraticCurveTo(cx + 10, cy - 30, cx + 24, cy - 26);
ctx.quadraticCurveTo(cx + 36, cy - 18, cx + 37, cy - 4);
ctx.lineTo(cx + 37, cy + 6); ctx.lineTo(cx + 36, cy + 22);
// M-shaped hairline
ctx.lineTo(cx + 30, cy + 2);
ctx.quadraticCurveTo(cx + 26, cy - 2, cx + 20, cy - 6);
ctx.quadraticCurveTo(cx + 10, cy - 12, cx + 4, cy - 10);
ctx.quadraticCurveTo(cx, cy - 13, cx - 4, cy - 10);
ctx.quadraticCurveTo(cx - 10, cy - 12, cx - 20, cy - 6);
ctx.quadraticCurveTo(cx - 26, cy - 2, cx - 30, cy + 2);
ctx.closePath(); ctx.fill();

// Quiff
ctx.fillStyle = HAIR;
ctx.beginPath();
ctx.moveTo(cx - 16, cy - 10);
ctx.quadraticCurveTo(cx - 14, cy - 22, cx - 8, cy - 36);
ctx.quadraticCurveTo(cx - 2, cy - 44, cx + 8, cy - 40);
ctx.quadraticCurveTo(cx + 16, cy - 34, cx + 22, cy - 22);
ctx.quadraticCurveTo(cx + 24, cy - 14, cx + 18, cy - 8);
ctx.quadraticCurveTo(cx + 4, cy - 14, cx - 4, cy - 14);
ctx.quadraticCurveTo(cx - 10, cy - 13, cx - 16, cy - 10);
ctx.closePath(); ctx.fill();
// Brylcreem highlight
ctx.strokeStyle = HAIR_HI; ctx.lineWidth = 2.5;
ctx.beginPath(); ctx.moveTo(cx - 10, cy - 16);
ctx.quadraticCurveTo(cx - 6, cy - 30, cx + 2, cy - 38);
ctx.quadraticCurveTo(cx + 10, cy - 36, cx + 18, cy - 24); ctx.stroke();
ctx.strokeStyle = 'rgba(190, 170, 140, 0.3)'; ctx.lineWidth = 1.5;
ctx.beginPath(); ctx.moveTo(cx - 4, cy - 22);
ctx.quadraticCurveTo(cx, cy - 34, cx + 6, cy - 36); ctx.stroke();

// Grey temple streaks
ctx.strokeStyle = 'rgba(140, 135, 125, 0.4)'; ctx.lineWidth = 2;
ctx.beginPath(); ctx.moveTo(cx - 34, cy + 2); ctx.lineTo(cx - 30, cy - 4); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 35, cy + 6); ctx.lineTo(cx - 32, cy + 0); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 34, cy + 2); ctx.lineTo(cx + 30, cy - 4); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 35, cy + 6); ctx.lineTo(cx + 32, cy + 0); ctx.stroke();
// Hair parting
ctx.strokeStyle = 'rgba(15, 10, 6, 0.5)'; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 18, cy - 8);
ctx.quadraticCurveTo(cx - 22, cy - 16, cx - 22, cy - 24); ctx.stroke();

// Sideburns
ctx.fillStyle = HAIR;
ctx.beginPath(); ctx.moveTo(cx - 35, cy + 8); ctx.lineTo(cx - 36, cy + 24);
ctx.lineTo(cx - 33, cy + 24); ctx.lineTo(cx - 34, cy + 8); ctx.closePath(); ctx.fill();
ctx.beginPath(); ctx.moveTo(cx + 35, cy + 8); ctx.lineTo(cx + 36, cy + 24);
ctx.lineTo(cx + 33, cy + 24); ctx.lineTo(cx + 34, cy + 8); ctx.closePath(); ctx.fill();

// ═══ EARS — cauliflower bumps ═══
ctx.fillStyle = SKIN; ctx.strokeStyle = SKIN_OUTLINE; ctx.lineWidth = 1;
ctx.beginPath(); ctx.ellipse(cx - 37, cy + 12, 6, 10, -0.2, 0, Math.PI * 2); ctx.fill(); ctx.stroke();
ctx.beginPath(); ctx.ellipse(cx + 37, cy + 12, 6, 10, 0.2, 0, Math.PI * 2); ctx.fill(); ctx.stroke();
ctx.fillStyle = SKIN_OUTLINE;
ctx.beginPath(); ctx.arc(cx - 39, cy + 14, 2.5, 0, Math.PI * 2); ctx.fill();
ctx.beginPath(); ctx.arc(cx + 39, cy + 14, 2.5, 0, Math.PI * 2); ctx.fill();

// ═══ FOREHEAD WRINKLES ═══
ctx.strokeStyle = SKIN_SHADOW; ctx.lineWidth = 1.2;
ctx.beginPath(); ctx.moveTo(cx - 18, cy - 4); ctx.quadraticCurveTo(cx, cy - 5.5, cx + 18, cy - 4); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 16, cy - 8); ctx.quadraticCurveTo(cx, cy - 9.5, cx + 16, cy - 8); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 13, cy - 12); ctx.quadraticCurveTo(cx, cy - 13, cx + 13, cy - 12); ctx.stroke();
// Frown furrows
ctx.lineWidth = 1.5;
ctx.beginPath(); ctx.moveTo(cx - 5, cy - 2); ctx.lineTo(cx - 4, cy + 5); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 5, cy - 2); ctx.lineTo(cx + 4, cy + 5); ctx.stroke();

// ═══ EYEBROWS — V-shaped, threatening ═══
ctx.fillStyle = HAIR;
ctx.beginPath(); ctx.moveTo(cx - 26, cy + 2);
ctx.quadraticCurveTo(cx - 18, cy - 1, cx - 8, cy + 5);
ctx.lineTo(cx - 6, cy + 8);
ctx.quadraticCurveTo(cx - 16, cy + 4, cx - 26, cy + 6);
ctx.closePath(); ctx.fill();
ctx.strokeStyle = HAIR; ctx.lineWidth = 1.8;
ctx.beginPath(); ctx.moveTo(cx - 24, cy + 1); ctx.lineTo(cx - 17, cy - 1); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 20, cy + 1); ctx.lineTo(cx - 12, cy + 1); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 14, cy + 2); ctx.lineTo(cx - 9, cy + 4); ctx.stroke();
ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 26, cy + 3); ctx.lineTo(cx - 29, cy + 0); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 24, cy + 2); ctx.lineTo(cx - 27, cy - 2); ctx.stroke();
// Right eyebrow
ctx.fillStyle = HAIR;
ctx.beginPath(); ctx.moveTo(cx + 26, cy + 2);
ctx.quadraticCurveTo(cx + 18, cy - 1, cx + 8, cy + 5);
ctx.lineTo(cx + 6, cy + 8);
ctx.quadraticCurveTo(cx + 16, cy + 4, cx + 26, cy + 6);
ctx.closePath(); ctx.fill();
ctx.strokeStyle = HAIR; ctx.lineWidth = 1.8;
ctx.beginPath(); ctx.moveTo(cx + 24, cy + 1); ctx.lineTo(cx + 17, cy - 1); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 20, cy + 1); ctx.lineTo(cx + 12, cy + 1); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 14, cy + 2); ctx.lineTo(cx + 9, cy + 4); ctx.stroke();
ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx + 26, cy + 3); ctx.lineTo(cx + 29, cy + 0); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 24, cy + 2); ctx.lineTo(cx + 27, cy - 2); ctx.stroke();

// ═══ EYES — narrow mean slits ═══
ctx.fillStyle = '#d0c8b8';
ctx.beginPath(); ctx.ellipse(cx - 14, cy + 12, 6, 2, -0.05, 0, Math.PI * 2); ctx.fill();
ctx.beginPath(); ctx.ellipse(cx + 14, cy + 12, 6, 2, 0.05, 0, Math.PI * 2); ctx.fill();
ctx.fillStyle = '#1a0a08';
ctx.beginPath(); ctx.ellipse(cx - 14, cy + 12, 3, 2, 0, 0, Math.PI * 2); ctx.fill();
ctx.beginPath(); ctx.ellipse(cx + 14, cy + 12, 3, 2, 0, 0, Math.PI * 2); ctx.fill();
// Heavy drooping eyelids
ctx.strokeStyle = SKIN_SHADOW; ctx.lineWidth = 2.5;
ctx.beginPath(); ctx.moveTo(cx - 21, cy + 10); ctx.quadraticCurveTo(cx - 14, cy + 7.5, cx - 7, cy + 10); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 7, cy + 10); ctx.quadraticCurveTo(cx + 14, cy + 7.5, cx + 21, cy + 10); ctx.stroke();
// Under-eye bags
ctx.lineWidth = 1.2;
ctx.beginPath(); ctx.moveTo(cx - 20, cy + 14); ctx.quadraticCurveTo(cx - 14, cy + 17, cx - 8, cy + 14); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 8, cy + 14); ctx.quadraticCurveTo(cx + 14, cy + 17, cx + 20, cy + 14); ctx.stroke();
ctx.lineWidth = 0.8;
ctx.beginPath(); ctx.moveTo(cx - 19, cy + 16); ctx.quadraticCurveTo(cx - 14, cy + 18.5, cx - 9, cy + 16); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 9, cy + 16); ctx.quadraticCurveTo(cx + 14, cy + 18.5, cx + 19, cy + 16); ctx.stroke();

// ═══ CROW'S FEET ═══
ctx.strokeStyle = SKIN_SHADOW; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 21, cy + 10); ctx.lineTo(cx - 26, cy + 6); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 21, cy + 11); ctx.lineTo(cx - 27, cy + 10); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 21, cy + 13); ctx.lineTo(cx - 26, cy + 15); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 21, cy + 10); ctx.lineTo(cx + 26, cy + 6); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 21, cy + 11); ctx.lineTo(cx + 27, cy + 10); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 21, cy + 13); ctx.lineTo(cx + 26, cy + 15); ctx.stroke();

// ═══ NOSE — battered, broader ═══
ctx.strokeStyle = SKIN_OUTLINE; ctx.lineWidth = 2;
ctx.beginPath(); ctx.moveTo(cx - 1, cy + 12); ctx.quadraticCurveTo(cx - 5, cy + 22, cx - 7, cy + 26); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 2, cy + 12); ctx.quadraticCurveTo(cx + 3, cy + 22, cx + 6, cy + 26); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx - 10, cy + 28); ctx.quadraticCurveTo(cx, cy + 31, cx + 10, cy + 28); ctx.stroke();
ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 3, cy + 18); ctx.quadraticCurveTo(cx - 5, cy + 20, cx - 3, cy + 22); ctx.stroke();

// ═══ NASOLABIAL FOLDS ═══
ctx.strokeStyle = SKIN_SHADOW; ctx.lineWidth = 1.5;
ctx.beginPath(); ctx.moveTo(cx - 10, cy + 27); ctx.quadraticCurveTo(cx - 14, cy + 32, cx - 15, cy + 38); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 10, cy + 27); ctx.quadraticCurveTo(cx + 14, cy + 32, cx + 15, cy + 38); ctx.stroke();

// ═══ SCARS ═══
ctx.strokeStyle = '#d49898'; ctx.lineWidth = 2;
ctx.beginPath(); ctx.moveTo(cx - 24, cy + 16); ctx.lineTo(cx - 13, cy + 27); ctx.stroke();
ctx.lineWidth = 1.2;
ctx.beginPath(); ctx.moveTo(cx + 18, cy + 20); ctx.lineTo(cx + 22, cy + 24); ctx.stroke();

// ═══ MOUTH — mean downturned scowl ═══
ctx.strokeStyle = SKIN_DARK; ctx.lineWidth = 2.5;
ctx.beginPath(); ctx.moveTo(cx - 14, cy + 37);
ctx.quadraticCurveTo(cx - 5, cy + 35, cx, cy + 36);
ctx.quadraticCurveTo(cx + 5, cy + 35, cx + 14, cy + 37); ctx.stroke();
ctx.lineWidth = 2;
ctx.beginPath(); ctx.moveTo(cx - 14, cy + 37); ctx.quadraticCurveTo(cx - 16, cy + 39, cx - 17, cy + 40); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 14, cy + 37); ctx.quadraticCurveTo(cx + 16, cy + 39, cx + 17, cy + 40); ctx.stroke();
ctx.strokeStyle = SKIN_SHADOW; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 10, cy + 39); ctx.quadraticCurveTo(cx, cy + 41, cx + 10, cy + 39); ctx.stroke();

// ═══ HEAVY STUBBLE ═══
ctx.fillStyle = 'rgba(50, 35, 25, 0.25)';
for (var si = 0; si < 200; si++) {
var sx = cx + (Math.random() - 0.5) * 62;
var sy2 = cy + 28 + Math.random() * 18;
var dx = Math.abs(sx - cx);
if (dx < 34 && sy2 > cy + 28) { ctx.beginPath(); ctx.arc(sx, sy2, 0.7 + Math.random() * 0.3, 0, Math.PI * 2); ctx.fill(); }
}
ctx.fillStyle = 'rgba(50, 35, 25, 0.3)';
for (var sj = 0; sj < 60; sj++) {
var sx3 = cx + (Math.random() - 0.5) * 30;
var sy3 = cy + 38 + Math.random() * 10;
ctx.beginPath(); ctx.arc(sx3, sy3, 0.5 + Math.random() * 0.3, 0, Math.PI * 2); ctx.fill();
}

var lfx = cx - 65, lfy = cy + 140;
var rfx = cx + 65, rfy = cy + 140;

var glowPulse = 0.5 + 0.5 * Math.sin(Date.now() / 100);
var glowStrength = fistPull;

var glowAlpha = glowStrength;
if (!this.isPractice()) {
if (this.sobriety < 25) glowAlpha *= 0.5;
else if (this.sobriety < 50) glowAlpha *= 0.7;
}

if (this.punchType === 'right_cross') {
rfx = cx + 65 + 30 * fistPull;
rfy = cy + 130 - 25 * fistPull;

if (this.phase === 'punching') {
rfx = cx + 65 + 30 * (1 - this.punchT) - 60 * this.punchT;
rfy = cy + 105 + 95 * this.punchT;
var fs = 1 + 1.2 * this.punchT;
this.drawFist(ctx, rfx, rfy, 16 * fs, 20 * fs, -0.2, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, glowAlpha * glowPulse);

} else if (this.punchType === 'left_hook') {
lfx = cx - 65 - 30 * fistPull;
lfy = cy + 130 - 25 * fistPull;

if (this.phase === 'punching') {
lfx = cx - 65 - 30 * (1 - this.punchT) + 60 * this.punchT;
lfy = cy + 105 + 95 * this.punchT;
var fs = 1 + 1.2 * this.punchT;
this.drawFist(ctx, lfx, lfy, 16 * fs, 20 * fs, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, glowAlpha * glowPulse);

} else if (this.punchType === 'uppercut') {
rfx = cx + 30;
rfy = cy + 160 + 35 * fistPull;

if (this.phase === 'punching') {
rfx = cx + 30 * (1 - this.punchT);
rfy = cy + 195 - 110 * this.punchT;
var fs = 1 + 1.5 * this.punchT;
this.drawFist(ctx, rfx, rfy, 16 * fs, 20 * fs, 0, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, 0, glowAlpha * glowPulse);

} else {
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
}

ctx.restore();
}

drawFist(ctx, x, y, rx, ry, rot, glow) {
if (glow > 0.05) {
ctx.save();
var glowR = Math.max(rx, ry) * 2.5;
var grad = ctx.createRadialGradient(x, y, 0, x, y, glowR);
grad.addColorStop(0, 'rgba(255, 100, 50, ' + (glow * 0.6) + ')');
grad.addColorStop(0.5, 'rgba(255, 60, 30, ' + (glow * 0.3) + ')');
grad.addColorStop(1, 'rgba(255, 30, 10, 0)');
ctx.fillStyle = grad;
ctx.beginPath();
ctx.ellipse(x, y, glowR, glowR, 0, 0, Math.PI * 2);
ctx.fill();
ctx.restore();
}

ctx.fillStyle = glow > 0.05 ? '#e0b898' : '#d4ac90';
ctx.beginPath();
ctx.ellipse(x, y, rx, ry, rot, 0, Math.PI * 2);
ctx.fill();
ctx.strokeStyle = glow > 0.05 ? '#cc6040' : '#a07a65';
ctx.lineWidth = 1.5;
ctx.stroke();

ctx.strokeStyle = glow > 0.05 ? '#bb6545' : '#a07a65';
ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(x - 6, y - 3); ctx.lineTo(x + 6, y - 3); ctx.stroke();
}

drawPunchPath(ctx) {
var t = this.telegraphT;
if (t < 0.15) return;
var progress = Math.min((t - 0.15) / 0.6, 1);

var pulse = 0.5 + 0.5 * Math.sin(Date.now() / 130);
var alpha = progress * 0.55 * pulse;

if (!this.isPractice()) {
if (this.sobriety < 25) alpha *= 0.4;
else if (this.sobriety < 50) alpha *= 0.65;
}

ctx.save();
ctx.strokeStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.fillStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.lineWidth = 2.5;
ctx.setLineDash([8, 6]);

var W = this.W, H = this.H;
var cx = this.copperBaseX;
var lean = 0, crouch = 0;
if (this.punchType === 'right_cross') lean = -35 * Math.min(t, 1);
else if (this.punchType === 'left_hook') lean = 35 * Math.min(t, 1);
else if (this.punchType === 'uppercut') crouch = 30 * Math.min(t, 1);

cx += lean;
var cy = this.copperBaseY + crouch;

if (this.punchType === 'right_cross') {
var fx = cx + 65 + 30 * t;
var fy = cy + 130 - 25 * t;
var landX = 100;
var landY = H * 0.75;
var cpx = W * 0.35;
var cpy = fy + 40;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(cpx, cpy, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, cpx, cpy, landX, landY, alpha);

} else if (this.punchType === 'left_hook') {
var fx = cx - 65 - 30 * t;
var fy = cy + 130 - 25 * t;
var landX = W - 100;
var landY = H * 0.75;
var cpx = W * 0.65;
var cpy = fy + 40;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(cpx, cpy, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, cpx, cpy, landX, landY, alpha);

} else if (this.punchType === 'uppercut') {
var fx = cx + 30;
var fy = cy + 160 + 35 * t;
var landX = W / 2;
var landY = H * 0.85;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(fx - 10, landY - 20, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, fx - 10, landY - 20, landX, landY, alpha);
}

ctx.setLineDash([]);
ctx.restore();
}

drawPathArrowhead(ctx, cpx, cpy, tx, ty, alpha) {
var angle = Math.atan2(ty - cpy, tx - cpx);
var headLen = 14;
ctx.setLineDash([]);
ctx.fillStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.beginPath();
ctx.moveTo(tx, ty);
ctx.lineTo(tx - headLen * Math.cos(angle - 0.45), ty - headLen * Math.sin(angle - 0.45));
ctx.lineTo(tx - headLen * Math.cos(angle + 0.45), ty - headLen * Math.sin(angle + 0.45));
ctx.closePath();
ctx.fill();
}

drawTimerBar(ctx) {
var t = this.telegraphT;
var remaining = 1 - t;
var barW = this.W * remaining;
var pulse = 0.4 + 0.6 * Math.abs(Math.sin(Date.now() / 120));

ctx.fillStyle = 'rgba(234, 100, 100, 0.5)';
ctx.fillRect((this.W - barW) / 2, this.H - 10, barW, 5);
if (remaining < 0.3) {
ctx.fillStyle = 'rgba(255, 50, 50, ' + (0.3 + 0.7 * pulse) * 0.5 + ')';
ctx.fillRect((this.W - barW) / 2, this.H - 10, barW, 5);
}
}

drawZones(ctx) {
var alpha = 0.05;
var ha = 0.18;
var practice = this.isPractice();
var correct = this.getCorrectDodge();

var hintAlpha = practice ? 0.22 + 0.08 * Math.sin(Date.now() / 200) : 0;

var a = this.hoveredZone === 'dodge_left' ? ha : alpha;
if (practice && (correct === 'dodge_left' || correct === 'either')) a = Math.max(a, hintAlpha);
ctx.fillStyle = 'rgba(170, 255, 170, ' + a + ')';
this.roundRect(ctx, 10, 130, 115, 210, 8); ctx.fill();
ctx.strokeStyle = 'rgba(170, 255, 170, ' + (a + 0.1) + ')'; ctx.lineWidth = 1; ctx.stroke();
ctx.font = '13px Georgia';
ctx.fillStyle = 'rgba(170, 255, 170, ' + (this.hoveredZone === 'dodge_left' ? 0.9 : (practice && (correct === 'dodge_left' || correct === 'either') ? 0.7 : 0.3)) + ')';
ctx.textAlign = 'center';
ctx.fillText('← DODGE', 67, 240);

a = this.hoveredZone === 'dodge_right' ? ha : alpha;
if (practice && (correct === 'dodge_right' || correct === 'either')) a = Math.max(a, hintAlpha);
ctx.fillStyle = 'rgba(170, 255, 170, ' + a + ')';
this.roundRect(ctx, this.W - 125, 130, 115, 210, 8); ctx.fill();
ctx.strokeStyle = 'rgba(170, 255, 170, ' + (a + 0.1) + ')'; ctx.stroke();
ctx.fillStyle = 'rgba(170, 255, 170, ' + (this.hoveredZone === 'dodge_right' ? 0.9 : (practice && (correct === 'dodge_right' || correct === 'either') ? 0.7 : 0.3)) + ')';
ctx.fillText('DODGE →', this.W - 67, 240);

a = this.hoveredZone === 'block' ? ha : alpha;
ctx.fillStyle = 'rgba(220, 200, 120, ' + a + ')';
this.roundRect(ctx, 155, 335, this.W - 310, 55, 8); ctx.fill();
ctx.strokeStyle = 'rgba(220, 200, 120, ' + (a + 0.1) + ')'; ctx.stroke();
ctx.fillStyle = 'rgba(220, 200, 120, ' + (this.hoveredZone === 'block' ? 0.9 : 0.3) + ')';
ctx.fillText('BLOCK', this.W / 2, 367);

a = this.hoveredZone === 'counter' ? ha : alpha;
ctx.fillStyle = 'rgba(255, 150, 100, ' + a + ')';
ctx.beginPath(); ctx.ellipse(this.W / 2, 190, 60, 65, 0, 0, Math.PI * 2); ctx.fill();
ctx.strokeStyle = 'rgba(255, 150, 100, ' + (a + 0.1) + ')'; ctx.lineWidth = 1; ctx.stroke();
ctx.fillStyle = 'rgba(255, 150, 100, ' + (this.hoveredZone === 'counter' ? 0.9 : 0.3) + ')';
ctx.fillText('COUNTER', this.W / 2, 195);
}

roundRect(ctx, x, y, w, h, r) {
ctx.beginPath();
ctx.moveTo(x + r, y);
ctx.lineTo(x + w - r, y);
ctx.quadraticCurveTo(x + w, y, x + w, y + r);
ctx.lineTo(x + w, y + h - r);
ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
ctx.lineTo(x + r, y + h);
ctx.quadraticCurveTo(x, y + h, x, y + h - r);
ctx.lineTo(x, y + r);
ctx.quadraticCurveTo(x, y, x + r, y);
ctx.closePath();
}

loop() {
this.draw();
if (!this.gameOver) {
requestAnimationFrame(() => this.loop());
}
}
};

window.startFightGame = function() {
document.getElementById('pre-fight').style.display = 'none';
document.getElementById('fight-arena').style.display = 'block';
var sobriety = parseInt(document.getElementById('sob-data').textContent) || 55;
new window.FightGame('fight-canvas', sobriety);
};

// ====== TYPEWRITER EFFECT ======
(function() {
function typewriterEffect(container) {
var textEntries = [];
// Gather all tw-expression elements (Harlowe links) to hide
var linkEls = container.querySelectorAll('tw-expression');
linkEls.forEach(function(el) {
el.style.opacity = '0';
el.style.transition = 'none';
el.style.pointerEvents = 'none';
});

function collectTextNodes(el) {
var children = el.childNodes;
for (var i = 0; i < children.length; i++) {
var child = children[i];
// Skip Harlowe link expressions — revealed after typing
if (child.nodeType === 1 && child.tagName === 'TW-EXPRESSION') continue;
// Skip flash-reveal elements — triggered separately after typing completes
if (child.nodeType === 1 && child.classList && child.classList.contains('flash-reveal')) continue;
if (child.nodeType === 3) {
var text = child.textContent;
if (text.length > 0) {
textEntries.push({ node: child, fullText: text });
child.textContent = '';
}
} else if (child.nodeType === 1) {
collectTextNodes(child);
}
}
}

collectTextNodes(container);

// Build flat character queue
var queue = [];
for (var t = 0; t < textEntries.length; t++) {
for (var c = 0; c < textEntries[t].fullText.length; c++) {
queue.push({ entryIdx: t, char: textEntries[t].fullText[c] });
}
}

// Create block cursor
var cursor = document.createElement('span');
cursor.className = 'tw-cursor';
cursor.textContent = '\u2588';
container.appendChild(cursor);

var qIdx = 0;
var baseSpeed = 25;

function typeNext() {
if (qIdx >= queue.length) {
// Typing complete — fade cursor, reveal link
cursor.classList.add('tw-cursor-fade');
setTimeout(function() {
cursor.style.display = 'none';
linkEls.forEach(function(el) {
el.style.transition = 'opacity 1.2s ease-in';
el.style.opacity = '1';
el.style.pointerEvents = 'auto';
});
// Trigger flash-reveal elements after typing completes
var flashEls = container.querySelectorAll('.flash-reveal');
flashEls.forEach(function(el) {
el.classList.add('flash-reveal-active');
});
}, 800);
return;
}

var item = queue[qIdx];
var textNode = textEntries[item.entryIdx].node;
textNode.textContent += item.char;
qIdx++;

// Move cursor to follow the typing position
var parent = textNode.parentNode;
if (parent && textNode.nextSibling !== cursor) {
parent.insertBefore(cursor, textNode.nextSibling);
}

// Variable speed — just ahead of reading
var ch = item.char;
var delay = baseSpeed;
if (ch === '.' || ch === '?' || ch === '!') delay = 280;
else if (ch === ',' || ch === ';' || ch === ':') delay = 110;
else if (ch === '\n') delay = 180;
else delay = baseSpeed + Math.floor(Math.random() * 12) - 4;

setTimeout(typeNext, delay);
}

// Brief pause before typing starts
setTimeout(typeNext, 900);
}

// Watch for .typewriter-page appearing in the DOM
var observer = new MutationObserver(function() {
var page = document.querySelector('.typewriter-page');
if (page && !page.dataset.twTyping) {
page.dataset.twTyping = 'true';
// Force Courier on the container and every child element
var twFont = "'Courier New', Courier, monospace";
page.style.fontFamily = twFont;
var allEls = page.querySelectorAll('*');
for (var k = 0; k < allEls.length; k++) {
allEls[k].style.fontFamily = twFont;
}
// TESTING MODE: skip typewriter, show everything immediately
// To re-enable typewriter effect, change skipTypewriter to false
var skipTypewriter = false;
if (skipTypewriter) {
// Just make sure the link is visible straight away
var linkEls = page.querySelectorAll('tw-expression');
linkEls.forEach(function(el) {
el.style.opacity = '1';
el.style.pointerEvents = 'auto';
});
} else {
// Small delay to let Harlowe finish rendering
setTimeout(function() { typewriterEffect(page); }, 100);
}
}
});

observer.observe(document.body, { childList: true, subtree: true });
})();

// ====== AUTO-GLOW SOLO LINK ======
// If a passage has exactly one active link (not greyed-out, not already
// a guided-link), glow it — same pulse as a manually-marked guided-link.
(function() {
var soloDebounce = null;
function checkSoloLink() {
var passage = document.querySelector('tw-passage');
if (!passage) return;
var allLinks = Array.from(passage.querySelectorAll('tw-link'));
allLinks.forEach(function(l) { l.classList.remove('auto-guided'); });
var active = allLinks.filter(function(l) {
return !l.closest('.greyed-out') && !l.closest('.guided-link') && !l.closest('.notebook-link');
});
if (active.length === 1) {
active[0].classList.add('auto-guided');
}
}
new MutationObserver(function() {
clearTimeout(soloDebounce);
soloDebounce = setTimeout(checkSoloLink, 350);
}).observe(document.body, { childList: true, subtree: true });
})();

// ====== DEAN STREET LAMP DYNAMIC HEIGHT ======
// The pole must end exactly at the bottom of the last visible text or link
// on the page. We measure by finding the actual bottom pixel of the last
// visible content element, ignoring padding, empty hooks, and the lamp itself.
(function() {
var sizeTimer = null;

function findContentBottom(passage, lamp) {
var passageTop = passage.getBoundingClientRect().top;
var maxBottom = passageTop; // start at top
var els = passage.getElementsByTagName('*');
for (var i = 0; i < els.length; i++) {
var el = els[i];
// Skip the lamp SVG and anything inside it
if (el === lamp || lamp.contains(el)) continue;
// Skip hidden elements
var cs = window.getComputedStyle(el);
if (cs.display === 'none' || cs.visibility === 'hidden') continue;
var rect = el.getBoundingClientRect();
// Skip zero-size elements (empty hooks, collapsed whitespace)
if (rect.height === 0 || rect.width === 0) continue;
if (rect.bottom > maxBottom) maxBottom = rect.bottom;
}
return maxBottom - passageTop;
}

function sizeLamp() {
var lamp = document.getElementById('dean-lamp-svg');
var passage = document.querySelector('tw-passage');
if (!lamp || !passage || !lamp.parentNode) return;

// Pass 1: shrink float, measure natural content bottom
lamp.setAttribute('height', '1');
var h = findContentBottom(passage, lamp);
if (h < 50) h = 50;
lamp.setAttribute('height', Math.ceil(h));

// Pass 2: with float active text reflows — re-measure
requestAnimationFrame(function() {
var h2 = findContentBottom(passage, lamp);
if (h2 < 50) h2 = 50;
lamp.setAttribute('height', Math.ceil(h2));
});
}

// Debounced: waits 600ms after last DOM change (after gap cleanup at 300ms)
var deanLampObs = new MutationObserver(function() {
if (!document.getElementById('dean-lamp-svg')) return;
if (sizeTimer) clearTimeout(sizeTimer);
sizeTimer = setTimeout(sizeLamp, 600);
});
deanLampObs.observe(document.body, { childList: true, subtree: true });
})();

// ====== WHITESPACE GAP CLEANUP ======
// When Harlowe conditionals evaluate to false, the hooks are hidden but
// <br> elements between them remain visible, creating blank gaps.
// This aggressively collapses BR runs to max 1 between hidden blocks,
// and also trims trailing BRs at the end of passages (gap before links).
(function() {
function cleanGaps() {
var passage = document.querySelector('tw-passage');
if (!passage || passage.dataset.gapCleaned) return;
passage.dataset.gapCleaned = '1';

// Walk the passage DOM and find "effective BR runs" — sequences of <br>
// elements with only invisible nodes between them
cleanContainer(passage);

// Also clean inside visible tw-hooks (nested conditionals)
var hooks = passage.querySelectorAll('tw-hook');
for (var h = 0; h < hooks.length; h++) {
if (hooks[h].offsetParent !== null || window.getComputedStyle(hooks[h]).display !== 'none') {
cleanContainer(hooks[h]);
}
}

// Trim trailing BRs at end of passage (gap before final links)
trimTrailingBRs(passage);

// Trim trailing BRs inside visible hooks too
for (var h2 = 0; h2 < hooks.length; h2++) {
if (hooks[h2].offsetParent !== null || window.getComputedStyle(hooks[h2]).display !== 'none') {
trimTrailingBRs(hooks[h2]);
}
}
}

function cleanContainer(container) {
var nodes = [];
var child = container.firstChild;
while (child) { nodes.push(child); child = child.nextSibling; }

var i = 0;
while (i < nodes.length) {
if (isBR(nodes[i])) {
// Start of a potential BR run
var brIndices = [i];
var j = i + 1;
while (j < nodes.length) {
if (isBR(nodes[j])) {
brIndices.push(j);
j++;
} else if (isInvisibleNode(nodes[j])) {
j++;
} else {
break;
}
}

// Check if this BR run sits between two visible content blocks,
// or is adjacent to hidden blocks. Be more aggressive near hidden content.
var prevVisible = hasPrecedingVisibleContent(nodes, i);
var nextVisible = hasFollowingVisibleContent(nodes, j);

// Allow max 1 BR between content (single paragraph break).
// If the run borders hidden content, allow at most 1.
var maxBRs = (prevVisible && nextVisible) ? 1 : 1;
if (brIndices.length > maxBRs) {
for (var k = maxBRs; k < brIndices.length; k++) {
nodes[brIndices[k]].style.display = 'none';
}
}
i = j;
} else {
i++;
}
}
}

function trimTrailingBRs(container) {
// Walk backward from end, hiding BRs and invisible nodes
var nodes = [];
var child = container.firstChild;
while (child) { nodes.push(child); child = child.nextSibling; }

for (var i = nodes.length - 1; i >= 0; i--) {
if (isBR(nodes[i])) {
nodes[i].style.display = 'none';
} else if (isInvisibleNode(nodes[i])) {
continue;
} else {
break; // hit visible content, stop
}
}
}

function hasPrecedingVisibleContent(nodes, idx) {
for (var i = idx - 1; i >= 0; i--) {
if (!isInvisibleNode(nodes[i]) && !isBR(nodes[i])) return true;
if (isBR(nodes[i])) return false;
}
return false;
}

function hasFollowingVisibleContent(nodes, idx) {
for (var i = idx; i < nodes.length; i++) {
if (!isInvisibleNode(nodes[i]) && !isBR(nodes[i])) return true;
}
return false;
}

function isBR(node) {
return node && node.nodeType === 1 && node.tagName === 'BR';
}

function isInvisibleNode(node) {
if (node.nodeType === 3) return node.textContent.trim() === '';
if (node.nodeType !== 1) return true;
var tag = node.tagName;
var style = window.getComputedStyle(node);
if (style.display === 'none') return true;
// Hidden tw-hooks (Harlowe hides them with inline style)
if (tag === 'TW-HOOK' && node.getAttribute('style') &&
node.getAttribute('style').indexOf('display') !== -1 &&
style.display === 'none') return true;
// tw-expression wrapping only hidden content
if (tag === 'TW-EXPRESSION') {
var visibleChild = false;
var ch = node.firstChild;
while (ch) {
if (ch.nodeType === 1) {
var chStyle = window.getComputedStyle(ch);
if (chStyle.display !== 'none' && ch.textContent.trim() !== '') {
// Check if it has any visible tw-link or real content
if (ch.querySelector && ch.querySelector('tw-link, a, canvas, img, svg, button, input')) {
visibleChild = true; break;
}
if (ch.textContent.trim() !== '') { visibleChild = true; break; }
}
} else if (ch.nodeType === 3 && ch.textContent.trim() !== '') {
visibleChild = true; break;
}
ch = ch.nextSibling;
}
if (!visibleChild) return true;
}
// Check for empty elements with no meaningful content
if (node.textContent.trim() === '' &&
!node.querySelector('canvas, img, svg, button, input, tw-link, a')) {
return true;
}
return false;
}

// Run cleanup on each passage load — run twice to catch late-rendering hooks
var gapObs = new MutationObserver(function(mutations) {
for (var m = 0; m < mutations.length; m++) {
var added = mutations[m].addedNodes;
for (var n = 0; n < added.length; n++) {
if (added[n].nodeType === 1 &&
(added[n].tagName === 'TW-PASSAGE' ||
(added[n].querySelector && added[n].querySelector('tw-passage')))) {
setTimeout(cleanGaps, 200);
setTimeout(function() {
var p = document.querySelector('tw-passage');
if (p) { delete p.dataset.gapCleaned; cleanGaps(); }
}, 600);
return;
}
}
}
});
gapObs.observe(document.body, { childList: true, subtree: true });
})();

// ====== TEMPORARY BACK BUTTON (for testing) ======
(function() {
})();

// ====== GINGER LIGHT SCENE — INLINE ======
(function() {
var glActive = false;
var glAnimId = null;

function initGingerLight() {
if (glActive) return;
glActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildScene(); };
document.head.appendChild(s);
} else {
buildScene();
}
}

function buildScene() {
// Full-screen overlay
var glWrap = document.createElement('div');
glWrap.id = 'gl-wrap';
glWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#08080e;';

// Canvas for Three.js — must be sized before renderer init
var glCanvas = document.createElement('canvas');
glCanvas.width = window.innerWidth;
glCanvas.height = window.innerHeight;
glCanvas.style.cssText = 'display:block;position:absolute;top:0;left:0;';
glWrap.appendChild(glCanvas);

// Vignette overlay
var glVig = document.createElement('div');
glVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at center,rgba(0,0,0,0) 0%,rgba(0,0,0,0) 40%,rgba(0,0,0,0.25) 70%,rgba(0,0,0,0.6) 100%);';
glWrap.appendChild(glVig);

// Datestamp
var glDate = document.createElement('div');
glDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
glDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.55);pointer-events:none;z-index:9002;';
glWrap.appendChild(glDate);

// Location label
var glLoc = document.createElement('div');
glLoc.textContent = 'CORNER OF DEAN STREET AND GREEK STREET, SOHO';
glLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px \'Courier New\',monospace;color:rgba(200,180,140,0.4);letter-spacing:2px;pointer-events:none;z-index:9002;white-space:nowrap;';
glWrap.appendChild(glLoc);

document.body.appendChild(glWrap);

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x08080e);

// Deep Soho fog — swallows the far end of the streets
scene.fog = new THREE.Fog(0x08080e, 4, 32);

var camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT EXPLANATION
// ============================================================
// Street corner: Dean Street runs north-south (along Z axis)
// Greek Street joins from the east (along X axis)
// The hero streetlamp stands at the corner, slightly on the pavement
// Camera looks up slightly at the lamp from across the junction
// Buildings line both streets, fading into fog

camera.position.set(6.5, 2.2, 8);
camera.lookAt(0, 4.5, -1);

var renderer = new THREE.WebGLRenderer({ antialias: true, canvas: glCanvas });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.6;
// canvas already in overlay

window.addEventListener('resize', function() {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

// Store base camera position for subtle breathing sway
var cameraBase = { x: 6.5, y: 2.2, z: 8 };

// ============================================================
// MATERIALS
// ============================================================
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x3a2a22, roughness: 0.9 });
var creamWall = new THREE.MeshStandardMaterial({ color: 0xc8bfaa, roughness: 0.85 });
var greyStone = new THREE.MeshStandardMaterial({ color: 0x6a6560, roughness: 0.85 });
var sootBrick = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x6b3a2a, roughness: 0.85 });
var shopFront = new THREE.MeshStandardMaterial({ color: 0x1a2a1a, roughness: 0.7 });
var darkWood = new THREE.MeshStandardMaterial({ color: 0x1a1008, roughness: 0.7 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.6, metalness: 0.1 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x151515, roughness: 0.55, metalness: 0.15 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a8070, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.2, metalness: 0.3 });
var warmGlass = new THREE.MeshStandardMaterial({ color: 0x2a1505, roughness: 0.3, emissive: 0xe87818, emissiveIntensity: 0.14 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.4 });
var kerbMat = new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.5, metalness: 0.15 });
var paveMat = new THREE.MeshStandardMaterial({ color: 0x4a4a4a, roughness: 0.65, metalness: 0.1 });
var drainMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.7, metalness: 0.4 });

// ============================================================
// HELPER: canvas texture
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function makeSign(text, opts) {
var o = opts || {};
var w = o.w || 512; var h = o.h || 128;
var bg = o.bg || '#1a1a1a'; var fg = o.fg || '#c8c0a0';
var fs = o.fs || 36; var ff = o.ff || 'bold Georgia';
var tex = makeCanvasTexture(w, h, function(cx, cw, ch) {
cx.fillStyle = bg; cx.fillRect(0, 0, cw, ch);
if (o.border) {
cx.strokeStyle = fg; cx.lineWidth = 3;
cx.strokeRect(4, 4, cw - 8, ch - 8);
}
cx.fillStyle = fg; cx.font = fs + 'px ' + ff;
cx.textAlign = 'center'; cx.textBaseline = 'middle';
cx.fillText(text, cw/2, ch/2);
});
return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.5 });
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
scene.add(m);
return m;
}

function placeMeshG(group, geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
group.add(m);
return m;
}

// ============================================================
// GROUND
// ============================================================
var pavement = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
pavement.rotation.x = -Math.PI / 2;
pavement.receiveShadow = true;
scene.add(pavement);

// Dean Street road (runs along Z — north-south)
var deanRoad = new THREE.Mesh(new THREE.PlaneGeometry(7, 50), roadMat);
deanRoad.rotation.x = -Math.PI / 2;
deanRoad.position.set(0, -0.01, -5);
