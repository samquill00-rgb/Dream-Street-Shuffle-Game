// ============================================================
// PAVEMENTS — raised kerbs along both streets
// ============================================================
var kerbMat = new THREE.MeshStandardMaterial({ color: 0x666666, roughness: 0.8 });
var paveMat = new THREE.MeshStandardMaterial({ color: 0x4a4a4a, roughness: 0.85 });

// Greek St pavement — pub side (west, at x≈0-1)
// Runs along -Z from z=5 down to z=-20
var greekPaveW = new THREE.Mesh(new THREE.BoxGeometry(2.5, 0.15, 30), paveMat);
greekPaveW.position.set(1.25, 0.075, -5);
greekPaveW.receiveShadow = true;
scene.add(greekPaveW);
// Kerb edge
var greekKerbW = new THREE.Mesh(new THREE.BoxGeometry(0.15, 0.18, 30), kerbMat);
greekKerbW.position.set(2.5, 0.09, -5);
scene.add(greekKerbW);

// Greek St pavement — opposite side (east, at x≈8-9)
var greekPaveE = new THREE.Mesh(new THREE.BoxGeometry(2.5, 0.15, 30), paveMat);
greekPaveE.position.set(7.75, 0.075, -5);
greekPaveE.receiveShadow = true;
scene.add(greekPaveE);
var greekKerbE = new THREE.Mesh(new THREE.BoxGeometry(0.15, 0.18, 30), kerbMat);
greekKerbE.position.set(6.5, 0.09, -5);
scene.add(greekKerbE);

// Romilly St pavement — pub side (north, at z≈0-1)
var romPaveN = new THREE.Mesh(new THREE.BoxGeometry(25, 0.15, 2.5), paveMat);
romPaveN.position.set(-10, 0.075, 1.25);
romPaveN.receiveShadow = true;
scene.add(romPaveN);
var romKerbN = new THREE.Mesh(new THREE.BoxGeometry(25, 0.18, 0.15), kerbMat);
romKerbN.position.set(-10, 0.09, 2.5);
scene.add(romKerbN);

// Romilly St pavement — opposite side (south, at z≈8-9)
var romPaveS = new THREE.Mesh(new THREE.BoxGeometry(25, 0.15, 2.5), paveMat);
romPaveS.position.set(-10, 0.075, 7.75);
romPaveS.receiveShadow = true;
scene.add(romPaveS);
var romKerbS = new THREE.Mesh(new THREE.BoxGeometry(25, 0.18, 0.15), kerbMat);
romKerbS.position.set(-10, 0.09, 6.5);
scene.add(romKerbS);

// Corner pavement (where the two streets meet, in front of the pub)
var cornerPave = new THREE.Mesh(new THREE.BoxGeometry(4, 0.15, 4), paveMat);
cornerPave.position.set(1.5, 0.075, 1.5);
cornerPave.receiveShadow = true;
scene.add(cornerPave);

// ============================================================
// STREETLAMPS
// ============================================================
var lampLights = [];
function createLamp(x, z) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
placeMeshG(g, new THREE.CylinderGeometry(0.05, 0.07, 5, 6), postMat, 0, 2.5, 0);
placeMeshG(g, new THREE.BoxGeometry(0.3, 0.4, 0.3), postMat, 0.3, 5, 0);
placeMeshG(g, new THREE.BoxGeometry(0.6, 0.06, 0.06), postMat, 0.15, 5, 0);
var light = new THREE.PointLight(0xffdda0, 0.6, 15);
light.position.set(0.3, 4.8, 0);
light.castShadow = true;
g.add(light);
lampLights.push(light);
// Glow sprite
var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(255, 220, 150, 0.8)');
grad.addColorStop(0.3, 'rgba(255, 200, 100, 0.3)');
grad.addColorStop(1, 'rgba(255, 180, 80, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.5 }));
glowSprite.position.set(0.3, 5, 0);
glowSprite.scale.set(3, 3, 1);
g.add(glowSprite);
g.position.set(x, 0, z);
scene.add(g);
}

function placeMeshG(group, geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
group.add(m);
}

createLamp(1, 1);
createLamp(1, -8);
createLamp(7, 4);

// ============================================================
// LIGHTING — low ambient + cold moonlight casting real shadows on the street
// ============================================================
scene.add(new THREE.AmbientLight(0x1a1a2a, 0.20));

var moonLight = new THREE.DirectionalLight(0x6a78b8, 0.38);
moonLight.position.set(10, 22, -4);
moonLight.target.position.set(0, 3, 0);
scene.add(moonLight.target);
moonLight.castShadow = true;
moonLight.shadow.mapSize.width = 2048;
moonLight.shadow.mapSize.height = 2048;
moonLight.shadow.camera.near = 0.5;
moonLight.shadow.camera.far = 60;
moonLight.shadow.camera.left = -20;
moonLight.shadow.camera.right = 20;
moonLight.shadow.camera.top = 20;
moonLight.shadow.camera.bottom = -5;
moonLight.shadow.bias = -0.0008;
moonLight.shadow.normalBias = 0.04;
scene.add(moonLight);

function enableChSceneShadows(root) {
  root.traverse(function(obj) {
    if (!(obj instanceof THREE.Mesh)) return;
    var mat = obj.material;
    if (mat && (mat.transparent === true && (mat.opacity || 1) < 0.7)) return;
    obj.receiveShadow = true;
    if (obj.position.y > 0.2 || (obj.geometry && obj.geometry.type !== 'PlaneGeometry')) {
      obj.castShadow = true;
    }
  });
}
setTimeout(function() { enableChSceneShadows(scene); }, 0);

// Warm interior glow from pub windows
var pubGlow1 = new THREE.PointLight(0xc89030, 0.5, 10);
pubGlow1.position.set(-1, 2, -2);
scene.add(pubGlow1);
var pubGlow2 = new THREE.PointLight(0xc89030, 0.4, 8);
pubGlow2.position.set(-5, 2, -1);
scene.add(pubGlow2);

// ============================================================
// FOG VOLUMES — thick Soho pea-souper atmosphere
// ============================================================

// Shared fog textures (create once, reuse)
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(180, 170, 155, 0.25)');
grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.12)');
grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(200, 160, 100, 0.12)');
grad.addColorStop(0.5, 'rgba(180, 140, 80, 0.05)');
grad.addColorStop(1, 'rgba(150, 120, 60, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// LAYER 1: Thick ground-hugging fog banks (the main pea-souper)
for (var i = 0; i < 50; i++) {
var fogMat = new THREE.SpriteMaterial({
map: thickFogTex, transparent: true,
opacity: 0.25 + Math.random() * 0.2
});
var fogSprite = new THREE.Sprite(fogMat);
fogSprite.position.set(
Math.random() * 50 - 20,
0.3 + Math.random() * 2,
Math.random() * 50 - 20
);
var s = 5 + Math.random() * 12;
fogSprite.scale.set(s, s * 0.35, 1);
scene.add(fogSprite);
fogSprites.push({
sprite: fogSprite,
baseX: fogSprite.position.x,
drift: 0.002 + Math.random() * 0.006,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.004,
swayAmt: 0.4 + Math.random() * 1.0
});
}

// LAYER 2: Mid-height fog (swirling around building level)
for (var i = 0; i < 30; i++) {
var midFogMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.15 + Math.random() * 0.15
});
var midFog = new THREE.Sprite(midFogMat);
midFog.position.set(
Math.random() * 40 - 15,
2 + Math.random() * 6,
Math.random() * 40 - 15
);
var ms = 6 + Math.random() * 14;
midFog.scale.set(ms, ms * 0.3, 1);
scene.add(midFog);
fogSprites.push({
sprite: midFog,
baseX: midFog.position.x,
drift: 0.004 + Math.random() * 0.008,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.006,
swayAmt: 0.5 + Math.random() * 1.5
});
}

// LAYER 3: Warm-tinted fog near the pub (light spilling into mist)
for (var i = 0; i < 15; i++) {
var warmFogMat = new THREE.SpriteMaterial({
map: warmFogTex, transparent: true,
opacity: 0.2 + Math.random() * 0.15
});
var warmFog = new THREE.Sprite(warmFogMat);
warmFog.position.set(
Math.random() * 10 - 3,
0.5 + Math.random() * 3,
Math.random() * 10 - 3
);
var ws = 3 + Math.random() * 6;
warmFog.scale.set(ws, ws * 0.4, 1);
scene.add(warmFog);
fogSprites.push({
sprite: warmFog,
baseX: warmFog.position.x,
drift: 0.003 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.005,
swayAmt: 0.3 + Math.random() * 0.6
});
}

// LAYER 4: High wisps drifting past the rooftops
for (var i = 0; i < 20; i++) {
var wispMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.1 + Math.random() * 0.1
});
var wisp = new THREE.Sprite(wispMat);
wisp.position.set(
Math.random() * 40 - 15,
6 + Math.random() * 8,
Math.random() * 40 - 15
);
wisp.scale.set(8 + Math.random() * 15, 3 + Math.random() * 4, 1);
scene.add(wisp);
fogSprites.push({
sprite: wisp,
baseX: wisp.position.x,
drift: 0.006 + Math.random() * 0.012,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.003 + Math.random() * 0.008,
swayAmt: 0.8 + Math.random() * 2.0
});
}

// ============================================================
// PUDDLES (post-rain, wet ground)
// ============================================================
for (var i = 0; i < 8; i++) {
var puddleMat = new THREE.MeshStandardMaterial({
color: 0x111118, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.3
});
var puddle = new THREE.Mesh(new THREE.CircleGeometry(0.4 + Math.random() * 0.8, 16), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(
Math.random() * 16 - 4,
0.02,
Math.random() * 16 - 4
);
scene.add(puddle);
}

// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();

function chAnimate() {
chAnimId = requestAnimationFrame(chAnimate);
var t = clock.getElapsedTime();

// Very subtle light breathing (barely perceptible)
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;
doorLight.intensity = 0.8 * breath;
pubGlow1.intensity = 0.5 * breath;
pubGlow2.intensity = 0.4 * breath;

for (var i = 0; i < lampLights.length; i++) {
lampLights[i].intensity = 0.6 * breath;
}

// Silhouettes sway gently
for (var i = 0; i < silhouettes.length; i++) {
var s = silhouettes[i];
s.swayPhase += s.swaySpeed * 0.008;
var swayOffset = Math.sin(s.swayPhase) * s.swayAmt * 0.5;
s.mesh.position.y = 1.8 + Math.sin(s.swayPhase * 0.7) * 0.005;
if (s.mesh.rotation.y > 1) {
s.mesh.position.z = s.baseZ + swayOffset;
} else {
s.mesh.position.x = s.baseX + swayOffset;
}
}

// Film grain
chGrainFrame++;
if (chGrainFrame % 3 === 0) {
var imgData = chGrainCtx.createImageData(256, 256);
var d = imgData.data;
for (var i = 0; i < d.length; i += 4) {
var v = Math.random() * 255;
d[i] = d[i+1] = d[i+2] = v;
d[i+3] = 255;
}
chGrainCtx.putImageData(imgData, 0, 0);
}

renderer.render(scene, camera);
}

chAnimate();

// ENTER BUTTON
var chBtn = document.createElement('button');
chBtn.textContent = 'ENTER THE COACH AND HORSES';
chBtn.style.cssText = [
'position:absolute','bottom:60px','left:50%','transform:translateX(-50%)',
'font:13px \'Courier New\',monospace','color:rgba(200,170,100,0.85)',
'letter-spacing:4px','cursor:pointer','padding:12px 28px',
'border:1px solid rgba(200,170,100,0.3)','background:rgba(0,0,0,0.4)',
'z-index:9003','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
chWrap.appendChild(chBtn);
setTimeout(function() { chBtn.style.opacity = '1'; }, 1500);

chBtn.addEventListener('mouseenter', function() {
this.style.color = 'rgba(230,200,120,0.95)';
this.style.borderColor = 'rgba(200,170,100,0.6)';
});
chBtn.addEventListener('mouseleave', function() {
this.style.color = 'rgba(200,170,100,0.85)';
this.style.borderColor = 'rgba(200,170,100,0.3)';
});

chBtn.addEventListener('click', function() {
chWrap.style.transition = 'opacity 1.2s ease';
chWrap.style.opacity = '0';
setTimeout(function() {
cancelAnimationFrame(chAnimId);
chWrap.remove();
var TARGET = 'Coach and Horses lock';
var link = document.querySelector('tw-link[passage-name="' + TARGET + '"]');
if (!link) {
var allLinks = document.querySelectorAll('tw-passage tw-link');
for (var i = 0; i < allLinks.length; i++) {
if (allLinks[i].textContent.trim() === '\u00B7') { link = allLinks[i]; break; }
}
}
if (link) {
link.click();
} else {
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', TARGET);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.click();
storyEl.removeChild(injected);
}
}, 1200);
});
}

// Watch for ch-container. Cleanup mirrors Pillars/Lackland: when the
// container disappears (passage change), cancel the animate loop and
// remove the body-appended wrap so the canvas + listeners don't leak.
setInterval(function() {
var container = document.getElementById('ch-container');
if (container && !chActive) {
initCoachHorses();
} else if (!container) {
chActive = false;
if (chAnimId) { cancelAnimationFrame(chAnimId); chAnimId = null; }
window._dssDisposeWrap('ch-wrap');
}
}, 300);
})();

// ====== PILLARS OF HERCULES SCENE — INLINE ======
(function() {
var phActive = false;
var phAnimId = null;

function initPillars() {
if (phActive) return;
phActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildPHScene(); };
document.head.appendChild(s);
} else {
buildPHScene();
}
}

function buildPHScene() {
// Create full-screen overlay wrapper
var phWrap = document.createElement('div');
phWrap.id = 'ph-wrap';
phWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#0a0a12;overflow:hidden;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0a12);
scene.fog = new THREE.Fog(0x0a0a12, 5, 40);

var camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT EXPLANATION
// ============================================================
// The Pillars of Hercules faces the camera straight on.
// Facade runs along X (roughly x=-4 to x=4), facing +Z.
// Camera is at +Z looking back at the building.
// Alleyway is on the LEFT side (negative X).
// Neighbouring buildings: cream/yellow to left of alley, pink/brown to right.
// Building body extends into -Z (behind facade).

camera.position.set(0, 3.5, 16);
camera.lookAt(0, 5, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.55;
phWrap.appendChild(renderer.domElement);
window._dssBindScene('ph-wrap', scene, renderer, camera);

// ============================================================
// MATERIALS
// ============================================================
var darkTimber = new THREE.MeshStandardMaterial({ color: 0x2a2018, roughness: 0.92 });
// Weathered stucco — cream base with hairline cracks, nicotine
// yellowing, soot streaks from gutters/windows, damp patches,
// minor paint repairs. Drawn before whitePlaster is declared so it
// becomes the new base material for the pub facade.
var plasterTex = makeCanvasTexture(512, 512, function(cx, w, h) {
  cx.fillStyle = '#c8b89a'; cx.fillRect(0, 0, w, h);
  // Subtle uneven base tone (rendering rough surface variation)
  for (var pp = 0; pp < 350; pp++) {
    var b = 180 + Math.floor(Math.random() * 30);
    cx.fillStyle = 'rgba(' + b + ',' + (b - 18) + ',' + (b - 32) + ',0.12)';
    cx.beginPath();
    cx.ellipse(Math.random() * w, Math.random() * h,
      6 + Math.random() * 24, 4 + Math.random() * 14, Math.random() * Math.PI, 0, Math.PI * 2);
    cx.fill();
  }
  // Nicotine wash — yellowish stain pooling lower (smokers' Soho)
  var nicoG = cx.createLinearGradient(0, h * 0.35, 0, h);
  nicoG.addColorStop(0, 'rgba(170, 145, 80, 0)');
  nicoG.addColorStop(0.6, 'rgba(170, 145, 80, 0.10)');
  nicoG.addColorStop(1, 'rgba(160, 130, 60, 0.18)');
  cx.fillStyle = nicoG; cx.fillRect(0, h * 0.35, w, h * 0.65);
  // Soot streaks running down from the cornice/eaves
  for (var ss = 0; ss < 6; ss++) {
    var sx = Math.random() * w;
    var sxw = 10 + Math.random() * 26;
    var sg = cx.createLinearGradient(sx, 0, sx, h);
    sg.addColorStop(0, 'rgba(15, 12, 8, 0.50)');
    sg.addColorStop(0.4, 'rgba(20, 16, 10, 0.22)');
    sg.addColorStop(0.85, 'rgba(25, 20, 12, 0.08)');
    sg.addColorStop(1, 'rgba(25, 20, 12, 0)');
    cx.fillStyle = sg;
    cx.fillRect(sx - sxw / 2, 0, sxw, h);
  }
  // Damp / green patches near the base
  for (var d = 0; d < 4; d++) {
    var dx = Math.random() * w;
    var dy = h * 0.7 + Math.random() * h * 0.3;
    var dr = 32 + Math.random() * 50;
    var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
    dg2.addColorStop(0, 'rgba(70, 80, 55, 0.30)');
    dg2.addColorStop(0.5, 'rgba(55, 65, 45, 0.14)');
    dg2.addColorStop(1, 'rgba(40, 50, 40, 0)');
    cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
  }
  // Hairline cracks (random forks)
  cx.strokeStyle = 'rgba(50, 38, 22, 0.45)';
  cx.lineWidth = 0.7;
  for (var ch = 0; ch < 14; ch++) {
    cx.beginPath();
    var cxh = Math.random() * w;
    var cyh = Math.random() * h;
    cx.moveTo(cxh, cyh);
    for (var sg2 = 0; sg2 < 5; sg2++) {
      cxh += (Math.random() - 0.5) * 28;
      cyh += 12 + Math.random() * 22;
      cx.lineTo(cxh, cyh);
    }
    cx.stroke();
  }
  // Paint-patch repairs (lighter ovals where someone touched up)
  for (var pr = 0; pr < 8; pr++) {
    var prx = Math.random() * w, pry = Math.random() * h;
    var prr = 12 + Math.random() * 22;
    var pg = cx.createRadialGradient(prx, pry, 0, prx, pry, prr);
    pg.addColorStop(0, 'rgba(225, 210, 180, 0.45)');
    pg.addColorStop(0.6, 'rgba(220, 200, 170, 0.14)');
    pg.addColorStop(1, 'rgba(220, 200, 170, 0)');
    cx.fillStyle = pg;
    cx.beginPath();
    cx.ellipse(prx, pry, prr, prr * 0.7, Math.random() * Math.PI, 0, Math.PI * 2);
    cx.fill();
  }
  // Old paste-up ghost (poster torn off, glue residue)
  cx.fillStyle = 'rgba(200, 170, 130, 0.10)';
  cx.fillRect(w * 0.18, h * 0.55, w * 0.12, h * 0.10);
  // Faint bird splat top-right
  cx.fillStyle = 'rgba(245, 240, 215, 0.36)';
  cx.beginPath();
  cx.ellipse(w * 0.88, h * 0.08, 5, 2.5, 0.4, 0, Math.PI * 2);
  cx.fill();
});
plasterTex.wrapS = plasterTex.wrapT = THREE.RepeatWrapping;
plasterTex.repeat.set(2, 3);
var whitePlaster = new THREE.MeshStandardMaterial({ map: plasterTex, roughness: 0.95 });
var mahogany = new THREE.MeshStandardMaterial({ color: 0x3d1e14, roughness: 0.82 });
var mahoganyDark = new THREE.MeshStandardMaterial({ color: 0x2e1510, roughness: 0.88 });
// Pavement — paving slabs with cracks, gum, wet patches
var paveFaceTexPh = makeCanvasTexture(512, 512, function(cx, w, h) {
  cx.fillStyle = '#34322e'; cx.fillRect(0, 0, w, h);
  var sw = 128, sh = 96;
  cx.strokeStyle = 'rgba(14, 14, 12, 0.6)'; cx.lineWidth = 1.4;
  for (var sy = 0; sy < h; sy += sh) {
    var off = ((sy / sh) % 2 === 0) ? 0 : sw / 2;
    for (var sx = -sw; sx < w + sw; sx += sw) {
      var bxp = sx + off;
      var sg = 44 + Math.floor(Math.random() * 26);
      cx.fillStyle = 'rgba(' + sg + ',' + sg + ',' + (sg - 4) + ',' + (0.32 + Math.random() * 0.3).toFixed(3) + ')';
      cx.fillRect(bxp, sy, sw, sh);
      cx.strokeRect(bxp, sy, sw, sh);
    }
  }
  cx.strokeStyle = 'rgba(12, 12, 10, 0.55)'; cx.lineWidth = 0.9;
  for (var c2 = 0; c2 < 7; c2++) {
    cx.beginPath();
    cx.moveTo(Math.random() * w, Math.random() * h);
    cx.lineTo(Math.random() * w, Math.random() * h);
    cx.stroke();
  }
  for (var fe = 0; fe < 60; fe++) {
    cx.fillStyle = 'rgba(170, 165, 155, ' + (0.14 + Math.random() * 0.20).toFixed(3) + ')';
    cx.beginPath(); cx.arc(Math.random() * w, Math.random() * h, 1.0 + Math.random() * 1.6, 0, Math.PI * 2); cx.fill();
  }
  for (var wp = 0; wp < 5; wp++) {
    var wpx = Math.random() * w, wpy = Math.random() * h;
    var wpr = 35 + Math.random() * 60;
    var wpg = cx.createRadialGradient(wpx, wpy, 0, wpx, wpy, wpr);
    wpg.addColorStop(0, 'rgba(60, 68, 72, 0.32)');
    wpg.addColorStop(1, 'rgba(60, 68, 72, 0)');
    cx.fillStyle = wpg; cx.fillRect(wpx - wpr, wpy - wpr, wpr * 2, wpr * 2);
  }
});
paveFaceTexPh.wrapS = paveFaceTexPh.wrapT = THREE.RepeatWrapping;
paveFaceTexPh.repeat.set(4, 4);
var pavementMat = new THREE.MeshStandardMaterial({ map: paveFaceTexPh, roughness: 0.85, metalness: 0.1 });

// Road — tarmac with aggregate, cracks, repair patches, tar-seal
var roadFaceTexPh = makeCanvasTexture(512, 512, function(cx, w, h) {
  cx.fillStyle = '#1a1a18'; cx.fillRect(0, 0, w, h);
  for (var p = 0; p < 4200; p++) {
    var pg = 25 + Math.floor(Math.random() * 70);
    cx.fillStyle = 'rgba(' + pg + ',' + pg + ',' + pg + ',0.42)';
    cx.fillRect(Math.random() * w, Math.random() * h, 1.5, 1.5);
  }
  for (var rp = 0; rp < 6; rp++) {
    var rx = Math.random() * w, ry = Math.random() * h;
    var rwd = 50 + Math.random() * 100, rht = 35 + Math.random() * 70;
    cx.fillStyle = 'rgba(74, 74, 74, ' + (0.16 + Math.random() * 0.22).toFixed(3) + ')';
    cx.fillRect(rx, ry, rwd, rht);
    cx.strokeStyle = 'rgba(100, 100, 100, 0.18)'; cx.lineWidth = 0.6;
    cx.strokeRect(rx, ry, rwd, rht);
  }
  cx.strokeStyle = 'rgba(8, 8, 8, 0.8)'; cx.lineWidth = 1.2;
  for (var c = 0; c < 10; c++) {
    cx.beginPath();
    var cx0 = Math.random() * w, cy0 = Math.random() * h;
    cx.moveTo(cx0, cy0);
    var ang = Math.random() * Math.PI * 2, len = 30 + Math.random() * 80;
    cx.lineTo(cx0 + Math.cos(ang) * len, cy0 + Math.sin(ang) * len);
    cx.lineTo(cx0 + Math.cos(ang + 0.4) * len * 1.4, cy0 + Math.sin(ang + 0.4) * len * 1.4);
    cx.stroke();
  }
  cx.strokeStyle = 'rgba(0, 0, 0, 0.9)'; cx.lineWidth = 2.6;
  for (var tm = 0; tm < 5; tm++) {
    cx.beginPath();
    var tx = Math.random() * w, ty = Math.random() * h;
    cx.moveTo(tx, ty);
    for (var ts = 0; ts < 5; ts++) {
      tx += (Math.random() - 0.5) * 30;
      ty += 8 + Math.random() * 16;
      cx.lineTo(tx, ty);
    }
    cx.stroke();
  }
  cx.fillStyle = 'rgba(220, 220, 200, 0.5)';
  cx.fillRect(w * 0.5 - 2, h * 0.3, 4, h * 0.4);
  cx.fillStyle = 'rgba(220, 220, 200, 0.18)';
  cx.fillRect(w * 0.5 - 2, h * 0.05, 4, h * 0.2);
  cx.fillRect(w * 0.5 - 2, h * 0.75, 4, h * 0.2);
  for (var os = 0; os < 4; os++) {
    var ox = Math.random() * w, oy = Math.random() * h;
    var orr = 8 + Math.random() * 18;
    var og = cx.createRadialGradient(ox, oy, 0, ox, oy, orr);
    og.addColorStop(0, 'rgba(0, 0, 0, 0.62)');
    og.addColorStop(0.7, 'rgba(15, 12, 5, 0.22)');
    og.addColorStop(1, 'rgba(15, 12, 5, 0)');
    cx.fillStyle = og; cx.fillRect(ox - orr, oy - orr, orr * 2, orr * 2);
  }
});
roadFaceTexPh.wrapS = roadFaceTexPh.wrapT = THREE.RepeatWrapping;
roadFaceTexPh.repeat.set(1, 8);
var roadMat = new THREE.MeshStandardMaterial({ map: roadFaceTexPh, roughness: 0.72, metalness: 0.18 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a7e60, roughness: 0.88 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.3, metalness: 0.2 });
var goldMat = new THREE.MeshStandardMaterial({ color: 0xa88830, roughness: 0.5, metalness: 0.3 });

// ============================================================
// HELPER: canvas texture
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
  var c = document.createElement('canvas');
  c.width = w; c.height = h;
  var cx = c.getContext('2d');
  drawFunc(cx, w, h);
  var tex = new THREE.CanvasTexture(c);
  tex.minFilter = THREE.LinearFilter;
  return tex;
}

function placeMesh(group, geo, mat, x, y, z) {
  var m = new THREE.Mesh(geo, mat);
  m.position.set(x, y, z);
  group.add(m);
  return m;
}

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

// Greek Street road (runs along Z in front of the pub)
var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 10);
road.receiveShadow = true;
scene.add(road);

// Wet road surface — just stopped raining, everything glistening
var wetMat = new THREE.MeshStandardMaterial({
  color: 0x1a1a1a, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.3
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(20, 20), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(0, 0.01, 8);
scene.add(wetRoad);

// Wet pavement sheen (closer to buildings — rain-slicked flagstones)
var wetPaveMat = new THREE.MeshStandardMaterial({
  color: 0x222228, roughness: 0.12, metalness: 0.55, transparent: true, opacity: 0.25
});
var wetPave = new THREE.Mesh(new THREE.PlaneGeometry(30, 4), wetPaveMat);
wetPave.rotation.x = -Math.PI / 2;
wetPave.position.set(0, 0.08, 2);
scene.add(wetPave);

// ============================================================
// THE PILLARS OF HERCULES
// ============================================================
var pub = new THREE.Group();

// ---- WHITE PLASTER BASE WALL (behind the timber) ----
// Main building body: x from -1.5 to 4, facade at z=0 facing +Z
// Building depth goes into -Z
var plasterWall = new THREE.Mesh(new THREE.BoxGeometry(5.5, 9, 7), whitePlaster);
plasterWall.position.set(1.25, 8, -3.5);
pub.add(plasterWall);

// ---- TWIN GABLES AT THE TOP ----
// These are the distinctive peaked roofs at the very top

// Left gable
var gableFrameL = new THREE.Mesh(new THREE.BoxGeometry(2.4, 1.6, 0.25), darkTimber);
gableFrameL.position.set(-0.2, 13.3, 0.15);
pub.add(gableFrameL);
var gableTopL = new THREE.Mesh(new THREE.ConeGeometry(1.6, 1.4, 4), darkTimber);
gableTopL.position.set(-0.2, 14.6, 0.15);
gableTopL.rotation.y = Math.PI / 4;
pub.add(gableTopL);
// White infill
var gableFillL = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 1.2), whitePlaster);
gableFillL.position.set(-0.2, 13.3, 0.32);
pub.add(gableFillL);

// Right gable
var gableFrameR = new THREE.Mesh(new THREE.BoxGeometry(2.4, 1.6, 0.25), darkTimber);
gableFrameR.position.set(2.7, 13.3, 0.15);
pub.add(gableFrameR);
var gableTopR = new THREE.Mesh(new THREE.ConeGeometry(1.6, 1.4, 4), darkTimber);
gableTopR.position.set(2.7, 14.6, 0.15);
gableTopR.rotation.y = Math.PI / 4;
pub.add(gableTopR);
var gableFillR = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 1.2), whitePlaster);
gableFillR.position.set(2.7, 13.3, 0.32);
pub.add(gableFillR);

// Small gable windows
var gableWinMatL = new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.3 });
placeMesh(pub, new THREE.PlaneGeometry(0.5, 0.8), gableWinMatL, -0.2, 13.3, 0.35);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.9, 0.04), darkTimber, -0.2, 13.3, 0.3);
var gableWinMatR = new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.25 });
placeMesh(pub, new THREE.PlaneGeometry(0.5, 0.8), gableWinMatR, 2.7, 13.3, 0.35);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.9, 0.04), darkTimber, 2.7, 13.3, 0.3);

// ---- HORIZONTAL TIMBER BEAMS (floor divisions) ----
// Clean main beams at each floor level — matching guide proportions
var beamHeights = [3.7, 7.0, 9.5, 12.5];
for (var bi = 0; bi < beamHeights.length; bi++) {
  var beam = new THREE.Mesh(new THREE.BoxGeometry(5.8, 0.18, 0.15), darkTimber);
  beam.position.set(1.25, beamHeights[bi], 0.22);
  pub.add(beam);
}

// ---- VERTICAL TIMBER POSTS ----
// 5 evenly-spaced structural posts (matching guide: edges + centre + quarters)
var postXs = [-1.3, 0.0, 1.25, 2.5, 3.8];
for (var pi = 0; pi < postXs.length; pi++) {
  // Lower section (1st + 2nd floor)
  var post1 = new THREE.Mesh(new THREE.BoxGeometry(0.15, 5.6, 0.15), darkTimber);
  post1.position.set(postXs[pi], 6.5, 0.22);
  pub.add(post1);
  // Upper section (3rd floor)
  var post2 = new THREE.Mesh(new THREE.BoxGeometry(0.15, 2.8, 0.15), darkTimber);
  post2.position.set(postXs[pi], 11, 0.22);
  pub.add(post2);
}

// ---- DECORATIVE X-BRACES (Tudor cross pattern) ----
// Placed only at the outer bays and one central — clean, orderly layout
function addXBrace(cx, cy, w, h) {
  var diagLen = Math.sqrt(w * w + h * h);
  var d1 = new THREE.Mesh(new THREE.BoxGeometry(0.08, diagLen, 0.1), darkTimber);
  d1.position.set(cx, cy, 0.22);
  d1.rotation.z = Math.atan2(w, h);
  pub.add(d1);
  var d2 = new THREE.Mesh(new THREE.BoxGeometry(0.08, diagLen, 0.1), darkTimber);
  d2.position.set(cx, cy, 0.22);
  d2.rotation.z = -Math.atan2(w, h);
  pub.add(d2);
}
// 2nd floor: X-braces in outer bays only
addXBrace(-0.65, 8.2, 0.8, 2.0);
addXBrace(3.15, 8.2, 0.8, 2.0);
// 3rd floor: X-braces in outer bays + one central
addXBrace(-0.65, 11, 0.8, 2.5);
addXBrace(3.15, 11, 0.8, 2.5);
addXBrace(1.25, 11, 1.0, 2.5);

// ---- DIAMOND PATTERN TIMBER (decorative panels between windows) ----
function addDiamond(cx, cy, size) {
  var d = new THREE.Mesh(new THREE.BoxGeometry(0.06, size * 1.4, 0.08), darkTimber);
  d.position.set(cx, cy, 0.24);
  d.rotation.z = Math.PI / 4;
  pub.add(d);
  var d2 = new THREE.Mesh(new THREE.BoxGeometry(0.06, size * 1.4, 0.08), darkTimber);
  d2.position.set(cx, cy, 0.24);
  d2.rotation.z = -Math.PI / 4;
  pub.add(d2);
}
// Diamonds only in the inner bays (between the X-braces) — 4 total
addDiamond(0.6, 8.2, 0.6);
addDiamond(1.9, 8.2, 0.6);
addDiamond(0.6, 11, 0.6);
addDiamond(1.9, 11, 0.6);

// ---- UPPER FLOOR WINDOWS (leaded glass style) ----
var sillMat = new THREE.MeshStandardMaterial({ color: 0xc8c0b0, roughness: 0.8 });

// 2nd floor windows — with sills, lintels, and glazing bars
for (var w2x = -0.2; w2x <= 2.8; w2x += 1.0) {
  var isLit = Math.random() < 0.6;
  // Glass glow
  var w2 = new THREE.Mesh(new THREE.PlaneGeometry(0.65, 1.2),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: isLit ? 0.45 : 0.2 }));
  w2.position.set(w2x, 10.8, 0.32);
  pub.add(w2);
  // Timber frame
  var w2f = new THREE.Mesh(new THREE.BoxGeometry(0.75, 1.3, 0.04), darkTimber);
  w2f.position.set(w2x, 10.8, 0.28);
  pub.add(w2f);
  // Glazing bars (leaded glass pattern — 2 vertical, 2 horizontal)
  placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x - 0.15, 10.8, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x + 0.15, 10.8, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 10.5, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 11.1, 0.34);
  // Stone sill below
  placeMesh(pub, new THREE.BoxGeometry(0.85, 0.06, 0.12), sillMat, w2x, 10.15, 0.3);
  // Timber lintel above
  placeMesh(pub, new THREE.BoxGeometry(0.85, 0.08, 0.1), darkTimber, w2x, 11.45, 0.28);
}

// 1st floor windows (bigger, more warm light — the main pub floors)
for (var w1x = -0.2; w1x <= 2.8; w1x += 1.0) {
  var isLit1 = Math.random() < 0.7;
