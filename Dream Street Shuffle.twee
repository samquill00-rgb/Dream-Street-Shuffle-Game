var rugTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#3a0e0e';
cx.fillRect(0, 0, w, h);
var i, j, a;
cx.strokeStyle = '#1a0505';
cx.lineWidth = 14;
cx.strokeRect(10, 10, w - 20, h - 20);
cx.strokeStyle = '#7a5a20';
cx.lineWidth = 6;
cx.strokeRect(22, 22, w - 44, h - 44);
for (i = 35; i < w - 35; i += 18) {
cx.fillStyle = '#5a3818';
cx.fillRect(i, 30, 8, 8);
cx.fillRect(i, h - 38, 8, 8);
}
for (j = 35; j < h - 35; j += 18) {
cx.fillStyle = '#5a3818';
cx.fillRect(30, j, 8, 8);
cx.fillRect(w - 38, j, 8, 8);
}
cx.strokeStyle = '#5a1818';
cx.lineWidth = 3;
cx.strokeRect(45, 45, w - 90, h - 90);
cx.strokeStyle = '#8a7a50';
cx.lineWidth = 1.5;
cx.strokeRect(50, 50, w - 100, h - 100);
cx.save();
cx.translate(w/2, h/2);
cx.rotate(Math.PI / 4);
cx.fillStyle = '#4a1510';
cx.fillRect(-65, -65, 130, 130);
cx.strokeStyle = '#7a5a28';
cx.lineWidth = 2;
cx.strokeRect(-65, -65, 130, 130);
cx.fillStyle = '#2a0a08';
cx.fillRect(-40, -40, 80, 80);
cx.strokeStyle = '#6a4a20';
cx.lineWidth = 1.5;
cx.strokeRect(-40, -40, 80, 80);
cx.fillStyle = '#5a2015';
cx.fillRect(-18, -18, 36, 36);
cx.restore();
var crnrs = [[120, 120], [w-120, 120], [120, h-120], [w-120, h-120]];
for (i = 0; i < crnrs.length; i++) {
cx.save();
cx.translate(crnrs[i][0], crnrs[i][1]);
cx.rotate(Math.PI / 4);
cx.fillStyle = '#4a1812';
cx.fillRect(-25, -25, 50, 50);
cx.strokeStyle = '#6a4a22';
cx.lineWidth = 1.5;
cx.strokeRect(-25, -25, 50, 50);
cx.fillStyle = '#3a0e0a';
cx.fillRect(-12, -12, 24, 24);
cx.restore();
}
for (i = 0; i < 8; i++) {
for (j = 0; j < 8; j++) {
var mx = 80 + i * 48;
var my = 80 + j * 48;
if (Math.sqrt(Math.pow(mx - w/2, 2) + Math.pow(my - h/2, 2)) < 60) { continue; }
if (mx < 55 || mx > w - 55 || my < 55 || my > h - 55) { continue; }
cx.fillStyle = '#5a2818';
cx.fillRect(mx - 3, my - 3, 6, 6);
cx.strokeStyle = '#6a4020';
cx.lineWidth = 0.5;
cx.strokeRect(mx - 3, my - 3, 6, 6);
}
}
for (i = 0; i < 40; i++) {
cx.fillStyle = 'rgba(20,10,5,' + (Math.random() * 0.12) + ')';
cx.fillRect(Math.random() * w, Math.random() * h, Math.random() * 30 + 5, Math.random() * 30 + 5);
}
});
