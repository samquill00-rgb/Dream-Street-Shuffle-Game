// --- LEFT: Cream/yellow Georgian building (left of the alleyway) ---
var leftBuilding = new THREE.Group();
var leftBody = new THREE.Mesh(new THREE.BoxGeometry(5, 14, 7),
  new THREE.MeshStandardMaterial({ color: 0xb8a880, roughness: 0.92 }));
leftBody.position.set(-6, 7, -3.5);
leftBuilding.add(leftBody);
// Windows facing +Z — raised above shop front (3 rows starting at y=4.5)
var leftWinYs = [4.5, 7.5, 10.5];
var leftRedMap = [[false, true], [true, false], [true, true]];
var redShades = [0xcc2020, 0xaa1818, 0xdd3030, 0xbb2525];
for (var row = 0; row < 3; row++) {
  for (var col = 0; col < 2; col++) {
    var lwx = -5 - col * 1.8;
    var lwy = leftWinYs[row];
    var isRed = leftRedMap[row][col];
    var redShade = redShades[(row * 2 + col) % redShades.length];
    // Glass
    var lwGlassMat = isRed
      ? new THREE.MeshBasicMaterial({ color: redShade, transparent: true, opacity: 0.55 })
      : darkGlass;
    var lw = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.06), lwGlassMat);
    lw.position.set(lwx, lwy, 0.05);
    leftBuilding.add(lw);
    // Frame
    var lwf = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.4, 0.08), windowFrame);
    lwf.position.set(lwx, lwy, 0.04);
    leftBuilding.add(lwf);
    // Sill
    var lws = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.06, 0.12), sillMat);
    lws.position.set(lwx, lwy - 0.72, 0.08);
    leftBuilding.add(lws);
    // Lintel
    var lwl = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.08, 0.08), sillMat);
    lwl.position.set(lwx, lwy + 0.72, 0.06);
    leftBuilding.add(lwl);
    // Red light spill from brothel windows
    if (isRed) {
      var redLight = new THREE.PointLight(redShade, 0.25, 4);
      redLight.position.set(lwx, lwy, 0.8);
      leftBuilding.add(redLight);
    }
  }
}
