// Timber frame
var w2f = new THREE.Mesh(new THREE.BoxGeometry(0.75, 1.3, 0.04), darkTimber);
w2f.position.set(w2x, 10.8, 0.28);
pub.add(w2f);
// Glazing bars (leaded glass pattern — 2 vertical, 2 horizontal)
placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x - 0.15, 10.8, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x + 0.15, 10.8, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 10.5, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 11.1, 0.34);
// Stone sill below
placeMesh(pub, new THREE.BoxGeometry(0.85, 0.06, 0.12), sillMat, w2x, 10.15, 0.3);
// Timber lintel above
placeMesh(pub, new THREE.BoxGeometry(0.85, 0.08, 0.1), darkTimber, w2x, 11.45, 0.28);
}

// 1st floor windows (bigger, more warm light — the main pub floors)
for (var w1x = -0.2; w1x <= 2.8; w1x += 1.0) {
var isLit1 = Math.random() < 0.7;
// Glass glow
var w1 = new THREE.Mesh(new THREE.PlaneGeometry(0.7, 1.4),
new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: isLit1 ? 0.5 : 0.2 }));
w1.position.set(w1x, 5.5, 0.32);
