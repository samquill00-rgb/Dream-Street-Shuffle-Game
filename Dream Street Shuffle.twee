// ============================================================
var chimMat = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.85 });

placeMesh(new THREE.BoxGeometry(0.5, 1.8, 0.5), chimMat, -7, 14.9, -2);
placeMesh(new THREE.BoxGeometry(0.6, 0.15, 0.6), chimMat, -7, 15.85, -2);
placeMesh(new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -9, 14.75, -4);
placeMesh(new THREE.BoxGeometry(0.6, 0.15, 0.6), chimMat, -9, 15.55, -4);
placeMesh(new THREE.BoxGeometry(0.4, 1.3, 0.4), chimMat, 7, 13.65, -1);
placeMesh(new THREE.BoxGeometry(0.5, 0.15, 0.5), chimMat, 7, 14.35, -1);

// Chimney pots (small cylinders on top)
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.3, 6), chimMat, -7, 16.05, -2);
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.3, 6), chimMat, -9, 15.75, -4);

// ============================================================
// CHIMNEY SMOKE — wisps rising from chimney pots
// ============================================================
var smokeSprites = [];
var smokeTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(100, 95, 85, 0.25)');
grad.addColorStop(0.4, 'rgba(80, 75, 65, 0.12)');
grad.addColorStop(1, 'rgba(60, 55, 45, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

// Smoke from each chimney
var chimneyPositions = [
{ x: -7, y: 16.2, z: -2 },
{ x: -9, y: 15.9, z: -4 }
];

for (var ci = 0; ci < chimneyPositions.length; ci++) {
for (var si = 0; si < 8; si++) {
var smokeMat = new THREE.SpriteMaterial({
map: smokeTex, transparent: true,
opacity: 0.15 + Math.random() * 0.15
});
var smokeSprite = new THREE.Sprite(smokeMat);
var startY = chimneyPositions[ci].y + Math.random() * 3;
smokeSprite.position.set(
chimneyPositions[ci].x + (Math.random() - 0.5) * 0.5,
startY,
chimneyPositions[ci].z + (Math.random() - 0.5) * 0.5
);
var ss = 0.5 + Math.random() * 1.5;
smokeSprite.scale.set(ss, ss, 1);
scene.add(smokeSprite);
smokeSprites.push({
sprite: smokeSprite,
baseX: chimneyPositions[ci].x,
baseZ: chimneyPositions[ci].z,
startY: chimneyPositions[ci].y,
rise: 0.003 + Math.random() * 0.005,
drift: 0.001 + Math.random() * 0.003,
maxHeight: 5 + Math.random() * 4,
phase: Math.random() * Math.PI * 2,
baseScale: ss
});
}
}

// ============================================================
// STREET FURNITURE
// ============================================================

// Bollard near the corner
var bollardMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.7, metalness: 0.3 });
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.8, 6), bollardMat, -2.5, 0.4, -2);
placeMesh(new THREE.SphereGeometry(0.1, 6, 4), bollardMat, -2.5, 0.85, -2);

// Another bollard
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.8, 6), bollardMat, -1.5, 0.4, -5);
placeMesh(new THREE.SphereGeometry(0.1, 6, 4), bollardMat, -1.5, 0.85, -5);

// Dustbin (galvanised bin, period-appropriate)
var binMat = new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.6, metalness: 0.3 });
var dustbin = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.3, 0.8, 8), binMat);
dustbin.position.set(-5.8, 0.4, 0.5);
scene.add(dustbin);
var binLid = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.28, 0.04, 8), binMat);
binLid.position.set(-5.8, 0.82, 0.5);
binLid.rotation.z = 0.1; // slightly askew
scene.add(binLid);

// Drain cover in the road (raised to avoid z-fighting)
var drain = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.04, 0.4), drainMat);
drain.position.set(1, 0.03, -1);
scene.add(drain);

// Street name plate on building wall (Dean Street)
var deanSignTex = makeCanvasTexture(256, 64, function(cx, w, h) {
cx.fillStyle = '#1a1a2a';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = '#aaa';
cx.lineWidth = 2;
cx.strokeRect(2, 2, w-4, h-4);
cx.fillStyle = '#e0d8c0';
cx.font = 'bold 22px serif';
cx.textAlign = 'center';
cx.textBaseline = 'middle';
cx.fillText('DEAN STREET W1', w/2, h/2);
});
var deanSignMat = new THREE.MeshStandardMaterial({ map: deanSignTex, roughness: 0.5 });
var deanSign = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 0.4), deanSignMat);
deanSign.position.set(-4.0, 3.5, 1.06);
scene.add(deanSign);

// ============================================================
// RED PHONE BOX — iconic K6, proper scale (~2.5m tall, 0.9m square)
// ============================================================
var phoneBox = new THREE.Group();
var phoneRedMat = new THREE.MeshStandardMaterial({ color: 0x9b1c1c, roughness: 0.55, metalness: 0.12 });
var phoneRedDark = new THREE.MeshStandardMaterial({ color: 0x6b1212, roughness: 0.6, metalness: 0.1 });
var phoneDarkMat = new THREE.MeshStandardMaterial({ color: 0x1a0808, roughness: 0.7 });
var phoneIronMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5, metalness: 0.4 });

// --- CONCRETE BASE ---
var concreteBase = new THREE.Mesh(
new THREE.BoxGeometry(1.1, 0.1, 1.1),
new THREE.MeshStandardMaterial({ color: 0x555550, roughness: 0.9 })
);
concreteBase.position.set(0, 0.05, 0);
phoneBox.add(concreteBase);

// --- LOWER PLINTH (stepped base) ---
var plinth1 = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.12, 1.0), phoneRedDark);
plinth1.position.set(0, 0.16, 0);
phoneBox.add(plinth1);
var plinth2 = new THREE.Mesh(new THREE.BoxGeometry(0.95, 0.08, 0.95), phoneRedDark);
plinth2.position.set(0, 0.26, 0);
phoneBox.add(plinth2);

// --- FOUR CORNER PILLARS ---
var pillarGeo = new THREE.BoxGeometry(0.08, 1.7, 0.08);
var pillarPositions = [
[-0.42, 1.15, -0.42], [0.42, 1.15, -0.42],
[-0.42, 1.15, 0.42], [0.42, 1.15, 0.42]
];
for (var pi = 0; pi < pillarPositions.length; pi++) {
var pillar = new THREE.Mesh(pillarGeo, phoneRedMat);
pillar.position.set(pillarPositions[pi][0], pillarPositions[pi][1], pillarPositions[pi][2]);
pillar.castShadow = true;
phoneBox.add(pillar);
}

// --- SOLID LOWER PANELS (below windows) ---
var lowerPanelH = 0.5;
// Front and back
var lowerFB = new THREE.BoxGeometry(0.76, lowerPanelH, 0.04);
placeMeshG(phoneBox, lowerFB, phoneRedMat, 0, 0.55, 0.44);
placeMeshG(phoneBox, lowerFB, phoneRedMat, 0, 0.55, -0.44);
// Sides
var lowerLR = new THREE.BoxGeometry(0.04, lowerPanelH, 0.76);
placeMeshG(phoneBox, lowerLR, phoneRedMat, -0.44, 0.55, 0);
placeMeshG(phoneBox, lowerLR, phoneRedMat, 0.44, 0.55, 0);

// --- WINDOW GLASS (18-pane pattern per side) ---
var phoneGlass = new THREE.MeshStandardMaterial({
color: 0x0a0a15, roughness: 0.12, metalness: 0.25,
emissive: 0xe87818, emissiveIntensity: 0.04
});
var phoneGlassBright = new THREE.MeshStandardMaterial({
color: 0x0a0a15, roughness: 0.12, metalness: 0.25,
emissive: 0xe87818, emissiveIntensity: 0.08
});

// Window area: 3 columns x 6 rows of small panes with mullions
// Each side gets a large glass panel + red mullion grid overlay
var glassH = 1.2;
var glassW = 0.72;
var mullionMat = phoneRedMat;

function addPhoneWindowSide(faceAxis, offset, rotY) {
// Main glass panel
var glass = new THREE.Mesh(new THREE.PlaneGeometry(glassW, glassH), phoneGlassBright);
glass.position.set(
faceAxis === 'x' ? offset : 0,
1.4,
faceAxis === 'z' ? offset : 0
);
glass.rotation.y = rotY;
phoneBox.add(glass);

// Horizontal mullions (5 bars creating 6 rows)
for (var mh = 0; mh < 5; mh++) {
var hBar = new THREE.Mesh(new THREE.BoxGeometry(
faceAxis === 'z' ? 0.76 : 0.025,
0.02,
faceAxis === 'x' ? 0.76 : 0.025
), mullionMat);
hBar.position.set(
faceAxis === 'x' ? offset * 1.02 : 0,
0.9 + mh * 0.24,
faceAxis === 'z' ? offset * 1.02 : 0
);
phoneBox.add(hBar);
}
// Vertical mullions (2 bars creating 3 columns)
for (var mv = 0; mv < 2; mv++) {
var vOff = -0.12 + mv * 0.24;
var vBar = new THREE.Mesh(new THREE.BoxGeometry(
faceAxis === 'z' ? 0.02 : 0.025,
glassH,
faceAxis === 'x' ? 0.02 : 0.025
), mullionMat);
vBar.position.set(
faceAxis === 'x' ? offset * 1.02 : vOff,
1.4,
faceAxis === 'z' ? offset * 1.02 : vOff
);
phoneBox.add(vBar);
}
}

addPhoneWindowSide('z', 0.455, 0);           // front
// Back is a solid panel (no glass on the rear of a real K6) — dark, unlit
var backPanelMat = new THREE.MeshStandardMaterial({ color: 0x3a0808, roughness: 0.8, metalness: 0.0 });
var backPanel = new THREE.Mesh(new THREE.BoxGeometry(0.76, 1.7, 0.06), backPanelMat);
backPanel.position.set(0, 1.15, -0.45);
phoneBox.add(backPanel);
addPhoneWindowSide('x', -0.455, Math.PI/2);   // left
addPhoneWindowSide('x', 0.455, -Math.PI/2);   // right

// --- ENTABLATURE (band above windows) ---
var entab = new THREE.Mesh(new THREE.BoxGeometry(0.98, 0.1, 0.98), phoneRedMat);
entab.position.set(0, 2.05, 0);
phoneBox.add(entab);

// --- TELEPHONE signs on entablature (all four sides) ---
var telSignTex = makeCanvasTexture(256, 48, function(cx, w, h) {
cx.fillStyle = '#9b1c1c';
cx.fillRect(0, 0, w, h);
cx.fillStyle = '#d0c8a0';
cx.font = 'bold 24px Georgia, serif';
cx.textAlign = 'center';
cx.textBaseline = 'middle';
cx.letterSpacing = '4px';
cx.fillText('TELEPHONE', w/2, h/2);
});
var telSignMat = new THREE.MeshStandardMaterial({ map: telSignTex, roughness: 0.5 });
// Front sign
var tsFront = new THREE.Mesh(new THREE.PlaneGeometry(0.7, 0.08), telSignMat);
tsFront.position.set(0, 2.05, 0.5);
phoneBox.add(tsFront);
// Back sign
var tsBack = new THREE.Mesh(new THREE.PlaneGeometry(0.7, 0.08), telSignMat);
tsBack.position.set(0, 2.05, -0.5);
tsBack.rotation.y = Math.PI;
phoneBox.add(tsBack);

// --- CROWN / DOME ---
// Crown cornice
var crownCornice = new THREE.Mesh(new THREE.BoxGeometry(1.02, 0.06, 1.02), phoneRedMat);
crownCornice.position.set(0, 2.13, 0);
phoneBox.add(crownCornice);

// Dome — the distinctive rounded top
var dome = new THREE.Mesh(
new THREE.CylinderGeometry(0.15, 0.48, 0.35, 8),
phoneRedMat
);
dome.position.set(0, 2.34, 0);
phoneBox.add(dome);

// Crown finial (small sphere on top)
var crownFinial = new THREE.Mesh(new THREE.SphereGeometry(0.06, 8, 6), phoneRedMat);
crownFinial.position.set(0, 2.56, 0);
phoneBox.add(crownFinial);

// --- DOOR (the side facing the camera — +Z) ---
// Door outer frame
var doorFrameL = new THREE.Mesh(new THREE.BoxGeometry(0.04, 1.7, 0.05), phoneRedDark);
doorFrameL.position.set(-0.32, 1.15, 0.46);
phoneBox.add(doorFrameL);
var doorFrameR = new THREE.Mesh(new THREE.BoxGeometry(0.04, 1.7, 0.05), phoneRedDark);
doorFrameR.position.set(0.32, 1.15, 0.46);
phoneBox.add(doorFrameR);
var doorFrameTop = new THREE.Mesh(new THREE.BoxGeometry(0.68, 0.04, 0.05), phoneRedDark);
doorFrameTop.position.set(0, 2.02, 0.46);
phoneBox.add(doorFrameTop);
var doorFrameBot = new THREE.Mesh(new THREE.BoxGeometry(0.68, 0.04, 0.05), phoneRedDark);
doorFrameBot.position.set(0, 0.32, 0.46);
phoneBox.add(doorFrameBot);

// Door glass panes (3 columns x 6 rows, matching the other sides)
var doorGlass = new THREE.Mesh(new THREE.PlaneGeometry(0.58, 1.6), phoneGlassBright);
doorGlass.position.set(0, 1.15, 0.47);
phoneBox.add(doorGlass);

// Door horizontal mullions (5 bars)
for (var dh = 0; dh < 5; dh++) {
var dHBar = new THREE.Mesh(new THREE.BoxGeometry(0.62, 0.02, 0.03), mullionMat);
dHBar.position.set(0, 0.5 + dh * 0.28, 0.47);
phoneBox.add(dHBar);
}
// Door vertical mullions (2 bars)
for (var dv = 0; dv < 2; dv++) {
var dvOff = -0.1 + dv * 0.2;
var dVBar = new THREE.Mesh(new THREE.BoxGeometry(0.02, 1.6, 0.03), mullionMat);
dVBar.position.set(dvOff, 1.15, 0.47);
phoneBox.add(dVBar);
}

// Door handle (small cylinder, on the right side)
var doorHandle = new THREE.Mesh(
new THREE.CylinderGeometry(0.015, 0.015, 0.12, 6),
phoneIronMat
);
doorHandle.rotation.x = Math.PI / 2;
doorHandle.position.set(0.24, 0.9, 0.5);
phoneBox.add(doorHandle);

// Scale up and position phone box on the west pavement, in the ginger light
phoneBox.scale.set(1.4, 1.4, 1.4);
phoneBox.position.set(-2.2, 0.15, -5.2);
phoneBox.castShadow = true;
scene.add(phoneBox);

// Interior light — warm glow spilling from the glass
var phoneGlowLight = new THREE.PointLight(0xe87818, 0.25, 5);
phoneGlowLight.position.set(-2.2, 2.0, -5.2);
scene.add(phoneGlowLight);

// ============================================================
// SILHOUETTES IN WINDOWS — gentle sway
// ============================================================
var silhouettes = [];

function makeSilhouetteTex(seed) {
return makeCanvasTexture(256, 256, function(cx, w, h) {
// Warm amber interior glow background
var bg = cx.createRadialGradient(w/2, h*0.4, 10, w/2, h*0.5, w);
bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
cx.fillStyle = bg;
cx.fillRect(0, 0, w, h);

// Dark silhouette figure
var figureCount = 1 + Math.floor(seed * 1.5);
for (var f = 0; f < figureCount; f++) {
var fx = (w / (figureCount + 1)) * (f + 1);
var baseY = h * 0.98;
var headR = 14 + seed * 6;
var shoulderW = 35 + seed * 15;

cx.fillStyle = 'rgba(10, 5, 0, 0.85)';

// Body
cx.beginPath();
cx.moveTo(fx - shoulderW/2, baseY - h*0.35);
cx.lineTo(fx + shoulderW/2, baseY - h*0.35);
cx.lineTo(fx + shoulderW/2 + 8, baseY);
cx.lineTo(fx - shoulderW/2 - 8, baseY);
cx.closePath();
cx.fill();

// Shoulders
cx.beginPath();
cx.ellipse(fx, baseY - h*0.38, shoulderW/2 + 5, 14, 0, 0, Math.PI, true);
cx.fill();

// Neck
cx.fillRect(fx - 6, baseY - h*0.48, 12, h*0.1);

// Head
cx.beginPath();
cx.arc(fx + (f - 1) * 4, baseY - h*0.52, headR, 0, Math.PI * 2);
cx.fill();
}
});
}

// Silhouette in west side building (the lit windows)
function addSilhouette(x, y, z, faceX, seed) {
var sTex = makeSilhouetteTex(seed);
var sMat = new THREE.MeshBasicMaterial({
map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 1.0), sMat);
if (faceX) {
sPlane.rotation.y = Math.PI / 2;
}
sPlane.position.set(x, y, z);
scene.add(sPlane);
silhouettes.push({
mesh: sPlane,
baseX: x,
baseY: y,
baseZ: z,
faceX: faceX,
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.2 + Math.random() * 0.4,
swayAmt: 0.015 + Math.random() * 0.02
});
}

// West building — lit windows
addSilhouette(-7.2, 8.5, 1.01, false, 0.5);
addSilhouette(-5.2, 5.5, 1.01, false, 0.8);
// East building — lit window
addSilhouette(4.0, 5, -4, true, 0.3);
// Building further north
addSilhouette(-4.0, 10.5, -9, true, 0.6);

// ============================================================
// LIGHTING
// ============================================================
// Very dim ambient — the scene should be mostly dark with ginger pools
scene.add(new THREE.AmbientLight(0x0a0a15, 0.2));

// Faint cool moonlight from above-right
var moonLight = new THREE.DirectionalLight(0x3344aa, 0.08);
moonLight.position.set(8, 20, -5);
moonLight.castShadow = true;
scene.add(moonLight);

// Warm interior glow from lit windows (west building)
var winGlow1 = new THREE.PointLight(0xd87018, 0.25, 6);
winGlow1.position.set(-6, 8.5, 2);
scene.add(winGlow1);

var winGlow2 = new THREE.PointLight(0xd87018, 0.15, 5);
winGlow2.position.set(-5, 5.5, 2);
scene.add(winGlow2);

// ============================================================
// PUDDLES — reflecting ginger light
// ============================================================
// Scattered puddles across the road and pavement — just rained
for (var i = 0; i < 20; i++) {
var puddleMat = new THREE.MeshStandardMaterial({
color: 0x080810, roughness: 0.04, metalness: 0.8, transparent: true, opacity: 0.45
});
var pSize = 0.4 + Math.random() * 1.2;
var puddle = new THREE.Mesh(new THREE.CircleGeometry(pSize, 16), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(
Math.random() * 16 - 5,
0.035,
Math.random() * 16 - 5
);
// Slightly squash each puddle so they look irregular, not perfect circles
puddle.scale.set(1, 1, 0.6 + Math.random() * 0.4);
scene.add(puddle);
}

// Large puddle directly under the lamp — ginger reflection pool
var heroReflect = new THREE.MeshStandardMaterial({
color: 0x0a0805, roughness: 0.03, metalness: 0.85, transparent: true, opacity: 0.55,
emissive: 0xe87818, emissiveIntensity: 0.12
});
var heroPuddle = new THREE.Mesh(new THREE.CircleGeometry(2.0, 24), heroReflect);
heroPuddle.rotation.x = -Math.PI / 2;
heroPuddle.position.set(-3.5, 0.038, -2.5);
heroPuddle.scale.set(1, 1, 0.7); // slightly oval
heroPuddle.renderOrder = 1;
scene.add(heroPuddle);

// Second large puddle in the road near the junction
var junctionPuddle = new THREE.Mesh(
new THREE.CircleGeometry(1.8, 20),
new THREE.MeshStandardMaterial({
color: 0x080810, roughness: 0.03, metalness: 0.85, transparent: true, opacity: 0.45
})
);
junctionPuddle.rotation.x = -Math.PI / 2;
junctionPuddle.position.set(1.5, 0.035, 1);
junctionPuddle.scale.set(1, 1, 0.6);
scene.add(junctionPuddle);

// Pavement puddle near the phone box
var pavePuddle = new THREE.Mesh(
new THREE.CircleGeometry(0.8, 16),
new THREE.MeshStandardMaterial({
color: 0x080810, roughness: 0.04, metalness: 0.8, transparent: true, opacity: 0.4
})
);
pavePuddle.rotation.x = -Math.PI / 2;
pavePuddle.position.set(-3, 0.17, -4.5);
scene.add(pavePuddle);

// (Rain has cleared — wet streets and puddles are the aftermath)

// ============================================================
// FOG VOLUMES — 4-layer Soho pea-souper
// ============================================================

// Shared fog textures
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(160, 155, 145, 0.22)');
grad.addColorStop(0.4, 'rgba(130, 125, 115, 0.1)');
grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(120, 115, 105, 0.12)');
grad.addColorStop(0.6, 'rgba(100, 95, 85, 0.05)');
grad.addColorStop(1, 'rgba(80, 75, 65, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var gingerFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.3)');
grad.addColorStop(0.25, 'rgba(220, 100, 18, 0.18)');
grad.addColorStop(0.55, 'rgba(200, 80, 12, 0.08)');
grad.addColorStop(1, 'rgba(160, 55, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// LAYER 1: Thick ground-hugging fog banks
for (var i = 0; i < 55; i++) {
var fogMat = new THREE.SpriteMaterial({
map: thickFogTex, transparent: true,
opacity: 0.2 + Math.random() * 0.2
});
var fogSprite = new THREE.Sprite(fogMat);
fogSprite.position.set(
Math.random() * 50 - 20,
0.2 + Math.random() * 1.8,
Math.random() * 50 - 20
);
var s = 5 + Math.random() * 12;
fogSprite.scale.set(s, s * 0.3, 1);
scene.add(fogSprite);
fogSprites.push({
sprite: fogSprite,
baseX: fogSprite.position.x,
drift: 0.002 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.004,
swayAmt: 0.4 + Math.random() * 1.0
});
}

// LAYER 2: Mid-height fog (building level)
for (var i = 0; i < 25; i++) {
var midFogMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.1 + Math.random() * 0.1
});
var midFog = new THREE.Sprite(midFogMat);
midFog.position.set(
Math.random() * 30 - 10,
2 + Math.random() * 5,
Math.random() * 30 - 10
);
var ms = 8 + Math.random() * 14;
midFog.scale.set(ms, ms * 0.35, 1);
scene.add(midFog);
fogSprites.push({
sprite: midFog,
baseX: midFog.position.x,
drift: 0.003 + Math.random() * 0.007,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.006,
swayAmt: 0.5 + Math.random() * 1.5
});
}

// LAYER 3: GINGER-tinted fog near the hero lamp (light bleeding into mist)
for (var i = 0; i < 40; i++) {
var gingerFogMat = new THREE.SpriteMaterial({
map: gingerFogTex, transparent: true,
opacity: 0.25 + Math.random() * 0.3
});
var gFog = new THREE.Sprite(gingerFogMat);
gFog.position.set(
-3.5 + (Math.random() - 0.5) * 16,
0.3 + Math.random() * 7,
-3.5 + (Math.random() - 0.5) * 16
);
var gs = 3 + Math.random() * 9;
gFog.scale.set(gs, gs * 0.5, 1);
scene.add(gFog);
fogSprites.push({
sprite: gFog,
baseX: gFog.position.x,
drift: 0.002 + Math.random() * 0.004,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.005,
swayAmt: 0.3 + Math.random() * 0.6
});
}

// LAYER 4: High wisps drifting past rooftops (fewer, larger, to avoid dot artefacts)
for (var i = 0; i < 10; i++) {
var wispMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.06 + Math.random() * 0.08
});
var wisp = new THREE.Sprite(wispMat);
wisp.position.set(
Math.random() * 30 - 10,
7 + Math.random() * 6,
Math.random() * 30 - 10
);
wisp.scale.set(12 + Math.random() * 15, 4 + Math.random() * 5, 1);
scene.add(wisp);
fogSprites.push({
sprite: wisp,
baseX: wisp.position.x,
drift: 0.005 + Math.random() * 0.01,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.003 + Math.random() * 0.008,
swayAmt: 0.8 + Math.random() * 2.0
});
}

// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();

function animate() {
glAnimId = requestAnimationFrame(animate);
var t = clock.getElapsedTime();

// --- CAMERA BREATHING ---
// Very subtle sway, like someone standing still on a cold night
camera.position.x = cameraBase.x + Math.sin(t * 0.15) * 0.03;
camera.position.y = cameraBase.y + Math.sin(t * 0.22) * 0.015;
camera.position.z = cameraBase.z + Math.cos(t * 0.18) * 0.02;

// --- HERO LAMP FLICKER ---
// Ginger gaslight flicker — irregular, organic
var flicker = 0.85
+ Math.sin(t * 1.7) * 0.08
+ Math.sin(t * 4.3) * 0.04
+ Math.sin(t * 7.1) * 0.02
+ Math.sin(t * 11.3) * 0.01;
gingerLight.intensity = 3.2 * flicker;
gingerFill.intensity = 1.2 * flicker;
gingerWash.intensity = 0.5 * flicker;
downSpot.intensity = 2.0 * flicker;

// Glow sprite pulses with the flicker
gingerGlow.material.opacity = 0.7 + (flicker - 0.85) * 2;
innerGlow.material.opacity = 0.8 + (flicker - 0.85) * 3;

// Lantern glass emissive flicker
gingerGlassMat.emissiveIntensity = 0.65 + (flicker - 0.85) * 3;

// Puddle reflection emissive flicker
heroReflect.emissiveIntensity = 0.02 + (flicker - 0.85) * 0.15;

// --- SECONDARY LAMP FLICKER ---
for (var i = 1; i < lampLights.length; i++) {
var lFlicker = 0.85 + Math.sin(t * (2.5 + i * 1.9)) * 0.06 + Math.sin(t * (5 + i * 3.1)) * 0.03;
lampLights[i].intensity = 0.3 * lFlicker;
}

// --- FOG DRIFT ---
for (var i = 0; i < fogSprites.length; i++) {
var f = fogSprites[i];
f.sway += f.swaySpeed;
f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
f.baseX += f.drift;
if (f.baseX > 25) f.baseX = -20;
}

// --- CHIMNEY SMOKE ---
for (var i = 0; i < smokeSprites.length; i++) {
var sm = smokeSprites[i];
var sprite = sm.sprite;
// Rise upward
sprite.position.y += sm.rise;
// Drift sideways with a gentle sway
sprite.position.x = sm.baseX + Math.sin(sm.phase + t * 0.3) * 0.8;
sprite.position.z = sm.baseZ + Math.cos(sm.phase + t * 0.2) * 0.3;
// Grow as it rises
var age = (sprite.position.y - sm.startY) / sm.maxHeight;
var scale = sm.baseScale + age * 2.5;
sprite.scale.set(scale, scale, 1);
// Fade out as it rises
sprite.material.opacity = Math.max(0, (1 - age) * 0.2);
// Reset when too high
if (sprite.position.y > sm.startY + sm.maxHeight) {
sprite.position.y = sm.startY;
sprite.position.x = sm.baseX + (Math.random() - 0.5) * 0.3;
}
}

// --- WARM GLASS PULSE ---
warmGlass.emissiveIntensity = 0.1 + Math.sin(t * 0.6) * 0.04 + Math.sin(t * 1.9) * 0.02;

// --- SILHOUETTE SWAY ---
for (var i = 0; i < silhouettes.length; i++) {
var s = silhouettes[i];
s.swayPhase += s.swaySpeed * 0.016;
var swayOffset = Math.sin(s.swayPhase) * s.swayAmt;
s.mesh.position.y = s.baseY + Math.sin(s.swayPhase * 0.7) * 0.01;
if (s.faceX) {
s.mesh.position.z = s.baseZ + swayOffset;
} else {
s.mesh.position.x = s.baseX + swayOffset;
}
}

// --- WINDOW GLOW ---
winGlow1.intensity = 0.25 + Math.sin(t * 0.4) * 0.05;
winGlow2.intensity = 0.15 + Math.sin(t * 0.7) * 0.03;

renderer.render(scene, camera);
}

// Run the scene
animate();

// Approach button — fades in after 1.5s
var glBtn = document.createElement('div');
glBtn.textContent = 'APPROACH THE GINGER LIGHT';
glBtn.style.cssText = [
'position:absolute','bottom:60px','left:50%','transform:translateX(-50%)',
'font:13px \'Courier New\',monospace','color:rgba(232,120,24,0.85)',
'letter-spacing:4px','cursor:pointer','padding:12px 28px',
'border:1px solid rgba(232,120,24,0.3)','background:rgba(0,0,0,0.4)',
'z-index:9003','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
glWrap.appendChild(glBtn);
setTimeout(function() { glBtn.style.opacity = '1'; }, 1500);

glBtn.addEventListener('mouseenter', function() {
this.style.color = 'rgba(255,160,50,0.95)';
this.style.borderColor = 'rgba(232,120,24,0.6)';
});
glBtn.addEventListener('mouseleave', function() {
this.style.color = 'rgba(232,120,24,0.85)';
this.style.borderColor = 'rgba(232,120,24,0.3)';
});

glBtn.addEventListener('click', function() {
glWrap.style.transition = 'opacity 1.2s ease';
glWrap.style.opacity = '0';
setTimeout(function() {
cancelAnimationFrame(glAnimId);
glWrap.remove();
// glActive stays TRUE while Harlowe navigates — prevents re-init loop
var TARGET = 'At the Corner of Dean Street and Greek Street';
// 1. Try specific passage-name attribute
var link = document.querySelector('tw-link[passage-name="' + TARGET + '"]');
// 2. Try middle-dot link text (our hidden link [[·|...]])
if (!link) {
var allLinks = document.querySelectorAll('tw-passage tw-link');
for (var i = 0; i < allLinks.length; i++) {
if (allLinks[i].textContent.trim() === '·') { link = allLinks[i]; break; }
}
}
// 3. Inject directly into tw-story so Harlowe's event delegation catches it
if (link) {
link.click();
} else {
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', TARGET);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.click();
storyEl.removeChild(injected);
}
}, 1200);
});
}

// Watch for ga-container — persistent across passage changes
setInterval(function() {
var container = document.getElementById('ga-container');
if (container && !glActive) {
initGingerLight();
} else if (!container) {
glActive = false; // reset only when passage has actually changed
}
}, 300);
})();

// ====== FRENCH HOUSE SCENE — INLINE ======
(function() {
var fhActive = false;
var fhAnimId = null;

function initFrenchHouse() {
if (fhActive) return;
fhActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildFHScene(); };
document.head.appendChild(s);
} else {
buildFHScene();
}
}

function buildFHScene() {
// Full-screen overlay
var fhWrap = document.createElement('div');
fhWrap.id = 'fh-wrap';
fhWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#050508;';

// Canvas for Three.js
var fhCanvas = document.createElement('canvas');
fhCanvas.width = window.innerWidth;
fhCanvas.height = window.innerHeight;
fhCanvas.style.cssText = 'display:block;position:absolute;top:0;left:0;';
fhWrap.appendChild(fhCanvas);

// Vignette overlay (offset centre for painterly feel)
var fhVig = document.createElement('div');
fhVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%,transparent 30%,rgba(0,0,0,0.6) 100%);';
fhWrap.appendChild(fhVig);

// Film grain overlay
var fhGrain = document.createElement('div');
fhGrain.id = 'grain';
fhGrain.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;opacity:0.02;mix-blend-mode:overlay;';
fhWrap.appendChild(fhGrain);

// Colour wash overlay
var fhColorwash = document.createElement('div');
fhColorwash.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9000;background:linear-gradient(180deg,rgba(10,8,25,0.3) 0%,rgba(5,5,15,0.08) 30%,rgba(5,5,15,0.08) 60%,rgba(5,3,2,0.4) 100%);';
fhWrap.appendChild(fhColorwash);

// Datestamp
var fhDate = document.createElement('div');
fhDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
fhDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.4);pointer-events:none;z-index:9003;';
fhWrap.appendChild(fhDate);

// Location label
var fhLoc = document.createElement('div');
fhLoc.textContent = 'DEAN STREET, SOHO';
fhLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px \'Courier New\',monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
fhWrap.appendChild(fhLoc);

document.body.appendChild(fhWrap);

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x050508);
scene.fog = new THREE.Fog(0x050508, 3, 28);

var camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT — Camera angled slightly from the right, looking left
// ============================================================
// Facade at z=0 facing +Z. Camera offset to the right so we see
// the building at a gentle angle, left side receding.
camera.position.set(4.0, 4.2, 16);
camera.lookAt(-0.5, 5.2, 0);

var renderer = new THREE.WebGLRenderer({ canvas: fhCanvas, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.55;

window.addEventListener('resize', function() {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================
var redBrick = new THREE.MeshStandardMaterial({ color: 0x8a4a38, roughness: 0.85 });
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x6a3a2a, roughness: 0.9 });
var lightBrick = new THREE.MeshStandardMaterial({ color: 0x9a5a48, roughness: 0.8 });
var whiteTrim = new THREE.MeshStandardMaterial({ color: 0xe8e4dc, roughness: 0.7 });
var creamTrim = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.75 });
var bluePaint = new THREE.MeshStandardMaterial({ color: 0x1a2a5a, roughness: 0.6 });
var darkBlue = new THREE.MeshStandardMaterial({ color: 0x0a1a3a, roughness: 0.7 });
var midBlue = new THREE.MeshStandardMaterial({ color: 0x15245a, roughness: 0.65 });
var blackFascia = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.5 });
var goldMat = new THREE.MeshStandardMaterial({ color: 0xc8a840, roughness: 0.3, metalness: 0.4 });
var brassMat = new THREE.MeshStandardMaterial({ color: 0xb89830, roughness: 0.35, metalness: 0.5 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.9 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.85 });
var sillMat = new THREE.MeshStandardMaterial({ color: 0xdcd4c8, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a15, roughness: 0.2, metalness: 0.3 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.6 });
var pipeMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.3 });
var woodMat = new THREE.MeshStandardMaterial({ color: 0x3a2a1a, roughness: 0.8 });
var darkWood = new THREE.MeshStandardMaterial({ color: 0x201510, roughness: 0.85 });
var plasterMat = new THREE.MeshStandardMaterial({ color: 0xc8c0b0, roughness: 0.8 });

// ============================================================
// HELPERS
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(group, geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
group.add(m);
return m;
}

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 10);
road.receiveShadow = true;
scene.add(road);

// Wet road surface (reflective sheen)
var wetMat = new THREE.MeshStandardMaterial({
color: 0x1a1a1a, roughness: 0.15, metalness: 0.5, transparent: true, opacity: 0.25
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(14, 14), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(0, 0.01, 8);
scene.add(wetRoad);

// Road centre line (period-correct white dashed line)
for (var rli = -6; rli < 20; rli += 2.5) {
var roadLine = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 1.5),
new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.7, transparent: true, opacity: 0.3 }));
roadLine.rotation.x = -Math.PI / 2;
roadLine.position.set(0, 0.02, rli);
scene.add(roadLine);
}

// ============================================================
// THE FRENCH HOUSE
// ============================================================
var pub = new THREE.Group();

// ---- MAIN BRICK BODY ----
// 4 storeys of red brick. Facade at z=0 facing +Z.
// Width about 7 units (x from -3 to 4)
var brickBody = new THREE.Mesh(new THREE.BoxGeometry(7, 13, 7), redBrick);
brickBody.position.set(0.5, 6.5, -3.5);
pub.add(brickBody);

// Slightly darker brick face panel (facade texture variation)
var facadePanel = new THREE.Mesh(new THREE.BoxGeometry(7.02, 13, 0.08), darkBrick);
facadePanel.position.set(0.5, 6.5, 0.04);
pub.add(facadePanel);

// Side wall visible at the angle — slightly different brick tone
var sideWall = new THREE.Mesh(new THREE.PlaneGeometry(7, 13),
new THREE.MeshStandardMaterial({ color: 0x7a4438, roughness: 0.88 }));
sideWall.position.set(4.01, 6.5, -3.5);
sideWall.rotation.y = -Math.PI / 2;
pub.add(sideWall);

// Individual brick coursework hints on facade (horizontal mortar lines)
for (var bri = 0.6; bri < 13; bri += 0.35) {
if (Math.random() > 0.3) {
var mortarLine = new THREE.Mesh(new THREE.PlaneGeometry(7.01, 0.015),
new THREE.MeshStandardMaterial({ color: 0xb09888, roughness: 0.9, transparent: true, opacity: 0.2 }));
mortarLine.position.set(0.5, bri, 0.06);
pub.add(mortarLine);
}
}

// ---- WHITE HORIZONTAL STRING COURSES (between floors) ----
var stringHeights = [3.6, 6.8, 10.0];
for (var si = 0; si < stringHeights.length; si++) {
// Main course
var stringCourse = new THREE.Mesh(new THREE.BoxGeometry(7.1, 0.12, 0.14), whiteTrim);
stringCourse.position.set(0.5, stringHeights[si], 0.12);
pub.add(stringCourse);
// Upper lip (projecting slightly)
placeMesh(pub, new THREE.BoxGeometry(7.12, 0.04, 0.18), whiteTrim, 0.5, stringHeights[si] + 0.07, 0.14);
// Shadow line below
var shadowLine = new THREE.Mesh(new THREE.BoxGeometry(7.1, 0.03, 0.06),
new THREE.MeshStandardMaterial({ color: 0x5a3a2a, roughness: 0.9 }));
shadowLine.position.set(0.5, stringHeights[si] - 0.08, 0.1);
pub.add(shadowLine);
// Side return on right (visible at angle)
placeMesh(pub, new THREE.BoxGeometry(0.14, 0.12, 0.3), whiteTrim, 4.01, stringHeights[si], -0.02);
}

// ---- TOP CORNICE (heavy projecting cornice at roofline) ----
var topCornice = new THREE.Mesh(new THREE.BoxGeometry(7.3, 0.2, 0.4), whiteTrim);
topCornice.position.set(0.5, 13.05, 0.2);
pub.add(topCornice);
// Second layer — deeper projection
placeMesh(pub, new THREE.BoxGeometry(7.35, 0.1, 0.5), whiteTrim, 0.5, 12.95, 0.28);
// Cornice underside
var corniceUnder = new THREE.Mesh(new THREE.BoxGeometry(7.3, 0.08, 0.5), creamTrim);
corniceUnder.position.set(0.5, 12.85, 0.25);
pub.add(corniceUnder);
// Dentil course (small blocks under cornice)
for (var di = -3; di <= 4; di += 0.3) {
var dentil = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.1, 0.06), whiteTrim);
dentil.position.set(di, 12.78, 0.22);
pub.add(dentil);
}
// Moulding band below dentils
placeMesh(pub, new THREE.BoxGeometry(7.25, 0.05, 0.1), creamTrim, 0.5, 12.7, 0.15);
// Side return of cornice
placeMesh(pub, new THREE.BoxGeometry(0.4, 0.2, 0.5), whiteTrim, 4.01, 13.05, -0.05);

// ---- MANSARD ROOF with DORMER WINDOWS ----
var roofMat = new THREE.MeshStandardMaterial({ color: 0x2a2a30, roughness: 0.85 });
var slateMat = new THREE.MeshStandardMaterial({ color: 0x3a3a42, roughness: 0.8 });
var roofSlab = new THREE.Mesh(new THREE.BoxGeometry(7.2, 1.8, 4), roofMat);
roofSlab.position.set(0.5, 14, -1.5);
pub.add(roofSlab);
// Mansard slope face (slightly angled appearance — a tilted plane)
var mansardFace = new THREE.Mesh(new THREE.PlaneGeometry(7.22, 2.0), slateMat);
mansardFace.position.set(0.5, 14, 0.52);
mansardFace.rotation.x = 0.15;
pub.add(mansardFace);
// Ridge tiles along top
placeMesh(pub, new THREE.BoxGeometry(7.2, 0.08, 0.12), roofMat, 0.5, 14.92, -0.2);
// Lead flashing strip at base of mansard
placeMesh(pub, new THREE.BoxGeometry(7.22, 0.06, 0.06),
new THREE.MeshStandardMaterial({ color: 0x555560, roughness: 0.4, metalness: 0.3 }),
0.5, 13.15, 0.12);

// Dormer windows (5 across the top)
for (var dx = -2.2; dx <= 3.2; dx += 1.35) {
// Dormer box
var dormerBox = new THREE.Mesh(new THREE.BoxGeometry(0.9, 1.2, 0.8), roofMat);
dormerBox.position.set(dx, 14.1, 0.3);
pub.add(dormerBox);
// White dormer face
var dormerFace = new THREE.Mesh(new THREE.BoxGeometry(0.92, 1.22, 0.06), whiteTrim);
dormerFace.position.set(dx, 14.1, 0.72);
pub.add(dormerFace);
// Dormer cheeks (side walls visible at angle)
placeMesh(pub, new THREE.BoxGeometry(0.06, 1.2, 0.8), slateMat, dx + 0.46, 14.1, 0.32);
placeMesh(pub, new THREE.BoxGeometry(0.06, 1.2, 0.8), slateMat, dx - 0.46, 14.1, 0.32);
// Glass with warm hint
var dormerGlass = new THREE.Mesh(new THREE.PlaneGeometry(0.6, 0.85),
new THREE.MeshBasicMaterial({ color: 0x556688, transparent: true, opacity: 0.3 }));
dormerGlass.position.set(dx, 14.15, 0.76);
pub.add(dormerGlass);
// Glazing bars — cross pattern
placeMesh(pub, new THREE.BoxGeometry(0.02, 0.85, 0.02), whiteTrim, dx, 14.15, 0.78);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.02, 0.02), whiteTrim, dx, 14.15, 0.78);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.02, 0.02), whiteTrim, dx, 14.42, 0.78);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.02, 0.02), whiteTrim, dx, 13.88, 0.78);
// Dormer sill
placeMesh(pub, new THREE.BoxGeometry(0.7, 0.04, 0.08), whiteTrim, dx, 13.68, 0.76);
// Peaked top
var dormerPeak = new THREE.Mesh(new THREE.ConeGeometry(0.55, 0.5, 4), roofMat);
dormerPeak.position.set(dx, 14.95, 0.3);
dormerPeak.rotation.y = Math.PI / 4;
pub.add(dormerPeak);
// Finial on peak
placeMesh(pub, new THREE.CylinderGeometry(0.015, 0.015, 0.15, 4), ironMat, dx, 15.25, 0.3);
}

// ---- UPPER FLOOR WINDOWS (3 rows of sash windows) ----
function addSashWindow(x, y, isLit, isBigger) {
var ww = isBigger ? 1.0 : 0.85;
var wh = isBigger ? 1.8 : 1.5;

// Brick reveal (recessed surround — creates depth)
placeMesh(pub, new THREE.BoxGeometry(ww + 0.28, wh + 0.28, 0.05),
new THREE.MeshStandardMaterial({ color: 0x5a3228, roughness: 0.9 }),
x, y, 0.04);

// White frame surround — outer
placeMesh(pub, new THREE.BoxGeometry(ww + 0.22, wh + 0.22, 0.06), windowFrame, x, y, 0.07);
// Inner frame (slightly recessed)
placeMesh(pub, new THREE.BoxGeometry(ww + 0.08, wh + 0.08, 0.04), windowFrame, x, y, 0.1);

// Glass — warm amber glow (lit) or dim bluish (dark)
var glassOp = isLit ? 0.75 : 0.25;
var glassCol = isLit ? 0xffcc66 : 0x2a3a55;
var glassMat = new THREE.MeshBasicMaterial({ color: glassCol, transparent: true, opacity: glassOp });
placeMesh(pub, new THREE.PlaneGeometry(ww, wh), glassMat, x, y, 0.14);
// Extra inner glow behind lit windows (warm light spilling out)
if (isLit) {
var innerGlow = new THREE.Mesh(new THREE.PlaneGeometry(ww * 0.8, wh * 0.7),
new THREE.MeshBasicMaterial({ color: 0xffe0a0, transparent: true, opacity: 0.3 }));
innerGlow.position.set(x, y, 0.12);
pub.add(innerGlow);
}

// Sash bar (horizontal divider — the distinctive sash window split)
placeMesh(pub, new THREE.BoxGeometry(ww + 0.1, 0.06, 0.06), windowFrame, x, y + 0.1, 0.14);
// Sash lift rail (thinner bar in lower sash)
placeMesh(pub, new THREE.BoxGeometry(ww, 0.025, 0.03), windowFrame, x, y - 0.2, 0.15);

// Vertical glazing bars (6 over 6 pane style)
placeMesh(pub, new THREE.BoxGeometry(0.025, wh, 0.02), windowFrame, x - ww * 0.25, y, 0.16);
placeMesh(pub, new THREE.BoxGeometry(0.025, wh, 0.02), windowFrame, x + ww * 0.25, y, 0.16);
// Horizontal glazing bars (upper and lower sections)
placeMesh(pub, new THREE.BoxGeometry(ww, 0.025, 0.02), windowFrame, x, y + wh * 0.22, 0.16);
placeMesh(pub, new THREE.BoxGeometry(ww, 0.025, 0.02), windowFrame, x, y - wh * 0.22, 0.16);
// Extra horizontals for 6-pane look
placeMesh(pub, new THREE.BoxGeometry(ww, 0.02, 0.02), windowFrame, x, y + wh * 0.36, 0.16);
placeMesh(pub, new THREE.BoxGeometry(ww, 0.02, 0.02), windowFrame, x, y - wh * 0.36, 0.16);

// Stone sill (projecting, with drip edge)
placeMesh(pub, new THREE.BoxGeometry(ww + 0.3, 0.08, 0.2), sillMat, x, y - wh / 2 - 0.06, 0.16);
// Drip edge underneath sill
placeMesh(pub, new THREE.BoxGeometry(ww + 0.32, 0.025, 0.03), sillMat, x, y - wh / 2 - 0.12, 0.22);

// Brick flat arch / lintel above (slightly lighter brick — gauged brick)
placeMesh(pub, new THREE.BoxGeometry(ww + 0.25, 0.12, 0.06), lightBrick, x, y + wh / 2 + 0.08, 0.1);
// Keystone hint at centre of lintel
placeMesh(pub, new THREE.BoxGeometry(0.1, 0.16, 0.04), lightBrick, x, y + wh / 2 + 0.1, 0.13);
}

// Window X positions (4 across, roughly evenly spaced)
var winXs = [-1.8, -0.3, 1.2, 2.7];

// 3rd floor windows (smaller, top floor — most lit, it's evening)
var topLit = [true, false, true, true];
for (var wi = 0; wi < winXs.length; wi++) {
addSashWindow(winXs[wi], 11.4, topLit[wi], false);
}
// 2nd floor windows (bigger — these have the flags — all lit)
for (var wi = 0; wi < winXs.length; wi++) {
addSashWindow(winXs[wi], 8.4, true, true);
}
// 1st floor windows (biggest, warmly lit — main pub floor)
for (var wi = 0; wi < winXs.length; wi++) {
addSashWindow(winXs[wi], 5.2, true, true);
}

// ---- FLAGS (hanging from first floor windows) ----
function makeTricolore() {
return makeCanvasTexture(96, 64, function(cx, w, h) {
cx.fillStyle = '#002395'; cx.fillRect(0, 0, w / 3, h);
cx.fillStyle = '#ffffff'; cx.fillRect(w / 3, 0, w / 3, h);
cx.fillStyle = '#ed2939'; cx.fillRect(w * 2 / 3, 0, w / 3, h);
// Slight fabric texture
for (var fy = 0; fy < h; fy += 3) {
cx.fillStyle = 'rgba(0,0,0,0.03)';
cx.fillRect(0, fy, w, 1);
}
});
}

// Flags at each 1st floor window — ALL French tricolores
var flagMeshes = [];
for (var fi = 0; fi < winXs.length; fi++) {
var flagTex = makeTricolore();
var flagMat = new THREE.MeshBasicMaterial({
map: flagTex, side: THREE.DoubleSide, transparent: true, opacity: 0.9
});
var flagPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.7, 0.5), flagMat);
flagPlane.position.set(winXs[fi], 6.4, 0.6);
flagPlane.rotation.x = -0.3;
flagPlane.rotation.z = (fi % 2 === 0) ? 0.15 : -0.15;
pub.add(flagPlane);
flagMeshes.push({ mesh: flagPlane, baseRotZ: flagPlane.rotation.z, phase: Math.random() * Math.PI * 2 });
// Flag pole
var pole = new THREE.Mesh(new THREE.CylinderGeometry(0.015, 0.015, 1.0, 4), ironMat);
pole.position.set(winXs[fi], 6.5, 0.25);
pole.rotation.x = -0.6;
pub.add(pole);
// Pole bracket on wall
placeMesh(pub, new THREE.BoxGeometry(0.06, 0.06, 0.15), ironMat, winXs[fi], 6.55, 0.12);
}

// Two larger tricolores flanking the fascia
var bigFlagMeshes = [];
var bigFlagL = new THREE.Mesh(new THREE.PlaneGeometry(0.9, 0.6),
new THREE.MeshBasicMaterial({ map: makeTricolore(), side: THREE.DoubleSide, transparent: true, opacity: 0.9 }));
bigFlagL.position.set(-2.5, 3.9, 0.8);
bigFlagL.rotation.x = -0.2;
pub.add(bigFlagL);
bigFlagMeshes.push({ mesh: bigFlagL, baseRotZ: 0, phase: 0.5 });

var bigFlagR = new THREE.Mesh(new THREE.PlaneGeometry(0.9, 0.6),
new THREE.MeshBasicMaterial({ map: makeTricolore(), side: THREE.DoubleSide, transparent: true, opacity: 0.9 }));
bigFlagR.position.set(3.5, 3.9, 0.8);
bigFlagR.rotation.x = -0.2;
pub.add(bigFlagR);
bigFlagMeshes.push({ mesh: bigFlagR, baseRotZ: 0, phase: 1.2 });

// ---- BLACK FASCIA "THE FRENCH HOUSE" ----
var fasciaC = document.createElement('canvas');
fasciaC.width = 768; fasciaC.height = 80;
var fctx = fasciaC.getContext('2d');
fctx.fillStyle = '#0a0a0a';
fctx.fillRect(0, 0, 768, 80);
// Gold border with double line
fctx.strokeStyle = '#c8a840'; fctx.lineWidth = 3;
fctx.strokeRect(4, 4, 760, 72);
fctx.strokeStyle = '#a08830'; fctx.lineWidth = 1;
fctx.strokeRect(8, 8, 752, 64);
// "Pol Roger & Co" on left
fctx.fillStyle = '#a08830';
fctx.font = 'italic 16px Georgia, serif';
fctx.textAlign = 'left';
fctx.fillText('Pol Roger & Co', 25, 50);
fctx.textAlign = 'right';
fctx.fillText('Pol Roger & Co', 743, 50);
// "THE FRENCH HOUSE" centred in gold
fctx.fillStyle = '#d4b040';
fctx.font = 'bold 36px Georgia, serif';
fctx.textAlign = 'center';
fctx.fillText('THE  FRENCH  HOUSE', 384, 48);
// Thin gold decorative rule
fctx.strokeStyle = '#b09830'; fctx.lineWidth = 1;
fctx.beginPath(); fctx.moveTo(150, 60); fctx.lineTo(618, 60); fctx.stroke();

var fasciaTex = new THREE.CanvasTexture(fasciaC);
var fascia = new THREE.Mesh(new THREE.BoxGeometry(7.0, 0.65, 0.2),
new THREE.MeshBasicMaterial({ map: fasciaTex }));
fascia.position.set(0.5, 3.85, 0.35);
pub.add(fascia);
// Fascia underside (black slab)
placeMesh(pub, new THREE.BoxGeometry(7.0, 0.08, 0.35), blackFascia, 0.5, 3.5, 0.3);
// Fascia top cap (gold strip)
placeMesh(pub, new THREE.BoxGeometry(7.02, 0.03, 0.22), goldMat, 0.5, 4.19, 0.35);

// Victorian globe lamps on fascia (3 lamps now)
var fasciaLamps = [];
for (var flx = -2.2; flx <= 3.2; flx += 2.7) {
// Ornate bracket
placeMesh(pub, new THREE.BoxGeometry(0.06, 0.25, 0.08), ironMat, flx, 4.15, 0.42);
placeMesh(pub, new THREE.BoxGeometry(0.04, 0.04, 0.15), ironMat, flx, 4.3, 0.48);
// Decorative scroll (curved bracket hint)
placeMesh(pub, new THREE.BoxGeometry(0.03, 0.15, 0.03), ironMat, flx + 0.04, 4.22, 0.46);
// Globe
var globe = new THREE.Mesh(new THREE.SphereGeometry(0.09, 8, 8),
new THREE.MeshBasicMaterial({ color: 0xffeebb, transparent: true, opacity: 0.7 }));
globe.position.set(flx, 4.35, 0.55);
pub.add(globe);
// Inner filament glow
var filament = new THREE.Mesh(new THREE.SphereGeometry(0.03, 4, 4),
new THREE.MeshBasicMaterial({ color: 0xffcc66 }));
filament.position.set(flx, 4.35, 0.55);
pub.add(filament);
var fasciaLight = new THREE.PointLight(0xffd080, 0.5, 5);
fasciaLight.position.set(flx, 4.35, 0.65);
fasciaLight.userData.baseIntensity = 0.5;
pub.add(fasciaLight);
fasciaLamps.push(fasciaLight);
}

// ---- BLUE AWNINGS (3 across the ground floor) ----
var awningMat = new THREE.MeshStandardMaterial({ color: 0x1a2a6a, roughness: 0.5 });
var awningEdge = new THREE.MeshStandardMaterial({ color: 0x1a2058, roughness: 0.6 });
var awningPositions = [-1.5, 0.5, 2.5];
for (var ai = 0; ai < awningPositions.length; ai++) {
// Awning body (angled box)
var awning = new THREE.Mesh(new THREE.BoxGeometry(2.0, 0.08, 0.9), awningMat);
awning.position.set(awningPositions[ai], 3.2, 0.7);
awning.rotation.x = 0.2;
pub.add(awning);
// Awning underside (slightly different shade for depth)
var awningUnder = new THREE.Mesh(new THREE.PlaneGeometry(1.95, 0.85), midBlue);
awningUnder.position.set(awningPositions[ai], 3.16, 0.7);
awningUnder.rotation.x = -Math.PI / 2 + 0.2;
pub.add(awningUnder);
// Awning front flap (valance)
var flap = new THREE.Mesh(new THREE.BoxGeometry(2.0, 0.3, 0.04), awningMat);
flap.position.set(awningPositions[ai], 3.0, 1.12);
pub.add(flap);
// Scalloped edge along bottom of valance (small triangles via thin boxes)
for (var sci = -0.85; sci <= 0.85; sci += 0.2) {
placeMesh(pub, new THREE.BoxGeometry(0.08, 0.06, 0.02), awningEdge,
awningPositions[ai] + sci, 2.83, 1.12);
}
// Awning side panels
placeMesh(pub, new THREE.BoxGeometry(0.04, 0.35, 0.9), awningMat, awningPositions[ai] - 1.0, 3.1, 0.7);
placeMesh(pub, new THREE.BoxGeometry(0.04, 0.35, 0.9), awningMat, awningPositions[ai] + 1.0, 3.1, 0.7);

// Text labels on awning front
var awningTextC = document.createElement('canvas');
awningTextC.width = 256; awningTextC.height = 48;
var atctx = awningTextC.getContext('2d');
atctx.fillStyle = '#1a2a6a'; atctx.fillRect(0, 0, 256, 48);
atctx.fillStyle = '#d8d0b0'; atctx.font = 'bold 22px Georgia, serif'; atctx.textAlign = 'center';
if (ai === 1) {
atctx.fillText('The French House', 128, 33);
} else {
atctx.fillStyle = '#e0d080'; atctx.font = 'bold 26px Georgia, serif';
atctx.fillText('RICARD', 128, 34);
}
var awningTex = new THREE.CanvasTexture(awningTextC);
var awningLabel = new THREE.Mesh(new THREE.PlaneGeometry(1.9, 0.26),
new THREE.MeshBasicMaterial({ map: awningTex }));
awningLabel.position.set(awningPositions[ai], 3.01, 1.15);
pub.add(awningLabel);
}

// ---- BLUE GROUND FLOOR ----
var blueGF = new THREE.Mesh(new THREE.BoxGeometry(7.02, 3.2, 0.15), bluePaint);
blueGF.position.set(0.5, 1.6, 0.15);
pub.add(blueGF);

// Thin gold pinstripe at top of blue area
placeMesh(pub, new THREE.BoxGeometry(7.04, 0.025, 0.04), goldMat, 0.5, 3.22, 0.24);

// White pilasters dividing the ground floor bays
var pilasterXs = [-3.0, -0.5, 1.5, 3.5];
for (var pxi = 0; pxi < pilasterXs.length; pxi++) {
// Main pilaster body
placeMesh(pub, new THREE.BoxGeometry(0.15, 3.2, 0.2), whiteTrim, pilasterXs[pxi], 1.6, 0.28);
// Fluted detail (vertical grooves via thin strips)
placeMesh(pub, new THREE.BoxGeometry(0.02, 3.0, 0.04), creamTrim, pilasterXs[pxi] - 0.04, 1.6, 0.39);
placeMesh(pub, new THREE.BoxGeometry(0.02, 3.0, 0.04), creamTrim, pilasterXs[pxi] + 0.04, 1.6, 0.39);
// Capital detail at top
placeMesh(pub, new THREE.BoxGeometry(0.22, 0.12, 0.24), whiteTrim, pilasterXs[pxi], 3.22, 0.28);
placeMesh(pub, new THREE.BoxGeometry(0.18, 0.06, 0.22), creamTrim, pilasterXs[pxi], 3.16, 0.28);
// Base plinth
placeMesh(pub, new THREE.BoxGeometry(0.2, 0.15, 0.22), whiteTrim, pilasterXs[pxi], 0.08, 0.28);
}

// Ground floor windows (large, warmly lit — 3 bays)
var bayXPositions = [-1.75, 0.5, 2.5];
var bayWidths = [2.2, 1.8, 1.8];
for (var bi = 0; bi < bayXPositions.length; bi++) {
var bx = bayXPositions[bi];
var bw = bayWidths[bi];

// Blue window frame (outer)
placeMesh(pub, new THREE.BoxGeometry(bw + 0.18, 2.4, 0.06), bluePaint, bx, 1.6, 0.26);
// Inner frame
placeMesh(pub, new THREE.BoxGeometry(bw + 0.08, 2.3, 0.04), darkBlue, bx, 1.6, 0.29);

// Large window glass — bright warm glow (main pub floor, lights on)
var gfGlass = new THREE.Mesh(new THREE.PlaneGeometry(bw, 2.2),
new THREE.MeshBasicMaterial({ color: 0xffcc66, transparent: true, opacity: 0.7 }));
gfGlass.position.set(bx, 1.6, 0.32);
pub.add(gfGlass);
// Inner warm glow layer (deeper amber, gives depth)
var gfInner = new THREE.Mesh(new THREE.PlaneGeometry(bw * 0.85, 1.8),
new THREE.MeshBasicMaterial({ color: 0xffe0a0, transparent: true, opacity: 0.35 }));
gfInner.position.set(bx, 1.6, 0.28);
pub.add(gfInner);

// Vertical glazing bars (more detailed)
var numBars = Math.floor(bw / 0.5);
for (var gbi = 0; gbi <= numBars; gbi++) {
var gbx = bx - bw / 2 + gbi * (bw / numBars);
placeMesh(pub, new THREE.BoxGeometry(0.035, 2.2, 0.04), whiteTrim, gbx, 1.6, 0.34);
}
// Horizontal glazing bars (3 across for multi-pane effect)
placeMesh(pub, new THREE.BoxGeometry(bw, 0.035, 0.04), whiteTrim, bx, 2.0, 0.34);
placeMesh(pub, new THREE.BoxGeometry(bw, 0.035, 0.04), whiteTrim, bx, 1.2, 0.34);
placeMesh(pub, new THREE.BoxGeometry(bw, 0.05, 0.04), whiteTrim, bx, 0.45, 0.34);

// Kickboard below window (solid dark blue with panelling)
placeMesh(pub, new THREE.BoxGeometry(bw, 0.35, 0.08), darkBlue, bx, 0.28, 0.3);
// Panel inset
placeMesh(pub, new THREE.BoxGeometry(bw - 0.15, 0.22, 0.03), midBlue, bx, 0.28, 0.35);

// Transom bar above window
placeMesh(pub, new THREE.BoxGeometry(bw + 0.1, 0.06, 0.06), whiteTrim, bx, 2.75, 0.32);
}

