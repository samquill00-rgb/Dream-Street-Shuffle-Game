<div class="phone-scene">
<svg class="phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="phBl"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="phCd" x1="0" x2="1"><stop offset="0%" stop-color="#5a2818" stop-opacity="0"/><stop offset="20%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="50%" stop-color="#8a4030" stop-opacity="0.62"/><stop offset="80%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="100%" stop-color="#5a2818" stop-opacity="0"/></linearGradient><linearGradient id="phHd" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4a1812"/><stop offset="40%" stop-color="#7a2e20"/><stop offset="100%" stop-color="#5a2018"/></linearGradient><radialGradient id="phGw" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#c08040" stop-opacity="0.12"/><stop offset="100%" stop-color="#c08040" stop-opacity="0"/></radialGradient></defs><!-- smoke wisps --><ellipse cx="125" cy="26" rx="58" ry="18" fill="#a08060" opacity="0.06" filter="url(#phBl)"/><ellipse cx="190" cy="30" rx="45" ry="14" fill="#907050" opacity="0.05" filter="url(#phBl)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#phGw)"/><!-- cord shadow for depth --><path d="M14 29 Q20 14 26 29 Q32 44 38 29 Q44 14 50 29 Q56 44 62 29 Q68 15 74 29 Q79 40 84 29 Q89 20 94 29 Q98 35 102 29 Q105 26 108 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><path d="M192 29 Q195 26 198 29 Q202 35 206 29 Q211 20 216 29 Q221 40 226 29 Q232 15 238 29 Q244 44 250 29 Q256 14 262 29 Q268 44 274 29 Q280 14 286 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><!-- coiled cord left --><path d="M14 27 Q20 12 26 27 Q32 42 38 27 Q44 12 50 27 Q56 42 62 27 Q68 13 74 27 Q79 38 84 27 Q89 18 94 27 Q98 33 102 27 Q105 24 108 27" fill="none" stroke="url(#phCd)" stroke-width="2" stroke-linecap="round"/><!-- coiled cord right --><path d="M192 27 Q195 24 198 27 Q202 33 206 27 Q211 18 216 27 Q221 38 226 27 Q232 13 238 27 Q244 42 250 27 Q256 12 262 27 Q268 42 274 27 Q280 12 286 27" fill="none" stroke="url(#phCd)" stroke-width="2" stroke-linecap="round"/><!-- cord connectors --><circle cx="110" cy="27" r="2" fill="#6a2820" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#6a2820" opacity="0.4"/><!-- handset --><g transform="translate(150,27) rotate(-12)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#phHd)" opacity="0.62"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="0" r="1" fill="#1a0808" opacity="0.22"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="0" r="1" fill="#1a0808" opacity="0.22"/></g></svg>

<div class="phone-type" style="--d:0.3s;--t:0.8s">It's Aoife.</div>\
<div class="phone-type phone-her" style="--d:2.1s;--t:1.6s">'The heating's gone. Will you be home soon? She won't leave-off crying.'</div>\
<div class="phone-type phone-you" style="--d:4.0s;--t:0.45s">'Later tonight.'</div>\
<div class="phone-type phone-her" style="--d:4.8s;--t:0.35s">'Much later?'</div>\
<div class="phone-type phone-you" style="--d:5.5s;--t:0.7s">'Yes. Goodnight. I love you.'</div>\

<svg class="phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="phBl2"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="phCd2" x1="0" x2="1"><stop offset="0%" stop-color="#5a2818" stop-opacity="0"/><stop offset="20%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="50%" stop-color="#8a4030" stop-opacity="0.62"/><stop offset="80%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="100%" stop-color="#5a2818" stop-opacity="0"/></linearGradient><linearGradient id="phHd2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4a1812"/><stop offset="40%" stop-color="#7a2e20"/><stop offset="100%" stop-color="#5a2018"/></linearGradient><radialGradient id="phGw2" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#c08040" stop-opacity="0.12"/><stop offset="100%" stop-color="#c08040" stop-opacity="0"/></radialGradient></defs><!-- smoke wisps --><ellipse cx="165" cy="28" rx="52" ry="16" fill="#a08060" opacity="0.06" filter="url(#phBl2)"/><ellipse cx="110" cy="24" rx="40" ry="13" fill="#907050" opacity="0.05" filter="url(#phBl2)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#phGw2)"/><!-- cord shadow --><path d="M14 29 Q20 44 26 29 Q32 14 38 29 Q44 44 50 29 Q56 14 62 29 Q68 42 74 29 Q79 18 84 29 Q89 36 94 29 Q98 24 102 29 Q105 32 108 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><path d="M192 29 Q195 32 198 29 Q202 24 206 29 Q211 36 216 29 Q221 18 226 29 Q232 42 238 29 Q244 14 250 29 Q256 44 262 29 Q268 14 274 29 Q280 44 286 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><!-- coiled cord left --><path d="M14 27 Q20 42 26 27 Q32 12 38 27 Q44 42 50 27 Q56 12 62 27 Q68 40 74 27 Q79 16 84 27 Q89 34 94 27 Q98 22 102 27 Q105 30 108 27" fill="none" stroke="url(#phCd2)" stroke-width="2" stroke-linecap="round"/><!-- coiled cord right --><path d="M192 27 Q195 30 198 27 Q202 22 206 27 Q211 34 216 27 Q221 16 226 27 Q232 40 238 27 Q244 12 250 27 Q256 42 262 27 Q268 12 274 27 Q280 42 286 27" fill="none" stroke="url(#phCd2)" stroke-width="2" stroke-linecap="round"/><!-- cord connectors --><circle cx="110" cy="27" r="2" fill="#6a2820" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#6a2820" opacity="0.4"/><!-- handset --><g transform="translate(150,27) rotate(8)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#phHd2)" opacity="0.62"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="0" r="1" fill="#1a0808" opacity="0.22"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="0" r="1" fill="#1a0808" opacity="0.22"/></g></svg>
</div>

<div class="phone-type" style="--d:8.5s;--t:1.0s">[[Hang up|Entering The Pillars of Hercules]]</div>

:: Lily phone call 1 {"position":"100,1200","size":"100,100"}
(set: $hadLilyCall1 to true)\
(set: $lilyCallCount to $lilyCallCount + 1)\
(set: $pendingLilyBreath to true)\
(set: $resumingFromCall to true)\
(set: $lilyCall1ReturnsAt to $returns)\
<div class="phone-scene lily-phone-scene">
<svg class="phone-rule lily-phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="lpBl"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="lpCd" x1="0" x2="1"><stop offset="0%" stop-color="#4a3858" stop-opacity="0"/><stop offset="20%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="50%" stop-color="#7a5888" stop-opacity="0.55"/><stop offset="80%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="100%" stop-color="#4a3858" stop-opacity="0"/></linearGradient><linearGradient id="lpHd" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#3a2048"/><stop offset="40%" stop-color="#5a3868"/><stop offset="100%" stop-color="#4a2858"/></linearGradient><radialGradient id="lpGw" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#b090c0" stop-opacity="0.10"/><stop offset="100%" stop-color="#b090c0" stop-opacity="0"/></radialGradient></defs><ellipse cx="130" cy="26" rx="55" ry="17" fill="#907098" opacity="0.05" filter="url(#lpBl)"/><ellipse cx="185" cy="30" rx="42" ry="13" fill="#806088" opacity="0.04" filter="url(#lpBl)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#lpGw)"/><path d="M14 27 Q20 12 26 27 Q32 42 38 27 Q44 12 50 27 Q56 42 62 27 Q68 13 74 27 Q79 38 84 27 Q89 18 94 27 Q98 33 102 27 Q105 24 108 27" fill="none" stroke="url(#lpCd)" stroke-width="2" stroke-linecap="round"/><path d="M192 27 Q195 24 198 27 Q202 33 206 27 Q211 18 216 27 Q221 38 226 27 Q232 13 238 27 Q244 42 250 27 Q256 12 262 27 Q268 42 274 27 Q280 12 286 27" fill="none" stroke="url(#lpCd)" stroke-width="2" stroke-linecap="round"/><circle cx="110" cy="27" r="2" fill="#5a3868" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#5a3868" opacity="0.4"/><g transform="translate(150,27) rotate(-8)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#lpHd)" opacity="0.55"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/></g></svg>

<div class="phone-type lily-phone-narrate" style="--d:0.3s;--t:1.0s">The phone rings. It's Lily.</div>\
<div class="phone-type lily-phone-her" style="--d:2.4s;--t:1.4s">'It was too funny not to tell you… somebody said… 'If he writes her a few sonnets, he loves her. If he writes her 300 sonnets, he loves sonnets.''</div>\
<div class="phone-type lily-phone-you" style="--d:4.2s;--t:1.0s">'I think that was Don Paterson,' you say, plausibly and incorrectly.</div>\
<div class="phone-type lily-phone-her" style="--d:5.6s;--t:1.4s">She doesn't reply.</div>\
<div class="phone-type lily-phone-you" style="--d:7.4s;--t:0.6s">'And where does that leave 14 sonnets?'</div>\
<div class="phone-type lily-phone-narrate" style="--d:8.4s;--t:1.2s">It was a stupid answering-back to an unanswerable position; it might have gone better in rhyme.</div>

<svg class="phone-rule lily-phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="lpBl2"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="lpCd2" x1="0" x2="1"><stop offset="0%" stop-color="#4a3858" stop-opacity="0"/><stop offset="20%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="50%" stop-color="#7a5888" stop-opacity="0.55"/><stop offset="80%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="100%" stop-color="#4a3858" stop-opacity="0"/></linearGradient><linearGradient id="lpHd2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#3a2048"/><stop offset="40%" stop-color="#5a3868"/><stop offset="100%" stop-color="#4a2858"/></linearGradient><radialGradient id="lpGw2" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#b090c0" stop-opacity="0.10"/><stop offset="100%" stop-color="#b090c0" stop-opacity="0"/></radialGradient></defs><ellipse cx="170" cy="28" rx="50" ry="15" fill="#907098" opacity="0.05" filter="url(#lpBl2)"/><ellipse cx="110" cy="24" rx="38" ry="12" fill="#806088" opacity="0.04" filter="url(#lpBl2)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#lpGw2)"/><path d="M14 27 Q20 42 26 27 Q32 12 38 27 Q44 42 50 27 Q56 12 62 27 Q68 40 74 27 Q79 16 84 27 Q89 34 94 27 Q98 22 102 27 Q105 30 108 27" fill="none" stroke="url(#lpCd2)" stroke-width="2" stroke-linecap="round"/><path d="M192 27 Q195 30 198 27 Q202 22 206 27 Q211 34 216 27 Q221 16 226 27 Q232 40 238 27 Q244 12 250 27 Q256 42 262 27 Q268 12 274 27 Q280 42 286 27" fill="none" stroke="url(#lpCd2)" stroke-width="2" stroke-linecap="round"/><circle cx="110" cy="27" r="2" fill="#5a3868" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#5a3868" opacity="0.4"/><g transform="translate(150,27) rotate(10)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#lpHd2)" opacity="0.55"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/></g></svg>
</div>

(after: 11s)[<div class="lily-glimpse lily-fade">Your tongue is cauterised on 66, its heat, which you dare not speak:<br><br><em class="lily-glimpse-verse">Tir’d with all these, from these would I be gone,<br>Save that, to die, I leave my love alone.</em><br><br>You both hang up, each leaving the other alone.</div>]\
(after: 15s)[<div class="phone-exit">(link-goto: "Hang up.", $lilyCallReturn)</div>]\
(after: 28s)[(go-to: $lilyCallReturn)]



:: After the call [outdoor] {"position":"100,1300","size":"100,100"}
<div class="typewriter-page">
You remember that Lily rang. You'd not heard her voice sustained so long in so many, many years. It flays you still, for all that you love others. You press your heels into Soho flagstones, breathe great gulps of its air. Anything to bring you back to here, which is the only place you'll live.

(if: $sawMemory1 is false)[(set: $sawMemory1 to true)<div class="memory-photo memory-photo-1"><div class="mp-image"><svg class="mp-bg" viewBox="0 0 300 200" preserveAspectRatio="xMidYMid slice"><defs><radialGradient id="fl1a" cx="70%" cy="75%" r="80%"><stop offset="0%" stop-color="#f5a868" stop-opacity="0.95"/><stop offset="28%" stop-color="#d8702a" stop-opacity="0.55"/><stop offset="60%" stop-color="#5a2018" stop-opacity="0.25"/><stop offset="100%" stop-color="#1a0a0a" stop-opacity="0"/></radialGradient></defs><rect width="300" height="200" fill="url(#fl1a)"/></svg><div class="mp-prose">A little earthquake in the heart upsets the world and you are twenty-one again, walking with her on your arm through the rain on St. Giles, past the funfair, before so very much went so far wrong.</div></div></div>]

[[On.|Dean Street]]
</div>

:: After Aoife [outdoor] {"position":"100,1350","size":"100,100"}
<div class="typewriter-page">
You remember that Aoife rang; her voice cold from the cold flat. The baby small in her little arms, crying. You'd promise her the world, if only you could.

[[On.|Dean Street]]
</div>

:: The dual ring {"position":"100,1500","size":"100,100"}
(set: $hadDualRing to true)\
(set: $lilyCallCount to $lilyCallCount + 1)\
<script>
/* Second heartbeat + second ring — the global header observer fires one
   heartbeat at ~1.5s for the Aoife scene; we layer a second pulse + a
   single phone-bell tone in at ~7.8s so the Lily call has its own audio
   marker rather than blooming on screen with no cue.

   Outer setTimeout(0) defers the _passageGen snapshot until after the
   MutationObserver has incremented for this passage; without it the
   inline-rendered script captures the stale value and the cancel-guard
   always trips. Same race fix as showDrinkPopupSafe / Dawn wheel. */
(function(){
  setTimeout(function(){
    var hbGen = window._passageGen;
    setTimeout(function(){
      if (window._passageGen !== hbGen) return;
      if (window.dssAudio && window.dssAudio.heartbeat) window.dssAudio.heartbeat(6);
      if (window.dssAudio && window.dssAudio.phoneBell) window.dssAudio.phoneBell(1);
    }, 7800);
  }, 0);
})();
</script>
<div class="phone-scene">
<svg class="phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="drBl"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="drCd" x1="0" x2="1"><stop offset="0%" stop-color="#5a2818" stop-opacity="0"/><stop offset="20%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="50%" stop-color="#8a4030" stop-opacity="0.62"/><stop offset="80%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="100%" stop-color="#5a2818" stop-opacity="0"/></linearGradient><linearGradient id="drHd" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4a1812"/><stop offset="40%" stop-color="#7a2e20"/><stop offset="100%" stop-color="#5a2018"/></linearGradient><radialGradient id="drGw" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#c08040" stop-opacity="0.12"/><stop offset="100%" stop-color="#c08040" stop-opacity="0"/></radialGradient></defs><ellipse cx="125" cy="26" rx="58" ry="18" fill="#a08060" opacity="0.06" filter="url(#drBl)"/><ellipse cx="190" cy="30" rx="45" ry="14" fill="#907050" opacity="0.05" filter="url(#drBl)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#drGw)"/><path d="M14 27 Q20 12 26 27 Q32 42 38 27 Q44 12 50 27 Q56 42 62 27 Q68 13 74 27 Q79 38 84 27 Q89 18 94 27 Q98 33 102 27 Q105 24 108 27" fill="none" stroke="url(#drCd)" stroke-width="2" stroke-linecap="round"/><path d="M192 27 Q195 24 198 27 Q202 33 206 27 Q211 18 216 27 Q221 38 226 27 Q232 13 238 27 Q244 42 250 27 Q256 12 262 27 Q268 42 274 27 Q280 12 286 27" fill="none" stroke="url(#drCd)" stroke-width="2" stroke-linecap="round"/><circle cx="110" cy="27" r="2" fill="#6a2820" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#6a2820" opacity="0.4"/><g transform="translate(150,27) rotate(-12)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#drHd)" opacity="0.62"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/></g></svg>

<div class="phone-type" style="--d:0.3s;--t:1.0s">It's Aoife.</div>\
<div class="phone-type phone-her" style="--d:1.6s;--t:1.4s">'Where are you?'</div>\
<div class="phone-type phone-you" style="--d:3.4s;--t:0.8s">'I'll be home soon,'</div>\
<div class="phone-type phone-her" style="--d:4.6s;--t:1.0s">'Just come back to us.'</div>\
<div class="phone-type" style="--d:6.0s;--t:0.6s">The line goes dead.</div>
</div>

<div class="phone-scene lily-phone-scene" style="margin-top: 1.5em;">
<svg class="phone-rule lily-phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="drBl2"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="drCd2" x1="0" x2="1"><stop offset="0%" stop-color="#4a3858" stop-opacity="0"/><stop offset="20%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="50%" stop-color="#7a5888" stop-opacity="0.55"/><stop offset="80%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="100%" stop-color="#4a3858" stop-opacity="0"/></linearGradient><linearGradient id="drHd2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#3a2048"/><stop offset="40%" stop-color="#5a3868"/><stop offset="100%" stop-color="#4a2858"/></linearGradient><radialGradient id="drGw2" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#b090c0" stop-opacity="0.10"/><stop offset="100%" stop-color="#b090c0" stop-opacity="0"/></radialGradient></defs><ellipse cx="140" cy="26" rx="52" ry="16" fill="#907098" opacity="0.05" filter="url(#drBl2)"/><ellipse cx="180" cy="30" rx="44" ry="14" fill="#806088" opacity="0.04" filter="url(#drBl2)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#drGw2)"/><path d="M14 27 Q20 12 26 27 Q32 42 38 27 Q44 12 50 27 Q56 42 62 27 Q68 13 74 27 Q79 38 84 27 Q89 18 94 27 Q98 33 102 27 Q105 24 108 27" fill="none" stroke="url(#drCd2)" stroke-width="2" stroke-linecap="round"/><path d="M192 27 Q195 24 198 27 Q202 33 206 27 Q211 18 216 27 Q221 38 226 27 Q232 13 238 27 Q244 42 250 27 Q256 12 262 27 Q268 42 274 27 Q280 12 286 27" fill="none" stroke="url(#drCd2)" stroke-width="2" stroke-linecap="round"/><circle cx="110" cy="27" r="2" fill="#5a3868" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#5a3868" opacity="0.4"/><g transform="translate(150,27) rotate(-8)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#drHd2)" opacity="0.55"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/></g></svg>

<div class="phone-type lily-phone-narrate" style="--d:7.8s;--t:1.2s">It rings again, immediately. It's Lily.</div>\
<div class="phone-type lily-phone-her" style="--d:10.2s;--t:1.6s">'What was her name? I think she was next to me in my yoga class.'</div>\
<div class="phone-type lily-phone-you" style="--d:12.2s;--t:0.8s">'Isadora. And yes I was young and…'</div>\
<div class="phone-type lily-phone-her" style="--d:13.4s;--t:1.8s">'How different things might have been.'</div>\
<div class="phone-type lily-phone-you" style="--d:15.6s;--t:1.2s">'How changed they are.'</div>\
<div class="phone-type lily-phone-her" style="--d:17.2s;--t:0.8s">'Goodnight, take it easy.'</div>\
<div class="phone-type lily-phone-narrate" style="--d:18.4s;--t:1.0s">'… as the grass grows on the weirs,'</div>\
<div class="phone-type lily-phone-narrate" style="--d:19.8s;--t:1.0s">'But I was young and foolish.'</div>

<svg class="phone-rule lily-phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="drBl3"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="drCd3" x1="0" x2="1"><stop offset="0%" stop-color="#4a3858" stop-opacity="0"/><stop offset="20%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="50%" stop-color="#7a5888" stop-opacity="0.55"/><stop offset="80%" stop-color="#6a4878" stop-opacity="0.42"/><stop offset="100%" stop-color="#4a3858" stop-opacity="0"/></linearGradient><linearGradient id="drHd3" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#3a2048"/><stop offset="40%" stop-color="#5a3868"/><stop offset="100%" stop-color="#4a2858"/></linearGradient><radialGradient id="drGw3" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#b090c0" stop-opacity="0.10"/><stop offset="100%" stop-color="#b090c0" stop-opacity="0"/></radialGradient></defs><ellipse cx="160" cy="28" rx="48" ry="15" fill="#907098" opacity="0.05" filter="url(#drBl3)"/><ellipse cx="120" cy="24" rx="40" ry="12" fill="#806088" opacity="0.04" filter="url(#drBl3)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#drGw3)"/><path d="M14 27 Q20 42 26 27 Q32 12 38 27 Q44 42 50 27 Q56 12 62 27 Q68 40 74 27 Q79 16 84 27 Q89 34 94 27 Q98 22 102 27 Q105 30 108 27" fill="none" stroke="url(#drCd3)" stroke-width="2" stroke-linecap="round"/><path d="M192 27 Q195 30 198 27 Q202 22 206 27 Q211 34 216 27 Q221 16 226 27 Q232 40 238 27 Q244 12 250 27 Q256 42 262 27 Q268 12 274 27 Q280 42 286 27" fill="none" stroke="url(#drCd3)" stroke-width="2" stroke-linecap="round"/><circle cx="110" cy="27" r="2" fill="#5a3868" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#5a3868" opacity="0.4"/><g transform="translate(150,27) rotate(10)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#drHd3)" opacity="0.55"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0818" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0818" opacity="0.3"/></g></svg>
</div>

(set: $sobriety to ($statLoss: $sobriety, 6))\
<span class="lily-glimpse lily-fade lily-fade-very-late">And the tears and the tears and the tears.</span>

(after: 28s)[<div class="phone-exit">(link: "Hang up.")[(set: $resumingFromCall to false)(set: $crashedAfterDualRing to true)(if: $sobriety > 8)[(set: $sobriety to 8)](if: $confidence > 18)[(set: $confidence to 18)](go-to: "Coach and Horses lock")]</div>]
(after: 40s)[(set: $resumingFromCall to false)(set: $crashedAfterDualRing to true)(if: $sobriety > 8)[(set: $sobriety to 8)](if: $confidence > 18)[(set: $confidence to 18)](go-to: "Coach and Horses lock")]

:: Title {"position":"100,50","size":"100,100"}
<style>@keyframes dst-fog1{0%,100%{transform:translateX(-5%);opacity:1}50%{transform:translateX(5%);opacity:0.6}}@keyframes dst-fog2{0%,100%{transform:translateX(8%);opacity:1}50%{transform:translateX(-6%);opacity:0.7}}@keyframes dst-titleGlow{0%,100%{text-shadow:0 0 40px rgba(120,160,220,0.3),0 0 80px rgba(80,128,200,0.1)}50%{text-shadow:0 0 55px rgba(120,160,220,0.45),0 0 110px rgba(80,128,200,0.18)}}@keyframes dst-breathe{0%,100%{opacity:0.7}50%{opacity:1}}/* Two irregular drift patterns — many keyframes, asymmetric spacing,
   multi-rotation tumbles so the petals look like they're catching air
   unpredictably rather than swaying on a fixed sine wave. */
@keyframes dst-petal-drift-a{0%{transform:translate3d(0,-40px,0) rotate(0deg);opacity:0}6%{opacity:1}13%{transform:translate3d(42px,11vh,0) rotate(75deg)}24%{transform:translate3d(28px,22vh,0) rotate(155deg)}33%{transform:translate3d(-12px,32vh,0) rotate(195deg)}45%{transform:translate3d(-58px,46vh,0) rotate(285deg)}54%{transform:translate3d(-32px,55vh,0) rotate(320deg)}66%{transform:translate3d(48px,68vh,0) rotate(430deg)}78%{transform:translate3d(38px,82vh,0) rotate(495deg)}90%{transform:translate3d(-22px,95vh,0) rotate(560deg);opacity:1}100%{transform:translate3d(10px,110vh,0) rotate(605deg);opacity:0}}@keyframes dst-petal-drift-b{0%{transform:translate3d(0,-40px,0) rotate(20deg);opacity:0}7%{opacity:1}14%{transform:translate3d(-50px,10vh,0) rotate(-65deg)}26%{transform:translate3d(-22px,24vh,0) rotate(-145deg)}38%{transform:translate3d(48px,38vh,0) rotate(-250deg)}48%{transform:translate3d(20px,50vh,0) rotate(-300deg)}59%{transform:translate3d(-62px,62vh,0) rotate(-410deg)}71%{transform:translate3d(-35px,76vh,0) rotate(-470deg)}84%{transform:translate3d(42px,90vh,0) rotate(-555deg)}92%{opacity:1}100%{transform:translate3d(15px,110vh,0) rotate(-610deg);opacity:0}}.dst-drip{position:absolute;top:-30px;pointer-events:none;z-index:1;animation-iteration-count:infinite;animation-timing-function:ease-in-out;will-change:transform,opacity}tw-passage tw-link{border-left:none!important;padding-left:0!important;}</style>
