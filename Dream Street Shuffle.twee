  // typewriter click between venues.
  function footstep(surface) {
    _play(function(ac) {
    var now = ac.currentTime;

    if (surface === 'cobble') {
      // Farnell-style footstep on wet Soho cobble.
      // What was missing: a sharp <3ms attack click at the moment of
      // contact. Without that broadband transient your brain doesn't
      // hear "impact" — only a soft thud. We also need stone resonance
      // (parallel bandpasses on the body modes, not a single biquad),
      // a brief HP "wet splash" transient, and a heel→toe pair per step.
      // Each impact is randomised so no two read identical.

      // Shared "wet street" reverb send. Short feedback delay with a HP
      // filter — the sound of two facing brick walls and a slick pavement.
      var rvDelay = ac.createDelay(0.5);
      rvDelay.delayTime.value = 0.062 + Math.random() * 0.025;
      var rvFilter = ac.createBiquadFilter();
      rvFilter.type = 'highpass'; rvFilter.frequency.value = 220;
      var rvFb = ac.createGain();
      rvFb.gain.value = 0.42;
      var rvOut = ac.createGain();
      rvOut.gain.value = 0.40;
      rvDelay.connect(rvFilter);
      rvFilter.connect(rvFb);
      rvFb.connect(rvDelay);
      rvFilter.connect(rvOut);
      rvOut.connect(ac.destination);

      function _cobbleImpact(t, isHeel) {
        // Per-impact randomisation: gain ±15%, freq ±10%
        var jG = 1 + (Math.random() - 0.5) * 0.30;
        var jF = 1 + (Math.random() - 0.5) * 0.20;
        // Heel is the heavier, lower-pitched strike; toe is sharper + quieter
        var weight = isHeel ? 1.0 : 0.62;
        var bodyFreq = isHeel ? 140 : 175;
        var midFreq  = isHeel ? 320 : 410;
        var ringFreq = isHeel ? 920 : 1280;

        // 1. ATTACK CLICK — ~2.5ms broadband transient, the "moment of
        //    contact" that tells your ear an impact has occurred.
        var clickDur = 0.0028;
        var clickLen = Math.max(8, Math.floor(ac.sampleRate * clickDur));
        var clickBuf = ac.createBuffer(1, clickLen, ac.sampleRate);
        var cd = clickBuf.getChannelData(0);
        for (var ci = 0; ci < clickLen; ci++) {
          cd[ci] = (Math.random() * 2 - 1) * (1 - ci / clickLen);
        }
        var clickSrc = ac.createBufferSource(); clickSrc.buffer = clickBuf;
        var clickHP = ac.createBiquadFilter();
        clickHP.type = 'highpass'; clickHP.frequency.value = 600 * jF;
        var clickG = ac.createGain();
        clickG.gain.value = 0.20 * weight * jG;
        clickSrc.connect(clickHP); clickHP.connect(clickG);
        clickG.connect(ac.destination);
        clickG.connect(rvDelay);
        clickSrc.start(t);

        // 2. STONE RESONANCE — short noise burst into three parallel
        //    bandpass resonators tuned to the modal frequencies of a
        //    paving stone. Higher Q than a single filter so the "stone"
        //    actually rings briefly after the impact.
        var resDur = 0.16;
        var resLen = Math.floor(ac.sampleRate * resDur);
        var resBuf = ac.createBuffer(1, resLen, ac.sampleRate);
        var rd = resBuf.getChannelData(0);
        for (var ri = 0; ri < resLen; ri++) {
          var renv = Math.exp(-ri / resLen * 8);
          rd[ri] = (Math.random() * 2 - 1) * renv;
        }
        var modes = [
          { f: bodyFreq, q: 2.4, g: 0.22 },
          { f: midFreq,  q: 3.2, g: 0.11 },
          { f: ringFreq, q: 3.8, g: 0.08 }
        ];
        modes.forEach(function(m, mi) {
          var src = ac.createBufferSource(); src.buffer = resBuf;
          var f = ac.createBiquadFilter();
          f.type = 'bandpass';
          f.frequency.value = m.f * jF;
          f.Q.value = m.q;
          var g = ac.createGain();
          g.gain.value = m.g * weight * jG;
          src.connect(f); f.connect(g); g.connect(ac.destination);
          if (mi >= 1) g.connect(rvDelay); // upper modes carry the reverb
          src.start(t);
        });

        // 3. WET SPLASH — tiny HP noise burst, the water film squelching
        //    between foot and stone. Quick exponential decay, well above
        //    voice range so it sparkles but doesn't compete.
        var spDur = 0.022;
        var spLen = Math.floor(ac.sampleRate * spDur);
        var spBuf = ac.createBuffer(1, spLen, ac.sampleRate);
        var sd = spBuf.getChannelData(0);
        for (var si = 0; si < spLen; si++) {
          sd[si] = (Math.random() * 2 - 1) * Math.exp(-si / spLen * 14);
        }
        var spSrc = ac.createBufferSource(); spSrc.buffer = spBuf;
        var spF = ac.createBiquadFilter();
        spF.type = 'highpass'; spF.frequency.value = 3800;
        var spG = ac.createGain();
        spG.gain.value = 0.028 * weight * jG;
        spSrc.connect(spF); spF.connect(spG); spG.connect(ac.destination);
        spSrc.start(t);
      }

      // Heel-toe pair, 80-115ms apart. Heel first, then toe lands.
      var heelToeGap = 0.080 + Math.random() * 0.035;
      _cobbleImpact(now, true);
      _cobbleImpact(now + heelToeGap, false);
      return;
    }

    [0, 0.11].forEach(function(off, idx) {
      var t = now + off;
      var dur = 0.07;
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) {
        var env = Math.exp(-i / bufLen * 9);
        d[i] = (Math.random()*2-1) * env;
      }
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter();
      if (surface === 'wood') {
        f.type='bandpass'; f.frequency.value = 220; f.Q.value = 2.5;
      } else if (surface === 'carpet') {
        f.type='lowpass'; f.frequency.value = 260; f.Q.value = 0.5;
      } else if (surface === 'gravel') {
        f.type='highpass'; f.frequency.value = 1600; f.Q.value = 0.6;
      } else {
        // wet pavement default — mid-band slap
        f.type='bandpass'; f.frequency.value = 700; f.Q.value = 1.5;
      }
      var g = ac.createGain();
      g.gain.value = (idx === 0 ? 0.07 : 0.045);
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(t);
    });
    });
  }
  // Passage transition — a slow wave-like swell that fades.
  // Filtered noise with a gentle filter sweep: opens up as it crests, closes as it dies.
  // Quiet so it doesn't compete with passage-specific sounds (drinks, doors, etc.)
  function passageWhoosh() {
    _play(function(ac) {
      var dur = 2.6, now = ac.currentTime;
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random()*2-1) * 0.5;
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type='lowpass';
      f.frequency.setValueAtTime(160, now);
      f.frequency.linearRampToValueAtTime(800, now + 0.95);
      f.frequency.exponentialRampToValueAtTime(140, now + dur);
      f.Q.value = 0.45;
      var g = ac.createGain();
      g.gain.setValueAtTime(0.001, now);
      g.gain.linearRampToValueAtTime(0.07, now + 0.85);
      g.gain.linearRampToValueAtTime(0.05, now + 1.6);
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now); src.stop(now + dur);
    });
  }
  // Lore box: an unravelling-parchment sound. Two layers stitched together —
  //   Layer A: a continuous high-band noise bed (the parchment itself),
  //            band-passed in the 2-3.5kHz region with a gentle sweep so the
  //            texture "opens up" as the scroll lays flat, then settles.
  //   Layer B: a handful of tiny crinkle transients (the folds and creases
  //            popping open) sprinkled across the duration — random short
  //            high-passed noise pings, decaying fast.
  // Quiet overall and short (~1.6s) so it complements the lore reveal without
  // stepping on the passage music.
  function loreUnravel() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 1.55;
      // ---- Layer A: parchment bed -------------------------------------
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * 0.5;
      var src = ac.createBufferSource(); src.buffer = buf;
      var bp = ac.createBiquadFilter(); bp.type = 'bandpass';
      bp.frequency.setValueAtTime(1800, now);
      bp.frequency.linearRampToValueAtTime(3200, now + 0.55);
      bp.frequency.exponentialRampToValueAtTime(900, now + dur);
      bp.Q.value = 0.9;
      var hs = ac.createBiquadFilter(); hs.type = 'highshelf';
      hs.frequency.value = 5000; hs.gain.value = 4;
      var bg = ac.createGain();
      bg.gain.setValueAtTime(0.0001, now);
      bg.gain.exponentialRampToValueAtTime(0.075, now + 0.18);
      bg.gain.linearRampToValueAtTime(0.055, now + 0.85);
      bg.gain.exponentialRampToValueAtTime(0.0001, now + dur);
      src.connect(bp); bp.connect(hs); hs.connect(bg); bg.connect(ac.destination);
      src.start(now); src.stop(now + dur);
      // ---- Layer B: crinkle transients --------------------------------
      // A handful of tiny high-frequency snaps spread across the duration,
      // each one a 25-50ms band-passed noise burst with a quick decay.
      var crinkles = 6;
      for (var c = 0; c < crinkles; c++) {
        var t0 = now + 0.04 + Math.random() * (dur - 0.18);
        var cdur = 0.025 + Math.random() * 0.030;
        var clen = Math.floor(ac.sampleRate * cdur);
        var cbuf = ac.createBuffer(1, clen, ac.sampleRate);
        var cd = cbuf.getChannelData(0);
        for (var j = 0; j < clen; j++) cd[j] = (Math.random() * 2 - 1);
        var csrc = ac.createBufferSource(); csrc.buffer = cbuf;
        var cf = ac.createBiquadFilter(); cf.type = 'bandpass';
        cf.frequency.value = 3500 + Math.random() * 2500;
        cf.Q.value = 4 + Math.random() * 4;
        var cg = ac.createGain();
        cg.gain.setValueAtTime(0.0001, t0);
        cg.gain.exponentialRampToValueAtTime(0.06 + Math.random() * 0.05, t0 + 0.005);
        cg.gain.exponentialRampToValueAtTime(0.0001, t0 + cdur);
        csrc.connect(cf); cf.connect(cg); cg.connect(ac.destination);
        csrc.start(t0); csrc.stop(t0 + cdur + 0.01);
      }
    });
  }
  // ====== BACKGROUND MUSIC BED ======
  // Dean Street theme — plays ONLY on the Dean Street home passage.
  // Uses Web Audio API (AudioBufferSourceNode with loop=true) for SAMPLE-LEVEL
  // gapless looping. HTML5 <audio loop> adds tiny browser gaps; this doesn't.
  // Volume ducks when any SFX fires (via the _play wrapper) and ramps back smoothly.
  // The MUSIC_FILE value below is a placeholder that sync_html.py replaces
  // with a base64 data URI of the audio file at sync time. To change which
  // file is embedded, edit MUSIC_SOURCE_FILE near the top of sync_html.py.
  var MUSIC_FILE = '__DSS_MUSIC_DATA_URI__';
  var MUSIC_VOLUME_BASE = 0.55;     // resting volume (0-1) — tweak here to set overall level
  var MUSIC_VOLUME_DUCK = 0.10;     // dipped volume during SFX
  var MUSIC_DUCK_HOLD_MS = 350;     // hold the duck for this long before recovering (ms)
  var MUSIC_DUCK_RAMP_S  = 0.6;     // smooth ramp back to base (seconds, for Web Audio)
  // Allow-list — music plays whenever the current passage has any of these tags.
  // Dean Street is uniquely tagged 'hub' in the .twee — that's why we use it.
  var MUSIC_PLAY_TAGS = {
    'hub': 1
  };
  // Fallback: also play on passages with these exact names.
  var MUSIC_PLAY_NAMES = {};
  var musicBuffer = null;     // decoded audio data (cached after first decode)
  var musicSource = null;     // current AudioBufferSourceNode (recreated each play)
  var musicGain = null;       // GainNode for volume + ducking
  var musicStarted = false;
  var musicDecoding = false;
  var musicDecodeQueue = [];  // callbacks waiting for decode to finish
  var duckTimer = null;
  // Decode the embedded data URI into an AudioBuffer (one-time, cached).
  // The decoded buffer is what enables sample-perfect looping.
  function _decodeMusic(cb) {
    if (musicBuffer) { cb(musicBuffer); return; }
    musicDecodeQueue.push(cb);
    if (musicDecoding) return;
    var ac = getCtx(); if (!ac) return;
    musicDecoding = true;
    fetch(MUSIC_FILE).then(function(r) { return r.arrayBuffer(); })
      .then(function(ab) {
        return new Promise(function(resolve, reject) {
          // Callback form for older Safari compatibility
          ac.decodeAudioData(ab, resolve, reject);
        });
      })
      .then(function(buf) {
        musicBuffer = buf;
        musicDecoding = false;
        var queue = musicDecodeQueue.slice();
        musicDecodeQueue.length = 0;
        queue.forEach(function(fn) { try { fn(buf); } catch(e) {} });
      })
      .catch(function(err) {
        musicDecoding = false;
        if (window.console) console.error('[dssAudio] music decode failed:', err);
      });
  }
  function _shouldPlayMusic(passageNode) {
    if (!passageNode) passageNode = document.querySelector('tw-passage');
    if (!passageNode) return false;
    var tagAttr = passageNode.getAttribute('tags') || '';
    var tags = tagAttr.split(/\s+/).filter(Boolean);
    for (var i = 0; i < tags.length; i++) {
      if (MUSIC_PLAY_TAGS[tags[i]]) return true;
    }
    var name = passageNode.getAttribute('data-name') || '';
    if (name && MUSIC_PLAY_NAMES[name]) return true;
    return false;
  }
  function startMusic() {
    if (musicStarted) return;
    if (!_shouldPlayMusic()) return;
    var ac = getCtx(); if (!ac) return;
    _decodeMusic(function(buf) {
      // Re-check in case the player navigated away during decode
      if (musicStarted || !_shouldPlayMusic()) return;
      var ac2 = getCtx(); if (!ac2) return;
      // Defensive cleanup of any stray source
      if (musicSource) { try { musicSource.stop(); } catch(e) {} musicSource = null; }
      // Create gain node lazily on first play. Honour mute state — music
      // restarts on passage tag changes, so without this, mute would silently
      // unstick the moment the player walked into a music-tagged passage.
      var startGain = _muted ? 0 : MUSIC_VOLUME_BASE;
      if (!musicGain) {
        musicGain = ac2.createGain();
        musicGain.gain.value = startGain;
        musicGain.connect(ac2.destination);
      } else {
        musicGain.gain.cancelScheduledValues(ac2.currentTime);
        musicGain.gain.setValueAtTime(startGain, ac2.currentTime);
      }
      musicSource = ac2.createBufferSource();
      musicSource.buffer = buf;
      musicSource.loop = true;          // <-- the key line: SAMPLE-LEVEL loop
      musicSource.connect(musicGain);
      musicSource.start(0);
      musicStarted = true;
    });
  }
  function stopMusic() {
    if (!musicStarted) return;
    if (musicSource) {
      try { musicSource.stop(); } catch(e) {}
      try { musicSource.disconnect(); } catch(e) {}
      musicSource = null;
    }
    musicStarted = false;
    if (duckTimer) { clearTimeout(duckTimer); duckTimer = null; }
  }
  function _duckMusic() {
    if (_muted) return; // Honour mute — don't unstick gain by ducking/recovering.
    if (!musicStarted || !musicGain) return;
    var ac = getCtx(); if (!ac) return;
    var now = ac.currentTime;
    musicGain.gain.cancelScheduledValues(now);
    musicGain.gain.setValueAtTime(MUSIC_VOLUME_DUCK, now);
    if (duckTimer) clearTimeout(duckTimer);
    duckTimer = setTimeout(function() {
      duckTimer = null;
      if (_muted) return;
      if (!musicGain) return;
      var ac2 = getCtx(); if (!ac2) return;
      var t = ac2.currentTime;
      musicGain.gain.cancelScheduledValues(t);
      musicGain.gain.setValueAtTime(MUSIC_VOLUME_DUCK, t);
      musicGain.gain.linearRampToValueAtTime(MUSIC_VOLUME_BASE, t + MUSIC_DUCK_RAMP_S);
    }, MUSIC_DUCK_HOLD_MS);
  }
  function updateMusicForPassage(passageNode) {
    if (_shouldPlayMusic(passageNode)) {
      startMusic();
    } else {
      stopMusic();
    }
  }
  function pauseMusic() { stopMusic(); }
  function resumeMusic() { startMusic(); }
  function setMusicVolume(v) {
    MUSIC_VOLUME_BASE = Math.max(0, Math.min(1, v));
    if (musicGain && !duckTimer) {
      var ac = getCtx(); if (!ac) return;
      musicGain.gain.cancelScheduledValues(ac.currentTime);
      musicGain.gain.setValueAtTime(_muted ? 0 : MUSIC_VOLUME_BASE, ac.currentTime);
    }
  }
  // ====== VENUE AMBIENT BEDS ======
  // Generic looped field-recording ambience tied to passage tags. Distinct
  // from the hub MUSIC bed: ambient beds are field recordings (pub, club,
  // street) that play whenever the player is anywhere inside that venue.
  //
  // Each bed has its own buffer, source, gain, and tag-set. On every passage
  // change, _updateAmbientBedsForPassage() iterates all registered beds and
  // starts/stops each based on whether the new passage's tags match.
  //
  // Adding a new venue is a one-line config change here, plus a tuple in
  // sync_html.py's AUDIO_EMBEDS list. The data-URI placeholder is what
  // sync_html.py replaces with the base64 audio.
  var _ambientBeds = [];
  function _decodeBed(bed, cb) {
    if (bed.buffer) { cb(bed.buffer); return; }
    bed.decodeQueue.push(cb);
    if (bed.decoding) return;
    var ac = getCtx(); if (!ac) return;
    bed.decoding = true;
    fetch(bed.dataUri).then(function(r) { return r.arrayBuffer(); })
      .then(function(ab) {
        return new Promise(function(resolve, reject) {
          ac.decodeAudioData(ab, resolve, reject);
        });
      })
      .then(function(buf) {
        bed.buffer = buf;
        bed.decoding = false;
        var queue = bed.decodeQueue.slice();
        bed.decodeQueue.length = 0;
        queue.forEach(function(fn) { try { fn(buf); } catch(e) {} });
      })
      .catch(function(err) {
        bed.decoding = false;
        if (window.console) console.error('[dssAudio] ambient bed decode failed:', bed.label || bed.dataUri.slice(0, 60), err);
      });
  }
  function _bedShouldPlay(bed, passageNode) {
    if (!passageNode) passageNode = document.querySelector('tw-passage');
    if (!passageNode) return false;
    var tagAttr = passageNode.getAttribute('tags') || '';
    var tags = tagAttr.split(/\s+/).filter(Boolean);
    for (var i = 0; i < tags.length; i++) {
      if (bed.tags[tags[i]]) return true;
    }
    return false;
  }
  function _startBed(bed) {
    if (bed.started) return;
    var ac = getCtx(); if (!ac) return;
    _decodeBed(bed, function(buf) {
      // Re-check in case the player navigated away during decode. Skip the
      // tag-match check when the bed was started via startBedByLabel
      // (manual start from a JS callsite — e.g. the Ronnie Scott's bar
      // canvas hand-off — where the current passage's tags don't match
      // the bed's tags by design).
      if (bed.started) return;
      if (!bed._forced && !_bedShouldPlay(bed)) return;
      var ac2 = getCtx(); if (!ac2) return;
      if (bed.source) { try { bed.source.stop(); } catch(e) {} bed.source = null; }
      var targetGain = _muted ? 0 : bed.volume;
      // Fade-in ramp avoids the bang you'd otherwise hear when a bed
      // starts: WebAudio's MP3 decoder can leave priming-frame garbage
      // at sample 0, and a 0→full-volume gain jump amplifies any DC
      // offset / initial waveform transient into an audible click. The
      // piano file in particular has loud note attacks in the first
      // second that read as a "bang" if started at full volume. 1.2s
      // ramp + a 200ms skip into the buffer between them dampen both.
      var FADE_IN_S = 1.2;
      if (!bed.gain) {
        bed.gain = ac2.createGain();
        bed.gain.gain.value = 0;
        bed.gain.connect(ac2.destination);
      } else {
        bed.gain.gain.cancelScheduledValues(ac2.currentTime);
        bed.gain.gain.setValueAtTime(0, ac2.currentTime);
      }
      bed.gain.gain.linearRampToValueAtTime(targetGain, ac2.currentTime + FADE_IN_S);
      bed.started = true;
      // bed.gapMs lets you insert a silent pause between loop iterations
      // — used by piano-eoin so the looping feels like the piece is
      // returning rather than seamlessly continuing. Implemented by
      // disabling native loop and rescheduling a fresh BufferSource via
      // onended + setTimeout. Without gapMs, native loop is used.
      var playIteration = function(skipIntro) {
        if (!bed.started || bed._finishing) return;
        var ac3 = getCtx(); if (!ac3) return;
        bed.source = ac3.createBufferSource();
        bed.source.buffer = buf;
        bed.source.loop = !bed.gapMs;
        bed.source.connect(bed.gain);
        // Skip the first 200ms only on the very first iteration — past
        // the MP3 priming garbage and the loud opening transient. Later
        // restarts after the silent gap can use the clean buffer head.
        bed.source.start(0, skipIntro ? 0.2 : 0);
        if (bed.gapMs) {
          bed.source.onended = function() {
            if (!bed.started || bed._finishing) return;
            bed.gapTimer = setTimeout(function() { playIteration(false); }, bed.gapMs);
          };
        }
      };
      playIteration(true);
    });
  }
  function _stopBed(bed) {
    bed._forced = false; // clear manual-start flag on any stop
    bed._finishing = false;
    // Clear pending gap-restart so a stop while waiting in the silent
    // gap doesn't relaunch a new iteration after the pause.
    if (bed.gapTimer) { clearTimeout(bed.gapTimer); bed.gapTimer = null; }
    if (!bed.started) return;
    if (bed.source) {
      try { bed.source.stop(); } catch(e) {}
      try { bed.source.disconnect(); } catch(e) {}
      bed.source = null;
    }
    bed.started = false;
    if (bed.duckTimer) { clearTimeout(bed.duckTimer); bed.duckTimer = null; }
  }
  function _duckBed(bed) {
    if (_muted) return;
    if (!bed.started || !bed.gain) return;
    var ac = getCtx(); if (!ac) return;
    var now = ac.currentTime;
    bed.gain.gain.cancelScheduledValues(now);
    bed.gain.gain.setValueAtTime(bed.duckVolume, now);
    if (bed.duckTimer) clearTimeout(bed.duckTimer);
    bed.duckTimer = setTimeout(function() {
      bed.duckTimer = null;
      if (_muted) return;
      if (!bed.gain) return;
      var ac2 = getCtx(); if (!ac2) return;
      var t = ac2.currentTime;
      bed.gain.gain.cancelScheduledValues(t);
      bed.gain.gain.setValueAtTime(bed.duckVolume, t);
      bed.gain.gain.linearRampToValueAtTime(bed.volume, t + 0.6);
    }, 350);
  }
  function _duckAllBeds() {
    for (var i = 0; i < _ambientBeds.length; i++) _duckBed(_ambientBeds[i]);
  }
  function updateAmbientBedsForPassage(passageNode) {
    for (var i = 0; i < _ambientBeds.length; i++) {
      var bed = _ambientBeds[i];
      if (_bedShouldPlay(bed, passageNode)) _startBed(bed);
      else _stopBed(bed);
    }
  }
  function registerAmbientBed(bed) {
    bed.buffer = null;
    bed.source = null;
    bed.gain = null;
    bed.started = false;
    bed.decoding = false;
    bed.decodeQueue = [];
    bed.duckTimer = null;
    if (typeof bed.volume !== 'number') bed.volume = 0.18;
    if (typeof bed.duckVolume !== 'number') bed.duckVolume = bed.volume * 0.35;
    _ambientBeds.push(bed);
  }
  // ----- Registered beds ---------------------------------------------------
  // The French — pub field recording, plays on every venue-french passage.
  registerAmbientBed({
    label: 'pub-french',
    dataUri: '__DSS_PUB_DATA_URI__',
    tags: { 'venue-french': 1 },
    volume: 0.16,
    duckVolume: 0.05
  });
  // The Pillars of Hercules — London-pub field recording, plays on every
  // venue-pillars passage (the in-pub interior scenes).
  registerAmbientBed({
    label: 'pub-pillars',
    dataUri: '__DSS_PILLARS_DATA_URI__',
    tags: { 'venue-pillars': 1 },
    volume: 0.20,
    duckVolume: 0.07
  });
  // Piano (Eoin Roe, Pianoteq) — the endgame theme. Plays on every
  // passage from Approach Centre Point onwards through to the Dawn
  // ending. Higher volume than ambient field-recordings: this is
  // foreground music, not room tone.
  registerAmbientBed({
    label: 'piano-eoin',
    dataUri: '__DSS_PIANO_DATA_URI__',
    tags: { 'piano-bed': 1 },
    volume: 0.30,
    duckVolume: 0.10,
    // 5s silent pause between loop iterations — the piano "returns" rather
    // than seamlessly continuing, so it feels intentional even if the
    // player lingers long enough to hear it round again.
    gapMs: 5000
  });
  // The Interval — a separate piece, heard over a radio in the
  // dream-staircase scene. Used to share the piano-bed; replaced so
  // the Interval has its own colour and the piano stays reserved for
  // the centre-point/dawn arc.
  registerAmbientBed({
    label: 'interval-radio',
    dataUri: '__DSS_INTERVAL_RADIO_DATA_URI__',
    tags: { 'interval-radio': 1 },
    volume: 0.28,
    duckVolume: 0.10
  });
  // Coach and Horses Gents toilet — auto-starts on the Coach passage (which
  // opens with "you've come-to in a cubicle"), then is manually stopped by
  // the SpewPopup's _fadeOut so the toilet rumble doesn't bleed into the bar
  // prose that appears in-place after the popup closes.
  registerAmbientBed({
    label: 'toilet-gents',
    dataUri: '__DSS_GENTS_DATA_URI__',
    tags: { 'venue-gents': 1 },
    volume: 0.22,
    duckVolume: 0.08
  });
  // Retro game music — plays during canvas-based minigames (the cellar fight,
  // PP Pong, Bernard's cow ride, the Sketch the Painter napkin-draw, and the
  // Ronnie Scott's bar canvas). Replaces whatever venue ambience would
  // otherwise play. Tag-driven for the four passage-based games; the Ronnie's
  // bar canvas starts/stops it manually from the bar-start-btn click + the
  // bar-end navigation, because the "Ronnie Scott's" passage doubles as the
  // jazz-club venue (with venue-ronnies ambience) when the player isn't
  // mid-game.
  registerAmbientBed({
    label: 'minigame-retro',
    dataUri: '__DSS_MINIGAME_DATA_URI__',
    tags: { 'minigame': 1 },
    volume: 0.22,
    duckVolume: 0.08
  });
  window._cowGameDataUri = '__DSS_COWGAME_DATA_URI__';
  window._jazzMiniDataUri = '__DSS_JAZZMINI_DATA_URI__';
  window._pongMiniDataUri = '__DSS_PONGMINI_DATA_URI__';
  window._waltzMiniDataUri = '__DSS_WALTZ_DATA_URI__';
  // Ronnie Scott's — jazz-bar people ambience (La Fontaine, Copenhagen).
  // Plays on every venue-ronnies passage: the club itself, the bar canvas
  // results, and The Set.
  registerAmbientBed({
    label: 'jazz-ronnies',
    dataUri: '__DSS_RONNIES_DATA_URI__',
    tags: { 'venue-ronnies': 1 },
    volume: 0.20,
    duckVolume: 0.07
  });
  // Quiet cafe — soft chatter / cutlery, for the Colony Room AND Trisha's.
  // Both venues are members'-club bars with subdued lounge feel; one bed
  // covers them via two tags. (If you want them to sound distinct later,
  // duplicate this block with a different recording for each tag.)
  registerAmbientBed({
    label: 'quiet-cafe',
    dataUri: '__DSS_QUIET_CAFE_DATA_URI__',
    tags: { 'venue-colony': 1, 'venue-trishas': 1 },
    volume: 0.20,
    duckVolume: 0.07
  });
  // Cellar pump-station hum — Copper's cellar (the fight) AND Lackland's
  // back room (the table-tennis basement). Same physical aesthetic — a
  // damp basement under Soho — so they share the bed. Two tags route to
  // the same recording.
  registerAmbientBed({
    label: 'cellar-pump',
    dataUri: '__DSS_CELLAR_DATA_URI__',
    tags: { 'venue-cellar': 1, 'venue-lackland-back': 1 },
    volume: 0.18,
    duckVolume: 0.06
  });
  // Carthage cicadas — distant Tunisian-night cicadas, for the dream-Carthage
  // shore/coast/stay passages. These passages used to carry the [dream] tag
  // (which auto-fires the procedural windFarnell bed); the tag is removed so
  // this field-recording bed gets the passages to itself. Green Sea Approach
  // and Maritime interlude keep [dream] — they want the wind.
  registerAmbientBed({
    label: 'carthage-cicadas',
    dataUri: '__DSS_CARTHAGE_DATA_URI__',
    tags: { 'carthage-cicadas': 1 },
    volume: 0.20,
    duckVolume: 0.07
  });
  // Carthage melody — a layered melodic line that plays over the cicadas
  // on the two passages that bracket the 3D shore experience: The coast
  // of Carthage (where the 3D embed loads) and Carthage shore (the game
  // passage you land in immediately after). Tagged separately from the
  // cicadas so Stay in Carthage (the inline pyre scene) doesn't fire it.
  registerAmbientBed({
    label: 'carthage-melody',
    dataUri: '__DSS_CARTHAGE_MELODY_DATA_URI__',
    tags: { 'carthage-shore': 1 },
    volume: 0.32,
    duckVolume: 0.10
  });
  // The Green Sea — seaside cafe field recording (Nabeul). Plays
  // continuously across the dream-Carthage bar arc: Green Sea Approach
  // (the 3D shore-and-bar embed), LINE 2 (the bar interior), and
  // LINE 2 Oxford (the memory cut-away that follows). Same pattern as
  // carthage-shore bridging the Carthage embed + game scene — the bed
  // doesn't stop and restart between passages.
  registerAmbientBed({
    label: 'green-sea',
    dataUri: '__DSS_GREEN_SEA_DATA_URI__',
    tags: { 'green-sea': 1 },
    volume: 0.22,
    duckVolume: 0.07
  });
  // Soho dawn — Berwick-Street-at-dawn field recording. Plays on the
  // Jeffrey Bernard outdoor scenes (tagged 'soho-dawn') and across the
  // Cecil Court venue (the bookshops + O'Flatterly's shop). The other
  // [outdoor] approaches use the dispatcher's distantTraffic bed instead.
  registerAmbientBed({
    label: 'soho-dawn',
    dataUri: '__DSS_SOHO_DAWN_DATA_URI__',
    tags: { 'soho-dawn': 1, 'venue-cecilcourt': 1 },
    volume: 0.18,
    duckVolume: 0.06
  });
  // Coach and Horses bar — late-night city ambience for the bar interior
  // (after the gents, plus other Coach passages like Empty Glass and
  // His round). On Coach and Horses lock itself, the tag is intentionally
  // omitted so the gents bed plays first; the SpewPopup's _fadeOut then
  // manually starts this bed for the in-place bar transition.
  registerAmbientBed({
    label: 'coach-bar',
    dataUri: '__DSS_COACH_NIGHT_DATA_URI__',
    tags: { 'venue-coach': 1 },
    volume: 0.20,
    duckVolume: 0.07
  });
  // Find a registered bed by its label. Used by code paths that need to
  // start/stop a bed manually rather than via passage-tag matching (e.g.
  // popup-driven moments like the SpewPopup in the gents).
  function findBedByLabel(label) {
    for (var i = 0; i < _ambientBeds.length; i++) {
      if (_ambientBeds[i].label === label) return _ambientBeds[i];
    }
    return null;
  }
  function stopBedByLabel(label) {
    var bed = findBedByLabel(label);
    if (bed) _stopBed(bed);
  }
  function startBedByLabel(label) {
    var bed = findBedByLabel(label);
    if (!bed) return;
    bed._forced = true;
    _startBed(bed);
  }
  // Smooth fade to silence then stop. Used for the dawn ending so the
  // piano doesn't loop forever as the petals fill the screen.
  function fadeBedByLabel(label, durationMs) {
    var bed = findBedByLabel(label);
    if (!bed || !bed.started || !bed.gain) return;
    var ac = getCtx(); if (!ac) return;
    var ms = (typeof durationMs === 'number' && durationMs > 0) ? durationMs : 4000;
    var t = ac.currentTime;
    bed.gain.gain.cancelScheduledValues(t);
    bed.gain.gain.setValueAtTime(bed.gain.gain.value, t);
    bed.gain.gain.linearRampToValueAtTime(0.0001, t + ms / 1000);
    setTimeout(function(){ _stopBed(bed); }, ms + 50);
  }
  // Let an ambient bed finish its current loop iteration and stop
  // naturally — the audio plays through to its honest ending point
  // instead of being faded mid-phrase. Used by the dawn ending so the
  // piano theme reaches its real coda before the petals settle.
  function letBedFinishByLabel(label) {
    var bed = findBedByLabel(label);
    if (!bed || !bed.started || !bed.source) return;
    try {
      // _finishing flag prevents the gapMs path from rescheduling another
      // iteration after this one ends — without it, the gap restart logic
      // would relaunch the bed even after we asked it to stop.
      bed._finishing = true;
      bed.source.loop = false;
      bed.source.onended = function(){
        try { _stopBed(bed); } catch(e) {}
      };
    } catch(e) {}
    if (bed.gapTimer) { clearTimeout(bed.gapTimer); bed.gapTimer = null; }
  }
  // Flute-like single tone — sine fundamental with a breathy noise attack
  // (air across the embouchure) and a subtle vibrato. Still one pitch.
  // Used when "NAME YOUR BOOK" appears at the end of The Night Ahead's typewriter.
  function chimeBook() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 2.0;
      // Breath noise — short, filtered, mixes into the attack
      var bufLen = Math.floor(ac.sampleRate * 0.45);
      var nBuf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var nData = nBuf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) nData[i] = (Math.random() * 2 - 1);
      var nSrc = ac.createBufferSource(); nSrc.buffer = nBuf;
      var nFilt = ac.createBiquadFilter();
      nFilt.type = 'bandpass'; nFilt.frequency.value = 2200; nFilt.Q.value = 0.9;
      var nGain = ac.createGain();
      nGain.gain.setValueAtTime(0, now);
      nGain.gain.linearRampToValueAtTime(0.03, now + 0.05);
      nGain.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
      nSrc.connect(nFilt); nFilt.connect(nGain); nGain.connect(ac.destination);
      nSrc.start(now); nSrc.stop(now + 0.45);
      // Main flute tone — sine fundamental, slower (woodwind) attack
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.value = 698; // F5 — warmer than A5
      // Subtle vibrato (~4.5 Hz, small depth) — kicks in after the attack
      var vib = ac.createOscillator(); vib.type = 'sine';
      vib.frequency.value = 4.5;
      var vibG = ac.createGain(); vibG.gain.value = 3.5;
      vib.connect(vibG); vibG.connect(o.frequency);
      vib.start(now + 0.15); vib.stop(now + dur);
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.10, now + 0.08); // slower, breathier attack
      g.gain.linearRampToValueAtTime(0.08, now + 0.3);
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + dur + 0.05);
    });
  }
  // Glass clink — short bright ceramic/glass tap, as if a glass is set
  // down on the bar. Plays alongside pour() at the start of a drink popup.
  function glassClink() {
    _play(function(ac) {
      var now = ac.currentTime;
      [4200, 3100].forEach(function(freq, i) {
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.setValueAtTime(freq, now);
        o.frequency.exponentialRampToValueAtTime(freq * 0.85, now + 0.20);
        var g = ac.createGain();
        var amp = i === 0 ? 0.09 : 0.05;
        g.gain.setValueAtTime(0, now);
        g.gain.linearRampToValueAtTime(amp, now + 0.005);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.22);
        o.connect(g); g.connect(ac.destination);
        o.start(now); o.stop(now + 0.24);
      });
    });
  }
  // Swallow — soft throaty gulp; a band-passed noise burst over a low
  // descending tone. Plays when the player releases the drink popup.
  function swallow() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 0.20;
      // Throat noise
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) {
        var env = Math.exp(-i / (ac.sampleRate * 0.07));
        d[i] = (Math.random() * 2 - 1) * env * 0.6;
      }
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter();
      f.type = 'bandpass'; f.frequency.value = 280; f.Q.value = 3.5;
      var g = ac.createGain(); g.gain.value = 0.22;
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
      // Low descending pitch — the throat closing
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(180, now);
      o.frequency.exponentialRampToValueAtTime(110, now + dur);
      var og = ac.createGain();
      og.gain.setValueAtTime(0, now);
      og.gain.linearRampToValueAtTime(0.06, now + 0.04);
      og.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(og); og.connect(ac.destination);
      o.start(now); o.stop(now + dur);
    });
  }
  // Dodge whoosh — band-passed noise sweep, as a punch passes through air.
  function dodgeWhoosh() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 0.32;
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = Math.random() * 2 - 1;
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'bandpass';
      f.frequency.setValueAtTime(800, now);
      f.frequency.exponentialRampToValueAtTime(2400, now + 0.12);
      f.frequency.exponentialRampToValueAtTime(400, now + dur);
      f.Q.value = 1.8;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.38, now + 0.08);
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
    });
  }
  // Muffled thud — block: leather/cloth absorbing a punch.
  function muffledThud() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Low sub-thump
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(95, now);
      o.frequency.exponentialRampToValueAtTime(50, now + 0.18);
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.36, now + 0.012);
      g.gain.exponentialRampToValueAtTime(0.001, now + 0.20);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + 0.22);
      // Soft cloth/leather noise
      var bufLen = Math.floor(ac.sampleRate * 0.12);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.04));
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'lowpass'; f.frequency.value = 600;
      var ng = ac.createGain(); ng.gain.value = 0.18;
      src.connect(f); f.connect(ng); ng.connect(ac.destination);
      src.start(now);
    });
  }
  // Punch impact — sharp, fleshy thud when a punch lands.
  function punchImpact() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Low transient
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(160, now);
      o.frequency.exponentialRampToValueAtTime(45, now + 0.15);
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.50, now + 0.005);
      g.gain.exponentialRampToValueAtTime(0.001, now + 0.20);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + 0.22);
      // Bright snap layer (skin/bone slap)
      var bufLen = Math.floor(ac.sampleRate * 0.06);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.012));
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'bandpass'; f.frequency.value = 1800; f.Q.value = 1.0;
      var ng = ac.createGain(); ng.gain.value = 0.3;
      src.connect(f); f.connect(ng); ng.connect(ac.destination);
      src.start(now);
    });
  }
  // Vial clink — daintier than glassClink, three high partials, longer decay.
  // Camera shutter — mechanical SLR snap. Two phases: open (sharp, brighter
  // burst) then close ~80ms later (slightly heavier, lower). A faint
  // mid-thunk underneath gives the mirror its body. Used when the napkin
  // portrait is captured at the Sketch the Painter passage.
  function cameraShutter() {
    _play(function(ac) {
      var now = ac.currentTime;
      function clack(t0, dur, freq, q, gain) {
        var bufLen = Math.floor(ac.sampleRate * dur);
        var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
        var d = buf.getChannelData(0);
        for (var i = 0; i < bufLen; i++) {
          var env = Math.exp(-i / (ac.sampleRate * (dur * 0.22)));
          d[i] = (Math.random() * 2 - 1) * env;
        }
        var src = ac.createBufferSource(); src.buffer = buf;
        var f = ac.createBiquadFilter(); f.type = 'bandpass';
        f.frequency.value = freq; f.Q.value = q;
        var g = ac.createGain(); g.gain.value = gain;
        src.connect(f); f.connect(g); g.connect(ac.destination);
        src.start(t0);
      }
      function thunk(t0, freq, gain) {
        var o = ac.createOscillator(); o.type = 'triangle';
        o.frequency.setValueAtTime(freq, t0);
        o.frequency.exponentialRampToValueAtTime(freq * 0.55, t0 + 0.06);
        var g = ac.createGain();
        g.gain.setValueAtTime(0, t0);
        g.gain.linearRampToValueAtTime(gain, t0 + 0.004);
        g.gain.exponentialRampToValueAtTime(0.001, t0 + 0.07);
        o.connect(g); g.connect(ac.destination);
        o.start(t0); o.stop(t0 + 0.09);
      }
      // Phase 1 — shutter open: brighter, shorter
      clack(now, 0.030, 4200, 4.5, 0.55);
      thunk(now, 180, 0.14);
      // Phase 2 — shutter close: heavier, lower, slight delay
      clack(now + 0.085, 0.050, 2600, 3.5, 0.60);
      thunk(now + 0.085, 130, 0.18);
    });
  }
  function vialClink() {
    _play(function(ac) {
      var now = ac.currentTime;
      [5800, 4200, 2900].forEach(function(freq, i) {
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.setValueAtTime(freq, now);
        o.frequency.exponentialRampToValueAtTime(freq * 0.92, now + 0.65);
        var g = ac.createGain();
        var amp = [0.055, 0.04, 0.03][i];
        g.gain.setValueAtTime(0, now);
        g.gain.linearRampToValueAtTime(amp, now + 0.005);
        g.gain.exponentialRampToValueAtTime(0.001, now + 0.65);
        o.connect(g); g.connect(ac.destination);
        o.start(now); o.stop(now + 0.70);
      });
    });
  }
  // Uncork — wet pop with a quick rising chirp.
  function uncork() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Pop transient
      var bufLen = Math.floor(ac.sampleRate * 0.08);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.008));
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'bandpass'; f.frequency.value = 700; f.Q.value = 3;
      var g = ac.createGain(); g.gain.value = 0.40;
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
      // Rising chirp (cork escaping bottle)
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(220, now);
      o.frequency.exponentialRampToValueAtTime(680, now + 0.05);
      var og = ac.createGain();
      og.gain.setValueAtTime(0, now);
      og.gain.linearRampToValueAtTime(0.16, now + 0.005);
      og.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
      o.connect(og); og.connect(ac.destination);
      o.start(now); o.stop(now + 0.10);
    });
  }
  // Uncanny breath — a slow, breathy exhalation as if something close is
  // exhaling near you. Used when the Fetch (your double) appears.
  function uncannyBreath() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 1.6;
      // Filtered breath noise
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) {
        var p = i / bufLen;
        // Slow attack, hold, slow release
        var env = Math.min(1, p * 4) * Math.min(1, (1 - p) * 3);
        d[i] = (Math.random() * 2 - 1) * env;
      }
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter();
      f.type = 'bandpass';
      f.frequency.setValueAtTime(700, now);
      f.frequency.exponentialRampToValueAtTime(1500, now + dur * 0.5);
      f.frequency.exponentialRampToValueAtTime(550, now + dur);
      f.Q.value = 2.0;
      var g = ac.createGain(); g.gain.value = 0.16;
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
      // A faint low pitch underneath — the suggestion of voice
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(135, now);
      o.frequency.exponentialRampToValueAtTime(105, now + dur);
      var og = ac.createGain();
      og.gain.setValueAtTime(0, now);
      og.gain.linearRampToValueAtTime(0.022, now + 0.5);
      og.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(og); og.connect(ac.destination);
      o.start(now); o.stop(now + dur);
    });
  }
  // Distant bell — a single far-off church bell. Inharmonic partials and
  // a long decay give it that "across the city" quality.
  function distantBell() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 3.6; // shorter tail — a single morning dong, not a continuous peal
      var partials = [
        { freq: 440,  amp: 0.035 },  // fundamental (A4) — subtle, not loud
        { freq: 880,  amp: 0.022 },  // octave
        { freq: 1180, amp: 0.014 },  // inharmonic — gives bell quality
        { freq: 220,  amp: 0.020 }   // sub-hum
        // sparkle partial dropped — too bright for a far-off morning bell
      ];
      partials.forEach(function(p) {
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.value = p.freq;
        var g = ac.createGain();
        g.gain.setValueAtTime(0, now);
        g.gain.linearRampToValueAtTime(p.amp, now + 0.02);
        g.gain.exponentialRampToValueAtTime(0.001, now + dur);
        o.connect(g); g.connect(ac.destination);
        o.start(now); o.stop(now + dur + 0.05);
      });
    });
  }
  // Phone line — a faint, looping carrier hum/crackle for under call dialogue.
  // Bandpass-filtered noise around the telephone band, with a slow LFO
  // wobbling the filter frequency for a tape-like crackle.
  var _phoneLineNodes = [];
  function stopPhoneLine() {
    _phoneLineNodes.forEach(function(node) {
      try { if (node.stop) node.stop(); } catch(e) {}
      try { node.disconnect(); } catch(e) {}
    });
    _phoneLineNodes = [];
  }
  function phoneLine() {
    stopPhoneLine();
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 4.0;
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * 0.55;
      var src = ac.createBufferSource(); src.buffer = buf; src.loop = true;
      var f = ac.createBiquadFilter();
      f.type = 'bandpass';
      f.frequency.value = 1800;
      f.Q.value = 4.0;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.045, now + 1.2); // gentle fade-in
      // Slow LFO on filter freq — gives the line a soft, breathing crackle
      var lfo = ac.createOscillator(); lfo.type = 'sine';
      lfo.frequency.value = 0.13;
      var lfoG = ac.createGain(); lfoG.gain.value = 220;
      lfo.connect(lfoG); lfoG.connect(f.frequency);
      lfo.start(now);
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
      _phoneLineNodes.push(src);
      _phoneLineNodes.push(lfo);
    });
  }
  // Hoof beat — a single clop. Short, low, with a cloth-on-ground noise.
  function hoofBeat() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Low body — pitch drops fast
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.setValueAtTime(180, now);
      o.frequency.exponentialRampToValueAtTime(70, now + 0.08);
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.22, now + 0.005);
      g.gain.exponentialRampToValueAtTime(0.001, now + 0.10);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + 0.12);
      // Light noise scuff
      var bufLen = Math.floor(ac.sampleRate * 0.05);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.018));
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'bandpass'; f.frequency.value = 600; f.Q.value = 1.5;
      var ng = ac.createGain(); ng.gain.value = 0.10;
      src.connect(f); f.connect(ng); ng.connect(ac.destination);
      src.start(now);
    });
  }
  // Cow moo — long, throaty, descending pitch with vibrato.
  function cowMoo() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 1.2;
      // Main pitch — low oscillator with descending slide
      var o = ac.createOscillator(); o.type = 'sawtooth';
      o.frequency.setValueAtTime(190, now);
      o.frequency.linearRampToValueAtTime(165, now + 0.25);
      o.frequency.linearRampToValueAtTime(155, now + 0.7);
      o.frequency.linearRampToValueAtTime(120, now + dur);
      // Slight vibrato — throaty
      var vib = ac.createOscillator(); vib.type = 'sine';
      vib.frequency.value = 6;
      var vibG = ac.createGain(); vibG.gain.value = 4;
      vib.connect(vibG); vibG.connect(o.frequency);
      vib.start(now); vib.stop(now + dur);
      var f = ac.createBiquadFilter(); f.type = 'lowpass';
      f.frequency.value = 750; f.Q.value = 0.8;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.10, now + 0.18);
      g.gain.linearRampToValueAtTime(0.085, now + 0.6);
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(f); f.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + dur);
    });
  }
  // Thunder clap — distant rumble building to a crack, with a long tail.
  // Modelled as: low rumble (filtered noise) + sharp transient + long roll.
  function thunderClap() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 2.6;
      // Low rumble — lowpass-filtered noise, swells then fades
      var bufLen = Math.floor(ac.sampleRate * dur);
      var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var d = buf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1);
      var src = ac.createBufferSource(); src.buffer = buf;
      var f = ac.createBiquadFilter(); f.type = 'lowpass';
      f.frequency.setValueAtTime(180, now);
      f.frequency.linearRampToValueAtTime(120, now + dur);
      f.Q.value = 0.7;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.32, now + 0.18);   // build
      g.gain.linearRampToValueAtTime(0.55, now + 0.30);   // crack peak
      g.gain.exponentialRampToValueAtTime(0.001, now + dur); // long roll
      src.connect(f); f.connect(g); g.connect(ac.destination);
      src.start(now);
      // Sharp crack transient at the peak
      var cLen = Math.floor(ac.sampleRate * 0.08);
      var cBuf = ac.createBuffer(1, cLen, ac.sampleRate);
      var cD = cBuf.getChannelData(0);
      for (var k = 0; k < cLen; k++) cD[k] = (Math.random() * 2 - 1) * Math.exp(-k / (ac.sampleRate * 0.012));
      var cSrc = ac.createBufferSource(); cSrc.buffer = cBuf;
      var cF = ac.createBiquadFilter(); cF.type = 'bandpass'; cF.frequency.value = 1400; cF.Q.value = 1.2;
      var cG = ac.createGain(); cG.gain.value = 0.42;
      cSrc.connect(cF); cF.connect(cG); cG.connect(ac.destination);
      cSrc.start(now + 0.28);
    });
  }
  // Door knock — a few sharp wood knocks. Times defaults to 3.
  function doorKnock(times) {
    times = times || 3;
    _play(function(ac) {
      var now = ac.currentTime;
      for (var k = 0; k < times; k++) {
        var t = now + k * 0.18;
        // Sharp wood-impact transient
        var bufLen = Math.floor(ac.sampleRate * 0.04);
        var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
        var d = buf.getChannelData(0);
        for (var i = 0; i < bufLen; i++) d[i] = (Math.random() * 2 - 1) * Math.exp(-i / (ac.sampleRate * 0.005));
        var src = ac.createBufferSource(); src.buffer = buf;
        var f = ac.createBiquadFilter(); f.type = 'bandpass'; f.frequency.value = 380; f.Q.value = 4.5;
        var g = ac.createGain(); g.gain.value = 0.42;
        src.connect(f); f.connect(g); g.connect(ac.destination);
        src.start(t);
        // Low resonance — the door's body
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.setValueAtTime(110, t);
        o.frequency.exponentialRampToValueAtTime(70, t + 0.10);
        var og = ac.createGain();
        og.gain.setValueAtTime(0, t);
        og.gain.linearRampToValueAtTime(0.18, t + 0.005);
        og.gain.exponentialRampToValueAtTime(0.001, t + 0.12);
        o.connect(og); og.connect(ac.destination);
        o.start(t); o.stop(t + 0.14);
      }
    });
  }
  // Lily chime — held string-harmonic note that swells and fades.
  // Played when the player clicks one of the lily-flower glimpses.
  // Pitched an octave down from the original (E6 → E5) so it reads as
  // warmer, less treble-piercing — same shape, lower register.
  // Brief upward arpeggio — fires when a password is correctly deployed.
  // Three quick sine pings rising through a major triad, with a shimmer
  // octave on top of the last note. Warm, small, not triumphant.
  function passwordSuccess() {
    _play(function(ac) {
      var now = ac.currentTime;
      var notes = [
        { f: 587.33, t: 0.00, dur: 0.55, amp: 0.075 }, // D5
        { f: 739.99, t: 0.09, dur: 0.55, amp: 0.075 }, // F#5
        { f: 880.00, t: 0.18, dur: 0.75, amp: 0.085 }  // A5
      ];
      notes.forEach(function(n) {
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.value = n.f;
        var g = ac.createGain();
        g.gain.setValueAtTime(0, now + n.t);
        g.gain.linearRampToValueAtTime(n.amp, now + n.t + 0.02);
        g.gain.linearRampToValueAtTime(n.amp * 0.7, now + n.t + 0.18);
        g.gain.exponentialRampToValueAtTime(0.001, now + n.t + n.dur);
        o.connect(g); g.connect(ac.destination);
        o.start(now + n.t); o.stop(now + n.t + n.dur + 0.05);
      });
      // Shimmer one octave above the final note
      var sh = ac.createOscillator(); sh.type = 'sine';
      sh.frequency.value = 1760;
      var shG = ac.createGain();
      shG.gain.setValueAtTime(0, now + 0.18);
      shG.gain.linearRampToValueAtTime(0.035, now + 0.26);
      shG.gain.exponentialRampToValueAtTime(0.001, now + 0.95);
      sh.connect(shG); shG.connect(ac.destination);
      sh.start(now + 0.18); sh.stop(now + 1.0);
    });
  }
  function lilyChime() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 2.4;
      // Main tone — sine, harmonic-like
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.value = 659; // E5 — warm, ringing (was 1318 / E6)
      // Subtle vibrato (~5 Hz, very small depth) — kicks in mid-swell
      var vib = ac.createOscillator(); vib.type = 'sine';
      vib.frequency.value = 5;
      var vibG = ac.createGain(); vibG.gain.value = 2.0;
      vib.connect(vibG); vibG.connect(o.frequency);
      vib.start(now + 0.4); vib.stop(now + dur);
      // Slow swell + slow fade
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.07, now + 0.5);   // slow swell
      g.gain.linearRampToValueAtTime(0.06, now + 1.0);   // brief hold
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + dur + 0.05);
      // A faint shimmer one octave up of the new fundamental, softer
      var o2 = ac.createOscillator(); o2.type = 'sine';
      o2.frequency.value = 988; // ~B5 (was 1976 / B6)
      var g2 = ac.createGain();
      g2.gain.setValueAtTime(0, now);
      g2.gain.linearRampToValueAtTime(0.025, now + 0.6);
      g2.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o2.connect(g2); g2.connect(ac.destination);
      o2.start(now + 0.1); o2.stop(now + dur + 0.05);
    });
  }
  // Low, dull "block" thunk — feedback for poking a flower that's already
  // been gathered. Pitched well below lilyChime, short and damped, with no
  // shimmer, so it reads as a soft refusal rather than a collection cue.
  function lilyBlock() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 0.22;
      var o = ac.createOscillator(); o.type = 'triangle';
      o.frequency.setValueAtTime(150, now);
      o.frequency.exponentialRampToValueAtTime(96, now + dur);  // slight downward thunk
      var g = ac.createGain();
      g.gain.setValueAtTime(0.0001, now);
      g.gain.linearRampToValueAtTime(0.09, now + 0.008);        // fast attack
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);    // quick damped decay
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + dur + 0.03);
      // Softer sub an octave down for body
      var o2 = ac.createOscillator(); o2.type = 'sine';
      o2.frequency.value = 75;
      var g2 = ac.createGain();
      g2.gain.setValueAtTime(0.0001, now);
      g2.gain.linearRampToValueAtTime(0.05, now + 0.01);
      g2.gain.exponentialRampToValueAtTime(0.001, now + dur * 0.8);
      o2.connect(g2); g2.connect(ac.destination);
      o2.start(now); o2.stop(now + dur);
    });
  }
  // Bright chord — a single sparkling celesta-like note plucked from a
  // Cmaj9 cluster, with an octave-up shimmer and a brief triangle tine at
  // the attack. Designed to be called repeatedly (throttled by the caller)
  // so that successive picks accumulate into an evolving chord. Used by the
  // liver-eating popup to give the eagle movement an airy, hymnal sparkle.
  function brightChord() {
    _play(function(ac) {
      var now = ac.currentTime;
      var notes = [1046.5, 1318.5, 1568.0, 1975.5, 2349.3, 2637.0];
      var f = notes[Math.floor(Math.random() * notes.length)];
      var dur = 1.1;
      var o = ac.createOscillator(); o.type = 'sine';
      o.frequency.value = f;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(0.10, now + 0.012);
      g.gain.exponentialRampToValueAtTime(0.001, now + dur);
      o.connect(g); g.connect(ac.destination);
      o.start(now); o.stop(now + dur + 0.05);
      var o2 = ac.createOscillator(); o2.type = 'sine';
      o2.frequency.value = f * 2;
      var g2 = ac.createGain();
      g2.gain.setValueAtTime(0, now);
      g2.gain.linearRampToValueAtTime(0.035, now + 0.018);
      g2.gain.exponentialRampToValueAtTime(0.001, now + dur * 0.7);
      o2.connect(g2); g2.connect(ac.destination);
      o2.start(now); o2.stop(now + dur);
      var o3 = ac.createOscillator(); o3.type = 'triangle';
      o3.frequency.value = f * 1.5;
      var g3 = ac.createGain();
      g3.gain.setValueAtTime(0, now);
      g3.gain.linearRampToValueAtTime(0.04, now + 0.006);
      g3.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
      o3.connect(g3); g3.connect(ac.destination);
      o3.start(now); o3.stop(now + 0.2);
    });
  }
  // Vinyl needle lift — the soft "thup" of the cartridge leaving the
  // groove, a brief surface-noise tail, and a few residual surface pops
  // as the needle moves away. Procedural, no sample.
  function needleLift() {
    _play(function(ac) {
      var now = ac.currentTime;
      // ── Thup: short noise burst, mid-low band ──
      var thupLen = Math.floor(ac.sampleRate * 0.08);
      var thupBuf = ac.createBuffer(1, thupLen, ac.sampleRate);
      var td = thupBuf.getChannelData(0);
      for (var i = 0; i < thupLen; i++) {
        var tEnv = Math.exp(-i / (ac.sampleRate * 0.012));
        td[i] = (Math.random() * 2 - 1) * tEnv;
      }
      var thupSrc = ac.createBufferSource(); thupSrc.buffer = thupBuf;
      var thupF = ac.createBiquadFilter(); thupF.type = 'bandpass';
      thupF.frequency.value = 320; thupF.Q.value = 1.2;
      var thupG = ac.createGain(); thupG.gain.value = 0.55;
      thupSrc.connect(thupF); thupF.connect(thupG); thupG.connect(ac.destination);
      thupSrc.start(now);
      // ── Fading vinyl surface hiss tail ──
      var hissLen = Math.floor(ac.sampleRate * 0.42);
      var hissBuf = ac.createBuffer(1, hissLen, ac.sampleRate);
      var hd = hissBuf.getChannelData(0);
      for (var j = 0; j < hissLen; j++) {
        var t = j / ac.sampleRate;
        var fadeIn = Math.min(1, t / 0.02);
        var decay = Math.exp(-t * 5.5);
        hd[j] = (Math.random() * 2 - 1) * fadeIn * decay * 0.18;
      }
      var hissSrc = ac.createBufferSource(); hissSrc.buffer = hissBuf;
      var hissF = ac.createBiquadFilter(); hissF.type = 'highpass';
      hissF.frequency.value = 1200; hissF.Q.value = 0.7;
      hissSrc.connect(hissF); hissF.connect(ac.destination);
      hissSrc.start(now);
      // ── A handful of residual surface pops in the tail ──
      for (var k = 0; k < 3; k++) {
        var t0 = now + 0.04 + Math.random() * 0.25;
        var popLen = Math.floor(ac.sampleRate * 0.008);
        var popBuf = ac.createBuffer(1, popLen, ac.sampleRate);
        var pd = popBuf.getChannelData(0);
        for (var p = 0; p < popLen; p++) {
          var penv = Math.exp(-p / (ac.sampleRate * 0.002));
          pd[p] = (Math.random() * 2 - 1) * penv;
        }
        var popSrc = ac.createBufferSource(); popSrc.buffer = popBuf;
        var popF = ac.createBiquadFilter(); popF.type = 'highpass';
        popF.frequency.value = 2400; popF.Q.value = 1.0;
        var popG = ac.createGain(); popG.gain.value = 0.18 + Math.random() * 0.12;
        popSrc.connect(popF); popF.connect(popG); popG.connect(ac.destination);
        popSrc.start(t0);
      }
    });
  }
  // ── COSMIC SEWER SUCK ──────────────────────────────────────────────
  // Long ~3.5s pipe-rush: filtered noise with a rising lowpass cutoff,
  // a sub rumble that pitches up (we accelerate toward the end of the
  // pipe), three submerged bubble pops scattered through the middle,
  // and a wet splash at the end when the player breaks the surface.
  // A short feedback delay across the whole graph gives it the vault-y
  // "cosmic" depth that distinguishes it from a plain water flush.
  function cosmicSewerSuck() {
    _play(function(ac) {
      var now = ac.currentTime;
      var DUR = 3.5;
      // ── Delay/feedback network — used as a parallel send for the wet,
      //    cathedral-ish tail. Light feedback, gentle highshelf cut so
      //    the tail doesn't get harsh. ──
      var delay = ac.createDelay(); delay.delayTime.value = 0.28;
      var fbk   = ac.createGain();   fbk.gain.value = 0.35;
      var dHpf  = ac.createBiquadFilter(); dHpf.type = 'highpass';
      dHpf.frequency.value = 180;
      var dWet  = ac.createGain();   dWet.gain.value = 0.45;
      delay.connect(dHpf); dHpf.connect(fbk); fbk.connect(delay);
      delay.connect(dWet); dWet.connect(ac.destination);
      // ── 1. Long noise whoosh — main "we are travelling" body. Lowpass
      //    opens as we accelerate; gain swells and tails off at the end. ──
      var bufLen = Math.floor(ac.sampleRate * DUR);
      var nbuf = ac.createBuffer(1, bufLen, ac.sampleRate);
      var nd = nbuf.getChannelData(0);
      for (var i = 0; i < bufLen; i++) nd[i] = (Math.random() * 2 - 1);
      var nSrc = ac.createBufferSource(); nSrc.buffer = nbuf;
      var nLp  = ac.createBiquadFilter(); nLp.type = 'lowpass'; nLp.Q.value = 0.9;
      nLp.frequency.setValueAtTime(320, now);
      nLp.frequency.exponentialRampToValueAtTime(2400, now + DUR * 0.78);
      nLp.frequency.exponentialRampToValueAtTime(4800, now + DUR);
      var nHp = ac.createBiquadFilter(); nHp.type = 'highpass';
      nHp.frequency.setValueAtTime(120, now);
      var nG  = ac.createGain();
      nG.gain.setValueAtTime(0.0001, now);
      nG.gain.exponentialRampToValueAtTime(0.34, now + DUR * 0.55);
      nG.gain.exponentialRampToValueAtTime(0.55, now + DUR * 0.85);
      nG.gain.exponentialRampToValueAtTime(0.0001, now + DUR);
      nSrc.connect(nLp); nLp.connect(nHp); nHp.connect(nG);
      nG.connect(ac.destination); nG.connect(delay);
      nSrc.start(now); nSrc.stop(now + DUR + 0.05);
      // ── 2. Sub rumble — low oscillator that pitches up so we feel the
      //    forward acceleration in the gut. Saw wave through a lowpass. ──
      var rOsc = ac.createOscillator(); rOsc.type = 'sawtooth';
      rOsc.frequency.setValueAtTime(34, now);
      rOsc.frequency.exponentialRampToValueAtTime(110, now + DUR * 0.85);
      rOsc.frequency.exponentialRampToValueAtTime(58, now + DUR);
      var rLp  = ac.createBiquadFilter(); rLp.type = 'lowpass';
      rLp.frequency.setValueAtTime(180, now);
      rLp.frequency.exponentialRampToValueAtTime(420, now + DUR * 0.85);
      var rG  = ac.createGain();
      rG.gain.setValueAtTime(0.0001, now);
      rG.gain.exponentialRampToValueAtTime(0.42, now + DUR * 0.55);
      rG.gain.exponentialRampToValueAtTime(0.68, now + DUR * 0.85);
      rG.gain.exponentialRampToValueAtTime(0.0001, now + DUR);
      rOsc.connect(rLp); rLp.connect(rG);
      rG.connect(ac.destination); rG.connect(delay);
      rOsc.start(now); rOsc.stop(now + DUR + 0.05);
      // ── 3. Three submerged bubble pops scattered through the middle ──
      [0.45, 1.1, 1.9].forEach(function(off) {
        var bt = now + off + (Math.random() - 0.5) * 0.18;
        // Pop body: short low sine that drops in pitch (cavity closes)
        var bOsc = ac.createOscillator(); bOsc.type = 'sine';
        var f0 = 280 + Math.random() * 220;
        bOsc.frequency.setValueAtTime(f0, bt);
        bOsc.frequency.exponentialRampToValueAtTime(70, bt + 0.18);
        var bG = ac.createGain();
        bG.gain.setValueAtTime(0.0001, bt);
        bG.gain.exponentialRampToValueAtTime(0.42, bt + 0.012);
        bG.gain.exponentialRampToValueAtTime(0.0001, bt + 0.22);
        bOsc.connect(bG); bG.connect(ac.destination); bG.connect(delay);
        bOsc.start(bt); bOsc.stop(bt + 0.24);
        // Pop click: tiny noise transient on top
        var cLen = Math.floor(ac.sampleRate * 0.018);
        var cBuf = ac.createBuffer(1, cLen, ac.sampleRate);
        var cd = cBuf.getChannelData(0);
        for (var j = 0; j < cLen; j++) {
          cd[j] = (Math.random() * 2 - 1) * Math.exp(-j / (ac.sampleRate * 0.003));
        }
        var cSrc = ac.createBufferSource(); cSrc.buffer = cBuf;
        var cBp = ac.createBiquadFilter(); cBp.type = 'bandpass';
        cBp.frequency.value = 1400; cBp.Q.value = 1.6;
        var cG = ac.createGain(); cG.gain.value = 0.22;
        cSrc.connect(cBp); cBp.connect(cG);
        cG.connect(ac.destination); cG.connect(delay);
        cSrc.start(bt);
      });
      // ── 4. Final splash — wet ploom when the player breaks the
      //    surface at the end of the pipe. Two layers: a low "thoom"
      //    oscillator and a fast noise transient with a falling bandpass. ──
      var spT = now + DUR * 0.86;
      var spOsc = ac.createOscillator(); spOsc.type = 'sine';
      spOsc.frequency.setValueAtTime(160, spT);
      spOsc.frequency.exponentialRampToValueAtTime(48, spT + 0.45);
      var spG = ac.createGain();
      spG.gain.setValueAtTime(0.0001, spT);
      spG.gain.exponentialRampToValueAtTime(0.62, spT + 0.02);
      spG.gain.exponentialRampToValueAtTime(0.0001, spT + 0.55);
      spOsc.connect(spG); spG.connect(ac.destination); spG.connect(delay);
      spOsc.start(spT); spOsc.stop(spT + 0.6);
      // Splash spray (noise transient with falling bandpass)
      var sLen = Math.floor(ac.sampleRate * 0.45);
      var sBuf = ac.createBuffer(1, sLen, ac.sampleRate);
      var sd = sBuf.getChannelData(0);
      for (var k = 0; k < sLen; k++) sd[k] = (Math.random() * 2 - 1);
      var sSrc = ac.createBufferSource(); sSrc.buffer = sBuf;
      var sBp = ac.createBiquadFilter(); sBp.type = 'bandpass'; sBp.Q.value = 1.4;
      sBp.frequency.setValueAtTime(2400, spT);
      sBp.frequency.exponentialRampToValueAtTime(420, spT + 0.4);
      var sG = ac.createGain();
      sG.gain.setValueAtTime(0.0001, spT);
      sG.gain.exponentialRampToValueAtTime(0.45, spT + 0.015);
      sG.gain.exponentialRampToValueAtTime(0.0001, spT + 0.5);
      sSrc.connect(sBp); sBp.connect(sG);
      sG.connect(ac.destination); sG.connect(delay);
      sSrc.start(spT);
    });
  }
  return {
    pour: pour, sip: sip, phoneRing: phoneRing, pageRustle: pageRustle, pageShuffle: pageShuffle,
    startPissStream: startPissStream, startRetchStream: startRetchStream,
    typewriterTick: typewriterTick, typewriterClack: typewriterClack,
    itemFound: itemFound,
    penScratch: penScratch, heartbeat: heartbeat,
    glassSmash: glassSmash, matchStrike: matchStrike, coinFlip: coinFlip,
    doorCreak: doorCreak, doorSwingBell: doorSwingBell, doorThud: doorThud, doorShopBell: doorShopBell,
    passageWhoosh: passageWhoosh, loreUnravel: loreUnravel,
    ambientPub: ambientPub, ambientDream: ambientDream, ambientOff: ambientOff, ambientCut: ambientCut,
    // Farnell-style procedural models
    phoneBell: phoneBell, windFarnell: windFarnell,
    fireFarnell: fireFarnell, footstep: footstep,
    chimeBook: chimeBook, lilyChime: lilyChime, lilyBlock: lilyBlock, brightChord: brightChord,
    passwordSuccess: passwordSuccess,
    stopPhoneBell: stopPhoneBell,
    phoneLine: phoneLine, stopPhoneLine: stopPhoneLine,
    glassClink: glassClink, swallow: swallow,
    dodgeWhoosh: dodgeWhoosh, muffledThud: muffledThud, punchImpact: punchImpact,
    vialClink: vialClink, uncork: uncork, cameraShutter: cameraShutter,
    uncannyBreath: uncannyBreath, distantBell: distantBell, doorKnock: doorKnock,
    thunderClap: thunderClap, hoofBeat: hoofBeat, cowMoo: cowMoo,
    distantTraffic: distantTraffic, stopDistantTraffic: stopDistantTraffic,
    carHorn: carHorn, dripDrop: dripDrop,
    needleLift: needleLift,
    cosmicSewerSuck: cosmicSewerSuck,
    // Background music bed
    startMusic: startMusic, stopMusic: stopMusic,
    updateMusicForPassage: updateMusicForPassage,
    pauseMusic: pauseMusic, resumeMusic: resumeMusic,
    setMusicVolume: setMusicVolume,
    setMuted: setMuted, isMuted: isMuted,
    _duckMusic: _duckMusic,
    // Venue ambient beds
    registerAmbientBed: registerAmbientBed,
    updateAmbientBedsForPassage: updateAmbientBedsForPassage,
    startBed: startBedByLabel, stopBed: stopBedByLabel, fadeBed: fadeBedByLabel, letBedFinish: letBedFinishByLabel
  };
})();

// ====== MUTE BUTTON (bottom-right corner) ======
// Single fixed-position toggle. Two SVG icons baked in (speaker on / speaker
// off); CSS swaps them via [data-muted]. Persists state via dssAudio.setMuted
// which writes to localStorage internally.
(function() {
  function buildMuteButton() {
    if (document.getElementById('dss-mute-btn')) return;
    var btn = document.createElement('button');
    btn.id = 'dss-mute-btn';
    btn.type = 'button';
    btn.setAttribute('aria-label', 'Mute audio');
    btn.setAttribute('data-muted', (window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted()) ? '1' : '0');
    btn.innerHTML = ''
      + '<svg class="dss-mute-icon dss-mute-icon-on" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">'
      +   '<path d="M4 9v6h4l5 4V5L8 9H4z"/>'
      +   '<path d="M16 8.5c1.2 1 1.8 2.2 1.8 3.5s-0.6 2.5-1.8 3.5"/>'
      +   '<path d="M19 6c2 1.7 3 3.7 3 6s-1 4.3-3 6"/>'
      + '</svg>'
      + '<svg class="dss-mute-icon dss-mute-icon-off" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">'
      +   '<path d="M4 9v6h4l5 4V5L8 9H4z"/>'
      +   '<line x1="16" y1="9" x2="22" y2="15"/>'
      +   '<line x1="22" y1="9" x2="16" y2="15"/>'
      + '</svg>';
    btn.addEventListener('click', function() {
      if (!window.dssAudio || !window.dssAudio.setMuted) return;
      var next = !window.dssAudio.isMuted();
      window.dssAudio.setMuted(next);
      btn.setAttribute('data-muted', next ? '1' : '0');
    });
    document.body.appendChild(btn);
  }
  if (document.body) {
    buildMuteButton();
  } else {
    document.addEventListener('DOMContentLoaded', buildMuteButton);
  }
})();

// ====== LILY CLICK CHIME + PETAL MOTE ======
// Inline <script> tags inside (click-replace:) hooks don't execute when
// Harlowe inserts them via innerHTML, so use a delegated click listener
// to fire the chime AND spawn a single white lily-petal mote that floats
// up toward the notebook link in the header.
(function() {
  function spawnLilyPetal(hook) {
    var nb = document.querySelector('.notebook-link');
    var hookRect = hook.getBoundingClientRect();
    var startX = hookRect.left + hookRect.width / 2;
    var startY = hookRect.top + hookRect.height / 2;
    // If we can't find the notebook, just float upward and offscreen.
    var dx = 0, dy = -260;
    if (nb) {
      var nbRect = nb.getBoundingClientRect();
      dx = (nbRect.left + nbRect.width / 2) - startX;
      dy = (nbRect.top + nbRect.height / 2) - startY;
    }
    var petal = document.createElement('div');
    petal.className = 'lily-petal-mote';
    petal.style.left = startX + 'px';
    petal.style.top = startY + 'px';
    petal.style.setProperty('--dx', dx + 'px');
    petal.style.setProperty('--dy', dy + 'px');
    petal.innerHTML = ''
      + '<svg viewBox="0 0 24 36" preserveAspectRatio="xMidYMid meet" aria-hidden="true">'
      +   '<defs>'
      +     '<radialGradient id="lpGrad" cx="50%" cy="40%" r="60%">'
      +       '<stop offset="0%" stop-color="rgba(255,252,255,0.95)"/>'
      +       '<stop offset="65%" stop-color="rgba(238,228,245,0.78)"/>'
      +       '<stop offset="100%" stop-color="rgba(210,200,235,0.0)"/>'
      +     '</radialGradient>'
      +   '</defs>'
      +   '<path d="M12,2 Q4,11 4,22 Q4,32 12,34 Q20,32 20,22 Q20,11 12,2 Z" '
      +     'fill="url(#lpGrad)" stroke="rgba(220,205,235,0.55)" stroke-width="0.4"/>'
      +   '<path d="M12,4 Q9,14 11,32" fill="none" '
      +     'stroke="rgba(230,215,240,0.35)" stroke-width="0.5"/>'
      + '</svg>';
    document.body.appendChild(petal);
    setTimeout(function() {
      if (petal.parentNode) petal.parentNode.removeChild(petal);
    }, 3700);
  }

  // Briefly fade a spent flower (down to near-invisible, then back) so a
  // click on an already-gathered lily reads as "nothing here". Re-applied
  // each click via a reflow so it restarts every time.
  function lilyBlip(el) {
    if (!el) return;
    el.classList.remove('lily-spent-blip');
    void el.offsetWidth;
    el.classList.add('lily-spent-blip');
  }
  window.dssLilyBlip = lilyBlip;

  // Track which lily hooks have already released their petal this view.
  // Harlowe's (click-replace:) is one-shot, but the named tw-hook lingers in
  // the DOM after it fires — so without this guard a second click would still
  // spawn a petal even though no new flower is gathered.
  var _petalled = {};
  document.addEventListener('click', function(e) {
    var hook = e.target.closest('tw-hook');
    if (!hook) return;
    var name = hook.getAttribute('name') || '';
    if (!/^lily\d+$/i.test(name)) return;
    if (_petalled[name]) {
      // Already gathered this view — no new petal, no notebook entry. Give a
      // low "blocked" thunk and fade the spent lily instead.
      if (window.dssAudio && window.dssAudio.lilyBlock) window.dssAudio.lilyBlock();
      lilyBlip(hook.querySelector('.lily-prompt') || hook);
      return;
    }
    _petalled[name] = true;
    if (window.dssAudio && window.dssAudio.lilyChime) {
      window.dssAudio.lilyChime();
    }
    // Defer one frame so the click has been visually acknowledged.
    requestAnimationFrame(function() { spawnLilyPetal(hook); });
  }, true);
})();

// ====== MINIGAME RULES MODAL ======
// A simple popup shown before a minigame begins: the game's title, a few
// plain-language rules, and a single PLAY button that closes the modal and
// runs opts.onPlay() to start the game. Appended to <body> at a high z-index;
// a MutationObserver on tw-story tears it down (without starting the game) if
// the player navigates away before pressing Play.
(function() {
  function showRules(opts) {
    opts = opts || {};
    if (typeof opts.onPlay !== 'function') return;
    var prev = document.getElementById('dss-rules-overlay');
    if (prev && prev.parentNode) prev.parentNode.removeChild(prev);

    var overlay = document.createElement('div');
    overlay.className = 'dss-rules-overlay';
    overlay.id = 'dss-rules-overlay';
    var card = document.createElement('div');
    card.className = 'dss-rules-card';

    var h = document.createElement('div');
    h.className = 'dss-rules-title';
    h.textContent = opts.title || 'How to play';
    card.appendChild(h);

    if (opts.subtitle) {
      var s = document.createElement('div');
      s.className = 'dss-rules-sub';
      s.textContent = opts.subtitle;
      card.appendChild(s);
    }

    var ul = document.createElement('ul');
    ul.className = 'dss-rules-list';
    (opts.lines || []).forEach(function(line) {
      var li = document.createElement('li');
      li.innerHTML = line;   // author-controlled; allows &larr; <b> etc.
      ul.appendChild(li);
    });
    card.appendChild(ul);

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'dss-rules-play';
    btn.innerHTML = '&#9654;&nbsp;&nbsp;Play';
    card.appendChild(btn);

    overlay.appendChild(card);
    document.body.appendChild(overlay);
    requestAnimationFrame(function() { overlay.classList.add('dss-rules-in'); });

    var done = false;
    var obs = null;
    function teardown() {
      if (obs) { try { obs.disconnect(); } catch (e) {} obs = null; }
      overlay.classList.remove('dss-rules-in');
      overlay.classList.add('dss-rules-out');
      setTimeout(function() {
        if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
      }, 280);
    }
    btn.addEventListener('click', function() {
      if (done) return; done = true;
      teardown();
      try { opts.onPlay(); } catch (e) {}
    });

    // If the player leaves the passage before pressing Play, remove the modal
    // without starting the game. Tear down only when the passage the modal was
    // launched from actually leaves the DOM — trailing mutations from the
    // passage transition that brought us here (which keep that passage in
    // place) must NOT trigger a false teardown.
    var story = document.querySelector('tw-story');
    var homePassage = document.querySelector('tw-passage');
    if (story && homePassage && window.MutationObserver) {
      obs = new MutationObserver(function() {
        if (done) return;
        if (document.contains(homePassage)) return;  // still on the launch passage
        done = true; teardown();
      });
      obs.observe(story, { childList: true, subtree: true });
    }
  }
  window.dssShowMinigameRules = showRules;
})();

// ====== DEBUG / PLAYTESTING MENU (backtick ` key) ======
// Strategy: store target passage in URL hash, reload page.
// Before Harlowe boots, a separate inline script replaces the start passage
// content with a (go-to:) redirect to the target passage.
(function() {
var debugPanel = null;

function jumpTo(passageName) {
  // Store target in URL hash and reload — the early-boot script handles the rest
  window.location.hash = '#dss-debug-jump=' + encodeURIComponent(passageName);
  window.location.reload();
}

// -- Grouping rules ------------------------------------------------------
// A passage is assigned to exactly one group. Rules run in order; first match wins.
// Hub / core passages are listed by explicit name so they stay at the top.
var HUB_NAMES = {
  'Start':1,'Title':1,'Dawn':1,'The Interval':1,'The Night Ahead':1,
  'The Fetch':1,'Standing':1,'Dean Street':1,
  'A Doorway on Dean Street':1,'At the Corner of Dean Street and Greek Street':1
};
var OPENING_NAMES = {
  'The coast of Carthage':1,'Carthage shore':1,'Stay in Carthage':1,
  'Maritime interlude':1
};
var ENDING_NAMES = {
  'Alba Complete':1,'Alba Incomplete':1,
  'Name Your Book':1
};
var PHONECALL_NAMES = {
  'The phone call':1,'Lily phone call 1':1,'The dual ring':1,'Dido':1,
  'No more':1,'None of us likes it!':1,'Things turn up':1,
  'His round':1,'The Empty Glass':1,'The novelist':1
};
var DISPLAY_NAMES = {
  'Lily SVG':1,
  'Deco Divider':1,'LINE 1':1,'LINE 2':1,'LINE 2 Oxford':1,'LINE 3':1,
  'White page':1,'Black page':1
};
// Venue tag -> human label
var VENUE_LABELS = {
  'venue-french':'The French','venue-colony':'The Colony Room',
  'venue-coach':'The Coach & Horses','venue-ronnies':"Ronnie Scott's",
  'venue-trishas':"Trisha's",'venue-cecilcourt':'Cecil Court',
  'venue-cellar':'Cellar / Fight','venue-pillars':'Pillars of Hercules'
};
// Order groups appear in
var GROUP_ORDER = [
  'Hub','Opening','Approaches',
  'The French','The Colony Room','The Coach & Horses',
  'Pillars of Hercules',"Ronnie Scott's","Trisha's",
  'Cecil Court','Cellar / Fight',
  'Chinese Fish & Chips','Ping Pong',
  'Phone call / Dido','Endings','Displays & UI',
  'Other','Archive'
];
// Accent colour per group header (just for visual variety)
var GROUP_COLOURS = {
  'Hub':'#d4b050','Opening':'#9ab4c8','Approaches':'#b59866',
  'The French':'#c89a7a','The Colony Room':'#a85c5c',
  'The Coach & Horses':'#a67a4a','Pillars of Hercules':'#9a8a70',
  "Ronnie Scott's":'#a478b8',"Trisha's":'#b89a68',
  'Cecil Court':'#7aa67a','Cellar / Fight':'#8a5a5a',
  'Chinese Fish & Chips':'#c88a4a','Ping Pong':'#6aa4c8',
  'Phone call / Dido':'#88aaaa','Endings':'#d4a060',
  'Displays & UI':'#666','Other':'#888','Archive':'#555'
};

function classify(name, tags) {
  if (/^ARCHIVE-/.test(name)) return 'Archive';
  if (HUB_NAMES[name]) return 'Hub';
  if (OPENING_NAMES[name]) return 'Opening';
  if (ENDING_NAMES[name]) return 'Endings';
  if (PHONECALL_NAMES[name]) return 'Phone call / Dido';
  if (DISPLAY_NAMES[name]) return 'Displays & UI';
  if (/^Approach /i.test(name) || /Approach$/.test(name) || name === 'The Colony Room Door') return 'Approaches';
  if (/^PP /.test(name) || name === 'PP Pong' || name === 'Watch the decider') return 'Ping Pong';
  if (name === 'Chinese Fish and Chips') return 'Chinese Fish & Chips';
  // Tag-based
  for (var i = 0; i < tags.length; i++) {
    if (VENUE_LABELS[tags[i]]) return VENUE_LABELS[tags[i]];
  }
  // Fallback by name fragments
  if (/Pillars|Lackland|Maltese/i.test(name)) return 'Pillars of Hercules';
  if (/Jeffrey Bernard|Cow ride/i.test(name)) return 'The Coach & Horses';
  if (/Colony/i.test(name)) return 'The Colony Room';
  if (/Shana|Trisha/i.test(name)) return "Trisha's";
  if (/Ronnie|The Set|Bar Canvas/i.test(name)) return "Ronnie Scott's";
  if (/Cecil Court|Watkins|O'Flatterly|Rescue the page|Return the page/i.test(name)) return 'Cecil Court';
  if (/Fight|Beaten|Copper|Stand your ground|St\. John/i.test(name)) return 'Cellar / Fight';
  if (/French|Spanish Artist|Painter|Sketch|critic|novelist|agent|Artists/i.test(name)) return 'The French';
  return 'Other';
}

function createPanel() {
  if (debugPanel) { debugPanel.remove(); debugPanel = null; return; }
  var panel = document.createElement('div');
  panel.id = 'dss-debug';
  panel.style.cssText = 'position:fixed;top:0;right:0;width:360px;height:100vh;background:rgba(10,8,6,0.96);color:#c8b89a;font:13px/1.5 Georgia,serif;z-index:99999;overflow-y:auto;padding:16px;border-left:1px solid #3a2a1a;';

  var html = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;"><strong style="color:#ea7a7a;letter-spacing:0.1em;">DEBUG MENU</strong><span id="dss-debug-close" style="cursor:pointer;color:#666;font-size:18px;">&times;</span></div>';

  // Current passage
  var cur = document.querySelector('tw-passage[data-name]');
  var curName = cur ? cur.getAttribute('data-name') : '(unknown)';
  html += '<div style="margin-bottom:12px;padding:8px;background:rgba(255,255,255,0.05);border-radius:4px;"><small style="color:#888;">Current passage:</small><br><strong>' + curName + '</strong></div>';

  // Collect + classify
  var passages = document.querySelectorAll('tw-passagedata');
  var groups = {};
  for (var j = 0; j < passages.length; j++) {
    var n = passages[j].getAttribute('name');
    if (!n || n === 'UserScript' || n === 'UserStylesheet' || n === 'StoryTitle' || n === 'StoryData') continue;
    var tagAttr = passages[j].getAttribute('tags') || '';
    var tags = tagAttr.split(/\s+/).filter(Boolean);
    var group = classify(n, tags);
    if (!groups[group]) groups[group] = [];
    groups[group].push(n);
  }
  var totalShown = 0, totalArchive = (groups['Archive'] || []).length;
  for (var g in groups) { if (g !== 'Archive') totalShown += groups[g].length; }

  // Tools (esoteric layer + tests)
  html += '<div style="margin:8px 0 6px;"><strong style="color:#d4b050;">Tools</strong></div>';
  html += '<div id="dss-dbg-tool-complete" style="padding:6px 10px;margin:2px 0;background:rgba(245,208,112,0.14);border:1px solid rgba(245,208,112,0.40);border-radius:3px;cursor:pointer;font-size:12px;color:#f5d070;">✦ Complete all (haunts + lilies + alba + objects) — jump to ending</div>';
  html += '<div id="dss-dbg-tool-reveal-pent" style="padding:6px 10px;margin:2px 0;background:rgba(212,176,80,0.10);border:1px solid rgba(212,176,80,0.25);border-radius:3px;cursor:pointer;font-size:12px;">⛤ Set 5 lilies + reveal pentangle on map</div>';
  html += '<div id="dss-dbg-tool-matchbook" style="padding:6px 10px;margin:2px 0;background:rgba(212,176,80,0.10);border:1px solid rgba(212,176,80,0.25);border-radius:3px;cursor:pointer;font-size:12px;">🚬 Give matchbook (test Cigarettes menu)</div>';
  html += '<div id="dss-dbg-tool-wipe" style="padding:6px 10px;margin:2px 0;background:rgba(234,122,122,0.10);border:1px solid rgba(234,122,122,0.3);border-radius:3px;cursor:pointer;font-size:12px;color:#ea9a9a;">⌫ Wipe autosave (reload to fresh title)</div>';
  html += '<div id="dss-dbg-tool-pentangle" style="padding:6px 10px;margin:2px 0;background:rgba(212,176,80,0.05);border:1px solid rgba(212,176,80,0.15);border-radius:3px;cursor:pointer;font-size:11px;color:#aa9070;">(legacy small overlay — for visual debug only)</div>';

  // Controls
  html += '<div style="margin:14px 0 8px;"><strong style="color:#d4b050;">Jump to Passage</strong></div>';
  html += '<input id="dss-dbg-search" type="text" placeholder="Type to filter..." style="width:100%;box-sizing:border-box;padding:6px 8px;background:#1a1410;color:#c8b89a;border:1px solid #3a2a1a;border-radius:3px;font:12px Georgia,serif;margin-bottom:6px;">';
  html += '<label style="display:flex;align-items:center;gap:6px;font-size:11px;color:#888;margin-bottom:10px;cursor:pointer;user-select:none;">' +
          '<input type="checkbox" id="dss-dbg-archive" style="margin:0;"> show ' + totalArchive + ' archived passages</label>';
  html += '<div style="font-size:11px;color:#666;margin-bottom:8px;">' + totalShown + ' passages, grouped by venue</div>';

  html += '<div id="dss-dbg-passages">';
  for (var o = 0; o < GROUP_ORDER.length; o++) {
    var gname = GROUP_ORDER[o];
    var list = groups[gname];
    if (!list || !list.length) continue;
    list.sort();
    var colour = GROUP_COLOURS[gname] || '#888';
    var extraClass = (gname === 'Archive') ? ' dss-dbg-archive-grp' : '';
    html += '<div class="dss-dbg-grp' + extraClass + '" data-group="' + gname + '" style="margin-top:12px;">';
    html += '<div style="font:600 11px/1.4 Georgia,serif;letter-spacing:0.1em;text-transform:uppercase;color:' + colour + ';border-bottom:1px solid rgba(200,170,100,0.18);padding-bottom:3px;margin-bottom:4px;">' + gname + ' <span style="color:#555;font-weight:400;">(' + list.length + ')</span></div>';
    for (var k = 0; k < list.length; k++) {
      var displayName = list[k].replace(/^ARCHIVE-/, '');
      html += '<div class="dss-dbg-jump" data-passage="' + list[k].replace(/"/g, '&quot;') + '" style="padding:4px 8px;margin:1px 0;background:rgba(255,255,255,0.03);border-radius:2px;cursor:pointer;font-size:12px;">' + displayName + '</div>';
    }
    html += '</div>';
  }
  html += '</div>';

  panel.innerHTML = html;
  document.body.appendChild(panel);
  debugPanel = panel;

  document.getElementById('dss-debug-close').addEventListener('click', function() { panel.remove(); debugPanel = null; });

  // Tool buttons
  var toolReveal = document.getElementById('dss-dbg-tool-reveal-pent');
  if (toolReveal) toolReveal.addEventListener('click', function() {
    try {
      var s = Harlowe.API_ACCESS.STATE.variables;
      s.tookLily1 = true; s.tookLily2 = true; s.tookLily3 = true;
      s.tookLily4 = true; s.tookLily5 = true; s.lilyCount = 5;
      s.sawPentangle = false;
    } catch(e) {}
    panel.remove(); debugPanel = null;
    setTimeout(function() {
      if (window.dssRevealPentangleOnMap) window.dssRevealPentangleOnMap();
    }, 150);
  });
  var toolComplete = document.getElementById('dss-dbg-tool-complete');
  if (toolComplete) toolComplete.addEventListener('click', function() {
    jumpTo('DBG Complete');
  });
  var toolMatchbook = document.getElementById('dss-dbg-tool-matchbook');
  if (toolMatchbook) toolMatchbook.addEventListener('click', function() {
    jumpTo('DBG Matchbook');
  });
  var toolWipe = document.getElementById('dss-dbg-tool-wipe');
  if (toolWipe) toolWipe.addEventListener('click', function() {
    if (!confirm('Wipe the autosave and reload to a fresh title? You will lose your in-progress night.')) return;
    try {
      var keys = [];
      for (var i = 0; i < localStorage.length; i++) keys.push(localStorage.key(i));
      keys.forEach(function(k){ if (/Saved Game/.test(k)) localStorage.removeItem(k); });
    } catch(e) {}
    // Strip any debug-jump hash so reload truly goes to title.
    window.location.hash = '';
    window.location.reload();
  });
  var toolPent = document.getElementById('dss-dbg-tool-pentangle');
  if (toolPent) toolPent.addEventListener('click', function() {
    if (window.dssShowPentangleOverlay) window.dssShowPentangleOverlay();
  });

  // Archive toggle
  var archiveGrps = panel.querySelectorAll('.dss-dbg-archive-grp');
  for (var a = 0; a < archiveGrps.length; a++) archiveGrps[a].style.display = 'none';
  document.getElementById('dss-dbg-archive').addEventListener('change', function() {
    var show = this.checked;
    var els = panel.querySelectorAll('.dss-dbg-archive-grp');
    for (var i = 0; i < els.length; i++) els[i].style.display = show ? '' : 'none';
  });

  // Search filter — hides items and empty groups
  document.getElementById('dss-dbg-search').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    var grps = panel.querySelectorAll('.dss-dbg-grp');
    var showArchive = document.getElementById('dss-dbg-archive').checked;
    for (var i = 0; i < grps.length; i++) {
      var isArchive = grps[i].classList.contains('dss-dbg-archive-grp');
      if (isArchive && !showArchive) { grps[i].style.display = 'none'; continue; }
      var items = grps[i].querySelectorAll('.dss-dbg-jump');
      var any = false;
      for (var j = 0; j < items.length; j++) {
        var match = items[j].getAttribute('data-passage').toLowerCase().indexOf(q) >= 0;
        items[j].style.display = match ? '' : 'none';
        if (match) any = true;
      }
      grps[i].style.display = any ? '' : 'none';
    }
  });

  panel.addEventListener('click', function(e) {
    if (e.target.classList.contains('dss-dbg-jump')) {
      jumpTo(e.target.getAttribute('data-passage'));
    }
  });

  panel.addEventListener('mouseover', function(e) { if (e.target.classList.contains('dss-dbg-jump')) e.target.style.background = 'rgba(212,176,80,0.15)'; });
  panel.addEventListener('mouseout', function(e) { if (e.target.classList.contains('dss-dbg-jump')) e.target.style.background = 'rgba(255,255,255,0.03)'; });
}

document.addEventListener('keydown', function(e) {
  if (e.key === '`') { e.preventDefault(); createPanel(); }
});
})();

// ====== COIN FLIP POPUP (notebook) ======
window.showCoinModal = function(opts) {
  var mode = opts.mode || "free", max = opts.maxToss || (mode === "free" ? 3 : 1), tc = 0, cb = opts.onResult || function() {};
  var o = document.createElement("div");
  o.id = "coin-overlay";
  var h = '<div class="coin-overlay-box"><div class="coin-overlay-stage"><div class="coin-overlay-disc" id="cm-d"><div class="cp-face cp-heads"></div><div class="cp-face cp-tails"></div></div></div>';
  if (mode === "decide" && opts.label1) h += '<div class="coin-gate-labels"><div class="coin-gate-label cg-h">Heads: ' + opts.label1 + '</div><div class="coin-gate-label cg-t">Tails: ' + opts.label2 + '</div></div>';
  h += '<button class="coin-overlay-btn" id="cm-b">Toss it</button><span class="coin-overlay-result" id="cm-r"></span></div>';
  o.innerHTML = h;
  document.body.appendChild(o);
  var d = document.getElementById("cm-d"), r = document.getElementById("cm-r"), b = document.getElementById("cm-b"), st = o.querySelector(".coin-overlay-stage");
  b.addEventListener("click", function() {
    if (d.classList.contains("cp-flipping")) return;
    if (window.dssAudio) window.dssAudio.coinFlip();
    tc++;
    var heads = (opts.forceResult !== null && opts.forceResult !== undefined) ? opts.forceResult : (Math.floor(Math.random() * 2) === 0), ed = heads ? "1440deg" : "1620deg", rd = heads ? "0deg" : "180deg";
    d.style.setProperty("--cp-end", ed);
    d.classList.remove("cp-flipping");
    void d.offsetWidth;
    d.classList.add("cp-flipping");
    for (var i = 0; 12 > i; i++) {
      var s = document.createElement("div");
      s.className = "cp-spark";
      var a = Math.random() * 360, dist = 60 + Math.random() * 40;
      s.style.setProperty("--sx", (Math.cos(a * Math.PI / 180) * dist) + "px");
      s.style.setProperty("--sy", (Math.sin(a * Math.PI / 180) * dist) + "px");
      s.style.animationDelay = (Math.random() * 0.3) + "s";
      s.style.animationDuration = (0.5 + Math.random() * 0.5) + "s";
      st.appendChild(s);
      setTimeout(function(el) { el.remove(); }, 1200, s);
    }
    r.textContent = "";
    b.classList.add("coin-btn-hidden");
    setTimeout(function() {
      r.textContent = heads ? "Heads." : "Tails.";
      d.style.transform = "rotateX(" + rd + ")";
      d.classList.remove("cp-flipping");
      if (mode === "decide") {
        var hl = o.querySelector(".cg-h"), tl = o.querySelector(".cg-t");
        if (hl && tl) {
          if (heads) { hl.style.color = "#c8a86a"; tl.style.opacity = "0.3"; }
          else { tl.style.color = "#c8a86a"; hl.style.opacity = "0.3"; }
        }
        setTimeout(function() { o.classList.add("coin-overlay-fade"); setTimeout(function() { o.remove(); cb(heads); }, 800); }, 1800);
      } else if (tc >= max) {
        setTimeout(function() {
          var ni = document.querySelector('.nb-coin-img');
          if (ni) ni.src = heads ? '__DSS_COIN_HEADS_DATA_URI__' : '__DSS_COIN_TAILS_DATA_URI__';
          o.classList.add("coin-overlay-fade");
          setTimeout(function() { o.remove(); }, 800);
        }, 1800);
      } else {
        setTimeout(function() { r.textContent = ""; b.classList.remove("coin-btn-hidden"); b.textContent = "Toss again"; }, 2200);
      }
    }, 2000);
  });
  if (opts.autoToss) { b.classList.add("coin-btn-hidden"); b.click(); }
};

// Reset coinGateUsed each time a new passage renders,
// so the coin flip works on every passage that has one.
(new MutationObserver(function() { window.coinGateUsed = false; }))
  .observe(document.querySelector('tw-story') || document.body, { childList: true });

// Track which coin gate option was chosen, keyed by the two option texts.
// On a return visit, the coin will land on the option you DIDN'T pick last time.
if (!window._coinGateHistory) window._coinGateHistory = {};

window.coinGate = function(t1, t2, firstAlwaysHeads) {
  if (window.coinGateUsed) return;
  var links = document.querySelectorAll("tw-link"), l1 = null, l2 = null;
  for (var i = 0; links.length > i; i++) {
    var t = links[i].textContent.trim();
    if (t === t1 && !l1) l1 = links[i];
    if (t === t2 && !l2) l2 = links[i];
  }
  if (!l1 || !l2) return;
  l1.style.pointerEvents = "none"; l1.classList.add("coin-gated");
  l2.style.pointerEvents = "none"; l2.classList.add("coin-gated");
  var w = document.createElement("div");
  w.className = "coin-gate-wrap";
  w.innerHTML = '<div class="coin-gate-hint">The Donkey will decide.</div><button class="coin-gate-btn">Toss the Donkey</button>';
  var p = l2.closest("tw-expression") || l2.parentElement;
  if (p && p.parentElement) p.parentElement.insertBefore(w, p.nextSibling);
  var historyKey = t1 + '|||' + t2;
  w.querySelector(".coin-gate-btn").addEventListener("click", function() {
    // Check if we've been here before — if so, force the other option.
    // If firstAlwaysHeads is true and we have no history yet, force heads
    // (i.e. always pick t1 the first time at this gate).
    var lastPick = window._coinGateHistory[historyKey];
    var forceHeads = null;
    if (lastPick === 'heads') forceHeads = false;  // last time was heads (t1), now force tails (t2)
    else if (lastPick === 'tails') forceHeads = true; // last time was tails (t2), now force heads (t1)
    else if (firstAlwaysHeads) forceHeads = true;     // first toss at this gate — rig to t1
    window.showCoinModal({ mode: "decide", label1: t1, label2: t2, autoToss: true, forceResult: forceHeads, onResult: function(isH) {
      window.coinGateUsed = true;
      window._coinGateHistory[historyKey] = isH ? 'heads' : 'tails';
      var c = isH ? l1 : l2;
      c.style.pointerEvents = ""; c.classList.remove("coin-gated"); c.click();
    }});
  });
};

window.flipCoinPopup = function() {
  window.showCoinModal({ mode: "free", maxToss: 1, autoToss: true });
};

// ====== SWALLOW SHELLEY'S LIVER (notebook button) ======
window.eatLiver = function() {
  /* Close any liver inspect popup if open */
  var lp = document.getElementById('liver-popup-overlay');
  if (lp) lp.remove();
  /* Close the notebook dialog properly via Harlowe's own close link.
     The notebook is created by (dialog:), and its close target is
     tw-dialog-links tw-link — clicking that lets Harlowe end the dialog
     cleanly so the engine will accept a subsequent goToPassage call. */
  var closeLink = document.querySelector('tw-dialog-links tw-link');
  if (closeLink) closeLink.click();
  /* Two-stage retry: 60ms is sometimes too short for the (dialog:) tear-down
     to release Harlowe's render lock, leaving Engine.go a no-op and the
     player marooned with the notebook gone but no passage transition.
     Fire at 80ms; if we don't see "Eat Shelleys Liver" on tw-passage by
     320ms, retry once. */
  var TARGET = 'Eat Shelleys Liver';
  function jump(){
    if (window.Engine && Engine.goToPassage) { Engine.goToPassage(TARGET); return; }
    if (window.Engine && Engine.go) { Engine.go(TARGET); return; }
  }
  setTimeout(function(){
    jump();
    setTimeout(function(){
      var p = document.querySelector('tw-passage');
      var pn = p && p.getAttribute('data-name');
      if (pn !== TARGET) jump();
    }, 240);
  }, 80);
};

// ====== SHELLEY'S LIVER POPUP (notebook) ======
window.liverPopup = function() {
  var old = document.getElementById('liver-popup-overlay');
  if (old) old.remove();
  var overlay = document.createElement('div');
  overlay.id = 'liver-popup-overlay';
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(8,6,4,0.78);display:flex;align-items:center;justify-content:center;z-index:19999;';
  overlay.innerHTML =
    '<div class="liver-popup-box">' +
      '<div class="liver-popup-title">SHELLEY\'S LIVER</div>' +
      '<div class="liver-popup-stage">' +
        '<svg viewBox="0 0 120 240" width="120" height="240" xmlns="http://www.w3.org/2000/svg">' +
          '<defs>' +
            '<linearGradient id="lpGlass" x1="0" y1="0" x2="1" y2="0">' +
              '<stop offset="0%" stop-color="rgba(180,160,130,0.18)"/>' +
              '<stop offset="28%" stop-color="rgba(220,210,190,0.34)"/>' +
              '<stop offset="68%" stop-color="rgba(200,185,155,0.14)"/>' +
              '<stop offset="100%" stop-color="rgba(150,135,110,0.22)"/>' +
            '</linearGradient>' +
            '<linearGradient id="lpLiq" x1="0" y1="0" x2="0" y2="1">' +
              '<stop offset="0%" stop-color="rgba(145,52,14,0.80)"/>' +
              '<stop offset="100%" stop-color="rgba(80,20,4,0.92)"/>' +
            '</linearGradient>' +
            '<radialGradient id="lpGlow" cx="50%" cy="50%" r="50%">' +
              '<stop offset="0%" stop-color="rgba(180,80,20,0.18)"/>' +
              '<stop offset="100%" stop-color="rgba(140,40,10,0)"/>' +
            '</radialGradient>' +
          '</defs>' +
          '<ellipse cx="60" cy="120" rx="38" ry="100" fill="url(#lpGlow)"/>' +
          '<rect x="42" y="12" width="36" height="14" rx="4" fill="rgba(160,140,110,0.42)" stroke="rgba(130,110,80,0.65)" stroke-width="1.5"/>' +
          '<rect x="46" y="8" width="28" height="8" rx="3" fill="rgba(190,170,140,0.55)" stroke="rgba(150,130,100,0.55)" stroke-width="1.2"/>' +
          '<path d="M38 26 L28 60 L28 210 Q28 222 40 224 L80 224 Q92 222 92 210 L92 60 L82 26 Z" fill="url(#lpGlass)" stroke="rgba(160,140,110,0.58)" stroke-width="1.8"/>' +
          '<path d="M30 128 L30 210 Q30 221 40 223 L80 223 Q90 221 90 210 L90 128 Z" fill="url(#lpLiq)" opacity="0.86"/>' +
          '<ellipse cx="60" cy="128" rx="30" ry="5.5" fill="rgba(165,60,18,0.38)"/>' +
          '<path d="M38 65 Q39 175 39 210" fill="none" stroke="rgba(230,220,200,0.30)" stroke-width="3.5" stroke-linecap="round"/>' +
          '<path d="M48 62 Q49 120 49 155" fill="none" stroke="rgba(230,220,200,0.16)" stroke-width="1.8" stroke-linecap="round"/>' +
          '<ellipse cx="60" cy="210" rx="29" ry="4" fill="rgba(60,12,2,0.38)"/>' +
        '</svg>' +
      '</div>' +
      '<div class="liver-popup-desc">A glass vial. The contents catch the light — dark amber, faintly luminous. The antiquarian said to swallow it near the end.</div>' +
      '<button class="liver-popup-close" id="liver-popup-close">&#10005;</button>' +
    '</div>';
  document.body.appendChild(overlay);
  overlay.addEventListener('click', function(e) { if (e.target === overlay) overlay.remove(); });
  document.getElementById('liver-popup-close').addEventListener('click', function() { overlay.remove(); });
};

// ====== VENUE HINT POPUP ======
window.venueHintPopup = function() {
  var old = document.getElementById('venue-hint-overlay');
  if (old) return;
  var overlay = document.createElement('div');
  overlay.id = 'venue-hint-overlay';
  /* Start invisible — fade-in and fade-out are both driven through this
     opacity transition so the cadence is uniform with the other
     wordToTheWisePopup. Inner box uses wtw-no-enter to disable its
     own per-element vhEnter animation. */
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(4,3,8,0.85);display:flex;align-items:center;justify-content:center;z-index:19999;opacity:0;transition:opacity 0.55s ease;';
  overlay.innerHTML =
    '<div class="venue-hint-box wtw-no-enter">' +
      '<div class="vh-mist vh-mist1"></div>' +
      '<div class="vh-mist vh-mist2"></div>' +
      '<div class="vh-mist vh-mist3"></div>' +
      '<div class="vh-label">⟡ A WORD TO THE WISE ⟡</div>' +
      '<div class="venue-hint-text">If a venue is still open it means there is more to explore there. Have another look.</div>' +
      '<div class="vh-legend">' +
        '<div class="vh-legend-row"><span class="hp hp-done">◆</span> a haunt &nbsp;·&nbsp; <span class="hp">◇</span> still to catch</div>' +
        '<div class="vh-legend-row"><span class="pp pp-done">▲</span> a word &nbsp;·&nbsp; <span class="pp">△</span> still to learn</div>' +
        '<div class="vh-legend-row"><span class="al al-done">✦</span> an alba line &nbsp;·&nbsp; <span class="al">✧</span> still to find</div>' +
        '<div class="vh-legend-row"><span class="qp qp-done">★</span> a quest &nbsp;·&nbsp; <span class="qp">☆</span> still to do</div>' +
      '</div>' +
    '</div>';
  document.body.appendChild(overlay);
  void overlay.offsetWidth;
  overlay.style.opacity = '1';
  var dismissed = false;
  function dismiss(){
    if (dismissed) return;
    dismissed = true;
    overlay.style.opacity = '0';
    document.removeEventListener('keydown', onKey);
    setTimeout(function(){ if (overlay.parentNode) overlay.remove(); }, 600);
  }
  function onKey(e){ if (e.key === 'Escape') dismiss(); }
  overlay.addEventListener('click', dismiss);
  document.addEventListener('keydown', onKey);
  /* Slightly longer visible window — the legend takes a beat more to read. */
  setTimeout(dismiss, 5500);
};

// ====== MORALE WARNING POPUP ======
window.moraleWarningPopup = function(conf, sobr) {
  var old = document.getElementById('morale-warn-overlay');
  if (old) return;
  var msg = '';
  if (conf < 30 && sobr < 30) msg = 'You\u2019re in a bad way. Get some grub, find a doorway, catch your breath.';
  else if (conf < 40) msg = 'Your confidence is slipping. Find somewhere to gather yourself.';
  else if (sobr < 40) msg = 'You should have gone to the gents earlier.';
  else return; // not low enough to warn
  var overlay = document.createElement('div');
  overlay.id = 'morale-warn-overlay';
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(4,3,8,0.85);display:flex;align-items:center;justify-content:center;z-index:19999;opacity:0;transition:opacity 0.55s ease;';
  overlay.innerHTML =
    '<div class="venue-hint-box wtw-no-enter">' +
      '<div class="vh-mist vh-mist1"></div>' +
      '<div class="vh-mist vh-mist2"></div>' +
      '<div class="vh-mist vh-mist3"></div>' +
      '<div class="vh-label">⟡ A WORD TO THE WISE ⟡</div>' +
      '<div class="venue-hint-text">' + msg + '</div>' +
    '</div>';
  document.body.appendChild(overlay);
  void overlay.offsetWidth;
  overlay.style.opacity = '1';
  var dismissed = false;
  function dismiss(){
    if (dismissed) return;
    dismissed = true;
    overlay.style.opacity = '0';
    document.removeEventListener('keydown', onKey);
    setTimeout(function(){ if (overlay.parentNode) overlay.remove(); }, 600);
  }
  function onKey(e){ if (e.key === 'Escape') dismiss(); }
  overlay.addEventListener('click', dismiss);
  document.addEventListener('keydown', onKey);
  setTimeout(dismiss, 3500);
};

// ====== CIGARETTE POPUP — hold-to-light ======
// Small antiquarian modal — one short message and a dismiss. Fired when a
// mechanic comes online (e.g. matchbook found → cigarettes are usable) and
// the player needs a one-line nudge they can ignore on replays. Esc / click
// outside / X all dismiss.
window.showWordToTheWise = function(opts) {
  if (document.getElementById('word-wise-overlay')) return;
  opts = opts || {};
  var title = opts.title || 'A word to the wise';
  var body = opts.body || '';
  var overlay = document.createElement('div');
  overlay.id = 'word-wise-overlay';
  overlay.innerHTML = '<div class="word-wise-box">' +
    '<button class="word-wise-close" type="button" aria-label="dismiss">&times;</button>' +
    '<div class="word-wise-title">' + title + '</div>' +
    '<div class="word-wise-body">' + body + '</div>' +
    '</div>';
  document.body.appendChild(overlay);
  function dismiss() {
    if (!overlay.parentNode) return;
    overlay.classList.add('word-wise-leaving');
    setTimeout(function() {
      if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
    }, 280);
    document.removeEventListener('keydown', onKey);
  }
  function onKey(e) { if (e.key === 'Escape' || e.key === 'Enter') dismiss(); }
  document.addEventListener('keydown', onKey);
  overlay.querySelector('.word-wise-close').addEventListener('click', dismiss);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) dismiss();
  });
};

// Atmospheric tactile beat in the family of hold-to-drink and the donkey
// coin: an overlay with a match head and an unlit cigarette. Press and
// hold — the match strikes, the flame catches, the cig lights. Release
// before the catch and the match goes out. Calls the optional onLit
// callback when the cigarette is lit, then auto-dismisses after a beat.
window.showCigarettePopup = function(onLit) {
  if (document.getElementById('cig-overlay')) return;
  var overlay = document.createElement('div');
  overlay.id = 'cig-overlay';
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(4,3,8,0.78);display:flex;align-items:center;justify-content:center;z-index:19999;cursor:pointer;user-select:none;-webkit-user-select:none;';

  // Box: cigarette + match drawn together as inline SVG. Match flame
  // grows as the player holds; cigarette tip lights once held long enough.
  overlay.innerHTML =
    '<div class="cig-box">' +
      '<div class="cig-instructions">Light a cigarette.</div>' +
      '<div class="cig-stage">' +
        '<svg class="cig-svg" viewBox="0 0 280 110" xmlns="http://www.w3.org/2000/svg">' +
          '<defs>' +
            '<radialGradient id="cigEmber" cx="50%" cy="50%" r="50%">' +
              '<stop offset="0%" stop-color="#fff5b8" stop-opacity="1"/>' +
              '<stop offset="40%" stop-color="#ff9020" stop-opacity="0.85"/>' +
              '<stop offset="100%" stop-color="#a03408" stop-opacity="0"/>' +
            '</radialGradient>' +
            '<radialGradient id="cigFlame" cx="50%" cy="65%" r="55%">' +
              '<stop offset="0%" stop-color="#fff8c0" stop-opacity="1"/>' +
              '<stop offset="35%" stop-color="#ffba48" stop-opacity="0.85"/>' +
              '<stop offset="80%" stop-color="#c84810" stop-opacity="0.4"/>' +
              '<stop offset="100%" stop-color="#c84810" stop-opacity="0"/>' +
            '</radialGradient>' +
          '</defs>' +
          // Cigarette body — paper white, with brown filter on right end.
          '<rect class="cig-paper" x="22" y="62" width="158" height="13" rx="2" fill="#f4ede0" stroke="rgba(60,40,20,0.4)" stroke-width="0.6"/>' +
          '<rect class="cig-filter" x="180" y="62" width="36" height="13" rx="2" fill="#b8945c" stroke="rgba(60,40,20,0.4)" stroke-width="0.6"/>' +
          '<line x1="180" y1="62" x2="180" y2="75" stroke="rgba(60,40,20,0.6)" stroke-width="0.6"/>' +
          // Cigarette ember (initially hidden, shown when lit)
          '<circle class="cig-ember" cx="22" cy="68.5" r="0" fill="url(#cigEmber)"/>' +
          // Match — simple wooden stick + red head, positioned to touch the cig tip
          '<rect class="cig-matchstick" x="58" y="32" width="34" height="2.4" rx="0.6" fill="#7a4a22" transform="rotate(28 75 33)"/>' +
          '<ellipse class="cig-matchhead" cx="58" cy="48" rx="3.2" ry="3.6" fill="#a83020"/>' +
          // Match flame (animates on hold)
          '<g class="cig-flame" opacity="0">' +
            '<ellipse cx="58" cy="40" rx="6" ry="11" fill="url(#cigFlame)"/>' +
            '<ellipse cx="58" cy="42" rx="3" ry="6" fill="#fff8c0" opacity="0.85"/>' +
          '</g>' +
        '</svg>' +
      '</div>' +
      '<div class="cig-hint">Press and hold.</div>' +
    '</div>';
  document.body.appendChild(overlay);

  var box = overlay.querySelector('.cig-box');
  var flame = overlay.querySelector('.cig-flame');
  var ember = overlay.querySelector('.cig-ember');
  var hint = overlay.querySelector('.cig-hint');
  var holdStart = 0;
  var lit = false;
  var dismissed = false;
  var rafId = null;
  var matchAudioFired = false;
  var LIGHT_MS = 1500; // hold duration to light

  function dismiss() {
    if (dismissed) return;
    dismissed = true;
    if (rafId) cancelAnimationFrame(rafId);
    if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
    document.removeEventListener('keydown', onKey);
    if (typeof onLit === 'function') {
      try { onLit(lit); } catch(e) {}
    }
  }

  function onKey(e){ if (e.key === 'Escape') dismiss(); }
  document.addEventListener('keydown', onKey);

  function tick() {
    if (dismissed) return;
    if (!holdStart) { rafId = requestAnimationFrame(tick); return; }
    var elapsed = Date.now() - holdStart;
    var t = Math.min(1, elapsed / LIGHT_MS);
    flame.setAttribute('opacity', String(t.toFixed(2)));
    if (t >= 1 && !lit) {
      lit = true;
      ember.setAttribute('r', '5.5');
      ember.setAttribute('fill', 'url(#cigEmber)');
      hint.textContent = 'Lit. Take a draw.';
      // Brief afterglow then dismiss
      setTimeout(function(){
        // Fade out the flame (match goes out, cig stays lit)
        flame.style.transition = 'opacity 0.6s ease-out';
        flame.setAttribute('opacity', '0');
        setTimeout(dismiss, 1400);
      }, 700);
    }
    rafId = requestAnimationFrame(tick);
  }

  function startHold(e) {
    if (lit || dismissed) return;
    if (e) e.preventDefault();
    holdStart = Date.now();
    if (!matchAudioFired && window.dssAudio && window.dssAudio.matchStrike) {
      window.dssAudio.matchStrike();
      matchAudioFired = true;
    }
    if (!rafId) tick();
  }
  function stopHold() {
    if (lit || dismissed) return;
    holdStart = 0;
    flame.setAttribute('opacity', '0');
    matchAudioFired = false; // allow another strike on next hold
  }
  // Don't trigger on overlay clicks — only on the box / svg
  box.addEventListener('mousedown', startHold);
  box.addEventListener('touchstart', startHold, { passive: false });
  document.addEventListener('mouseup', stopHold);
  document.addEventListener('touchend', stopHold);
  // Click outside the box dismisses (giving up)
  overlay.addEventListener('click', function(e){
    if (e.target === overlay) dismiss();
  });
};

// ====== SIDE-OF-SCREEN BURNING CIGARETTE ======
// Spawns a small vertical cigarette in the lower-right of the viewport.
// Ember pulses, smoke wisps drift up, the paper slowly shortens to the
// filter as it burns. Lives on document.body so it persists across passage
// transitions — game continues to play while you smoke. Lighting another
// while one is burning replaces the previous one.
window.startBurningCigarette = function(opts) {
  opts = opts || {};
  var BURN_MS = opts.durationMs || 90000;
  var existing = document.getElementById('side-cig');
  if (existing && existing.parentNode) existing.parentNode.removeChild(existing);
  var sc = document.createElement('div');
  sc.id = 'side-cig';
  sc.innerHTML =
    '<div class="side-cig-stick" id="side-cig-stick">' +
      '<div class="side-cig-paper">' +
        '<div class="side-cig-ash"></div>' +
        '<svg class="side-cig-ember" viewBox="0 0 28 14" preserveAspectRatio="none" aria-hidden="true">' +
          '<defs>' +
            '<radialGradient id="scEmberCore" cx="50%" cy="55%" r="55%">' +
              '<stop offset="0%" stop-color="#fff5b8"/>' +
              '<stop offset="32%" stop-color="#ffba48"/>' +
              '<stop offset="72%" stop-color="#ff5818"/>' +
              '<stop offset="100%" stop-color="#a02808"/>' +
            '</radialGradient>' +
          '</defs>' +
          '<ellipse cx="14" cy="8" rx="13" ry="5.6" fill="#1a0a04"/>' +
          '<ellipse cx="14" cy="7.2" rx="11.8" ry="4.6" fill="url(#scEmberCore)"/>' +
          '<ellipse cx="11.5" cy="6.6" rx="2.6" ry="1.3" fill="#fff5b8" opacity="0.7"/>' +
          '<ellipse cx="16.5" cy="7.3" rx="1.8" ry="1" fill="#fff5b8" opacity="0.5"/>' +
        '</svg>' +
      '</div>' +
      '<div class="side-cig-filter"></div>' +
      '<div class="side-cig-puffs" id="side-cig-puffs"></div>' +
    '</div>';
  document.body.appendChild(sc);
  var START_H = 130, END_H = 38;
  var startTime = Date.now();
  var stick = document.getElementById('side-cig-stick');
  stick.style.height = START_H + 'px';
  var ember = sc.querySelector('.side-cig-ember');
  // Schedule irregular inhale/exhale puffs. Each "drag" brightens the ember
  // (oxygen flooding the cherry) for a beat, then a cluster of smoke wisps
  // rises from the filter end as the player exhales.
  var puffTimer = null;
  function spawnPuff() {
    var puffsHost = document.getElementById('side-cig-puffs');
    if (!puffsHost) return;
    var count = 3 + Math.floor(Math.random() * 2); // 3 or 4 wisps per puff
    for (var i = 0; i < count; i++) {
      (function(idx){
        setTimeout(function(){
          var w = document.createElement('div');
          w.className = 'cig-puff-wisp';
          var dx = (Math.random() * 56 - 32);          // sideways drift
          var sz = 34 + Math.random() * 22;            // start size
          var endScale = 4 + Math.random() * 2;        // dispersion
          w.style.width = sz + 'px';
          w.style.height = sz + 'px';
          w.style.left = (idx * 6 - 8 + Math.random() * 12) + 'px';
          w.style.setProperty('--drift-x', dx + 'px');
          w.style.setProperty('--scale-end', endScale);
          puffsHost.appendChild(w);
          setTimeout(function(){ if (w.parentNode) w.parentNode.removeChild(w); }, 8200);
        }, idx * 160 + Math.random() * 90);
      })(i);
    }
  }
  function scheduleNextPuff() {
    var delay = 8000 + Math.random() * 8000; // 8–16s between drags
    puffTimer = setTimeout(function(){
      if (!document.body.contains(sc)) return;
      // The inhale — ember brightens (the "draw") for a beat before the
      // exhaled smoke appears, so the cherry visibly glows brighter as the
      // cigarette burns down a little.
      if (ember) ember.classList.add('side-cig-ember-drag');
      setTimeout(function(){
        if (ember) ember.classList.remove('side-cig-ember-drag');
      }, 1800);
      setTimeout(spawnPuff, 1500);
      scheduleNextPuff();
    }, delay);
  }
  // First drag comes fairly soon after lighting.
  setTimeout(function(){
    if (!document.body.contains(sc)) return;
    if (ember) ember.classList.add('side-cig-ember-drag');
    setTimeout(function(){ if (ember) ember.classList.remove('side-cig-ember-drag'); }, 1200);
    setTimeout(spawnPuff, 1050);
    scheduleNextPuff();
  }, 2000 + Math.random() * 1500);
  function tick() {
    if (!document.body.contains(sc)) {
      if (puffTimer) clearTimeout(puffTimer);
      return;
    }
    var elapsed = Date.now() - startTime;
    var t = Math.min(1, elapsed / BURN_MS);
    stick.style.height = (START_H + (END_H - START_H) * t) + 'px';
    if (t >= 1) {
      if (puffTimer) clearTimeout(puffTimer);
      // Dropped. The stub tips forward and falls off the bottom of the
      // viewport — the player has flicked away the spent cigarette.
      sc.classList.add('side-cig-dropping');
      setTimeout(function(){ if (sc.parentNode) sc.parentNode.removeChild(sc); }, 1800);
      return;
    }
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
};

// ====== NAPKIN PORTRAIT — KEEP WORKING ON IT ======
// Player drew Benito on a napkin at The French. After leaving, the
// notebook entry offers a "Work on it" button that reopens the drawing
// canvas as a popup — load the saved PNG as the starting state, add
// more strokes, save back. Lets the player return to the only thing
// they've made tonight, over and over.
window.showNapkinPopup = function() {
  if (document.getElementById('napkin-popup-overlay')) return;

  var overlay = document.createElement('div');
  overlay.id = 'napkin-popup-overlay';
  // z-index 999999 keeps the popup ABOVE the notebook dialog (and its
  // close button at 100000), so the canvas is what the player sees as
  // soon as they click "Work on it" — no need to close the notebook first.
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(4,3,8,0.85);display:flex;align-items:center;justify-content:center;z-index:999999;flex-direction:column;';
  // Stop click bubbling so the notebook's outside-click-to-close handler
  // can't fire when the player is drawing/clicking inside the popup.
  overlay.addEventListener('click', function(e) { e.stopPropagation(); });
  overlay.addEventListener('mousedown', function(e) { e.stopPropagation(); });
  overlay.addEventListener('touchstart', function(e) { e.stopPropagation(); }, { passive: true });

  overlay.innerHTML =
    '<div class="napkin-popup-box">' +
      '<canvas class="napkin-canvas" id="napkin-popup-canvas" width="400" height="480"></canvas>' +
      '<div class="napkin-tools">' +
        '<div class="napkin-tools-row">' +
          '<div class="napkin-color active" data-color="#111111" style="background:#111111" title="Black"></div>' +
          '<div class="napkin-color" data-color="#1e4fd6" style="background:#1e4fd6" title="Blue"></div>' +
          '<div class="napkin-color" data-color="#d81f1f" style="background:#d81f1f" title="Red"></div>' +
          '<div class="napkin-color" data-color="#f5c518" style="background:#f5c518" title="Yellow"></div>' +
          '<div class="napkin-color" data-color="#2aa14a" style="background:#2aa14a" title="Green"></div>' +
          '<div class="napkin-color napkin-erase" data-color="#f2e7c9" title="Eraser">×</div>' +
        '</div>' +
        '<div class="napkin-tools-row">' +
          '<div class="napkin-size napkin-size-thin active" data-size="thin" title="Thin line"></div>' +
          '<div class="napkin-size napkin-size-thick" data-size="thick" title="Thick line"></div>' +
          '<button class="napkin-btn" id="napkin-popup-undo" disabled>Undo</button>' +
          '<button class="napkin-btn" id="napkin-popup-done">Done</button>' +
          '<button class="napkin-btn napkin-popup-close" id="napkin-popup-cancel">×</button>' +
        '</div>' +
      '</div>' +
    '</div>';
  document.body.appendChild(overlay);

  var canvas = document.getElementById('napkin-popup-canvas');
  var ctx = canvas.getContext('2d');
  var W = canvas.width, H = canvas.height;
  var color = '#111111';
  var brushSize = 3.2;
  var drawing = false;
  var lastX = 0, lastY = 0;
  /* Stroke stack for THIS session only — undo can roll back the
     strokes added since the popup opened, but not the saved PNG
     underneath (those strokes are now part of the loaded image). */
  var strokes = [];
  var currentStroke = null;
  var baseImage = null;       // the loaded saved napkin as Image
  var baseImageReady = false;

  function paintBase() {
    if (baseImage && baseImageReady) {
      ctx.drawImage(baseImage, 0, 0, W, H);
    } else {
      // Fresh napkin if no saved data (shouldn't happen, but safe).
      ctx.fillStyle = '#f2e7c9';
      ctx.fillRect(0, 0, W, H);
    }
  }
  function replayStrokes() {
    strokes.forEach(function(s){
      if (!s.points || s.points.length === 0) return;
      var w = s.width || 3.2;
      ctx.strokeStyle = s.color;
      ctx.fillStyle = s.color;
      ctx.lineWidth = w;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      if (s.points.length === 1) {
        ctx.beginPath();
        ctx.arc(s.points[0].x, s.points[0].y, Math.max(w / 2, 1), 0, Math.PI * 2);
        ctx.fill();
        return;
      }
      ctx.beginPath();
      ctx.moveTo(s.points[0].x, s.points[0].y);
      for (var i = 1; i < s.points.length; i++) {
        ctx.lineTo(s.points[i].x, s.points[i].y);
      }
      ctx.stroke();
    });
  }
  function updateButtons() {
    var undo = document.getElementById('napkin-popup-undo');
    if (strokes.length > 0) undo.removeAttribute('disabled');
    else undo.setAttribute('disabled', '');
  }
  function getPos(e) {
    var rect = canvas.getBoundingClientRect();
    var sx = canvas.width / rect.width, sy = canvas.height / rect.height;
    var cx, cy;
    if (e.touches && e.touches[0]) { cx = e.touches[0].clientX; cy = e.touches[0].clientY; }
    else { cx = e.clientX; cy = e.clientY; }
    return { x: (cx - rect.left) * sx, y: (cy - rect.top) * sy };
  }
  function startDraw(e) {
    e.preventDefault();
    drawing = true;
    var p = getPos(e);
    lastX = p.x; lastY = p.y;
    currentStroke = { color: color, width: brushSize, points: [{x: p.x, y: p.y}] };
    strokes.push(currentStroke);
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.arc(lastX, lastY, Math.max(brushSize / 2, 1), 0, Math.PI * 2);
    ctx.fill();
    updateButtons();
  }
  function draw(e) {
    if (!drawing) return;
    e.preventDefault();
    var p = getPos(e);
    ctx.strokeStyle = color;
    ctx.lineWidth = brushSize;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    lastX = p.x; lastY = p.y;
    if (currentStroke) currentStroke.points.push({x: p.x, y: p.y});
  }
  function stopDraw() { drawing = false; currentStroke = null; }

  canvas.addEventListener('mousedown', startDraw);
  canvas.addEventListener('mousemove', draw);
  canvas.addEventListener('mouseup', stopDraw);
  canvas.addEventListener('mouseleave', stopDraw);
  canvas.addEventListener('touchstart', startDraw, { passive: false });
  canvas.addEventListener('touchmove', draw, { passive: false });
  canvas.addEventListener('touchend', stopDraw);

  overlay.querySelectorAll('.napkin-color').forEach(function(btn) {
    btn.addEventListener('click', function() {
      overlay.querySelectorAll('.napkin-color').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      color = btn.getAttribute('data-color');
    });
  });
  overlay.querySelectorAll('.napkin-size').forEach(function(btn) {
    btn.addEventListener('click', function() {
      overlay.querySelectorAll('.napkin-size').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      brushSize = (btn.getAttribute('data-size') === 'thick') ? 7 : 3.2;
    });
  });
  document.getElementById('napkin-popup-undo').addEventListener('click', function() {
    if (strokes.length === 0) return;
    strokes.pop();
    paintBase();
    replayStrokes();
    updateButtons();
  });
  function close() {
    if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
  }
  document.getElementById('napkin-popup-cancel').addEventListener('click', close);
  document.getElementById('napkin-popup-done').addEventListener('click', function() {
    // Flatten current canvas state into the saved napkin so subsequent
    // sessions build on it.
    try { localStorage.setItem('dss_napkin', canvas.toDataURL('image/png')); } catch(e) {}
    // Update any visible nb-napkin-img elements so the notebook
    // immediately reflects the change.
    var imgs = document.querySelectorAll('.nb-napkin-img');
    imgs.forEach(function(img){ img.setAttribute('src', canvas.toDataURL('image/png')); });
    if (window.dssAudio && window.dssAudio.cameraShutter) {
      try { window.dssAudio.cameraShutter(); } catch(e) {}
    }
    close();
  });

  // Load the existing saved napkin (if any) as the canvas starting state.
  var saved = null;
  try { saved = localStorage.getItem('dss_napkin'); } catch(e) {}
  if (saved) {
    baseImage = new Image();
    baseImage.onload = function() {
      baseImageReady = true;
      paintBase();
    };
    baseImage.src = saved;
  } else {
    // Fresh napkin background as fallback
    ctx.fillStyle = '#f2e7c9';
    ctx.fillRect(0, 0, W, H);
    for (var i = 0; i < 2200; i++) {
      var x = Math.random() * W, y = Math.random() * H;
      ctx.fillStyle = 'rgba(170,140,80,' + (Math.random() * 0.05) + ')';
      ctx.fillRect(x, y, 1, 1);
    }
  }
};

// ====== GENERIC WORD-TO-THE-WISE POPUP ======
// Used by Dean Street's various morale / chippy hints. Twee-side gating
// flags ($shownLowConf etc.) ensure each unique message only triggers once
// per playthrough — the modal grabs attention, then dismisses on click or
// Escape, leaving the underlying action links available on the page.
window.wordToTheWisePopup = function(message) {
  if (document.getElementById('wtw-overlay')) return;
  var overlay = document.createElement('div');
  overlay.id = 'wtw-overlay';
  /* Start invisible so we can drive BOTH fade-in and fade-out through the
     overlay opacity, identical curves either way. Inner box previously had
     its own vhEnter animation which made fade-in feel different to fade-out;
     the wtw-no-enter class neutralises it. */
  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(4,3,8,0.85);display:flex;align-items:center;justify-content:center;z-index:19999;opacity:0;transition:opacity 0.55s ease;';
  overlay.innerHTML =
    '<div class="venue-hint-box wtw-no-enter">' +
      '<div class="vh-mist vh-mist1"></div>' +
      '<div class="vh-mist vh-mist2"></div>' +
      '<div class="vh-mist vh-mist3"></div>' +
      '<div class="vh-label">⟡ A WORD TO THE WISE ⟡</div>' +
      '<div class="venue-hint-text">' + message + '</div>' +
    '</div>';
  document.body.appendChild(overlay);
  /* Force a layout flush, then transition to opacity 1 so the browser
     animates rather than snapping. */
  void overlay.offsetWidth;
  overlay.style.opacity = '1';
  var dismissed = false;
  function dismiss(){
    if (dismissed) return;
    dismissed = true;
    overlay.style.opacity = '0';
    document.removeEventListener('keydown', onKey);
    setTimeout(function(){ if (overlay.parentNode) overlay.remove(); }, 600);
  }
  function onKey(e){ if (e.key === 'Escape') dismiss(); }
  overlay.addEventListener('click', dismiss);
  document.addEventListener('keydown', onKey);
  /* Total visible window: 0.55s fade in + ~3s readable + 0.55s fade out. */
  setTimeout(dismiss, 3500);
};

// ====== STAT HEAL ANIMATION ======
// Call with gains object: { confidence: n, sobriety: n }
// Shows a brief overlay with floating stat-gain labels, then auto-dismisses.
window.showHealAnimation = function(gains) {
  var lines = [];
  if (gains.confidence > 0) lines.push({ text: '\u2736 CONFIDENCE +' + gains.confidence, col: 'rgba(210,175,80,0.95)', shadow: 'rgba(210,170,60,0.5)' });
  if (gains.sobriety   > 0) lines.push({ text: '\u2736 SOBRIETY +' + gains.sobriety,     col: 'rgba(130,205,145,0.95)', shadow: 'rgba(110,190,120,0.45)' });
  if (!lines.length) return;

  var overlay = document.createElement('div');
  overlay.style.cssText = [
    'position:fixed;top:0;left:0;width:100%;height:100%;',
    'z-index:99998;pointer-events:none;',
    'display:flex;flex-direction:column;align-items:center;justify-content:center;',
    'background:rgba(26,16,4,0);',
    'transition:background 0.35s ease;',
  ].join('');
  document.body.appendChild(overlay);

  var statEls = lines.map(function(line, i) {
    var el = document.createElement('div');
    el.style.cssText = [
      'font:small-caps 700 15px "Cinzel",Georgia,serif;',
      'letter-spacing:0.14em;',
      'color:' + line.col + ';',
      'text-shadow:0 0 16px ' + line.shadow + ',0 0 32px ' + line.shadow + ';',
      'opacity:0;',
      'transform:translateY(10px);',
      'transition:opacity 0.45s ' + (0.12 + i * 0.22) + 's ease,transform 0.5s ' + (0.12 + i * 0.22) + 's ease;',
      'margin:5px 0;',
    ].join('');
    el.textContent = line.text;
    overlay.appendChild(el);
    return el;
  });

  // Double-rAF to ensure first paint before transition
  requestAnimationFrame(function() {
    requestAnimationFrame(function() {
      overlay.style.background = 'rgba(26,16,4,0.50)';
      statEls.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    });
  });

  // Hold, then fade out upward
  setTimeout(function() {
    overlay.style.transition = 'background 0.55s ease';
    overlay.style.background = 'rgba(26,16,4,0)';
    statEls.forEach(function(el, i) {
      el.style.transition = 'opacity 0.5s ' + (i * 0.1) + 's ease,transform 0.5s ' + (i * 0.1) + 's ease';
      el.style.opacity = '0';
      el.style.transform = 'translateY(-12px)';
    });
    setTimeout(function() { if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }, 600);
  }, 1750);
};

// ====== NOTEBOOK TAB SWITCHER ======
window.nbSwitchTab = function(tabEl) {
var page = tabEl.closest('.nb-page');
if (!page) return;
var tabs = page.querySelectorAll('.nb-tab');
var panels = page.querySelectorAll('.nb-panel');
var target = tabEl.getAttribute('data-tab');
tabs.forEach(function(t) { t.classList.remove('nb-tab-active'); });
panels.forEach(function(p) { p.classList.remove('nb-panel-active'); });
tabEl.classList.add('nb-tab-active');
var targetPanel = page.querySelector('.nb-panel-' + target);
if (targetPanel) targetPanel.classList.add('nb-panel-active');

// Pentangle reveal: when player navigates to LILLIES or MAP for the first time
// after collecting all 5 lilies, fire the corresponding animation.
var queue = page.dataset.pentangleQueue || '';
function consumeAndFire(tabKey, selector, triggerClass) {
  if (queue.indexOf(tabKey) < 0) return;
  var svg = page.querySelector(selector);
  if (!svg) return;
  svg.classList.remove(triggerClass);
  void svg.offsetWidth;
  svg.classList.add(triggerClass);
  queue = queue.split(',').filter(function(t){ return t && t !== tabKey; }).join(',');
  page.dataset.pentangleQueue = queue;
}
if (target === 'lily') consumeAndFire('lily', '.nb-lily-row', 'nb-lily-pentangle');
if (target === 'map')  {
  var fired = false;
  // Inline-snoop the queue first so we know if the map animation will fire
  if (queue.indexOf('map') >= 0 && page.querySelector('.soho-map svg')) fired = true;
  consumeAndFire('map',  '.soho-map svg', 'nb-map-pentangle');
  // After the animation actually fires, set $sawPentangle so subsequent
  // notebook opens don't keep re-queueing the reveal.
  if (fired && window.Harlowe && window.Harlowe.API_ACCESS) {
    try { window.Harlowe.API_ACCESS.STATE.variables.sawPentangle = true; } catch(e) {}
  }
}
};

// ====== NOTEBOOK LAYOUT FORCE ======
// Harlowe wraps dialog content in elements that break CSS layout.
// This polls for the dialog and forces layout with inline styles.
setInterval(function() {
var nbPage = document.querySelector('.nb-page');
if (!nbPage) return;

// Always find tw-dialog and force it full-screen
var el = nbPage.parentElement;
while (el && el.tagName !== 'TW-DIALOG') {
el.style.cssText = 'display:block !important;width:100% !important;max-width:none !important;overflow:visible !important;';
el = el.parentElement;
}
if (el && el.tagName === 'TW-DIALOG') {
el.style.cssText = 'position:fixed !important;top:0 !important;left:0 !important;width:100vw !important;max-width:none !important;height:100vh !important;display:flex !important;align-items:flex-start !important;justify-content:center !important;padding-top:4vh !important;background:transparent !important;border:none !important;z-index:9999 !important;overflow:hidden !important;';
}

// Force the tabbed layout container
nbPage.style.cssText = 'display:flex;flex-direction:column;position:relative;width:60vw;max-width:700px;height:84vh;overflow:hidden;background:#f4edd8;border:none;padding:0;z-index:10001;';

// Force tab bar
var tabBar = nbPage.querySelector('.nb-tabs');
if (tabBar) {
tabBar.style.cssText = 'display:flex;align-items:flex-end;padding:7px 0.6em 0;gap:3px;background:transparent;border-bottom:2px solid rgba(155,120,65,0.55);flex-shrink:0;';
}

// Force each panel
var panels = nbPage.querySelectorAll('.nb-panel');
panels.forEach(function(p) {
if (p.classList.contains('nb-panel-active')) {
if (p.classList.contains('nb-panel-map')) {
p.style.cssText = 'display:flex;flex:1;overflow:hidden;padding:0;background:rgba(20,18,15,0.95);align-items:center;justify-content:center;';
} else {
p.style.cssText = 'display:block;flex:1;overflow-y:auto;padding:0.8em 2em 2em 2em;box-sizing:border-box;background:#f4edd8;background-image:linear-gradient(rgba(120,100,80,0.15) 1px, transparent 1px);background-size:100% 2em;background-position:0 0.8em;font-family:"Courier New",Courier,monospace;font-size:1em;line-height:1.6;color:rgba(42,32,20,0.68);';
}
} else {
p.style.cssText = 'display:none;';
}
});

// Populate the napkin portrait image from localStorage (drawn at The French).
var napkinImgs = nbPage.querySelectorAll('.nb-napkin-img');
if (napkinImgs.length) {
try {
var napkinData = localStorage.getItem('dss_napkin');
if (napkinData) {
napkinImgs.forEach(function(img) {
if (img.getAttribute('src') !== napkinData) img.setAttribute('src', napkinData);
});
}
} catch(e) {}
}

// Force map sizing inside map panel
var mapPanel = nbPage.querySelector('.nb-panel-map');
if (mapPanel && mapPanel.classList.contains('nb-panel-active')) {
var map = mapPanel.querySelector('.soho-map');
if (map) {
map.style.cssText = 'width:100%;height:100%;display:flex;align-items:center;justify-content:center;padding:8px;box-sizing:border-box;margin:0;line-height:0;';
}
var mapSvg = mapPanel.querySelector('.soho-map svg');
if (mapSvg) {
mapSvg.style.cssText = 'width:100%;height:100%;display:block;';
}
}

// One-time setup: close button and backdrop click
if (el && el.tagName === 'TW-DIALOG' && !el.dataset.nbGuarded) {
el.dataset.nbGuarded = 'true';
var closeBtn = document.createElement('div');
closeBtn.textContent = '\u2715';
closeBtn.style.cssText = 'position:fixed;top:1.2em;right:1.5em;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#a09080;cursor:pointer;border:1px solid rgba(160,128,96,0.3);border-radius:50%;background:rgba(14,12,10,0.8);z-index:100000;transition:all 0.3s ease;';
closeBtn.addEventListener('mouseenter', function() {
this.style.color = '#d4a574';
this.style.borderColor = 'rgba(212,165,116,0.5)';
this.style.background = 'rgba(14,12,10,0.95)';
});
closeBtn.addEventListener('mouseleave', function() {
this.style.color = '#a09080';
this.style.borderColor = 'rgba(160,128,96,0.3)';
this.style.background = 'rgba(14,12,10,0.8)';
});
closeBtn.addEventListener('click', function() {
var link = document.querySelector('tw-dialog-links tw-link');
if (link) link.click();
});
el.appendChild(closeBtn);
el.addEventListener('click', function(e) {
var clickedNb = e.target.closest('.nb-page');
var clickedClose = e.target.closest('div[style*="z-index:100000"]');
if (!clickedNb && !clickedClose) {
var link = document.querySelector('tw-dialog-links tw-link');
if (link) link.click();
}
});
}
}, 200);

// ====== BAR GAME CLASS (two-phase: orders + carry) ======
window.BarGame = class BarGame {
constructor(canvasId, sobriety) {
this.canvas = document.getElementById(canvasId);
this.ctx = this.canvas.getContext('2d');
this.W = this.canvas.width; this.H = this.canvas.height;
this.sobriety = sobriety;
this.stopped = false;
this.mx = this.W/2; this.my = this.H/2;
this.t = 0;
this.lt = performance.now();

// ========== MIXING PHASE STATE ==========
this.phase = 'mixing';
this.mRound = 0; this.mScore = 0;
this.pouring = false; this.pourLevel = 0; this.pourDone = false;
this.pourSpeed = 0; this.wobT = 0;
this.finishPhase = false; this.finHover = -1; this.finPicked = null;
this.mFeed = null; this.mTransition = false;
this.pourDrops = []; this.bubbles = [];
this.bottleAngle = 0; this.pourStream = 0;
this.pourTime = 0; this.pourCommitted = false;
this.handShake = 0;
this.targetOff = 0; this.targetPhase = Math.random() * Math.PI * 2;
this.liquidWobble = 0;
this.pourAccuracy = 0;

// Drink definitions (unchanged from original)
this.drinks = [
  {name:"Bourbon",who:"Guitarist",glass:"tulip",liqCol:"#c98030",liqHi:"#e8b860",target:0.55,
   bottle:{col:"#8b4513",acc:"#c9a961",lab:"WT"},
   finish:{prompt:"Which glass?",correct:0,opts:["Tulip glass","Rocks glass"],
   okMsg:"Tulip glass. Right.",badMsg:"Wrong glass \u2014 he said tulip."}},
  {name:"Moscow Mule",who:"Moe",glass:"copper",liqCol:"#e0d090",liqHi:"#f0e8b0",target:0.60,
   bottle:{col:"#c0c0c0",acc:"#e8e8e8",lab:"Vodka"},
   finish:{prompt:"Lime?",correct:0,opts:["Squeeze fresh lime","Pour bottled juice"],
   okMsg:"Fresh lime. Perfect.",badMsg:"He said fresh lime, not bottled."}},
  {name:"Scotch",who:"Pianist",glass:"rocks",liqCol:"#d4a050",liqHi:"#e8c070",target:0.40,
   bottle:{col:"#5a2d0c",acc:"#d4a574",lab:"Mac"},
   finish:{prompt:"How?",correct:1,opts:["Add ice","Serve neat"],
   okMsg:"Neat. As requested.",badMsg:"He said neat \u2014 no ice."}}
];

this.glassH = {tulip: 70, copper: 55, rocks: 42};
this.completedDrinks = [];
this.sparkles = [];
this.smokePs = [];
for (var i = 0; i < 8; i++) this.smokePs.push({x:Math.random()*this.W,y:Math.random()*120+20,s:20+Math.random()*40,sp:0.1+Math.random()*0.2,off:Math.random()*10});
this.patrons = this._initPatrons();

// ========== CARRY PHASE STATE ==========
this.carryPhase = {
  scrollPos: 0,
  scrollSpeed: 200,
  maxScroll: 7000,
  playerY: 320,
  playerVelY: 0,
  playerJumping: false,
  playerDuckingInput: false,
  gravity: 600,
  jumpPower: -400,
  groundY: 320,
  baseGroundY: 320,
  glassesLeft: 3,
  invulnTimer: 0,
  obstacles: [],
  nextObstacleTime: 0,
  screenShake: 0,
  difficultyPhase: 0,
  wobbling: false,
  wobbleTimer: 0,
  staggerTimer: 0,
  pitFalling: false,
  pitFallPhase: null,
  pitFallY: 0,
  pitFallVel: 0,
  pitFallBottomT: 0,
  pitFallObs: null,
  terrain: [
    {x: 0, y: 320},
    {x: 900, y: 320},
    {x: 1050, y: 285},
    {x: 1550, y: 285},
    {x: 1700, y: 320},
    {x: 2500, y: 320},
    {x: 2650, y: 295},
    {x: 3250, y: 295},
    {x: 3400, y: 320},
    {x: 4000, y: 320},
    {x: 4150, y: 275},
    {x: 4650, y: 275},
    {x: 4850, y: 320},
    {x: 5400, y: 320},
    {x: 5550, y: 290},
    {x: 6050, y: 290},
    {x: 6200, y: 320},
    {x: 7000, y: 320}
  ]
};

this._generateObstacles();

// ========== EVENT LISTENERS ==========
this.canvas.addEventListener('mousemove', (e) => {
  var r = this.canvas.getBoundingClientRect();
  this.mx = (e.clientX - r.left) * (this.W / r.width);
  this.my = (e.clientY - r.top) * (this.H / r.height);
});

this.canvas.addEventListener('mousedown', (e) => {
  if (this.phase === 'mixing' && !this.pourDone && !this.finishPhase && !this.mTransition) {
    this.pouring = true;
    this.pourCommitted = true;
  }
  if (this.phase === 'carry') {
    this._playerJump();
  }
});

this.canvas.addEventListener('mouseup', (e) => {
  if (this.phase === 'mixing' && this.pouring) {
    this.pouring = false;
    this.pourDone = true;
    this._scorePour();
  }
});

this.canvas.addEventListener('mouseleave', (e) => {
  if (this.phase === 'mixing' && this.pouring) {
    this.pouring = false;
    this.pourDone = true;
    this._scorePour();
  }
});

this.canvas.addEventListener('click', () => {
  // No longer needed for finish choices
});

document.addEventListener('keydown', (e) => {
  if (this.phase === 'carry') {
    if (e.code === 'Space' || e.code === 'ArrowUp') {
      e.preventDefault();
      this._playerJump();
    }
    if (e.code === 'ArrowDown') {
      e.preventDefault();
      this.carryPhase.playerDuckingInput = true;
    }
  }
});

document.addEventListener('keyup', (e) => {
  if (this.phase === 'carry') {
    if (e.code === 'ArrowDown') {
      this.carryPhase.playerDuckingInput = false;
    }
  }
});

document.getElementById('bar-round-display').textContent = '\u2727 ' + this.drinks[0].who + '\u2019s ' + this.drinks[0].name + ' \u2727';
document.getElementById('bar-narrative').innerHTML = '<em style="color:#d4a574;">Click and hold to pour. Release when the level looks right.</em>';

var self = this;
setTimeout(function() { if (self.phase === 'mixing' && !self.pourDone) document.getElementById('bar-narrative').innerHTML = ''; }, 3000);

this._loop();
}

// ========== MIXING PHASE: HELPERS ==========
_initPatrons() {
var patrons = [];
for (var i = 0; i < 5; i++) {
  patrons.push({
    x: 30 + Math.random() * (this.W - 60),
    y: 80 + Math.random() * 100,
    w: 15 + Math.random() * 20,
    h: 25 + Math.random() * 35
  });
}
return patrons;
}

_liquidY(glassType, gy, fill) {
var h = this.glassH[glassType] || 55;
var offset = glassType === 'tulip' ? -5 : 0;
return gy + h * (1 - fill * 0.85) + offset;
}

_scorePour() {
var d = this.drinks[this.mRound];
var effectiveTarget = Math.max(0.1, Math.min(0.9, d.target + this.targetOff));
var diff = Math.abs(this.pourLevel - effectiveTarget);
if (diff < 0.07) { this.pourAccuracy = 2; }
else if (diff < 0.16) { this.pourAccuracy = 1; }
else { this.pourAccuracy = 0; }
var gx = this.W/2, gy = 270;
this.mScore += this.pourAccuracy;
var narr = document.getElementById('bar-narrative');
if (this.pourAccuracy === 2) {
  this._spawnSparkles(gx, gy, 15);
  narr.innerHTML = '<em style="color:#4CFF00;">Perfect pour.</em>';
} else if (this.pourAccuracy === 1) {
  this._spawnSparkles(gx, gy + 15, 8);
  narr.innerHTML = '<em style="color:#d4a574;">Close enough.</em>';
} else {
  narr.innerHTML = '<em style="color:#FF6B6B;">' + (this.pourLevel > effectiveTarget ? 'Too much.' : 'Not enough.') + '</em>';
}
this.liquidWobble = 1.0;
this.mTransition = true;
this.completedDrinks.push({
  name: d.name,
  who: d.who,
  glass: d.glass,
  liqCol: d.liqCol,
  accuracy: this.pourAccuracy
});
var self = this;
setTimeout(function() {
  self.mRound++;
  if (self.mRound >= 3) {
    self._startCarryTransition();
  } else {
    self._resetPour();
    var nd = self.drinks[self.mRound];
    document.getElementById('bar-round-display').textContent = '\u2727 ' + nd.who + '\u2019s ' + nd.name + ' \u2727';
    narr.innerHTML = '';
  }
}, 1200);
}

_startCarryTransition() {
var narr = document.getElementById('bar-narrative');
document.getElementById('bar-round-display').textContent = '\u2727 Drinks ready! \u2727';
narr.innerHTML = '<em style="color:#d4a574;">Now carry the tray back to the stage.<br><strong>SPACE / UP</strong> to jump &nbsp; <strong>DOWN</strong> to duck</em>';
this.phase = 'carryWait';
var self = this;
setTimeout(function() {
  narr.innerHTML = '';
  document.getElementById('bar-round-display').textContent = '\u2727 CARRY THE TRAY \u2727';
  self.phase = 'carry';
  if (window._jazzMiniDataUri && !window._jazzMiniEl) {
    var _jmEl = new Audio(window._jazzMiniDataUri);
    _jmEl.volume = 0.28; _jmEl.loop = true;
    _jmEl.muted = !!(window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted());
    _jmEl.play().catch(function(){});
    window._jazzMiniEl = _jmEl;
    if (window._jazzMiniMuteWatcher) { try { clearInterval(window._jazzMiniMuteWatcher); } catch(e) {} }
    window._jazzMiniMuteWatcher = setInterval(function(){
      var el = window._jazzMiniEl;
      if (!el) { clearInterval(window._jazzMiniMuteWatcher); window._jazzMiniMuteWatcher = null; return; }
      var m = !!(window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted());
      if (el.muted !== m) el.muted = m;
    }, 250);
  }
}, 3000);
}

_resetPour() {
this.pouring = false; this.pourLevel = 0; this.pourDone = false;
this.finishPhase = false; this.finHover = -1; this.finPicked = null;
this.mFeed = null; this.mTransition = false;
this.pourDrops = []; this.bubbles = [];
this.bottleAngle = 0; this.pourStream = 0;
this.pourAccuracy = 0;
this.pourTime = 0; this.pourCommitted = false;
this.handShake = 0;
this.targetOff = 0; this.targetPhase = Math.random() * Math.PI * 2;
this.liquidWobble = 0;
}

_spawnSparkles(x, y, count) {
for (var i = 0; i < count; i++) {
  var angle = Math.random() * Math.PI * 2;
  var speed = 2 + Math.random() * 3;
  this.sparkles.push({
    x: x,
    y: y,
    vx: Math.cos(angle) * speed,
    vy: Math.sin(angle) * speed,
    life: 1,
    size: 1 + Math.random() * 2
  });
}
}

// ========== CARRY PHASE: OBSTACLES ==========
_generateObstacles() {
this.carryPhase.obstacles = [];
var baseGY = this.carryPhase.baseGroundY;
var maxScroll = this.carryPhase.maxScroll;

var dist = 450; // start after a short run-up
var lastAction = ''; // 'jump' or 'duck'
var sameCount = 0;
var sinceGap = 0;
var obsCount = 0;       // total obstacles placed so far
var pitsPlaced = 0;     // bottomless-pit count — used to force at least one early

while (dist < maxScroll - 200) {
  var progress = dist / maxScroll; // 0.0 to 1.0

  // Decide what chunk to place
  var chunk;
  var r = Math.random();

  // Guarantee at least one bottomless pit (with the rising music) shows up
  // by the third obstacle. The pit is the visual centrepiece of the carry
  // run — without this, an unlucky RNG roll could give a player who dies
  // early a whole game with no pit at all.
  if (pitsPlaced === 0 && obsCount >= 2) {
    chunk = 'floor_gap';
  }
  // Force a breather every 5-8 obstacles
  else if (sinceGap >= 5 + Math.floor(Math.random() * 3)) {
    chunk = 'gap';
  }
  // Early section: mostly singles, introduce floor gaps
  else if (progress < 0.3) {
    if (r < 0.35) chunk = 'single_low';
    else if (r < 0.7) chunk = 'single_high';
    else if (r < 0.88) chunk = 'floor_gap';
    else chunk = 'gap';
  }
  // Middle section: introduce doubles and combos
  else if (progress < 0.7) {
    if (r < 0.2) chunk = 'single_low';
    else if (r < 0.4) chunk = 'single_high';
    else if (r < 0.5) chunk = 'floor_gap';
    else if (r < 0.6) chunk = 'double_low';
    else if (r < 0.7) chunk = 'double_high';
    else if (r < 0.8) chunk = 'combo_low_high';
    else if (r < 0.9) chunk = 'combo_high_low';
    else chunk = 'gap';
  }
  // Late section: denser, tougher
  else {
    if (r < 0.18) chunk = 'single_low';
    else if (r < 0.36) chunk = 'single_high';
    else if (r < 0.48) chunk = 'floor_gap';
    else if (r < 0.6) chunk = 'double_low';
    else if (r < 0.72) chunk = 'double_high';
    else if (r < 0.82) chunk = 'combo_low_high';
    else if (r < 0.92) chunk = 'combo_high_low';
    else chunk = 'gap';
  }

  // Prevent 3+ of same action in a row
  var chunkAction = '';
  if (chunk === 'single_low' || chunk === 'double_low' || chunk === 'floor_gap') chunkAction = 'jump';
  else if (chunk === 'single_high' || chunk === 'double_high') chunkAction = 'duck';

  if (chunkAction === lastAction) {
    sameCount++;
    if (sameCount >= 2) {
      // Force the opposite
      if (chunkAction === 'jump') {
        chunk = (Math.random() < 0.7) ? 'single_high' : 'double_high';
        chunkAction = 'duck';
      } else {
        chunk = (Math.random() < 0.7) ? 'single_low' : 'double_low';
        chunkAction = 'jump';
      }
      sameCount = 0;
    }
  } else {
    sameCount = (chunkAction !== '') ? 1 : sameCount;
  }
  if (chunkAction !== '') lastAction = chunkAction;

  var style = Math.floor(Math.random() * 3) + 1; // 1, 2, or 3 — which art set
  var type = Math.floor(Math.random() * 3); // 0, 1, or 2 — variant within set

  if (chunk === 'gap') {
    dist += 300 + Math.random() * 200; // breather gap
    sinceGap = 0;
    obsCount++;
  }
  else if (chunk === 'floor_gap') {
    var gapWidth = 80 + Math.random() * 60;
    var localGY = this._getTerrainY(dist);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: false, isGap: true, style: style,
      width: gapWidth,
      y: localGY, height: 80, hit: false, groundY: localGY
    });
    dist += 320 + Math.random() * 180;
    sinceGap++;
    obsCount++;
    pitsPlaced++;
  }
  else if (chunk === 'single_low') {
    var h = 30 + Math.random() * 20;
    var localGY = this._getTerrainY(dist);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: false, style: style,
      width: 50 + Math.random() * 40,
      y: localGY - h, height: h, hit: false, groundY: localGY
    });
    dist += 300 + Math.random() * 180;
    sinceGap++;
    obsCount++;
  }
  else if (chunk === 'single_high') {
    var localGY = this._getTerrainY(dist);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: true, style: style,
      width: 70 + Math.random() * 30,
      y: 0, height: localGY + 5, hit: false, groundY: localGY
    });
    dist += 300 + Math.random() * 180;
    sinceGap++;
    obsCount++;
  }
  else if (chunk === 'double_low') {
    var h1 = 30 + Math.random() * 15;
    var h2 = 30 + Math.random() * 15;
    var style2 = Math.floor(Math.random() * 3) + 1;
    var type2 = Math.floor(Math.random() * 3);
    var gap1 = 240 + Math.random() * 60;
    var localGY1 = this._getTerrainY(dist);
    var localGY2 = this._getTerrainY(dist + gap1);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: false, style: style,
      width: 45 + Math.random() * 25,
      y: localGY1 - h1, height: h1, hit: false, groundY: localGY1
    });
    this.carryPhase.obstacles.push({
      x: dist + gap1, type: type2, isHigh: false, style: style2,
      width: 45 + Math.random() * 25,
      y: localGY2 - h2, height: h2, hit: false, groundY: localGY2
    });
    dist += 500 + Math.random() * 200;
    sinceGap += 2;
    obsCount++;
  }
  else if (chunk === 'double_high') {
    var style2 = Math.floor(Math.random() * 3) + 1;
    var type2 = Math.floor(Math.random() * 3);
    var gap1 = 260 + Math.random() * 60;
    var localGY1 = this._getTerrainY(dist);
    var localGY2 = this._getTerrainY(dist + gap1);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: true, style: style,
      width: 65 + Math.random() * 25,
      y: 0, height: localGY1 + 5, hit: false, groundY: localGY1
    });
    this.carryPhase.obstacles.push({
      x: dist + gap1, type: type2, isHigh: true, style: style2,
      width: 65 + Math.random() * 25,
      y: 0, height: localGY2 + 5, hit: false, groundY: localGY2
    });
    dist += 520 + Math.random() * 200;
    sinceGap += 2;
    obsCount++;
  }
  else if (chunk === 'combo_low_high') {
    var h1 = 30 + Math.random() * 15;
    var style2 = Math.floor(Math.random() * 3) + 1;
    var type2 = Math.floor(Math.random() * 3);
    /* Jump airtime is ~1.3s ≈ 330px at full scroll speed, so the high
       obstacle must be at least ~400px away to give time to land + duck. */
    var gap1 = 410 + Math.random() * 90;
    var localGY1 = this._getTerrainY(dist);
    var localGY2 = this._getTerrainY(dist + gap1);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: false, style: style,
      width: 45 + Math.random() * 25,
      y: localGY1 - h1, height: h1, hit: false, groundY: localGY1
    });
    this.carryPhase.obstacles.push({
      x: dist + gap1, type: type2, isHigh: true, style: style2,
      width: 65 + Math.random() * 25,
      y: 0, height: localGY2 + 5, hit: false, groundY: localGY2
    });
    dist += 540 + Math.random() * 200;
    sinceGap += 2;
    obsCount++;
  }
  else if (chunk === 'combo_high_low') {
    var h2 = 30 + Math.random() * 15;
    var style2 = Math.floor(Math.random() * 3) + 1;
    var type2 = Math.floor(Math.random() * 3);
    var gap1 = 300 + Math.random() * 60;
    var localGY1 = this._getTerrainY(dist);
    var localGY2 = this._getTerrainY(dist + gap1);
    this.carryPhase.obstacles.push({
      x: dist, type: type, isHigh: true, style: style,
      width: 65 + Math.random() * 25,
      y: 0, height: localGY1 + 5, hit: false, groundY: localGY1
    });
    this.carryPhase.obstacles.push({
      x: dist + gap1, type: type2, isHigh: false, style: style2,
      width: 45 + Math.random() * 25,
      y: localGY2 - h2, height: h2, hit: false, groundY: localGY2
    });
    dist += 560 + Math.random() * 200;
    sinceGap += 2;
    obsCount++;
  }
}
}

_getTerrainY(worldX) {
var t = this.carryPhase.terrain;
if (worldX <= t[0].x) return t[0].y;
if (worldX >= t[t.length-1].x) return t[t.length-1].y;
for (var i = 0; i < t.length - 1; i++) {
  if (worldX >= t[i].x && worldX < t[i+1].x) {
    var frac = (worldX - t[i].x) / (t[i+1].x - t[i].x);
    return t[i].y + frac * (t[i+1].y - t[i].y);
  }
}
return this.carryPhase.baseGroundY;
}

_playerJump() {
if (this.phase === 'carry' && !this.carryPhase.playerJumping && this.carryPhase.staggerTimer <= 0 && this.carryPhase.playerY >= this.carryPhase.groundY - 5) {
  this.carryPhase.playerJumping = true;
  this.carryPhase.playerVelY = this.carryPhase.jumpPower;
}
}

_checkObstacleCollisions() {
var cp = this.carryPhase;
if (cp.invulnTimer > 0) return;
var isDucking = cp.playerDuckingInput && !cp.playerJumping;
var playerLeft = 85, playerRight = 115;

for (var i = 0; i < cp.obstacles.length; i++) {
  var obs = cp.obstacles[i];
  if (obs.hit) continue;
  var obsLeft = obs.x - cp.scrollPos;
  var obsRight = obsLeft + obs.width;
  if (obsLeft > this.W || obsRight < 0) continue;

  // Horizontal overlap check
  if (playerLeft >= obsRight || playerRight <= obsLeft) continue;

  var collides = false;
  if (obs.isHigh) {
    // HIGH obstacles: you MUST duck. Jumping does NOT help.
    if (!isDucking) collides = true;
    // Trigger duck scatter when successfully ducking through
    if (isDucking && !obs.scattered) {
      obs.scattered = true;
      obs.scatterTime = this.t;
    }
  } else if (obs.isGap) {
    // FLOOR GAP: you must be airborne to clear it. Failing to jump
    // doesn't just hit — the player falls into the pit and bounces
    // out (handled in _updateCarry via pitFalling).
    var isAirborne = cp.playerY < cp.groundY - 15;
    if (!isAirborne) {
      cp.pitFalling = true;
      cp.pitFallPhase = 'fall';
      cp.pitFallY = 0;
      cp.pitFallVel = 0;
      cp.pitFallBottomT = 0;
      cp.pitFallObs = obs;
      if (window.dssAudio && window.dssAudio.dodgeWhoosh) window.dssAudio.dodgeWhoosh();
      return; // skip the rest of collision handling this frame
    }
  } else {
    // LOW obstacles: you must jump over them.
    var isAirborne = cp.playerY < cp.groundY - 15;
    if (!isAirborne) collides = true;
  }

  if (collides) {
    // Bounced back from a high obstacle while airborne — physics only, no
    // automatic glass loss. The hit still routes through the wobble system
    // below so the first time it's a "nearly lost it" wobble, not a drop.
    var bouncedBack = obs.isHigh && cp.playerJumping;
    if (bouncedBack) {
      cp.scrollPos = Math.max(0, cp.scrollPos - 100);
      cp.playerJumping = false;
      cp.playerVelY = 0;
      cp.playerY = cp.groundY;
      cp.staggerTimer = 0.9;
    }
    // Wobble mechanic: first hit wobbles (drink stays on tray), a second hit
    // within the wobble window is what actually drops a glass.
    if (!cp.wobbling) {
      cp.wobbling = true;
      cp.wobbleTimer = 3.0;
      cp.invulnTimer = bouncedBack ? 1.2 : 1.0;
      cp.screenShake = bouncedBack ? 1.2 : 0.6;
      if (window.dssAudio && window.dssAudio.muffledThud) window.dssAudio.muffledThud();
      if (window.dssAudio && window.dssAudio.glassClink) window.dssAudio.glassClink();
    } else {
      obs.hit = true;
      cp.glassesLeft = Math.max(0, cp.glassesLeft - 1);
      cp.wobbling = false;
      cp.wobbleTimer = 0;
      cp.invulnTimer = 1.5;
      cp.screenShake = 1;
      if (window.dssAudio && window.dssAudio.punchImpact) window.dssAudio.punchImpact();
      if (window.dssAudio && window.dssAudio.glassClink) window.dssAudio.glassClink();
    }
  }
}
}

// ========== MAIN LOOP ==========
stop() {
  this.stopped = true;
  document.removeEventListener('keydown', this._keydownHandler);
  document.removeEventListener('keyup', this._keyupHandler);
}

_loop() {
if (this.stopped) return;
var now = performance.now(), dt = Math.min(now - this.lt, 50); this.lt = now;
this.t += dt * 0.001;
this._update(dt);
this._draw();
requestAnimationFrame(() => this._loop());
}

_update(dt) {
if (this.phase === 'mixing') this._updateMixing(dt);
if (this.phase === 'carry') this._updateCarry(dt);

// Update sparkles
this.sparkles = this.sparkles.filter((s) => {
  s.x += s.vx;
  s.y += s.vy;
  s.vy += 0.12;
  s.life -= 0.035;
  s.vx *= 0.98;
  return s.life > 0;
});

this.liquidWobble *= 0.94;
}

_updateMixing(dt) {
this.wobT += dt * 0.004;

// Oscillate target while pouring. Four harmonics — slower low end for
// the main drift, plus a higher-frequency jitter so the line twitches
// unpredictably (player has wider scoring zones, so it can afford to
// move more erratically without becoming unwinnable).
if (this.pourCommitted && !this.pourDone) {
  this.targetPhase += dt * 0.0026;
  this.targetOff = Math.sin(this.targetPhase * 1.4) * 0.14 + Math.sin(this.targetPhase * 2.4 + 1.7) * 0.10 + Math.sin(this.targetPhase * 4.1 + 0.9) * 0.05 + Math.sin(this.targetPhase * 7.3 + 2.3) * 0.045;
}

// Sobriety hand shake
var drunk = (100 - this.sobriety) / 100;
this.handShake = Math.sin(this.wobT * 4.2) * drunk * 3 + Math.sin(this.wobT * 2.7) * drunk * 2;

if (this.pouring && !this.pourDone) {
  this.pourTime += dt;
  var ramp = Math.min(1, this.pourTime / 400);
  var steadySpeed = 0.00048;
  var wobbleMult = 1.0 + drunk * 0.4 * Math.sin(this.wobT * 3.1 + Math.sin(this.wobT * 1.7) * 0.5);
  var speed = steadySpeed * ramp * wobbleMult;
  this.pourLevel = Math.min(1.0, this.pourLevel + Math.max(0.00005, speed) * dt);
  this.bottleAngle = Math.min(0.45, this.bottleAngle + 0.006 * ramp);
  this.pourStream = Math.min(1, this.pourStream + 0.06);

  if (Math.random() < 0.25 && ramp > 0.3) {
    this.pourDrops.push({
      x: this.W/2 + 38 + this.handShake,
      y: 95 + Math.random()*15,
      vy: 1.5 + Math.random()*2.5,
      vx: (Math.random()-0.5) * 0.8,
      life: 1
    });
  }

  if (this.mRound === 1 && this.pourLevel > 0.08 && Math.random() < 0.12) {
    var glassBase = 320 - this.pourLevel * 120;
    this.bubbles.push({
      x: this.W/2 - 16 + Math.random()*32,
      y: glassBase + Math.random() * 20,
      vy: -0.2 - Math.random()*0.4,
      life: 1,
      r: 0.8 + Math.random()*2
    });
  }
} else {
  this.bottleAngle = Math.max(0, this.bottleAngle - 0.015);
  this.pourStream = Math.max(0, this.pourStream - 0.04);
}

this.pourDrops = this.pourDrops.filter(function(d) {
  d.y += d.vy; d.x += (d.vx || 0); d.vy += 0.08; d.life -= 0.025;
  return d.life > 0 && d.y < 340;
});

this.bubbles = this.bubbles.filter(function(b) {
  b.y += b.vy; b.x += Math.sin(b.y * 0.1) * 0.15; b.life -= 0.006;
  return b.life > 0;
});
}

_updateCarry(dt) {
var cp = this.carryPhase;
var s = dt * 0.001;

// Stagger timer: character is stunned, world pauses
if (cp.staggerTimer > 0) {
  cp.staggerTimer -= s;
  if (cp.invulnTimer > 0) cp.invulnTimer -= s;
  cp.screenShake *= 0.92;
  // Don't scroll or check collisions during stagger
  return;
}

// Pit-fall animation — physics-based: player drops in under gravity,
// hits bottom, then a sharp upward kick launches them clear of the pit
// (overshoots groundY slightly, like a proper jump out).
if (cp.pitFalling) {
  var pitG     = 1600; // gravity for the pit-bounce (stronger than normal)
  var pitDepth = 62;   // how deep into the pit
  var pitKick  = -560; // initial upward velocity when bouncing out
  if (cp.pitFallPhase === 'fall') {
    cp.pitFallVel += pitG * s;
    cp.pitFallY += cp.pitFallVel * s;
    if (cp.pitFallY >= pitDepth) {
      cp.pitFallY = pitDepth;
      cp.pitFallVel = 0;
      cp.pitFallPhase = 'bottom';
      cp.pitFallBottomT = 0;
      if (window.dssAudio && window.dssAudio.muffledThud) window.dssAudio.muffledThud();
      if (window.dssAudio && window.dssAudio.glassClink) window.dssAudio.glassClink();
    }
  } else if (cp.pitFallPhase === 'bottom') {
    cp.pitFallBottomT += s;
    if (cp.pitFallBottomT >= 0.06) {
      cp.pitFallVel = pitKick;
      cp.pitFallPhase = 'rising';
      if (window.dssAudio && window.dssAudio.dodgeWhoosh) window.dssAudio.dodgeWhoosh();
    }
  } else if (cp.pitFallPhase === 'rising') {
    cp.pitFallVel += pitG * s;
    cp.pitFallY += cp.pitFallVel * s;
    // After overshoot, when falling back through ground level, end the animation.
    if (cp.pitFallY <= 0 && cp.pitFallVel > 0) {
      cp.pitFalling = false;
      cp.pitFallPhase = null;
      cp.playerY = cp.groundY;
      cp.playerVelY = 0;
      cp.playerJumping = false;
      if (cp.pitFallObs) cp.pitFallObs.hit = true;
      if (!cp.wobbling) {
        cp.wobbling = true;
        cp.wobbleTimer = 3.0;
      } else {
        cp.glassesLeft = Math.max(0, cp.glassesLeft - 1);
        cp.wobbling = false;
        cp.wobbleTimer = 0;
      }
      cp.invulnTimer = 1.4;
      cp.screenShake = 0.7;
      cp.pitFallObs = null;
      if (cp.invulnTimer > 0) cp.invulnTimer -= s;
      cp.screenShake *= 0.92;
      return;
    }
  }
  cp.playerY = cp.groundY + cp.pitFallY;
  cp.playerVelY = 0;
  cp.playerJumping = false;
  if (cp.invulnTimer > 0) cp.invulnTimer -= s;
  cp.screenShake *= 0.92;
  return;
}

// Speed ramp: starts at 170, gently climbs to 260, plateaus
var progressRatio = cp.scrollPos / cp.maxScroll;
cp.scrollSpeed = 170 + Math.min(progressRatio * 1.5, 1.0) * 90;
cp.difficultyPhase = Math.floor(progressRatio * 4);

// Dynamic terrain: player is at screen x=100, so world x = scrollPos + 100
cp.groundY = this._getTerrainY(cp.scrollPos + 100);

// Player physics
cp.playerVelY += cp.gravity * s;
cp.playerY += cp.playerVelY * s;

// Ground collision / terrain following
if (cp.playerJumping) {
  // Airborne: land when reaching the ground
  if (cp.playerY >= cp.groundY) {
    cp.playerY = cp.groundY;
    cp.playerVelY = 0;
    cp.playerJumping = false;
  }
} else {
  // On ground: follow terrain smoothly
  cp.playerY = cp.groundY;
  cp.playerVelY = 0;
}

cp.scrollPos += cp.scrollSpeed * s;

this._checkObstacleCollisions();

if (cp.invulnTimer > 0) cp.invulnTimer -= s;
cp.screenShake *= 0.92;

// Wobble timer: if you survive long enough after a wobble, it resets
if (cp.wobbling) {
  cp.wobbleTimer -= s;
  if (cp.wobbleTimer <= 0) {
    cp.wobbling = false;
    cp.wobbleTimer = 0;
  }
}

if (cp.scrollPos >= cp.maxScroll) {
  this.phase = 'result';
  this._resultCarry();
}
}


_draw() {
if (this.phase === 'mixing') this._drawMixing();
else if (this.phase === 'carryWait') this._drawCarryWait();
else if (this.phase === 'carry') this._drawCarry();
else if (this.phase === 'result') this._drawResult();
}


_drawCarryWait() {
var c = this.ctx, W = this.W, H = this.H;
c.fillStyle = '#0a0804';
c.fillRect(0, 0, W, H);
this._drawAtmosphere(c);
c.save();
c.font = 'bold 20px Georgia';
c.textAlign = 'center';
c.fillStyle = '#d4a574';
c.fillText('Get ready...', W/2, H/2 - 20);
c.font = '14px Georgia';
c.fillStyle = '#8a7a6a';
c.fillText('SPACE / UP to jump', W/2, H/2 + 20);
c.fillText('DOWN to duck', W/2, H/2 + 45);
c.restore();
}

// ========== DRAW: MIXING ==========
_drawMixing() {
var c = this.ctx, W = this.W, H = this.H;
c.fillStyle = '#0a0804';
c.fillRect(0, 0, W, H);

this._drawAtmosphere(c);

var gx = W/2, gy = 230;
var d = this.drinks[this.mRound];

// Bottle
this._drawBottle(c, gx - 50, 40, 40, 90, d.bottle.col, d.bottle.acc, d.bottle.lab);

// Bottle tilt for pouring
c.save();
c.translate(gx - 30, 85);
c.rotate(this.bottleAngle);
c.fillStyle = 'rgba(255, 220, 150, ' + (this.pourStream * 0.4) + ')';
if (this.pourStream > 0) {
  for (var i = 0; i < this.pourStream * 8; i++) {
    var px = (Math.random() - 0.5) * 6;
    var py = i * 4;
    c.fillRect(px, py, 3, 3);
  }
}
c.restore();

// Pour drops
c.fillStyle = d.liqCol;
this.pourDrops.forEach((drop) => {
  c.globalAlpha = drop.life * 0.7;
  c.beginPath();
  c.arc(drop.x, drop.y, 2, 0, Math.PI * 2);
  c.fill();
});
c.globalAlpha = 1;

// Glass — scaled up 1.5x
var glassScale = 1.5;
c.save();
c.translate(gx, gy);
c.scale(glassScale, glassScale);
c.translate(-gx, -gy);
this._drawGlass(c, d.glass, gx, gy, this.pourLevel, d.target, d.liqCol, d.liqHi);

// Target marker + tolerance band — the band shows the "close enough"
// zone visibly so the player can see the leniency they have. Inner
// dashed line is the bullseye (perfect zone), outer is the pass zone.
var effTarget = d.target + this.targetOff;
var targetY    = this._liquidY(d.glass, gy, effTarget);
var bandTop    = this._liquidY(d.glass, gy, effTarget + 0.16);
var bandBottom = this._liquidY(d.glass, gy, effTarget - 0.16);
var perfTop    = this._liquidY(d.glass, gy, effTarget + 0.07);
var perfBottom = this._liquidY(d.glass, gy, effTarget - 0.07);
// Outer pass-zone shading
c.fillStyle = 'rgba(255, 200, 120, 0.07)';
c.fillRect(gx - 30, bandTop, 60, bandBottom - bandTop);
// Inner perfect-zone shading (just slightly brighter)
c.fillStyle = 'rgba(120, 255, 120, 0.10)';
c.fillRect(gx - 30, perfTop, 60, perfBottom - perfTop);
// Centre target line
c.strokeStyle = 'rgba(255, 100, 100, 0.45)';
c.lineWidth = 1.5;
c.beginPath();
c.moveTo(gx - 30, targetY);
c.lineTo(gx + 30, targetY);
c.stroke();
// Faint outer band edges
c.strokeStyle = 'rgba(255, 200, 120, 0.20)';
c.lineWidth = 0.8;
c.setLineDash([3, 3]);
c.beginPath();
c.moveTo(gx - 30, bandTop);    c.lineTo(gx + 30, bandTop);
c.moveTo(gx - 30, bandBottom); c.lineTo(gx + 30, bandBottom);
c.stroke();
c.setLineDash([]);
c.restore();

// Bubbles (Moscow Mule)
this.bubbles.forEach((b) => {
  c.save();
  c.globalAlpha = b.life * 0.6;
  c.strokeStyle = 'rgba(200, 200, 255, 0.8)';
  c.lineWidth = 1;
  c.beginPath();
  c.arc(gx - 16 + b.x, gy + 10 + b.y, b.r, 0, Math.PI * 2);
  c.stroke();
  c.restore();
});

// Completed drinks sidebar
var sideX = 10, sideY = 10;
c.fillStyle = 'rgba(100, 80, 60, 0.4)';
c.fillRect(sideX, sideY, 80, 380);
c.strokeStyle = 'rgba(200, 180, 160, 0.5)';
c.lineWidth = 1;
c.strokeRect(sideX, sideY, 80, 380);

var completed = 0;
for (var i = 0; i < this.completedDrinks.length; i++) {
  this._drawCompletedDrink(c, this.completedDrinks[i], sideX + 5, sideY + 10 + i * 120);
  completed++;
}

// Sparkles
this._drawSparkles(c);
}

_drawCompletedDrink(c, cd, dx, dy) {
c.save();
c.font = 'bold 10px Georgia';
c.textAlign = 'center';
c.fillStyle = '#d4a574';
c.fillText(cd.who, dx + 35, dy + 5);

// Mini glass
var gy = dy + 20;
this._drawGlass(c, cd.glass, dx + 35, gy, 0.6, 0, cd.liqCol, '#fff');

// Accuracy stars
c.font = 'bold 14px Georgia';
var starColor = cd.accuracy === 2 ? '#4CFF00' : cd.accuracy === 1 ? '#d4a574' : '#666';
c.fillStyle = starColor;
if (cd.accuracy === 2) {
  c.fillText('★', dx + 35, dy + 75);
} else if (cd.accuracy === 1) {
  c.fillText('◐', dx + 35, dy + 75);
} else {
  c.fillText('○', dx + 35, dy + 75);
}

c.restore();
}

_drawGlass(c, type, gx, gy, fill, target, liqCol, liqHi) {
c.save();
if (type === 'tulip') {
  var bw = 30, bh = 70, stemH = 28, baseW = 22;
  c.fillStyle = 'rgba(180,170,160,0.25)';
  c.fillRect(gx - 2, gy + bh - 5, 4, stemH);
  c.beginPath();
  c.ellipse(gx, gy + bh + stemH - 2, baseW/2, 4, 0, 0, Math.PI * 2);
  c.fillStyle = 'rgba(180,170,160,0.3)';
  c.fill();
  c.beginPath();
  c.moveTo(gx - 6, gy + bh - 5);
  c.quadraticCurveTo(gx - bw/2 - 8, gy + bh * 0.5, gx - bw/2, gy + bh * 0.2);
  c.quadraticCurveTo(gx - bw/2 + 4, gy - 5, gx, gy - 8);
  c.quadraticCurveTo(gx + bw/2 - 4, gy - 5, gx + bw/2, gy + bh * 0.2);
  c.quadraticCurveTo(gx + bw/2 + 8, gy + bh * 0.5, gx + 6, gy + bh - 5);
  c.closePath();
  c.strokeStyle = 'rgba(200,190,180,0.4)';
  c.lineWidth = 1.5;
  c.stroke();
  if (fill > 0) {
    var liqTop = gy + bh * (1 - fill * 0.85) - 5;
    c.save();
    c.beginPath();
    c.moveTo(gx - 6, gy + bh - 5);
    c.quadraticCurveTo(gx - bw/2 - 8, gy + bh * 0.5, gx - bw/2, gy + bh * 0.2);
    c.quadraticCurveTo(gx - bw/2 + 4, gy - 5, gx, gy - 8);
    c.quadraticCurveTo(gx + bw/2 - 4, gy - 5, gx + bw/2, gy + bh * 0.2);
    c.quadraticCurveTo(gx + bw/2 + 8, gy + bh * 0.5, gx + 6, gy + bh - 5);
    c.closePath();
    c.clip();
    var lg = c.createLinearGradient(gx - bw/2, liqTop, gx + bw/2, gy + bh);
    lg.addColorStop(0, liqHi);
    lg.addColorStop(1, liqCol);
    c.fillStyle = lg;
    c.fillRect(gx - bw, liqTop, bw * 2, gy + bh - liqTop + 10);
    if (this.liquidWobble > 0) {
      c.globalAlpha = this.liquidWobble * 0.3;
      for (var i = 0; i < 3; i++) {
        var rippleY = liqTop + Math.sin(this.t * 5 + i) * 2;
        c.strokeStyle = 'rgba(255,255,255,0.4)';
        c.lineWidth = 0.5;
        c.beginPath();
        c.moveTo(gx - 10, rippleY);
        c.quadraticCurveTo(gx, rippleY - 1, gx + 10, rippleY);
        c.stroke();
      }
    }
    c.globalAlpha = 0.08;
    c.fillStyle = 'rgba(255,255,255,1)';
    c.fillRect(gx - bw/2 + 2, liqTop, bw * 0.3, gy + bh - liqTop);
    c.restore();
  }
  c.strokeStyle = 'rgba(255,255,255,0.1)';
  c.lineWidth = 1;
  c.beginPath();
  c.moveTo(gx - bw/2 + 5, gy + bh * 0.3);
  c.lineTo(gx - bw/2 + 3, gy + bh * 0.6);
  c.stroke();
} else if (type === 'copper') {
  var mw = 36, mh = 55;
  c.strokeStyle = '#8a6030';
  c.lineWidth = 3;
  c.beginPath();
  c.arc(gx + mw/2 + 8, gy + mh/2, 12, -1.2, 1.2);
  c.stroke();
  var mg = c.createLinearGradient(gx - mw/2, 0, gx + mw/2, 0);
  mg.addColorStop(0, '#8a5a20');
  mg.addColorStop(0.3, '#c9883a');
  mg.addColorStop(0.5, '#daa050');
  mg.addColorStop(0.7, '#c98838');
  mg.addColorStop(1, '#8a5a20');
  c.fillStyle = mg;
  c.beginPath();
  c.roundRect(gx - mw/2, gy, mw, mh, 3);
  c.fill();
  c.strokeStyle = '#e8b860';
  c.lineWidth = 1.5;
  c.beginPath();
  c.moveTo(gx - mw/2, gy + 2);
  c.lineTo(gx + mw/2, gy + 2);
  c.stroke();
  if (fill > 0) {
    var liqTop2 = gy + mh * (1 - fill * 0.85);
    c.save();
    c.beginPath();
    c.roundRect(gx - mw/2, gy, mw, mh, 3);
    c.clip();
    var lg2 = c.createLinearGradient(0, liqTop2, 0, gy + mh);
    lg2.addColorStop(0, liqHi);
    lg2.addColorStop(1, liqCol);
    c.fillStyle = lg2;
    c.fillRect(gx - mw/2, liqTop2, mw, mh);
    if (this.liquidWobble > 0) {
      c.globalAlpha = this.liquidWobble * 0.2;
      for (var i = 0; i < 2; i++) {
        var rippleY = liqTop2 + Math.sin(this.t * 4.5 + i) * 1.5;
        c.strokeStyle = 'rgba(255,255,255,0.3)';
        c.lineWidth = 0.5;
        c.beginPath();
        c.moveTo(gx - 12, rippleY);
        c.quadraticCurveTo(gx, rippleY - 1, gx + 12, rippleY);
        c.stroke();
      }
    }
    c.restore();
  }
  c.save();
  c.globalAlpha = 0.2;
  for (var i = 0; i < 4; i++) {
    var dx2 = gx - mw/2 + 5 + i * 9, dy2 = gy + 15 + (i % 2) * 12;
    c.beginPath();
    c.ellipse(dx2, dy2, 1.5, 2.5, 0, 0, Math.PI * 2);
    c.fillStyle = '#e8d8c0';
    c.fill();
  }
  c.restore();
} else if (type === 'rocks') {
  var rw = 36, rh = 42;
  c.beginPath();
  c.moveTo(gx - rw/2 + 3, gy);
  c.lineTo(gx - rw/2, gy + rh);
  c.lineTo(gx + rw/2, gy + rh);
  c.lineTo(gx + rw/2 - 3, gy);
  c.closePath();
  c.strokeStyle = 'rgba(200,190,180,0.35)';
  c.lineWidth = 1.5;
  c.stroke();
  c.save();
  c.globalAlpha = 0.08;
  c.strokeStyle = '#fff';
  c.lineWidth = 0.5;
  for (var i = 0; i < 5; i++) {
    var cy = gy + 8 + i * 7;
    c.beginPath();
    c.moveTo(gx - rw/2 + 4, cy);
    c.lineTo(gx + rw/2 - 4, cy);
    c.stroke();
  }
  c.restore();
  if (fill > 0) {
    var liqTop3 = gy + rh * (1 - fill * 0.85);
    c.save();
    c.beginPath();
    c.moveTo(gx - rw/2 + 3, gy);
    c.lineTo(gx - rw/2, gy + rh);
    c.lineTo(gx + rw/2, gy + rh);
    c.lineTo(gx + rw/2 - 3, gy);
    c.closePath();
    c.clip();
    var lg3 = c.createLinearGradient(0, liqTop3, 0, gy + rh);
    lg3.addColorStop(0, liqHi);
    lg3.addColorStop(1, liqCol);
    c.fillStyle = lg3;
    c.fillRect(gx - rw, liqTop3, rw * 2, rh);
    if (this.liquidWobble > 0) {
      c.globalAlpha = this.liquidWobble * 0.25;
      for (var i = 0; i < 2; i++) {
        var rippleY = liqTop3 + Math.sin(this.t * 5.2 + i * 0.5) * 1.8;
        c.strokeStyle = 'rgba(255,255,255,0.4)';
        c.lineWidth = 0.5;
        c.beginPath();
        c.moveTo(gx - 12, rippleY);
        c.quadraticCurveTo(gx, rippleY - 1, gx + 12, rippleY);
        c.stroke();
      }
    }
    c.globalAlpha = 0.06;
    c.fillStyle = 'rgba(255,255,255,1)';
    c.fillRect(gx - rw/2 + 3, liqTop3, rw * 0.25, rh);
    c.restore();
  }
  c.strokeStyle = 'rgba(255,255,255,0.1)';
  c.lineWidth = 1;
  c.beginPath();
  c.moveTo(gx - rw/2 + 5, gy + 5);
  c.lineTo(gx - rw/2 + 3, gy + rh - 5);
  c.stroke();
  c.fillStyle = 'rgba(200,190,180,0.12)';
  c.fillRect(gx - rw/2 + 1, gy + rh - 6, rw - 2, 6);
}
c.restore();
}

_drawBottle(c, x, y, w, h, col, acc, lab) {
c.fillStyle = col;
var nW = 10, nH = 20, cx = x + w / 2;
c.beginPath();
c.moveTo(cx - nW/2, y);
c.lineTo(cx - nW/2, y + nH);
c.quadraticCurveTo(x + 2, y + nH + 5, x + 4, y + nH + 12);
c.lineTo(x + 4, y + h - 5);
c.quadraticCurveTo(x + 4, y + h, x + 8, y + h);
c.lineTo(x + w - 8, y + h);
c.quadraticCurveTo(x + w - 4, y + h, x + w - 4, y + h - 5);
c.lineTo(x + w - 4, y + nH + 12);
c.quadraticCurveTo(x + w - 2, y + nH + 5, cx + nW/2, y + nH);
c.lineTo(cx + nW/2, y);
c.closePath();
c.fill();
c.fillStyle = acc;
c.fillRect(x + 6, y + h * 0.35, w - 12, h * 0.3);
if (lab === 'WT') {
  // Wild Turkey — a small turkey silhouette in profile on the cream label.
  c.save();
  c.translate(cx, y + h * 0.5);
  c.fillStyle = col;
  c.strokeStyle = col;
  c.lineCap = 'round';
  c.lineJoin = 'round';
  // Tail feathers — five lines fanning up and back to the left
  c.lineWidth = 1.6;
  c.beginPath();
  for (var ti = 0; ti < 5; ti++) {
    var ang = -Math.PI + 0.30 + ti * 0.30;
    var len = 8.5;
    c.moveTo(-1, 0);
    c.lineTo(-1 + Math.cos(ang) * len, Math.sin(ang) * len);
  }
  c.stroke();
  // Body
  c.beginPath();
  c.ellipse(0, 1, 6.5, 4.2, 0.05, 0, Math.PI * 2);
  c.fill();
  // Neck — curving up and to the right
  c.lineWidth = 2;
  c.beginPath();
  c.moveTo(3, -1);
  c.quadraticCurveTo(5.5, -3.5, 6.5, -7);
  c.stroke();
  // Head
  c.beginPath();
  c.arc(6.6, -7.5, 1.9, 0, Math.PI * 2);
  c.fill();
  // Beak — small triangle pointing right
  c.beginPath();
  c.moveTo(8.2, -7.5);
  c.lineTo(10.5, -7.0);
  c.lineTo(8.2, -6.4);
  c.closePath();
  c.fill();
  // Wattle — a small red dab below the beak
  c.fillStyle = '#a01818';
  c.beginPath();
  c.arc(7.6, -5.5, 0.9, 0, Math.PI * 2);
  c.fill();
  // Tiny eye highlight on the head
  c.fillStyle = acc;
  c.beginPath();
  c.arc(7.0, -8.0, 0.4, 0, Math.PI * 2);
  c.fill();
  // Two leg lines down from body
  c.strokeStyle = col;
  c.lineWidth = 0.9;
  c.beginPath();
  c.moveTo(-1, 4.5); c.lineTo(-1.5, 7);
  c.moveTo(2, 4.5);  c.lineTo(2.5, 7);
  c.stroke();
  c.restore();
} else {
  c.fillStyle = col;
  c.font = 'bold 11px Georgia';
  c.textAlign = 'center';
  c.fillText(lab, cx, y + h * 0.35 + h * 0.15 + 4);
}
c.fillStyle = '#555';
c.fillRect(cx - nW/2 - 1, y - 3, nW + 2, 5);
c.save();
c.globalAlpha = 0.08;
c.fillStyle = '#fff';
c.fillRect(x + 6, y + nH + 14, 4, h * 0.5);
c.restore();
}

_drawAtmosphere(c) {
var W = this.W, H = this.H;
var lg1 = c.createRadialGradient(W*0.2, -30, 20, W*0.2, 80, 250);
lg1.addColorStop(0, 'rgba(255,220,150,0.08)');
lg1.addColorStop(1, 'rgba(0,0,0,0)');
c.fillStyle = lg1;
c.fillRect(0, 0, W, 180);
var lg2 = c.createRadialGradient(W*0.8, -20, 20, W*0.8, 70, 240);
lg2.addColorStop(0, 'rgba(255,180,100,0.06)');
lg2.addColorStop(1, 'rgba(0,0,0,0)');
c.fillStyle = lg2;
c.fillRect(0, 0, W, 170);
var lg3 = c.createRadialGradient(W/2, 0, 10, W/2, 120, 300);
lg3.addColorStop(0, 'rgba(255,200,100,0.12)');
lg3.addColorStop(1, 'rgba(0,0,0,0)');
c.fillStyle = lg3;
c.fillRect(0, 0, W, 250);
c.save();
c.globalAlpha = 0.25;
c.fillStyle = '#1a1a1a';
for (var i = 0; i < this.patrons.length; i++) {
  var p = this.patrons[i];
  c.beginPath();
  c.ellipse(p.x + p.w/2, p.y + 8, p.w * 0.35, p.w * 0.4, 0, 0, Math.PI * 2);
  c.fill();
  c.fillRect(p.x + p.w * 0.25, p.y + p.h * 0.4, p.w * 0.5, p.h * 0.6);
}
c.restore();
c.save();
c.globalAlpha = 0.15;
c.fillStyle = '#0a0a0a';
var sx = 80, sy = 60;
c.beginPath();
c.ellipse(sx, sy, 4, 8, 0.3, 0, Math.PI * 2);
c.fill();
c.fillRect(sx + 3, sy - 12, 2, 24);
c.beginPath();
c.ellipse(sx + 8, sy - 8, 3, 5, 0, 0, Math.PI * 2);
c.fill();
var tx = W - 90, ty = 50;
c.beginPath();
c.ellipse(tx, ty, 3, 6, 0.4, 0, Math.PI * 2);
c.fill();
c.quadraticCurveTo(tx + 8, ty - 5, tx + 12, ty);
c.stroke();
c.restore();
c.save();
c.globalAlpha = 0.08;
var neonGrad = c.createRadialGradient(W - 50, 50, 0, W - 50, 50, 60);
neonGrad.addColorStop(0, 'rgba(255, 100, 100, 0.5)');
neonGrad.addColorStop(1, 'rgba(0, 0, 0, 0)');
c.fillStyle = neonGrad;
c.fillRect(W - 100, 20, 100, 60);
c.restore();
var smokeOffsets = [
  {baseX: 0.15, baseY: 180, cols: 0.15},
  {baseX: 0.5, baseY: 200, cols: 0.2},
  {baseX: 0.85, baseY: 190, cols: 0.15}
];
for (var so = 0; so < smokeOffsets.length; so++) {
  var so_data = smokeOffsets[so];
  for (var si = 0; si < 3; si++) {
    var p = this.smokePs[si * 2];
    var sx = W * so_data.baseX + Math.sin(this.t * p.sp + p.off) * 25;
    var sy = so_data.baseY - si * 35 + Math.sin(this.t * p.sp * 0.7 + p.off) * 15;
    var sm = c.createRadialGradient(sx, sy, 0, sx, sy, 35 + si * 10);
    sm.addColorStop(0, 'rgba(120,110,140,' + (0.035 - si * 0.008) + ')');
    sm.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = sm;
    c.fillRect(sx - 40 - si * 10, sy - 40 - si * 10, 80 + si * 20, 80 + si * 20);
  }
}
c.save();
c.globalAlpha = 0.04;
var flicker = Math.sin(this.t * 3.5) * 0.5 + 0.5;
var candleGrad1 = c.createRadialGradient(100, 280, 0, 100, 280, 40);
candleGrad1.addColorStop(0, 'rgba(255,200,100,' + (flicker * 0.5) + ')');
candleGrad1.addColorStop(1, 'rgba(0,0,0,0)');
c.fillStyle = candleGrad1;
c.fillRect(70, 250, 60, 60);
var candleGrad2 = c.createRadialGradient(W - 100, 300, 0, W - 100, 300, 45);
candleGrad2.addColorStop(0, 'rgba(255,200,100,' + (flicker * 0.5) + ')');
candleGrad2.addColorStop(1, 'rgba(0,0,0,0)');
c.fillStyle = candleGrad2;
c.fillRect(W - 130, 270, 60, 60);
c.restore();
}

_drawSparkles(c) {
this.sparkles.forEach((s) => {
  c.save();
  c.globalAlpha = s.life * 0.8;
  c.fillStyle = '#ffd700';
  c.beginPath();
  c.arc(s.x, s.y, s.size, 0, Math.PI * 2);
  c.fill();
  c.globalAlpha = s.life * 0.3;
  var halo = c.createRadialGradient(s.x, s.y, s.size, s.x, s.y, s.size * 4);
  halo.addColorStop(0, 'rgba(255,215,0,0.6)');
  halo.addColorStop(1, 'rgba(0,0,0,0)');
  c.fillStyle = halo;
  c.fillRect(s.x - s.size * 4, s.y - s.size * 4, s.size * 8, s.size * 8);
  c.restore();
});
}

// ========== DRAW: CARRY PHASE ==========
_drawCarry() {
var c = this.ctx, W = this.W, H = this.H;
var cp = this.carryPhase;
var gY = cp.baseGroundY;
var progressRatio = cp.scrollPos / cp.maxScroll;

// Screen shake
var shake = cp.screenShake * 3;
c.save();
c.translate(Math.random() * shake - shake/2, Math.random() * shake - shake/2);

// Draw background
this._drawCarryBgLevel1(c, W, H, gY);


// === FINISH LINE ===
var finishWorldX = cp.maxScroll - 60;
var finishScreenX = finishWorldX - cp.scrollPos;
if (finishScreenX < W + 100 && finishScreenX > -100) {
  var finishGY = this._getTerrainY(finishWorldX);
  c.save();
  // Spotlight glow from above
  var spotGrad = c.createRadialGradient(finishScreenX, finishGY - 80, 10, finishScreenX, finishGY - 40, 120);
  spotGrad.addColorStop(0, 'rgba(255,220,120,0.25)');
  spotGrad.addColorStop(0.6, 'rgba(255,200,80,0.08)');
  spotGrad.addColorStop(1, 'rgba(255,200,80,0)');
  c.fillStyle = spotGrad;
  c.fillRect(finishScreenX - 120, 0, 240, finishGY);
  // Spotlight cone (triangle from top)
  c.globalAlpha = 0.1 + Math.sin(this.t * 2) * 0.04;
  c.fillStyle = '#ffe880';
  c.beginPath();
  c.moveTo(finishScreenX - 5, 0);
  c.lineTo(finishScreenX + 5, 0);
  c.lineTo(finishScreenX + 70, finishGY);
  c.lineTo(finishScreenX - 70, finishGY);
  c.closePath();
  c.fill();
  // Stage edge - red velvet curtain drapes on either side
  var curtainW = 25;
  // Left curtain
  c.globalAlpha = 0.7;
  var cGrad = c.createLinearGradient(finishScreenX - 65, 0, finishScreenX - 40, 0);
  cGrad.addColorStop(0, '#3a0a0a');
  cGrad.addColorStop(0.5, '#8a2020');
  cGrad.addColorStop(1, '#5a1010');
  c.fillStyle = cGrad;
  c.beginPath();
  c.moveTo(finishScreenX - 65, 0);
  c.lineTo(finishScreenX - 40, 0);
  c.quadraticCurveTo(finishScreenX - 38, finishGY * 0.3, finishScreenX - 45, finishGY * 0.5);
  c.quadraticCurveTo(finishScreenX - 38, finishGY * 0.7, finishScreenX - 40, finishGY);
  c.lineTo(finishScreenX - 65, finishGY);
  c.closePath();
  c.fill();
  // Right curtain
  var cGrad2 = c.createLinearGradient(finishScreenX + 40, 0, finishScreenX + 65, 0);
  cGrad2.addColorStop(0, '#5a1010');
  cGrad2.addColorStop(0.5, '#8a2020');
  cGrad2.addColorStop(1, '#3a0a0a');
  c.fillStyle = cGrad2;
  c.beginPath();
  c.moveTo(finishScreenX + 40, 0);
  c.lineTo(finishScreenX + 65, 0);
  c.lineTo(finishScreenX + 65, finishGY);
  c.quadraticCurveTo(finishScreenX + 38, finishGY * 0.7, finishScreenX + 45, finishGY * 0.5);
  c.quadraticCurveTo(finishScreenX + 38, finishGY * 0.3, finishScreenX + 40, 0);
  c.closePath();
  c.fill();
  // Curtain valance (top drape)
  c.globalAlpha = 0.75;
  c.fillStyle = '#6a1515';
  c.beginPath();
  c.moveTo(finishScreenX - 68, 0);
  c.lineTo(finishScreenX + 68, 0);
  c.quadraticCurveTo(finishScreenX + 50, 35, finishScreenX, 28);
  c.quadraticCurveTo(finishScreenX - 50, 35, finishScreenX - 68, 0);
  c.closePath();
  c.fill();
  // Gold fringe on valance
  c.strokeStyle = '#c9a050';
  c.lineWidth = 2;
  c.globalAlpha = 0.6;
  c.beginPath();
  c.moveTo(finishScreenX - 60, 5);
  c.quadraticCurveTo(finishScreenX, 35, finishScreenX + 60, 5);
  c.stroke();
  // Gold tassels
  c.fillStyle = '#c9a050';
  c.globalAlpha = 0.5;
  for (var tassel = 0; tassel < 5; tassel++) {
    var tX = finishScreenX - 40 + tassel * 20;
    var tY = 10 + Math.sin(tassel * 1.2) * 8 + 15;
    c.beginPath();
    c.moveTo(tX, tY);
    c.lineTo(tX - 3, tY + 10);
    c.lineTo(tX + 3, tY + 10);
    c.closePath();
    c.fill();
  }
  // "STAGE" text
  c.globalAlpha = 0.5 + Math.sin(this.t * 3) * 0.2;
  c.fillStyle = '#c9a050';
  c.font = 'bold 14px Georgia';
  c.textAlign = 'center';
  c.fillText('★ STAGE ★', finishScreenX, finishGY - 8);
  c.restore();
}

// === OBSTACLES ===
this._drawObstacles(c);

// === PLAYER ===
this._drawPlayer(c);
this._drawTray(c);

// === WOBBLE WARNING ===
if (cp.wobbling) {
  c.save();
  var wFlash = Math.sin(this.t * 10) * 0.3 + 0.7;
  c.globalAlpha = wFlash * Math.min(1, cp.wobbleTimer / 1.0);
  c.fillStyle = '#ff9040';
  c.font = 'bold 12px Georgia';
  c.textAlign = 'center';
  c.fillText('STEADY!', 100, cp.playerY - 22);
  c.restore();
}

// === STAGGER / RUBBER DUCK BONK ===
if (cp.staggerTimer > 0) {
  c.save();
  var bonkAlpha = Math.min(1, cp.staggerTimer / 0.3);
  var bonkFloat = (0.9 - cp.staggerTimer) * 25;
  var bonkScale = 1.0 + (0.9 - Math.min(0.9, cp.staggerTimer)) * 0.3;
  var bonkX = 100;
  var bonkY = cp.playerY - 50 - bonkFloat;
  var bonkRot = Math.sin(this.t * 12) * 0.15;

  c.globalAlpha = bonkAlpha;
  c.translate(bonkX, bonkY);
  c.rotate(bonkRot);
  c.scale(bonkScale, bonkScale);

  // === BIG RUBBER DUCK ===
  // Body — bright yellow
  c.fillStyle = '#ffdd00';
  c.beginPath();
  c.ellipse(0, 8, 22, 16, 0, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#d4a800';
  c.lineWidth = 1.5;
  c.stroke();
  // Belly highlight
  c.fillStyle = '#ffee55';
  c.beginPath();
  c.ellipse(-3, 10, 14, 10, -0.2, 0, Math.PI * 2);
  c.fill();
  // Head
  c.fillStyle = '#ffdd00';
  c.beginPath();
  c.arc(16, -6, 13, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#d4a800';
  c.lineWidth = 1.2;
  c.stroke();
  // Head highlight
  c.fillStyle = '#ffee55';
  c.beginPath();
  c.arc(14, -9, 7, 0, Math.PI * 2);
  c.fill();
  // Eye — big cartoon eye
  c.fillStyle = '#ffffff';
  c.beginPath();
  c.arc(20, -9, 4.5, 0, Math.PI * 2);
  c.fill();
  c.fillStyle = '#111111';
  c.beginPath();
  c.arc(21, -9, 2.5, 0, Math.PI * 2);
  c.fill();
  c.fillStyle = '#ffffff';
  c.beginPath();
  c.arc(22, -10.5, 1, 0, Math.PI * 2);
  c.fill();
  // Beak — bright orange
  c.fillStyle = '#ff8800';
  c.beginPath();
  c.moveTo(27, -6);
  c.quadraticCurveTo(36, -4, 27, -1);
  c.quadraticCurveTo(30, -3.5, 27, -6);
  c.closePath();
  c.fill();
  // Little wing
  c.fillStyle = '#eec800';
  c.beginPath();
  c.ellipse(-10, 4, 8, 5, -0.4, 0, Math.PI * 2);
  c.fill();
  // Tail tuft
  c.fillStyle = '#ffdd00';
  c.beginPath();
  c.moveTo(-20, 2);
  c.lineTo(-26, -2);
  c.lineTo(-23, 4);
  c.lineTo(-27, 3);
  c.lineTo(-22, 7);
  c.closePath();
  c.fill();

  // "BONK!" text coming from the duck
  c.fillStyle = '#ff2020';
  c.font = 'bold 16px Georgia';
  c.textAlign = 'center';
  c.fillText('BONK!', 0, -24);

  c.restore();
}

// === SMOKE WISPS ===
c.save();
c.globalAlpha = 0.06;
for (var i = 0; i < 5; i++) {
  var smokeX = ((i * 190) - cp.scrollPos * 0.4) % (W + 200);
  if (smokeX < -100) smokeX += W + 300;
  var smokeY = 80 + Math.sin(this.t * 0.3 + i * 1.7) * 30;
  var sm = c.createRadialGradient(smokeX, smokeY, 0, smokeX, smokeY, 60 + Math.sin(this.t * 0.5 + i) * 20);
  sm.addColorStop(0, 'rgba(200, 180, 160, 0.5)');
  sm.addColorStop(1, 'rgba(0,0,0,0)');
  c.fillStyle = sm;
  c.fillRect(smokeX - 80, smokeY - 60, 160, 120);
}
c.restore();

c.restore(); // end screen shake

// === UI: Glass counter ===
c.save();
c.fillStyle = 'rgba(10, 8, 4, 0.85)';
c.fillRect(0, 0, 130, 50);
c.strokeStyle = 'rgba(200, 180, 160, 0.4)';
c.lineWidth = 1;
c.strokeRect(0, 0, 130, 50);
c.fillStyle = '#d4a574';
c.font = '11px Georgia';
c.fillText('Glasses left:', 8, 20);
// Draw mini glasses
for (var i = 0; i < 3; i++) {
  var gAlive = i < cp.glassesLeft;
  c.fillStyle = gAlive ? '#c9a050' : '#3a2a1a';
  c.fillRect(10 + i * 22, 28, 8, 14);
  if (gAlive) {
    c.fillStyle = '#e8c060';
    c.fillRect(11 + i * 22, 34, 6, 7);
  }
  c.strokeStyle = gAlive ? '#d4a574' : '#2a1a10';
  c.lineWidth = 0.8;
  c.strokeRect(10 + i * 22, 28, 8, 14);
}
c.restore();

// === UI: Progress bar ===
var pW = (cp.scrollPos / cp.maxScroll) * (W - 40);
c.save();
c.fillStyle = 'rgba(30, 20, 10, 0.7)';
c.fillRect(20, H - 22, W - 40, 12);
var pGrad = c.createLinearGradient(20, 0, 20 + pW, 0);
pGrad.addColorStop(0, '#8a6030');
pGrad.addColorStop(1, '#d4a574');
c.fillStyle = pGrad;
c.fillRect(20, H - 22, pW, 12);
c.strokeStyle = 'rgba(200, 180, 160, 0.3)';
c.lineWidth = 0.8;
c.strokeRect(20, H - 22, W - 40, 12);
c.fillStyle = '#8a7a6a';
c.font = '8px Georgia';
c.textAlign = 'left';
c.fillText('BAR', 22, H - 12);
c.textAlign = 'right';
c.fillText('STAGE', W - 22, H - 12);
c.textAlign = 'left';
c.restore();
}

// ========== BACKGROUND: LEVEL 1 - THE FLOOR ==========
_drawCarryBgLevel1(c, W, H, gY) {
var cp = this.carryPhase;

// === CEILING ===
var ceilGrad = c.createLinearGradient(0, 0, 0, 40);
ceilGrad.addColorStop(0, '#0a0604');
ceilGrad.addColorStop(1, '#1a0f0a');
c.fillStyle = ceilGrad;
c.fillRect(0, 0, W, 40);
// Ceiling beams
c.fillStyle = '#2a1a10';
for (var i = 0; i < 10; i++) {
  var beamX = ((-cp.scrollPos * 0.8) % 180) + i * 180;
  c.fillRect(beamX, 0, 12, 40);
  c.fillStyle = '#1a1008';
  c.fillRect(beamX + 1, 0, 2, 40);
  c.fillStyle = '#2a1a10';
}

// === BACK WALL ===
var wallGrad = c.createLinearGradient(0, 40, 0, gY);
wallGrad.addColorStop(0, '#2d1810');
wallGrad.addColorStop(0.4, '#3a2018');
wallGrad.addColorStop(1, '#251510');
c.fillStyle = wallGrad;
c.fillRect(0, 40, W, gY - 40);

// Brick texture (subtle)
c.save();
c.globalAlpha = 0.06;
c.fillStyle = '#5a3a28';
for (var row = 0; row < 12; row++) {
  var brickOff = (row % 2) * 35;
  for (var col = 0; col < 10; col++) {
    var bx = ((-cp.scrollPos * 0.15) % 70) + brickOff + col * 70;
    c.fillRect(bx, 45 + row * 22, 65, 18);
  }
}
c.restore();

// Wainscoting follows terrain
c.save();
c.beginPath();
for (var screenX = 0; screenX <= W; screenX += 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  if (screenX === 0) c.moveTo(screenX, terrainY - 70);
  else c.lineTo(screenX, terrainY - 70);
}
for (var screenX = W; screenX >= 0; screenX -= 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  c.lineTo(screenX, terrainY);
}
c.closePath();
c.fillStyle = '#201008';
c.fill();
// Top edge line
c.beginPath();
for (var screenX = 0; screenX <= W; screenX += 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  if (screenX === 0) c.moveTo(screenX, terrainY - 70);
  else c.lineTo(screenX, terrainY - 70);
}
c.strokeStyle = '#3a2818';
c.lineWidth = 1;
c.stroke();
// Panel details (simplified - using base terrain for consistency)
for (var i = 0; i < 12; i++) {
  var panX = ((-cp.scrollPos * 0.8) % 160) + i * 160;
  var panWorldX = cp.scrollPos + panX;
  var panTerrainY = this._getTerrainY(panWorldX);
  c.strokeStyle = '#2a1a10';
  c.lineWidth = 0.8;
  c.strokeRect(panX + 8, panTerrainY - 65, 140, 58);
}
c.restore();

// Framed photos / posters on wall (parallax slow)
var posters = [
  {off: 50, w: 45, h: 55, col: '#4a3828', label: 'MONK'},
  {off: 320, w: 40, h: 50, col: '#3a3040', label: 'MILES'},
  {off: 600, w: 50, h: 40, col: '#2a3a28', label: 'BIRD'},
  {off: 880, w: 42, h: 52, col: '#4a2828', label: 'TRANE'},
  {off: 1150, w: 48, h: 45, col: '#3a3828', label: 'MINGUS'},
  {off: 1450, w: 44, h: 50, col: '#2a2840', label: 'EVANS'}
];
for (var i = 0; i < posters.length; i++) {
  var p = posters[i];
  var pX = p.off - cp.scrollPos * 0.25;
  if (pX > -60 && pX < W + 10) {
    c.fillStyle = '#4a3a28';
    c.fillRect(pX - 3, 70 - 3, p.w + 6, p.h + 6);
    c.fillStyle = p.col;
    c.fillRect(pX, 70, p.w, p.h);
    c.fillStyle = '#d4c8a0';
    c.font = 'bold 7px Georgia';
    c.textAlign = 'center';
    c.fillText(p.label, pX + p.w/2, 70 + p.h - 6);
    c.textAlign = 'left';
    c.fillStyle = '#0a0a0a';
    c.beginPath();
    c.arc(pX + p.w/2, 70 + p.h/2 - 8, 6, 0, Math.PI * 2);
    c.fill();
    c.fillRect(pX + p.w/2 - 4, 70 + p.h/2 - 2, 8, 14);
  }
}

// Seated patrons at tables (mid-ground parallax)
for (var i = 0; i < 6; i++) {
  var tX = 80 + i * 450 - cp.scrollPos * 0.5;
  if (tX > -120 && tX < W + 50) {
    var patronTerrainY = this._getTerrainY(cp.scrollPos + tX);
    c.save();
    c.globalAlpha = 0.5;
    c.fillStyle = '#1a1210';
    c.beginPath();
    c.ellipse(tX, patronTerrainY - 30, 30, 8, 0, 0, Math.PI * 2);
    c.fill();
    c.fillRect(tX - 3, patronTerrainY - 24, 6, 24);
    c.fillStyle = 'rgba(200,180,140,0.4)';
    c.fillRect(tX - 8, patronTerrainY - 38, 4, 8);
    c.fillRect(tX + 4, patronTerrainY - 36, 4, 6);
    c.fillStyle = '#0e0a08';
    c.beginPath();
    c.arc(tX - 30, patronTerrainY - 50, 8, 0, Math.PI * 2);
    c.fill();
    c.fillRect(tX - 36, patronTerrainY - 42, 12, 20);
    c.fillRect(tX - 38, patronTerrainY - 22, 16, 22);
    if (i % 2 === 0) {
      c.beginPath();
      c.arc(tX + 28, patronTerrainY - 48, 7, 0, Math.PI * 2);
      c.fill();
      c.fillRect(tX + 22, patronTerrainY - 41, 12, 18);
      c.fillRect(tX + 20, patronTerrainY - 23, 16, 23);
    }
    c.restore();
  }
}

// === FLOOR (terrain-following) ===
c.save();
c.beginPath();
// Walk along the terrain contour across the visible screen
var startWorldX = cp.scrollPos;
var endWorldX = cp.scrollPos + W;
c.moveTo(0, this._getTerrainY(startWorldX));
// Sample terrain across screen width
for (var screenX = 0; screenX <= W; screenX += 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  c.lineTo(screenX, terrainY);
}
// Close the polygon at the bottom
c.lineTo(W, H);
c.lineTo(0, H);
c.closePath();
var floorGrad = c.createLinearGradient(0, 280, 0, H);
floorGrad.addColorStop(0, '#2a1a10');
floorGrad.addColorStop(0.3, '#221610');
floorGrad.addColorStop(1, '#1a100a');
c.fillStyle = floorGrad;
c.fill();
c.restore();

// Floorboard lines (vertical, terrain-following)
c.strokeStyle = 'rgba(60, 40, 25, 0.5)';
c.lineWidth = 0.8;
for (var i = 0; i < 15; i++) {
  var bX = ((-cp.scrollPos * 1.0) % 120) + i * 120;
  var terrainAtBoard = this._getTerrainY(cp.scrollPos + bX);
  c.beginPath();
  c.moveTo(bX, terrainAtBoard);
  c.lineTo(bX, H);
  c.stroke();
}
// Horizontal plank seam also follows terrain
c.beginPath();
for (var screenX = 0; screenX <= W; screenX += 8) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  if (screenX === 0) c.moveTo(screenX, terrainY + 30);
  else c.lineTo(screenX, terrainY + 30);
}
c.stroke();

// Floor highlight strip follows terrain
c.save();
c.globalAlpha = 0.06;
c.fillStyle = '#c9a060';
c.beginPath();
for (var screenX = 0; screenX <= W; screenX += 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  if (screenX === 0) c.moveTo(screenX, terrainY);
  else c.lineTo(screenX, terrainY);
}
for (var screenX = W; screenX >= 0; screenX -= 4) {
  var worldX = cp.scrollPos + screenX;
  var terrainY = this._getTerrainY(worldX);
  c.lineTo(screenX, terrainY + 4);
}
c.closePath();
c.fill();
c.restore();

// Spotlight pools on floor
c.save();
for (var i = 0; i < 3; i++) {
  var spotX = 140 + i * 500 - cp.scrollPos * 0.6;
  if (spotX > -100 && spotX < W + 100) {
    var spotTerrainY = this._getTerrainY(cp.scrollPos + spotX);
    var spot = c.createRadialGradient(spotX, spotTerrainY + 5, 0, spotX, spotTerrainY + 5, 70);
    spot.addColorStop(0, 'rgba(255,220,140,0.08)');
    spot.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = spot;
    c.fillRect(spotX - 70, spotTerrainY - 20, 140, 80);
  }
}
c.restore();

// === SMOKE WISPS ===
c.save();
c.globalAlpha = 0.06;
for (var i = 0; i < 5; i++) {
  var smokeX = ((i * 190) - cp.scrollPos * 0.4) % (W + 200);
  if (smokeX < -100) smokeX += W + 300;
  var smokeY = 80 + Math.sin(this.t * 0.3 + i * 1.7) * 30;
  var sm = c.createRadialGradient(smokeX, smokeY, 0, smokeX, smokeY, 60 + Math.sin(this.t * 0.5 + i) * 20);
  sm.addColorStop(0, 'rgba(200, 180, 160, 0.5)');
  sm.addColorStop(1, 'rgba(0,0,0,0)');
  c.fillStyle = sm;
  c.fillRect(smokeX - 80, smokeY - 60, 160, 120);
}
c.restore();
}

_drawObstacles(c) {
var cp = this.carryPhase;
var W = this.W;
var pulse = 0.55 + Math.sin(this.t * 4) * 0.35;

for (var i = 0; i < cp.obstacles.length; i++) {
  var obs = cp.obstacles[i];
  var ox = obs.x - cp.scrollPos;
  if (ox > -150 && ox < W + 50) {
    if (obs.hit) { c.globalAlpha = 0.35; }
    if (obs.isHigh) {
      // === RED DANGER ZONE behind high obstacles ===
      var hCx = ox + obs.width / 2;
      var hBottom = obs.height;
      // Wide red-tinted danger stripe area
      c.save();
      var dangerW = obs.width + 40;
      var dangerX = ox - 20;
      // Red translucent column from ceiling to obstacle bottom
      var dangerGrad = c.createLinearGradient(0, 0, 0, hBottom + 30);
      dangerGrad.addColorStop(0, 'rgba(180,40,40,0.12)');
      dangerGrad.addColorStop(0.7, 'rgba(200,50,30,0.18)');
      dangerGrad.addColorStop(1, 'rgba(200,60,30,0.05)');
      c.fillStyle = dangerGrad;
      c.fillRect(dangerX, 0, dangerW, hBottom + 30);
      // Diagonal warning stripes
      c.globalAlpha = 0.08 + pulse * 0.06;
      c.strokeStyle = '#ff4040';
      c.lineWidth = 3;
      for (var stripe = -8; stripe < 12; stripe++) {
        var sx = dangerX + stripe * 12;
        c.beginPath();
        c.moveTo(sx, 0);
        c.lineTo(sx + hBottom * 0.4, hBottom + 20);
        c.stroke();
      }
      c.restore();

      // Draw the obstacle itself
      if (obs.style === 1) this._drawHighObs1(c, obs.type, ox, obs.width, obs.height);
      else if (obs.style === 2) this._drawHighObs2(c, obs.type, ox, obs.width, obs.height);
      else this._drawHighObs3(c, obs.type, ox, obs.width, obs.height);

      // === MALLARD DUCKS — waddle normally or scatter in panic ===
      if (!obs.hit) {
        c.save();
        var dSeed = obs.x * 7.3;
        var numDucks = 2 + Math.floor((dSeed % 3));
        var isScattered = obs.scattered;
        var scatterElapsed = isScattered ? (this.t - obs.scatterTime) : 0;

        // Feather particles when scattering
        if (isScattered && scatterElapsed < 2.0) {
          c.save();
          var featherAlpha = Math.max(0, 1.0 - scatterElapsed / 2.0);
          c.globalAlpha = featherAlpha * 0.6;
          for (var fi = 0; fi < 8; fi++) {
            var fSeed = dSeed + fi * 17.3;
            var fAngle = (fSeed % 6.28) + scatterElapsed * (2 + (fi % 3));
            var fDist = scatterElapsed * (40 + (fSeed % 30));
            var fX = hCx + Math.cos(fAngle) * fDist;
            var fY = hBottom + 22 - scatterElapsed * (20 + fi * 8) + Math.sin(this.t * 6 + fi) * 5;
            var fRot = this.t * 8 + fi * 2;
            c.save();
            c.translate(fX, fY);
            c.rotate(fRot);
            c.fillStyle = (fi % 3 === 0) ? '#5a4a30' : (fi % 3 === 1) ? '#1a6a30' : '#e8e8d0';
            c.beginPath();
            c.ellipse(0, 0, 3, 1.2, 0, 0, Math.PI * 2);
            c.fill();
            c.restore();
          }
          c.restore();
        }

        for (var di = 0; di < numDucks; di++) {
          // Base position
          var duckRestX = ox - 18 + di * (obs.width / numDucks + 10) + Math.sin(dSeed + di * 2.1) * 8;
          var duckRestY = hBottom + 22 + Math.sin(dSeed + di * 3.7) * 4;
          var duckX, duckY, duckRot, duckAlpha, flapping;

          if (isScattered && scatterElapsed < 2.5) {
            // SCATTER! Each duck flies off in a different direction
            var scatterAngle = -0.8 - di * 0.5 + (di % 2 === 0 ? -0.6 : 0.6);
            var scatterSpeed = 80 + di * 25;
            var flyT = Math.min(scatterElapsed, 2.0);
            duckX = duckRestX + Math.cos(scatterAngle) * scatterSpeed * flyT;
            duckY = duckRestY + Math.sin(scatterAngle) * scatterSpeed * flyT - flyT * 50;
            duckRot = scatterAngle * 0.4 + Math.sin(this.t * 15 + di) * 0.3;
            duckAlpha = Math.max(0, 1.0 - scatterElapsed / 2.2);
            flapping = true;
          } else if (isScattered) {
            continue; // ducks have flown away
          } else {
            // Normal waddling
            var waddle = Math.sin(this.t * 4 + di * 2.3) * 2;
            var bobY = Math.sin(this.t * 3.5 + di * 1.8) * 1.5;
            duckX = duckRestX + waddle;
            duckY = duckRestY + bobY;
            duckRot = 0;
            duckAlpha = 1;
            flapping = false;
          }

          c.save();
          c.globalAlpha = duckAlpha;
          c.translate(duckX, duckY);
          c.rotate(duckRot);

          // Body
          c.fillStyle = '#5a4a30';
          c.beginPath();
          c.ellipse(0, 0, 8, 5, 0, 0, Math.PI * 2);
          c.fill();
          // Breast
          c.fillStyle = '#6a3a20';
          c.beginPath();
          c.ellipse(5, 1, 4, 4, 0, 0, Math.PI * 2);
          c.fill();
          // Head — iridescent green
          c.fillStyle = '#1a6a30';
          c.beginPath();
          c.arc(9, -4, 4, 0, Math.PI * 2);
          c.fill();
          // Eye — wide open if panicking
          c.fillStyle = '#111';
          c.beginPath();
          c.arc(10.5, -5, flapping ? 1.2 : 0.8, 0, Math.PI * 2);
          c.fill();
          // Beak — open if panicking
          c.fillStyle = '#d4a030';
          if (flapping) {
            // Open beak — top
            c.beginPath();
            c.moveTo(13, -5.5);
            c.lineTo(18, -5);
            c.lineTo(13, -3.5);
            c.closePath();
            c.fill();
            // Open beak — bottom
            c.fillStyle = '#c08020';
            c.beginPath();
            c.moveTo(13, -3);
            c.lineTo(17, -1.5);
            c.lineTo(13, -1.5);
            c.closePath();
            c.fill();
          } else {
            c.beginPath();
            c.moveTo(13, -4);
            c.lineTo(17, -3.5);
            c.lineTo(13, -2.5);
            c.closePath();
            c.fill();
          }
          // White neck ring
          c.strokeStyle = '#e8e8e8';
          c.lineWidth = 1;
          c.beginPath();
          c.arc(9, -4, 4.5, 1.2, 2.0);
          c.stroke();
          // Wings — flapping if scattered
          if (flapping) {
            var wingAngle = Math.sin(this.t * 18 + di * 3) * 0.8;
            // Left wing
            c.save();
            c.fillStyle = '#4a3a25';
            c.translate(-4, -2);
            c.rotate(-0.5 + wingAngle);
            c.beginPath();
            c.ellipse(0, -6, 4, 8, 0, 0, Math.PI * 2);
            c.fill();
            c.restore();
            // Right wing
            c.save();
            c.fillStyle = '#4a3a25';
            c.translate(-4, -2);
            c.rotate(-0.5 - wingAngle);
            c.beginPath();
            c.ellipse(0, 6, 4, 8, 0, 0, Math.PI * 2);
            c.fill();
            c.restore();
          }
          // Tail
          c.fillStyle = '#3a3a2a';
          c.beginPath();
          c.moveTo(-7, -2);
          c.lineTo(-12, -4);
          c.lineTo(-10, 0);
          c.closePath();
          c.fill();
          // Feet (tucked up if flying)
          if (!flapping) {
            c.fillStyle = '#d48030';
            c.fillRect(-2, 4, 3, 2);
            c.fillRect(3, 4, 3, 2);
          } else {
            c.fillStyle = '#d48030';
            c.fillRect(0, 3, 2, 3);
            c.fillRect(4, 4, 2, 2);
          }
          c.restore();
        }
        c.restore();
      }

      // DUCK cue - bigger, bolder, with pulsing border
      if (!obs.hit) {
        c.save();
        // Thick pulsing red line at obstacle bottom
        c.globalAlpha = 0.5 + pulse * 0.4;
        c.strokeStyle = '#ff4040';
        c.lineWidth = 3;
        c.setLineDash([8, 5]);
        c.beginPath();
        c.moveTo(ox - 10, hBottom);
        c.lineTo(ox + obs.width + 10, hBottom);
        c.stroke();
        c.setLineDash([]);
        c.restore();
        // Large DUCK text with dark backing
        c.save();
        c.globalAlpha = pulse * 0.9;
        c.fillStyle = 'rgba(80,0,0,0.5)';
        c.fillRect(hCx - 30, hBottom + 2, 60, 20);
        c.fillStyle = '#ff5050';
        c.font = 'bold 16px Georgia';
        c.textAlign = 'center';
        c.fillText('\u2193 DUCK!', hCx, hBottom + 17);
        c.restore();
        // Down arrows flanking the obstacle
        c.save();
        c.globalAlpha = pulse * 0.6;
        c.fillStyle = '#ff5050';
        c.font = 'bold 18px Georgia';
        c.textAlign = 'center';
        c.fillText('\u25BC', ox - 8, hBottom - 10);
        c.fillText('\u25BC', ox + obs.width + 8, hBottom - 10);
        c.restore();
      }
    } else if (obs.isGap) {
      // FLOOR GAP — dramatic pit/hole in the pub floor
      var gapCx = ox + obs.width / 2;
      var gapTop = obs.y;
      var gapH = this.H - gapTop; // extends to bottom of canvas
      c.save();

      // Deep black pit
      var pitGrad = c.createLinearGradient(0, gapTop, 0, gapTop + 60);
      pitGrad.addColorStop(0, '#080404');
      pitGrad.addColorStop(0.4, '#030202');
      pitGrad.addColorStop(1, '#000000');
      c.fillStyle = pitGrad;
      c.fillRect(ox - 2, gapTop, obs.width + 4, gapH);

      // Amber glow from below (like there's a cellar down there)
      var cellarGlow = c.createRadialGradient(gapCx, gapTop + 40, 5, gapCx, gapTop + 30, obs.width * 0.7);
      cellarGlow.addColorStop(0, 'rgba(200,120,40,0.15)');
      cellarGlow.addColorStop(1, 'rgba(200,120,40,0)');
      c.fillStyle = cellarGlow;
      c.fillRect(ox - 20, gapTop + 5, obs.width + 40, 70);

      // Broken floorboard edges on left side
      c.fillStyle = '#5a3a20';
      c.beginPath();
      c.moveTo(ox - 2, gapTop);
      c.lineTo(ox + 8, gapTop);
      c.lineTo(ox + 5, gapTop + 20);
      c.lineTo(ox + 10, gapTop + 35);
      c.lineTo(ox + 3, gapTop + 50);
      c.lineTo(ox - 2, gapTop + 40);
      c.closePath();
      c.fill();
      c.strokeStyle = '#3a2210';
      c.lineWidth = 1;
      c.stroke();

      // Broken floorboard edges on right side
      c.beginPath();
      c.moveTo(ox + obs.width + 2, gapTop);
      c.lineTo(ox + obs.width - 6, gapTop);
      c.lineTo(ox + obs.width - 3, gapTop + 18);
      c.lineTo(ox + obs.width - 8, gapTop + 30);
      c.lineTo(ox + obs.width - 2, gapTop + 45);
      c.lineTo(ox + obs.width + 2, gapTop + 38);
      c.closePath();
      c.fill();
      c.stroke();

      // Splintered wood pieces hanging
      c.fillStyle = '#4a2a15';
      c.save();
      c.translate(ox + 12, gapTop);
      c.rotate(0.3);
      c.fillRect(0, 0, 4, 18);
      c.restore();
      c.save();
      c.translate(ox + obs.width - 10, gapTop);
      c.rotate(-0.2);
      c.fillRect(0, 0, 3, 14);
      c.restore();

      // Top edge shadow — dark gradient spreading outward
      c.globalAlpha = 0.6;
      var topShadow = c.createLinearGradient(0, gapTop - 8, 0, gapTop + 12);
      topShadow.addColorStop(0, 'rgba(0,0,0,0)');
      topShadow.addColorStop(0.5, 'rgba(0,0,0,0.6)');
      topShadow.addColorStop(1, 'rgba(0,0,0,0.3)');
      c.fillStyle = topShadow;
      c.fillRect(ox - 10, gapTop - 8, obs.width + 20, 20);
      c.globalAlpha = 1;

      // Pulsing amber warning markers on edges
      c.globalAlpha = 0.4 + pulse * 0.3;
      c.fillStyle = '#ffaa40';
      // Left warning dot
      c.beginPath();
      c.arc(ox - 4, gapTop + 3, 3, 0, Math.PI * 2);
      c.fill();
      // Right warning dot
      c.beginPath();
      c.arc(ox + obs.width + 4, gapTop + 3, 3, 0, Math.PI * 2);
      c.fill();
      c.globalAlpha = 1;

      // === MUSIC NOTES drifting up from the jazz abyss ===
      var noteChars = ['\u266A', '\u266B', '\u266C', '\u2669'];
      var noteSeed = obs.x * 3.7;
      for (var ni = 0; ni < 10; ni++) {
        // Each note has its own cycle based on time + seed
        var notePhase = (this.t * 0.55 + ni * 0.9 + noteSeed * 0.01) % 3.0;
        var noteRise = notePhase / 3.0; // 0 to 1 as it rises
        var noteX = ox + 6 + (ni * (obs.width - 12) / 9) + Math.sin(this.t * 1.5 + ni * 2.1) * 10;
        var noteY = gapTop + 60 - noteRise * 130; // rises from deep in pit to well above
        var noteAlpha = 0;
        if (noteRise < 0.12) noteAlpha = noteRise / 0.12; // fade in
        else if (noteRise > 0.78) noteAlpha = (1.0 - noteRise) / 0.22; // fade out at top
        else noteAlpha = 1.0;
        noteAlpha *= 0.9; // much more visible than before
        // Let them drift higher above the pit before clipping
        if (noteY < gapTop - 45 || noteY > gapTop + 70) continue;
        c.save();
        c.globalAlpha = noteAlpha;
        // Brighter gold tones
        c.fillStyle = (ni % 2 === 0) ? '#f0c060' : '#ffd070';
        c.font = 'bold ' + (13 + (ni % 3) * 2) + 'px Georgia';
        c.textAlign = 'center';
        c.shadowColor = 'rgba(255,180,60,0.55)';
        c.shadowBlur = 6;
        var noteRot = Math.sin(this.t * 2 + ni * 1.7) * 0.35;
        c.translate(noteX, noteY);
        c.rotate(noteRot);
        c.fillText(noteChars[ni % noteChars.length], 0, 0);
        c.restore();
      }

      c.restore();

      // JUMP cue — amber/orange for gaps, distinct from green JUMP
      if (!obs.hit) {
        c.save();
        c.globalAlpha = pulse * 0.9;
        c.fillStyle = 'rgba(60,30,0,0.6)';
        c.fillRect(gapCx - 30, gapTop - 28, 60, 22);
        c.strokeStyle = 'rgba(255,170,64,0.4)';
        c.lineWidth = 1;
        c.strokeRect(gapCx - 30, gapTop - 28, 60, 22);
        c.fillStyle = '#ffaa40';
        c.font = 'bold 15px Georgia';
        c.textAlign = 'center';
        c.fillText('\u2191 JUMP!', gapCx, gapTop - 11);
        c.restore();
      }
    } else {
      if (obs.style === 1) this._drawLowObs1(c, obs.type, ox, obs.y, obs.width, obs.height);
      else if (obs.style === 2) this._drawLowObs2(c, obs.type, ox, obs.y, obs.width, obs.height);
      else this._drawLowObs3(c, obs.type, ox, obs.y, obs.width, obs.height);
      // JUMP cue - green with backing
      if (!obs.hit) {
        var cx = ox + obs.width / 2;
        c.save();
        c.globalAlpha = pulse * 0.85;
        c.fillStyle = 'rgba(0,40,0,0.4)';
        c.fillRect(cx - 28, obs.y - 22, 56, 18);
        c.fillStyle = '#60ff90';
        c.font = 'bold 14px Georgia';
        c.textAlign = 'center';
        c.fillText('\u2191 JUMP', cx, obs.y - 8);
        c.restore();
      }
    }
    if (obs.hit) { c.globalAlpha = 1; }
  }
}
}

// === HIGH OBSTACLES (hang from ceiling, duck under) ===
_drawHighObs1(c, type, x, w, h) {
var cx = x + w/2;
var bottom = h; // bottom edge of the obstacle zone
// Danger glow behind high obstacles so they stand out
var dg = c.createRadialGradient(cx, bottom - 20, 5, cx, bottom, 50);
dg.addColorStop(0, 'rgba(255,80,80,0.15)');
dg.addColorStop(1, 'rgba(255,80,80,0)');
c.fillStyle = dg;
c.fillRect(cx - 50, bottom - 60, 100, 70);
if (type === 0) {
  // Hanging lamp with wide shade
  c.fillStyle = '#3a3530';
  c.fillRect(cx - 1, 0, 2, bottom - 40); // cord
  // Shade - wide cone
  c.fillStyle = '#c9a050';
  c.beginPath();
  c.moveTo(cx - 28, bottom);
  c.lineTo(cx - 8, bottom - 35);
  c.lineTo(cx + 8, bottom - 35);
  c.lineTo(cx + 28, bottom);
  c.closePath();
  c.fill();
  c.strokeStyle = '#a08030';
  c.lineWidth = 1.5;
  c.stroke();
  // Warm light glow
  var lg = c.createRadialGradient(cx, bottom, 5, cx, bottom + 20, 60);
  lg.addColorStop(0, 'rgba(255,220,120,0.25)');
  lg.addColorStop(1, 'rgba(255,200,80,0)');
  c.fillStyle = lg;
  c.fillRect(cx - 60, bottom - 10, 120, 80);
  // Bulb
  c.fillStyle = '#ffe880';
  c.beginPath();
  c.arc(cx, bottom - 8, 4, 0, Math.PI * 2);
  c.fill();
} else if (type === 1) {
  // Low-hanging speaker/monitor wedge on a bracket
  c.fillStyle = '#2a2a2a';
  c.fillRect(cx - 3, 0, 6, bottom - 50); // mounting pole
  // Bracket
  c.fillStyle = '#444';
  c.fillRect(cx - 22, bottom - 52, 44, 6);
  // Speaker box
  c.fillStyle = '#1a1a1a';
  c.fillRect(cx - 20, bottom - 46, 40, 46);
  c.strokeStyle = '#333';
  c.lineWidth = 1.5;
  c.strokeRect(cx - 20, bottom - 46, 40, 46);
  // Speaker cone
  c.fillStyle = '#2a2a2a';
  c.beginPath();
  c.arc(cx, bottom - 24, 12, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#444';
  c.lineWidth = 1;
  c.stroke();
  c.beginPath();
  c.arc(cx, bottom - 24, 5, 0, Math.PI * 2);
  c.fill();
  // Mesh grille lines
  c.strokeStyle = '#333';
  c.lineWidth = 0.5;
  for (var g = -16; g <= 16; g += 4) {
    c.beginPath();
    c.moveTo(cx - 18, bottom - 24 + g);
    c.lineTo(cx + 18, bottom - 24 + g);
    c.stroke();
  }
} else {
  // Bunting / banner hanging across the path
  c.fillStyle = '#3a3530';
  c.fillRect(x, 0, 2, bottom - 20); // left cord
  c.fillRect(x + w - 2, 0, 2, bottom - 20); // right cord
  // Sagging rope
  c.strokeStyle = '#8a7a60';
  c.lineWidth = 2;
  c.beginPath();
  c.moveTo(x, bottom - 20);
  c.quadraticCurveTo(cx, bottom + 5, x + w, bottom - 20);
  c.stroke();
  // Triangular pennants
  var cols = ['#8b3030','#c9a050','#3a5a8a','#6a8a3a','#8a5a8a'];
  var segs = 6;
  for (var p = 0; p < segs; p++) {
    var t1 = p / segs, t2 = (p + 0.5) / segs;
    var px1 = x + t1 * w;
    var py1 = (bottom - 20) + Math.sin(t1 * Math.PI) * 25;
    var px2 = x + t2 * w;
    var py2 = (bottom - 20) + Math.sin(t2 * Math.PI) * 25;
    var px3 = (px1 + px2) / 2;
    var py3 = py2 + 18;
    c.fillStyle = cols[p % cols.length];
    c.beginPath();
    c.moveTo(px1, py1);
    c.lineTo(px2, py2);
    c.lineTo(px3, py3);
    c.closePath();
    c.fill();
  }
}
}

// === LOW OBSTACLES (on the ground, jump over) ===
_drawLowObs1(c, type, x, y, w, h) {
var cx = x + w/2;
var gY = y + h;
if (type === 0) {
  // Toppled bar stool
  var seatY = y + 4;
  // Seat (circle, tilted)
  c.fillStyle = '#6a4030';
  c.beginPath();
  c.ellipse(cx, seatY, w/2 - 4, 8, 0.15, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#4a2a18';
  c.lineWidth = 1.5;
  c.stroke();
  // Padded top
  c.fillStyle = '#8a5a40';
  c.beginPath();
  c.ellipse(cx, seatY - 3, w/2 - 8, 5, 0.15, 0, Math.PI * 2);
  c.fill();
  // Central pole (angled because toppled)
  c.strokeStyle = '#888';
  c.lineWidth = 3;
  c.beginPath();
  c.moveTo(cx, seatY + 6);
  c.lineTo(cx + 12, gY);
  c.stroke();
  // Foot ring
  c.strokeStyle = '#777';
  c.lineWidth = 2;
  c.beginPath();
  c.ellipse(cx + 8, gY - 8, 10, 3, 0, 0, Math.PI * 2);
  c.stroke();
  // Base
  c.fillStyle = '#666';
  c.beginPath();
  c.ellipse(cx + 10, gY - 2, 14, 4, 0, 0, Math.PI * 2);
  c.fill();
} else if (type === 1) {
  // Instrument case (saxophone or guitar)
  var caseH = h - 2;
  var caseW = w - 4;
  // Main case body
  c.fillStyle = '#1a1a1a';
  c.beginPath();
  c.moveTo(x + 4, gY);
  c.lineTo(x + 4, y + 6);
  c.quadraticCurveTo(cx, y, x + w - 4, y + 6);
  c.lineTo(x + w - 4, gY);
  c.closePath();
  c.fill();
  // Case edge
  c.strokeStyle = '#444';
  c.lineWidth = 1.5;
  c.stroke();
  // Latches
  c.fillStyle = '#c9a050';
  c.fillRect(cx - 12, y + caseH * 0.3, 5, 4);
  c.fillRect(cx + 7, y + caseH * 0.3, 5, 4);
  // Handle
  c.strokeStyle = '#888';
  c.lineWidth = 2.5;
  c.beginPath();
  c.moveTo(cx - 8, y + 4);
  c.quadraticCurveTo(cx, y - 2, cx + 8, y + 4);
  c.stroke();
  // Brand label
  c.fillStyle = '#c9a050';
  c.font = 'italic 8px Georgia';
  c.textAlign = 'center';
  c.fillText('SELMER', cx, y + caseH * 0.6);
} else {
  // Crate of beer bottles
  var crateW = w - 6, crateH = h - 2;
  // Wooden crate
  c.fillStyle = '#5a3a20';
  c.fillRect(x + 3, y + 4, crateW, crateH - 4);
  c.strokeStyle = '#3a2210';
  c.lineWidth = 1.5;
  c.strokeRect(x + 3, y + 4, crateW, crateH - 4);
  // Horizontal slat
  c.fillStyle = '#4a2a15';
  c.fillRect(x + 3, y + crateH/2, crateW, 4);
  // Bottles sticking up
  var bottleCount = Math.floor(crateW / 10);
  for (var b = 0; b < bottleCount; b++) {
    var bx = x + 8 + b * (crateW - 10) / Math.max(1, bottleCount - 1);
    // Bottle body
    c.fillStyle = '#2a4a20';
    c.fillRect(bx - 2.5, y - 8, 5, 16);
    // Neck
    c.fillRect(bx - 1.5, y - 14, 3, 8);
    // Cap
    c.fillStyle = '#c9a050';
    c.fillRect(bx - 2, y - 16, 4, 3);
    // Label
    c.fillStyle = '#d4c8a0';
    c.fillRect(bx - 2, y - 4, 4, 6);
    // Glass highlight
    c.fillStyle = 'rgba(255,255,255,0.1)';
    c.fillRect(bx - 1, y - 12, 1.5, 10);
  }
}
}

// === HIGH OBSTACLES LEVEL 2 (bar top) ===
_drawHighObs2(c, type, x, w, h) {
var cx = x + w/2;
var bottom = h;
var dg = c.createRadialGradient(cx, bottom - 20, 5, cx, bottom, 50);
dg.addColorStop(0, 'rgba(255,80,80,0.15)');
dg.addColorStop(1, 'rgba(255,80,80,0)');
c.fillStyle = dg;
c.fillRect(cx - 50, bottom - 60, 100, 70);

if (type === 0) {
  // Hanging bottle rack (wooden rack with bottles hanging upside down)
  c.fillStyle = '#4a3a2a';
  c.fillRect(cx - 1, 0, 2, bottom - 30); // mounting pole
  // Rack frame
  c.strokeStyle = '#3a2a1a';
  c.lineWidth = 2;
  c.strokeRect(cx - 25, bottom - 45, 50, 35);
  // Hanging bottles (upside down)
  for (var b = 0; b < 4; b++) {
    var bx = cx - 18 + b * 12;
    // Bottle hanging down
    c.fillStyle = '#2a4a20';
    c.fillRect(bx - 2, bottom - 35, 4, 20);
    c.fillStyle = '#4a6a30';
    c.fillRect(bx - 3, bottom - 38, 6, 4); // bottom (now at top due to inversion)
  }
} else if (type === 1) {
  // Shelf bracket with bottles
  c.fillStyle = '#4a3a2a';
  c.fillRect(cx - 1, 0, 2, bottom - 35);
  // Bracket
  c.fillStyle = '#5a4a3a';
  c.beginPath();
  c.moveTo(cx, bottom - 40);
  c.lineTo(cx - 35, bottom - 40);
  c.lineTo(cx - 35, bottom - 32);
  c.closePath();
  c.fill();
  // Shelf
  c.fillStyle = '#6a5a4a';
  c.fillRect(cx - 35, bottom - 33, 35, 4);
  // Bottles on shelf
  for (var b = 0; b < 5; b++) {
    var bx = cx - 32 + b * 7;
    c.fillStyle = '#2a4a20';
    c.fillRect(bx, bottom - 30, 4, 15);
    c.fillStyle = '#d4a050';
    c.fillRect(bx, bottom - 32, 4, 2);
  }
} else {
  // Bartender's arm reaching across
  c.fillStyle = '#c9a07a';
  c.beginPath();
  c.ellipse(cx + 20, bottom - 35, 6, 8, 0.3, 0, Math.PI * 2);
  c.fill();
  // Arm extending
  c.strokeStyle = '#c9a07a';
  c.lineWidth = 4;
  c.beginPath();
  c.moveTo(cx, bottom - 40);
  c.quadraticCurveTo(cx + 25, bottom - 50, cx + 40, bottom - 35);
  c.stroke();
  // Hand holding cloth/glass
  c.fillStyle = '#c9a07a';
  c.beginPath();
  c.arc(cx + 40, bottom - 35, 5, 0, Math.PI * 2);
  c.fill();
  // Cloth fluttering
  c.fillStyle = '#d4c8a0';
  c.beginPath();
  c.moveTo(cx + 35, bottom - 30);
  c.quadraticCurveTo(cx + 50, bottom - 20, cx + 45, bottom - 10);
  c.quadraticCurveTo(cx + 40, bottom - 15, cx + 35, bottom - 20);
  c.closePath();
  c.fill();
}
}

// === LOW OBSTACLES LEVEL 2 (bar top) ===
_drawLowObs2(c, type, x, y, w, h) {
var cx = x + w/2;
var gY = y + h;

if (type === 0) {
  // Beer taps (brass/chrome tap handles sticking up from bar)
  c.fillStyle = '#d4a574';
  c.beginPath();
  c.ellipse(cx - 8, y + h - 5, 3, 8, 0, 0, Math.PI * 2);
  c.fill();
  c.fillStyle = '#a08050';
  c.beginPath();
  c.ellipse(cx - 8, y + h - 5, 2, 6, 0, 0, Math.PI * 2);
  c.fill();
  // Second tap
  c.fillStyle = '#d4a574';
  c.beginPath();
  c.ellipse(cx + 8, y + h - 5, 3, 8, 0, 0, Math.PI * 2);
  c.fill();
  c.fillStyle = '#a08050';
  c.beginPath();
  c.ellipse(cx + 8, y + h - 5, 2, 6, 0, 0, Math.PI * 2);
  c.fill();
} else if (type === 1) {
  // Tip jar with coins (glass jar, coins visible)
  c.fillStyle = '#2a4a40';
  c.beginPath();
  c.arc(cx, y + h/2, w/2 - 2, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#4a6a60';
  c.lineWidth = 1.5;
  c.stroke();
  // Coins in jar
  c.fillStyle = '#c9a050';
  for (var coin = 0; coin < 6; coin++) {
    var coinX = cx - w/4 + Math.random() * (w/2);
    var coinY = y + h/2 + Math.random() * (h/3);
    c.beginPath();
    c.ellipse(coinX, coinY, 2.5, 1.5, 0, 0, Math.PI * 2);
    c.fill();
  }
  // Jar lid
  c.fillStyle = '#d4a574';
  c.fillRect(cx - w/2 - 2, y + 2, w + 4, 4);
} else {
  // Spilled drink with fallen glass (puddle, broken glass shards)
  c.fillStyle = 'rgba(200, 160, 80, 0.4)';
  c.beginPath();
  c.ellipse(cx, y + h - 5, w/2 - 4, 4, 0, 0, Math.PI * 2);
  c.fill();
  // Broken glass shards
  c.fillStyle = 'rgba(100, 150, 200, 0.5)';
  c.beginPath();
  c.moveTo(cx - 10, y + h - 5);
  c.lineTo(cx - 12, y + h - 2);
  c.lineTo(cx - 8, y + h - 1);
  c.closePath();
  c.fill();
  c.beginPath();
  c.moveTo(cx, y + h - 8);
  c.lineTo(cx - 2, y + h - 2);
  c.lineTo(cx + 3, y + h - 3);
  c.closePath();
  c.fill();
  c.beginPath();
  c.moveTo(cx + 10, y + h - 6);
  c.lineTo(cx + 8, y + h - 2);
  c.lineTo(cx + 14, y + h - 1);
  c.closePath();
  c.fill();
}
}

// === HIGH OBSTACLES LEVEL 3 (stage) ===
_drawHighObs3(c, type, x, w, h) {
var cx = x + w/2;
var bottom = h;
var dg = c.createRadialGradient(cx, bottom - 20, 5, cx, bottom, 50);
dg.addColorStop(0, 'rgba(255,80,80,0.15)');
dg.addColorStop(1, 'rgba(255,80,80,0)');
c.fillStyle = dg;
c.fillRect(cx - 50, bottom - 60, 100, 70);

if (type === 0) {
  // Guitar neck swinging overhead
  c.fillStyle = '#3a2018';
  c.fillRect(cx - 2, bottom - 50, 4, 50); // strap
  // Guitar neck
  c.fillStyle = '#5a4a3a';
  c.fillRect(cx - 8, bottom - 45, 16, 35);
  // Frets
  c.strokeStyle = '#d4a574';
  c.lineWidth = 0.5;
  for (var f = 0; f < 12; f++) {
    c.beginPath();
    c.moveTo(cx - 7, bottom - 43 + f * 3);
    c.lineTo(cx + 7, bottom - 43 + f * 3);
    c.stroke();
  }
  // Tuning pegs
  c.fillStyle = '#8a7a6a';
  for (var p = 0; p < 3; p++) {
    c.beginPath();
    c.arc(cx - 10, bottom - 40 + p * 8, 2, 0, Math.PI * 2);
    c.fill();
    c.beginPath();
    c.arc(cx + 10, bottom - 40 + p * 8, 2, 0, Math.PI * 2);
    c.fill();
  }
} else if (type === 1) {
  // Cymbal on tall stand
  c.fillStyle = '#1a1a1a';
  c.fillRect(cx - 1, bottom - 40, 2, 40); // stand pole
  // Cymbal disc
  c.fillStyle = '#8a7a50';
  c.beginPath();
  c.ellipse(cx, bottom - 45, 25, 8, 0.1, 0, Math.PI * 2);
  c.fill();
  c.strokeStyle = '#5a4a30';
  c.lineWidth = 2;
  c.stroke();
  // Cymbal shine
  c.fillStyle = 'rgba(255, 255, 200, 0.15)';
  c.beginPath();
  c.ellipse(cx - 5, bottom - 47, 8, 3, 0.1, 0, Math.PI * 2);
  c.fill();
} else {
  // Low-hanging spotlight rig (PAR can lights on a bar)
  c.fillStyle = '#1a1a1a';
  c.fillRect(cx - 1, 0, 2, bottom - 25); // mounting pole
  // Truss/pipe
  c.fillStyle = '#2a2a2a';
  c.fillRect(cx - 30, bottom - 30, 60, 4);
  // PAR cans
  for (var par = 0; par < 3; par++) {
    var parX = cx - 20 + par * 20;
    c.fillStyle = '#333';
    c.fillRect(parX - 10, bottom - 28, 20, 16);
    // Lens
    c.fillStyle = 'rgba(255, 200, 100, 0.3)';
    c.beginPath();
    c.arc(parX, bottom - 20, 8, 0, Math.PI * 2);
    c.fill();
  }
}
}

// === LOW OBSTACLES LEVEL 3 (stage) ===
_drawLowObs3(c, type, x, y, w, h) {
var cx = x + w/2;
var gY = y + h;

if (type === 0) {
  // Stage monitor wedge (angled black wedge speaker)
  c.fillStyle = '#1a1a1a';
  c.beginPath();
  c.moveTo(x, y + h);
  c.lineTo(x + w, y + h);
  c.lineTo(x + w - 5, y);
  c.lineTo(x + 5, y);
  c.closePath();
  c.fill();
  c.strokeStyle = '#333';
  c.lineWidth = 1.5;
  c.stroke();
  // Speaker cone
  c.fillStyle = '#2a2a2a';
  c.beginPath();
  c.arc(cx, y + h - 8, 6, 0, Math.PI * 2);
  c.fill();
} else if (type === 1) {
  // Cable bundle with gaffer tape (tangled cables on floor)
  c.fillStyle = '#1a1a1a';
  c.beginPath();
  c.ellipse(cx, y + h - 3, w/2, h/2, 0, 0, Math.PI * 2);
  c.fill();
  // Cables
  c.strokeStyle = '#3a3a3a';
  c.lineWidth = 1;
  for (var c_i = 0; c_i < 5; c_i++) {
    c.beginPath();
    c.moveTo(cx - w/3, y + h - Math.random() * 6);
    c.quadraticCurveTo(cx, y + h - 4 - Math.random() * 8, cx + w/3, y + h - Math.random() * 6);
    c.stroke();
  }
  // Gaffer tape strips
  c.fillStyle = '#333333';
  c.fillRect(cx - w/3, y + h - 4, w/3, 2);
  c.fillRect(cx, y + h - 3, w/4, 1);
} else {
  // Fallen mic stand (stand on its side with mic)
  c.fillStyle = '#1a1a1a';
  c.beginPath();
  c.moveTo(x + 5, y + h);
  c.lineTo(x + w - 5, y + 5);
  c.lineTo(x + w - 2, y + h);
  c.closePath();
  c.fill();
  // Mic head
  c.fillStyle = '#3a3a3a';
  c.beginPath();
  c.arc(x + w - 5, y + 2, 4, 0, Math.PI * 2);
  c.fill();
  // Mic clip
  c.fillStyle = '#888';
  c.fillRect(x + w - 8, y + 6, 6, 3);
}
}

_drawPlayer(c) {
var cp = this.carryPhase;
var px = 100, py = cp.playerY;
var isDucking = cp.playerDuckingInput && !cp.playerJumping;
var isAirborne = cp.playerY < cp.groundY - 5;
var legCycle = Math.sin(this.t * 8);
var blink = (Math.sin(this.t * 2.1) > 0.95);

// Invulnerability flash
if (cp.invulnTimer > 0 && Math.sin(this.t * 30) > 0) { c.globalAlpha = 0.4; }

c.save();

// Stagger shake — character wobbles side to side rapidly
if (cp.staggerTimer > 0) {
  var staggerIntensity = Math.min(1, cp.staggerTimer / 0.5);
  var shakeX = Math.sin(this.t * 28) * 6 * staggerIntensity;
  var shakeR = Math.sin(this.t * 22) * 0.15 * staggerIntensity;
  c.translate(px + shakeX, py);
  c.rotate(shakeR);
  c.translate(-(px + shakeX), -py);
  // Draw dizzy stars above head
  c.save();
  c.globalAlpha = 0.7 * staggerIntensity;
  c.fillStyle = '#ffe880';
  c.font = '10px Georgia';
  c.textAlign = 'center';
  var starAngle = this.t * 6;
  for (var si = 0; si < 3; si++) {
    var sa = starAngle + si * (Math.PI * 2 / 3);
    var starX = px + Math.cos(sa) * 14;
    var starY = py - 18 + Math.sin(sa) * 5;
    c.fillText('\u2726', starX, starY);
  }
  c.restore();
}

if (isDucking) {
  // DUCKING POSE — crouched low
  var duckY = cp.groundY + 5;
  // Shadow
  c.fillStyle = 'rgba(0,0,0,0.3)';
  c.beginPath();
  c.ellipse(px, cp.groundY + 38, 16, 4, 0, 0, Math.PI * 2);
  c.fill();
  // Legs (folded)
  c.fillStyle = '#1a1a28';
  c.fillRect(px - 8, duckY + 10, 7, 12);
  c.fillRect(px + 1, duckY + 10, 7, 12);
  // Shoes
  c.fillStyle = '#2a1a10';
  c.fillRect(px - 10, duckY + 20, 10, 5);
  c.fillRect(px, duckY + 20, 10, 5);
  // Torso (hunched)
  c.fillStyle = '#4a3a2a';
  c.fillRect(px - 8, duckY, 16, 14);
  // Collar
  c.fillStyle = '#d4c8b0';
  c.fillRect(px - 5, duckY, 10, 3);
  // Head (tucked)
  c.fillStyle = '#c9a07a';
  c.beginPath();
  c.arc(px, duckY - 4, 7, 0, Math.PI * 2);
  c.fill();
  // Hair
  c.fillStyle = '#3a2a1a';
  c.beginPath();
  c.arc(px, duckY - 6, 7, Math.PI, Math.PI * 2);
  c.fill();
  // Arms holding tray up
  c.strokeStyle = '#c9a07a';
  c.lineWidth = 2.5;
  c.beginPath();
  c.moveTo(px + 7, duckY + 5);
  c.lineTo(px + 14, duckY - 10);
  c.stroke();
  c.beginPath();
  c.moveTo(px - 7, duckY + 5);
  c.lineTo(px - 14, duckY - 10);
  c.stroke();
} else {
  // STANDING / RUNNING / JUMPING POSE
  var bodyTop = py;
  // Shadow (only on ground)
  if (!isAirborne) {
    c.fillStyle = 'rgba(0,0,0,0.3)';
    c.beginPath();
    c.ellipse(px, cp.groundY + 38, 12, 3, 0, 0, Math.PI * 2);
    c.fill();
  }
  // Shoes
  c.fillStyle = '#2a1a10';
  var shoeL = isAirborne ? -2 : legCycle * 5;
  var shoeR = isAirborne ? 2 : -legCycle * 5;
  c.fillRect(px - 7 + shoeL, bodyTop + 33, 8, 5);
  c.fillRect(px - 1 + shoeR, bodyTop + 33, 8, 5);
  // Legs (dark trousers)
  c.fillStyle = '#1a1a28';
  c.save();
  c.beginPath();
  c.moveTo(px - 3, bodyTop + 20);
  c.lineTo(px - 6 + shoeL, bodyTop + 34);
  c.lineTo(px + 1 + shoeL, bodyTop + 34);
  c.lineTo(px, bodyTop + 20);
  c.closePath();
  c.fill();
  c.beginPath();
  c.moveTo(px, bodyTop + 20);
  c.lineTo(px - 1 + shoeR, bodyTop + 34);
  c.lineTo(px + 6 + shoeR, bodyTop + 34);
  c.lineTo(px + 3, bodyTop + 20);
  c.closePath();
  c.fill();
  c.restore();
  // Torso (brown waistcoat over white shirt)
  c.fillStyle = '#d4c8b0'; // shirt
  c.fillRect(px - 7, bodyTop + 6, 14, 16);
  c.fillStyle = '#4a3a2a'; // waistcoat
  c.fillRect(px - 7, bodyTop + 6, 5, 15);
  c.fillRect(px + 2, bodyTop + 6, 5, 15);
  // Waistcoat buttons
  c.fillStyle = '#c9a050';
  c.beginPath(); c.arc(px, bodyTop + 10, 1, 0, Math.PI * 2); c.fill();
  c.beginPath(); c.arc(px, bodyTop + 15, 1, 0, Math.PI * 2); c.fill();
  // Collar / bow tie
  c.fillStyle = '#d4c8b0';
  c.fillRect(px - 5, bodyTop + 4, 10, 3);
  c.fillStyle = '#8a2020';
  c.beginPath();
  c.moveTo(px - 3, bodyTop + 5);
  c.lineTo(px, bodyTop + 3);
  c.lineTo(px + 3, bodyTop + 5);
  c.lineTo(px, bodyTop + 7);
  c.closePath();
  c.fill();
  // Head
  c.fillStyle = '#c9a07a';
  c.beginPath();
  c.arc(px, bodyTop - 2, 8, 0, Math.PI * 2);
  c.fill();
  // Hair
  c.fillStyle = '#3a2a1a';
  c.beginPath();
  c.arc(px, bodyTop - 4, 8, Math.PI + 0.3, Math.PI * 2 - 0.3);
  c.fill();
  // Eyes
  c.fillStyle = blink ? '#c9a07a' : '#1a1a1a';
  c.beginPath(); c.arc(px - 3, bodyTop - 2, 1.2, 0, Math.PI * 2); c.fill();
  c.beginPath(); c.arc(px + 3, bodyTop - 2, 1.2, 0, Math.PI * 2); c.fill();
  // Nose
  c.fillStyle = '#b8906a';
  c.beginPath(); c.arc(px, bodyTop + 1, 1, 0, Math.PI * 2); c.fill();
  // Arms holding tray up
  c.strokeStyle = '#c9a07a';
  c.lineWidth = 2.5;
  var armBob = isAirborne ? 2 : Math.sin(this.t * 8) * 1.5;
  c.beginPath();
  c.moveTo(px + 7, bodyTop + 10);
  c.quadraticCurveTo(px + 14, bodyTop + 2, px + 16, bodyTop - 10 + armBob);
  c.stroke();
  c.beginPath();
  c.moveTo(px - 7, bodyTop + 10);
  c.quadraticCurveTo(px - 14, bodyTop + 2, px - 16, bodyTop - 10 + armBob);
  c.stroke();
  // Hands
  c.fillStyle = '#c9a07a';
  c.beginPath(); c.arc(px + 16, bodyTop - 10 + armBob, 2, 0, Math.PI * 2); c.fill();
  c.beginPath(); c.arc(px - 16, bodyTop - 10 + armBob, 2, 0, Math.PI * 2); c.fill();
}

c.restore();
c.globalAlpha = 1;
}

_drawTray(c) {
var cp = this.carryPhase;
var px = 100;
var isDucking = cp.playerDuckingInput && !cp.playerJumping;
var trayY = isDucking ? (cp.groundY - 8) : (cp.playerY - 12);
var armBob = (cp.playerY < cp.groundY - 5) ? 2 : Math.sin(this.t * 8) * 1.5;
if (!isDucking) trayY += armBob;

var wobble = cp.screenShake * 2;

// Wobble effect: tray rocks back and forth when in danger
var wobbleRot = 0;
if (cp.wobbling) {
  var wobbleIntensity = Math.min(1, cp.wobbleTimer / 1.5); // fades out over time
  wobbleRot = Math.sin(this.t * 14) * 0.12 * wobbleIntensity;
}

c.save();
c.translate(px, trayY);
c.rotate(wobble * 0.04 + wobbleRot);

// Silver tray with rim
c.fillStyle = '#888';
c.beginPath();
c.ellipse(0, 0, 22, 5, 0, 0, Math.PI * 2);
c.fill();
c.fillStyle = '#aaa';
c.beginPath();
c.ellipse(0, -1, 20, 4, 0, 0, Math.PI * 2);
c.fill();
// Tray highlight
c.fillStyle = 'rgba(255,255,255,0.15)';
c.beginPath();
c.ellipse(-4, -2, 10, 2, -0.2, 0, Math.PI * 2);
c.fill();

// Glasses on tray
var cols = ['#c98030','#e0d090','#d4a050'];
var names = ['B','M','S'];
for (var i = 0; i < cp.glassesLeft; i++) {
  var gx = -14 + i * 14;
  // Glass body
  c.fillStyle = 'rgba(200,200,200,0.25)';
  c.fillRect(gx - 4, -16, 8, 14);
  c.strokeStyle = 'rgba(255,255,255,0.3)';
  c.lineWidth = 0.8;
  c.strokeRect(gx - 4, -16, 8, 14);
  // Liquid
  c.fillStyle = cols[i] || '#d4a050';
  c.fillRect(gx - 3, -10, 6, 8);
  // Glass highlight
  c.fillStyle = 'rgba(255,255,255,0.15)';
  c.fillRect(gx - 3, -14, 2, 10);
}

c.restore();
}

// ========== RESULT PHASE ==========
_resultCarry() {
var cp = this.carryPhase;
var perfect = cp.glassesLeft === 3;
var win = cp.glassesLeft >= 1;

document.getElementById('bar-round-display').textContent = win ? '★ YOU MADE IT! ★' : '✗ SPILLED! ✗';
var narr = document.getElementById('bar-narrative');

if (perfect) {
  narr.innerHTML = '<em style="color:#4CFF00;">All three drinks reach the stage. Moe nods. The band plays on.</em>';
} else if (cp.glassesLeft === 2) {
  narr.innerHTML = '<em style="color:#d4a574;">Two land safely. Moe shrugs. "Better than nothing."</em>';
} else if (win) {
  narr.innerHTML = '<em style="color:#c8a674;">One drink left standing. Moe takes it. "It\'ll do."</em>';
} else {
  narr.innerHTML = '<em style="color:#FF6B6B;">Empty tray. The pianist sighs. The band waits.</em>';
}

this.phase = 'result';

var self = this;
setTimeout(function() {
  var lk = win ? document.querySelector('#bar-win-link tw-link') : document.querySelector('#bar-lose-link tw-link');
  if (lk) lk.click();
}, 2500);
}

_drawResult() {
var c = this.ctx, W = this.W, H = this.H;
c.fillStyle = '#0a0804';
c.fillRect(0, 0, W, H);

var glasses = this.carryPhase.glassesLeft;
var isWin = glasses >= 1;

c.save();
c.textAlign = 'center';

// Headline — only delivery counts.
c.font = 'bold 28px Georgia';
c.fillStyle = isWin ? '#4CFF00' : '#FF6B6B';
c.fillText('DELIVERED ' + glasses + '/3', W/2, 110);

// Three star slots, lit per glass delivered.
c.font = 'bold 32px Georgia';
for (var i = 0; i < 3; i++) {
  c.fillStyle = i < glasses ? '#e8c060' : 'rgba(232,192,96,0.18)';
  c.fillText('★', W/2 - 50 + i * 50, 170);
}


// One-line tagline keyed to the count.
c.font = 'italic 14px Georgia';
c.fillStyle = '#a8906a';
var caption;
if (glasses === 3) caption = 'A clean run.';
else if (glasses === 2) caption = 'Most of it home.';
else if (glasses === 1) caption = 'One survivor.';
else caption = 'The tray came up short.';
c.fillText(caption, W/2, 220);

this._drawSparkles(c);
c.restore();
}
};

// ====== DRINK POPUP (sip animation for buying drinks) ======
window.DrinkPopup = class DrinkPopup {
constructor(drinkType) {
  // drinkType: 'pint', 'whisky', 'gin', 'wine', 'champagne'
  this.type = drinkType || 'whisky';
  this.sipped = false;
  this.tiltAngle = 0;
  this.tiltTarget = 0;
  this.liquidLevel = 0;      // starts empty — pours in on entry
  this.fillLevel = 0;        // animation fill progress (0→1)
  this.filling = true;       // true during pour-in animation
  this.idleBob = 0;          // gentle vertical bob offset (px)
  this.wobble = 0;
  this.wobbleDecay = 0;
  this.fadeAlpha = 0;
  this.fadeTarget = 1;
  this.done = false;
  this.t = 0;

  // Drink configs: label, liquid colour, highlight, glass shape, ambient glow colour.
  // Specific drink names are now period-correct Soho-1973 brands/vintages: a
  // chosen "Claret" pours a Château Margaux '66; the Colony's house champagne
  // is Bollinger '66; etc. Old generic keys (wine/champagne/whisky/etc.) are
  // kept around as fallbacks but their labels have been upgraded to the
  // specific drink each chosen link resolves to.
  this.configs = {
    pint:        { label: 'Pint',                     liq: '#180a02', hi: '#2a1608', foam: '#e0d4b8', bg: '#9a8050', glow: 'rgba(140,90,28,0.12)' },
    whisky:      { label: "Laphroaig 10",             liq: '#b88438', hi: '#e0b870', foam: null,       bg: '#9a8050', glow: 'rgba(180,130,50,0.18)' },
    gin:         { label: 'Gin & Bitter Lemon',       liq: '#d4d488', hi: '#e0e0b0', foam: null,       bg: '#6ea0b0', glow: 'rgba(140,170,150,0.12)' },
    wine:        { label: 'Wine',                     liq: '#4a0818', hi: '#681628', foam: null,       bg: '#9a8050', glow: 'rgba(110,20,40,0.16)' },
    champagne:   { label: "Bollinger '66",            liq: '#cab85c', hi: '#dcc880', foam: '#e0d8c0', bg: '#9a8050', glow: 'rgba(180,168,72,0.13)' },
    scotch:      { label: 'Scotch',                   liq: '#b07a32', hi: '#c89048', foam: null,       bg: '#9a8050', glow: 'rgba(140,90,32,0.14)' },
    cider:       { label: 'Cidre Brut de Bretagne',   liq: '#b08420', hi: '#c49838', foam: '#dcd0a0', bg: '#9a8050', glow: 'rgba(140,110,28,0.12)' },
    vodka:       { label: 'Stolichnaya & Tonic',      liq: '#c0d0d0', hi: '#d0dcdc', foam: null,       bg: '#6ea0b0', glow: 'rgba(130,160,170,0.11)' },
    beer:        { label: "Watney's Red Barrel",      liq: '#a06014', hi: '#bc8030', foam: '#e0d4b8', bg: '#9a8050', glow: 'rgba(140,100,20,0.13)' },
    // Specific reds — different vintages/regions get distinct colours
    claret:      { label: "Château Margaux '66",      liq: '#3a0612', hi: '#581020', foam: null,       bg: '#9a8050', glow: 'rgba(120,15,35,0.18)' },
    beaujolais:  { label: "Fleurie '71",              liq: '#5a1822', hi: '#7a2434', foam: null,       bg: '#9a8050', glow: 'rgba(130,30,50,0.16)' },
    // Trisha's "sponsored drink" — slightly more amber than the Colony's Bollinger
    krug:        { label: "Krug Grande Cuvée",        liq: '#d8c068', hi: '#e8d088', foam: '#e8e0c8', bg: '#9a8050', glow: 'rgba(200,180,90,0.14)' }
  };
  this.cfg = this.configs[this.type] || this.configs.whisky;

  this._build();
  this._startLoop();
  window._drinkPopupOpen = true;
  if (window.dssAudio) {
    window.dssAudio.glassClink();        // glass meets bar
    setTimeout(function(){ if (window.dssAudio) window.dssAudio.pour(); }, 90);
  }
}

_build() {
  // Overlay
  this.overlay = document.createElement('div');
  this.overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0);transition:background 0.5s;';
  document.body.appendChild(this.overlay);

  // Card
  this.card = document.createElement('div');
  this.card.style.cssText = [
    'display:flex;flex-direction:column;align-items:center;',
    'padding:0 0 20px;',
    'background:rgba(14,9,4,0.97);',
    'border:1px solid rgba(200,168,106,0.35);',
    'border-top:2px solid rgba(200,168,106,0.65);',
    'border-radius:10px;',
    'opacity:0;',
    'transform:translateY(18px);',
    'transition:opacity 0.45s,transform 0.45s;',
    'min-width:180px;',
  ].join('');
  this.overlay.appendChild(this.card);

  // Drink name label
  this.nameLabel = document.createElement('div');
  this.nameLabel.style.cssText = [
    'width:100%;box-sizing:border-box;',
    'padding:12px 28px 10px;',
    'text-align:center;',
    'font:small-caps 600 13px "Cinzel",Georgia,serif;',
    'letter-spacing:0.12em;',
    'color:rgba(200,168,106,0.85);',
    'border-bottom:1px solid rgba(200,168,106,0.15);',
  ].join('');
  this.nameLabel.textContent = this.cfg.label;
  this.card.appendChild(this.nameLabel);

  // Canvas wrapper
  var canvasWrap = document.createElement('div');
  canvasWrap.style.cssText = 'padding:18px 28px 0;';
  this.card.appendChild(canvasWrap);

  // Canvas (taller to accommodate the lips above the glass)
  this.canvas = document.createElement('canvas');
  this.canvas.width = 160;
  this.canvas.height = 260;
  this.canvas.style.cssText = 'cursor:pointer;display:block;';
  this.ctx = this.canvas.getContext('2d');
  canvasWrap.appendChild(this.canvas);
  // Lip animation state
  this.lipOpen = 0;         // 0 = closed, 1 = parted for drinking
  this.lipOpenTarget = 0.18; // resting parted-kiss position
  this.streamT = 0;         // time accumulator for stream dashes
  this.streamStrength = 0;  // 0 = no pour, 1 = full pour (ramps up/down for taper)
  this.entryStrength = 0;   // 0 = no entry pour, 1 = stream pouring in during fill

  // Prompt text
  this.prompt = document.createElement('div');
  this.prompt.style.cssText = 'margin-top:10px;font:italic 13px Georgia,serif;color:rgba(212,165,116,0.75);letter-spacing:0.04em;';
  this.prompt.textContent = 'Hold to drink';
  this.card.appendChild(this.prompt);

  // Fade in
  var self = this;
  this.drinking = false;    // true while mouse/touch held down
  this.hasDrunk = false;    // true once they've drunk at least a little
  this.minLevel = 0.30;     // can't go below this — no downing it
  this.closing = false;     // true once fade-out has started

  setTimeout(function() {
    self.overlay.style.background = 'rgba(0,0,0,0.6)';
    self.card.style.opacity = '1';
    self.card.style.transform = 'translateY(0)';
    self.fadeAlpha = 1;
  }, 30);

  // Hold-to-drink handlers (mouse + touch)
  var startDrink = function(e) {
    e.preventDefault();
    if (self.closing || self.done || self.filling) return;
    if (self.liquidLevel <= self.minLevel + 0.01) return; // already hit bottom
    self.drinking = true;
    self.hasDrunk = true;
    self.tiltTarget = -0.55;
    self.wobbleDecay = 0.6;
    self.prompt.textContent = '';
    if (window.dssAudio) window.dssAudio.sip();
  };
  var stopDrink = function(e) {
    e.preventDefault();
    if (!self.drinking) return;
    self.drinking = false;
    self.tiltTarget = 0;
    self.wobbleDecay = 0.8;
    // Once they let go after drinking, fade out after a short pause
    if (self.hasDrunk && !self.closing) {
      self.closing = true;
      if (window.dssAudio) window.dssAudio.swallow();
      setTimeout(function() {
        self._fadeOut();
      }, 700);
    }
  };

  this.canvas.addEventListener('mousedown', startDrink);
  this.canvas.addEventListener('mouseup', stopDrink);
  this.canvas.addEventListener('mouseleave', stopDrink);
  this.canvas.addEventListener('touchstart', startDrink);
  this.canvas.addEventListener('touchend', stopDrink);
  this.canvas.addEventListener('touchcancel', stopDrink);
}

_fadeOut() {
  this.overlay.style.background = 'rgba(0,0,0,0)';
  this.card.style.opacity = '0';
  this.card.style.transform = 'translateY(-12px)';
  var self = this;
  setTimeout(function() {
    self.done = true;
    if (self.overlay.parentNode) self.overlay.parentNode.removeChild(self.overlay);
    window._drinkPopupOpen = false;
    window.dispatchEvent(new CustomEvent('drinkpopup:closed'));
  }, 480);
}

_startLoop() {
  var self = this;
  var lt = performance.now();
  function loop() {
    if (self.done) return;
    var now = performance.now();
    var dt = Math.min(now - lt, 50) * 0.001;
    lt = now;
    self.t += dt;
    // Pour-in fill animation (liquid rises from 0 to 1 over ~0.7s on entry)
    if (self.filling) {
      self.fillLevel = Math.min(1, self.fillLevel + 1.5 * dt);
      self.liquidLevel = self.fillLevel;
      if (self.fillLevel >= 1) {
        self.filling = false;
        self.liquidLevel = 1.0;
        self.wobbleDecay = 0.4; // little slosh as it settles
      }
    }
    // Smooth tilt
    self.tiltAngle += (self.tiltTarget - self.tiltAngle) * 4 * dt;
    // Idle bob disabled — clean pour, no floaty glass
    self.idleBob = 0;
    // Lip-open target: parted for drinking, resting kiss otherwise
    self.lipOpenTarget = self.drinking && !self.filling ? 1.0 : 0.18;
    // Drain liquid while holding (only after fill is complete)
    if (self.drinking && !self.filling) {
      // Drain rate slows as you approach the minimum (can't down it)
      var headroom = self.liquidLevel - self.minLevel;
      var rate = 0.35 * Math.min(1.0, headroom * 4); // slows near bottom
      self.liquidLevel = Math.max(self.minLevel, self.liquidLevel - rate * dt);
      // If hit the floor, auto-release
      if (self.liquidLevel <= self.minLevel + 0.005) {
        self.liquidLevel = self.minLevel;
        self.drinking = false;
        self.tiltTarget = 0;
        if (!self.closing) {
          self.closing = true;
          setTimeout(function() { self._fadeOut(); }, 700);
        }
      }
    }
    // Wobble removed — the pour stays steady and clean
    self.wobble = 0;
    // Smooth stream strength: grows in when drinking, fades out when released
    var streamWant = (self.drinking && !self.filling && self.liquidLevel > self.minLevel + 0.01) ? 1 : 0;
    self.streamStrength += (streamWant - self.streamStrength) * 6 * dt;
    // Entry-pour strength: ramps up fast while filling, tails off after the glass is full
    var entryWant = self.filling ? 1 : 0;
    var entryRate = self.filling ? 10 : 4;
    self.entryStrength += (entryWant - self.entryStrength) * entryRate * dt;
    self._draw();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}

_draw() {
  var c = this.ctx, W = 160, H = 260;
  c.clearRect(0, 0, W, H);

  var cfg = this.cfg;
  var lev = this.liquidLevel;
  var wob = this.wobble;
  var bob = this.idleBob || 0;

  // Fixed layout: glass up top, lips waiting below
  var glassPivotY = 115;   // bottom of the glass
  var lipCy = 210;         // vertical centre of the mouth

  // Smooth lip opening: target is set in the loop based on drinking state
  this.lipOpen += (this.lipOpenTarget - this.lipOpen) * 0.2;

  // Ambient radial glow behind the glass (per-drink colour, fades with level)
  if (cfg.glow && lev > 0.05) {
    var gCx = W / 2, gCy = glassPivotY - 40 + bob;
    var grd = c.createRadialGradient(gCx, gCy, 0, gCx, gCy, 72);
    grd.addColorStop(0, cfg.glow);
    grd.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = grd;
    c.fillRect(0, 0, W, H);
  }

  // Lips below the glass, waiting to receive the pour
  this._drawLips(c, W, cfg, lipCy);

  // Stream of liquid from glass rim down into the lips (ramps in/out via streamStrength)
  if (this.streamStrength > 0.02) {
    this._drawStream(c, W, H, cfg, bob, glassPivotY, lipCy);
  }

  // Entry pour: stream from above the canvas into the glass rim during the fill phase
  if (this.entryStrength > 0.02) {
    this._drawEntryPour(c, W, H, cfg, bob, glassPivotY);
  }

  // Glass up top, tilting on pivot (base of the glass)
  c.save();
  c.translate(W / 2, glassPivotY + bob);
  c.rotate(this.tiltAngle);

  if (this.type === 'pint' || this.type === 'cider' || this.type === 'beer') {
    this._drawPint(c, cfg, lev, wob);
  } else if (this.type === 'wine' || this.type === 'claret' || this.type === 'beaujolais') {
    this._drawWine(c, cfg, lev, wob);
  } else if (this.type === 'champagne' || this.type === 'krug') {
    this._drawChampagne(c, cfg, lev, wob);
  } else if (this.type === 'gin' || this.type === 'vodka') {
    this._drawTallGlass(c, cfg, lev, wob);
  } else {
    this._drawTumbler(c, cfg, lev, wob);
  }

  c.restore();
}

// === LIPS (big Soho pout, position passed in) ===
_drawLips(c, W, cfg, cyArg) {
  var cx = W / 2;
  var cy = (typeof cyArg === 'number') ? cyArg : 210;  // vertical centre of the mouth
  var lipW = 120;          // overall width
  var upperH = 18;         // upper lip thickness
  var lowerH = 17;         // lower lip thickness
  var open = this.lipOpen * 14; // parted gap in px (0 closed → ~14 wide open)

  c.save();

  // --- Upper lip ---
  // Classic M-curve (Cupid's bow) top, concave bottom where it meets the opening
  c.fillStyle = '#6e3a32';
  c.beginPath();
  c.moveTo(cx - lipW / 2, cy);
  // Top edge: dip to left peak, rise to centre dip of cupid's bow, rise to right peak, down to right corner
  c.bezierCurveTo(cx - lipW / 2 + 10, cy - upperH * 1.1, cx - 28, cy - upperH * 1.25, cx - 14, cy - upperH * 0.75);
  c.quadraticCurveTo(cx - 4, cy - upperH * 0.15, cx, cy - upperH * 0.55); // centre dip
  c.quadraticCurveTo(cx + 4, cy - upperH * 0.15, cx + 14, cy - upperH * 0.75);
  c.bezierCurveTo(cx + 28, cy - upperH * 1.25, cx + lipW / 2 - 10, cy - upperH * 1.1, cx + lipW / 2, cy);
  // Bottom edge of upper lip: gentle arch with the parted gap in the middle
  c.lineTo(cx + lipW / 2 - 6, cy - 1);
  c.quadraticCurveTo(cx + 20, cy + open * 0.3, cx, cy + open * 0.5);
  c.quadraticCurveTo(cx - 20, cy + open * 0.3, cx - lipW / 2 + 6, cy - 1);
  c.closePath();
  c.fill();

  // Upper-lip sheen (light glam highlight)
  c.fillStyle = 'rgba(180,140,120,0.16)';
  c.beginPath();
  c.ellipse(cx - 18, cy - upperH * 0.6, 14, 3, -0.18, 0, Math.PI * 2);
  c.fill();
  c.beginPath();
  c.ellipse(cx + 22, cy - upperH * 0.55, 10, 2.4, 0.16, 0, Math.PI * 2);
  c.fill();

  // --- Dark parted opening (visible when open > 0) ---
  if (open > 0.2) {
    c.fillStyle = '#180408';
    c.beginPath();
    c.moveTo(cx - 34, cy + 1);
    c.quadraticCurveTo(cx, cy + open * 0.5, cx + 34, cy + 1);
    c.quadraticCurveTo(cx, cy + open + 2, cx - 34, cy + 1);
    c.closePath();
    c.fill();
    // A tiny puddle of the drink colour if we're mid-sip (catches the stream)
    if (this.drinking && this.liquidLevel > this.minLevel + 0.01) {
      c.fillStyle = cfg.liq;
      c.globalAlpha = 0.75;
      c.beginPath();
      c.ellipse(cx, cy + open * 0.6, Math.min(28, open * 2.2), Math.max(1.5, open * 0.35), 0, 0, Math.PI * 2);
      c.fill();
      c.globalAlpha = 1;
    }
  }

  // --- Lower lip ---
  c.fillStyle = '#5a2e28';
  c.beginPath();
  c.moveTo(cx - lipW / 2, cy);
  c.quadraticCurveTo(cx - 20, cy + open * 0.35 + 1, cx, cy + open * 0.65 + 1);
  c.quadraticCurveTo(cx + 20, cy + open * 0.35 + 1, cx + lipW / 2, cy);
  // Bottom curve of lower lip — fuller, rounder than upper
  c.bezierCurveTo(cx + lipW / 2 - 6, cy + lowerH * 1.05, cx + 20, cy + lowerH * 1.35, cx, cy + lowerH * 1.28);
  c.bezierCurveTo(cx - 20, cy + lowerH * 1.35, cx - lipW / 2 + 6, cy + lowerH * 1.05, cx - lipW / 2, cy);
  c.closePath();
  c.fill();

  // Lower-lip sheen (central glossy highlight — the classic pin-up pop)
  c.fillStyle = 'rgba(180,140,120,0.22)';
  c.beginPath();
  c.ellipse(cx, cy + lowerH * 0.7, 18, 3, 0, 0, Math.PI * 2);
  c.fill();
  c.fillStyle = 'rgba(220,200,180,0.16)';
  c.beginPath();
  c.ellipse(cx - 2, cy + lowerH * 0.65, 6, 1.6, 0, 0, Math.PI * 2);
  c.fill();

  // Subtle outer shadow under lips to ground them
  c.fillStyle = 'rgba(0,0,0,0.25)';
  c.beginPath();
  c.ellipse(cx, cy + lowerH * 1.55, lipW * 0.42, 3, 0, 0, Math.PI * 2);
  c.fill();

  c.restore();
}

// === STREAM of liquid from glass rim DOWN into the lips ===
// Per-glass rim offset (low side of the rim when tilted left): x = left rim, y = top of glass
_getRimOffset() {
  // Returns the LOW rim corner in the glass's own local coords (pivot at base, y up is negative)
  if (this.type === 'pint' || this.type === 'cider' || this.type === 'beer') {
    return { x: -20, y: -100 };   // topW=40, gH=100
  } else if (this.type === 'wine' || this.type === 'claret' || this.type === 'beaujolais') {
    return { x: -20, y: -74 };    // bowl top ~-74, bowl half-width ~20 at top
  } else if (this.type === 'champagne' || this.type === 'krug') {
    return { x: -8, y: -97 };     // stem+flute = 32+65 = 97, fluteW=16
  } else if (this.type === 'gin' || this.type === 'vodka') {
    return { x: -15, y: -80 };    // topW=30, gH=80
  }
  // whisky / scotch / tumbler default
  return { x: -22, y: -52 };      // topW=44, gH=52
}

_drawStream(c, W, H, cfg, bob, pivotYArg, lipCyArg) {
  this.streamT += 0.08;
  var strength = this.streamStrength;
  if (strength < 0.02) return;

  // Glass is pivoted at its BASE (pivotYArg). Tilt is negative (counter-clockwise),
  // so liquid pours from the LEFT side of the rim (the low side).
  var pivotY = (typeof pivotYArg === 'number') ? pivotYArg : 115;
  pivotY += bob;

  // Precise per-glass rim origin, rotated by current tilt
  var rim = this._getRimOffset();
  var a = this.tiltAngle;
  var rx = Math.cos(a) * rim.x - Math.sin(a) * rim.y;
  var ry = Math.sin(a) * rim.x + Math.cos(a) * rim.y;
  var sx = W / 2 + rx;
  var sy = pivotY + ry;

  // Mouth target (just inside the parted lips, centred)
  var lipCy = (typeof lipCyArg === 'number') ? lipCyArg : 210;
  var ex = W / 2;
  var ey = lipCy + this.lipOpen * 4;

  // Arcing control point — stream bows outward-then-down into the mouth
  var cxp = (sx + ex) / 2 - 4;
  var cyp = (sy + ey) / 2 + 10;

  c.save();
  c.lineCap = 'round';
  c.lineJoin = 'round';

  // --- Main ribbon: drawn as tapered segments along the curve ---
  // Narrow at rim, swells in the middle, tapers as it enters the mouth.
  var steps = 16;
  var lastX = sx, lastY = sy;
  c.strokeStyle = cfg.liq;
  c.globalAlpha = 0.92 * strength;
  for (var i = 1; i <= steps; i++) {
    var t = i / steps;
    var bx = (1 - t) * (1 - t) * sx + 2 * (1 - t) * t * cxp + t * t * ex;
    var by = (1 - t) * (1 - t) * sy + 2 * (1 - t) * t * cyp + t * t * ey;
    // Width profile: thin (1.8) at rim, peak (5.2) around t=0.45, thinner (2.2) at mouth
    var bulge = 1 - Math.abs(t - 0.45) * 1.6;
    if (bulge < 0) bulge = 0;
    var w = (1.8 + bulge * 3.6) * strength;
    if (w < 1) w = 1;
    c.lineWidth = w;
    c.beginPath();
    c.moveTo(lastX, lastY);
    c.lineTo(bx, by);
    c.stroke();
    lastX = bx; lastY = by;
  }

  // --- Highlight down the middle of the ribbon ---
  c.strokeStyle = cfg.hi || 'rgba(255,255,255,0.5)';
  c.lineWidth = 1.3 * strength;
  c.globalAlpha = 0.55 * strength;
  c.beginPath();
  c.moveTo(sx, sy);
  c.quadraticCurveTo(cxp, cyp, ex, ey);
  c.stroke();

  // --- Droplets tumbling along the arc (more of them, varied sizes) ---
  c.fillStyle = cfg.liq;
  c.globalAlpha = 0.9 * strength;
  var dropCount = 10;
  for (var d = 0; d < dropCount; d++) {
    var dt = ((this.streamT * 0.5 + d / dropCount) % 1);
    var dx = (1 - dt) * (1 - dt) * sx + 2 * (1 - dt) * dt * cxp + dt * dt * ex;
    var dy = (1 - dt) * (1 - dt) * sy + 2 * (1 - dt) * dt * cyp + dt * dt * ey;
    var ds = (1.3 + Math.sin(d * 2.1 + this.streamT * 2) * 0.6) * strength;
    if (ds < 0.5) ds = 0.5;
    c.beginPath();
    c.arc(dx, dy, ds, 0, Math.PI * 2);
    c.fill();
  }

  // --- Splash at the lips: small droplets spraying sideways on impact ---
  if (strength > 0.4) {
    c.fillStyle = cfg.liq;
    var splashN = 6;
    for (var s = 0; s < splashN; s++) {
      // Cycle each droplet through a short arc life so they look ejected
      var life = ((this.streamT * 1.8 + s * 0.19) % 1);
      var sideSign = (s % 2 === 0) ? 1 : -1;
      var ang = sideSign * (0.4 + (s % 3) * 0.15);
      var rOut = life * 14;                          // flies outward
      var spx = ex + Math.cos(Math.PI / 2 + ang) * rOut * sideSign * 0.9;
      var spy = ey - 2 + Math.sin(life * Math.PI) * -3 + life * 4; // tiny arc: up then down
      var alpha = (1 - life) * 0.75 * strength;
      var size = (1.3 - life * 0.7) * strength;
      if (size < 0.4) continue;
      c.globalAlpha = alpha;
      c.beginPath();
      c.arc(spx, spy, size, 0, Math.PI * 2);
      c.fill();
    }
  }

  c.globalAlpha = 1;
  c.restore();
}

// === ENTRY POUR: stream from above the canvas INTO the glass rim during fill ===
_drawEntryPour(c, W, H, cfg, bob, glassPivotY) {
  var strength = this.entryStrength;
  if (strength < 0.02) return;

  // Target: just below the centre of the glass rim (so the stream visibly ends inside the glass)
  var rim = this._getRimOffset();
  var glassTopY = glassPivotY + bob + rim.y;
  var tx = W / 2;
  var ty = glassTopY + 4;

  // Source: offscreen above the glass, slightly offset so it's not a dead-straight column
  var sx = W / 2 + 4;
  var sy = 8;

  // Gentle arc control point
  var cxp = (sx + tx) / 2 - 3;
  var cyp = (sy + ty) / 2 + 5;

  c.save();
  c.lineCap = 'round';
  c.lineJoin = 'round';

  // Tapered ribbon, drawn as short segments with a thickness profile
  var steps = 18;
  var lastX = sx, lastY = sy;
  c.strokeStyle = cfg.liq;
  c.globalAlpha = 0.88 * strength;
  for (var i = 1; i <= steps; i++) {
    var t = i / steps;
    var bx = (1 - t) * (1 - t) * sx + 2 * (1 - t) * t * cxp + t * t * tx;
    var by = (1 - t) * (1 - t) * sy + 2 * (1 - t) * t * cyp + t * t * ty;
    // Width: narrow at source, swells mid-flow, narrows at rim
    var bulge = 1 - Math.abs(t - 0.5) * 1.3;
    if (bulge < 0) bulge = 0;
    var w = (1.8 + bulge * 2.8) * strength;
    if (w < 0.9) w = 0.9;
    c.lineWidth = w;
    c.beginPath();
    c.moveTo(lastX, lastY);
    c.lineTo(bx, by);
    c.stroke();
    lastX = bx; lastY = by;
  }

  // Highlight down the spine
  c.strokeStyle = cfg.hi || 'rgba(255,255,255,0.5)';
  c.lineWidth = 1.1 * strength;
  c.globalAlpha = 0.5 * strength;
  c.beginPath();
  c.moveTo(sx, sy);
  c.quadraticCurveTo(cxp, cyp, tx, ty);
  c.stroke();

  // Droplets tumbling down the pour
  c.fillStyle = cfg.liq;
  c.globalAlpha = 0.92 * strength;
  for (var d = 0; d < 9; d++) {
    var dt = ((this.t * 1.6 + d / 9) % 1);
    var dx = (1 - dt) * (1 - dt) * sx + 2 * (1 - dt) * dt * cxp + dt * dt * tx;
    var dy = (1 - dt) * (1 - dt) * sy + 2 * (1 - dt) * dt * cyp + dt * dt * ty;
    var ds = (1.2 + Math.sin(d * 1.9 + this.t * 3) * 0.45) * strength;
    if (ds < 0.5) ds = 0.5;
    c.beginPath();
    c.arc(dx, dy, ds, 0, Math.PI * 2);
    c.fill();
  }

  // Small ripple ring at the pour's impact point on the rim
  if (strength > 0.35 && this.fillLevel > 0.04) {
    c.strokeStyle = cfg.hi || cfg.liq;
    c.globalAlpha = 0.45 * strength;
    c.lineWidth = 1;
    var ringR = 4 + Math.sin(this.t * 12) * 1.2;
    c.beginPath();
    c.ellipse(tx, ty + 1, ringR, 1.6, 0, 0, Math.PI * 2);
    c.stroke();
  }

  c.globalAlpha = 1;
  c.restore();
}

// Helper: given a liquid baseline y (in local glass coords) and a local x offset,
// returns the y of a *world-horizontal* surface line at that x. Used so the liquid
// stays level under gravity even while the glass is tilted.
_tiltedY(baseY, x) {
  return baseY - x * Math.tan(this.tiltAngle);
}

// === PINT GLASS ===
_drawPint(c, cfg, lev, wob) {
  var gW = 36, gH = 100, topW = 40;
  var y0 = -gH;
  // Glass body (slight taper)
  c.fillStyle = 'rgba(200,200,200,0.08)';
  c.beginPath();
  c.moveTo(-gW / 2, 0);
  c.lineTo(-topW / 2, y0);
  c.lineTo(topW / 2, y0);
  c.lineTo(gW / 2, 0);
  c.closePath();
  c.fill();
  c.strokeStyle = 'rgba(255,255,255,0.18)';
  c.lineWidth = 1.2;
  c.stroke();
  // Liquid (top surface tilts to stay world-horizontal while the glass tilts)
  var liqH = gH * 0.88 * lev;
  var liqTop = -liqH;
  var lW = gW / 2 - 2 + (topW / 2 - gW / 2) * (liqH / gH);
  var yL = Math.max(-gH + 2, this._tiltedY(liqTop, -lW));
  var yR = Math.min(-1, this._tiltedY(liqTop, lW));
  c.fillStyle = cfg.liq;
  c.beginPath();
  c.moveTo(-gW / 2 + 2, 0);
  c.lineTo(-lW, yL + wob * 200);
  c.quadraticCurveTo(0, (yL + yR) / 2 - wob * 400, lW, yR + wob * 200);
  c.lineTo(gW / 2 - 2, 0);
  c.closePath();
  c.fill();
  // Foam head — counter-rotated so it sits flat on the world-horizontal surface
  if (cfg.foam && lev > 0.5) {
    c.save();
    c.translate(0, (yL + yR) / 2 + wob * 200);
    c.rotate(-this.tiltAngle);
    c.fillStyle = cfg.foam;
    c.beginPath();
    c.ellipse(0, 0, lW, 8, 0, 0, Math.PI * 2);
    c.fill();
    c.restore();
  }
  // Glass highlight
  c.fillStyle = 'rgba(255,255,255,0.08)';
  c.fillRect(-topW / 2 + 3, y0 + 5, 4, gH - 10);
  // Handle
  c.strokeStyle = 'rgba(255,255,255,0.15)';
  c.lineWidth = 3;
  c.beginPath();
  c.moveTo(gW / 2, -gH * 0.25);
  c.quadraticCurveTo(gW / 2 + 16, -gH * 0.5, gW / 2, -gH * 0.75);
  c.stroke();
}

// === TUMBLER (whisky/scotch) ===
_drawTumbler(c, cfg, lev, wob) {
  // Heavy crystal-cut rocks glass — period-correct Soho '73 (Caithness-ish).
  // Bigger than before so the glass is the visual focus, with a chunky
  // crystal base and a fat rim.
  var gW = 56, gH = 76, topW = 64;
  var y0 = -gH;
  var baseH = 12; // height of the heavy crystal base block

  // === Outer glass body (full silhouette) ===
  c.fillStyle = 'rgba(200,210,225,0.05)';
  c.beginPath();
  c.moveTo(-gW / 2, 0);
  c.lineTo(-topW / 2, y0);
  c.lineTo(topW / 2, y0);
  c.lineTo(gW / 2, 0);
  c.closePath();
  c.fill();

  // === Chunky crystal base block (denser fill, suggests heavy base) ===
  c.fillStyle = 'rgba(220,230,245,0.15)';
  c.beginPath();
  c.moveTo(-gW / 2, 0);
  c.lineTo(gW / 2, 0);
  c.lineTo(gW / 2 - 1, -baseH);
  c.lineTo(-gW / 2 + 1, -baseH);
  c.closePath();
  c.fill();

  // === Glass outline (clean stroke around the body) ===
  c.strokeStyle = 'rgba(255,255,255,0.28)';
  c.lineWidth = 1.3;
  c.beginPath();
  c.moveTo(-gW / 2, 0);
  c.lineTo(-topW / 2, y0);
  c.lineTo(topW / 2, y0);
  c.lineTo(gW / 2, 0);
  c.stroke();

  // === Liquid — a pub double sits low in the glass and lets the light
  //    through. Roughly half what it used to be, with translucency. ===
  var liqH = gH * 0.22 * lev;
  var liqTop = -liqH;
  var lW = gW / 2 - 1.5;
  var yL = Math.max(-gH + 2, this._tiltedY(liqTop, -lW));
  var yR = Math.min(-1, this._tiltedY(liqTop, lW));
  // Liquid body — subtle gradient + translucency, so the crystal reads through it
  c.save();
  c.globalAlpha = 0.42;
  var lqGrad = c.createLinearGradient(0, 0, 0, liqTop);
  lqGrad.addColorStop(0, cfg.liq);
  lqGrad.addColorStop(1, cfg.hi || cfg.liq);
  c.fillStyle = lqGrad;
  c.beginPath();
  c.moveTo(-lW, 0);
  c.lineTo(-lW - 1, yL + wob * 100);
  c.quadraticCurveTo(0, (yL + yR) / 2 - wob * 200, lW + 1, yR + wob * 100);
  c.lineTo(lW, 0);
  c.closePath();
  c.fill();
  c.restore();

  // === Ice cubes (with facets and warm-amber glow from the whisky) ===
  if (liqH > 8) {
    var icePos = [[-9, -liqH * 0.50], [5, -liqH * 0.38], [-1, -liqH * 0.68]];
    for (var i = 0; i < icePos.length; i++) {
      var ix = icePos[i][0], iy = icePos[i][1] + wob * 80;
      if (iy > -3 && iy < liqTop + 3) {
        c.fillStyle = 'rgba(225,238,250,0.30)';
        c.strokeStyle = 'rgba(240,250,255,0.55)';
        c.lineWidth = 0.7;
        c.beginPath();
        c.rect(ix, iy, 9, 9);
        c.fill();
        c.stroke();
        // Cross-facet line (cut-cube look)
        c.strokeStyle = 'rgba(255,255,255,0.25)';
        c.lineWidth = 0.5;
        c.beginPath();
        c.moveTo(ix, iy);
        c.lineTo(ix + 9, iy + 9);
        c.stroke();
        // Top-left highlight
        c.fillStyle = 'rgba(255,255,255,0.30)';
        c.fillRect(ix + 1, iy + 1, 3, 1.6);
      }
    }
  }

  // === Liquid surface highlight (meniscus) ===
  c.save();
  c.translate(0, (yL + yR) / 2 + wob * 100);
  c.rotate(-this.tiltAngle);
  c.fillStyle = cfg.hi;
  c.globalAlpha = 0.30;
  c.beginPath();
  c.ellipse(0, 0, lW - 2, 2.6, 0, 0, Math.PI * 2);
  c.fill();
  c.globalAlpha = 0.5;
  c.strokeStyle = 'rgba(255,255,255,0.22)';
  c.lineWidth = 0.6;
  c.beginPath();
  c.ellipse(0, 0, lW - 2, 2.6, 0, 0, Math.PI * 2);
  c.stroke();
  c.globalAlpha = 1;
  c.restore();

  // === Glass highlights — left edge & subtle right refraction ===
  c.fillStyle = 'rgba(255,255,255,0.12)';
  c.fillRect(-topW / 2 + 4, y0 + 4, 2, gH - 8);
  c.fillStyle = 'rgba(255,255,255,0.05)';
  c.fillRect(topW / 2 - 5, y0 + 4, 1.5, gH - 8);

  // === Thicker fluted rim ===
  c.strokeStyle = 'rgba(255,255,255,0.42)';
  c.lineWidth = 2;
  c.beginPath();
  c.moveTo(-topW / 2 + 1, y0);
  c.lineTo(topW / 2 - 1, y0);
  c.stroke();
  // Rim highlight directly under it (catches light)
  c.strokeStyle = 'rgba(255,255,255,0.14)';
  c.lineWidth = 0.6;
  c.beginPath();
  c.moveTo(-topW / 2 + 2, y0 + 2);
  c.lineTo(topW / 2 - 2, y0 + 2);
  c.stroke();

  // === Cut-crystal pattern on the heavy base — radiating prism cuts +
  //    secondary rays + an outer ring, all visible through the liquid. ===
  c.save();
  c.translate(0, -baseH / 2);
  // Primary rays (6) — main star
  c.strokeStyle = 'rgba(255,255,255,0.55)';
  c.lineWidth = 1.1;
  for (var si = 0; si < 6; si++) {
    var sa = si * Math.PI / 3;
    c.beginPath();
    c.moveTo(0, 0);
    c.lineTo(Math.cos(sa) * 12, Math.sin(sa) * 3.5);
    c.stroke();
  }
  // Secondary rays (6) at a 30° offset — gives a 12-point star feel
  c.strokeStyle = 'rgba(255,250,220,0.32)';
  c.lineWidth = 0.7;
  for (var sj = 0; sj < 6; sj++) {
    var saj = sj * Math.PI / 3 + Math.PI / 6;
    c.beginPath();
    c.moveTo(Math.cos(saj) * 2, Math.sin(saj) * 0.6);
    c.lineTo(Math.cos(saj) * 9, Math.sin(saj) * 2.7);
    c.stroke();
  }
  // Outer ring catching the prism light
  c.strokeStyle = 'rgba(255,255,240,0.30)';
  c.lineWidth = 0.6;
  c.beginPath();
  c.ellipse(0, 0, 13, 3.8, 0, 0, Math.PI * 2);
  c.stroke();
  // Inner ring (suggests a turned-base detail)
  c.strokeStyle = 'rgba(255,255,255,0.22)';
  c.lineWidth = 0.5;
  c.beginPath();
  c.ellipse(0, 0, 5.5, 1.7, 0, 0, Math.PI * 2);
  c.stroke();
  // Bright outer caps on the primary rays — prismatic sparkle
  c.strokeStyle = 'rgba(255,250,220,0.55)';
  c.lineWidth = 0.7;
  for (var si2 = 0; si2 < 6; si2++) {
    var sa2 = si2 * Math.PI / 3;
    c.beginPath();
    c.moveTo(Math.cos(sa2) * 9, Math.sin(sa2) * 2.7);
    c.lineTo(Math.cos(sa2) * 13, Math.sin(sa2) * 3.8);
    c.stroke();
  }
  // Central highlight — the kaleidoscope eye of the cut
  c.fillStyle = 'rgba(255,255,240,0.75)';
  c.beginPath();
  c.arc(0, 0, 1.6, 0, Math.PI * 2);
  c.fill();
  c.restore();

  // === Bottom seat line — where glass meets surface ===
  c.strokeStyle = 'rgba(255,255,255,0.18)';
  c.lineWidth = 1.6;
  c.beginPath();
  c.moveTo(-gW / 2 - 2, 1);
  c.lineTo(gW / 2 + 2, 1);
  c.stroke();
}

// === WINE GLASS ===
_drawWine(c, cfg, lev, wob) {
  // Burgundy-style wine glass — wider than it is tall, properly globular.
  // Previously 34×50 read too narrow and got mistaken for a flute.
  var bowlW = 48, bowlH = 42, stemH = 32, baseW = 28;
  var bowlY = -(stemH + bowlH);
  // Stem
  c.strokeStyle = 'rgba(255,255,255,0.2)';
  c.lineWidth = 2;
  c.beginPath();
  c.moveTo(0, 0);
  c.lineTo(0, -stemH);
  c.stroke();
  // Base
  c.beginPath();
  c.ellipse(0, 0, baseW / 2, 4, 0, 0, Math.PI * 2);
  c.stroke();
  // Bowl
  c.fillStyle = 'rgba(200,200,200,0.06)';
  c.beginPath();
  c.moveTo(-8, -stemH);
  c.quadraticCurveTo(-bowlW / 2, -stemH - bowlH * 0.5, -bowlW / 2 + 4, bowlY);
  c.lineTo(bowlW / 2 - 4, bowlY);
  c.quadraticCurveTo(bowlW / 2, -stemH - bowlH * 0.5, 8, -stemH);
  c.closePath();
  c.fill();
  c.strokeStyle = 'rgba(255,255,255,0.18)';
  c.lineWidth = 1;
  c.stroke();
  // Liquid in bowl (top surface tilts to stay world-horizontal)
  var liqH = bowlH * 0.55 * lev;
  var liqBot = -stemH;
  var liqTop = liqBot - liqH;
  var lW = 7 + (bowlW / 2 - 10) * (liqH / bowlH);
  var yL = Math.max(-(stemH + bowlH) + 2, this._tiltedY(liqTop, -lW));
  var yR = Math.min(liqBot - 1, this._tiltedY(liqTop, lW));
  // Base liquid colour
  c.fillStyle = cfg.liq;
  c.beginPath();
  c.moveTo(-7, liqBot);
  c.quadraticCurveTo(-lW, yL + wob * 100, 0, (yL + yR) / 2 - wob * 150);
  c.quadraticCurveTo(lW, yR + wob * 100, 7, liqBot);
  c.closePath();
  c.fill();
  // Luster — light sheen on left inner bowl face
  if (liqH > 4) {
    var luster = c.createLinearGradient(-lW, (yL + yR) / 2, lW * 0.3, liqBot);
    luster.addColorStop(0, 'rgba(210,90,110,0.28)');
    luster.addColorStop(0.5, 'rgba(180,60,80,0.08)');
    luster.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = luster;
    c.beginPath();
    c.moveTo(-7, liqBot);
    c.quadraticCurveTo(-lW, yL + wob * 100, 0, (yL + yR) / 2 - wob * 150);
    c.quadraticCurveTo(lW, yR + wob * 100, 7, liqBot);
    c.closePath();
    c.fill();
  }
}

// === CHAMPAGNE FLUTE ===
_drawChampagne(c, cfg, lev, wob) {
  var fluteW = 16, fluteH = 65, stemH = 32, baseW = 22;
  var fluteY = -(stemH + fluteH);
  // Stem
  c.strokeStyle = 'rgba(255,255,255,0.2)';
  c.lineWidth = 1.5;
  c.beginPath();
  c.moveTo(0, 0);
  c.lineTo(0, -stemH);
  c.stroke();
  // Base
  c.beginPath();
  c.ellipse(0, 0, baseW / 2, 3, 0, 0, Math.PI * 2);
  c.stroke();
  // Flute body
  c.fillStyle = 'rgba(200,200,200,0.06)';
  c.beginPath();
  c.moveTo(-fluteW / 2 + 2, -stemH);
  c.lineTo(-fluteW / 2, fluteY + 10);
  c.quadraticCurveTo(-fluteW / 2 + 2, fluteY, 0, fluteY);
  c.quadraticCurveTo(fluteW / 2 - 2, fluteY, fluteW / 2, fluteY + 10);
  c.lineTo(fluteW / 2 - 2, -stemH);
  c.closePath();
  c.fill();
  c.strokeStyle = 'rgba(255,255,255,0.18)';
  c.lineWidth = 1;
  c.stroke();
  // Liquid (top surface tilts to stay world-horizontal)
  var liqH = fluteH * 0.75 * lev;
  var liqBot = -stemH;
  var liqTop = liqBot - liqH;
  var lWf = fluteW / 2 - 2;
  var yL = Math.max(-(stemH + fluteH) + 2, this._tiltedY(liqTop, -lWf));
  var yR = Math.min(liqBot - 1, this._tiltedY(liqTop, lWf));
  c.fillStyle = cfg.liq;
  c.beginPath();
  c.moveTo(-fluteW / 2 + 3, liqBot);
  c.lineTo(-fluteW / 2 + 2, yL + wob * 80);
  c.quadraticCurveTo(0, (yL + yR) / 2 - wob * 150, fluteW / 2 - 2, yR + wob * 80);
  c.lineTo(fluteW / 2 - 3, liqBot);
  c.closePath();
  c.fill();
  // Bubbles — three rising streams with varied speed and drift
  if (lev > 0.15 && liqH > 6) {
    var streams = [
      { x: -3.5, speed: 20, phase: 0.0, drift: 1.4 },
      { x:  0.5, speed: 15, phase: 0.8, drift: 0.9 },
      { x:  3.5, speed: 24, phase: 1.6, drift: 1.7 }
    ];
    for (var s = 0; s < streams.length; s++) {
      var str = streams[s];
      for (var b = 0; b < 4; b++) {
        var tOff = (this.t * str.speed + str.phase + b * (liqH / str.speed)) % liqH;
        var bx = str.x + Math.sin(this.t * 2.1 + s * 1.3 + b * 0.7) * str.drift;
        var by = liqBot - tOff;
        if (by > liqTop + 1 && by < liqBot - 1) {
          var prog = tOff / liqH;
          var bsize = 0.6 + prog * 0.9;          // grow as they rise
          var balpha = 0.20 + prog * 0.30;       // brighten near surface
          c.fillStyle = 'rgba(255,252,200,' + balpha.toFixed(2) + ')';
          c.beginPath();
          c.arc(bx, by, bsize, 0, Math.PI * 2);
          c.fill();
        }
      }
    }
  }
}

// === TALL GLASS (gin & tonic / bitter lemon) ===
_drawTallGlass(c, cfg, lev, wob) {
  var gW = 28, gH = 80, topW = 30;
  var y0 = -gH;
  // Glass body
  c.fillStyle = 'rgba(200,200,200,0.07)';
  c.beginPath();
  c.moveTo(-gW / 2, 0);
  c.lineTo(-topW / 2, y0);
  c.lineTo(topW / 2, y0);
  c.lineTo(gW / 2, 0);
  c.closePath();
  c.fill();
  c.strokeStyle = 'rgba(255,255,255,0.18)';
  c.lineWidth = 1.2;
  c.stroke();
  // Liquid (top surface tilts to stay world-horizontal)
  var liqH = gH * 0.8 * lev;
  var liqTop = -liqH;
  var lW = gW / 2 - 2;
  var yL = Math.max(-gH + 2, this._tiltedY(liqTop, -lW));
  var yR = Math.min(-1, this._tiltedY(liqTop, lW));
  c.fillStyle = cfg.liq;
  c.beginPath();
  c.moveTo(-lW, 0);
  c.lineTo(-lW - 1, yL + wob * 150);
  c.quadraticCurveTo(0, (yL + yR) / 2 - wob * 300, lW + 1, yR + wob * 150);
  c.lineTo(lW, 0);
  c.closePath();
  c.fill();
  // Lemon slice on rim
  c.fillStyle = '#e8d860';
  c.globalAlpha = 0.7;
  c.beginPath();
  c.arc(topW / 2 - 2, y0 + 2, 8, 0, Math.PI, true);
  c.fill();
  c.fillStyle = '#f0e880';
  c.beginPath();
  c.arc(topW / 2 - 2, y0 + 2, 5, 0, Math.PI, true);
  c.fill();
  c.globalAlpha = 1;
  // Ice cubes
  c.fillStyle = 'rgba(200,220,240,0.2)';
  c.fillRect(-5, -liqH * 0.4, 10, 8);
  c.fillRect(2, -liqH * 0.6, 8, 7);
  // Glass highlight
  c.fillStyle = 'rgba(255,255,255,0.06)';
  c.fillRect(-topW / 2 + 3, y0 + 4, 3, gH - 8);
  // Base
  c.strokeStyle = 'rgba(255,255,255,0.1)';
  c.lineWidth = 2;
  c.beginPath();
  c.moveTo(-gW / 2 - 1, 2);
  c.lineTo(gW / 2 + 1, 2);
  c.stroke();
}
};

// Global helper to show drink popup from passage scripts
window.showDrinkPopup = function(drinkType) {
  new window.DrinkPopup(drinkType);
};


window.startBarGame = function() {
if (window.currentBarGame) window.currentBarGame.stop();
document.getElementById('pre-bar').classList.add('hidden');
var sobriety = parseInt(document.getElementById('sob-data-bar').textContent) || 55;
var canvas = document.getElementById('bar-canvas');
canvas.style.display = 'block';
canvas.classList.remove('success-flash', 'error-flash');
window.currentBarGame = new window.BarGame('bar-canvas', sobriety);
// The Ronnie Scott's passage doubles as the venue (jazz bed) AND the bar
// canvas minigame container. Hand off audio: stop the jazz, start the
// retro bed. Tag-based observer will swap them back when the player
// navigates to Bar Canvas Win/Lose (which carry venue-ronnies but not
// minigame).
if (window.dssAudio) {
  if (window.dssAudio.stopBed) { try { window.dssAudio.stopBed('jazz-ronnies'); } catch(e) {} }
  if (window.dssAudio.stopBed) { try { window.dssAudio.stopBed('minigame-retro'); } catch(e) {} }
}
if (window._jazzMiniEl) { try { window._jazzMiniEl.pause(); window._jazzMiniEl.src=''; window._jazzMiniEl=null; } catch(e) {} }
if (window._jazzMiniMuteWatcher) { try { clearInterval(window._jazzMiniMuteWatcher); } catch(e) {} window._jazzMiniMuteWatcher = null; }
// Start the bar-mini music for the entire game (mixing + carry phases).
// _startCarryTransition guards on !_jazzMiniEl so it won't restart it.
// Respect dssAudio's mute state: set .muted at creation and poll so a
// mute toggle mid-game takes effect (the <audio> element is outside the
// Web Audio graph that dssAudio.setMuted controls).
if (window._jazzMiniDataUri) {
  try {
    var _jmInit = new Audio(window._jazzMiniDataUri);
    _jmInit.volume = 0.28; _jmInit.loop = true;
    _jmInit.muted = !!(window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted());
    _jmInit.play().catch(function(){});
    window._jazzMiniEl = _jmInit;
    window._jazzMiniMuteWatcher = setInterval(function(){
      var el = window._jazzMiniEl;
      if (!el) { clearInterval(window._jazzMiniMuteWatcher); window._jazzMiniMuteWatcher = null; return; }
      var m = !!(window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted());
      if (el.muted !== m) el.muted = m;
    }, 250);
  } catch(e) {}
}
var _jmObs = new MutationObserver(function(mutations) {
  for (var m = 0; m < mutations.length; m++) {
    for (var n = 0; n < mutations[m].addedNodes.length; n++) {
      var nd = mutations[m].addedNodes[n];
      if (nd.nodeType === 1 && nd.tagName === 'TW-PASSAGE') {
        if (window._jazzMiniEl) { window._jazzMiniEl.pause(); window._jazzMiniEl.src=''; window._jazzMiniEl=null; }
        if (window._jazzMiniMuteWatcher) { try { clearInterval(window._jazzMiniMuteWatcher); } catch(e) {} window._jazzMiniMuteWatcher = null; }
        _jmObs.disconnect(); return;
      }
    }
  }
});
_jmObs.observe(document.body, { childList: true, subtree: true });
};
// Delegated click listener as backup for inline onclick
document.addEventListener('click', function(e) {
if (e.target && e.target.id === 'bar-start-btn') window.startBarGame();
if (e.target && e.target.id === 'fight-start-btn') window.startFightGame();
});

// ====== PASSAGE GENERATION GUARD ======
// Tracks passage navigation so scheduled popups can be cancelled if the player moves on.
window._passageGen = 0;
(function() {
  function watch() {
    var story = document.querySelector('tw-story');
    if (!story) return;
    new MutationObserver(function(muts) {
      muts.forEach(function(m) {
        m.addedNodes.forEach(function(n) {
          if (n.nodeType === 1 && n.tagName === 'TW-PASSAGE') {
            window._passageGen++;
            // Audio cues triggered by passage content / name.
            // Defer attribute read by a tick — Harlowe populates data-name
            // asynchronously after creating the tw-passage element, so reading
            // it synchronously in the observer returns empty.
            (function(passageNode) {
              setTimeout(function() {
            try {
              // Harlowe doesn't put the passage NAME on tw-passage as a DOM
              // attribute (we checked — it just has `tags`). So all our
              // detection works off the `tags` attribute and DOM content.
              var passageTags = passageNode.getAttribute('tags') || '';
              var tags = passageTags.split(/\s+/).filter(Boolean);
              if (window.dssAudio) {
                // Dean Street theme — starts on Dean Street, stops elsewhere.
                // Detection is by tag (Dean Street is uniquely tagged 'hub').
                if (window.dssAudio.updateMusicForPassage) window.dssAudio.updateMusicForPassage(passageNode);
                // Venue ambient beds (pub, club, etc.) — start whichever bed
                // matches this passage's tags; stop any that don't.
                if (window.dssAudio.updateAmbientBedsForPassage) window.dssAudio.updateAmbientBedsForPassage(passageNode);
                // Page 93 retrieved from the pyre — a bigger moment than the
                // old single page-rustle. Layered cue: fist into the flames,
                // then the heat roaring around the hand, then the paper
                // itself emerging, then a far-off bell — the mythic chime
                // for the page recovered from Dido's fire.
                if (passageNode.querySelector('.page-found')) {
                  if (window.dssAudio.punchImpact) setTimeout(function(){ window.dssAudio.punchImpact(); }, 60);
                  if (window.dssAudio.passageWhoosh) setTimeout(function(){ window.dssAudio.passageWhoosh(); }, 140);
                  setTimeout(function(){ window.dssAudio.pageRustle(); }, 560);
                  if (window.dssAudio.distantBell) setTimeout(function(){ window.dssAudio.distantBell(); }, 950);
                }
                // Item acquired — matchbook gets a special strike, everything
                // else gets the generic itemFound thud. Page-found has its own.
                if (passageNode.querySelector('.item-box') && !passageNode.querySelector('.page-found')) {
                  var itemNames = passageNode.querySelectorAll('.item-name');
                  var isMatchbook = false;
                  for (var ix = 0; ix < itemNames.length; ix++) {
                    if (/matchbook/i.test(itemNames[ix].textContent)) { isMatchbook = true; break; }
                  }
                  if (isMatchbook) {
                    setTimeout(function(){ window.dssAudio.matchStrike(); }, 220);
                  } else {
                    setTimeout(function(){ window.dssAudio.itemFound(); }, 220);
                  }
                }
                // Haunt collected — pen scratching in the notebook
                if (passageNode.querySelector('.haunt-box')) {
                  setTimeout(function(){ window.dssAudio.penScratch(); }, 600);
                }
                // Phone scenes are split into two passages:
                //   .phone-ringing — the "Answer the phone" prompt; bell rings
                //   .phone-scene   — the dialogue; heartbeat plays under it
                // The bell stops as soon as we leave the ringing passage.
                if (passageNode.querySelector('.phone-ringing')) {
                  var ringGen = window._passageGen;
                  setTimeout(function(){
                    if (window._passageGen !== ringGen) return;
                    window.dssAudio.phoneBell(3);
                  }, 250);
                } else {
                  // Any non-ringing passage: silence the bell.
                  if (window.dssAudio.stopPhoneBell) window.dssAudio.stopPhoneBell();
                }
                if (passageNode.querySelector('.phone-scene')) {
                  var hbGen = window._passageGen;
                  setTimeout(function(){
                    if (window._passageGen !== hbGen) return;
                    window.dssAudio.heartbeat(6);
                  }, 1500);
                  // Subtle telephone-line ambient under the dialogue.
                  setTimeout(function(){
                    if (window._passageGen !== hbGen) return;
                    if (window.dssAudio.phoneLine) window.dssAudio.phoneLine();
                  }, 200);
                } else {
                  // Non-call passage: cut the phone-line ambient.
                  if (window.dssAudio.stopPhoneLine) window.dssAudio.stopPhoneLine();
                }
                // Glass smash — fires ~1.5s after the drink popup fully closes
                if (passageNode.querySelector('.empty-glass-marker')) {
                  var smashGen = window._passageGen;
                  var smashOnce = function() {
                    window.removeEventListener('drinkpopup:closed', smashOnce);
                    if (window._passageGen !== smashGen) return;
                    setTimeout(function(){ if (window._passageGen === smashGen) window.dssAudio.glassSmash(); }, 1500);
                  };
                  window.addEventListener('drinkpopup:closed', smashOnce);
                }
                // Venue door creak + first-entry whoosh, by venue tag.
                // Track `_currentVenue` so we don't creak on every sub-passage
                // within a venue (e.g. Davy Merkin inside the Colony) — only
                // when we ENTER the venue freshly from outside.
                var VENUES = ['venue-french', 'venue-coach', 'venue-colony',
                              'venue-trishas', 'venue-cecilcourt', 'venue-ronnies'];
                var newVenue = null;
                for (var vi = 0; vi < VENUES.length; vi++) {
                  if (tags.indexOf(VENUES[vi]) !== -1) { newVenue = VENUES[vi]; break; }
                }
                // Per-venue entry door SFX — fires only when ENTERING a
                // venue fresh from outside (not on sub-passages within
                // the same venue). Each venue gets a distinct sound so
                // the player feels the difference between thresholds.
                if (newVenue && newVenue !== window._currentVenue) {
                  var doorMap = {
                    'venue-coach':      'doorCreak',     // heavy pub door + brass shop-bell
                    'venue-trishas':    'doorSwingBell', // quick swing + brass ping
                    'venue-ronnies':    'doorThud',      // muffled velvet curtain
                    // venue-cecilcourt intentionally omitted — the street
                    // passages (Cecil Court, Watkins, Waltz) are outdoors and
                    // looking-through-windows; the shop bell fires only on
                    // actually entering O'Flatterly's shop, handled below.
                    'venue-colony':     'doorCreak',     // old members-club door
                    'venue-french':     'doorCreak',     // old pub door
                    'venue-pillars':    'doorCreak'      // pub door
                  };
                  var fn = doorMap[newVenue];
                  if (fn && window.dssAudio && window.dssAudio[fn]) {
                    setTimeout(function(){ window.dssAudio[fn](); }, 120);
                  }
                }
                // Cecil Court shop bell — fires when stepping inside
                // O'Flatterly's shop (detected via .shop-bell-marker). Rings
                // once per "phase" of the page-return arc: pre-quest,
                // returning-with-page, and post-return — so the brass
                // clapper rings again each time the situation has changed.
                if (passageNode.querySelector('.shop-bell-marker')) {
                  var _st = window.Harlowe && window.Harlowe.API_ACCESS && window.Harlowe.API_ACCESS.STATE && window.Harlowe.API_ACCESS.STATE.variables;
                  var phase = 'pre';
                  if (_st && _st.returnedPage) phase = 'post';
                  else if (_st && _st.hasMissingPage) phase = 'has-page';
                  if (!window._heardOflatterlyBellPhases) window._heardOflatterlyBellPhases = {};
                  if (!window._heardOflatterlyBellPhases[phase]) {
                    window._heardOflatterlyBellPhases[phase] = true;
                    if (window.dssAudio && window.dssAudio.doorShopBell) {
                      setTimeout(function(){ window.dssAudio.doorShopBell(); }, 120);
                    }
                  }
                }
                window._currentVenue = newVenue;
                // Ambient beds: pyre (fire) > dream (wind) > outdoor (traffic).
                // Each takes the _ambient slot; switching cleanly stops the
                // previous one (and any horn timer it may have scheduled).
                var inDream = (tags.indexOf('dream') !== -1);
                var inPyre = (tags.indexOf('pyre') !== -1);
                var inOutdoor = (tags.indexOf('outdoor') !== -1);
                // Alba revelation passages (LINE 1) carry [outdoor] but should
                // feel hushed — duck the traffic bed to ~22% so it's a quiet
                // murmur, not a road, while the line types itself out.
                var hasRevelation = passageNode.querySelector('.revelation-box');
                if (inPyre) {
                  window.dssAudio.fireFarnell();
                } else if (inDream) {
                  window.dssAudio.windFarnell();
                } else if (inOutdoor) {
                  window.dssAudio.distantTraffic(hasRevelation ? 0.22 : 1);
                } else if (window._wasInDream || window._wasInPyre || window._wasOutdoor) {
                  window.dssAudio.ambientOff();
                }
                window._wasInDream = inDream;
                window._wasInPyre = inPyre;
                window._wasOutdoor = inOutdoor;
              }
            } catch(e) { if (window.console) console.error('[dssAudio]', e); }
              }, 80);
            })(n);
            // Hide ceremony boxes (and the HAUNTS lore-box explainer that
            // sometimes appears alongside them) on first render. They'll
            // fade in once the drink popup has had its moment.
            // (link:)-wrapped lore-boxes aren't in the DOM yet at this point,
            // so they won't get caught by the selector.
            var hideSel = '.haunt-box, .revelation-box, .page-found, .item-box, .lore-box';
            var toHide = n.querySelectorAll(hideSel);
            for (var hh = 0; hh < toHide.length; hh++) {
              toHide[hh].style.transition = 'opacity 0.8s ease';
              toHide[hh].style.opacity = '0';
            }
            // Reveal any haunt boxes in the new passage — but wait for
            // an open drink popup to finish first, so the ceremony is
            // not hidden behind the drinking animation.
            var doReveal = function() {
              var TYPES = [
                { sel: '.haunt-box',     cls: 'haunt-mote',       n: 18 },
                { sel: '.revelation-box',cls: 'revelation-mote',  n: 18 },
                { sel: '.page-found',    cls: 'page-mote',        n: 18 },
                { sel: '.item-box',      cls: 'item-mote',        n: 18 },
                { sel: '.quest-collected',cls: 'quest-mote',      n: 18 }
              ];
              // Helper exposed for late-spawning motes from custom flows
              // (e.g. the Critic page-turn waits until the verdict's
              // aftermath fades in before firing). Mirrors the spawn logic
              // below — kept in sync if either is updated.
              if (!window.dssSpawnMotes) window.dssSpawnMotes = function(box, cls, count, opts) {
                if (!box || box.getAttribute('data-motes-fired') === '1') return;
                box.setAttribute('data-motes-fired', '1');
                count = count || 18;
                opts = opts || {};
                /* If the box is off-screen, scroll it into view first and
                   defer the spawn so origin coordinates land in the viewport.
                   Otherwise motes appear to stream up from below (or down
                   from above) the visible page. Pass {noScroll:true} for
                   flows that shouldn't ever yank the viewport (e.g. the
                   Great Ham critic aftermath — the player has just watched
                   a careful book-closing animation, a scroll after it reads
                   as a jolt). */
                var preRect = box.getBoundingClientRect();
                if (!opts.noScroll && (preRect.top < 0 || preRect.bottom > window.innerHeight)) {
                  try { box.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch(e) {}
                  box.removeAttribute('data-motes-fired');
                  setTimeout(function(){ window.dssSpawnMotes(box, cls, count, opts); }, 550);
                  return;
                }
                var rect = box.getBoundingClientRect();
                /* Anchor motes at the box's centre so the gesture reads as
                   "the collected thing is sending up wisps". The old
                   top-right offset (0.78, 0.18) drifted the origin off the
                   visible content and felt haphazard. */
                var startTop = rect.top + rect.height * 0.5;
                var startLeft = rect.left + rect.width * 0.5;
                var nbEl = document.querySelector('.notebook-link');
                var nb = nbEl ? nbEl.getBoundingClientRect() : null;
                var nbX = nb ? (nb.left + nb.width * 0.5) : null;
                var nbY = nb ? (nb.top  + nb.height * 0.5) : null;
                for (var k = 1; k <= count; k++) {
                  var m = document.createElement('span');
                  m.className = cls + ' ' + cls + '-' + k;
                  m.style.position = 'fixed';
                  m.style.top = startTop + 'px';
                  m.style.left = startLeft + 'px';
                  m.style.right = 'auto';
                  m.style.zIndex = '99999';
                  if (nbX !== null) {
                    var jitterX = (Math.random() - 0.5) * 28;
                    var jitterY = (Math.random() - 0.5) * 18;
                    m.style.setProperty('--mote-tx', ((nbX - startLeft) + jitterX) + 'px');
                    m.style.setProperty('--mote-ty', ((nbY - startTop) + jitterY) + 'px');
                  } else {
                    m.style.setProperty('--mote-tx', '210px');
                    m.style.setProperty('--mote-ty', '-540px');
                  }
                  document.body.appendChild(m);
                }
                // Pulse the notebook link the same way the global observer does.
                var nbLink = document.querySelector('.notebook-link');
                if (nbLink) {
                  nbLink.classList.remove('notebook-pulse');
                  void nbLink.offsetWidth;
                  nbLink.classList.add('notebook-pulse');
                  setTimeout(function(){ if (nbLink) nbLink.classList.remove('notebook-pulse'); }, 7500);
                }
              };
              var performSpawn = function() {
                // Compute the NOTEBOOK link's viewport-centre once per reveal so
                // every spawned mote can target it. Motes that miss the notebook
                // ruin the "filed away" gesture, so we redirect each mote toward
                // the real header link instead of using a fixed translate.
                var notebookEl = document.querySelector('.notebook-link');
                var nb = notebookEl ? notebookEl.getBoundingClientRect() : null;
                var nbX = nb ? (nb.left + nb.width * 0.5) : null;
                var nbY = nb ? (nb.top  + nb.height * 0.5) : null;
                var anyBoxSpawned = false;
                TYPES.forEach(function(t) {
                  var boxes = document.querySelectorAll(t.sel + ':not([data-motes])');
                  for (var i = 0; i < boxes.length; i++) {
                    boxes[i].setAttribute('data-motes', '1');
                    anyBoxSpawned = true;
                    // Capture the box's viewport position NOW. Motes are fixed
                    // children of <body>, so they pin to the viewport even if
                    // the user scrolls during the animation — the start point
                    // is locked at the moment of collection.
                    var rect = boxes[i].getBoundingClientRect();
                    /* Centre-of-box origin — see dssSpawnMotes comment above. */
                    var startTop = rect.top + rect.height * 0.5;
                    var startLeft = rect.left + rect.width * 0.5;
                    for (var k = 1; k <= t.n; k++) {
                      var m = document.createElement('span');
                      m.className = t.cls + ' ' + t.cls + '-' + k;
                      m.style.position = 'fixed';
                      m.style.top = startTop + 'px';
                      m.style.left = startLeft + 'px';
                      m.style.right = 'auto';
                      m.style.zIndex = '99999';
                      // Per-mote target offset: aim each mote at the notebook
                      // centre, with a tiny random scatter so the wisp reads as
                      // organic rather than a laser-line. Fall back to a
                      // sensible up-and-right if the notebook isn't in the DOM.
                      if (nbX !== null) {
                        var jitterX = (Math.random() - 0.5) * 28;
                        var jitterY = (Math.random() - 0.5) * 18;
                        var dx = (nbX - startLeft) + jitterX;
                        var dy = (nbY - startTop)  + jitterY;
                        m.style.setProperty('--mote-tx', dx + 'px');
                        m.style.setProperty('--mote-ty', dy + 'px');
                      } else {
                        m.style.setProperty('--mote-tx', '210px');
                        m.style.setProperty('--mote-ty', '-540px');
                      }
                      document.body.appendChild(m);
                    }
                  }
                });
                // Now fade the boxes back in
                for (var rr = 0; rr < toHide.length; rr++) {
                  toHide[rr].style.opacity = '1';
                }
                // Pulse the NOTEBOOK link for ANY collection-box type — haunt,
                // item, page-found, revelation. Previously only haunts triggered
                // the pulse; that left items and pages feeling un-filed.
                if (anyBoxSpawned) {
                  var nbLink = document.querySelector('.notebook-link');
                  if (nbLink) {
                    nbLink.classList.remove('notebook-pulse');
                    void nbLink.offsetWidth; // restart animation if already mid-pulse
                    nbLink.classList.add('notebook-pulse');
                    setTimeout(function() {
                      if (nbLink) nbLink.classList.remove('notebook-pulse');
                    }, 7500);
                  }
                }
                if (window.hauntBackgroundGlow) window.hauntBackgroundGlow();
                // Wheel reveal moved to the Dawn passage — fires there when the
                // alba is complete, over the dawn view, rather than mid-game on
                // the 12th haunt collection.
              };
              /* Don't auto-scroll just to make motes look "right" — yanking
                 the page after a drink-popup closes destroys reading flow.
                 The notebook pulse + box fade-in are enough cue; the player
                 reaches the box naturally as they read on. */
              performSpawn();
            };
            setTimeout(function() {
              if (window._drinkPopupOpen) {
                var handler = function() {
                  window.removeEventListener('drinkpopup:closed', handler);
                  setTimeout(doReveal, 200);
                };
                window.addEventListener('drinkpopup:closed', handler);
              } else {
                doReveal();
              }
            }, 600);
          }
        });
      });
    }).observe(story, { childList: true });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', watch);
  else watch();
})();

// ====== HAUNT BACKGROUND GLOW ======
// When a passage contains a visible .haunt-box, paint a warm golden radial glow
// behind all content so the moment of acquiring a haunt feels special.
window.hauntBackgroundGlow = function() {
  var passage = document.querySelector('tw-passage');
  if (!passage) return;

  // Remove any previous glow overlay (from a prior passage)
  var old = document.getElementById('haunt-bg-glow');
  if (old) old.parentNode.removeChild(old);

  // Find all .haunt-box elements in the current passage
  var boxes = passage.querySelectorAll('.haunt-box');
  if (!boxes.length) return;

  // Check if at least one box is actually visible (not inside a hidden conditional)
  var hasVisible = false;
  for (var i = 0; i < boxes.length; i++) {
    var el = boxes[i];
    // Walk up the DOM to check no ancestor is hidden
    var hidden = false;
    var parent = el.parentElement;
    while (parent && parent !== passage) {
      var style = window.getComputedStyle(parent);
      if (style.display === 'none' || style.visibility === 'hidden') { hidden = true; break; }
      parent = parent.parentElement;
    }
    if (!hidden) { hasVisible = true; break; }
  }
  if (!hasVisible) return;

  // Pulse the NOTEBOOK link in the header so the player sees where the haunt has gone
  var notebookLink = document.querySelector('.notebook-link');
  if (notebookLink) {
    notebookLink.classList.add('notebook-pulse');
    setTimeout(function() {
      if (notebookLink) notebookLink.classList.remove('notebook-pulse');
    }, 7500);
  }

  // Create the golden glow overlay
  var glow = document.createElement('div');
  glow.id = 'haunt-bg-glow';
  glow.style.cssText = [
    'position:fixed;',
    'top:0;left:0;width:100vw;height:100vh;',
    'pointer-events:none;',
    'z-index:0;',
    'opacity:0;',
    'transition:opacity 1.8s ease-in;',
    'background:radial-gradient(ellipse at 50% 55%,',
    '  rgba(180,140,50,0.12) 0%,',
    '  rgba(160,120,40,0.07) 30%,',
    '  rgba(120,90,30,0.03) 55%,',
    '  rgba(0,0,0,0) 80%);'
  ].join('');

  // Insert as first child of body so it's behind everything
  document.body.insertBefore(glow, document.body.firstChild);

  // Fade in after a brief moment (allow the hauntReveal animation to start first)
  setTimeout(function() { glow.style.opacity = '1'; }, 100);

  // Auto-remove when the player navigates away (passage changes)
  var gen = window._passageGen;
  var check = setInterval(function() {
    if (window._passageGen !== gen) {
      clearInterval(check);
      glow.style.opacity = '0';
      setTimeout(function() {
        if (glow.parentNode) glow.parentNode.removeChild(glow);
      }, 2000);
    }
  }, 300);
};

// ====== OPUS STATE REVEAL — Ripley's Wheel ======
// Fires from the Dawn passage when the alba is complete. Drawn over the
// dawn view as the win-state coda. Caller is responsible for gating; the
// only safety check here is "don't double-spawn".
window.dssOpusReveal = function() {
  if (document.getElementById('dss-wheel-modal')) return;

  // Read collected haunts from Harlowe state. The wheel always renders its
  // geometric frame (rim, spokes, hub, Sol, ouroboros), but the alchemical
  // + haunt writing for each gate only shows for haunts the player actually
  // caught — so the wheel becomes a record of the night, not an all-or-
  // nothing reward. Defensive fallback: if state can't be read for any
  // reason, treat zero haunts as collected (the wheel still renders, just
  // without writing) rather than silently showing everything.
  var collectedHaunts = {};
  try {
    var dwmSt = window.Harlowe && window.Harlowe.API_ACCESS && window.Harlowe.API_ACCESS.STATE && window.Harlowe.API_ACCESS.STATE.variables;
    var dwmH = (dwmSt && dwmSt.haunts) || [];
    for (var dwmHi = 0; dwmHi < dwmH.length; dwmHi++) collectedHaunts[dwmH[dwmHi]] = true;
  } catch(e) {}

  // Canonical Ripley sequence (Compound of Alchymy, 1471), clockwise from 12 o'clock.
  // Calcinatio at the top — the start of the work. The patient alchemy reader
  // scans top-down clockwise and reads the twelve gates in their proper order.
  var stages = [
    ['Calcinatio',    'The Sketch'],
    ['Solutio',       'The Refusal'],
    ['Separatio',     'The Sorting'],
    ['Coniunctio',    'The Debt'],
    ['Putrefactio',   'The Beast'],
    ['Congelatio',    'The Head'],
    ['Cibatio',       'The Feeding'],
    ['Sublimatio',    'The Delivery'],
    ['Fermentatio',   'The Game'],
    ['Exaltatio',     'The Crown'],
    ['Multiplicatio', 'The Spread'],
    ['Projectio',     'The Wound']
  ];

  var modal = document.createElement('div');
  modal.id = 'dss-wheel-modal';
  modal.style.opacity = '0';

  var cx = 390, cy = 390;
  var rOuter = 280, rInner = 210, rHub = 70;
  var rHaunt = 232, rStage = 345;

  var s = '<svg viewBox="0 0 780 780" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">';
  // Frame: rim, inner ring, hub, spokes — spins into place.
  s += '<g class="dwm-frame">';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rOuter+'" fill="none" stroke="#d4a820" stroke-width="1.4" opacity="0.85"/>';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rInner+'" fill="none" stroke="#d4a820" stroke-width="0.7" opacity="0.45"/>';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rHub+'"   fill="none" stroke="#d4a820" stroke-width="0.5" opacity="0.4"/>';
  for (var i = 0; i < 12; i++) {
    var a = (-90 + i * 30) * Math.PI / 180;
    var x1 = (cx + rInner * Math.cos(a)).toFixed(1);
    var y1 = (cy + rInner * Math.sin(a)).toFixed(1);
    var x2 = (cx + rOuter * Math.cos(a)).toFixed(1);
    var y2 = (cy + rOuter * Math.sin(a)).toFixed(1);
    s += '<line x1="'+x1+'" y1="'+y1+'" x2="'+x2+'" y2="'+y2+'" stroke="#d4a820" stroke-width="0.55" opacity="0.55"/>';
  }
  s += '</g>';
  // Labels + central Sol + encircling Ouroboros — all fade in after the wheel has settled.
  s += '<g class="dwm-labels">';
  for (var i = 0; i < 12; i++) {
    var a = (-90 + i * 30) * Math.PI / 180;
    var hx = (cx + rHaunt * Math.cos(a)).toFixed(1);
    var hy = (cy + rHaunt * Math.sin(a) + 3).toFixed(1);
    var sx = (cx + rStage * Math.cos(a)).toFixed(1);
    var sy = (cy + rStage * Math.sin(a) + 4).toFixed(1);
    // Only emit text for gates whose haunt the player caught — uncaught
    // gates leave their spoke + ring empty, marking what wasn't found.
    if (collectedHaunts[stages[i][1]]) {
      s += '<text class="dwm-haunt" x="'+hx+'" y="'+hy+'" text-anchor="middle">' + stages[i][1] + '</text>';
      s += '<text class="dwm-stage" x="'+sx+'" y="'+sy+'" text-anchor="middle">' + stages[i][0] + '</text>';
    }
  }
  // Sol — astrological sun glyph (☉) at the heart: outer halo, eight rays, inner disk, central dot.
  // Ray-count is a placeholder pending mystical-number choice (will become 4 short + 7 long, or 9 + 3, etc.).
  s += '<g class="dwm-sol">';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="44" fill="none" stroke="#d4a820" stroke-width="0.7" opacity="0.45"/>';
  // Twelve rays at 30° intervals: 9 long + 3 short = 93 (Thelema). The 3 short rays
  // sit at 12, 4, and 8 o'clock — an equilateral triangle, the alchemical sigil
  // of fire / sulfur, hidden in Sol.
  // Long rays render as tapered triangular wedges for volume; short rays as fine lines.
  for (var r = 0; r < 12; r++) {
    var ra = (r * 30 - 90) * Math.PI / 180;
    var isShort = (r === 0 || r === 4 || r === 8);
    if (isShort) {
      var rxs1 = (cx + 22 * Math.cos(ra)).toFixed(1);
      var rys1 = (cy + 22 * Math.sin(ra)).toFixed(1);
      var rxs2 = (cx + 30 * Math.cos(ra)).toFixed(1);
      var rys2 = (cy + 30 * Math.sin(ra)).toFixed(1);
      s += '<line x1="'+rxs1+'" y1="'+rys1+'" x2="'+rxs2+'" y2="'+rys2+'" stroke="#d4a820" stroke-width="1.0" opacity="0.85" stroke-linecap="round"/>';
    } else {
      var rBase = 22;
      var rTipLong = 42;
      var halfBase = 2.4;
      var perpAng = ra + Math.PI / 2;
      var bxL = (cx + rBase * Math.cos(ra) + halfBase * Math.cos(perpAng)).toFixed(1);
      var byL = (cy + rBase * Math.sin(ra) + halfBase * Math.sin(perpAng)).toFixed(1);
      var bxR = (cx + rBase * Math.cos(ra) - halfBase * Math.cos(perpAng)).toFixed(1);
      var byR = (cy + rBase * Math.sin(ra) - halfBase * Math.sin(perpAng)).toFixed(1);
      var tx  = (cx + rTipLong * Math.cos(ra)).toFixed(1);
      var ty  = (cy + rTipLong * Math.sin(ra)).toFixed(1);
      s += '<path d="M '+bxL+' '+byL+' L '+tx+' '+ty+' L '+bxR+' '+byR+' Z" fill="#d4a820" fill-opacity="0.78" stroke="#d4a820" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/>';
    }
  }
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="18" fill="none" stroke="#d4a820" stroke-width="1.1" opacity="0.85"/>';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="14" fill="none" stroke="#d4a820" stroke-width="0.4" opacity="0.45"/>';
  s += '<circle cx="'+cx+'" cy="'+cy+'" r="3.0" fill="#d4a820" opacity="0.95"/>';
  s += '</g>';
  // Ouroboros — serpent wraps the rim, head meets tail at 6 o'clock (Cibatio — the work feeds itself).
  // Body: 320° arc with 40° gap; layered strokes for body weight + scale rhythm.
  // Head: bulge with eye and a faint forked-tongue mark, "biting" toward the tail across the gap.
  var rSerp = 295;
  var sStartX = (cx + rSerp * Math.cos(110 * Math.PI / 180)).toFixed(1);
  var sStartY = (cy + rSerp * Math.sin(110 * Math.PI / 180)).toFixed(1);
  var sEndX   = (cx + rSerp * Math.cos(70  * Math.PI / 180)).toFixed(1);
  var sEndY   = (cy + rSerp * Math.sin(70  * Math.PI / 180)).toFixed(1);
  var headX = parseFloat((cx + rSerp * Math.cos(72 * Math.PI / 180)).toFixed(1));
  var headY = parseFloat((cy + rSerp * Math.sin(72 * Math.PI / 180)).toFixed(1));
  var tailX = parseFloat((cx + rSerp * Math.cos(108 * Math.PI / 180)).toFixed(1));
  var tailY = parseFloat((cy + rSerp * Math.sin(108 * Math.PI / 180)).toFixed(1));
  // Body tangent at the head: perpendicular to the radius, going clockwise. At angle 72°
  // on the rim, that tangent direction is 162° in SVG angle terms — pointing down-and-left
  // toward the gap (and the tail). The serpent's nose points along this direction.
  var headRot = 162;
  var headRotRad = headRot * Math.PI / 180;
  // Head-local coordinate helper: maps (forward, lateral) offsets onto the SVG plane.
  var dwmPt = function(forward, lateral) {
    var fx = headX + forward * Math.cos(headRotRad) + lateral * Math.cos(headRotRad + Math.PI/2);
    var fy = headY + forward * Math.sin(headRotRad) + lateral * Math.sin(headRotRad + Math.PI/2);
    return [fx.toFixed(1), fy.toFixed(1)];
  };
  s += '<g class="dwm-serpent">';
  // === Body — line-art style: two parallel rails with chevron scale pattern between. ===
  var rRailIn = rSerp - 5;
  var rRailOut = rSerp + 5;
  var iSX = (cx + rRailIn  * Math.cos(110 * Math.PI / 180)).toFixed(1);
  var iSY = (cy + rRailIn  * Math.sin(110 * Math.PI / 180)).toFixed(1);
  var iEX = (cx + rRailIn  * Math.cos(70  * Math.PI / 180)).toFixed(1);
  var iEY = (cy + rRailIn  * Math.sin(70  * Math.PI / 180)).toFixed(1);
  var oSX = (cx + rRailOut * Math.cos(110 * Math.PI / 180)).toFixed(1);
  var oSY = (cy + rRailOut * Math.sin(110 * Math.PI / 180)).toFixed(1);
  var oEX = (cx + rRailOut * Math.cos(70  * Math.PI / 180)).toFixed(1);
  var oEY = (cy + rRailOut * Math.sin(70  * Math.PI / 180)).toFixed(1);
  s += '<path d="M '+iSX+' '+iSY+' A '+rRailIn +' '+rRailIn +' 0 1 1 '+iEX+' '+iEY+'" fill="none" stroke="#d4a820" stroke-width="1.0" opacity="0.85"/>';
  s += '<path d="M '+oSX+' '+oSY+' A '+rRailOut+' '+rRailOut+' 0 1 1 '+oEX+' '+oEY+'" fill="none" stroke="#d4a820" stroke-width="1.0" opacity="0.85"/>';
  // 38 chevron scales — small ∨ pointing inward, between the rails.
  // Alternate scales are filled with low-opacity gold for a banded shade pattern.
  var nScales = 38;
  for (var nS = 0; nS < nScales; nS++) {
    var tS = (nS + 0.5) / nScales;
    var thRad = (110 + tS * 320) * Math.PI / 180;
    var dRad = 3.6 * Math.PI / 180;
    var sxIn = (cx + rRailIn  * Math.cos(thRad)).toFixed(1);
    var syIn = (cy + rRailIn  * Math.sin(thRad)).toFixed(1);
    var sxOL = (cx + rRailOut * Math.cos(thRad - dRad)).toFixed(1);
    var syOL = (cy + rRailOut * Math.sin(thRad - dRad)).toFixed(1);
    var sxOR = (cx + rRailOut * Math.cos(thRad + dRad)).toFixed(1);
    var syOR = (cy + rRailOut * Math.sin(thRad + dRad)).toFixed(1);
    var fillVal = (nS % 2 === 0) ? '#d4a820' : 'none';
    var fillOp  = (nS % 2 === 0) ? '0.32'    : '0';
    s += '<path d="M '+sxOL+' '+syOL+' L '+sxIn+' '+syIn+' L '+sxOR+' '+syOR+' Z" fill="'+fillVal+'" fill-opacity="'+fillOp+'" stroke="#d4a820" stroke-width="0.55" opacity="0.72"/>';
  }
  // === Tail — two converging lines from the body rail endpoints, meeting at a sharp point. ===
  // The tip mirrors the body's two-rail structure tapered to a single coordinate.
  var tailTipX = (cx + (rSerp - 8) * Math.cos(96 * Math.PI / 180)).toFixed(1);
  var tailTipY = (cy + (rSerp - 8) * Math.sin(96 * Math.PI / 180)).toFixed(1);
  var topCtlX  = (cx + (rRailOut - 0.5) * Math.cos(104 * Math.PI / 180)).toFixed(1);
  var topCtlY  = (cy + (rRailOut - 0.5) * Math.sin(104 * Math.PI / 180)).toFixed(1);
  var botCtlX  = (cx + (rRailIn  + 0.5) * Math.cos(103 * Math.PI / 180)).toFixed(1);
  var botCtlY  = (cy + (rRailIn  + 0.5) * Math.sin(103 * Math.PI / 180)).toFixed(1);
  s += '<path d="M '+oSX+' '+oSY+' Q '+topCtlX+' '+topCtlY+' '+tailTipX+' '+tailTipY+'" fill="none" stroke="#d4a820" stroke-width="1.0" opacity="0.88" stroke-linecap="round"/>';
  s += '<path d="M '+iSX+' '+iSY+' Q '+botCtlX+' '+botCtlY+' '+tailTipX+' '+tailTipY+'" fill="none" stroke="#d4a820" stroke-width="1.0" opacity="0.88" stroke-linecap="round"/>';
  // === Head — line-art viper silhouette, drawn in head-local coordinates. ===
  var p1 = dwmPt(-7,  4.5);  // back-top of skull (neck connects here)
  var p2 = dwmPt(-3,  6.8);  // widest, top
  var p3 = dwmPt( 7,  4.0);  // narrowing toward snout, top
  var p4 = dwmPt(13,  0.8);  // nose tip (slight upcurve)
  var p5 = dwmPt( 7, -3.2);  // narrowing toward snout, bottom
  var p6 = dwmPt(-3, -5.0);  // jaw, bottom
  var p7 = dwmPt(-7, -3.5);  // back-bottom of skull
  var headPath =
    'M '+p1[0]+' '+p1[1]+
    ' Q '+p2[0]+' '+p2[1]+' '+p3[0]+' '+p3[1]+
    ' Q '+p4[0]+' '+p4[1]+' '+p5[0]+' '+p5[1]+
    ' Q '+p6[0]+' '+p6[1]+' '+p7[0]+' '+p7[1]+
    ' Z';
  s += '<path d="'+headPath+'" fill="#d4a820" fill-opacity="0.22" stroke="#d4a820" stroke-width="1.1" opacity="0.95" stroke-linejoin="round"/>';
  // Mouth — inset curve on the lower jaw, suggesting parted jaws around the bitten tail.
  var mp1 = dwmPt(-1, -4.0);
  var mp2 = dwmPt( 4, -5.5);
  var mp3 = dwmPt( 9, -2.0);
  s += '<path d="M '+mp1[0]+' '+mp1[1]+' Q '+mp2[0]+' '+mp2[1]+' '+mp3[0]+' '+mp3[1]+'" fill="none" stroke="#d4a820" stroke-width="0.7" opacity="0.78"/>';
  // Slit eye — viper-style, vertical narrow ellipse on the upper side of the head.
  var ePt = dwmPt(-2, 3.0);
  s += '<ellipse cx="'+ePt[0]+'" cy="'+ePt[1]+'" rx="0.95" ry="2.0" transform="rotate('+(headRot+90)+' '+ePt[0]+' '+ePt[1]+')" fill="#0c0805" opacity="0.95"/>';
  // === Forked tongue — stem from snout tip → fork joint → two prongs. ===
  var tipPt  = dwmPt(13, 0);
  var stemPt = dwmPt(22, 0.5);
  var pr1Pt  = dwmPt(30, 4);
  var pr2Pt  = dwmPt(30, -4);
  s += '<path d="M '+tipPt[0]+' '+tipPt[1]+' L '+stemPt[0]+' '+stemPt[1]+' L '+pr1Pt[0]+' '+pr1Pt[1]+' M '+stemPt[0]+' '+stemPt[1]+' L '+pr2Pt[0]+' '+pr2Pt[1]+'" fill="none" stroke="#d4a820" stroke-width="1.0" opacity="0.85" stroke-linecap="round"/>';
  s += '</g>';
  s += '</g>';
  s += '</svg>';
  modal.innerHTML = s;
  document.body.appendChild(modal);

  // Force a layout flush so the opacity:0 paints before we transition to 1.
  void modal.offsetWidth;
  modal.style.opacity = '1';

  setTimeout(function() { modal.style.opacity = '0'; }, 7500);
  setTimeout(function() { if (modal.parentNode) modal.parentNode.removeChild(modal); }, 10500);
};

// ====== ASTRAL REVEAL — Centre Point cosmos =====
// The night's wandering rendered as a galactic formation, built from the
// ACTUAL game graph: every passage's editor position becomes a star, every
// [[link]] / (go-to:) / (link-goto:) becomes a thread between them.
// `window._DSS_PASSAGE_GRAPH` is a baked JSON array produced by sync_html.py
// (Harlowe consumes its DOM passage elements at boot, so we can't read
// them at runtime). The constellation is faithful to the .twee structure —
// Dean Street where it actually is, the dream pyre off to one side,
// Centre Point up top. The point of the reveal is "the city you walked
// is this cosmic shape" — that lands only if the shape IS the city.
// Fires once on first arrival at Centre Point.
__DSS_PASSAGE_GRAPH__
window.dssAstralReveal = function(onDone) {
  if (document.getElementById('dss-astral-modal')) { if (onDone) onDone(); return; }
  var graph = window._DSS_PASSAGE_GRAPH;
  if (!graph || !graph.length) return;

  // Unpack the baked graph into the working node/link arrays.
  var nameToIdx = {};
  var passages = [];
  for (var pi = 0; pi < graph.length; pi++) {
    var g = graph[pi];
    nameToIdx[g.n] = passages.length;
    passages.push({
      name: g.n,
      gx: g.x, gy: g.y,
      tags: (g.t || '').trim().split(/\s+/),
      linkTargets: g.l || []
    });
  }
  var links = [];
  for (var si = 0; si < passages.length; si++) {
    var lt = passages[si].linkTargets;
    for (var li = 0; li < lt.length; li++) {
      var dst = lt[li];
      if (dst < passages.length && dst !== si) links.push({ a: si, b: dst });
    }
  }

  // ── 3. Normalise editor coordinates into the SVG viewBox. ──
  // Maintain aspect ratio; centre the graph; pad the edges so big nodes
  // don't get clipped at the viewport.
  var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
  for (var pp = 0; pp < passages.length; pp++) {
    var P = passages[pp];
    if (P.gx < minX) minX = P.gx; if (P.gx > maxX) maxX = P.gx;
    if (P.gy < minY) minY = P.gy; if (P.gy > maxY) maxY = P.gy;
  }
  // Layout: hub-centric quadrant-scaled radial. Each passage keeps its
  // ANGLE relative to Dean Street (so geographic zones — cellar east,
  // dream south-west, dawn north — stay spatially distinct). Distance
  // is scaled per-direction so the cluster fills a CIRCLE rather than
  // the editor's rectangular bounding box: north/south/east/west each
  // get their own scale so the most-distant passage in each direction
  // lands at the same rim distance. Result: a roughly spherical
  // constellation, matching the Twine-editor screenshot's shape.
  var hubGraph = null;
  for (var hi = 0; hi < passages.length; hi++) {
    if (passages[hi].name === 'Dean Street') { hubGraph = passages[hi]; break; }
  }
  if (!hubGraph) hubGraph = passages[0];
  var maxN = 1, maxS = 1, maxE = 1, maxW = 1;
  for (var mi = 0; mi < passages.length; mi++) {
    var ddx = passages[mi].gx - hubGraph.gx;
    var ddy = passages[mi].gy - hubGraph.gy;
    if (ddx > maxE) maxE = ddx;
    if (-ddx > maxW) maxW = -ddx;
    if (ddy > maxS) maxS = ddy;
    if (-ddy > maxN) maxN = -ddy;
  }
  var maxR = 440;
  for (var qq = 0; qq < passages.length; qq++) {
    var Q = passages[qq];
    if (Q === hubGraph) { Q.nx = 500; Q.ny = 500; continue; }
    var dx = Q.gx - hubGraph.gx, dy = Q.gy - hubGraph.gy;
    // Normalise each axis component by its quadrant's max so the rim
    // sits at the same distance in every direction.
    var nxNorm = dx > 0 ? dx / maxE : dx / maxW;   // -1..+1
    var nyNorm = dy > 0 ? dy / maxS : dy / maxN;   // -1..+1
    var ang = Math.atan2(nyNorm, nxNorm);
    var rawNorm = Math.sqrt(nxNorm * nxNorm + nyNorm * nyNorm);
    if (rawNorm > 1) rawNorm = 1;
    // sqrt curve gives the near-hub area more breathing room.
    var r = Math.sqrt(rawNorm) * maxR;
    Q.nx = 500 + r * Math.cos(ang);
    Q.ny = 500 + r * Math.sin(ang);
  }

  // ── 3b. RECENTRE on the bounding box of laid-out nodes. Pinning the hub
  // at (500, 500) leaves the cluster lop-sided when there are many more
  // passages south of Dean Street than north of it (which there are —
  // dawn lives top, the cellar/fight/pyre live south). Translate every
  // node + the hub so the actual layout box sits centred in the viewBox.
  var lxMin = Infinity, lxMax = -Infinity, lyMin = Infinity, lyMax = -Infinity;
  for (var bb = 0; bb < passages.length; bb++) {
    var BP = passages[bb];
    if (BP.nx < lxMin) lxMin = BP.nx;
    if (BP.nx > lxMax) lxMax = BP.nx;
    if (BP.ny < lyMin) lyMin = BP.ny;
    if (BP.ny > lyMax) lyMax = BP.ny;
  }
  var shiftX = 500 - (lxMin + lxMax) / 2;
  var shiftY = 500 - (lyMin + lyMax) / 2;
  for (var cc = 0; cc < passages.length; cc++) {
    passages[cc].nx += shiftX;
    passages[cc].ny += shiftY;
  }

  // ── 4. Compute degree → node size. Most-linked passages render as the
  //      brightest stars (Dean Street will be massive, lone passages tiny).
  var degree = new Array(passages.length);
  for (var di = 0; di < degree.length; di++) degree[di] = 0;
  for (var L = 0; L < links.length; L++) {
    degree[links[L].a]++; degree[links[L].b]++;
  }
  var maxDeg = 1;
  for (var dd = 0; dd < degree.length; dd++) if (degree[dd] > maxDeg) maxDeg = degree[dd];

  // ── 5. Classify each passage's colour by tag/identity. ──
  // The Twine editor's tag colours map intuitively: dream/dawn passages
  // read as otherworldly (blue), venues + outdoor scenes read as charged
  // (red), hub passages stand out gold. Defaults to amber.
  function kindFor(P) {
    var tagSet = {};
    for (var ti = 0; ti < P.tags.length; ti++) tagSet[P.tags[ti]] = 1;
    if (P.name === 'Dean Street' || tagSet.hub) return 'hub';
    if (tagSet.dream || tagSet.pyre || tagSet['dawn-end'] || tagSet['dawn-approach'] || tagSet['interval-radio'] || tagSet['carthage-cicadas']) return 'blue';
    if (tagSet.outdoor || tagSet.pong || tagSet.minigame || /^Fight /.test(P.name) || /^PP /.test(P.name)) return 'red';
    return 'main';
  }

  // ── 6. Build SVG. ──
  var s = '<svg viewBox="0 0 1000 1000" preserveAspectRatio="xMidYMid meet">';
  // Links first so they sit under the nodes. Stagger by distance from hub.
  // Find the hub node (Dean Street) for stagger origin.
  var hubIdx = nameToIdx['Dean Street'];
  if (hubIdx === undefined) hubIdx = 0;
  var hubX = passages[hubIdx].nx, hubY = passages[hubIdx].ny;
  function distToHub(P) {
    var dx = P.nx - hubX, dy = P.ny - hubY;
    return Math.sqrt(dx*dx + dy*dy);
  }
  var maxDist = 1;
  for (var pdi = 0; pdi < passages.length; pdi++) {
    var d = distToHub(passages[pdi]); if (d > maxDist) maxDist = d;
  }
  s += '<g class="ast-links">';
  for (var Li = 0; Li < links.length; Li++) {
    var A = passages[links[Li].a], B = passages[links[Li].b];
    if (!A || !B) continue;
    var avgDist = (distToHub(A) + distToHub(B)) / 2;
    var delay = 0.45 + (avgDist / maxDist) * 1.6;
    // Lighter stroke + lower opacity than before: dense clusters (cellar
    // / fight) were reading as web rather than constellation. Thinning
    // the links lets the stars breathe.
    s += '<line x1="' + A.nx.toFixed(1) + '" y1="' + A.ny.toFixed(1) +
         '" x2="' + B.nx.toFixed(1) + '" y2="' + B.ny.toFixed(1) +
         '" stroke="#d4a820" stroke-width="0.4" opacity="0" style="animation: ast-link-in 1.4s ease-out ' + delay.toFixed(2) + 's forwards;"/>';
  }
  s += '</g>';
  // Nodes — sized by degree, coloured by kind. Accent stars (red/blue)
  // now punchier and with a wider halo so they read as distinct beats
  // against the gold web rather than blending into the background.
  s += '<g class="ast-nodes">';
  for (var ni = 0; ni < passages.length; ni++) {
    var N = passages[ni];
    var k = kindFor(N);
    var r = 2.4 + (degree[ni] / maxDeg) * 9.5;
    if (k === 'hub') r = Math.max(r, 11);
    if (k === 'red' || k === 'blue') r = Math.max(r, 4.5);
    var col = k === 'hub'  ? '#f5d070' :
              k === 'red'  ? '#ec5230' :
              k === 'blue' ? '#7ac0e0' : '#d4a820';
    var glow = k === 'hub'  ? '0 0 14px rgba(255,220,120,0.85)' :
               k === 'red'  ? '0 0 9px rgba(236,82,48,0.85)) drop-shadow(0 0 18px rgba(220,60,30,0.35)' :
               k === 'blue' ? '0 0 9px rgba(122,192,224,0.85)) drop-shadow(0 0 18px rgba(90,160,210,0.35)' : '';
    var dist = distToHub(N);
    var delay = 0.45 + (dist / maxDist) * 1.6;
    if (ni === hubIdx) delay = 0;
    s += '<circle cx="' + N.nx.toFixed(1) + '" cy="' + N.ny.toFixed(1) +
         '" r="' + r.toFixed(1) + '" fill="' + col +
         '" opacity="0" style="animation: ast-node-in 1.2s ease-out ' + delay.toFixed(2) + 's forwards;' +
         (glow ? ' filter: drop-shadow(' + glow + ');' : '') + '"/>';
  }
  s += '</g>';
  s += '</svg>';

  var modal = document.createElement('div');
  modal.id = 'dss-astral-modal';
  modal.style.opacity = '0';
  modal.innerHTML = s;
  document.body.appendChild(modal);

  // Force layout flush, then fade the overlay in.
  void modal.offsetWidth;
  modal.style.opacity = '1';

  // Visible window: ~3s build, ~5s hold, ~2.5s fade-out.
  var fadeT = setTimeout(function() { modal.style.opacity = '0'; }, 8500);
  var removeT = setTimeout(function() {
    if (modal.parentNode) modal.parentNode.removeChild(modal);
    if (cleanupObs) cleanupObs.disconnect();
    if (onDone) onDone();
  }, 11500);

  // Cancel-on-navigate: the astral modal is appended to document.body, not the
  // tw-passage, so it would otherwise persist across passage transitions and
  // bleed into the next passage (visible during the CLIMB IT click into Alba
  // Complete — the dots and lines hung over the Tyburn prose). Watch for
  // tw-passage replacement and tear the modal down immediately.
  var twStory = document.querySelector('tw-story');
  var cleanupObs = null;
  if (twStory) {
    var initialPassage = twStory.querySelector('tw-passage');
    cleanupObs = new MutationObserver(function() {
      var current = twStory.querySelector('tw-passage');
      if (current !== initialPassage) {
        clearTimeout(fadeT);
        clearTimeout(removeT);
        if (modal.parentNode) modal.parentNode.removeChild(modal);
        cleanupObs.disconnect();
        if (onDone) onDone();
      }
    });
    cleanupObs.observe(twStory, { childList: true, subtree: true });
  }
};

// Safe DrinkPopup: cancelled if the player navigates away before the delay fires.
// typeOrFn: a drink type string, or a function that returns one (for DOM-read cases).
//
// FIX (race condition): Harlowe runs passage <script> tags synchronously during
// rendering, before the MutationObserver microtask has had a chance to fire and
// increment _passageGen for the new passage.  If we snapshot gen immediately, we
// capture the OLD value; the MO then increments it, and the cancel-guard fires
// incorrectly, silently swallowing every passage-load popup.
//
// The outer setTimeout(0) defers the snapshot by one event-loop task, which is
// enough for all pending microtasks (including the MO callback) to flush first.
// Navigation-away cancellation still works correctly because gen is snapshotted
// AFTER the current passage's increment, so any subsequent navigation will push
// _passageGen higher and trip the guard as intended.
window.showDrinkPopupSafe = function(typeOrFn, delay) {
  setTimeout(function() {
    var gen = window._passageGen; // snapshot after MO has fired for this passage
    setTimeout(function() {
      if (window._passageGen !== gen) return; // navigated away — cancel
      var t = typeof typeOrFn === 'function' ? typeOrFn() : typeOrFn;
      if (t) window.showDrinkPopup(t);
    }, delay !== undefined ? delay : 50);
  }, 0);
};

// ====== SPEW POPUP (hold-to-retch / hold-to-piss animation) ======
// Used in two places:
//   mode 'gents'   — Coach and Horses Gents, the player vomits ("The Gents", "Hold to retch")
//   mode 'doorway' — A doorway on Dean Street, the player pisses ("A Doorway", "Hold to piss")
// Default is 'gents' for back-compat with any old callsites.
window.SpewPopup = class SpewPopup {
constructor(mode) {
  this.mode = (mode === 'doorway') ? 'doorway' : 'gents';
  this.done = false;
  this.closing = false;
  this.retching = false;
  this.hasRetched = false;
  this.t = 0;
  this.streamLevel = 0;
  this.particles = [];
  this.wobbleDecay = 0;
  this._build();
  this._startLoop();
}
_build() {
  this.overlay = document.createElement('div');
  this.overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0);transition:background 0.5s;';
  document.body.appendChild(this.overlay);
  this.card = document.createElement('div');
  this.card.style.cssText = [
    'display:flex;flex-direction:column;align-items:center;',
    'padding:0 0 20px;',
    'background:linear-gradient(135deg, #131513 0%, #1a1c1a 50%, #131513 100%);',
    'box-shadow:0 18px 70px rgba(0,0,0,0.85), 0 0 32px rgba(100,120,100,0.10), inset 0 0 30px rgba(0,0,0,0.25);',
    'position:relative;overflow:hidden;',
    'opacity:0;transform:translateY(18px);',
    'transition:opacity 0.45s,transform 0.45s;',
    'min-width:200px;',
  ].join('');
  this.overlay.appendChild(this.card);
  // Art-nouveau sage corner vines to match the game's lore-box aesthetic
  var cornerDeco = document.createElement('div');
  cornerDeco.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;background:url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 preserveAspectRatio=%27none%27 viewBox=%270 0 400 200%27%3E%3Cpath d=%27M0,50 Q0,0 50,0%27 fill=%27none%27 stroke=%27%23607860%27 stroke-width=%271.2%27 opacity=%270.55%27/%3E%3Cpath d=%27M50,0 Q56,8 50,16 Q44,10 50,0%27 fill=%27none%27 stroke=%27%23607860%27 stroke-width=%270.8%27 opacity=%270.35%27/%3E%3Cpath d=%27M50,0 L350,0%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.4%27 opacity=%270.2%27/%3E%3Cpath d=%27M400,150 Q400,200 350,200%27 fill=%27none%27 stroke=%27%23607860%27 stroke-width=%271.2%27 opacity=%270.55%27/%3E%3Cpath d=%27M350,200 Q344,192 350,184 Q356,190 350,200%27 fill=%27none%27 stroke=%27%23607860%27 stroke-width=%270.8%27 opacity=%270.35%27/%3E%3Cpath d=%27M50,200 L350,200%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.4%27 opacity=%270.2%27/%3E%3Cpath d=%27M0,50 L0,200%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.4%27 opacity=%270.15%27/%3E%3Cpath d=%27M400,0 L400,150%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.4%27 opacity=%270.15%27/%3E%3Cpath d=%27M400,0 Q395,6 388,4%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.6%27 opacity=%270.25%27/%3E%3Cpath d=%27M0,200 Q5,194 12,196%27 fill=%27none%27 stroke=%27%23506850%27 stroke-width=%270.6%27 opacity=%270.25%27/%3E%3C/svg%3E") no-repeat center/100% 100%;';
  this.card.appendChild(cornerDeco);
  this.nameLabel = document.createElement('div');
  this.nameLabel.style.cssText = [
    'position:relative;z-index:2;',
    'width:100%;box-sizing:border-box;',
    'padding:16px 32px 10px;text-align:center;',
    'font-family:"Playfair Display",Georgia,serif;',
    'font-style:italic;font-size:0.95em;',
    'letter-spacing:0.28em;color:#b8c4b0;',
  ].join('');
  this.nameLabel.textContent = (this.mode === 'doorway') ? 'A Doorway' : 'The Gents';
  this.card.appendChild(this.nameLabel);
  // Sage separator under the label
  var sep = document.createElement('div');
  sep.style.cssText = 'position:relative;z-index:2;width:50%;height:1px;background:linear-gradient(to right, transparent, rgba(135,155,125,0.4), transparent);margin:0 auto;';
  this.card.appendChild(sep);
  var canvasWrap = document.createElement('div');
  canvasWrap.style.cssText = 'position:relative;z-index:2;padding:18px 28px 0;';
  this.card.appendChild(canvasWrap);
  this.canvas = document.createElement('canvas');
  this.canvas.width = 160;
  this.canvas.height = 200;
  this.canvas.style.cssText = 'cursor:pointer;display:block;';
  this.ctx = this.canvas.getContext('2d');
  canvasWrap.appendChild(this.canvas);
  this.prompt = document.createElement('div');
  this.prompt.style.cssText = 'position:relative;z-index:2;margin-top:12px;font-family:"Crimson Text",Georgia,serif;font-style:italic;font-size:0.95em;color:#c0c8b8;letter-spacing:0.02em;';
  this.prompt.textContent = (this.mode === 'doorway') ? 'Hold to piss' : 'Hold to retch';
  this.card.appendChild(this.prompt);
  var self = this;
  setTimeout(function() {
    self.overlay.style.background = 'rgba(0,0,0,0.6)';
    self.card.style.opacity = '1';
    self.card.style.transform = 'translateY(0)';
  }, 30);
  var startRetch = function(e) {
    e.preventDefault();
    if (self.closing || self.done) return;
    self.retching = true;
    self.hasRetched = true;
    self.wobbleDecay = 0.8;
    self.prompt.textContent = '';
    if (window.dssAudio) {
      try {
        var starter = (self.mode === 'doorway')
          ? window.dssAudio.startPissStream
          : window.dssAudio.startRetchStream;
        if (starter) self._stream = starter();
      } catch(err) {}
    }
  };
  var stopRetch = function(e) {
    e.preventDefault();
    if (!self.retching) return;
    self.retching = false;
    self.wobbleDecay = 0.4;
    if (self._stream) { try { self._stream.stop(); } catch(err) {} self._stream = null; }
    if (self.hasRetched && self.streamLevel >= 0.6 && !self.closing) {
      self.closing = true;
      setTimeout(function() { self._fadeOut(); }, 800);
    }
  };
  this.canvas.addEventListener('mousedown', startRetch);
  this.canvas.addEventListener('mouseup', stopRetch);
  this.canvas.addEventListener('mouseleave', stopRetch);
  this.canvas.addEventListener('touchstart', startRetch);
  this.canvas.addEventListener('touchend', stopRetch);
  this.canvas.addEventListener('touchcancel', stopRetch);
}
_fadeOut() {
  this.overlay.style.background = 'rgba(0,0,0,0)';
  this.card.style.opacity = '0';
  this.card.style.transform = 'translateY(-12px)';
  // The bar prose appears in-place behind the popup as it fades. Hand off
  // the audio: stop the toilet ambience and start the late-night-street
  // bed for the bar moment that follows. Tag-based auto-stop will catch
  // the coach-bar bed when the player navigates out of the passage.
  if (window.dssAudio && window.dssAudio.stopBed) {
    try { window.dssAudio.stopBed('toilet-gents'); } catch(e) {}
  }
  if (window.dssAudio && window.dssAudio.startBed) {
    try { window.dssAudio.startBed('coach-bar'); } catch(e) {}
  }
  var self = this;
  setTimeout(function() {
    self.done = true;
    if (self.overlay.parentNode) self.overlay.parentNode.removeChild(self.overlay);
  }, 480);
}
_startLoop() {
  var self = this;
  var lt = performance.now();
  function loop() {
    if (self.done) return;
    var now = performance.now();
    var dt = Math.min(now - lt, 50) * 0.001;
    lt = now;
    self.t += dt;
    if (self.retching) {
      self.streamLevel = Math.min(1, self.streamLevel + 0.45 * dt);
      if (Math.random() < 0.5) {
        self.particles.push({
          x: 80 + (Math.random() - 0.5) * 18,
          y: 118,
          vx: (Math.random() - 0.5) * 55,
          vy: 15 + Math.random() * 35,
          life: 1.0,
          size: 1.5 + Math.random() * 2.5,
          col: Math.random() < 0.6 ? '#c8a020' : '#d4b830'
        });
      }
    }
    self.particles = self.particles.filter(function(p) {
      p.x += p.vx * dt;
      p.y += p.vy * dt;
      p.vy += 90 * dt;
      p.life -= dt * 1.8;
      return p.life > 0;
    });
    if (self.wobbleDecay > 0.01) self.wobbleDecay *= (1 - 1.5 * dt);
    self._draw();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}
_draw() {
  var c = this.ctx, W = 160, H = 200, t = this.t;
  c.clearRect(0, 0, W, H);
  var bx = W / 2, by = 155, bRx = 52, bRy = 34;
  // Sickly ambient glow when retching
  if (this.streamLevel > 0.05) {
    var grd = c.createRadialGradient(bx, by, 0, bx, by, 62);
    grd.addColorStop(0, 'rgba(195,165,20,' + (this.streamLevel * 0.22).toFixed(2) + ')');
    grd.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = grd; c.fillRect(0, 0, W, H);
  }
  // Toilet outer rim
  c.fillStyle = 'rgba(205,205,200,0.93)';
  c.beginPath(); c.ellipse(bx, by, bRx, bRy, 0, 0, Math.PI * 2); c.fill();
  c.strokeStyle = 'rgba(175,175,170,0.75)'; c.lineWidth = 1.5;
  c.beginPath(); c.ellipse(bx, by, bRx, bRy, 0, 0, Math.PI * 2); c.stroke();
  // Inner bowl
  c.fillStyle = 'rgba(238,240,236,0.97)';
  c.beginPath(); c.ellipse(bx, by + 2, bRx - 10, bRy - 9, 0, 0, Math.PI * 2); c.fill();
  // Water / contents — colour shifts from clear to bilious as streamLevel rises
  var wl = this.streamLevel;
  if (wl > 0.04) {
    var rr = Math.round(205), gg = Math.round(182 - wl * 50), bb = Math.round(28 - wl * 20);
    c.fillStyle = 'rgba(' + rr + ',' + gg + ',' + bb + ',0.72)';
    c.beginPath();
    c.ellipse(bx, by + 2, (bRx - 11) * Math.min(1, wl * 1.3), (bRy - 10) * Math.min(1, wl * 1.3), 0, 0, Math.PI * 2);
    c.fill();
    // Surface shimmer
    c.strokeStyle = 'rgba(240,220,100,0.35)'; c.lineWidth = 0.9;
    c.beginPath(); c.ellipse(bx + Math.sin(t * 7) * 3, by - 1, (bRx - 16) * Math.min(1, wl), 3.5, 0, 0, Math.PI * 2); c.stroke();
  }
  // Streams arcing from figure into bowl
  if (this.retching && wl > 0) {
    var sa = Math.min(1, wl * 2.2);
    c.lineCap = 'round';
    if (this.mode === 'gents') {
      // Retching — stream drops from mouth (y≈73) nearly straight down into bowl
      var sx = bx + Math.sin(t * 3) * 2;
      c.strokeStyle = 'rgba(210,185,40,' + sa.toFixed(2) + ')';
      c.lineWidth = 2.8 + Math.sin(t * 3) * 0.6;
      c.beginPath();
      c.moveTo(sx, 73);
      c.quadraticCurveTo(sx + Math.sin(t * 4) * 4, 105, bx + 2, by - bRy + 6);
      c.stroke();
      c.lineWidth = 1.4;
      c.strokeStyle = 'rgba(230,210,60,' + (sa * 0.55).toFixed(2) + ')';
      c.beginPath();
      c.moveTo(sx - 3, 75);
      c.quadraticCurveTo(sx + Math.sin(t * 4) * 3 - 2, 108, bx - 3, by - bRy + 9);
      c.stroke();
    } else {
      // Pissing — stream arcs from standing height
      c.strokeStyle = 'rgba(210,185,40,' + sa.toFixed(2) + ')';
      c.lineWidth = 2.8 + Math.sin(t * 3) * 0.6;
      c.beginPath();
      c.moveTo(bx + Math.sin(t * 3) * 3, 88);
      c.quadraticCurveTo(bx + 10 + Math.sin(t * 4) * 5, 120, bx + 2, by - bRy + 6);
      c.stroke();
      c.lineWidth = 1.4;
      c.strokeStyle = 'rgba(230,210,60,' + (sa * 0.55).toFixed(2) + ')';
      c.beginPath();
      c.moveTo(bx + Math.sin(t * 3) * 3 - 3, 90);
      c.quadraticCurveTo(bx + 6 + Math.sin(t * 4) * 4, 122, bx - 4, by - bRy + 9);
      c.stroke();
    }
  }
  // Splatter particles
  for (var i = 0; i < this.particles.length; i++) {
    var p = this.particles[i];
    c.globalAlpha = p.life * 0.75;
    c.fillStyle = p.col;
    c.beginPath(); c.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2); c.fill();
  }
  c.globalAlpha = 1;
  c.strokeStyle = 'rgba(95,75,55,0.62)';
  c.lineWidth = 2.5; c.lineCap = 'round'; c.lineJoin = 'round';
  var headSway = Math.sin(t * 1.2) * 1.5;
  if (this.mode === 'gents') {
    // Silhouette — figure kneeling, hunched over the bowl, head drooping
    var heave = this.retching ? Math.sin(t * 8) * 1.8 : 0;
    // Head drooping forward toward bowl
    c.beginPath(); c.arc(bx + headSway, 55 + heave, 8, 0, Math.PI * 2); c.stroke();
    // Neck arching down
    c.beginPath();
    c.moveTo(bx + headSway * 0.5, 63 + heave);
    c.quadraticCurveTo(bx + 1, 76, bx + 2, 88);
    c.stroke();
    // Spine — hunched arc from neck to hips
    c.beginPath();
    c.moveTo(bx + 2, 88);
    c.quadraticCurveTo(bx - 6, 108, bx - 20, 114);
    c.quadraticCurveTo(bx - 32, 120, bx - 28, 142);
    c.stroke();
    // Arms reaching down to grip bowl rim
    c.beginPath();
    c.moveTo(bx + 1, 97);
    c.quadraticCurveTo(bx + 20, 114, bx + 28, 124);
    c.moveTo(bx + 1, 97);
    c.quadraticCurveTo(bx - 6, 116, bx, 126);
    c.stroke();
    // Kneeling legs
    c.beginPath();
    c.moveTo(bx - 28, 142);
    c.lineTo(bx - 30, 168);
    c.moveTo(bx - 26, 142);
    c.lineTo(bx - 8, 162);
    c.stroke();
  } else {
    // Silhouette — figure upright at the urinal
    // Head
    c.beginPath(); c.arc(bx + headSway, 18, 8, 0, Math.PI * 2); c.stroke();
    // Spine, upright
    c.beginPath();
    c.moveTo(bx + headSway * 0.4, 26);
    c.quadraticCurveTo(bx + 2, 55, bx + 3, 85);
    c.stroke();
    // Arms loose at sides
    c.beginPath();
    c.moveTo(bx, 42); c.lineTo(bx - 16, 68);
    c.moveTo(bx + 2, 42); c.lineTo(bx + 14, 62);
    c.stroke();
  }
}
};
window.showSpewPopup = function(mode) { new window.SpewPopup(mode); };

// ====== EAT POPUP (hold-to-eat animation for the Chinese Fish and Chips) ======
window.EatPopup = class EatPopup {
constructor(foodType) {
  this.type = foodType || 'chips';
  this.done = false;
  this.closing = false;
  this.eating = false;
  this.hasEaten = false;
  this.t = 0;
  this.eaten = 0;
  this.wobbleDecay = 0;
  this.steam = [];
  this._build();
  for (var i = 0; i < 5; i++) this.steam.push(this._newSteam(true));
  this._startLoop();
}
_newSteam(scatter) {
  return {
    x: 52 + Math.random() * 56,
    y: scatter ? (20 + Math.random() * 50) : (55 + Math.random() * 20),
    speed: 14 + Math.random() * 14,
    life: scatter ? Math.random() : (0.1 + Math.random() * 0.3),
    size: 2.5 + Math.random() * 3.5,
    drift: 0.7 + Math.random() * 1.3,
    phase: Math.random() * Math.PI * 2
  };
}
_build() {
  this.overlay = document.createElement('div');
  this.overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0);transition:background 0.5s;';
  document.body.appendChild(this.overlay);
  this.card = document.createElement('div');
  this.card.style.cssText = [
    'display:flex;flex-direction:column;align-items:center;',
    'padding:0 0 20px;',
    'background:rgba(14,9,4,0.97);',
    'border:1px solid rgba(200,168,106,0.35);',
    'border-top:2px solid rgba(200,168,106,0.65);',
    'border-radius:10px;',
    'opacity:0;transform:translateY(18px);',
    'transition:opacity 0.45s,transform 0.45s;',
    'min-width:180px;',
  ].join('');
  this.overlay.appendChild(this.card);
  this.nameLabel = document.createElement('div');
  this.nameLabel.style.cssText = [
    'width:100%;box-sizing:border-box;',
    'padding:12px 28px 10px;text-align:center;',
    'font:small-caps 600 13px "Cinzel",Georgia,serif;',
    'letter-spacing:0.12em;color:rgba(200,168,106,0.85);',
    'border-bottom:1px solid rgba(200,168,106,0.15);',
  ].join('');
  this.nameLabel.textContent = 'Fish & Chips';
  this.card.appendChild(this.nameLabel);
  var canvasWrap = document.createElement('div');
  canvasWrap.style.cssText = 'padding:18px 28px 0;';
  this.card.appendChild(canvasWrap);
  this.canvas = document.createElement('canvas');
  this.canvas.width = 160;
  this.canvas.height = 200;
  this.canvas.style.cssText = 'cursor:pointer;display:block;';
  this.ctx = this.canvas.getContext('2d');
  canvasWrap.appendChild(this.canvas);
  this.prompt = document.createElement('div');
  this.prompt.style.cssText = 'margin-top:10px;font:italic 13px Georgia,serif;color:rgba(212,165,116,0.75);letter-spacing:0.04em;';
  this.prompt.textContent = 'Hold to eat';
  this.card.appendChild(this.prompt);
  var self = this;
  setTimeout(function() {
    self.overlay.style.background = 'rgba(0,0,0,0.6)';
    self.card.style.opacity = '1';
    self.card.style.transform = 'translateY(0)';
  }, 30);
  var startEat = function(e) {
    e.preventDefault();
    if (self.closing || self.done || self.eaten >= 0.95) return;
    self.eating = true;
    self.hasEaten = true;
    self.wobbleDecay = 0.5;
    self.prompt.textContent = '';
  };
  var stopEat = function(e) {
    e.preventDefault();
    if (!self.eating) return;
    self.eating = false;
    if (self.hasEaten && self.eaten >= 0.5 && !self.closing) {
      self.closing = true;
      setTimeout(function() { self._fadeOut(); }, 800);
    }
  };
  this.canvas.addEventListener('mousedown', startEat);
  this.canvas.addEventListener('mouseup', stopEat);
  this.canvas.addEventListener('mouseleave', stopEat);
  this.canvas.addEventListener('touchstart', startEat);
  this.canvas.addEventListener('touchend', stopEat);
  this.canvas.addEventListener('touchcancel', stopEat);
}
_fadeOut() {
  this.overlay.style.background = 'rgba(0,0,0,0)';
  this.card.style.opacity = '0';
  this.card.style.transform = 'translateY(-12px)';
  var self = this;
  setTimeout(function() {
    self.done = true;
    if (self.overlay.parentNode) self.overlay.parentNode.removeChild(self.overlay);
  }, 480);
}
_startLoop() {
  var self = this;
  var lt = performance.now();
  function loop() {
    if (self.done) return;
    var now = performance.now();
    var dt = Math.min(now - lt, 50) * 0.001;
    lt = now;
    self.t += dt;
    if (self.eating) {
      var rate = 0.28 * Math.min(1.0, (1.0 - self.eaten) * 3.5);
      self.eaten = Math.min(1, self.eaten + rate * dt);
      if (self.eaten >= 0.95 && !self.closing) {
        self.eating = false;
        self.closing = true;
        setTimeout(function() { self._fadeOut(); }, 600);
      }
    }
    // Steam particles
    self.steam.forEach(function(s) {
      s.y -= s.speed * dt;
      s.x += Math.sin(self.t * s.drift + s.phase) * 9 * dt;
      s.life -= dt * 0.38;
      if (s.life <= 0) { Object.assign(s, self._newSteam(false)); }
    });
    if (self.wobbleDecay > 0.01) self.wobbleDecay *= (1 - 2 * dt);
    self._draw();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}
_draw() {
  var c = this.ctx, W = 160, H = 200, t = this.t;
  c.clearRect(0, 0, W, H);
  var eaten = this.eaten;
  // Warm amber glow under the cone
  var grd = c.createRadialGradient(W / 2, 152, 0, W / 2, 152, 70);
  grd.addColorStop(0, 'rgba(210,158,38,0.24)');
  grd.addColorStop(1, 'rgba(0,0,0,0)');
  c.fillStyle = grd; c.fillRect(0, 0, W, H);

  c.save();
  c.translate(W / 2, 132);

  // ── ROLLED NEWSPAPER CONE — narrow twisted point at the bottom,
  //    wide flared opening at the top, paper rolled into a cornet. ──

  // Soft shadow under the point
  c.fillStyle = 'rgba(0,0,0,0.28)';
  c.beginPath();
  c.ellipse(2, 36, 16, 4, 0, 0, Math.PI * 2);
  c.fill();

  // Outer paper cone — greaseproof / off-white newsprint
  var paperGrad = c.createLinearGradient(0, -52, 0, 36);
  paperGrad.addColorStop(0, '#f0e8d2');
  paperGrad.addColorStop(0.55, '#dccfa8');
  paperGrad.addColorStop(0.85, '#b8a878');
  paperGrad.addColorStop(1, '#8c7c52');
  c.fillStyle = paperGrad;
  c.beginPath();
  // Top edge — crinkled rim, slightly flared open
  c.moveTo(-50, -50);
  c.quadraticCurveTo(-44, -54, -32, -50);
  c.quadraticCurveTo(-18, -56, -4, -52);
  c.quadraticCurveTo(10, -56, 24, -50);
  c.quadraticCurveTo(38, -54, 50, -48);
  // Right side — tapering down to twisted point
  c.quadraticCurveTo(46, -28, 34, -8);
  c.quadraticCurveTo(22, 14, 10, 30);
  c.quadraticCurveTo(6, 36, 2, 38);
  // Twisted point at the bottom
  c.quadraticCurveTo(0, 40, -2, 38);
  c.quadraticCurveTo(-6, 36, -10, 30);
  // Left side — back up
  c.quadraticCurveTo(-22, 14, -34, -8);
  c.quadraticCurveTo(-46, -28, -50, -50);
  c.closePath();
  c.fill();
  c.strokeStyle = 'rgba(95,78,42,0.55)';
  c.lineWidth = 1.0;
  c.stroke();

  // ── Newsprint texture (clipped to the cone) ──
  c.save();
  c.beginPath();
  c.moveTo(-50, -50);
  c.quadraticCurveTo(-44, -54, -32, -50);
  c.quadraticCurveTo(-18, -56, -4, -52);
  c.quadraticCurveTo(10, -56, 24, -50);
  c.quadraticCurveTo(38, -54, 50, -48);
  c.quadraticCurveTo(46, -28, 34, -8);
  c.quadraticCurveTo(22, 14, 10, 30);
  c.quadraticCurveTo(6, 36, 2, 38);
  c.quadraticCurveTo(0, 40, -2, 38);
  c.quadraticCurveTo(-6, 36, -10, 30);
  c.quadraticCurveTo(-22, 14, -34, -8);
  c.quadraticCurveTo(-46, -28, -50, -50);
  c.closePath();
  c.clip();

  // Body-text dashes in two suggested columns — purely abstract, no readable text
  c.fillStyle = 'rgba(40,30,18,0.38)';
  var rows = [
    [-22, -44], [-22, -40], [-22, -36], [-22, -32], [-22, -28], [-22, -24],
    [-22, -20], [-22, -16], [-22, -12], [-22,  -8], [-22,  -4], [-22,   0],
    [-22,   4], [-22,   8], [-22,  12],
    [  4, -44], [  4, -40], [  4, -36], [  4, -32], [  4, -28], [  4, -24],
    [  4, -20], [  4, -16], [  4, -12], [  4,  -8], [  4,  -4], [  4,   0],
    [  4,   4], [  4,   8], [  4,  12]
  ];
  for (var ri = 0; ri < rows.length; ri++) {
    var rx = rows[ri][0], ry = rows[ri][1];
    // Lines narrow as we go down (taper into the cone)
    var taper = Math.max(0.25, 1 - (ry + 50) / 100);
    var lenA = (4 + (Math.sin(ri * 1.7) * 1.5 + 3)) * taper;
    var gap = 2 * taper;
    var lenB = (3 + (Math.cos(ri * 1.3) * 1.2 + 2.5)) * taper;
    c.fillRect(rx, ry, lenA, 0.55);
    c.fillRect(rx + lenA + gap, ry, lenB, 0.55);
  }
  // Small dark photo-ish patch (abstract, no recognizable content)
  c.fillStyle = 'rgba(60,46,28,0.4)';
  c.fillRect(-16, -48, 12, 5);
  c.fillStyle = 'rgba(40,30,18,0.5)';
  for (var dy = 0; dy < 5; dy += 1) {
    for (var dx = 0; dx < 12; dx += 1.6) {
      if ((dx + dy) % 2 < 1) c.fillRect(-16 + dx, -48 + dy, 0.55, 0.55);
    }
  }

  // Diagonal seam — where the paper has been rolled (overlap line)
  c.strokeStyle = 'rgba(95,72,40,0.45)';
  c.lineWidth = 0.7;
  c.beginPath();
  c.moveTo(10, -50);
  c.quadraticCurveTo(6, -20, 2, 18);
  c.stroke();

  // Shadowed crease running down the back of the cone (interior dimness)
  c.strokeStyle = 'rgba(60,42,18,0.35)';
  c.lineWidth = 0.8;
  c.beginPath();
  c.moveTo(-16, -52);
  c.quadraticCurveTo(-8, -16, -2, 30);
  c.stroke();

  // Grease translucency — darker patches where the paper has soaked through
  c.fillStyle = 'rgba(140,98,52,0.22)';
  c.beginPath(); c.ellipse(-18, 6, 8, 12, -0.3, 0, Math.PI * 2); c.fill();
  c.beginPath(); c.ellipse(14, 10, 6, 10, 0.4, 0, Math.PI * 2); c.fill();
  c.beginPath(); c.ellipse(-4, 22, 5, 7, 0, 0, Math.PI * 2); c.fill();

  c.restore(); // end clip

  // Paper-fold highlights along the rolled edges
  c.strokeStyle = 'rgba(255,245,210,0.55)';
  c.lineWidth = 0.7;
  c.beginPath(); c.moveTo(-46, -46); c.quadraticCurveTo(-30, -18, -10, 28); c.stroke();
  c.beginPath(); c.moveTo(46, -44); c.quadraticCurveTo(30, -18, 8, 28); c.stroke();

  // ── Dark interior at the cone opening (so the contents read as "inside" the cone) ──
  c.fillStyle = 'rgba(35,22,10,0.55)';
  c.beginPath();
  c.ellipse(0, -48, 46, 6, 0, 0, Math.PI * 2);
  c.fill();

  // (Fish is drawn AFTER chips, below, so it sits on top of the pile.)

  // ── CHIPS — a dense handful clustered at and above the cone opening.
  //    All chips sit at or above the rim (y ≥ -75, y ≤ -48). Paper is
  //    opaque — nothing should be visible "through" the cone wall.
  //    Array is ordered BOTTOM-OF-PILE first → drawn behind. Eating order
  //    is computed from y so the topmost (highest) chips disappear first. ──
  var chipDefs = [
    // ── Bottom row, sitting in the cone opening ──
    { x: -38, y: -48, w:  9, h: 5, a:  0.34, hi: 0.50 },
    { x: -27, y: -48, w: 18, h: 6, a:  0.06, hi: 0.55 },
    { x: -10, y: -48, w: 11, h: 6, a: -0.10, hi: 0.55 },
    { x:   3, y: -48, w: 16, h: 6, a:  0.04, hi: 0.55 },
    { x:  17, y: -48, w: 13, h: 6, a: -0.18, hi: 0.55 },
    { x:  29, y: -48, w:  8, h: 5, a: -0.36, hi: 0.50 },
    // ── Mid stack ──
    { x: -31, y: -54, w: 11, h: 6, a:  0.18, hi: 0.55 },
    { x: -19, y: -55, w: 19, h: 6, a: -0.06, hi: 0.55 },
    { x:  -4, y: -56, w: 13, h: 6, a:  0.10, hi: 0.55 },
    { x:   9, y: -55, w: 17, h: 6, a: -0.14, hi: 0.55 },
    { x:  22, y: -54, w: 10, h: 6, a:  0.22, hi: 0.55 },
    // ── Upper pile ──
    { x: -22, y: -62, w: 16, h: 6, a:  0.04, hi: 0.55 },
    { x:  -9, y: -63, w: 11, h: 6, a: -0.10, hi: 0.55 },
    { x:   5, y: -62, w: 17, h: 6, a:  0.16, hi: 0.55 },
    { x:  19, y: -60, w:  9, h: 5, a: -0.22, hi: 0.55 },
    // ── Top crown — chips poking up highest ──
    { x: -14, y: -69, w: 18, h: 6, a: -0.18, hi: 0.60 },
    { x:   1, y: -71, w: 10, h: 6, a:  0.06, hi: 0.60 },
    { x:  11, y: -68, w: 15, h: 6, a:  0.24, hi: 0.60 },
    { x:  -3, y: -73, w: 14, h: 5, a:  0.14, hi: 0.65 },
  ];
  var vis = 1 - eaten;
  for (var ci = 0; ci < chipDefs.length; ci++) {
    var ch = chipDefs[ci];
    // Eating order from y — higher in the pile (more negative y) = eaten first.
    // Range maps y from -77 (top) → frac=1, to y=-48 (rim) → frac=0.
    var frac = Math.max(0, Math.min(1, (-ch.y - 48) / 29));
    var ca = Math.min(1, Math.max(0, (vis - frac + 0.18) / 0.14));
    if (ca <= 0) continue;
    c.save();
    c.translate(ch.x + ch.w / 2, ch.y + ch.h / 2);
    c.rotate(ch.a);
    c.globalAlpha = ca;
    // Chip body — golden gradient
    var chipGrad = c.createLinearGradient(0, -ch.h/2, 0, ch.h/2);
    chipGrad.addColorStop(0, '#e8b048');
    chipGrad.addColorStop(0.5, '#c88820');
    chipGrad.addColorStop(1, '#8a5808');
    c.fillStyle = chipGrad;
    c.beginPath();
    c.moveTo(-ch.w/2, -ch.h/2 + 1);
    c.lineTo(-ch.w/2 + 1, -ch.h/2);
    c.lineTo(ch.w/2 - 1, -ch.h/2);
    c.lineTo(ch.w/2, -ch.h/2 + 1);
    c.lineTo(ch.w/2, ch.h/2 - 1);
    c.lineTo(ch.w/2 - 1, ch.h/2);
    c.lineTo(-ch.w/2 + 1, ch.h/2);
    c.lineTo(-ch.w/2, ch.h/2 - 1);
    c.closePath();
    c.fill();
    // Top-edge highlight
    c.fillStyle = 'rgba(255,225,150,' + ch.hi + ')';
    c.fillRect(-ch.w/2 + 1.5, -ch.h/2 + 0.5, ch.w - 3, 1.2);
    // Darker browned edges (where chip met fryer)
    c.fillStyle = 'rgba(90,46,8,0.55)';
    c.fillRect(-ch.w/2, ch.h/2 - 1.2, ch.w, 1.2);
    // Tiny grease shine
    c.fillStyle = 'rgba(255,250,220,0.35)';
    c.fillRect(-ch.w/2 + 2, -ch.h/2 + 1.8, ch.w * 0.3, 0.8);
    c.restore();
  }
  c.globalAlpha = 1;

  // ── FISH — battered piece sitting on top of the chip pile. Long and
  //    tapered: wide rounded "head" on the left, narrowing to a thinner
  //    "tail" end on the right (less oval, more like a real fillet). ──
  if (eaten < 0.85) {
    var fa = Math.max(0, 1 - eaten * 1.6);
    c.globalAlpha = fa;
    var fishGrad = c.createRadialGradient(-10, -61, 2, -4, -59, 32);
    fishGrad.addColorStop(0, '#f0bb50');
    fishGrad.addColorStop(0.55, '#cc8420');
    fishGrad.addColorStop(1, '#8a4e08');
    c.fillStyle = fishGrad;
    c.beginPath();
    // Wide rounded head end (left)
    c.moveTo(-28, -55);
    c.quadraticCurveTo(-34, -63, -28, -69);
    c.quadraticCurveTo(-20, -73, -8, -71);
    // Top edge going right, tapering down
    c.quadraticCurveTo(8, -70, 22, -65);
    c.quadraticCurveTo(32, -62, 34, -59);
    // Narrow tail end
    c.quadraticCurveTo(34, -56, 30, -55);
    // Bottom edge returning left
    c.quadraticCurveTo(18, -54, 4, -53);
    c.quadraticCurveTo(-12, -52, -22, -53);
    c.quadraticCurveTo(-30, -53, -28, -55);
    c.closePath();
    c.fill();
    // Crispy darker spots (batter blisters) — denser at the head end
    c.fillStyle = 'rgba(90,52,12,0.55)';
    c.beginPath(); c.ellipse(-20, -65, 2.6, 1.6, 0.3, 0, Math.PI*2); c.fill();
    c.beginPath(); c.ellipse(-10, -68, 2.2, 1.4, -0.2, 0, Math.PI*2); c.fill();
    c.beginPath(); c.ellipse( -4, -61, 1.8, 1.2, 0.5, 0, Math.PI*2); c.fill();
    c.beginPath(); c.ellipse( 10, -63, 1.8, 1.1, 0.0, 0, Math.PI*2); c.fill();
    c.beginPath(); c.ellipse( 22, -61, 1.4, 0.9, -0.2, 0, Math.PI*2); c.fill();
    // Lighter batter ridges — follow the taper
    c.strokeStyle = 'rgba(255,225,150,0.6)';
    c.lineWidth = 0.7;
    c.beginPath(); c.moveTo(-24, -69); c.quadraticCurveTo(-6, -71, 18, -66); c.stroke();
    c.beginPath(); c.moveTo(-22, -57); c.quadraticCurveTo(0, -59, 26, -58); c.stroke();
    // Tiny salt grains
    c.fillStyle = 'rgba(255,255,250,0.85)';
    c.beginPath(); c.arc(-15, -66, 0.5, 0, Math.PI*2); c.fill();
    c.beginPath(); c.arc(  0, -65, 0.45, 0, Math.PI*2); c.fill();
    c.beginPath(); c.arc( 14, -62, 0.45, 0, Math.PI*2); c.fill();
    c.beginPath(); c.arc( 26, -60, 0.4, 0, Math.PI*2); c.fill();
    c.globalAlpha = 1;
  }

  c.restore();

  // ── Steam particles drifting up from the opening ──
  this.steam.forEach(function(s) {
    var sa = s.life > 0.5 ? 0.26 : s.life * 0.5;
    if (sa <= 0) return;
    c.globalAlpha = sa * (1 - eaten * 0.65);
    c.fillStyle = 'rgba(220,210,200,0.85)';
    c.beginPath(); c.arc(s.x, s.y, s.size, 0, Math.PI * 2); c.fill();
  });
  c.globalAlpha = 1;
}
};
window.showEatPopup = function(foodType) { new window.EatPopup(foodType || 'chips'); };

// ====== LIVER POPUP (guide the eagle to Prometheus's liver) ======
// The player steers an eagle from the top-left toward Shelley's liver on a
// rock in the bottom-right. Mouse/touch position drives the eagle with easing.
// When it reaches the liver, the eagle tilts down, the liver shrinks, and the
// popup fades. Draws on Prometheus Unbound — the eagle, the crag, the pulse.
window.LiverPopup = class LiverPopup {
constructor() {
  this.done = false;
  this.closing = false;
  this.eating = false;
  this.eatProgress = 0;
  this.liverSize = 1.0;
  this.t = 0;
  // Eagle state
  this.eagleX = 25; this.eagleY = 25;
  this.eagleTargetX = 25; this.eagleTargetY = 25;
  this.eagleTilt = 0;
  this.hasMoved = false;
  // Cloud drift (set in _initClouds after canvas sized)
  this.clouds = [];
  // Liver target position (bottom-right of canvas)
  this.liverX = 172; this.liverY = 128;
  this._build();
  this._initClouds();
  this._startLoop();
}
_initClouds() {
  for (var i = 0; i < 5; i++) {
    this.clouds.push({
      x: Math.random() * 200,
      y: 18 + Math.random() * 75,
      vx: 3 + Math.random() * 5,
      size: 16 + Math.random() * 14,
      alpha: 0.06 + Math.random() * 0.10
    });
  }
}
_build() {
  this.overlay = document.createElement('div');
  // z-index 999999 keeps the eagle popup ABOVE the notebook dialog (and its
  // close button at 100000), so it can be invoked from inside the notebook
  // as a popup-within-popup. Matches the napkin popup pattern.
  this.overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:999999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0);transition:background 0.5s;';
  document.body.appendChild(this.overlay);
  this.card = document.createElement('div');
  this.card.style.cssText = [
    'position:relative;',
    'display:flex;flex-direction:column;align-items:center;',
    'padding:10px 10px 16px;',
    'background:radial-gradient(ellipse at center, rgba(30,18,10,0.98) 0%, rgba(10,6,3,0.99) 100%);',
    'border:1px solid rgba(200,168,106,0.6);',
    'border-radius:3px;',
    'box-shadow:',
    '  0 0 0 1px rgba(50,34,18,0.9),',
    '  0 0 0 5px rgba(200,168,106,0.14),',
    '  0 0 0 6px rgba(50,34,18,0.85),',
    '  0 12px 42px rgba(0,0,0,0.75),',
    '  inset 0 0 40px rgba(0,0,0,0.55),',
    '  inset 0 0 0 1px rgba(200,168,106,0.22);',
    'opacity:0;transform:translateY(18px);',
    'transition:opacity 0.6s,transform 0.6s;',
    'min-width:200px;',
  ].join('');
  this.overlay.appendChild(this.card);
  // Gold filigree corner ornaments — antiquarian reliquary vibe
  var cornerSVG = '<svg viewBox="0 0 32 32" width="30" height="30" xmlns="http://www.w3.org/2000/svg">' +
    '<path d="M4 4 L16 4 M4 4 L4 16" stroke="rgba(210,175,110,0.75)" stroke-width="0.9" fill="none" stroke-linecap="round"/>' +
    '<path d="M4 4 Q12 4, 14 8 Q16 12, 12 14 Q7 16, 4 12" fill="none" stroke="rgba(200,168,106,0.55)" stroke-width="0.7"/>' +
    '<path d="M4 4 Q8 6, 10 10" fill="none" stroke="rgba(220,185,120,0.4)" stroke-width="0.5"/>' +
    '<circle cx="7" cy="7" r="1.4" fill="none" stroke="rgba(220,185,120,0.8)" stroke-width="0.45"/>' +
    '<circle cx="7" cy="7" r="0.55" fill="rgba(235,205,140,0.9)"/>' +
    '</svg>';
  var cornerPositions = [
    'top:2px;left:2px;',
    'top:2px;right:2px;transform:scaleX(-1);',
    'bottom:2px;left:2px;transform:scaleY(-1);',
    'bottom:2px;right:2px;transform:scale(-1,-1);'
  ];
  var _card = this.card;
  cornerPositions.forEach(function(pos) {
    var d = document.createElement('div');
    d.style.cssText = 'position:absolute;pointer-events:none;z-index:2;opacity:0.9;' + pos;
    d.innerHTML = cornerSVG;
    _card.appendChild(d);
  });
  var canvasWrap = document.createElement('div');
  canvasWrap.style.cssText = 'padding:14px 14px;';
  this.card.appendChild(canvasWrap);
  this.canvas = document.createElement('canvas');
  this.canvas.width = 200;
  this.canvas.height = 160;
  this.canvas.style.cssText = 'cursor:crosshair;display:block;';
  this.ctx = this.canvas.getContext('2d');
  canvasWrap.appendChild(this.canvas);
  // Gold caps quote — flashes up when the eagle finishes feeding.
  this.quote = document.createElement('div');
  this.quote.style.cssText = [
    'font-family:"Playfair Display",Georgia,serif;',
    'color:#f5d070;',
    'font-size:11px;',
    'letter-spacing:0.18em;',
    'text-align:center;',
    'padding:2px 16px 6px;',
    'text-transform:uppercase;',
    'opacity:0;',
    'transition:opacity 0.7s ease;',
    'text-shadow:0 0 8px rgba(245,208,112,0.55),0 0 16px rgba(245,208,112,0.25),0 0 2px rgba(8,6,4,0.95);',
    'max-width:220px;',
    'line-height:1.55;'
  ].join('');
  this.quote.textContent = 'There is no part of me that is not of the Gods.';
  this.card.appendChild(this.quote);
  // Intentionally no label and no prompt — the myth speaks for itself.
  this.prompt = { textContent: '' };
  var self = this;
  setTimeout(function() {
    self.overlay.style.background = 'rgba(0,0,0,0.6)';
    self.card.style.opacity = '1';
    self.card.style.transform = 'translateY(0)';
  }, 30);
  var handleMove = function(e) {
    if (self.closing || self.done || self.eating) return;
    var rect = self.canvas.getBoundingClientRect();
    var cx, cy;
    if (e.touches && e.touches.length) {
      cx = e.touches[0].clientX; cy = e.touches[0].clientY;
    } else {
      cx = e.clientX; cy = e.clientY;
    }
    self.eagleTargetX = Math.max(8, Math.min(192, cx - rect.left));
    self.eagleTargetY = Math.max(8, Math.min(152, cy - rect.top));
    if (!self.hasMoved) {
      self.hasMoved = true;
      self.prompt.textContent = '';
    }
    // Bright-chord sparkle on movement. Throttled by time + distance so
    // mousemove storms turn into an evolving chord rather than a buzz.
    var nowT = performance.now();
    if (self._lastChordT === undefined) {
      self._lastChordT = 0;
      self._lastChordX = self.eagleTargetX;
      self._lastChordY = self.eagleTargetY;
    }
    var cdx = self.eagleTargetX - self._lastChordX;
    var cdy = self.eagleTargetY - self._lastChordY;
    if (nowT - self._lastChordT > 170 && (cdx * cdx + cdy * cdy) > 100) {
      self._lastChordT = nowT;
      self._lastChordX = self.eagleTargetX;
      self._lastChordY = self.eagleTargetY;
      if (window.dssAudio && window.dssAudio.brightChord) window.dssAudio.brightChord();
    }
  };
  this.canvas.addEventListener('mousemove', handleMove);
  this.canvas.addEventListener('mousedown', handleMove);
  this.canvas.addEventListener('touchstart', function(e) { e.preventDefault(); handleMove(e); });
  this.canvas.addEventListener('touchmove', function(e) { e.preventDefault(); handleMove(e); });
}
_fadeOut() {
  this.overlay.style.background = 'rgba(0,0,0,0)';
  this.card.style.opacity = '0';
  this.card.style.transform = 'translateY(-12px)';
  var self = this;
  setTimeout(function() {
    self.done = true;
    if (self.overlay.parentNode) self.overlay.parentNode.removeChild(self.overlay);
    window.dispatchEvent(new CustomEvent('liverpopup:closed'));
  }, 480);
}
_startLoop() {
  var self = this;
  var lt = performance.now();
  function loop() {
    if (self.done) return;
    var now = performance.now();
    var dt = Math.min(now - lt, 50) * 0.001;
    lt = now;
    self.t += dt;
    // Eagle eases toward target position
    var prevX = self.eagleX;
    self.eagleX += (self.eagleTargetX - self.eagleX) * 3.2 * dt;
    self.eagleY += (self.eagleTargetY - self.eagleY) * 3.2 * dt;
    // Tilt follows horizontal velocity
    var vx = self.eagleX - prevX;
    self.eagleTilt += (vx * 0.04 - self.eagleTilt) * 5 * dt;
    // Check for arrival at liver
    if (!self.eating && !self.closing) {
      var dx = self.eagleX - self.liverX, dy = self.eagleY - self.liverY;
      if (Math.sqrt(dx * dx + dy * dy) < 20) {
        self.eating = true;
        self.eatProgress = 0;
      }
    }
    // Eating progression
    if (self.eating) {
      self.eatProgress = Math.min(1, self.eatProgress + 1.4 * dt);
      self.liverSize = Math.max(0, 1 - self.eatProgress);
      // Eagle head bobs toward liver while eating
      self.eagleTargetX = self.liverX;
      self.eagleTargetY = self.liverY - 4;
      if (self.eatProgress >= 1 && !self.closing) {
        self.closing = true;
        if (self.quote) self.quote.style.opacity = '1';
        setTimeout(function() { self._fadeOut(); }, 2500);
      }
    }
    // Drift clouds
    self.clouds.forEach(function(cl) {
      cl.x += cl.vx * dt;
      if (cl.x > 230) { cl.x = -30; cl.y = 18 + Math.random() * 75; }
    });
    self._draw();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}
_draw() {
  var c = this.ctx, W = 200, H = 160, t = this.t;
  // Stormy sky
  var sky = c.createLinearGradient(0, 0, 0, H);
  sky.addColorStop(0, '#282636');
  sky.addColorStop(0.55, '#423748');
  sky.addColorStop(1, '#362d3a');
  c.fillStyle = sky;
  c.fillRect(0, 0, W, H);
  // Clouds
  for (var i = 0; i < this.clouds.length; i++) {
    var cl = this.clouds[i];
    c.fillStyle = 'rgba(205,200,215,' + cl.alpha.toFixed(2) + ')';
    c.beginPath();
    c.ellipse(cl.x, cl.y, cl.size, cl.size * 0.38, 0, 0, Math.PI * 2);
    c.fill();
  }
  // Distant crag hint (far background)
  c.fillStyle = 'rgba(50,48,58,0.55)';
  c.beginPath();
  c.moveTo(0, 160); c.lineTo(0, 135);
  c.lineTo(28, 125); c.lineTo(50, 130); c.lineTo(72, 125); c.lineTo(90, 132);
  c.lineTo(90, 160); c.closePath(); c.fill();
  // The main rock / crag (bottom-right, where Prometheus is bound)
  c.fillStyle = '#3a3840';
  c.beginPath();
  c.moveTo(118, 160);
  c.lineTo(126, 142);
  c.lineTo(138, 130);
  c.lineTo(152, 122);
  c.lineTo(168, 118);
  c.lineTo(182, 122);
  c.lineTo(195, 135);
  c.lineTo(200, 152);
  c.lineTo(200, 160);
  c.closePath();
  c.fill();
  // Rock highlights (moonlight catches the edges)
  c.fillStyle = 'rgba(100,92,105,0.5)';
  c.beginPath();
  c.moveTo(152, 124); c.lineTo(168, 120); c.lineTo(178, 126); c.lineTo(164, 134); c.closePath();
  c.fill();
  c.fillStyle = 'rgba(70,65,75,0.7)';
  c.beginPath();
  c.moveTo(128, 143); c.lineTo(140, 134); c.lineTo(144, 145); c.lineTo(132, 152); c.closePath();
  c.fill();
  // Chain (going off-frame right, suggesting Prometheus bound)
  c.strokeStyle = 'rgba(130,110,90,0.65)';
  c.lineWidth = 1.3;
  for (var k = 0; k < 5; k++) {
    var kx = 186 + k * 3, ky = 130 + Math.sin(k * 1.1) * 1.2;
    c.beginPath();
    c.ellipse(kx, ky, 1.6, 1, k * 0.3, 0, Math.PI * 2);
    c.stroke();
  }
  // Wrist silhouette, bound (small, just visible at rock edge)
  c.fillStyle = 'rgba(65,50,38,0.88)';
  c.beginPath();
  c.ellipse(184, 132, 5, 3, 0.3, 0, Math.PI * 2);
  c.fill();
  // The liver — pulsing red on the rock
  if (this.liverSize > 0.04) {
    var lv = this.liverSize;
    var pulse = 1 + Math.sin(t * 2.4) * 0.10 * lv;
    // Ambient glow
    var lg = c.createRadialGradient(this.liverX, this.liverY, 0, this.liverX, this.liverY, 18 * pulse * lv);
    lg.addColorStop(0, 'rgba(120,30,38,0.42)');
    lg.addColorStop(1, 'rgba(0,0,0,0)');
    c.fillStyle = lg;
    c.fillRect(this.liverX - 25, this.liverY - 25, 50, 50);
    // Liver body
    c.fillStyle = '#6a1820';
    c.beginPath();
    c.ellipse(this.liverX, this.liverY, 9 * pulse * lv, 6 * pulse * lv, 0.2, 0, Math.PI * 2);
    c.fill();
    // Highlight
    c.fillStyle = '#8a2e34';
    c.beginPath();
    c.ellipse(this.liverX - 2, this.liverY - 1.5, 3.2 * lv, 1.8 * lv, 0.2, 0, Math.PI * 2);
    c.fill();
    // Darker lobe suggestion
    c.fillStyle = 'rgba(60,10,18,0.5)';
    c.beginPath();
    c.ellipse(this.liverX + 3, this.liverY + 1.5, 3 * lv, 1.5 * lv, 0.3, 0, Math.PI * 2);
    c.fill();
  }
  // Blood flecks during eating
  if (this.eating && this.eatProgress < 0.85) {
    var flecks = 4;
    for (var f = 0; f < flecks; f++) {
      var fa = Math.max(0, (0.4 - this.eatProgress * 0.35)) * (0.7 + Math.sin(t * 8 + f) * 0.3);
      c.fillStyle = 'rgba(120,28,32,' + fa.toFixed(2) + ')';
      c.beginPath();
      c.arc(this.liverX + (f - 1.5) * 4, this.liverY - 6 - this.eatProgress * 8 + Math.sin(t * 11 + f * 2) * 2, 1.3, 0, Math.PI * 2);
      c.fill();
    }
  }
  // The eagle/harpy — silhouette with flapping wings
  if (!this.eating || this.eatProgress < 0.75) {
    var ex = this.eagleX, ey = this.eagleY;
    var flap = Math.sin(t * 13);
    var wingSpan = 14 + flap * 5;
    var wingRise = -5 - flap * 5;
    c.save();
    c.translate(ex, ey);
    c.rotate(this.eagleTilt);
    // Body
    c.fillStyle = '#16101a';
    c.beginPath();
    c.ellipse(0, 0, 4.5, 2.2, 0, 0, Math.PI * 2);
    c.fill();
    // Tail feathers
    c.beginPath();
    c.moveTo(-4, 0); c.lineTo(-8, -1.5); c.lineTo(-8, 1.5); c.closePath();
    c.fill();
    // Head (tilts down when eating)
    var headY = this.eating ? 2.5 : 0;
    var headX = this.eating ? 3 : 3.5;
    c.beginPath();
    c.ellipse(headX, headY, 2.3, 1.8, 0, 0, Math.PI * 2);
    c.fill();
    // Beak (hooked)
    c.fillStyle = '#2e1c14';
    c.beginPath();
    c.moveTo(headX + 1.8, headY);
    c.lineTo(headX + 4.5, headY + (this.eating ? 1.5 : 0.8));
    c.lineTo(headX + 2, headY + 1.2);
    c.closePath();
    c.fill();
    // Wings — curved, flapping
    c.strokeStyle = '#16101a';
    c.lineWidth = 2.8;
    c.lineCap = 'round';
    c.lineJoin = 'round';
    // Left wing
    c.beginPath();
    c.moveTo(-2, -0.5);
    c.quadraticCurveTo(-wingSpan * 0.5, wingRise, -wingSpan - 2, wingRise - 1);
    c.stroke();
    // Right wing
    c.beginPath();
    c.moveTo(2, -0.5);
    c.quadraticCurveTo(wingSpan * 0.5, wingRise, wingSpan + 2, wingRise - 1);
    c.stroke();
    // Feather tips
    c.lineWidth = 1.2;
    c.strokeStyle = 'rgba(40,28,42,0.85)';
    c.beginPath();
    c.moveTo(-wingSpan * 0.55, wingRise * 0.55);
    c.lineTo(-wingSpan - 2, wingRise - 1);
    c.stroke();
    c.beginPath();
    c.moveTo(wingSpan * 0.55, wingRise * 0.55);
    c.lineTo(wingSpan + 2, wingRise - 1);
    c.stroke();
    c.restore();
  }
}
};
window.showLiverPopup = function() { new window.LiverPopup(); };

// ====== HEAL EXIT LINK HANDLER ======
// Fires the stat heal animation then navigates via a hidden Harlowe link.
// Used in recovery passages because <script> inside (link:) hooks isn't reliable.
document.addEventListener('click', function(e) {
  if (!e.target || !e.target.classList || !e.target.classList.contains('heal-exit-link')) return;
  var el = e.target;
  var gains = { confidence: 0, sobriety: 0 };
  var valsId = el.getAttribute('data-vals');
  if (valsId) {
    var valsEl = document.getElementById(valsId);
    if (valsEl) {
      var p = valsEl.textContent.split(',');
      gains.confidence = parseInt(p[0]) || 0;
      gains.sobriety   = parseInt(p[1]) || 0;
    }
  } else {
    gains.confidence = parseInt(el.getAttribute('data-conf')) || 0;
    gains.sobriety   = parseInt(el.getAttribute('data-sobr')) || 0;
  }
  if (window.showHealAnimation) window.showHealAnimation(gains);
  var navEl = document.getElementById(el.getAttribute('data-nav') || '');
  var twLink = navEl && navEl.querySelector('tw-link');
  if (twLink) twLink.click();
});

/* ===== FIGHT MINIGAME ENGINE ===== */
window.FightGame = class FightGame {
constructor(canvasId, sobriety) {
this.canvas = document.getElementById(canvasId);
this.ctx = this.canvas.getContext('2d');
this.W = this.canvas.width;
this.H = this.canvas.height;
this.sobriety = sobriety;

this.score = 0;
this.round = 0;
this.gameOver = false;
this.phase = 'idle';
this.phaseTimer = 0;
this.punchType = '';
this.resultText = '';
this.resultClass = '';
this.narrativeText = '';
this.clickable = false;
this.acted = false;
this.copperHit = false;

this.copperBaseX = this.W / 2;
this.copperBaseY = 80;
this.telegraphT = 0;
this.punchT = 0;
this.resultFlash = 0;
this.hoveredZone = '';

// Tightened from 2000ms — the player has less time to read the
// telegraph and pick a side. Tuned with the per-round difficulty
// scaling below so round 3 lands inside ~1100ms.
this.baseTelegraphDuration = 1550;
this.telegraphDuration = this.baseTelegraphDuration;

this.roundPunches = ['right_cross', 'left_hook', 'uppercut', 'right_cross', 'left_hook', 'uppercut'];

this.practiceIntros = [
"Watch his RIGHT glove glow. The punch will swing ACROSS and land on your left. Dodge to the SAME side as the glowing glove (right).",
"Now his LEFT glove glows. The punch swings across to land on your right. Dodge to the SAME side as the glove (left).",
"This time he crouches. The glove drops low for an uppercut. Dodge either side."
];

this.realIntros = [
"Copper feints left. You clock it; he clocks you clocking it. The right cross comes.",
"Copper works behind the jab until he steps in: a straight right to your nose.",
"You both breathe heavy as sports. An uppercut emits straight from his stomach."
];

this.practiceNarr = [
{ clean: "Good. You read it.", block: "Blocked it. Safe, but dodging scores more.", caught: "He pulls the punch. Click the SAME side as the glowing glove next time." },
{ clean: "Quick feet. You've got it.", block: "Covered up. Try dodging for more points.", caught: "Wrong side. Click the SAME side as the glowing glove — it shows where the punch is coming FROM." },
{ clean: "Sidestepped it clean.", block: "Absorbed it. Either side works for an uppercut.", caught: "Too slow. Step sideways when he crouches." }
];

this.realDodgeNarr = [
{ clean: "You slip under it so as to suggest a vacuum.",
block: "You shell up and take a hit, with the general grace of the crayfish.",
caught: "You give ground and feel the wall behind you. No room. A hook finds your shoulder." },
{ clean: "Your neck rolls. His knuckles are pinking your cheek.",
block: "You parry at the wrist. A jab goes wide.",
caught: "'Careful, clever cunt,' says Copper." },
{ clean: "You swerve it and he stumbles.",
block: "You smother him on the inside. The uppercut dies on your shoulder.",
caught: "His experienced punch,\nTakes you to lunch,\nAnd hey, nonnie, nonie!" }
];

this.practiceCounterNarr = [
{ success: "You swing and Copper leans back. He grins.", fail: "Copper catches your wrist. 'Timing,' he says." },
{ success: "Copper nods. 'Not bad.'", fail: "He swats your hand away. 'Watch the glove first.'" },
{ success: "You step inside. Copper grunts approval.", fail: "He rides it. 'Patience.'" }
];

this.realCounterNarr = [
{ success: "You let the right come. Your own left hook finds the unclaimed territory of his diaphragm.",
fail: "You swing — Copper saw it coming a street away." },
{ success: "You step inside his reach and land one clean to the ribs.",
fail: "'Careful, clever cunt,' says Copper." },
{ success: "Your forehead to his nose, which powders like a shingle under its force.",
fail: "His experienced punch,\nTakes you to lunch,\nAnd hey, nonnie, nonie!" }
];

this.setupInput();
this.startRound();
this.loop();
}

isPractice() { return this.round < 3; }
realRoundIndex() { return this.round - 3; }

setupInput() {
this.canvas.addEventListener('mousemove', (e) => {
if (!this.clickable) { this.hoveredZone = ''; return; }
var rect = this.canvas.getBoundingClientRect();
var mx = (e.clientX - rect.left) * (this.W / rect.width);
var my = (e.clientY - rect.top) * (this.H / rect.height);
this.hoveredZone = this.getZone(mx, my);
this.canvas.style.cursor = this.hoveredZone ? 'pointer' : 'crosshair';
});

this.canvas.addEventListener('click', (e) => {
if (!this.clickable || this.acted) return;
var rect = this.canvas.getBoundingClientRect();
var mx = (e.clientX - rect.left) * (this.W / rect.width);
var my = (e.clientY - rect.top) * (this.H / rect.height);
var zone = this.getZone(mx, my);
if (zone) this.handleAction(zone);
});
}

getZone(mx, my) {
if (mx < 130 && my > 120 && my < 350) return 'dodge_left';
if (mx > this.W - 130 && my > 120 && my < 350) return 'dodge_right';
if (mx > 150 && mx < this.W - 150 && my > 330) return 'block';
if (mx > 210 && mx < this.W - 210 && my > 80 && my < 280) return 'counter';
return '';
}

startRound() {
this.phase = 'intro';
this.phaseTimer = Date.now();
this.telegraphT = 0;
this.punchT = 0;
this.resultFlash = 0;
this.clickable = false;
this.acted = false;
this.copperHit = false;
this.hoveredZone = '';

if (this.isPractice()) {
// Practice rounds stay slow — they're the teaching moments.
this.telegraphDuration = 3200;
} else {
// Real rounds: get FASTER as the fight goes on. Round 1 lands near
// baseTelegraphDuration, round 3 lands ~25% tighter. Sobriety drops
// it further — drunk player has fewer milliseconds to react.
var roundSpeed = 1 - (this.realRoundIndex() * 0.12);
var sobPenalty = (100 - this.sobriety) * 4;
this.telegraphDuration = Math.max(820, Math.round(this.baseTelegraphDuration * roundSpeed - sobPenalty));
}

this.updateRoundDisplay();
var introDelay = this.isPractice() ? 3200 : 2500;

setTimeout(() => {
if (this.gameOver) return;
this.phase = 'telegraph';
this.phaseTimer = Date.now();
this.punchType = this.roundPunches[this.round];
this.clickable = true;
if (!this.isPractice()) this.clearNarrative();
}, introDelay);
}

getCorrectDodge() {
if (this.punchType === 'right_cross') return 'dodge_right';
if (this.punchType === 'left_hook') return 'dodge_left';
if (this.punchType === 'uppercut') return 'either';
return 'dodge_left';
}

handleAction(zone) {
this.acted = true;
this.clickable = false;
var practice = this.isPractice();
var ni = practice ? this.round : this.realRoundIndex();

// impactSound is fired at end of the punching animation (when result lands).
var impactSound = null;
if (zone === 'counter') {
// Counter chance is lower in real rounds; sobriety helps but caps lower.
// Previously a failed counter still scored +1 — now it's 0, so a bad
// counter call is a real cost. (Practice round still very forgiving.)
var chance = practice ? 0.8 : 0.18 + (this.sobriety / 380);
if (Math.random() < chance) {
if (!practice) this.score += 3;
this.resultText = '★ COUNTER ★';
this.resultClass = 'win';
this.copperHit = true;
this.narrativeText = practice ? this.practiceCounterNarr[ni].success : this.realCounterNarr[ni].success;
impactSound = 'counter_win';
} else {
// Failed counter — no points, you just ate the punch.
this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceCounterNarr[ni].fail : this.realCounterNarr[ni].fail;
impactSound = 'punchImpact';
}
} else if (zone === 'block') {
if (!practice) this.score += 1;
this.resultText = 'ABSORBED';
this.resultClass = 'neutral';
this.narrativeText = practice ? this.practiceNarr[ni].block : this.realDodgeNarr[ni].block;
impactSound = 'muffledThud';
} else {
var correct = this.getCorrectDodge();
var isCorrect = (zone === correct) || (correct === 'either');
if (isCorrect) {
if (!practice) this.score += 2;
this.resultText = 'CLEAN';
this.resultClass = 'win';
this.narrativeText = practice ? this.practiceNarr[ni].clean : this.realDodgeNarr[ni].clean;
impactSound = 'dodgeWhoosh';
} else {
// Wrong dodge — you took the punch full on. Sting it: −1 from the score
// in real rounds, so a sloppy guess can flip a borderline win to a loss.
if (!practice) this.score = Math.max(0, this.score - 1);
this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceNarr[ni].caught : this.realDodgeNarr[ni].caught;
impactSound = 'punchImpact';
}
}
this._impactSound = impactSound;

this.phase = 'punching';
this.phaseTimer = Date.now();

setTimeout(() => {
this.phase = 'result';
this.phaseTimer = Date.now();
this.resultFlash = 1;
this.showResult(this.resultText, this.resultClass);
// in-round narrative stripped
this.updateRoundDisplay();
// Impact sound — fires when the punch lands or whiffs past
if (window.dssAudio) {
  if (this._impactSound === 'counter_win') {
    window.dssAudio.dodgeWhoosh();
    setTimeout(function(){ if (window.dssAudio) window.dssAudio.punchImpact(); }, 180);
  } else if (this._impactSound && window.dssAudio[this._impactSound]) {
    window.dssAudio[this._impactSound]();
  }
}

setTimeout(() => {
if (practice && this.round === 2) {
this.showNarrative("Practice over. This time it's real.");
setTimeout(() => { this.round = 3; this.startRound(); }, 3500);
} else if (!practice && this.round >= 5) {
this.endGame();
} else {
this.round++;
this.startRound();
}
}, 2500);
}, 500);
}

timeOut() {
this.acted = true;
this.clickable = false;
var practice = this.isPractice();
var ni = practice ? this.round : this.realRoundIndex();

this.resultText = 'CAUGHT';
this.resultClass = 'lose';
this.narrativeText = practice ? this.practiceNarr[ni].caught : this.realDodgeNarr[ni].caught;

this.phase = 'punching';
this.phaseTimer = Date.now();

setTimeout(() => {
this.phase = 'result';
this.phaseTimer = Date.now();
this.resultFlash = 1;
this.showResult(this.resultText, this.resultClass);
// in-round narrative stripped
this.updateRoundDisplay();
// Timeout = caught flat-footed — punch lands
if (window.dssAudio) window.dssAudio.punchImpact();

setTimeout(() => {
if (practice && this.round === 2) {
this.showNarrative("Practice over. This time it's real.");
setTimeout(() => { this.round = 3; this.startRound(); }, 3500);
} else if (!practice && this.round >= 5) {
this.endGame();
} else {
this.round++;
this.startRound();
}
}, 2500);
}, 500);
}

endGame() {
if (this.gameOver) return; // guard against double-call (round + timeOut paths)
this.gameOver = true;
var won = this.score >= 5;
var perfect = this.score >= 9;
window._lastFightScore = this.score;
var endEl = document.getElementById('fight-end');
var inst = document.getElementById('fight-instructions');
if (inst) inst.style.display = 'none';

if (won) {
var label = perfect ? '🤜 PERFECT SCORE 🤜' : '🤜 STANDING 🤜';
endEl.innerHTML = '<span style="color:#aaffaa;text-shadow:0 0 15px rgba(170,255,170,0.6);">' + label + '</span>';
this.showNarrative("'It's alright,' says Copper, 'Alright. Tell whoever sent you that I know that they sent you.'");
} else {
endEl.innerHTML = '<span style="color:#ffaaaa;text-shadow:0 0 10px rgba(255,170,170,0.4);">🤜 DOWN 🤜</span>';
}

// On loss, auto-advance after a one-second beat — no narrative, no button.
if (!won) {
setTimeout(function() {
var targetPassage = 'Fight Defeat';
var wrap = document.getElementById('go-fight-defeat');
var link = wrap && wrap.querySelector('tw-link');
if (link) {
  try { link.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window })); return; }
  catch(e) { try { link.click(); return; } catch(e2) {} }
}
var anyLink = document.querySelector('tw-link[passage-name="' + targetPassage + '"]');
if (anyLink) {
  try { anyLink.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window })); return; }
  catch(e) {}
}
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', targetPassage);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
setTimeout(function(){ if (injected.parentNode) injected.parentNode.removeChild(injected); }, 50);
}, 1000);
return;
}

setTimeout(function() {
// Guard against double-fire (round + timeOut paths can both call endGame).
var existing = document.getElementById('fight-continue-btn');
if (existing && existing.parentNode) existing.parentNode.removeChild(existing);
var btn = document.createElement('button');
btn.id = 'fight-continue-btn';
btn.className = 'fight-continue-btn';
btn.textContent = won ? 'Get out' : 'Continue';
var targetPassage = won ? (perfect ? 'Fight Victory Perfect' : 'Fight Victory') : 'Fight Defeat';
var wrapId = won ? (perfect ? 'go-fight-victory-perfect' : 'go-fight-victory') : 'go-fight-defeat';
btn.onclick = function() {
// Strategy 1: click the real Harlowe-processed tw-link inside the hidden
// wrapper. This is the same pattern used by heal-exit links and the bar
// canvas. Dispatch a real bubbling MouseEvent — some Harlowe builds bind
// click via document-level delegation, so we need bubbles: true.
var wrap = document.getElementById(wrapId);
var link = wrap && wrap.querySelector('tw-link');
if (link) {
  try {
    link.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
    return;
  } catch(e) { try { link.click(); return; } catch(e2) {} }
}
// Strategy 2: search the whole document for a tw-link to this passage
// (covers the case where the hidden wrapper got destroyed somehow).
var anyLink = document.querySelector('tw-link[passage-name="' + targetPassage + '"]');
if (anyLink) {
  try {
    anyLink.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
    return;
  } catch(e) {}
}
// Strategy 3: inject a fresh tw-link and click it.
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', targetPassage);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window }));
setTimeout(function(){ if (injected.parentNode) injected.parentNode.removeChild(injected); }, 50);
};
endEl.appendChild(document.createElement('br'));
endEl.appendChild(btn);
}, 2000);
}

updateRoundDisplay() {
var el = document.getElementById('round-display');
if (!el) return;
if (this.isPractice()) {
el.innerHTML =
  '<div class="fight-board">' +
    '<div class="fight-board-label">PRACTICE</div>' +
    '<div class="fight-board-round">Round ' + (this.round + 1) + ' / 3</div>' +
    '<div class="fight-board-pips">' + this._renderScorePips(0) + '</div>' +
    '<div class="fight-board-key">win @ 5 &middot; perfect @ 9</div>' +
  '</div>';
} else {
var r = this.realRoundIndex() + 1;
var goal = this.score >= 9 ? 'PERFECT' : this.score >= 5 ? 'WIN LOCKED' : (5 - this.score) + ' to win';
el.innerHTML =
  '<div class="fight-board">' +
    '<div class="fight-board-label">ROUND ' + r + '</div>' +
    '<div class="fight-board-pips">' + this._renderScorePips(this.score) + '</div>' +
    '<div class="fight-board-key">' + this.score + ' &middot; ' + goal + ' &middot; perfect @ 9</div>' +
  '</div>';
}
}

// Score pips for the fight board — nine slots, filled to current score.
// Live and empty slots get distinct treatments; threshold rings at 3/6.
_renderScorePips(score) {
var html = '';
for (var i = 0; i < 9; i++) {
  var filled = i < score;
  var tier = i < 3 ? 'low' : i < 6 ? 'mid' : 'high';
  var divider = (i === 2 || i === 5) ? ' fight-pip-divider' : '';
  html += '<span class="fight-pip ' + (filled ? 'fight-pip-filled fight-pip-' + tier : 'fight-pip-empty') + divider + '"></span>';
}
return html;
}

showNarrative(text) {
var el = document.getElementById('fight-narrative');
if (el) { el.style.opacity = '1'; el.textContent = text; }
}

clearNarrative() {
var el = document.getElementById('fight-narrative');
if (el) el.style.opacity = '0';
}

showResult(text, cls) {
var el = document.getElementById('round-display');
if (!el) return;
var col = cls === 'win' ? '#aaffaa' : cls === 'lose' ? '#ffaaaa' : '#eeddaa';
if (this.isPractice()) {
el.innerHTML =
  '<div class="fight-board">' +
    '<div class="fight-board-label">PRACTICE</div>' +
    '<div class="fight-board-call" style="color:' + col + ';">' + text + '</div>' +
    '<div class="fight-board-pips">' + this._renderScorePips(0) + '</div>' +
    '<div class="fight-board-key">win @ 5 &middot; perfect @ 9</div>' +
  '</div>';
} else {
var goal = this.score >= 9 ? 'PERFECT' : this.score >= 5 ? 'WIN LOCKED' : (5 - this.score) + ' to win';
el.innerHTML =
  '<div class="fight-board">' +
    '<div class="fight-board-call" style="color:' + col + ';">' + text + '</div>' +
    '<div class="fight-board-pips">' + this._renderScorePips(this.score) + '</div>' +
    '<div class="fight-board-key">' + this.score + ' &middot; ' + goal + ' &middot; perfect @ 9</div>' +
  '</div>';
}
}

draw() {
var ctx = this.ctx;
var W = this.W, H = this.H;

ctx.fillStyle = '#0e0808';
ctx.fillRect(0, 0, W, H);

ctx.strokeStyle = '#1e1212';
ctx.lineWidth = 0.5;
for (var row = 0; row < H; row += 30) {
ctx.beginPath(); ctx.moveTo(0, row); ctx.lineTo(W, row); ctx.stroke();
var off = (Math.floor(row / 30) % 2) * 35;
for (var col = off; col < W; col += 70) {
ctx.beginPath(); ctx.moveTo(col, row); ctx.lineTo(col, row + 30); ctx.stroke();
}
}

var lg = ctx.createRadialGradient(W / 2, -20, 10, W / 2, -20, 350);
lg.addColorStop(0, 'rgba(180, 140, 80, 0.10)');
lg.addColorStop(1, 'rgba(0, 0, 0, 0)');
ctx.fillStyle = lg;
ctx.fillRect(0, 0, W, H);

this.drawCopper(ctx);

if (this.phase === 'telegraph' && this.clickable) {
// Punch-path arrow removed — was counterintuitive (eye followed it as a
// "click here" cue when the player needed to do the opposite).
// drawZones now lights up the safe dodge zone instead.
this.drawZones(ctx);
this.drawTimerBar(ctx);
}

if (this.phase === 'result' && this.resultFlash > 0) {
this.resultFlash -= 0.02;
if (this.resultClass === 'win') ctx.fillStyle = 'rgba(170, 255, 170, ' + (this.resultFlash * 0.08) + ')';
else if (this.resultClass === 'lose') ctx.fillStyle = 'rgba(255, 100, 100, ' + (this.resultFlash * 0.1) + ')';
else ctx.fillStyle = 'rgba(220, 200, 120, ' + (this.resultFlash * 0.06) + ')';
ctx.fillRect(0, 0, W, H);
}

if (this.sobriety < 35) {
var str = (35 - this.sobriety) / 35;
var vig = ctx.createRadialGradient(W/2, H/2, H*0.2, W/2, H/2, H*0.6);
vig.addColorStop(0, 'rgba(0,0,0,0)');
vig.addColorStop(1, 'rgba(0,0,0,' + (str * 0.45) + ')');
ctx.fillStyle = vig;
ctx.fillRect(0, 0, W, H);
}
}

drawCopper(ctx) {
ctx.save();
var cx = this.copperBaseX;
var cy = this.copperBaseY;
var lean = 0, crouch = 0, fistPull = 0;

if (this.phase === 'telegraph') {
var t = Math.min((Date.now() - this.phaseTimer) / this.telegraphDuration, 1);
this.telegraphT = t;
if (this.punchType === 'right_cross') { lean = -35 * t; fistPull = t; }
else if (this.punchType === 'left_hook') { lean = 35 * t; fistPull = t; }
else if (this.punchType === 'uppercut') { crouch = 30 * t; fistPull = t; }
if (t >= 1 && !this.acted) this.timeOut();
}

if (this.phase === 'punching') {
var pt = Math.min((Date.now() - this.phaseTimer) / 500, 1);
this.punchT = pt;
if (this.copperHit) {
// Recoil — head/body jerks UP and back from the player's counter.
// Sin curve peaks at pt=0.5 then settles, like a natural snap.
var recoilCurve = Math.sin(pt * Math.PI);
cy -= 34 * recoilCurve;
lean = 6 * recoilCurve;
fistPull = 1;
} else {
cy += 40 * pt;
fistPull = 1 - pt;
}
}

cx += lean;
cy += crouch;

// ═══ COPPER COLOUR CONSTANTS ═══
var SKIN = '#c4a07a', SKIN_SHADOW = '#a88060', SKIN_OUTLINE = '#8e6e52', SKIN_DARK = '#7a6050';
var HAIR = '#2a1e14', HAIR_HI = '#3e3020';
var SUIT = '#1e1e24', SUIT_DARK = '#101016', SUIT_LIGHT = '#2e2e36';
var STRIPE = 'rgba(150,150,160,0.06)', SHIRT_WHITE = '#d8d4cc';
var TIE = '#2a1a1a', TIE_HI = '#3e2828';
var TROUSERS = '#1a1a20', TROUSERS_DARK = '#0e0e14';

// ═══ SHADOW ═══
ctx.fillStyle = 'rgba(0,0,0,0.25)';
ctx.beginPath(); ctx.ellipse(this.copperBaseX, 340, 95, 22, 0, 0, Math.PI * 2); ctx.fill();

// ═══ TROUSERS with pinstripes ═══
ctx.fillStyle = TROUSERS; ctx.strokeStyle = TROUSERS_DARK; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 70, cy + 195); ctx.lineTo(cx - 74, cy + 320); ctx.lineTo(cx - 2, cy + 320); ctx.lineTo(cx - 2, cy + 205); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 70, cy + 195); ctx.lineTo(cx + 74, cy + 320); ctx.lineTo(cx + 2, cy + 320); ctx.lineTo(cx + 2, cy + 205); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.save(); ctx.strokeStyle = STRIPE; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx - 70, cy + 195); ctx.lineTo(cx - 74, cy + 320); ctx.lineTo(cx - 2, cy + 320); ctx.lineTo(cx - 2, cy + 205); ctx.closePath(); ctx.clip(); for (var s = -75; s <= -2; s += 8) { ctx.beginPath(); ctx.moveTo(cx + s, cy + 195); ctx.lineTo(cx + s - 1, cy + 320); ctx.stroke(); } ctx.restore();
ctx.save(); ctx.strokeStyle = STRIPE; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx + 70, cy + 195); ctx.lineTo(cx + 74, cy + 320); ctx.lineTo(cx + 2, cy + 320); ctx.lineTo(cx + 2, cy + 205); ctx.closePath(); ctx.clip(); for (var s = 2; s <= 75; s += 8) { ctx.beginPath(); ctx.moveTo(cx + s, cy + 195); ctx.lineTo(cx + s - 1, cy + 320); ctx.stroke(); } ctx.restore();
ctx.strokeStyle = 'rgba(255,255,255,0.05)'; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 36, cy + 200); ctx.lineTo(cx - 38, cy + 320); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 36, cy + 200); ctx.lineTo(cx + 38, cy + 320); ctx.stroke();

// ═══ BELT ═══
ctx.fillStyle = '#1a1210'; ctx.strokeStyle = '#0e0a08'; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 72, cy + 192); ctx.lineTo(cx + 72, cy + 192); ctx.lineTo(cx + 72, cy + 204); ctx.lineTo(cx - 72, cy + 204); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.fillStyle = '#c0a040'; ctx.strokeStyle = '#a08830'; ctx.lineWidth = 0.8; ctx.beginPath(); ctx.rect(cx - 8, cy + 194, 16, 8); ctx.fill(); ctx.stroke();
ctx.fillStyle = '#d4b050'; ctx.beginPath(); ctx.rect(cx - 5, cy + 196, 10, 4); ctx.fill();

// ═══ SUIT JACKET — shorter, shaped, dark pinstripe ═══
ctx.fillStyle = SUIT; ctx.strokeStyle = SUIT_DARK; ctx.lineWidth = 1.5;
ctx.beginPath(); ctx.moveTo(cx - 32, cy + 58); ctx.lineTo(cx - 78, cy + 68); ctx.quadraticCurveTo(cx - 82, cy + 120, cx - 78, cy + 160); ctx.quadraticCurveTo(cx - 76, cy + 185, cx - 72, cy + 195); ctx.lineTo(cx - 10, cy + 195); ctx.lineTo(cx - 10, cy + 88); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 32, cy + 58); ctx.lineTo(cx + 78, cy + 68); ctx.quadraticCurveTo(cx + 82, cy + 120, cx + 78, cy + 160); ctx.quadraticCurveTo(cx + 76, cy + 185, cx + 72, cy + 195); ctx.lineTo(cx + 10, cy + 195); ctx.lineTo(cx + 10, cy + 88); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.save(); ctx.strokeStyle = STRIPE; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx - 82, cy + 68); ctx.quadraticCurveTo(cx - 82, cy + 120, cx - 78, cy + 160); ctx.quadraticCurveTo(cx - 76, cy + 185, cx - 72, cy + 195); ctx.lineTo(cx - 10, cy + 195); ctx.lineTo(cx - 10, cy + 88); ctx.lineTo(cx - 32, cy + 58); ctx.lineTo(cx - 78, cy + 68); ctx.closePath(); ctx.clip(); for (var s = -85; s <= -5; s += 8) { ctx.beginPath(); ctx.moveTo(cx + s, cy + 58); ctx.lineTo(cx + s - 2, cy + 200); ctx.stroke(); } ctx.restore();
ctx.save(); ctx.strokeStyle = STRIPE; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx + 82, cy + 68); ctx.quadraticCurveTo(cx + 82, cy + 120, cx + 78, cy + 160); ctx.quadraticCurveTo(cx + 76, cy + 185, cx + 72, cy + 195); ctx.lineTo(cx + 10, cy + 195); ctx.lineTo(cx + 10, cy + 88); ctx.lineTo(cx + 32, cy + 58); ctx.lineTo(cx + 78, cy + 68); ctx.closePath(); ctx.clip(); for (var s = 5; s <= 85; s += 8) { ctx.beginPath(); ctx.moveTo(cx + s, cy + 58); ctx.lineTo(cx + s - 2, cy + 200); ctx.stroke(); } ctx.restore();
ctx.strokeStyle = SUIT_LIGHT; ctx.lineWidth = 0.8; ctx.beginPath(); ctx.moveTo(cx - 72, cy + 194); ctx.lineTo(cx - 10, cy + 194); ctx.stroke(); ctx.beginPath(); ctx.moveTo(cx + 10, cy + 194); ctx.lineTo(cx + 72, cy + 194); ctx.stroke();
ctx.fillStyle = SUIT_LIGHT; ctx.beginPath(); ctx.arc(cx - 12, cy + 140, 2.5, 0, Math.PI * 2); ctx.fill();

// ═══ SHOULDERS — broad ═══
ctx.fillStyle = SUIT; ctx.strokeStyle = SUIT_DARK; ctx.lineWidth = 1.5;
ctx.beginPath(); ctx.ellipse(cx, cy + 72, 88, 28, 0, 0, Math.PI * 2); ctx.fill(); ctx.stroke();

// ═══ SHIRT ═══
ctx.fillStyle = SHIRT_WHITE; ctx.strokeStyle = '#b8b4ac'; ctx.lineWidth = 0.8;
ctx.beginPath(); ctx.moveTo(cx - 28, cy + 50); ctx.lineTo(cx - 12, cy + 195); ctx.lineTo(cx + 12, cy + 195); ctx.lineTo(cx + 28, cy + 50); ctx.closePath(); ctx.fill(); ctx.stroke();

// ═══ KIPPER TIE ═══
ctx.fillStyle = TIE;
ctx.beginPath(); ctx.moveTo(cx - 8, cy + 54); ctx.lineTo(cx + 8, cy + 54); ctx.lineTo(cx + 7, cy + 70); ctx.lineTo(cx - 7, cy + 70); ctx.closePath(); ctx.fill();
ctx.strokeStyle = TIE_HI; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx - 2, cy + 55); ctx.lineTo(cx - 1, cy + 69); ctx.stroke(); ctx.beginPath(); ctx.moveTo(cx + 2, cy + 55); ctx.lineTo(cx + 1, cy + 69); ctx.stroke();
ctx.fillStyle = TIE;
ctx.beginPath(); ctx.moveTo(cx - 7, cy + 70); ctx.lineTo(cx - 13, cy + 170); ctx.lineTo(cx, cy + 182); ctx.lineTo(cx + 13, cy + 170); ctx.lineTo(cx + 7, cy + 70); ctx.closePath(); ctx.fill();
ctx.strokeStyle = TIE_HI; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(cx, cy + 72); ctx.lineTo(cx, cy + 178); ctx.stroke();
ctx.strokeStyle = 'rgba(0,0,0,0.25)'; ctx.lineWidth = 0.8; ctx.beginPath(); ctx.moveTo(cx - 8, cy + 72); ctx.lineTo(cx - 13, cy + 170); ctx.stroke(); ctx.beginPath(); ctx.moveTo(cx + 8, cy + 72); ctx.lineTo(cx + 13, cy + 170); ctx.stroke();
ctx.strokeStyle = 'rgba(60,30,30,0.3)'; ctx.lineWidth = 0.5; for (var ty = cy + 80; ty < cy + 168; ty += 12) { var tw = 7 + ((ty - cy - 70) / 100) * 6; ctx.beginPath(); ctx.moveTo(cx - tw, ty); ctx.lineTo(cx + tw, ty + 6); ctx.stroke(); }

// ═══ COLLAR ═══
ctx.fillStyle = SHIRT_WHITE; ctx.strokeStyle = '#b0aca4'; ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(cx - 5, cy + 50); ctx.lineTo(cx - 32, cy + 46); ctx.lineTo(cx - 36, cy + 54); ctx.lineTo(cx - 30, cy + 62); ctx.lineTo(cx - 8, cy + 56); ctx.closePath(); ctx.fill(); ctx.stroke();
ctx.beginPath(); ctx.moveTo(cx + 5, cy + 50); ctx.lineTo(cx + 32, cy + 46); ctx.lineTo(cx + 36, cy + 54); ctx.lineTo(cx + 30, cy + 62); ctx.lineTo(cx + 8, cy + 56); ctx.closePath(); ctx.fill(); ctx.stroke();
