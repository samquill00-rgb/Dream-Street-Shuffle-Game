  cx.strokeRect(5, 5, w - 10, h - 10);
  cx.fillStyle = '#c8a840';
  cx.font = 'bold 14px Georgia'; cx.textAlign = 'center';
  cx.fillText('PILLARS', w/2, 38);
  cx.fillText('OF', w/2, 58);
  cx.fillText('HERCULES', w/2, 78);
  cx.font = '9px Georgia';
  cx.fillText('FREE HOUSE', w/2, 105);
});
var signMat = new THREE.MeshStandardMaterial({ map: signTex, roughness: 0.5, side: THREE.DoubleSide });
