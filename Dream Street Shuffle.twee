:: Maltese Gangsters {"position":"1400,550","size":"100,100"}
(set: $metSalvu to true)\
(set: $sobriety to ($statGain: $sobriety, 30))\
<div class="copper-door">
<!-- Maltese cross rule — dark iron tones -->
<svg viewBox="0 0 300 40" width="100%" height="40" preserveAspectRatio="none"><defs><linearGradient id="mgEdge" x1="0" x2="1"><stop offset="0%" stop-color="#6b2020" stop-opacity="0"/><stop offset="15%" stop-color="#6b2020" stop-opacity="0.5"/><stop offset="85%" stop-color="#6b2020" stop-opacity="0.5"/><stop offset="100%" stop-color="#6b2020" stop-opacity="0"/></linearGradient></defs><line x1="0" y1="36" x2="300" y2="36" stroke="url(#mgEdge)" stroke-width="1.5"/><line x1="0" y1="4" x2="300" y2="4" stroke="url(#mgEdge)" stroke-width="0.8"/><!-- Maltese cross centre --><g transform="translate(150,20)" fill="none" stroke="#8b3030" stroke-width="1.2" opacity="0.55"><path d="M0,-10 L4,-4 L10,0 L4,4 L0,10 L-4,4 L-10,0 L-4,-4 Z"/><circle cx="0" cy="0" r="2.5" stroke-width="0.8"/></g><!-- Side studs --><circle cx="60" cy="20" r="1.8" fill="#4a1818" opacity="0.4"/><circle cx="240" cy="20" r="1.8" fill="#4a1818" opacity="0.4"/><circle cx="30" cy="20" r="1.2" fill="#4a1818" opacity="0.25"/><circle cx="270" cy="20" r="1.2" fill="#4a1818" opacity="0.25"/></svg>

<div class="copper-knock-prompt">Knock three times.</div>
<div class="copper-knock-counter" id="copperKnockCount">○ ○ ○</div>
<button class="copper-knock-btn" type="button" id="copperKnockBtn">KNOCK</button>

<div class="copper-knock-reveal" id="salvuReveal">
Salvu Copper, who is proportioned brutally, opens the door and leans over the threshold, like a hawk might hang over its prey.

'Can I help you?' says Salvu.

<span id="salvuGoLink" style="display:none">[[continue|Approach Coppers Lair]]</span>
</div>

<svg viewBox="0 0 300 40" width="100%" height="40" preserveAspectRatio="none"><defs><linearGradient id="mgEdge2" x1="0" x2="1"><stop offset="0%" stop-color="#6b2020" stop-opacity="0"/><stop offset="15%" stop-color="#6b2020" stop-opacity="0.5"/><stop offset="85%" stop-color="#6b2020" stop-opacity="0.5"/><stop offset="100%" stop-color="#6b2020" stop-opacity="0"/></linearGradient></defs><line x1="0" y1="4" x2="300" y2="4" stroke="url(#mgEdge2)" stroke-width="1.5"/><line x1="0" y1="36" x2="300" y2="36" stroke="url(#mgEdge2)" stroke-width="0.8"/><g transform="translate(150,20)" fill="none" stroke="#8b3030" stroke-width="1.2" opacity="0.55"><path d="M0,-10 L4,-4 L10,0 L4,4 L0,10 L-4,4 L-10,0 L-4,-4 Z"/><circle cx="0" cy="0" r="2.5" stroke-width="0.8"/></g></svg>
</div>

<script>
// Three deliberate knocks. Each one a held breath. The third opens the door.
(function(){
  var btn = document.getElementById('copperKnockBtn');
  var count = document.getElementById('copperKnockCount');
  var reveal = document.getElementById('salvuReveal');
  if (!btn || !count || !reveal) return;
  var knocks = 0;
  var lastClick = 0;
  function render(){
    var marks = [];
    for (var i = 0; i < 3; i++) marks.push(i < knocks ? '●' : '○');
    count.textContent = marks.join(' ');
  }
  btn.addEventListener('click', function(){
    if (knocks >= 3) return;
    var now = Date.now();
    // Reject clicks too close together — knocking takes intent.
    if (now - lastClick < 240) return;
    lastClick = now;
    knocks++;
    if (window.dssAudio && window.dssAudio.doorKnock) {
      // One knock per click — three deliberate raps, no doubled finish.
      window.dssAudio.doorKnock(1);
    }
    render();
    if (knocks >= 3) {
      btn.disabled = true;
      btn.classList.add('spent');
      setTimeout(function(){
        if (window.dssAudio && window.dssAudio.doorCreak) window.dssAudio.doorCreak();
        reveal.classList.add('open');
        // After Salvu's prose has had time to land, navigate.
        setTimeout(function(){
          var lk = document.querySelector('#salvuGoLink tw-link');
          if (lk) lk.click();
        }, 4500);
      }, 800);
    }
  });
})();
</script>

