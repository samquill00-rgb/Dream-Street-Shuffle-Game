box(tableGroup, 1.4, 0.06, 0.7, tableMat, 0, tableY, tableZ);
box(tableGroup, 0.06, tableY, 0.06, darkWood, -0.6, tableY / 2, tableZ - 0.25);
box(tableGroup, 0.06, tableY, 0.06, darkWood, 0.6, tableY / 2, tableZ - 0.25);
box(tableGroup, 0.06, tableY, 0.06, darkWood, -0.6, tableY / 2, tableZ + 0.25);
box(tableGroup, 0.06, tableY, 0.06, darkWood, 0.6, tableY / 2, tableZ + 0.25);

