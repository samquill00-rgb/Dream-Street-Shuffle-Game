ctx.quadraticCurveTo(cx - 5, cy + 37.5, cx, cy + 37.5);
ctx.quadraticCurveTo(cx + 5, cy + 37.5, cx + 13, cy + 37); ctx.stroke();

// ═══ HEAVY STUBBLE ═══
ctx.fillStyle = 'rgba(50, 35, 25, 0.25)';
for (var si = 0; si < 200; si++) {
var sx = cx + (Math.random() - 0.5) * 62;
var sy2 = cy + 28 + Math.random() * 18;
var dx = Math.abs(sx - cx);
if (dx < 34 && sy2 > cy + 28) { ctx.beginPath(); ctx.arc(sx, sy2, 0.7 + Math.random() * 0.3, 0, Math.PI * 2); ctx.fill(); }
}
ctx.fillStyle = 'rgba(50, 35, 25, 0.3)';
for (var sj = 0; sj < 60; sj++) {
var sx3 = cx + (Math.random() - 0.5) * 30;
var sy3 = cy + 38 + Math.random() * 10;
ctx.beginPath(); ctx.arc(sx3, sy3, 0.5 + Math.random() * 0.3, 0, Math.PI * 2); ctx.fill();
}

var lfx = cx - 65, lfy = cy + 140;
var rfx = cx + 65, rfy = cy + 140;

var glowPulse = 0.5 + 0.5 * Math.sin(Date.now() / 100);
var glowStrength = fistPull;

var glowAlpha = glowStrength;
if (!this.isPractice()) {
if (this.sobriety < 25) glowAlpha *= 0.5;
else if (this.sobriety < 50) glowAlpha *= 0.7;
}

if (this.punchType === 'right_cross') {
rfx = cx + 65 + 30 * fistPull;
rfy = cy + 130 - 25 * fistPull;

if (this.phase === 'punching' && !this.copperHit) {
rfx = cx + 65 + 30 * (1 - this.punchT) - 60 * this.punchT;
rfy = cy + 105 + 95 * this.punchT;
var fs = 1 + 1.2 * this.punchT;
this.drawFist(ctx, rfx, rfy, 16 * fs, 20 * fs, -0.2, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, glowAlpha * glowPulse);

} else if (this.punchType === 'left_hook') {
lfx = cx - 65 - 30 * fistPull;
lfy = cy + 130 - 25 * fistPull;

if (this.phase === 'punching' && !this.copperHit) {
lfx = cx - 65 - 30 * (1 - this.punchT) + 60 * this.punchT;
lfy = cy + 105 + 95 * this.punchT;
var fs = 1 + 1.2 * this.punchT;
this.drawFist(ctx, lfx, lfy, 16 * fs, 20 * fs, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, glowAlpha * glowPulse);

} else if (this.punchType === 'uppercut') {
rfx = cx + 30;
rfy = cy + 160 + 35 * fistPull;

if (this.phase === 'punching' && !this.copperHit) {
rfx = cx + 30 * (1 - this.punchT);
rfy = cy + 195 - 110 * this.punchT;
var fs = 1 + 1.5 * this.punchT;
this.drawFist(ctx, rfx, rfy, 16 * fs, 20 * fs, 0, 0);
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
ctx.restore(); return;
}

this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, 0, glowAlpha * glowPulse);

} else {
this.drawFist(ctx, lfx, lfy, 16, 20, 0.2, 0);
this.drawFist(ctx, rfx, rfy, 16, 20, -0.2, 0);
}

ctx.restore();
}

drawFist(ctx, x, y, rx, ry, rot, glow) {
// Strong, large telegraph glow — was too small and dim to be noticed.
if (glow > 0.05) {
ctx.save();
// Outer halo (very wide and bright)
var glowR = Math.max(rx, ry) * 6;
var grad = ctx.createRadialGradient(x, y, Math.max(rx, ry) * 0.6, x, y, glowR);
grad.addColorStop(0, 'rgba(255, 220, 120, ' + (glow * 0.95) + ')');
grad.addColorStop(0.18, 'rgba(255, 140, 60, ' + (glow * 0.78) + ')');
grad.addColorStop(0.50, 'rgba(255, 80, 40, ' + (glow * 0.42) + ')');
grad.addColorStop(1, 'rgba(255, 30, 10, 0)');
ctx.fillStyle = grad;
ctx.beginPath();
ctx.ellipse(x, y, glowR, glowR, 0, 0, Math.PI * 2);
ctx.fill();
// Pulsing ring around the glove itself
var ringPulse = 0.5 + 0.5 * Math.sin(Date.now() / 110);
ctx.strokeStyle = 'rgba(255, 200, 100, ' + (glow * (0.55 + 0.45 * ringPulse)) + ')';
ctx.lineWidth = 3.5;
ctx.beginPath();
ctx.ellipse(x, y, rx + 5 + ringPulse * 3, ry + 5 + ringPulse * 3, rot, 0, Math.PI * 2);
ctx.stroke();
ctx.restore();
}

// Fist fill — when glowing, it goes bright red-orange instead of just slightly warmer beige.
if (glow > 0.05) {
var fillIntensity = Math.min(1, glow * 1.2);
ctx.fillStyle = 'rgba(' + Math.round(220 + 35 * fillIntensity) + ', ' + Math.round(70 + 30 * (1 - fillIntensity)) + ', ' + Math.round(40 + 20 * (1 - fillIntensity)) + ', 1)';
} else {
ctx.fillStyle = '#c4a07a';
}
ctx.beginPath();
ctx.ellipse(x, y, rx, ry, rot, 0, Math.PI * 2);
ctx.fill();
ctx.strokeStyle = glow > 0.05 ? '#ffd060' : '#8e6e52';
ctx.lineWidth = glow > 0.05 ? 2.5 : 1.5;
ctx.stroke();

ctx.strokeStyle = glow > 0.05 ? '#ffe080' : '#8e6e52';
ctx.lineWidth = 1;
ctx.beginPath(); ctx.moveTo(x - 6, y - 3); ctx.lineTo(x + 6, y - 3); ctx.stroke();
}

drawPunchPath(ctx) {
var t = this.telegraphT;
if (t < 0.15) return;
var progress = Math.min((t - 0.15) / 0.6, 1);

var pulse = 0.5 + 0.5 * Math.sin(Date.now() / 130);
var alpha = progress * 0.55 * pulse;

if (!this.isPractice()) {
if (this.sobriety < 25) alpha *= 0.4;
else if (this.sobriety < 50) alpha *= 0.65;
}

ctx.save();
ctx.strokeStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.fillStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.lineWidth = 2.5;
ctx.setLineDash([8, 6]);

var W = this.W, H = this.H;
var cx = this.copperBaseX;
var lean = 0, crouch = 0;
if (this.punchType === 'right_cross') lean = -35 * Math.min(t, 1);
else if (this.punchType === 'left_hook') lean = 35 * Math.min(t, 1);
else if (this.punchType === 'uppercut') crouch = 30 * Math.min(t, 1);

cx += lean;
var cy = this.copperBaseY + crouch;

if (this.punchType === 'right_cross') {
var fx = cx + 65 + 30 * t;
var fy = cy + 130 - 25 * t;
var landX = 100;
var landY = H * 0.75;
var cpx = W * 0.35;
var cpy = fy + 40;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(cpx, cpy, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, cpx, cpy, landX, landY, alpha);

} else if (this.punchType === 'left_hook') {
var fx = cx - 65 - 30 * t;
var fy = cy + 130 - 25 * t;
var landX = W - 100;
var landY = H * 0.75;
var cpx = W * 0.65;
var cpy = fy + 40;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(cpx, cpy, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, cpx, cpy, landX, landY, alpha);

} else if (this.punchType === 'uppercut') {
var fx = cx + 30;
var fy = cy + 160 + 35 * t;
var landX = W / 2;
var landY = H * 0.85;
ctx.beginPath();
ctx.moveTo(fx, fy);
ctx.quadraticCurveTo(fx - 10, landY - 20, landX, landY);
ctx.stroke();
this.drawPathArrowhead(ctx, fx - 10, landY - 20, landX, landY, alpha);
}

ctx.setLineDash([]);
ctx.restore();
}

drawPathArrowhead(ctx, cpx, cpy, tx, ty, alpha) {
var angle = Math.atan2(ty - cpy, tx - cpx);
var headLen = 14;
ctx.setLineDash([]);
ctx.fillStyle = 'rgba(255, 120, 60, ' + alpha + ')';
ctx.beginPath();
ctx.moveTo(tx, ty);
ctx.lineTo(tx - headLen * Math.cos(angle - 0.45), ty - headLen * Math.sin(angle - 0.45));
ctx.lineTo(tx - headLen * Math.cos(angle + 0.45), ty - headLen * Math.sin(angle + 0.45));
ctx.closePath();
ctx.fill();
}

drawTimerBar(ctx) {
var t = this.telegraphT;
var remaining = 1 - t;
var barW = this.W * remaining;
var pulse = 0.4 + 0.6 * Math.abs(Math.sin(Date.now() / 120));

ctx.fillStyle = 'rgba(234, 100, 100, 0.5)';
ctx.fillRect((this.W - barW) / 2, this.H - 10, barW, 5);
if (remaining < 0.3) {
ctx.fillStyle = 'rgba(255, 50, 50, ' + (0.3 + 0.7 * pulse) * 0.5 + ')';
ctx.fillRect((this.W - barW) / 2, this.H - 10, barW, 5);
}
}

drawZones(ctx) {
var alpha = 0.16;   // baseline zone fill — was 0.05 (barely visible)
var ha = 0.35;      // hover alpha
var practice = this.isPractice();
var correct = this.getCorrectDodge();

// Safe-zone telegraph glow — replaces the old punch-trajectory arrow.
// The CORRECT dodge zone lights up so the player's eye is drawn to where
// they should click, rather than to where the punch is going.
var safeGlow = 0;
if (this.phase === 'telegraph' && this.telegraphT > 0.15) {
  var progress = Math.min((this.telegraphT - 0.15) / 0.6, 1);
  var pulse = 0.5 + 0.5 * Math.sin(Date.now() / 200);
  safeGlow = progress * 0.45 * pulse;
  if (!practice) {
    if (this.sobriety < 25) safeGlow *= 0.4;
    else if (this.sobriety < 50) safeGlow *= 0.65;
  }
}

var leftCue  = (correct === 'dodge_left'  || correct === 'either') ? safeGlow : 0;
var rightCue = (correct === 'dodge_right' || correct === 'either') ? safeGlow : 0;

// ─── DODGE LEFT ───
var aL = Math.max(alpha, leftCue);
if (this.hoveredZone === 'dodge_left') aL = Math.max(aL, ha);
ctx.fillStyle = 'rgba(170, 255, 170, ' + aL + ')';
this.roundRect(ctx, 10, 130, 115, 210, 8); ctx.fill();
ctx.strokeStyle = 'rgba(170, 255, 170, ' + (aL + 0.25) + ')'; ctx.lineWidth = 1.5; ctx.stroke();
ctx.font = 'bold 16px Georgia';
ctx.textAlign = 'center';
var labelL = this.hoveredZone === 'dodge_left' ? 1 : (leftCue > 0.04 ? Math.min(1, 0.7 + leftCue * 1.4) : 0.7);
ctx.lineWidth = 3;
ctx.strokeStyle = 'rgba(0, 0, 0, 0.6)';
ctx.strokeText('← DODGE', 67, 240);
ctx.fillStyle = 'rgba(190, 255, 190, ' + labelL + ')';
ctx.fillText('← DODGE', 67, 240);

// ─── DODGE RIGHT ───
var aR = Math.max(alpha, rightCue);
if (this.hoveredZone === 'dodge_right') aR = Math.max(aR, ha);
ctx.fillStyle = 'rgba(170, 255, 170, ' + aR + ')';
this.roundRect(ctx, this.W - 125, 130, 115, 210, 8); ctx.fill();
ctx.strokeStyle = 'rgba(170, 255, 170, ' + (aR + 0.25) + ')'; ctx.lineWidth = 1.5; ctx.stroke();
var labelR = this.hoveredZone === 'dodge_right' ? 1 : (rightCue > 0.04 ? Math.min(1, 0.7 + rightCue * 1.4) : 0.7);
ctx.lineWidth = 3;
ctx.strokeStyle = 'rgba(0, 0, 0, 0.6)';
ctx.strokeText('DODGE →', this.W - 67, 240);
ctx.fillStyle = 'rgba(190, 255, 190, ' + labelR + ')';
ctx.fillText('DODGE →', this.W - 67, 240);

// ─── BLOCK ───
var aB = this.hoveredZone === 'block' ? ha : alpha;
ctx.fillStyle = 'rgba(220, 200, 120, ' + aB + ')';
this.roundRect(ctx, 155, 335, this.W - 310, 55, 8); ctx.fill();
ctx.strokeStyle = 'rgba(220, 200, 120, ' + (aB + 0.25) + ')'; ctx.lineWidth = 1.5; ctx.stroke();
ctx.lineWidth = 3;
ctx.strokeStyle = 'rgba(0, 0, 0, 0.6)';
ctx.strokeText('BLOCK', this.W / 2, 370);
ctx.fillStyle = 'rgba(240, 218, 138, ' + (this.hoveredZone === 'block' ? 1 : 0.75) + ')';
ctx.fillText('BLOCK', this.W / 2, 370);

// Counter discoverability — a subtle amber pulse on Counter during
// PRACTICE rounds only, slower than the dodge glow so it doesn't
// compete. After practice, it goes dim like the rest.
var counterPulse = 0;
if (practice && this.phase === 'telegraph' && this.telegraphT > 0.15) {
  var cp = Math.min((this.telegraphT - 0.15) / 0.6, 1);
  counterPulse = cp * 0.16 * (0.5 + 0.5 * Math.sin(Date.now() / 320));
}
var aC = this.hoveredZone === 'counter' ? ha : Math.max(alpha, counterPulse);
ctx.fillStyle = 'rgba(255, 150, 100, ' + aC + ')';
ctx.beginPath(); ctx.ellipse(this.W / 2, 190, 60, 65, 0, 0, Math.PI * 2); ctx.fill();
ctx.strokeStyle = 'rgba(255, 150, 100, ' + (aC + 0.30) + ')'; ctx.lineWidth = 1.5; ctx.stroke();
var labelC = this.hoveredZone === 'counter' ? 1 : (counterPulse > 0.04 ? Math.min(1, 0.7 + counterPulse * 1.6) : 0.75);
ctx.lineWidth = 3;
ctx.strokeStyle = 'rgba(0, 0, 0, 0.6)';
ctx.strokeText('COUNTER', this.W / 2, 195);
ctx.fillStyle = 'rgba(255, 178, 130, ' + labelC + ')';
ctx.fillText('COUNTER', this.W / 2, 195);
}

roundRect(ctx, x, y, w, h, r) {
ctx.beginPath();
ctx.moveTo(x + r, y);
ctx.lineTo(x + w - r, y);
ctx.quadraticCurveTo(x + w, y, x + w, y + r);
ctx.lineTo(x + w, y + h - r);
ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
ctx.lineTo(x + r, y + h);
ctx.quadraticCurveTo(x, y + h, x, y + h - r);
ctx.lineTo(x, y + r);
ctx.quadraticCurveTo(x, y, x + r, y);
ctx.closePath();
}

loop() {
this.draw();
if (!this.gameOver) {
requestAnimationFrame(() => this.loop());
}
}
};

window.startFightGame = function() {
document.getElementById('pre-fight').style.display = 'none';
document.getElementById('fight-arena').style.display = 'block';
var sobriety = parseInt(document.getElementById('sob-data').textContent) || 55;
new window.FightGame('fight-canvas', sobriety);
};

// ====== TYPEWRITER EFFECT ======
(function() {
function typewriterEffect(container) {
var textEntries = [];
// Gather Harlowe links to hide during typing. `tw-expression` wraps
// (link:)/(link-goto:) style macros; `tw-link` is the bare [[bracket]]
// link Harlowe renders directly. Both must be hidden — otherwise the
// bracket link sits dead on the page while text types in around it.
var linkEls = container.querySelectorAll('tw-expression, tw-link');
linkEls.forEach(function(el) {
el.style.opacity = '0';
el.style.transition = 'none';
el.style.pointerEvents = 'none';
});

function collectTextNodes(el) {
var children = el.childNodes;
for (var i = 0; i < children.length; i++) {
var child = children[i];
// Skip Harlowe link expressions — revealed after typing
if (child.nodeType === 1 && child.tagName === 'TW-EXPRESSION') continue;
// Skip bare [[bracket]] links too — same treatment, hidden until done
if (child.nodeType === 1 && child.tagName === 'TW-LINK') continue;
// Skip flash-reveal elements — triggered separately after typing completes
if (child.nodeType === 1 && child.classList && child.classList.contains('flash-reveal')) continue;
if (child.nodeType === 3) {
var text = child.textContent;
if (text.length > 0) {
textEntries.push({ node: child, fullText: text });
child.textContent = '';
}
} else if (child.nodeType === 1) {
collectTextNodes(child);
}
}
}

collectTextNodes(container);

// Build flat character queue
var queue = [];
for (var t = 0; t < textEntries.length; t++) {
for (var c = 0; c < textEntries[t].fullText.length; c++) {
queue.push({ entryIdx: t, char: textEntries[t].fullText[c] });
}
}

// Create block cursor
var cursor = document.createElement('span');
cursor.className = 'tw-cursor';
cursor.textContent = '\u2588';
container.appendChild(cursor);

// === PAPER ROLL WRAPPER ===
// Wrap the text content of .typewriter-page in an inner div that we can
// translate upward as text reveals. Using transform (rather than
// scrollTop) lets the page itself keep overflow:visible + clip-path,
// which is what allows the SVG wine stains to stray off the paper's
// left/right edges onto the dark background.
//
// IMPORTANT: leave any <svg> decorations as direct children of the page
// — they're position:absolute relative to the page's padding box, and
// moving them into the wrapper would shift their containing block to
// the wrapper's narrower content box (offsetting the stains/burns).
var rollWrapper = document.createElement('div');
rollWrapper.className = 'typewriter-paper-roll';
var kids = Array.prototype.slice.call(container.childNodes);
for (var ki = 0; ki < kids.length; ki++) {
  var kid = kids[ki];
  if (kid.nodeType === 1 && kid.tagName && kid.tagName.toLowerCase() === 'svg') {
    continue; // leave SVG decorations on the page
  }
  rollWrapper.appendChild(kid);
}
container.appendChild(rollWrapper);
var currentRoll = 0;

var qIdx = 0;
// Realistic typewriter pace — the original 28ms ran too fast at speed,
// the 14ms revision was a sprint, 20ms still felt machine-quick. 55ms
// landed honest but a touch too leisurely; 42ms keeps the typist-cadence
// feel while reading at a comfortable forward clip.
var baseSpeed = 42;

// Anchor to the global passage generation so any in-flight tick chain
// stops as soon as the player navigates away — even to a passage that
// has no typewriter of its own.
var myGen = (window._passageGen || 0);

function typeNext() {
if (myGen !== (window._passageGen || 0)) return; // passage swapped — abort
if (!container.isConnected) return; // container removed from DOM
if (qIdx >= queue.length) {
// Typing complete — fade cursor, reveal link
cursor.classList.add('tw-cursor-fade');
setTimeout(function() {
cursor.style.display = 'none';
linkEls.forEach(function(el) {
el.style.transition = 'opacity 1.2s ease-in';
el.style.opacity = '1';
el.style.pointerEvents = 'auto';
});
// Trigger flash-reveal elements after typing completes
var flashEls = container.querySelectorAll('.flash-reveal');
flashEls.forEach(function(el) {
el.classList.add('flash-reveal-active');
});
}, 800);
return;
}

var item = queue[qIdx];
var textNode = textEntries[item.entryIdx].node;
textNode.textContent += item.char;
qIdx++;

// Typewriter tick — skip pure whitespace so it doesn't sound like
// rapid-fire. ALSO skip entirely if the page is marked silent — these
// are atmosphere passages where the prose is being read, not typed.
if (window.dssAudio && item.char !== ' ' && item.char !== '\n' && item.char !== '\t' && !container.classList.contains('typewriter-silent')) {
  window.dssAudio.typewriterTick();
}

// Move cursor to follow the typing position
var parent = textNode.parentNode;
if (parent && textNode.nextSibling !== cursor) {
parent.insertBefore(cursor, textNode.nextSibling);
}

// "Carriage" effect — the page is a fixed-height window. Translate the
// inner roll-wrapper upward as the cursor moves down past ~65% of the
// visible window, keeping the cursor at a fixed carriage line. From the
// player's perspective, the paper rolls up through the typewriter while
// the cursor stays put — opposite direction to the revealing text.
var carriageY = container.clientHeight * 0.65;
var pageRect = container.getBoundingClientRect();
var cursorRect = cursor.getBoundingClientRect();
var cursorYInPage = cursorRect.top - pageRect.top;
var overshoot = cursorYInPage - carriageY;
if (overshoot > 0) {
  currentRoll += overshoot;
  rollWrapper.style.transform = 'translateY(-' + currentRoll + 'px)';
}

// Variable speed — natural reading pace. Punctuation pauses scaled up
// to match the slower base pace; a real typist breathes at periods.
var ch = item.char;
var delay = baseSpeed;
if (ch === '.' || ch === '?' || ch === '!') delay = 220;
else if (ch === ',' || ch === ';' || ch === ':') delay = 110;
else if (ch === '\n') delay = 170;
else delay = baseSpeed + Math.floor(Math.random() * 12) - 5;

setTimeout(typeNext, delay);
}

// Pre-warm the audio engine. The first tick fires synchronously with
// the first character, but if the AudioContext is still in 'suspended'
// limbo from the navigation click, the earliest scheduled buffers get
// silently dropped — so the first few letters appear without sound.
// A silent (vol 0) tick now wakes the context so the real first click
// lands cleanly with its character.
if (window.dssAudio && window.dssAudio.typewriterTick) {
  try { window.dssAudio.typewriterTick(0); } catch(e) {}
}
// Brief pause before typing starts — short enough that the first click
// lands while the page is still settling, not after a noticeable wait.
setTimeout(typeNext, 350);
}

// Watch for .typewriter-page appearing in the DOM
var observer = new MutationObserver(function() {
var page = document.querySelector('.typewriter-page');
if (page && !page.dataset.twTyping) {
page.dataset.twTyping = 'true';
// Force Courier on the container and every child element
var twFont = "'Courier New', Courier, monospace";
page.style.fontFamily = twFont;
var allEls = page.querySelectorAll('*');
for (var k = 0; k < allEls.length; k++) {
allEls[k].style.fontFamily = twFont;
}
// Per-page opt-out: pages marked .typewriter-static skip the type-on
// animation entirely — useful for short atmosphere reflections where
// the slow type-out feels like a wait rather than a beat.
var skipTypewriter = page.classList.contains('typewriter-static');
if (skipTypewriter) {
// Just make sure links are visible straight away — both macro and
// bracket forms, so future opacity-hiding CSS on .typewriter-static
// can't strand bracket links the way it stranded animated ones.
var linkEls = page.querySelectorAll('tw-expression, tw-link');
linkEls.forEach(function(el) {
el.style.opacity = '1';
el.style.pointerEvents = 'auto';
});
} else {
// Small delay to let Harlowe finish rendering
setTimeout(function() { typewriterEffect(page); }, 100);
}
}
});

observer.observe(document.body, { childList: true, subtree: true });
})();

// ====== LILY-GLIMPSE FADE ======
// .lily-glimpse spans fade in via the `lilyFadeIn` CSS animation on
// `.lily-glimpse.lily-fade` — handled entirely in CSS, no JS needed.
// (A previous session typed them out character-by-character; Dr Quill
// preferred the single opacity bloom.)

// ====== ALBA GOLDEN FLASH + MEMORY DISSOLVE ======
// Fires per-element (data-flashed marker) so each revelation / memory
// gets its own transition. Overlays self-remove once animation ends.
(function() {
function spawnFlash(cls) {
var el = document.createElement('div');
el.className = cls;
document.body.appendChild(el);
el.addEventListener('animationend', function() {
if (el.parentNode) el.parentNode.removeChild(el);
});
}
function albaTypewriter(em, startDelay) {
// Pre-warm the audio engine — same reason as the main typewriter: keeps
// the first soft click of the alba reveal from being swallowed by a
// still-suspending AudioContext.
if (window.dssAudio && window.dssAudio.typewriterTick) {
  try { window.dssAudio.typewriterTick(0); } catch(e) {}
}
var fullText = em.textContent;
em.textContent = '';
// Capture passage generation so a passage swap mid-reveal stops the chain
// — otherwise the soft alba clicks bleed onto the next passage.
var myAlbaGen = (window._passageGen || 0);
var cursor = document.createElement('span');
cursor.className = 'alba-tw-cursor';
cursor.textContent = '\u2588';
em.appendChild(cursor);
var i = 0;
function step() {
if (myAlbaGen !== (window._passageGen || 0)) return; // passage swapped
if (!em.isConnected) return; // element removed from DOM
if (i >= fullText.length) {
setTimeout(function() {
cursor.classList.add('alba-tw-cursor-fade');
}, 600);
return;
}
var ch = fullText[i++];
cursor.insertAdjacentText('beforebegin', ch);
// Soft typewriter click under the morning bell — quieter than the main
// typewriter (vol 0.09 vs default 0.18) so it sits under the chime rather
// than fighting it. Spaces and newlines stay silent (no key-strike for
// the space bar — the carriage doesn't click on whitespace travel).
if (window.dssAudio && window.dssAudio.typewriterTick && ch !== ' ' && ch !== '\n' && ch !== '\t') {
  try { window.dssAudio.typewriterTick(0.09); } catch(e) {}
}
var delay;
if (ch === '.' || ch === '!' || ch === '?') delay = 240;
else if (ch === ',' || ch === ';' || ch === ':') delay = 90;
else delay = 55 + Math.floor(Math.random() * 14) - 5;
setTimeout(step, delay);
}
setTimeout(step, startDelay || 1100);
}
var flashObserver = new MutationObserver(function() {
// Golden flash for alba revelation-box
var revBoxes = document.querySelectorAll('.revelation-box:not([data-flashed])');
revBoxes.forEach(function(rb) {
rb.setAttribute('data-flashed', '1');
spawnFlash(rb.classList.contains('revelation-lily') ? 'alba-flash-lily' : 'alba-flash-overlay');
// The "big noise" of an alba being caught — distant bell, four-and-a-
// half-second decay, rings under the typewriter's lead-in pause.
if (window.dssAudio && window.dssAudio.distantBell) window.dssAudio.distantBell();
var em = rb.querySelector('em');
if (em && !em.dataset.albaTyped) {
em.dataset.albaTyped = '1';
albaTypewriter(em, 1100);
}
});
// Violet dissolve for memory moments (lily-window OR inline .memory-moment)
var memories = document.querySelectorAll('.lily-window:not([data-flashed]), .memory-moment:not([data-flashed])');
memories.forEach(function(m) {
m.setAttribute('data-flashed', '1');
spawnFlash('alba-flash-violet');
});
});
flashObserver.observe(document.body, { childList: true, subtree: true });
})();

// ====== AUTO-GLOW SOLO LINK ======
// If a passage has exactly one active link (not greyed-out, not already
// a guided-link), glow it — same pulse as a manually-marked guided-link.
(function() {
var soloDebounce = null;
function checkSoloLink() {
var passage = document.querySelector('tw-passage');
if (!passage) return;
var allLinks = Array.from(passage.querySelectorAll('tw-link'));
allLinks.forEach(function(l) { l.classList.remove('auto-guided'); });
var active = allLinks.filter(function(l) {
return !l.closest('.greyed-out') && !l.closest('.guided-link') && !l.closest('.notebook-link');
});
if (active.length === 1) {
active[0].classList.add('auto-guided');
}
}
new MutationObserver(function() {
clearTimeout(soloDebounce);
soloDebounce = setTimeout(checkSoloLink, 350);
}).observe(document.body, { childList: true, subtree: true });
})();

// ====== LORE BOX OPENING SOUND ======
// Lore boxes are wrapped in (link: "⟡ LORE: ...")[<div class="lore-box">...]
// Harlowe replaces the link with the hook contents on click. We use the
// capture phase so we definitely get the event before Harlowe consumes it
// or replaces the element. Belt-and-braces: also a MutationObserver that
// fires the rustle whenever a NEW .lore-box appears in the DOM that wasn't
// already there at passage load.
(function() {
  // Uniform link-click tick — every tw-link gets a soft typewriter
  // tap when clicked. The writer is at his notebook all night.
  // Skip hidden navigation links (the '·' dots) and the BACK link
  // since they have their own audio identities or are silent by design.
  // Also skip links inside .ending-pane (Centre Point endings) — those
  // moments are silent by design.
  var _lastTick = 0;
  document.addEventListener('click', function(e) {
    var link = e.target && e.target.closest && e.target.closest('tw-link');
    if (!link) return;
    var txt = (link.textContent || '').trim();
    if (txt === '·' || txt === '·' || txt === '') return;
    if (/^←\s*BACK$/.test(txt)) return; // ← BACK has its own implication
    if (txt === 'BEGIN') return; // start-of-game BEGIN is silent
    if (link.getAttribute('data-auto-expand') === '1') return; // auto-expand on revisit is silent
    if (link.closest('.ending-pane')) return;
    var now = Date.now();
    if (now - _lastTick < 80) return;
    _lastTick = now;
    if (window.dssAudio && window.dssAudio.typewriterTick) {
      window.dssAudio.typewriterTick(0.10);
    }
  }, true);
  // Window-level Set tracks which lore titles the player has opened this
  // session. Lives in memory only (resets on page reload, which we treat as
  // "starting fresh"). Harlowe's $seenLore array proved unreliable for
  // mutate-from-JS-then-read-on-next-passage; this avoids the round-trip.
  if (!window.dssSeenLore) window.dssSeenLore = new Set();
  document.addEventListener('click', function(e) {
    var link = e.target && e.target.closest && e.target.closest('tw-link');
    if (!link) return;
    var txt = (link.textContent || '').toUpperCase();
    if (txt.indexOf('LORE') === -1) return;
    // Suppress unravel sound for auto-expansions on revisit — those are
    // restorations, not fresh discoveries.
    if (link.getAttribute('data-auto-expand') === '1') return;
    if (window.dssAudio && window.dssAudio.loreUnravel) {
      window.dssAudio.loreUnravel();
    }
    var title = (link.textContent || '').trim();
    if (title) window.dssSeenLore.add(title);
  }, true);
  // Tap on an already-taken lily — play a soft hollow chime so the player
  // gets feedback (the flower's gone, there's nothing to pick). Quieter
  // than the collection lilyChime and pitched lower. Throttled so a quick
  // double-tap doesn't fire twice.
  var _lastTakenChime = 0;
  document.addEventListener('click', function(e) {
    var taken = e.target && e.target.closest && e.target.closest('.lily-taken');
    if (!taken) return;
    // Fade the spent flower on every poke (even inside the throttle window)
    // so the visual feedback always tracks the click.
    if (window.dssLilyBlip) window.dssLilyBlip(taken.querySelector('.lily-prompt') || taken);
    var now = Date.now();
    if (now - _lastTakenChime < 400) return;
    _lastTakenChime = now;
    if (!window.dssAudio) return;
    // The flower's already gone — a low, dull "block" thunk rather than the
    // bright collection chime, so the player reads it as "nothing to pick".
    if (window.dssAudio.lilyBlock) {
      window.dssAudio.lilyBlock();
    } else if (window.dssAudio.lilyChime) {
      window.dssAudio.lilyChime();
    }
  }, true);

  // Fallback: watch for lore-boxes appearing AFTER initial passage render.
  // We tag every box that's already in the DOM at the time a new passage
  // loads as "seen" so the haunt-explainer (rendered inline on first haunt)
  // doesn't trigger the rustle.
  var seen = new WeakSet();
  function tagExisting() {
    var boxes = document.querySelectorAll('.lore-box');
    for (var i = 0; i < boxes.length; i++) seen.add(boxes[i]);
  }
  // Re-tag whenever Harlowe swaps in a new passage.
  new MutationObserver(function(mutations) {
    var passageSwapped = false;
    for (var i = 0; i < mutations.length; i++) {
      var m = mutations[i];
      for (var j = 0; j < m.addedNodes.length; j++) {
        var n = m.addedNodes[j];
        if (n.nodeType !== 1) continue;
        if (n.tagName === 'TW-PASSAGE') passageSwapped = true;
      }
    }
    if (passageSwapped) {
      /* Auto-expand any LORE link that the player has opened before. Tag
         the link with data-auto-expand BEFORE clicking so the click-tick
         and unravel sound both skip it. Pre-snapshot the existing
         lore-boxes so we can tag the newly-revealed ones with .lore-seen
         (greyed) once Harlowe replaces the links with their hook bodies.
         Delay 250ms is enough for Harlowe to wire up tw-link click
         handlers on the freshly-rendered passage. */
      setTimeout(function(){
        tagExisting();
        try {
          var seenSet = window.dssSeenLore;
          if (!seenSet || !seenSet.size) return;
          var preBoxes = new Set();
          var preDoc = document.querySelectorAll('.lore-box');
          for (var pb = 0; pb < preDoc.length; pb++) preBoxes.add(preDoc[pb]);
          var links = document.querySelectorAll('tw-link');
          var clickedAny = false;
          for (var i = 0; i < links.length; i++) {
            var ln = links[i];
            var lnTxt = (ln.textContent || '').trim();
            if (!lnTxt || lnTxt.toUpperCase().indexOf('LORE') === -1) continue;
            if (!seenSet.has(lnTxt)) continue;
            ln.setAttribute('data-auto-expand', '1');
            try { ln.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true })); }
            catch(e) { try { ln.click(); } catch(e2) {} }
            clickedAny = true;
          }
          if (clickedAny) {
            setTimeout(function() {
              var post = document.querySelectorAll('.lore-box');
              for (var pp = 0; pp < post.length; pp++) {
                if (!preBoxes.has(post[pp])) {
                  post[pp].classList.add('lore-seen');
                  // Also tag for the existing 'seen' WeakSet so the sound
                  // observer doesn't fire the unravel rustle for it.
                  seen.add(post[pp]);
                }
              }
            }, 60);
          }
        } catch(e) {}
      }, 250);
    } else {
      // No passage swap — any lore-box added now is from a click expansion.
      var boxes = document.querySelectorAll('.lore-box');
      for (var b = 0; b < boxes.length; b++) {
        if (!seen.has(boxes[b])) {
          seen.add(boxes[b]);
          if (window.dssAudio && window.dssAudio.loreUnravel) {
            window.dssAudio.loreUnravel();
            break; // only one rustle per click expansion
          }
        }
      }
    }
  }).observe(document.body, { childList: true, subtree: true });
  // Initial tag pass
  tagExisting();
})();

// ====== PASSAGE FADE LOCK ======
// tw-passage has a CSS `passageFadeIn` animation (0.55s delay + 0.55s fade).
// If anything mutates the element's animation/style after that — including
// some Harlowe (link:) click expansions which can briefly reset opacity on
// the parent during the in-place hook swap — the animation can re-trigger
// and the player sees a flash that looks like a full passage reload.
// Once a passage has finished fading in, we lock its opacity to 1 and clear
// the animation so any later in-place mutation can't replay the fade.
// New passages (real navigation) get a fresh tw-passage element and run
// the animation normally before being locked again.
(function() {
  document.addEventListener('animationend', function(e) {
    if (e.animationName !== 'passageFadeIn') return;
    var p = e.target;
    if (!p || p.tagName !== 'TW-PASSAGE') return;
    p.style.animation = 'none';
    p.style.opacity = '1';
  }, true);
})();

// ====== DEAN STREET LAMP DYNAMIC HEIGHT ======
// The pole must end exactly at the bottom of the last visible text or link
// on the page. We measure by finding the actual bottom pixel of the last
// visible content element, ignoring padding, empty hooks, and the lamp itself.
(function() {
var sizeTimer = null;

function findContentBottom(passage, lamp) {
var passageTop = passage.getBoundingClientRect().top;
var maxBottom = passageTop; // start at top
var els = passage.getElementsByTagName('*');
for (var i = 0; i < els.length; i++) {
var el = els[i];
// Skip the lamp SVG and anything inside it
if (el === lamp || lamp.contains(el)) continue;
// Skip hidden elements
var cs = window.getComputedStyle(el);
if (cs.display === 'none' || cs.visibility === 'hidden') continue;
var rect = el.getBoundingClientRect();
// Skip zero-size elements (empty hooks, collapsed whitespace)
if (rect.height === 0 || rect.width === 0) continue;
if (rect.bottom > maxBottom) maxBottom = rect.bottom;
}
return maxBottom - passageTop;
}

function sizeLamp() {
var lamp = document.getElementById('dean-lamp-svg');
var passage = document.querySelector('tw-passage');
if (!lamp || !passage || !lamp.parentNode) return;

// Pass 1: shrink float, measure natural content bottom
lamp.setAttribute('height', '1');
var h = findContentBottom(passage, lamp);
if (h < 50) h = 50;
lamp.setAttribute('height', Math.ceil(h));

// Pass 2: with float active text reflows — re-measure
requestAnimationFrame(function() {
var h2 = findContentBottom(passage, lamp);
if (h2 < 50) h2 = 50;
lamp.setAttribute('height', Math.ceil(h2));
});
}

// Debounced: waits 600ms after last DOM change (after gap cleanup at 300ms)
var deanLampObs = new MutationObserver(function() {
if (!document.getElementById('dean-lamp-svg')) return;
if (sizeTimer) clearTimeout(sizeTimer);
sizeTimer = setTimeout(sizeLamp, 150);
});
deanLampObs.observe(document.body, { childList: true, subtree: true });
})();

// ====== WHITESPACE GAP CLEANUP ======
// When Harlowe conditionals evaluate to false, the hooks are hidden but
// <br> elements between them remain visible, creating blank gaps.
// This aggressively collapses BR runs to max 1 between hidden blocks,
// and also trims trailing BRs at the end of passages (gap before links).
(function() {
function cleanGaps() {
var passage = document.querySelector('tw-passage');
if (!passage || passage.dataset.gapCleaned) return;
passage.dataset.gapCleaned = '1';

// Walk the passage DOM and find "effective BR runs" — sequences of <br>
// elements with only invisible nodes between them
cleanContainer(passage);

// Also clean inside visible tw-hooks (nested conditionals)
var hooks = passage.querySelectorAll('tw-hook');
for (var h = 0; h < hooks.length; h++) {
if (hooks[h].offsetParent !== null || window.getComputedStyle(hooks[h]).display !== 'none') {
cleanContainer(hooks[h]);
}
}

// Trim trailing BRs at end of passage (gap before final links)
trimTrailingBRs(passage);

// Trim leading BRs at start of passage (gap after invisible opening macros)
trimLeadingBRs(passage);

// Trim trailing/leading BRs inside visible hooks too
for (var h2 = 0; h2 < hooks.length; h2++) {
if (hooks[h2].offsetParent !== null || window.getComputedStyle(hooks[h2]).display !== 'none') {
trimTrailingBRs(hooks[h2]);
trimLeadingBRs(hooks[h2]);
}
}

// Hide haunt/lore boxes that have escaped their (if:) hooks.
// Harlowe's HTML parser pushes <div> block elements outside their tw-hook
// container. On repeat visits the hook is hidden but the escaped div is not,
// creating invisible-but-space-occupying elements. We detect them by checking
// that (a) they have no tw-hook ancestor and (b) the nearest preceding
// tw-expression contains a hidden conditional hook (not a link hook).
hideEscapedConditionals(passage);
}

function cleanContainer(container) {
var nodes = [];
var child = container.firstChild;
while (child) { nodes.push(child); child = child.nextSibling; }

var i = 0;
while (i < nodes.length) {
if (isBR(nodes[i])) {
// Start of a potential BR run
var brIndices = [i];
var j = i + 1;
while (j < nodes.length) {
if (isBR(nodes[j])) {
brIndices.push(j);
j++;
} else if (isInvisibleNode(nodes[j])) {
j++;
} else {
break;
}
}

// Check if this BR run sits between two visible content blocks,
// or is adjacent to hidden blocks. Be more aggressive near hidden content.
var prevVisible = hasPrecedingVisibleContent(nodes, i);
var nextVisible = hasFollowingVisibleContent(nodes, j);

// Allow max 1 BR between content (single paragraph break).
// If the run borders hidden content, allow at most 1.
var maxBRs = (prevVisible && nextVisible) ? 1 : 1;
if (brIndices.length > maxBRs) {
for (var k = maxBRs; k < brIndices.length; k++) {
nodes[brIndices[k]].style.display = 'none';
}
}
i = j;
} else {
i++;
}
}
}

function trimTrailingBRs(container) {
// Walk backward from end, hiding BRs and invisible nodes
var nodes = [];
var child = container.firstChild;
while (child) { nodes.push(child); child = child.nextSibling; }

for (var i = nodes.length - 1; i >= 0; i--) {
if (isBR(nodes[i])) {
nodes[i].style.display = 'none';
} else if (isInvisibleNode(nodes[i])) {
continue;
} else {
break; // hit visible content, stop
}
}
}

function trimLeadingBRs(container) {
// Walk forward from start, hiding BRs and invisible nodes
// until we hit the first real visible content
var nodes = [];
var child = container.firstChild;
while (child) { nodes.push(child); child = child.nextSibling; }

for (var i = 0; i < nodes.length; i++) {
if (isBR(nodes[i])) {
nodes[i].style.display = 'none';
} else if (isInvisibleNode(nodes[i])) {
continue;
} else {
break; // hit visible content, stop
}
}
}

function hideEscapedConditionals(passage) {
// When Harlowe sets innerHTML on a tw-hook containing <div> elements,
// the browser's HTML parser pushes block-level elements outside the
// inline tw-hook. On repeat visits the (if:) is false so the hook is
// hidden, but the escaped div is a sibling at passage level with
// opacity:0 (from its CSS animation), taking up full layout height.
//
// Detection: box has NO tw-hook ancestor AND the nearest preceding
// sibling tw-expression contains a hidden conditional hook (not a
// link hook — link hooks contain a tw-link alongside the tw-hook).
var boxes = passage.querySelectorAll('.haunt-box, .lore-box');
for (var b = 0; b < boxes.length; b++) {
var box = boxes[b];
// Step 1: check for any tw-hook ancestor
var el = box.parentElement;
var inHook = false;
while (el && el !== passage) {
if (el.tagName === 'TW-HOOK') { inHook = true; break; }
el = el.parentElement;
}
if (inHook) continue; // properly inside a hook — leave alone
// Step 2: walk backwards to find nearest tw-expression sibling
var sib = box.previousSibling;
while (sib) {
if (sib.nodeType === 1 && sib.tagName !== 'BR') {
if (sib.tagName === 'TW-EXPRESSION') {
// Link hooks contain a tw-link — leave those alone
if (sib.querySelector('tw-link')) break;
// Conditional hook: check if the tw-hook inside is hidden
var innerHook = sib.querySelector('tw-hook');
if (innerHook && window.getComputedStyle(innerHook).display === 'none') {
box.style.display = 'none';
}
break;
}
// Stop if we hit any other visible element
if (!isInvisibleNode(sib)) break;
}
sib = sib.previousSibling;
}
}
}

function hasPrecedingVisibleContent(nodes, idx) {
for (var i = idx - 1; i >= 0; i--) {
if (!isInvisibleNode(nodes[i]) && !isBR(nodes[i])) return true;
if (isBR(nodes[i])) return false;
}
return false;
}

function hasFollowingVisibleContent(nodes, idx) {
for (var i = idx; i < nodes.length; i++) {
if (!isInvisibleNode(nodes[i]) && !isBR(nodes[i])) return true;
}
return false;
}

function isBR(node) {
return node && node.nodeType === 1 && node.tagName === 'BR';
}

function isInvisibleNode(node) {
if (node.nodeType === 3) return node.textContent.trim() === '';
if (node.nodeType !== 1) return true;
var tag = node.tagName;
var style = window.getComputedStyle(node);
if (style.display === 'none') return true;
// Hidden tw-hooks (Harlowe hides them with inline style)
if (tag === 'TW-HOOK' && node.getAttribute('style') &&
node.getAttribute('style').indexOf('display') !== -1 &&
style.display === 'none') return true;
// tw-expression wrapping only hidden content
if (tag === 'TW-EXPRESSION') {
var visibleChild = false;
var ch = node.firstChild;
while (ch) {
if (ch.nodeType === 1) {
var chStyle = window.getComputedStyle(ch);
if (chStyle.display !== 'none' && ch.textContent.trim() !== '') {
// Check if it has any visible tw-link or real content
if (ch.querySelector && ch.querySelector('tw-link, a, canvas, img, svg, button, input')) {
visibleChild = true; break;
}
if (ch.textContent.trim() !== '') { visibleChild = true; break; }
}
} else if (ch.nodeType === 3 && ch.textContent.trim() !== '') {
visibleChild = true; break;
}
ch = ch.nextSibling;
}
if (!visibleChild) return true;
}
// Check for empty elements with no meaningful content
if (node.textContent.trim() === '' &&
!node.querySelector('canvas, img, svg, button, input, tw-link, a')) {
return true;
}
return false;
}

// Run cleanup on each passage load — three passes to catch late-rendering
// hooks. All three fire while the passage is still invisible (the
// passageFadeIn animation has a matching delay, see CSS).
var gapObs = new MutationObserver(function(mutations) {
for (var m = 0; m < mutations.length; m++) {
var added = mutations[m].addedNodes;
for (var n = 0; n < added.length; n++) {
if (added[n].nodeType === 1 &&
(added[n].tagName === 'TW-PASSAGE' ||
(added[n].querySelector && added[n].querySelector('tw-passage')))) {
setTimeout(cleanGaps, 30);
setTimeout(function() {
var p = document.querySelector('tw-passage');
if (p) { delete p.dataset.gapCleaned; cleanGaps(); }
}, 200);
setTimeout(function() {
var p = document.querySelector('tw-passage');
if (p) { delete p.dataset.gapCleaned; cleanGaps(); }
}, 450);
return;
}
}
}
});
gapObs.observe(document.body, { childList: true, subtree: true });
})();

// ============================================================
// ====== dssScene — REUSABLE 3D ATMOSPHERE TOOLKIT ===========
// ============================================================
// Procedural materials and props extracted from the Chippy /
// Pillars / Lackland scenes so new 3D approach scenes can pull
// the same Soho-night look without re-deriving every texture.
//
// Usage (inside a scene IIFE, after THREE is loaded):
//   var brickMat = dssScene.makeGrimyBrick({ baseColor: 0x7a5a48 });
//   var roadMat  = dssScene.makeGrimyRoad();
//   var paveMat  = dssScene.makePavingSlabs();
//   var stucco   = dssScene.makeWeatheredStucco();
//   dssScene.createVictorianGasLamp(scene, -4, 3.5);
//   var btn = dssScene.createEnterButton('ENTER THE SOMEWHERE',
//     function() { /* nav handler */ });
//   wrap.appendChild(btn);
//
// All `make*` factories return a THREE.MeshStandardMaterial with
// `map`/`repeat` set, ready to apply to geometry. `create*`
// factories build a THREE.Group (or DOM element) and add it for
// you when given a parent.
// ------------------------------------------------------------
window.dssScene = (function() {

  // ---------- canvas texture helper ----------
  function makeCanvasTexture(w, h, drawFunc) {
    var c = document.createElement('canvas');
    c.width = w; c.height = h;
    var cx = c.getContext('2d');
    drawFunc(cx, w, h);
    var tex = new THREE.CanvasTexture(c);
    tex.minFilter = THREE.LinearFilter;
    return tex;
  }

  // ---------- GRIMY BRICK ----------
  // Running-bond brickwork with mortar courses, soot streaks,
  // damp/lichen patches, paste-up ghost, top soot wash.
  // opts:
  //   baseColor:  fill rgb (default 0x6f4f3a)
  //   repeat:     [u, v] tiling (default [2, 4])
  //   sootStreaks: count (default 5)
  //   dampPatches: count (default 5)
  //   lichen:      count (default 12)
  //   highlightBricks: count of brighter-painted bricks (default 8)
  function makeGrimyBrick(opts) {
    opts = opts || {};
    var base = '#' + (opts.baseColor || 0x6f4f3a).toString(16).padStart(6, '0');
    var streaks = opts.sootStreaks != null ? opts.sootStreaks : 5;
    var damp    = opts.dampPatches != null ? opts.dampPatches : 5;
    var lichen  = opts.lichen      != null ? opts.lichen      : 12;
    var highlights = opts.highlightBricks != null ? opts.highlightBricks : 8;
    var tex = makeCanvasTexture(512, 512, function(cx, w, h) {
      cx.fillStyle = base; cx.fillRect(0, 0, w, h);
      var bH = 14, bW = 32;
      for (var by = 0; by < h; by += bH) {
        var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
        for (var bx = -bW; bx < w + bW; bx += bW) {
          var px = bx + rowOff;
          var r = 95 + Math.floor(Math.random() * 50);
          var g = 60 + Math.floor(Math.random() * 35);
          var b = 45 + Math.floor(Math.random() * 30);
          if (Math.random() > 0.94) { r -= 40; g -= 32; b -= 22; }
          if (Math.random() > 0.96) { r += 30; g += 18; b += 10; }
          cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
          cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
          cx.fillStyle = 'rgba(20,12,6,' + (0.05 + Math.random() * 0.10).toFixed(3) + ')';
          cx.fillRect(px + 1, by + bH - 3, bW - 2, 2);
        }
      }
      cx.fillStyle = 'rgba(170, 145, 115, 0.32)';
      for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
      cx.fillStyle = 'rgba(160, 135, 105, 0.22)';
      for (var hyy = 0; hyy < h; hyy += bH) {
        var ro = ((Math.floor(hyy / bH)) % 2 === 0) ? 0 : bW / 2;
        for (var hxx = ro; hxx < w; hxx += bW) cx.fillRect(hxx, hyy, 1.4, bH);
      }
      for (var ss = 0; ss < streaks; ss++) {
        var sx = Math.random() * w;
        var sxw = 12 + Math.random() * 30;
        var sg = cx.createLinearGradient(sx, 0, sx, h);
        sg.addColorStop(0, 'rgba(8, 6, 4, 0.55)');
        sg.addColorStop(0.3, 'rgba(12, 10, 6, 0.32)');
        sg.addColorStop(0.7, 'rgba(18, 14, 9, 0.12)');
        sg.addColorStop(1, 'rgba(22, 18, 10, 0)');
        cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
      }
      for (var d = 0; d < damp; d++) {
        var dx = Math.random() * w;
        var dy = h * 0.45 + Math.random() * h * 0.55;
        var dr = 30 + Math.random() * 50;
        var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
        dg2.addColorStop(0, 'rgba(60, 75, 55, 0.32)');
        dg2.addColorStop(0.5, 'rgba(50, 60, 45, 0.16)');
        dg2.addColorStop(1, 'rgba(40, 50, 40, 0)');
        cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
      }
      for (var lp = 0; lp < lichen; lp++) {
        cx.fillStyle = 'rgba(95, 105, 60, ' + (0.10 + Math.random() * 0.18).toFixed(3) + ')';
        cx.beginPath();
        cx.ellipse(Math.random() * w, Math.random() * h,
          5 + Math.random() * 12, 3 + Math.random() * 6.6,
          Math.random() * Math.PI, 0, Math.PI * 2);
        cx.fill();
      }
      var topG = cx.createLinearGradient(0, 0, 0, h * 0.45);
      topG.addColorStop(0, 'rgba(18, 12, 8, 0.42)');
      topG.addColorStop(1, 'rgba(18, 12, 8, 0)');
      cx.fillStyle = topG; cx.fillRect(0, 0, w, h * 0.45);
      cx.fillStyle = 'rgba(220, 200, 160, 0.08)';
      cx.fillRect(w * 0.12, h * 0.42, w * 0.18, h * 0.13);
      for (var hl = 0; hl < highlights; hl++) {
        var hbx = Math.floor(Math.random() * (w / bW)) * bW;
        var hby = Math.floor(Math.random() * (h / bH)) * bH;
        cx.fillStyle = 'rgba(220, 195, 150, ' + (0.10 + Math.random() * 0.15).toFixed(3) + ')';
        cx.fillRect(hbx + 1, hby + 1, bW - 2, 2);
      }
    });
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    var r = opts.repeat || [2, 4];
    tex.repeat.set(r[0], r[1]);
    return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.92 });
  }

  // ---------- WEATHERED STUCCO ----------
  // Cream stucco with hairline cracks, nicotine wash pooling
  // lower, soot streaks from gutters, damp/green patches, paint-
  // patch repairs, paste-up ghost, bird splat.
  // opts:
  //   baseColor: default 0xc8b89a
  //   repeat:    default [2, 3]
  function makeWeatheredStucco(opts) {
    opts = opts || {};
    var base = '#' + (opts.baseColor || 0xc8b89a).toString(16).padStart(6, '0');
    var tex = makeCanvasTexture(512, 512, function(cx, w, h) {
      cx.fillStyle = base; cx.fillRect(0, 0, w, h);
      for (var pp = 0; pp < 350; pp++) {
        var b = 180 + Math.floor(Math.random() * 30);
        cx.fillStyle = 'rgba(' + b + ',' + (b - 18) + ',' + (b - 32) + ',0.12)';
        cx.beginPath();
        cx.ellipse(Math.random() * w, Math.random() * h,
          6 + Math.random() * 24, 4 + Math.random() * 14, Math.random() * Math.PI, 0, Math.PI * 2);
        cx.fill();
      }
      var nicoG = cx.createLinearGradient(0, h * 0.35, 0, h);
      nicoG.addColorStop(0, 'rgba(170, 145, 80, 0)');
      nicoG.addColorStop(0.6, 'rgba(170, 145, 80, 0.10)');
      nicoG.addColorStop(1, 'rgba(160, 130, 60, 0.18)');
      cx.fillStyle = nicoG; cx.fillRect(0, h * 0.35, w, h * 0.65);
      for (var ss = 0; ss < 6; ss++) {
        var sx = Math.random() * w;
        var sxw = 10 + Math.random() * 26;
        var sg = cx.createLinearGradient(sx, 0, sx, h);
        sg.addColorStop(0, 'rgba(15, 12, 8, 0.50)');
        sg.addColorStop(0.4, 'rgba(20, 16, 10, 0.22)');
        sg.addColorStop(0.85, 'rgba(25, 20, 12, 0.08)');
        sg.addColorStop(1, 'rgba(25, 20, 12, 0)');
        cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
      }
      for (var d = 0; d < 4; d++) {
        var dx = Math.random() * w;
        var dy = h * 0.7 + Math.random() * h * 0.3;
        var dr = 32 + Math.random() * 50;
        var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
        dg2.addColorStop(0, 'rgba(70, 80, 55, 0.30)');
        dg2.addColorStop(1, 'rgba(40, 50, 40, 0)');
        cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
      }
      cx.strokeStyle = 'rgba(50, 38, 22, 0.45)'; cx.lineWidth = 0.7;
      for (var ch = 0; ch < 14; ch++) {
        cx.beginPath();
        var cxh = Math.random() * w, cyh = Math.random() * h;
        cx.moveTo(cxh, cyh);
        for (var sg2 = 0; sg2 < 5; sg2++) {
          cxh += (Math.random() - 0.5) * 28; cyh += 12 + Math.random() * 22;
          cx.lineTo(cxh, cyh);
        }
        cx.stroke();
      }
      for (var pr = 0; pr < 8; pr++) {
        var prx = Math.random() * w, pry = Math.random() * h;
        var prr = 12 + Math.random() * 22;
        var pg = cx.createRadialGradient(prx, pry, 0, prx, pry, prr);
        pg.addColorStop(0, 'rgba(225, 210, 180, 0.45)');
        pg.addColorStop(0.6, 'rgba(220, 200, 170, 0.14)');
        pg.addColorStop(1, 'rgba(220, 200, 170, 0)');
        cx.fillStyle = pg;
        cx.beginPath();
        cx.ellipse(prx, pry, prr, prr * 0.7, Math.random() * Math.PI, 0, Math.PI * 2);
        cx.fill();
      }
      cx.fillStyle = 'rgba(200, 170, 130, 0.10)';
      cx.fillRect(w * 0.18, h * 0.55, w * 0.12, h * 0.10);
      cx.fillStyle = 'rgba(245, 240, 215, 0.36)';
      cx.beginPath();
      cx.ellipse(w * 0.88, h * 0.08, 5, 2.5, 0.4, 0, Math.PI * 2);
      cx.fill();
    });
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    var r = opts.repeat || [2, 3];
    tex.repeat.set(r[0], r[1]);
    return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.95 });
  }

  // ---------- GRIMY ROAD ----------
  // Tarmac with aggregate speckle, lighter repair patches, jagged
  // cracks, wandering tar-seal sealant lines, oil blotches, faded
  // white centre line.
  function makeGrimyRoad(opts) {
    opts = opts || {};
    var base = '#' + (opts.baseColor || 0x1c1c1c).toString(16).padStart(6, '0');
    var tex = makeCanvasTexture(512, 512, function(cx, w, h) {
      cx.fillStyle = base; cx.fillRect(0, 0, w, h);
      for (var p = 0; p < 4200; p++) {
        var pg = 25 + Math.floor(Math.random() * 70);
        cx.fillStyle = 'rgba(' + pg + ',' + pg + ',' + pg + ',0.42)';
        cx.fillRect(Math.random() * w, Math.random() * h, 1.5, 1.5);
      }
      for (var rp = 0; rp < 6; rp++) {
        var rx = Math.random() * w, ry = Math.random() * h;
        var rwd = 50 + Math.random() * 100, rht = 35 + Math.random() * 70;
        cx.fillStyle = 'rgba(78, 78, 78, ' + (0.16 + Math.random() * 0.22).toFixed(3) + ')';
        cx.fillRect(rx, ry, rwd, rht);
        cx.strokeStyle = 'rgba(100, 100, 100, 0.18)'; cx.lineWidth = 0.6;
        cx.strokeRect(rx, ry, rwd, rht);
      }
      cx.strokeStyle = 'rgba(8, 8, 8, 0.8)'; cx.lineWidth = 1.2;
      for (var c = 0; c < 10; c++) {
        cx.beginPath();
        var cx0 = Math.random() * w, cy0 = Math.random() * h;
        cx.moveTo(cx0, cy0);
        var ang = Math.random() * Math.PI * 2, len = 30 + Math.random() * 80;
        cx.lineTo(cx0 + Math.cos(ang) * len, cy0 + Math.sin(ang) * len);
        cx.lineTo(cx0 + Math.cos(ang + 0.4) * len * 1.4, cy0 + Math.sin(ang + 0.4) * len * 1.4);
        cx.stroke();
      }
      cx.strokeStyle = 'rgba(0, 0, 0, 0.9)'; cx.lineWidth = 2.6;
      for (var tm = 0; tm < 5; tm++) {
        cx.beginPath();
        var tx = Math.random() * w, ty = Math.random() * h;
        cx.moveTo(tx, ty);
        for (var ts = 0; ts < 5; ts++) {
          tx += (Math.random() - 0.5) * 30; ty += 8 + Math.random() * 16;
          cx.lineTo(tx, ty);
        }
        cx.stroke();
      }
      cx.fillStyle = 'rgba(220, 220, 200, 0.5)';
      cx.fillRect(w * 0.5 - 2, h * 0.3, 4, h * 0.4);
      cx.fillStyle = 'rgba(220, 220, 200, 0.18)';
      cx.fillRect(w * 0.5 - 2, h * 0.05, 4, h * 0.2);
      cx.fillRect(w * 0.5 - 2, h * 0.75, 4, h * 0.2);
      for (var os = 0; os < 4; os++) {
        var ox = Math.random() * w, oy = Math.random() * h;
        var orr = 8 + Math.random() * 18;
        var og = cx.createRadialGradient(ox, oy, 0, ox, oy, orr);
        og.addColorStop(0, 'rgba(0, 0, 0, 0.62)');
        og.addColorStop(0.7, 'rgba(15, 12, 5, 0.22)');
        og.addColorStop(1, 'rgba(15, 12, 5, 0)');
        cx.fillStyle = og; cx.fillRect(ox - orr, oy - orr, orr * 2, orr * 2);
      }
    });
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    var r = opts.repeat || [1, 8];
    tex.repeat.set(r[0], r[1]);
    return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.78, metalness: 0.18 });
  }

  // ---------- PAVING SLABS ----------
  // London paving slabs with grout, cracks, gum/fag-ends and
  // wet patches.
  function makePavingSlabs(opts) {
    opts = opts || {};
    var base = '#' + (opts.baseColor || 0x3a3a36).toString(16).padStart(6, '0');
    var tex = makeCanvasTexture(512, 512, function(cx, w, h) {
      cx.fillStyle = base; cx.fillRect(0, 0, w, h);
      var sw = 128, sh = 96;
      cx.strokeStyle = 'rgba(18, 18, 16, 0.55)'; cx.lineWidth = 1.4;
      for (var sy = 0; sy < h; sy += sh) {
        var off = ((sy / sh) % 2 === 0) ? 0 : sw / 2;
        for (var sx = -sw; sx < w + sw; sx += sw) {
          var bxp = sx + off;
          var sg = 48 + Math.floor(Math.random() * 28);
          cx.fillStyle = 'rgba(' + sg + ',' + sg + ',' + (sg - 4) + ',' + (0.32 + Math.random() * 0.3).toFixed(3) + ')';
          cx.fillRect(bxp, sy, sw, sh);
          cx.strokeRect(bxp, sy, sw, sh);
        }
      }
      cx.strokeStyle = 'rgba(15, 15, 12, 0.55)'; cx.lineWidth = 0.9;
      for (var c2 = 0; c2 < 7; c2++) {
        cx.beginPath();
        cx.moveTo(Math.random() * w, Math.random() * h);
        cx.lineTo(Math.random() * w, Math.random() * h);
        cx.stroke();
      }
      for (var fe = 0; fe < 60; fe++) {
        cx.fillStyle = 'rgba(180, 175, 165, ' + (0.15 + Math.random() * 0.22).toFixed(3) + ')';
        cx.beginPath();
        cx.arc(Math.random() * w, Math.random() * h, 1.0 + Math.random() * 1.6, 0, Math.PI * 2);
        cx.fill();
      }
      for (var wp = 0; wp < 5; wp++) {
        var wpx = Math.random() * w, wpy = Math.random() * h;
        var wpr = 35 + Math.random() * 60;
        var wpg = cx.createRadialGradient(wpx, wpy, 0, wpx, wpy, wpr);
        wpg.addColorStop(0, 'rgba(72, 78, 80, 0.35)');
        wpg.addColorStop(1, 'rgba(72, 78, 80, 0)');
        cx.fillStyle = wpg; cx.fillRect(wpx - wpr, wpy - wpr, wpr * 2, wpr * 2);
      }
    });
    tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
    var r = opts.repeat || [4, 4];
    tex.repeat.set(r[0], r[1]);
    return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.88 });
  }

  // ---------- VICTORIAN GAS LAMP ----------
  // Cast-iron stepped base, fluted shaft, mid-band, ladder rest,
  // capital, 4-sided emissive glass lantern, pyramidal cap,
  // crown finial, point light, halo + inner-core sprites.
  // Adds the lamp group to `parent` at (x, 0, z). Returns the
  // group (with `.userData.light` set to the PointLight).
  //
  // opts:
  //   intensity:   point-light intensity (default 0.5)
  //   distance:    point-light range (default 10)
  //   lampColor:   point-light + glow colour (default 0xffd6a0)
  //   haloScale:   outer halo sprite size (default 2.2)
  //   coreScale:   inner-core sprite size (default 0.9)
  //   paneColor:   solid emissive pane colour (default 0xfff0c8)
  function createVictorianGasLamp(parent, x, z, opts) {
    opts = opts || {};
    var lampColor = opts.lampColor || 0xffd6a0;
    var paneColor = opts.paneColor || 0xfff0c8;
    var g = new THREE.Group();
    var castIron = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.78, metalness: 0.22 });
    var darkIron = new THREE.MeshStandardMaterial({ color: 0x121212, roughness: 0.7, metalness: 0.3 });
    var brassish = new THREE.MeshStandardMaterial({ color: 0x6a4a1a, roughness: 0.6, metalness: 0.35 });
    function place(geo, mat, px, py, pz) {
      var m = new THREE.Mesh(geo, mat); m.position.set(px, py, pz); g.add(m); return m;
    }
    // Stepped base
    place(new THREE.CylinderGeometry(0.24, 0.28, 0.10, 16), castIron, 0, 0.05, 0);
    place(new THREE.CylinderGeometry(0.20, 0.24, 0.18, 16), castIron, 0, 0.19, 0);
    place(new THREE.CylinderGeometry(0.17, 0.20, 0.05, 16), darkIron, 0, 0.31, 0);
    place(new THREE.BoxGeometry(0.32, 0.32, 0.32), castIron, 0, 0.50, 0);
    place(new THREE.CylinderGeometry(0.11, 0.16, 0.06, 16), darkIron, 0, 0.69, 0);
    // Shaft
    place(new THREE.CylinderGeometry(0.058, 0.10, 3.9, 16), castIron, 0, 2.65, 0);
    // Mid-band
    place(new THREE.CylinderGeometry(0.082, 0.082, 0.06, 16), darkIron, 0, 1.55, 0);
    place(new THREE.CylinderGeometry(0.090, 0.090, 0.02, 16), darkIron, 0, 1.58, 0);
    place(new THREE.CylinderGeometry(0.090, 0.090, 0.02, 16), darkIron, 0, 1.52, 0);
    // Ladder rest
    place(new THREE.BoxGeometry(0.52, 0.018, 0.018), castIron, 0, 4.45, 0);
    place(new THREE.BoxGeometry(0.018, 0.018, 0.52), castIron, 0, 4.45, 0);
    place(new THREE.SphereGeometry(0.024, 6, 4), castIron,  0.26, 4.45, 0);
    place(new THREE.SphereGeometry(0.024, 6, 4), castIron, -0.26, 4.45, 0);
    place(new THREE.SphereGeometry(0.024, 6, 4), castIron, 0, 4.45,  0.26);
    place(new THREE.SphereGeometry(0.024, 6, 4), castIron, 0, 4.45, -0.26);
    // Capital
    place(new THREE.CylinderGeometry(0.085, 0.062, 0.08, 16), castIron, 0, 4.66, 0);
    place(new THREE.CylinderGeometry(0.105, 0.085, 0.04, 16), darkIron, 0, 4.72, 0);
    place(new THREE.CylinderGeometry(0.045, 0.045, 0.14, 12), castIron, 0, 4.81, 0);
    // Lantern base + 4 emissive panes
    place(new THREE.BoxGeometry(0.34, 0.04, 0.34), darkIron, 0, 4.91, 0);
    var paneMat = new THREE.MeshBasicMaterial({ color: paneColor });
    var paneF = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneF.position.set(0, 5.16, 0.134); g.add(paneF);
    var paneB = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneB.position.set(0, 5.16, -0.134); paneB.rotation.y = Math.PI; g.add(paneB);
    var paneL = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneL.position.set(-0.134, 5.16, 0); paneL.rotation.y = Math.PI / 2; g.add(paneL);
    var paneR = new THREE.Mesh(new THREE.PlaneGeometry(0.26, 0.40), paneMat);
    paneR.position.set(0.134, 5.16, 0); paneR.rotation.y = -Math.PI / 2; g.add(paneR);
    // Corner posts + cross-bars
    var corners = [[0.135, 0.135], [-0.135, 0.135], [0.135, -0.135], [-0.135, -0.135]];
    for (var cp = 0; cp < 4; cp++) {
      place(new THREE.BoxGeometry(0.028, 0.44, 0.028), darkIron, corners[cp][0], 5.16, corners[cp][1]);
    }
    place(new THREE.BoxGeometry(0.28, 0.018, 0.018), darkIron, 0, 5.16,  0.135);
    place(new THREE.BoxGeometry(0.28, 0.018, 0.018), darkIron, 0, 5.16, -0.135);
    place(new THREE.BoxGeometry(0.018, 0.018, 0.28), darkIron,  0.135, 5.16, 0);
    place(new THREE.BoxGeometry(0.018, 0.018, 0.28), darkIron, -0.135, 5.16, 0);
    // Top plate + pyramidal cap
    place(new THREE.BoxGeometry(0.36, 0.045, 0.36), darkIron, 0, 5.40, 0);
    var cap = new THREE.Mesh(new THREE.ConeGeometry(0.24, 0.20, 4), castIron);
    cap.position.set(0, 5.52, 0); cap.rotation.y = Math.PI / 4; g.add(cap);
    // Crown finial
    place(new THREE.SphereGeometry(0.034, 8, 6), darkIron, 0, 5.66, 0);
    place(new THREE.CylinderGeometry(0.008, 0.008, 0.12, 8), darkIron, 0, 5.74, 0);
    place(new THREE.SphereGeometry(0.018, 6, 4), brassish,  0, 5.82, 0);
    // Point light
    var light = new THREE.PointLight(lampColor, opts.intensity != null ? opts.intensity : 0.5, opts.distance != null ? opts.distance : 10);
    light.position.set(0, 5.16, 0); light.castShadow = true; g.add(light);
    // Halo sprite
    var glowTex = makeCanvasTexture(128, 128, function(cx, w, h) {
      var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
      grad.addColorStop(0, 'rgba(255, 220, 150, 0.85)');
      grad.addColorStop(0.25, 'rgba(255, 200, 110, 0.40)');
      grad.addColorStop(0.6, 'rgba(220, 160, 70, 0.08)');
      grad.addColorStop(1, 'rgba(180, 120, 50, 0)');
      cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
    });
    var halo = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.7 }));
    halo.position.set(0, 5.16, 0);
    var hs = opts.haloScale || 2.2;
    halo.scale.set(hs, hs, 1); g.add(halo);
    // Inner core
    var coreTex = makeCanvasTexture(64, 64, function(cx, w, h) {
      var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
      grad.addColorStop(0, 'rgba(255, 245, 200, 1)');
      grad.addColorStop(0.3, 'rgba(255, 220, 140, 0.55)');
      grad.addColorStop(1, 'rgba(255, 200, 110, 0)');
      cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
    });
    var core = new THREE.Sprite(new THREE.SpriteMaterial({ map: coreTex, transparent: true, opacity: 0.9 }));
    core.position.set(0, 5.16, 0);
    var cs = opts.coreScale || 0.9;
    core.scale.set(cs, cs, 1); g.add(core);
    g.position.set(x, 0, z); g.userData.light = light;
    parent.add(g); return g;
  }

  // ---------- HOODED SHOP LAMP ----------
  // Bracket-out + downward-cone hood + bulb + warm point light.
  // Adds to `parent` at the given world position.
  function createHoodedShopLamp(parent, x, y, z, opts) {
    opts = opts || {};
    var body = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.5 });
    function place(geo, mat, px, py, pz) {
      var m = new THREE.Mesh(geo, mat); m.position.set(px, py, pz); parent.add(m); return m;
    }
    // Bracket
    place(new THREE.BoxGeometry(0.04, 0.04, 0.32), body, x, y, z);
    // Hood
    var hood = new THREE.Mesh(new THREE.CylinderGeometry(0.18, 0.10, 0.16, 12), body);
    hood.position.set(x, y - 0.10, z + 0.16); parent.add(hood);
    // Bulb
    var bulb = new THREE.Mesh(new THREE.SphereGeometry(0.05, 8, 6),
      new THREE.MeshBasicMaterial({ color: 0xfff0c8 }));
    bulb.position.set(x, y - 0.22, z + 0.16); parent.add(bulb);
    // Light
    var light = new THREE.PointLight(opts.lightColor || 0xffe5a0,
      opts.intensity != null ? opts.intensity : 0.45,
      opts.distance != null ? opts.distance : 4);
    light.position.set(x, y - 0.4, z + 0.19);
    parent.add(light);
    return { hood: hood, bulb: bulb, light: light };
  }

  // ---------- ENTER BUTTON (Ginger-Light style) ----------
  // Standard approach button: transparent dark fill, coloured
  // text + border, fades in, hover brightens.
  // Returns the DOM element. Caller appends + wires onclick.
  function createEnterButton(label, opts) {
    opts = opts || {};
    var color = opts.color || '232,180,80';
    var hover = opts.hoverColor || '255,210,120';
    var fadeIn = opts.fadeInMs != null ? opts.fadeInMs : 1800;
    var btn = document.createElement('div');
    btn.textContent = label;
    btn.style.cssText = [
      'position:fixed', 'bottom:60px', 'left:50%', 'transform:translateX(-50%)',
      'font:13px "Courier New",monospace',
      'color:rgba(' + color + ',0.85)',
      'letter-spacing:4px', 'cursor:pointer', 'padding:12px 28px',
      'border:1px solid rgba(' + color + ',0.3)',
      'background:rgba(0,0,0,0.4)',
      'z-index:9004', 'white-space:nowrap',
      'opacity:0', 'transition:opacity 1.5s ease, color 0.3s ease, border-color 0.3s ease'
    ].join(';');
    setTimeout(function() { btn.style.opacity = '1'; }, fadeIn);
    btn.addEventListener('mouseenter', function() {
      this.style.color = 'rgba(' + hover + ',0.95)';
      this.style.borderColor = 'rgba(' + color + ',0.6)';
    });
    btn.addEventListener('mouseleave', function() {
      this.style.color = 'rgba(' + color + ',0.85)';
      this.style.borderColor = 'rgba(' + color + ',0.3)';
    });
    return btn;
  }

  // ---------- UV FLY-KILLER ----------
  // Grey casing + slatted grille + bright additive-blended violet
  // UV tube + bluish halo sprite. Adds parts to `parent` centred
  // at (x, y, z). Returns { casing, light }.
  function createFlyKiller(parent, x, y, z, opts) {
    opts = opts || {};
    function place(geo, mat, px, py, pz) {
      var m = new THREE.Mesh(geo, mat); m.position.set(px, py, pz); parent.add(m); return m;
    }
    // Casing
    var casing = place(new THREE.BoxGeometry(0.85, 0.32, 0.10),
      new THREE.MeshStandardMaterial({ color: 0x2a2a2c, roughness: 0.65, metalness: 0.25 }),
      x, y, z);
    // Grille slats
    for (var fk = 0; fk < 5; fk++) {
      place(new THREE.BoxGeometry(0.78, 0.018, 0.015),
        new THREE.MeshStandardMaterial({ color: 0x1a1a1c, roughness: 0.7, metalness: 0.3 }),
        x, y - 0.11 + fk * 0.06, z + 0.05);
    }
    // UV tube (additive)
    var tubeMat = new THREE.MeshBasicMaterial({
      color: 0x6a90ff, blending: THREE.AdditiveBlending,
      transparent: true, opacity: 1.0, depthWrite: false
    });
    var tube = new THREE.Mesh(new THREE.PlaneGeometry(0.72, 0.18), tubeMat);
    tube.position.set(x, y, z + 0.07); parent.add(tube);
    // Inner core
    var coreMat = new THREE.MeshBasicMaterial({
      color: 0xcad8ff, blending: THREE.AdditiveBlending,
      transparent: true, opacity: 1.0, depthWrite: false
    });
    var core = new THREE.Mesh(new THREE.PlaneGeometry(0.65, 0.06), coreMat);
    core.position.set(x, y, z + 0.08); parent.add(core);
    // Halo
    var haloTex = makeCanvasTexture(64, 64, function(cx, w, h) {
      var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
      grad.addColorStop(0, 'rgba(120, 160, 255, 0.95)');
      grad.addColorStop(0.4, 'rgba(80, 120, 255, 0.35)');
      grad.addColorStop(1, 'rgba(60, 100, 255, 0)');
      cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
    });
    var halo = new THREE.Sprite(new THREE.SpriteMaterial({
      map: haloTex, transparent: true, opacity: 0.85,
      blending: THREE.AdditiveBlending, depthWrite: false
    }));
    halo.position.set(x, y, z + 0.09); halo.scale.set(1.3, 0.5, 1); parent.add(halo);
    // Light spill
    var light = new THREE.PointLight(0x4060ff,
      opts.intensity != null ? opts.intensity : 0.55,
      opts.distance != null ? opts.distance : 3.5);
    light.position.set(x, y - 0.15, z - 0.1); parent.add(light);
    return { casing: casing, light: light };
  }

  return {
    makeCanvasTexture: makeCanvasTexture,
    makeGrimyBrick: makeGrimyBrick,
    makeWeatheredStucco: makeWeatheredStucco,
    makeGrimyRoad: makeGrimyRoad,
    makePavingSlabs: makePavingSlabs,
    createVictorianGasLamp: createVictorianGasLamp,
    createHoodedShopLamp: createHoodedShopLamp,
    createEnterButton: createEnterButton,
    createFlyKiller: createFlyKiller
  };
})();

// ====== SHARED THREE.JS DISPOSAL HELPERS ======
// Each approach scene appends a body-level wrap div, creates a WebGL
// renderer + Three.js scene, and registers a window 'resize' listener.
// Without explicit disposal, every revisit accumulates GPU textures,
// geometries, materials, and stale resize handlers. These helpers give
// each scene a one-line bind (registers the resize + tracks the trio)
// and a one-line dispose (called from the setInterval !container branch).
window._dssThreeRegistry = window._dssThreeRegistry || {};
window._dssBindScene = function(wrapId, scene, renderer, camera) {
  var resize = function() {
    if (!camera || !renderer) return;
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  };
  window.addEventListener('resize', resize);
  window._dssThreeRegistry[wrapId] = { scene: scene, renderer: renderer, resize: resize };
};
window._dssDisposeWrap = function(wrapId) {
  var entry = window._dssThreeRegistry && window._dssThreeRegistry[wrapId];
  if (entry) {
    window._dssDisposeThreeScene(entry.scene, entry.renderer, entry.resize);
    delete window._dssThreeRegistry[wrapId];
  }
  var wrap = document.getElementById(wrapId);
  if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
};
window._dssDisposeThreeScene = function(scene, renderer, resizeHandler) {
  try {
    if (resizeHandler) window.removeEventListener('resize', resizeHandler);
  } catch(e) {}
  try {
    if (scene && scene.traverse) {
      scene.traverse(function(child) {
        if (child.geometry && child.geometry.dispose) {
          try { child.geometry.dispose(); } catch(e) {}
        }
        if (child.material) {
          var mats = Array.isArray(child.material) ? child.material : [child.material];
          for (var mi = 0; mi < mats.length; mi++) {
            var m = mats[mi]; if (!m) continue;
            // Dispose every texture-bearing slot. Three.js doesn't auto-free these.
            ['map','normalMap','specularMap','emissiveMap','alphaMap','aoMap','bumpMap','displacementMap','envMap','lightMap','metalnessMap','roughnessMap']
              .forEach(function(key){ if (m[key] && m[key].dispose) { try { m[key].dispose(); } catch(e) {} } });
            if (m.dispose) { try { m.dispose(); } catch(e) {} }
          }
        }
      });
    }
  } catch(e) {}
  try {
    if (renderer) {
      if (renderer.renderLists && renderer.renderLists.dispose) renderer.renderLists.dispose();
      if (renderer.dispose) renderer.dispose();
      // Force context loss so the GPU buffer is released immediately
      // rather than waiting for GC of the WebGL canvas.
      if (renderer.forceContextLoss) {
        try { renderer.forceContextLoss(); } catch(e) {}
      }
    }
  } catch(e) {}
};

// ====== GINGER LIGHT SCENE — INLINE ======
(function() {
var glActive = false;
var glAnimId = null;

function initGingerLight() {
if (glActive) return;
glActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildGLScene(); };
document.head.appendChild(s);
} else {
buildGLScene();
}
}

function buildGLScene() {
// Create full-screen overlay wrapper
var glWrap = document.createElement('div');
glWrap.id = 'gl-wrap';
glWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#08080e;overflow:hidden;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x08080e);

// Deep Soho fog — swallows the far end of the streets
scene.fog = new THREE.Fog(0x08080e, 4, 32);

var camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT EXPLANATION
// ============================================================
// Street corner: Dean Street runs north-south (along Z axis)
// Greek Street joins from the east (along X axis)
// The hero streetlamp stands at the corner, slightly on the pavement
// Camera looks up slightly at the lamp from across the junction
// Buildings line both streets, fading into fog

camera.position.set(6.5, 2.2, 8);
camera.lookAt(0, 4.5, -1);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.6;
glWrap.appendChild(renderer.domElement);
window._dssBindScene('gl-wrap', scene, renderer, camera);

// Store base camera position for subtle breathing sway
var cameraBase = { x: 6.5, y: 2.2, z: 8 };

// ============================================================
// MATERIALS
// ============================================================
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x3a2a22, roughness: 0.9 });
var creamWall = new THREE.MeshStandardMaterial({ color: 0xc8bfaa, roughness: 0.85 });
var greyStone = new THREE.MeshStandardMaterial({ color: 0x6a6560, roughness: 0.85 });
var sootBrick = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x6b3a2a, roughness: 0.85 });
var shopFront = new THREE.MeshStandardMaterial({ color: 0x1a2a1a, roughness: 0.7 });
var darkWood = new THREE.MeshStandardMaterial({ color: 0x1a1008, roughness: 0.7 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.6, metalness: 0.1 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x151515, roughness: 0.55, metalness: 0.15 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a8070, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.2, metalness: 0.3 });
var warmGlass = new THREE.MeshStandardMaterial({ color: 0x2a1505, roughness: 0.3, emissive: 0xe87818, emissiveIntensity: 0.14 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.4 });
var kerbMat = new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.5, metalness: 0.15 });
var paveMat = new THREE.MeshStandardMaterial({ color: 0x4a4a4a, roughness: 0.65, metalness: 0.1 });
var drainMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.7, metalness: 0.4 });

// ============================================================
// HELPER: canvas texture
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
  var c = document.createElement('canvas');
  c.width = w; c.height = h;
  var cx = c.getContext('2d');
  drawFunc(cx, w, h);
  var tex = new THREE.CanvasTexture(c);
  tex.minFilter = THREE.LinearFilter;
  return tex;
}

function makeSign(text, opts) {
  var o = opts || {};
  var w = o.w || 512; var h = o.h || 128;
  var bg = o.bg || '#1a1a1a'; var fg = o.fg || '#c8c0a0';
  var fs = o.fs || 36; var ff = o.ff || 'bold Georgia';
  var tex = makeCanvasTexture(w, h, function(cx, cw, ch) {
    cx.fillStyle = bg; cx.fillRect(0, 0, cw, ch);
    if (o.border) {
      cx.strokeStyle = fg; cx.lineWidth = 3;
      cx.strokeRect(4, 4, cw - 8, ch - 8);
    }
    cx.fillStyle = fg; cx.font = fs + 'px ' + ff;
    cx.textAlign = 'center'; cx.textBaseline = 'middle';
    cx.fillText(text, cw/2, ch/2);
  });
  return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.5 });
}

function placeMesh(geo, mat, x, y, z) {
  var m = new THREE.Mesh(geo, mat);
  m.position.set(x, y, z);
  scene.add(m);
  return m;
}

function placeMeshG(group, geo, mat, x, y, z) {
  var m = new THREE.Mesh(geo, mat);
  m.position.set(x, y, z);
  group.add(m);
  return m;
}

// ============================================================
