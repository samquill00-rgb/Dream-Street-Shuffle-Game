var rightFascia = makeCanvasTexture(640, 80, function(cx, w, h) {
  cx.fillStyle = '#3a2a28';
  cx.fillRect(0, 0, w, h);
  cx.fillStyle = '#e8d8b0';
  cx.font = 'bold 46px Georgia, serif';
  cx.textAlign = 'center';
  cx.textBaseline = 'middle';
