scene.add(joistGroup);

var jz;
for (jz = -halfL + 1; jz <= halfL - 1; jz += 1.8) {
box(joistGroup, roomWidth - 0.2, 0.12, 0.08, woodBeam, 0, roomHeight - 0.06, jz);
}
box(joistGroup, 0.15, 0.2, roomLength - 0.4, woodBeam, -1.5, roomHeight - 0.1, 0);
box(joistGroup, 0.15, 0.2, roomLength - 0.4, woodBeam, 1.5, roomHeight - 0.1, 0);

// ============================================================
// SUPPORT POSTS
// ============================================================
var postGroup = new THREE.Group();
scene.add(postGroup);

box(postGroup, 0.12, roomHeight, 0.12, woodBeam, -1.2, roomHeight / 2, 2);
box(postGroup, 0.12, roomHeight, 0.12, woodBeam, 1.2, roomHeight / 2, -2);
box(postGroup, 0.12, roomHeight, 0.12, darkWood, -1.2, roomHeight / 2, -5);

// ============================================================
// PIPES
