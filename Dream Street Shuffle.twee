// Romilly St pavement — opposite side (south, at z≈8-9)
var romPaveS = new THREE.Mesh(new THREE.BoxGeometry(25, 0.15, 2.5), paveMat);
romPaveS.position.set(-10, 0.075, 7.75);
romPaveS.receiveShadow = true;
scene.add(romPaveS);
var romKerbS = new THREE.Mesh(new THREE.BoxGeometry(25, 0.18, 0.15), kerbMat);
romKerbS.position.set(-10, 0.09, 6.5);
scene.add(romKerbS);

// Corner pavement (where the two streets meet, in front of the pub)
var cornerPave = new THREE.Mesh(new THREE.BoxGeometry(4, 0.15, 4), paveMat);
cornerPave.position.set(1.5, 0.075, 1.5);
cornerPave.receiveShadow = true;
scene.add(cornerPave);

// ============================================================
// STREETLAMPS
// ============================================================
var lampLights = [];
function createLamp(x, z) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
placeMeshG(g, new THREE.CylinderGeometry(0.05, 0.07, 5, 6), postMat, 0, 2.5, 0);
placeMeshG(g, new THREE.BoxGeometry(0.3, 0.4, 0.3), postMat, 0.3, 5, 0);
placeMeshG(g, new THREE.BoxGeometry(0.6, 0.06, 0.06), postMat, 0.15, 5, 0);
var light = new THREE.PointLight(0xffdda0, 0.6, 15);
light.position.set(0.3, 4.8, 0);
light.castShadow = true;
g.add(light);
lampLights.push(light);
// Glow sprite
var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(255, 220, 150, 0.8)');
grad.addColorStop(0.3, 'rgba(255, 200, 100, 0.3)');
grad.addColorStop(1, 'rgba(255, 180, 80, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.5 }));
glowSprite.position.set(0.3, 5, 0);
glowSprite.scale.set(3, 3, 1);
g.add(glowSprite);
g.position.set(x, 0, z);
scene.add(g);
}

function placeMeshG(group, geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
group.add(m);
}

createLamp(1, 1);
createLamp(1, -8);
createLamp(7, 4);

// ============================================================
// LIGHTING
// ============================================================
scene.add(new THREE.AmbientLight(0x1a1a2a, 0.3));

var moonLight = new THREE.DirectionalLight(0x4455aa, 0.12);
moonLight.position.set(10, 20, -5);
moonLight.castShadow = true;
scene.add(moonLight);

// Warm interior glow from pub windows
var pubGlow1 = new THREE.PointLight(0xc89030, 0.5, 10);
pubGlow1.position.set(-1, 2, -2);
scene.add(pubGlow1);
var pubGlow2 = new THREE.PointLight(0xc89030, 0.4, 8);
pubGlow2.position.set(-5, 2, -1);
scene.add(pubGlow2);

// ============================================================
// FOG VOLUMES — thick Soho pea-souper atmosphere
// ============================================================

// Shared fog textures (create once, reuse)
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(180, 170, 155, 0.25)');
grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.12)');
grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(200, 160, 100, 0.12)');
grad.addColorStop(0.5, 'rgba(180, 140, 80, 0.05)');
grad.addColorStop(1, 'rgba(150, 120, 60, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// LAYER 1: Thick ground-hugging fog banks (the main pea-souper)
for (var i = 0; i < 50; i++) {
var fogMat = new THREE.SpriteMaterial({
map: thickFogTex, transparent: true,
opacity: 0.25 + Math.random() * 0.2
});
var fogSprite = new THREE.Sprite(fogMat);
fogSprite.position.set(
Math.random() * 50 - 20,
0.3 + Math.random() * 2,
Math.random() * 50 - 20
);
var s = 5 + Math.random() * 12;
fogSprite.scale.set(s, s * 0.35, 1);
scene.add(fogSprite);
fogSprites.push({
sprite: fogSprite,
baseX: fogSprite.position.x,
drift: 0.002 + Math.random() * 0.006,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.004,
swayAmt: 0.4 + Math.random() * 1.0
});
}

// LAYER 2: Mid-height fog (swirling around building level)
for (var i = 0; i < 30; i++) {
var midFogMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.15 + Math.random() * 0.15
});
var midFog = new THREE.Sprite(midFogMat);
midFog.position.set(
Math.random() * 40 - 15,
2 + Math.random() * 6,
Math.random() * 40 - 15
);
var ms = 6 + Math.random() * 14;
midFog.scale.set(ms, ms * 0.3, 1);
scene.add(midFog);
fogSprites.push({
sprite: midFog,
baseX: midFog.position.x,
drift: 0.004 + Math.random() * 0.008,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.006,
swayAmt: 0.5 + Math.random() * 1.5
});
}

// LAYER 3: Warm-tinted fog near the pub (light spilling into mist)
for (var i = 0; i < 15; i++) {
var warmFogMat = new THREE.SpriteMaterial({
map: warmFogTex, transparent: true,
opacity: 0.2 + Math.random() * 0.15
});
var warmFog = new THREE.Sprite(warmFogMat);
warmFog.position.set(
Math.random() * 10 - 3,
0.5 + Math.random() * 3,
Math.random() * 10 - 3
);
var ws = 3 + Math.random() * 6;
warmFog.scale.set(ws, ws * 0.4, 1);
scene.add(warmFog);
fogSprites.push({
sprite: warmFog,
baseX: warmFog.position.x,
drift: 0.003 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.005,
swayAmt: 0.3 + Math.random() * 0.6
});
}

// LAYER 4: High wisps drifting past the rooftops
for (var i = 0; i < 20; i++) {
var wispMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.1 + Math.random() * 0.1
});
var wisp = new THREE.Sprite(wispMat);
wisp.position.set(
Math.random() * 40 - 15,
6 + Math.random() * 8,
Math.random() * 40 - 15
);
wisp.scale.set(8 + Math.random() * 15, 3 + Math.random() * 4, 1);
scene.add(wisp);
fogSprites.push({
sprite: wisp,
baseX: wisp.position.x,
drift: 0.006 + Math.random() * 0.012,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.003 + Math.random() * 0.008,
swayAmt: 0.8 + Math.random() * 2.0
});
}

// ============================================================
// PUDDLES (post-rain, wet ground)
// ============================================================
for (var i = 0; i < 8; i++) {
var puddleMat = new THREE.MeshStandardMaterial({
color: 0x111118, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.3
});
var puddle = new THREE.Mesh(new THREE.CircleGeometry(0.4 + Math.random() * 0.8, 16), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(
Math.random() * 16 - 4,
0.02,
Math.random() * 16 - 4
);
scene.add(puddle);
}

// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();

function chAnimate() {
chAnimId = requestAnimationFrame(chAnimate);
var t = clock.getElapsedTime();

// Very subtle light breathing (barely perceptible)
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;
doorLight.intensity = 0.8 * breath;
pubGlow1.intensity = 0.5 * breath;
pubGlow2.intensity = 0.4 * breath;

for (var i = 0; i < lampLights.length; i++) {
lampLights[i].intensity = 0.6 * breath;
}

// Silhouettes sway gently
for (var i = 0; i < silhouettes.length; i++) {
var s = silhouettes[i];
s.swayPhase += s.swaySpeed * 0.008;
var swayOffset = Math.sin(s.swayPhase) * s.swayAmt * 0.5;
s.mesh.position.y = 1.8 + Math.sin(s.swayPhase * 0.7) * 0.005;
if (s.mesh.rotation.y > 1) {
s.mesh.position.z = s.baseZ + swayOffset;
} else {
s.mesh.position.x = s.baseX + swayOffset;
}
}

// Film grain
chGrainFrame++;
if (chGrainFrame % 3 === 0) {
var imgData = chGrainCtx.createImageData(256, 256);
var d = imgData.data;
for (var i = 0; i < d.length; i += 4) {
var v = Math.random() * 255;
d[i] = d[i+1] = d[i+2] = v;
d[i+3] = 255;
}
chGrainCtx.putImageData(imgData, 0, 0);
}

renderer.render(scene, camera);
}

chAnimate();

// ENTER BUTTON
var chBtn = document.createElement('button');
chBtn.textContent = 'ENTER THE COACH AND HORSES';
chBtn.style.cssText = [
'position:absolute','bottom:60px','left:50%','transform:translateX(-50%)',
'font:13px \'Courier New\',monospace','color:rgba(200,170,100,0.85)',
'letter-spacing:4px','cursor:pointer','padding:12px 28px',
'border:1px solid rgba(200,170,100,0.3)','background:rgba(0,0,0,0.4)',
'z-index:9003','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
chWrap.appendChild(chBtn);
setTimeout(function() { chBtn.style.opacity = '1'; }, 1500);

chBtn.addEventListener('mouseenter', function() {
this.style.color = 'rgba(230,200,120,0.95)';
this.style.borderColor = 'rgba(200,170,100,0.6)';
});
chBtn.addEventListener('mouseleave', function() {
this.style.color = 'rgba(200,170,100,0.85)';
this.style.borderColor = 'rgba(200,170,100,0.3)';
});

chBtn.addEventListener('click', function() {
chWrap.style.transition = 'opacity 1.2s ease';
chWrap.style.opacity = '0';
setTimeout(function() {
cancelAnimationFrame(chAnimId);
chWrap.remove();
var TARGET = 'Coach and Horses lock';
var link = document.querySelector('tw-link[passage-name="' + TARGET + '"]');
if (!link) {
var allLinks = document.querySelectorAll('tw-passage tw-link');
for (var i = 0; i < allLinks.length; i++) {
if (allLinks[i].textContent.trim() === '\u00B7') { link = allLinks[i]; break; }
}
}
if (link) {
link.click();
} else {
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', TARGET);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.click();
storyEl.removeChild(injected);
}
}, 1200);
});
}

// Watch for ch-container
setInterval(function() {
var container = document.getElementById('ch-container');
if (container && !chActive) {
initCoachHorses();
} else if (!container) {
chActive = false;
}
}, 300);
})();

// ====== PILLARS OF HERCULES SCENE — INLINE ======
(function() {
var phActive = false;
var phAnimId = null;

function initPillars() {
if (phActive) return;
phActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildPHScene(); };
document.head.appendChild(s);
} else {
buildPHScene();
}
}

function buildPHScene() {
// Create full-screen overlay wrapper
var phWrap = document.createElement('div');
phWrap.id = 'ph-wrap';
phWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#0a0a12;overflow:hidden;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0a12);
scene.fog = new THREE.Fog(0x0a0a12, 5, 40);

var camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT EXPLANATION
// ============================================================
// The Pillars of Hercules faces the camera straight on.
// Facade runs along X (roughly x=-4 to x=4), facing +Z.
// Camera is at +Z looking back at the building.
// Alleyway is on the LEFT side (negative X).
// Neighbouring buildings: cream/yellow to left of alley, pink/brown to right.
// Building body extends into -Z (behind facade).

camera.position.set(0, 3.5, 16);
camera.lookAt(0, 5, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.55;
phWrap.appendChild(renderer.domElement);

window.addEventListener('resize', function() {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================
var darkTimber = new THREE.MeshStandardMaterial({ color: 0x2a2018, roughness: 0.92 });
var whitePlaster = new THREE.MeshStandardMaterial({ color: 0xc8b89a, roughness: 0.95 });
var mahogany = new THREE.MeshStandardMaterial({ color: 0x3d1e14, roughness: 0.82 });
var mahoganyDark = new THREE.MeshStandardMaterial({ color: 0x2e1510, roughness: 0.88 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x2e2e2c, roughness: 0.7, metalness: 0.15 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x141412, roughness: 0.55, metalness: 0.2 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a7e60, roughness: 0.88 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.3, metalness: 0.2 });
var goldMat = new THREE.MeshStandardMaterial({ color: 0xa88830, roughness: 0.5, metalness: 0.3 });

// ============================================================
// HELPER: canvas texture
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
  var c = document.createElement('canvas');
  c.width = w; c.height = h;
  var cx = c.getContext('2d');
  drawFunc(cx, w, h);
  var tex = new THREE.CanvasTexture(c);
  tex.minFilter = THREE.LinearFilter;
  return tex;
}

function placeMesh(group, geo, mat, x, y, z) {
  var m = new THREE.Mesh(geo, mat);
  m.position.set(x, y, z);
  group.add(m);
  return m;
}

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

// Greek Street road (runs along Z in front of the pub)
var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 10);
road.receiveShadow = true;
scene.add(road);

// Wet road surface — just stopped raining, everything glistening
var wetMat = new THREE.MeshStandardMaterial({
  color: 0x1a1a1a, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.3
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(20, 20), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(0, 0.01, 8);
scene.add(wetRoad);

// Wet pavement sheen (closer to buildings — rain-slicked flagstones)
