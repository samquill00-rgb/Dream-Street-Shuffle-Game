  // Ambient bed — single-slot state machine. Only one bed plays at a time.
  var _ambient = null;
  function _stopAmbient(fadeSec) {
    var ac = getCtx(); if (!ac || !_ambient) return;
    var prev = _ambient; _ambient = null;
    if (prev.timer) { try { clearTimeout(prev.timer); } catch(e) {} }
    if (prev.dripTimer) { try { clearTimeout(prev.dripTimer); } catch(e) {} }
    var fade = (typeof fadeSec === 'number') ? Math.max(0, fadeSec) : 0.5;
    try {
      prev.g.gain.cancelScheduledValues(ac.currentTime);
      if (fade <= 0.005) {
        prev.g.gain.setValueAtTime(0, ac.currentTime);
        prev.src.stop(ac.currentTime + 0.01);
      } else {
        prev.g.gain.linearRampToValueAtTime(0, ac.currentTime + fade);
