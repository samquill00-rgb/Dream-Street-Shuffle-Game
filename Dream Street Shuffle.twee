finial.position.set(0, 6.32, 0);
heroLamp.add(finial);
var finialSpike = new THREE.Mesh(new THREE.CylinderGeometry(0.01, 0.03, 0.12, 4), ironMat);
finialSpike.position.set(0, 6.42, 0);
