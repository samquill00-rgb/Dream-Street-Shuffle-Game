<script>(function(){/* Continue the prefetch chain started on The Fetch — by now Three.js is already loaded by the CP scene init below, so this is mainly for the iframe HTML, which is the dominant network cost on Dawn Approach. Idempotent: HTTP cache dedups and the link element is id-guarded. */try{fetch('oxford-street-from-centre-point-3d-static.html',{cache:'force-cache'});}catch(e){}if(!document.getElementById('dss-three-prefetch')){var l=document.createElement('link');l.id='dss-three-prefetch';l.rel='preload';l.as='script';l.href='https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';document.head.appendChild(l);}})();</script>\
(set: $visitedCentrePoint to true)\
(if: $sawAstralReveal is false)[(set: $sawAstralReveal to true)<script>
/* First arrival at Centre Point — the city you walked tonight dissolves
   into stars. Fires once. Deferred ~2.4s so the 3D scene paints in first;
   then the astral graph rises over it, holds, fades. The dot link below
   stays clickable underneath (z-index 9998 < pointer-events:none anyway).
   Outer setTimeout(0) defers the _passageGen snapshot until after the
   MutationObserver has incremented it for THIS passage; same race fix as
   showDrinkPopupSafe and the Ripley's Wheel trigger. */
(function(){
  setTimeout(function(){
    var pgGen = window._passageGen;
    setTimeout(function(){
      if (window._passageGen !== pgGen) return;
      if (window.dssAstralReveal) window.dssAstralReveal();
    }, 2400);
  }, 0);
})();
</script>]
(if: ($alba contains $alba1) and ($alba contains $alba2) and ($alba contains $alba3))[<div id="cp-container"></div>[[·|Alba Complete]]](else:)[<div id="cp-container"></div>[[·|Alba Incomplete]]]

:: PP Pong [pong] {"position":"1300,1550","size":"100,100"}
<span id="pp-data-opponent" style="display:none;">(print: $opponent)</span>
<span id="pp-data-sobriety" style="display:none;">(print: $sobriety)</span>
<div class="pp-arena">
<div class="pp-score" id="score-display"></div>
<div class="pp-score-sub" id="score-sub"></div>
<canvas id="pong-canvas" width="540" height="340"></canvas>
<div id="pp-narrative"></div>
<div id="pp-game-end"></div>
<div id="pp-instructions" style="text-align:center;color:#6a5030;font-size:0.8em;margin-top:0.8em;letter-spacing:0.1em;">Move mouse to control paddle</div>
</div>
<span id="pp-go-win" style="display:none;">[[Victory|PP Victory]]</span>
<span id="pp-go-lose" style="display:none;">[[Defeat|PP Defeat]]</span>
<script>
(function(){var __boot=function(){
var opponent = (document.getElementById('pp-data-opponent') || {}).textContent || 'Opponent';
var sobriety = parseInt((document.getElementById('pp-data-sobriety') || {}).textContent) || 55;
if (window.dssAudio && window.dssAudio.stopBed) { try { window.dssAudio.stopBed('minigame-retro'); } catch(e) {} }
var _pongEl = null;
var _pongMuteWatcher = null;
function _pongMuted() { return !!(window.dssAudio && window.dssAudio.isMuted && window.dssAudio.isMuted()); }
if (window._pongMiniDataUri) {
  _pongEl = new Audio(window._pongMiniDataUri);
  _pongEl.volume = 0.28; _pongEl.loop = true;
  _pongEl.muted = _pongMuted();
  _pongEl.play().catch(function(){});
  _pongMuteWatcher = setInterval(function() {
    if (!_pongEl) { clearInterval(_pongMuteWatcher); _pongMuteWatcher = null; return; }
    var m = _pongMuted();
    if (_pongEl.muted !== m) _pongEl.muted = m;
  }, 250);
}
var W = 540, H = 340;
var canvas = document.getElementById('pong-canvas');
var ctx = canvas.getContext('2d');
var playerScore = 0, oppScore = 0, rallyCount = 0; // rallyCount escalates ball speed each serve
var gameOver = false, paused = false, serving = true, serveTime = Date.now();
var ball = {x:W/2,y:H/2,dx:0,dy:0,r:5,base:4.4};
var pPad = {x:12,y:H/2-35,w:8,h:70};
var oPad = {x:W-20,y:H/2-35,w:8,h:70};
var mouseY = H/2, actualY = pPad.y;
var aiTarget = H/2, aiLast = 0;
// Countdown phase before the first serve — gives the player a beat to settle
// the paddle, and gives the music a moment to be heard before the rally starts.
var phase = 'countdown', countdownStart = Date.now();
var COUNTDOWN_DUR = 1800; // 600ms × three beats: 3, 2, 1, then play
var narr = {
'Jack Curtis':{
win:["Jack Curtis nods. A veteran's approval.","Your shot surprises you both.","Even the poet blinks.","A clean winner. Jack Curtis says nothing."],
lose:["Jack Curtis places it where you aren't. He's done this before.","The ball passes you like a rumour.","Jack Curtis smiles, unhurried. A poet's patience.","He reads you like a manuscript."]
},
'Percy Ritson':{
win:["Percy Ritson overcommits. Wild swing, clean miss.","His brilliance undoes him.","Too much angle. Percy Ritson curses.","Speed without direction is just noise."],
lose:["Percy Ritson smashes it. You never saw it.","A wild shot that somehow finds the corner.","Percy Ritson whoops. The cellar echoes.","He plays like a man with nothing to lose."]
}
};
function setupInput(){
function h(cy){var r=canvas.getBoundingClientRect();mouseY=(cy-r.top)*(H/r.height);}
canvas.addEventListener('mousemove',function(e){h(e.clientY);});
canvas.addEventListener('touchmove',function(e){e.preventDefault();h(e.touches[0].clientY);},{passive:false});
document.addEventListener('mousemove',function(e){var r=canvas.getBoundingClientRect();if(e.clientY>=r.top&&e.clientY<=r.bottom)h(e.clientY);});
}
function serve(){
ball.x=W/2;ball.y=H/2;
/* Cap rally-driven serve-speed escalation so longer matches don't outrun the player. */
var sp=ball.base+Math.min(rallyCount,6)*0.25;var a=(Math.random()-0.5)*0.8;var d=(rallyCount%2===0)?-1:1;
ball.dx=d*sp*Math.cos(a);ball.dy=sp*Math.sin(a);
serving=true;serveTime=Date.now();rallyCount++;
}
function callScore(){
/* Table-tennis announcement: love for 0, deuce at 2-all+, advantage/match point as appropriate. */
if(playerScore===0&&oppScore===0)return'love-all';
if(playerScore>=2&&oppScore>=2){
  if(playerScore===oppScore)return'deuce';
  if(playerScore>oppScore)return'advantage you \u2014 match point';
  return'advantage '+opponent+' \u2014 match point';
}
if(playerScore>=2&&playerScore>oppScore)return'match point \u2014 you';
if(oppScore>=2&&oppScore>playerScore)return'match point \u2014 '+opponent;
var n=function(x){return x===0?'love':String(x);};
return n(playerScore)+'\u2013'+n(oppScore);
}
function updateScore(){
var el=document.getElementById('score-display');
if(el){
  el.innerHTML =
    '<div class="pp-scoreboard">'+
      '<div class="pp-side pp-side-you">'+
        '<div class="pp-name">YOU</div>'+
        '<div class="pp-num pp-num-you">'+playerScore+'</div>'+
      '</div>'+
      '<div class="pp-middle">'+
        '<div class="pp-vs">\u00b7</div>'+
      '</div>'+
      '<div class="pp-side pp-side-opp">'+
        '<div class="pp-name">'+opponent.toUpperCase()+'</div>'+
        '<div class="pp-num pp-num-opp">'+oppScore+'</div>'+
      '</div>'+
    '</div>';
}
var sub=document.getElementById('score-sub');
if(sub)sub.textContent=callScore();
}
function showNarrative(pw){
var lines=pw?narr[opponent].win:narr[opponent].lose;
var line=lines[Math.floor(Math.random()*lines.length)];
var el=document.getElementById('pp-narrative');
if(!el)return;
el.style.cssText='text-align:center;color:#b8a070;font-size:0.9em;font-style:italic;margin-top:1em;min-height:1.5em;';
el.style.opacity='1';el.textContent=line;
if(sobriety<30&&Math.random()<0.4)el.textContent=line+' Your vision swims.';
}
function updatePlayer(){
var ty=mouseY-pPad.h/2;
if(sobriety<25){ty+=(Math.random()-0.5)*40;if(Math.random()<0.15)return;actualY+=(ty-actualY)*0.06;}
else if(sobriety<50){ty+=(Math.random()-0.5)*15;actualY+=(ty-actualY)*0.12;}
else{actualY+=(ty-actualY)*0.25;}
pPad.y=Math.max(0,Math.min(H-pPad.h,actualY));
}
/* Rubber-band: positive when AI is BEHIND (plays better), negative when
   AHEAD (plays worse). The negative side stays uncapped at -1.5 so a 2-0
   AI lead really feels easy; the positive (comeback) side is held to +0.8
   so the AI can press, but isn't surgical when you're on match point —
   the "final point feels unbeatable" complaint was the AI catching up at
   the full +1.5 catchup multiplier. Once both players hit 2 (deuce), bias
   goes to zero and sudden-death is honest. */
function aiBias(){
/* Tightened range so the AI's swings between "easy" and "hard" feel
   like the same opponent throughout: -1.0 when AI is leading, +0.6 when
   trailing. Stops the match from feeling like two different games stitched
   together. Bias zeroes at 2-2 for honest sudden-death (now matches always
   resolve within 5 points, see pointEnd). */
if (playerScore >= 2 && oppScore >= 2) return 0;
var lead = oppScore - playerScore;
var raw = -lead * 0.8;
return Math.max(-1.0, Math.min(0.6, raw));
}
function updateAI(){
var now=Date.now();
var bias=aiBias();
/* speedMul rides between ~0.55 (AI ahead) and ~1.45 (AI behind).
   accMul shrinks reaction time and prediction noise when AI is behind. */
var speedMul = 1 + bias * 0.45;
var accMul   = Math.max(0.4, 1 - bias * 0.5);     // <1 = sharper when AI behind
var noiseMul = Math.max(0.35, 1 - bias * 0.55);   // less noise when AI behind
if(opponent==='Jack Curtis'){
/* Jack — patient veteran. Reacts ~75ms, predicts cleanly with light noise. */
var rt = 75 * accMul;
if(now-aiLast<rt)return;aiLast=now;
var py=ball.y;
if(ball.dx>0){var f=(oPad.x-ball.x)/ball.dx;py=ball.y+ball.dy*f;while(py<0||py>H){if(py<0)py=-py;if(py>H)py=2*H-py;}}
py+=(Math.random()-0.5)*12*noiseMul;aiTarget=py;
var sp=4.4*speedMul,c=oPad.y+oPad.h/2,d=aiTarget-c;
if(Math.abs(d)>4)oPad.y+=Math.sign(d)*Math.min(sp,Math.abs(d));
}else{
/* Percy — wild but quicker now; the accurate-prediction roll fires more often. */
var rt = 35 * accMul;
if(now-aiLast<rt)return;aiLast=now;
var py=ball.y+ball.dy*8;py+=(Math.random()-0.5)*32*noiseMul;
/* Accurate-prediction roll: 30% baseline, rises when AI is behind. */
var predChance = Math.max(0.05, Math.min(0.85, 0.30 + bias * 0.35));
if(Math.random()<predChance){var f=ball.dx>0?(oPad.x-ball.x)/ball.dx:30;py=ball.y+ball.dy*f;while(py<0||py>H){if(py<0)py=-py;if(py>H)py=2*H-py;}}
aiTarget=py;
var sp=6.2*speedMul,c=oPad.y+oPad.h/2,d=aiTarget-c;
if(Math.abs(d)>3)oPad.y+=Math.sign(d)*Math.min(sp,Math.abs(d));
}
oPad.y=Math.max(0,Math.min(H-oPad.h,oPad.y));
}
function updateBall(){
if(serving){if(Date.now()-serveTime<800)return;serving=false;}
ball.x+=ball.dx;ball.y+=ball.dy;
if(ball.y-ball.r<0){ball.y=ball.r;ball.dy=Math.abs(ball.dy);}
if(ball.y+ball.r>H){ball.y=H-ball.r;ball.dy=-Math.abs(ball.dy);}
if(ball.dx<0&&ball.x-ball.r<=pPad.x+pPad.w&&ball.x+ball.r>=pPad.x&&ball.y>=pPad.y&&ball.y<=pPad.y+pPad.h){
var hp=(ball.y-pPad.y)/pPad.h;var a=(hp-0.5)*Math.PI*0.6;
var sp=Math.min(Math.sqrt(ball.dx*ball.dx+ball.dy*ball.dy)*1.05,7);
ball.dx=sp*Math.cos(a);ball.dy=sp*Math.sin(a);ball.x=pPad.x+pPad.w+ball.r;
}
if(ball.dx>0&&ball.x+ball.r>=oPad.x&&ball.x-ball.r<=oPad.x+oPad.w&&ball.y>=oPad.y&&ball.y<=oPad.y+oPad.h){
var hp=(ball.y-oPad.y)/oPad.h;var am=opponent==='Percy Ritson'?0.8:0.6;
var a=Math.PI-(hp-0.5)*Math.PI*am;
var sp=Math.min(Math.sqrt(ball.dx*ball.dx+ball.dy*ball.dy)*1.05,7);
ball.dx=sp*Math.cos(a);ball.dy=sp*Math.sin(a);ball.x=oPad.x-ball.r;
}
if(ball.x<-20){oppScore++;pointEnd(false);}
else if(ball.x>W+20){playerScore++;pointEnd(true);}
}
function pointEnd(pw){
updateScore();paused=true;
/* First to 3 wins — flat, no deuce. Previously a "win by 1" rule could
   loop 2-2 → 3-3 → 4-3… on the rubber-band, which made the match feel
   too long or inconsistently hard. Now every match ends in 3–5 points,
   always decisive. The AI bias still rubber-bands within a tight range
   so the difficulty curve is consistent across opponents. */
if(playerScore>=3||oppScore>=3){endGame(playerScore>=3);return;}
setTimeout(function(){paused=false;serve();},800);
}
function endGame(pw){
gameOver=true;
if (_pongMuteWatcher) { clearInterval(_pongMuteWatcher); _pongMuteWatcher=null; }
if (_pongEl) { _pongEl.pause(); _pongEl.src=''; _pongEl=null; }
var el=document.getElementById('pp-game-end');
var inst=document.getElementById('pp-instructions');if(inst)inst.style.display='none';
var sub=document.getElementById('score-sub');if(sub)sub.textContent='';
if(el){
el.style.cssText='text-align:center;font-family:Courier New,monospace;font-size:1.4em;margin-top:0.5em;min-height:1.5em;';
if(pw)el.innerHTML='<span style="color:#d4a574;text-shadow:0 0 15px rgba(212,165,116,0.7),0 0 30px rgba(180,130,70,0.4);">\u2605 VICTORY \u2605</span>';
else el.innerHTML='<span style="color:#ffaaaa;text-shadow:0 0 10px rgba(255,170,170,0.4);">DEFEAT</span>';
}
setTimeout(function(){
var sel=pw?'#pp-go-win tw-link':'#pp-go-lose tw-link';
var link=document.querySelector(sel);if(link)link.click();
},2000);
}
function rRect(x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();}
function draw(){
// Table felt — deep tournament green
ctx.fillStyle='#0b2212';ctx.fillRect(0,0,W,H);
// Subtle inner frame line
ctx.strokeStyle='rgba(255,255,255,0.05)';ctx.lineWidth=1;ctx.setLineDash([]);ctx.strokeRect(8,8,W-16,H-16);
// Service mid-line (horizontal)
ctx.strokeStyle='rgba(255,255,255,0.08)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(8,H/2);ctx.lineTo(W-8,H/2);ctx.stroke();
// Net — segmented white rectangles
var nw=4,nh=7,ng=4,nx=Math.floor(W/2)-Math.floor(nw/2);
ctx.fillStyle='rgba(248,248,235,0.72)';
for(var ni=4;ni<H-4;ni+=nh+ng){ctx.fillRect(nx,ni,nw,Math.min(nh,H-ni-4));}
// Net post caps (top & bottom)
ctx.fillStyle='rgba(248,248,235,0.9)';ctx.fillRect(nx-1,0,nw+2,5);ctx.fillRect(nx-1,H-5,nw+2,5);
// Edge vignette — top/bottom
var ev=ctx.createLinearGradient(0,0,0,H);ev.addColorStop(0,'rgba(0,0,0,0.5)');ev.addColorStop(0.14,'rgba(0,0,0,0)');ev.addColorStop(0.86,'rgba(0,0,0,0)');ev.addColorStop(1,'rgba(0,0,0,0.5)');ctx.fillStyle=ev;ctx.fillRect(0,0,W,H);
// Edge vignette — sides
var eh=ctx.createLinearGradient(0,0,W,0);eh.addColorStop(0,'rgba(0,0,0,0.38)');eh.addColorStop(0.12,'rgba(0,0,0,0)');eh.addColorStop(0.88,'rgba(0,0,0,0)');eh.addColorStop(1,'rgba(0,0,0,0.38)');ctx.fillStyle=eh;ctx.fillRect(0,0,W,H);
// Player paddle — white/cool glow
ctx.shadowColor='rgba(190,210,255,0.85)';ctx.shadowBlur=20;ctx.fillStyle='#dce8f4';rRect(pPad.x,pPad.y,pPad.w,pPad.h,3);ctx.fill();
// Opponent paddle — red with amber rim glow
ctx.shadowColor='rgba(220,70,30,0.75)';ctx.shadowBlur=18;ctx.fillStyle='#bf2c14';rRect(oPad.x,oPad.y,oPad.w,oPad.h,3);ctx.fill();
// Ball — white with strong glow
ctx.shadowColor='rgba(255,255,220,1.0)';ctx.shadowBlur=22;ctx.fillStyle='#f2ede0';ctx.beginPath();ctx.arc(ball.x,ball.y,ball.r,0,Math.PI*2);ctx.fill();
ctx.shadowBlur=0;
// Drunk radial vignette
if(sobriety<30){var dg=ctx.createRadialGradient(W/2,H/2,H*0.3,W/2,H/2,H*0.7);dg.addColorStop(0,'rgba(0,0,0,0)');dg.addColorStop(1,'rgba(0,0,0,0.5)');ctx.fillStyle=dg;ctx.fillRect(0,0,W,H);}
if(serving){ctx.fillStyle='rgba(255,248,200,0.55)';ctx.font='13px Courier New';ctx.textAlign='center';ctx.fillText('\u00b7  \u00b7  \u00b7',W/2,H/2+40);}
}
function drawCountdown(){
var elapsed = Date.now() - countdownStart;
ctx.fillStyle = 'rgba(4,8,4,0.62)';
ctx.fillRect(0,0,W,H);
ctx.textAlign = 'center';
ctx.font = '12px Courier New, monospace';
ctx.fillStyle = 'rgba(255,248,200,0.7)';
ctx.fillText('GET READY', W/2, H/2 - 80);
ctx.shadowColor = 'rgba(255,248,200,0.7)';
ctx.shadowBlur = 22;
ctx.font = 'bold 88px Courier New, monospace';
if (elapsed < 600)        { ctx.fillStyle = '#dce8f4'; ctx.fillText('3', W/2, H/2 + 30); }
else if (elapsed < 1200)  { ctx.fillStyle = '#dce8f4'; ctx.fillText('2', W/2, H/2 + 30); }
else if (elapsed < 1800)  { ctx.fillStyle = '#bf2c14'; ctx.fillText('1', W/2, H/2 + 30); }
ctx.shadowBlur = 0;
}
function loop(){
if (gameOver) { draw(); return; }
if (phase === 'countdown') {
  updatePlayer();             // let the player position their paddle while we count down
  draw();
  drawCountdown();
  if (Date.now() - countdownStart >= COUNTDOWN_DUR) { phase = 'play'; serve(); }
  requestAnimationFrame(loop);
} else {
  if (!paused) { updatePlayer(); updateAI(); updateBall(); }
  draw();
  requestAnimationFrame(loop);
}
}
setupInput();updateScore();loop();
};(window.dssShowMinigameRules||function(o){o.onPlay()})({key:'pong',title:'PING PONG',lines:["Move your mouse to slide the paddle up and down.","First to five points takes the match.","Don't let the ball get past you."],onPlay:__boot});})();
</script>

