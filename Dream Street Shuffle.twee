grafC.width = 128; grafC.height = 64;
var gctx = grafC.getContext('2d');
gctx.fillStyle = 'rgba(40,32,24,0)';
gctx.fillRect(0, 0, 128, 64);
gctx.fillStyle = 'rgba(120,100,80,0.25)';
gctx.font = 'italic 18px Arial'; gctx.textAlign = 'left';
gctx.fillText('73', 15, 35);
var grafTex = new THREE.CanvasTexture(grafC);
var graf = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.4),
  new THREE.MeshBasicMaterial({ map: grafTex, transparent: true }));
graf.position.set(alleyX - alleyWidth/2 + 0.01, 1.2, -0.5);
graf.rotation.y = Math.PI / 2;
pub.add(graf);

// Bollard at the alley entrance
