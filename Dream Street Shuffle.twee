// Timber frame
var w1f = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.5, 0.04), darkTimber);
w1f.position.set(w1x, 5.5, 0.28);
pub.add(w1f);
// Glazing bars (cross pattern — more detailed leaded glass)
