ctx.quadraticCurveTo(cx + 5, cy + 36, cx + 13, cy + 37); ctx.stroke();
// Thin dark crack - no teeth showing
ctx.strokeStyle = 'rgba(40,20,15,0.6)'; ctx.lineWidth = 0.8;
