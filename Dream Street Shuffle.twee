// ============================================================
// RUG
// ============================================================
var rugGroup = new THREE.Group();
scene.add(rugGroup);

var rugTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#3a0e0e';
cx.fillRect(0, 0, w, h);
var i, j, a;
cx.strokeStyle = '#1a0505';
cx.lineWidth = 14;
cx.strokeRect(10, 10, w - 20, h - 20);
cx.strokeStyle = '#7a5a20';
cx.lineWidth = 6;
cx.strokeRect(22, 22, w - 44, h - 44);
for (i = 35; i < w - 35; i += 18) {
cx.fillStyle = '#5a3818';
cx.fillRect(i, 30, 8, 8);
cx.fillRect(i, h - 38, 8, 8);
}
for (j = 35; j < h - 35; j += 18) {
cx.fillStyle = '#5a3818';
cx.fillRect(30, j, 8, 8);
cx.fillRect(w - 38, j, 8, 8);
}
cx.strokeStyle = '#5a1818';
cx.lineWidth = 3;
cx.strokeRect(45, 45, w - 90, h - 90);
cx.strokeStyle = '#8a7a50';
cx.lineWidth = 1.5;
cx.strokeRect(50, 50, w - 100, h - 100);
cx.save();
cx.translate(w/2, h/2);
cx.rotate(Math.PI / 4);
cx.fillStyle = '#4a1510';
cx.fillRect(-65, -65, 130, 130);
cx.strokeStyle = '#7a5a28';
cx.lineWidth = 2;
cx.strokeRect(-65, -65, 130, 130);
cx.fillStyle = '#2a0a08';
cx.fillRect(-40, -40, 80, 80);
cx.strokeStyle = '#6a4a20';
cx.lineWidth = 1.5;
cx.strokeRect(-40, -40, 80, 80);
cx.fillStyle = '#5a2015';
cx.fillRect(-18, -18, 36, 36);
cx.restore();
var crnrs = [[120, 120], [w-120, 120], [120, h-120], [w-120, h-120]];
for (i = 0; i < crnrs.length; i++) {
cx.save();
cx.translate(crnrs[i][0], crnrs[i][1]);
cx.rotate(Math.PI / 4);
cx.fillStyle = '#4a1812';
cx.fillRect(-25, -25, 50, 50);
cx.strokeStyle = '#6a4a22';
cx.lineWidth = 1.5;
cx.strokeRect(-25, -25, 50, 50);
cx.fillStyle = '#3a0e0a';
cx.fillRect(-12, -12, 24, 24);
cx.restore();
}
for (i = 0; i < 8; i++) {
for (j = 0; j < 8; j++) {
var mx = 80 + i * 48;
var my = 80 + j * 48;
if (Math.sqrt(Math.pow(mx - w/2, 2) + Math.pow(my - h/2, 2)) < 60) { continue; }
if (mx < 55 || mx > w - 55 || my < 55 || my > h - 55) { continue; }
cx.fillStyle = '#5a2818';
cx.fillRect(mx - 3, my - 3, 6, 6);
cx.strokeStyle = '#6a4020';
cx.lineWidth = 0.5;
cx.strokeRect(mx - 3, my - 3, 6, 6);
}
}
for (i = 0; i < 40; i++) {
cx.fillStyle = 'rgba(20,10,5,' + (Math.random() * 0.12) + ')';
cx.fillRect(Math.random() * w, Math.random() * h, Math.random() * 30 + 5, Math.random() * 30 + 5);
}
});
var rugMat = new THREE.MeshStandardMaterial({ map: rugTex, roughness: 0.92 });
var rug = new THREE.Mesh(new THREE.PlaneGeometry(2.8, 4.0), rugMat);
rug.rotation.x = -Math.PI / 2;
rug.position.set(halfW - 1.2, 0.003, 1.5);
rug.receiveShadow = true;
rugGroup.add(rug);

// ============================================================
// SOFA
// ============================================================
var sofaGroup = new THREE.Group();
sofaGroup.position.set(halfW - 0.55, 0, 1.5);
scene.add(sofaGroup);

var chesterRed = new THREE.MeshStandardMaterial({ color: 0x6a1818, roughness: 0.7 });
var chesterDark = new THREE.MeshStandardMaterial({ color: 0x4a1010, roughness: 0.75 });

box(sofaGroup, 0.7, 0.35, 1.6, chesterRed, 0, 0.175, 0);
box(sofaGroup, 0.6, 0.08, 1.5, chesterRed, 0, 0.39, 0);
box(sofaGroup, 0.15, 0.5, 1.6, chesterDark, 0.28, 0.6, 0);
box(sofaGroup, 0.6, 0.35, 0.12, chesterDark, 0, 0.5, -0.8);
box(sofaGroup, 0.6, 0.35, 0.12, chesterDark, 0, 0.5, 0.8);
box(sofaGroup, 0.55, 0.06, 0.16, chesterRed, -0.05, 0.68, -0.8);
box(sofaGroup, 0.55, 0.06, 0.16, chesterRed, -0.05, 0.68, 0.8);
var tuftTex = makeCanvasTexture(256, 128, function(cx, cw, ch) {
cx.fillStyle = '#5a1515';
cx.fillRect(0, 0, cw, ch);
var row, col;
for (row = 0; row < 5; row++) {
for (col = 0; col < 10; col++) {
var tx = col * 26 + (row % 2 === 0 ? 0 : 13);
var ty = row * 26 + 5;
cx.fillStyle = '#3a0a0a';
cx.beginPath();
cx.arc(tx + 13, ty + 13, 4, 0, Math.PI * 2);
cx.fill();
cx.strokeStyle = '#4a1212';
cx.lineWidth = 0.8;
cx.beginPath();
cx.moveTo(tx, ty + 13);
cx.lineTo(tx + 13, ty);
cx.lineTo(tx + 26, ty + 13);
cx.lineTo(tx + 13, ty + 26);
cx.closePath();
cx.stroke();
}
}
});
var tuftMat = new THREE.MeshStandardMaterial({ map: tuftTex, roughness: 0.75 });
var tuftPanel = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 0.45), tuftMat);
tuftPanel.position.set(0.2, 0.6, 0);
tuftPanel.rotation.y = -Math.PI / 2;
sofaGroup.add(tuftPanel);

box(sofaGroup, 0.08, 0.04, 0.08, darkWood, -0.25, 0.02, -0.7);
box(sofaGroup, 0.08, 0.04, 0.08, darkWood, -0.25, 0.02, 0.7);
box(sofaGroup, 0.08, 0.04, 0.08, darkWood, 0.25, 0.02, -0.7);
box(sofaGroup, 0.08, 0.04, 0.08, darkWood, 0.25, 0.02, 0.7);

// ============================================================
// DEBRIS
// ============================================================
var debrisGroup = new THREE.Group();
scene.add(debrisGroup);

cyl(debrisGroup, 0.25, 0.28, 0.7, 10, darkWood, -2.3, 0.35, -1);

box(debrisGroup, 0.3, 0.02, 0.2, concreteDark, 1.0, 0.01, 5);
box(debrisGroup, 0.15, 0.08, 0.12, ironMat, -0.8, 0.04, 3);

// ============================================================
// PUDDLE
// ============================================================
var puddleTex = makeCanvasTexture(256, 256, function(cx, cw, ch) {
cx.clearRect(0, 0, cw, ch);
var grd = cx.createRadialGradient(cw/2, ch/2, 0, cw/2, ch/2, cw/2);
grd.addColorStop(0, 'rgba(60,15,12,0.85)');
grd.addColorStop(0.3, 'rgba(70,20,16,0.65)');
grd.addColorStop(0.6, 'rgba(50,16,12,0.45)');
grd.addColorStop(0.85, 'rgba(40,14,10,0.2)');
grd.addColorStop(1, 'rgba(30,10,8,0)');
cx.fillStyle = grd;
cx.beginPath();
cx.moveTo(cw * 0.3, ch * 0.15);
cx.quadraticCurveTo(cw * 0.7, ch * 0.05, cw * 0.8, ch * 0.3);
cx.quadraticCurveTo(cw * 0.9, ch * 0.6, cw * 0.7, ch * 0.8);
cx.quadraticCurveTo(cw * 0.5, ch * 0.95, cw * 0.25, ch * 0.75);
cx.quadraticCurveTo(cw * 0.1, ch * 0.5, cw * 0.15, ch * 0.3);
cx.quadraticCurveTo(cw * 0.2, ch * 0.1, cw * 0.3, ch * 0.15);
cx.closePath();
cx.fill();
cx.strokeStyle = 'rgba(50,15,12,0.35)';
cx.lineWidth = 8;
cx.lineCap = 'round';
cx.beginPath();
cx.moveTo(cw * 0.6, ch * 0.4);
cx.quadraticCurveTo(cw * 0.85, ch * 0.35, cw * 0.9, ch * 0.5);
cx.stroke();
cx.lineWidth = 5;
cx.beginPath();
cx.moveTo(cw * 0.4, ch * 0.55);
cx.quadraticCurveTo(cw * 0.2, ch * 0.7, cw * 0.15, ch * 0.85);
cx.stroke();
cx.fillStyle = 'rgba(35,8,6,0.4)';
cx.beginPath();
cx.ellipse(cw * 0.45, ch * 0.45, 30, 22, 0.3, 0, Math.PI * 2);
cx.fill();
cx.fillStyle = 'rgba(80,40,35,0.12)';
cx.beginPath();
cx.ellipse(cw * 0.42, ch * 0.4, 18, 12, -0.2, 0, Math.PI * 2);
cx.fill();
});
var puddleMat = new THREE.MeshStandardMaterial({
map: puddleTex, transparent: true, roughness: 0.35, metalness: 0.15,
emissive: 0x120403, emissiveIntensity: 0.1
});
var puddle = new THREE.Mesh(new THREE.PlaneGeometry(1.6, 1.4), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(-0.6, 0.006, 4.0);
puddle.receiveShadow = true;
debrisGroup.add(puddle);

// ============================================================
// WIRES
// ============================================================
var wireGroup = new THREE.Group();
scene.add(wireGroup);

var wirePts = [];
wirePts.push(new THREE.Vector3(0, roomHeight - 1.0, 1.5));
wirePts.push(new THREE.Vector3(0.8, roomHeight - 0.6, 1.5));
wirePts.push(new THREE.Vector3(1.8, roomHeight - 0.3, 1.5));
wirePts.push(new THREE.Vector3(halfW - 0.1, roomHeight - 0.2, 1.5));
var wireCurve = new THREE.CatmullRomCurve3(wirePts);
var wirePathGeo = new THREE.TubeGeometry(wireCurve, 20, 0.008, 4, false);
var wirePath = new THREE.Mesh(wirePathGeo, wireMat);
wireGroup.add(wirePath);

var wire2Pts = [];
wire2Pts.push(new THREE.Vector3(-halfW + 0.1, roomHeight - 0.15, 5));
wire2Pts.push(new THREE.Vector3(-halfW + 0.15, roomHeight - 0.4, 3));
wire2Pts.push(new THREE.Vector3(-halfW + 0.1, roomHeight - 0.2, 0));
wire2Pts.push(new THREE.Vector3(-halfW + 0.12, roomHeight - 0.5, -3));
var wire2Curve = new THREE.CatmullRomCurve3(wire2Pts);
var wire2Geo = new THREE.TubeGeometry(wire2Curve, 20, 0.006, 4, false);
wireGroup.add(new THREE.Mesh(wire2Geo, wireMat));

// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();
var baseBulbIntensity = 2.5;
var baseBulbEmissive = 0.55;
var baseGlowOpacity = 0.1;

function clAnimate() {
clAnimId = requestAnimationFrame(clAnimate);
var t = clock.getElapsedTime();

// Breathing light instead of pulsing/flickering
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;
bulbLight.intensity = baseBulbIntensity * breath;
bulbGlass.emissiveIntensity = baseBulbEmissive * breath;
glowSphere.material.opacity = baseGlowOpacity * breath;

// Subtle sway
var sway = Math.sin(t * 0.4) * 0.0015;
bulbSphere.position.x = sway;
bulbLight.position.x = sway;
glowSphere.position.x = sway;
wire.position.x = sway * 0.5;

// Camera drift
camera.position.x = 0.3 + Math.sin(t * 0.12) * 0.017 + Math.sin(t * 0.5) * 0.003;
camera.position.y = 1.5 + Math.sin(t * 0.15) * 0.006 + Math.sin(t * 0.6) * 0.002;

renderer.render(scene, camera);
}

clAnimate();

// ============================================================
// OVERLAYS
// ============================================================

// Vignette
var clVig = document.createElement('div');
clVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 25%, rgba(0,0,0,0.65) 100%);';
clWrap.appendChild(clVig);

// Colorwash
var clWash = document.createElement('div');
clWash.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;background:linear-gradient(180deg, rgba(8,8,20,0.35) 0%, rgba(5,5,12,0.1) 30%, rgba(5,5,12,0.1) 60%, rgba(8,5,3,0.35) 100%);';
clWrap.appendChild(clWash);

// Datestamp
var clDate = document.createElement('div');
clDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
clDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.4);pointer-events:none;z-index:9003;';
clWrap.appendChild(clDate);

// Location
var clLoc = document.createElement('div');
clLoc.textContent = 'BENEATH GREEK STREET, SOHO';
clLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
clWrap.appendChild(clLoc);

// Button
var clBtn = document.createElement('div');
clBtn.textContent = "DESCEND TO COPPER'S LAIR";
clBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(180,170,150,0.85);border:1px solid rgba(180,170,150,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
setTimeout(function() { clBtn.style.opacity = '1'; }, 2500);
clBtn.addEventListener('mouseenter', function() {
clBtn.style.color = 'rgba(210,200,170,0.95)';
clBtn.style.borderColor = 'rgba(180,170,150,0.6)';
});
clBtn.addEventListener('mouseleave', function() {
clBtn.style.color = 'rgba(180,170,150,0.85)';
clBtn.style.borderColor = 'rgba(180,170,150,0.3)';
});
clBtn.addEventListener('click', function() {
clWrap.style.transition = 'opacity 1.5s ease';
clWrap.style.opacity = '0';
setTimeout(function() {
if (clAnimId) cancelAnimationFrame(clAnimId);
clAnimId = null;
if (clWrap.parentNode) clWrap.parentNode.removeChild(clWrap);
var TARGET = "In Copper's lair";
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
clWrap.appendChild(clBtn);

document.body.appendChild(clWrap);
}

setInterval(function() {
var container = document.getElementById('cl-container');
if (container && !clActive) {
initCoppersLair();
} else if (!container) {
clActive = false;
if (clAnimId) { cancelAnimationFrame(clAnimId); clAnimId = null; }
var wrap = document.getElementById('cl-wrap');
if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
}
}, 300);
})();
// ====== CENTRE POINT SCENE — INLINE ======
(function() {
var cpActive = false;
var cpAnimId = null;

function initCentrePoint() {
if (cpActive) return;
cpActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildCPScene(); };
document.head.appendChild(s);
} else {
buildCPScene();
}
}

function buildCPScene() {
var cpWrap = document.createElement('div');
cpWrap.id = 'cp-wrap';
cpWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#060810;';

// ============================================================
// HELPERS (defined first — used by materials below)
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
cpScene.add(m);
return m;
}

// ============================================================
// SCENE SETUP
// ============================================================
var cpScene = new THREE.Scene();
cpScene.background = new THREE.Color(0x060810);
cpScene.fog = new THREE.Fog(0x060810, 45, 220);

var cpCamera = new THREE.PerspectiveCamera(82, window.innerWidth / window.innerHeight, 0.1, 300);
cpCamera.position.set(0.6, 1.2, 5.0);
cpCamera.lookAt(0.3, 28, -2);

var cpRenderer = new THREE.WebGLRenderer({ antialias: true });
cpRenderer.setSize(window.innerWidth, window.innerHeight);
cpRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
cpRenderer.shadowMap.enabled = true;
cpRenderer.shadowMap.type = THREE.PCFSoftShadowMap;
cpRenderer.toneMapping = THREE.ACESFilmicToneMapping;
cpRenderer.toneMappingExposure = 0.55;
cpWrap.appendChild(cpRenderer.domElement);

window.addEventListener('resize', function() {
cpCamera.aspect = window.innerWidth / window.innerHeight;
cpCamera.updateProjectionMatrix();
cpRenderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================

// Centre Point's distinctive off-white precast concrete panels
// with a slightly grainy aggregate finish — Portland stone dust mixed in
var concreteTex = makeCanvasTexture(512, 512, function(cx, w, h) {
// Base off-white — not pure white, slightly warm and aged
cx.fillStyle = '#cdc8bc';
cx.fillRect(0, 0, w, h);
// Aggregate texture — fine pebbled surface
for (var i = 0; i < 3000; i++) {
var gx = Math.random() * w;
var gy = Math.random() * h;
var gr = 0.8 + Math.random() * 1.8;
var tone = 150 + Math.random() * 60;
cx.fillStyle = 'rgba(' + tone + ',' + (tone-5) + ',' + (tone-10) + ',0.35)';
cx.beginPath();
cx.arc(gx, gy, gr, 0, Math.PI * 2);
cx.fill();
}
// Pollution staining — London grime running down from the top
var soot = cx.createLinearGradient(0, 0, 0, h);
soot.addColorStop(0,   'rgba(40, 38, 32, 0.18)');
soot.addColorStop(0.2, 'rgba(40, 38, 32, 0.08)');
soot.addColorStop(0.6, 'rgba(0,0,0,0)');
soot.addColorStop(1,   'rgba(40, 38, 32, 0.06)');
cx.fillStyle = soot;
cx.fillRect(0, 0, w, h);
// Rain streak staining
cx.strokeStyle = 'rgba(80, 75, 65, 0.05)';
cx.lineWidth = 1.5;
for (var rs = 0; rs < 18; rs++) {
cx.beginPath();
var rx = Math.random() * w;
cx.moveTo(rx, 0);
for (var ry = 0; ry < h; ry += 25) {
rx += (Math.random() - 0.5) * 3;
cx.lineTo(rx, ry);
}
cx.stroke();
}
});
var concreteMat = new THREE.MeshStandardMaterial({
map: concreteTex, roughness: 0.88, metalness: 0.0
});

// The dark recessed concrete between the honeycomb cells
var recessMat = new THREE.MeshStandardMaterial({
color: 0x1a1a18, roughness: 0.92
});

// Dark glass in the honeycomb windows — slightly reflective, 1973 tinted glass
var darkGlassTex = makeCanvasTexture(128, 128, function(cx, w, h) {
cx.fillStyle = '#080c10';
cx.fillRect(0, 0, w, h);
// Faint reflection — sky and light caught in the glass
var refl = cx.createLinearGradient(0, 0, w, h);
refl.addColorStop(0,   'rgba(60, 70, 90, 0.25)');
refl.addColorStop(0.4, 'rgba(20, 25, 35, 0.10)');
refl.addColorStop(1,   'rgba(5, 8, 12, 0.05)');
cx.fillStyle = refl;
cx.fillRect(0, 0, w, h);
});
var darkGlass = new THREE.MeshStandardMaterial({
map: darkGlassTex, roughness: 0.15, metalness: 0.55,
color: 0x0a0e14
});

// A few windows warmly lit — offices working late
var warmGlass = new THREE.MeshStandardMaterial({
color: 0x1a0c02, roughness: 0.3,
emissive: 0xd07020, emissiveIntensity: 0.28
});

// Very faintly lit window — fluorescent strip light, cold
var coldGlass = new THREE.MeshStandardMaterial({
color: 0x080c10, roughness: 0.3,
emissive: 0x8090b0, emissiveIntensity: 0.08
});

// Ground pavement
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#484840';
cx.fillRect(0, 0, w, h);
// Concrete paving slabs
cx.strokeStyle = 'rgba(20, 18, 14, 0.55)';
cx.lineWidth = 3;
for (var gx = 0; gx <= w; gx += 128) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx, h); cx.stroke();
}
for (var gy = 0; gy <= h; gy += 128) {
cx.beginPath(); cx.moveTo(0, gy); cx.lineTo(w, gy); cx.stroke();
}
// Surface grime and oil stains
cx.fillStyle = 'rgba(25, 22, 16, 0.15)';
for (var st = 0; st < 12; st++) {
cx.beginPath();
cx.ellipse(Math.random()*w, Math.random()*h, 10+Math.random()*30, 6+Math.random()*18, Math.random()*Math.PI, 0, Math.PI*2);
cx.fill();
}
});
var paveMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.92 });

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), paveMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
cpScene.add(ground);

// ============================================================
// CENTRE POINT TOWER
// ============================================================
// The building is a cylindrical-ish tower with a hexagonal/faceted
// plan. Each face of the tower has the distinctive deep-set honeycomb
// window grid: horizontal bands of precast concrete framing
// large trapezoidal glazed bays.
//
// We build it as a CylinderGeometry core (the structural mass)
// then tile the honeycomb facade panels onto the visible faces.

var tower = new THREE.Group();

// ----- CORE SHAFT -----
// 34-storey tower. In 1973 it dominated the Tottenham Court Road skyline.
// Scale: ~0.7 units per storey, so total ~24 units tall.
var STOREYS = 34;
var STOREY_H = 0.72;
var TOWER_H = STOREYS * STOREY_H;
var TOWER_R = 2.8;

// Octagonal core — the structural body
var coreGeo = new THREE.CylinderGeometry(TOWER_R, TOWER_R + 0.2, TOWER_H, 8, 1);
var core = new THREE.Mesh(coreGeo, recessMat);
core.position.set(0, TOWER_H / 2, 0);
tower.add(core);

// ----- HONEYCOMB FACADE PANELS -----
// Centre Point's signature: each storey has deep-set concrete ribs
// forming a diamond/hexagonal grid on the facade.
// We'll tile this on the front 3 faces of the octagon.

// Each honeycomb cell: a concrete surround (thick, projected forward)
// with a recessed glass pane inside.
// Cell dimensions roughly: 0.65 wide × 0.68 tall

var CELL_W = 0.62;
var CELL_H = 0.66;
var PANEL_DEPTH = 0.18;
var GLASS_INSET = 0.12;

// The angled faces of the octagon — we'll cover faces at angles:
// 0° (front), ±45° (front-flanks), and partially ±90° (sides)
var facadeAngles = [0, -45, 45, -90, 90];
var facadeWidths = [5.0, 3.5, 3.5, 2.2, 2.2];

// Random seed for consistent window lighting
var winStates = [];
for (var w = 0; w < 2000; w++) {
var r = Math.random();
winStates.push(r < 0.08 ? 'warm' : r < 0.13 ? 'cold' : 'dark');
}

var warmWindows = [];
var winIdx = 0;

facadeAngles.forEach(function(angleDeg, fi) {
var angleRad = angleDeg * Math.PI / 180;
var fWidth   = facadeWidths[fi];

// Position of this face: on the surface of the octagon
var faceDist = TOWER_R * Math.cos(Math.PI / 8);

var cols = Math.floor(fWidth / CELL_W);
var rows = STOREYS;

for (var row = 0; row < rows; row++) {
for (var col = 0; col < cols; col++) {

// Local position on the face
var lx = (col - (cols - 1) / 2) * CELL_W;
var ly = (row + 0.5) * CELL_H + 0.5;

// Odd rows offset by half a cell — the honeycomb stagger
if (row % 2 === 1) lx += CELL_W * 0.5;

// Concrete surround (the rib frame around each cell)
var surroundGeo = new THREE.BoxGeometry(CELL_W - 0.04, CELL_H - 0.04, PANEL_DEPTH);
var surround = new THREE.Mesh(surroundGeo, concreteMat);

// Glass pane — inset behind the surround
var glassState = winStates[winIdx % winStates.length];
winIdx++;
var glassMat = (glassState === 'warm') ? warmGlass :
(glassState === 'cold') ? coldGlass : darkGlass;

var glassGeo = new THREE.BoxGeometry(CELL_W * 0.72, CELL_H * 0.78, 0.04);
var glass = new THREE.Mesh(glassGeo, glassMat);
glass.position.z = -GLASS_INSET;

// The horizontal rib — a thin bar across the bottom of each cell
var ribGeo = new THREE.BoxGeometry(CELL_W, 0.06, PANEL_DEPTH + 0.04);
var rib = new THREE.Mesh(ribGeo, concreteMat);
rib.position.y = -(CELL_H / 2) + 0.03;

// Group the cell
var cell = new THREE.Group();
cell.add(surround);
cell.add(glass);
cell.add(rib);

// Position on the face, rotated to sit on the correct face of octagon
cell.position.set(lx, ly, faceDist);
cell.rotation.y = -angleRad;

// Rotate so x-axis aligns with the face
var worldPos = new THREE.Vector3();
var cosA = Math.cos(angleRad);
var sinA = Math.sin(angleRad);
cell.position.set(
lx * cosA - 0 * sinA,
ly,
lx * sinA + faceDist * cosA
);

if (glassState === 'warm') {
warmWindows.push({ x: cell.position.x, y: ly, z: cell.position.z });
}

tower.add(cell);
}
}
});

// ----- PODIUM / BASE -----
// The building sits on a broad podium at street level
var podiumGeo = new THREE.BoxGeometry(7, 2.0, 7);
var podium = new THREE.Mesh(podiumGeo, concreteMat);
podium.position.set(0, 1.0, 0);
tower.add(podium);

// Podium overhang / colonnade edge
var overhangGeo = new THREE.BoxGeometry(8.2, 0.25, 8.2);
var overhang = new THREE.Mesh(overhangGeo, concreteMat);
overhang.position.set(0, 2.1, 0);
tower.add(overhang);

// Colonnade pillars around the base
for (var pi = 0; pi < 8; pi++) {
var pa = (pi / 8) * Math.PI * 2;
var px = Math.sin(pa) * 3.8;
var pz = Math.cos(pa) * 3.8;
var pillarGeo = new THREE.CylinderGeometry(0.15, 0.18, 2.2, 8);
var pillar = new THREE.Mesh(pillarGeo, concreteMat);
pillar.position.set(px, 1.1, pz);
tower.add(pillar);
}

// ----- ROOF / CROWN -----
// The top of Centre Point has a distinctive recessed plant-room and
// a parapet with a slightly different profile
var roofSlab = new THREE.Mesh(
new THREE.CylinderGeometry(TOWER_R + 0.1, TOWER_R + 0.1, 0.4, 8),
concreteMat
);
roofSlab.position.set(0, TOWER_H + 0.2, 0);
tower.add(roofSlab);

// Plant room on roof
var plantRoom = new THREE.Mesh(
new THREE.BoxGeometry(3.5, 2.5, 3.5),
recessMat
);
plantRoom.position.set(0, TOWER_H + 1.65, 0);
tower.add(plantRoom);

// Roof parapet
var parapet = new THREE.Mesh(
new THREE.CylinderGeometry(TOWER_R + 0.3, TOWER_R + 0.3, 0.3, 8),
concreteMat
);
parapet.position.set(0, TOWER_H + 0.55, 0);
tower.add(parapet);

// Aviation warning light on top
var warningLight = new THREE.Mesh(
new THREE.SphereGeometry(0.12, 8, 6),
new THREE.MeshStandardMaterial({
color: 0x400000, roughness: 0.3,
emissive: 0xff2000, emissiveIntensity: 0.6
})
);
warningLight.position.set(0, TOWER_H + 3.2, 0);
tower.add(warningLight);

cpScene.add(tower);

// ============================================================
// LOWER BUILDING / PODIUM CONTEXT — the smaller block at the base
// ============================================================
// Centre Point had a lower surrounding block — shops, service access
var lowerBlock = new THREE.Mesh(
new THREE.BoxGeometry(10, 5.5, 8),
concreteMat
);
lowerBlock.position.set(0, 2.75, -3.5);
cpScene.add(lowerBlock);

// A few windows on the lower block
for (var lb = 0; lb < 6; lb++) {
var lwx = -3.5 + lb * 1.4;
var lwGlass = (Math.random() < 0.3) ? warmGlass : darkGlass;
var lwin = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.9, 0.06), lwGlass);
lwin.position.set(lwx, 3.8, 0.5);
cpScene.add(lwin);
}

// ============================================================
// SKY — night sky with a faint sodium glow on the horizon
// ============================================================
// Sky dome
var skyGeo = new THREE.SphereGeometry(150, 16, 8);
var skyTex = makeCanvasTexture(512, 256, function(cx, w, h) {
// Very dark blue-black night sky
var skyGrad = cx.createLinearGradient(0, 0, 0, h);
skyGrad.addColorStop(0,    '#030408');
skyGrad.addColorStop(0.5,  '#060810');
skyGrad.addColorStop(0.75, '#0c0e18');
skyGrad.addColorStop(0.85, '#1a1008');
skyGrad.addColorStop(1,    '#2a1a08');
cx.fillStyle = skyGrad;
cx.fillRect(0, 0, w, h);
// Stars — faint
cx.fillStyle = 'rgba(255,255,255,0.7)';
for (var s = 0; s < 180; s++) {
var sx = Math.random() * w;
var sy = Math.random() * h * 0.7;
var sr = 0.4 + Math.random() * 0.8;
cx.beginPath();
cx.arc(sx, sy, sr, 0, Math.PI * 2);
cx.fill();
}
});
var skyMat = new THREE.MeshBasicMaterial({ map: skyTex, side: THREE.BackSide });
var sky = new THREE.Mesh(skyGeo, skyMat);
cpScene.add(sky);

// ============================================================
// STARS
// ============================================================
var starTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var g = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
g.addColorStop(0,    'rgba(255,255,255,0.95)');
g.addColorStop(0.12, 'rgba(255,255,255,0.6)');
g.addColorStop(0.4,  'rgba(200,210,255,0.15)');
g.addColorStop(1,    'rgba(0,0,0,0)');
cx.fillStyle = g;
cx.fillRect(0, 0, w, h);
});

for (var si = 0; si < 220; si++) {
var sMat = new THREE.SpriteMaterial({
map: starTex, transparent: true,
opacity: 0.3 + Math.random() * 0.7,
fog: false
});
var sSpr = new THREE.Sprite(sMat);
var sTheta = Math.random() * Math.PI * 2;
var sPhi   = 0.05 + Math.random() * 0.45;
var sDist  = 90 + Math.random() * 30;
sSpr.position.set(
Math.sin(sTheta) * Math.sin(sPhi) * sDist,
Math.cos(sPhi)   * sDist * 0.6 + 15,
Math.cos(sTheta) * Math.sin(sPhi) * sDist - 20
);
var sSz = 0.4 + Math.random() * 1.1;
sSpr.scale.set(sSz, sSz, 1);
cpScene.add(sSpr);
}

// ============================================================
// TOWER UPLIGHTING — dramatic uplights on the base washing the concrete
// ============================================================
var upLight1 = new THREE.SpotLight(0xfff0d0, 1.8, 35, Math.PI / 7, 0.5);
upLight1.position.set(-3, 0.5, 4.5);
upLight1.target.position.set(-1, 15, 0);
cpScene.add(upLight1);
cpScene.add(upLight1.target);

var upLight2 = new THREE.SpotLight(0xfff0d0, 1.5, 35, Math.PI / 7, 0.5);
upLight2.position.set(3, 0.5, 4.5);
upLight2.target.position.set(1, 15, 0);
cpScene.add(upLight2);
cpScene.add(upLight2.target);

var upLight3 = new THREE.SpotLight(0xffe8b0, 1.0, 40, Math.PI / 8, 0.6);
upLight3.position.set(0, 0.5, 5.5);
upLight3.target.position.set(0, 22, 0);
cpScene.add(upLight3);
cpScene.add(upLight3.target);

// ============================================================
// WARM WINDOW GLOW LIGHTS
// ============================================================
// Add a few point lights near the warmly lit windows
var windowGlows = [];
var glowSubset = warmWindows.slice(0, 8);
glowSubset.forEach(function(ww) {
var wl = new THREE.PointLight(0xd07020, 0.18, 3.5);
wl.position.set(ww.x * 0.85, ww.y, ww.z * 0.85 + 0.5);
cpScene.add(wl);
windowGlows.push(wl);
});

// ============================================================
// AVIATION WARNING LIGHT — animated red blink
// ============================================================
var avLight = new THREE.PointLight(0xff2000, 0.0, 20);
avLight.position.set(0, TOWER_H + 3.3, 0);
cpScene.add(avLight);

// ============================================================
// AMBIENT + MOON
// ============================================================
cpScene.add(new THREE.AmbientLight(0x05060e, 0.12));

var moonLight = new THREE.DirectionalLight(0x1a2255, 0.06);
moonLight.position.set(-8, 30, 10);
cpScene.add(moonLight);

// ============================================================
// FOG SPRITES — ground-level murk
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0,   'rgba(130,125,115,0.28)');
grad.addColorStop(0.5, 'rgba(100, 95, 85,0.12)');
grad.addColorStop(1,   'rgba(70, 65, 55, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var sodiumFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0,   'rgba(220,110,20,0.22)');
grad.addColorStop(0.4, 'rgba(190, 85,14,0.10)');
grad.addColorStop(1,   'rgba(140, 55, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

for (var fi = 0; fi < 50; fi++) {
var fMat = new THREE.SpriteMaterial({
map: (fi < 35) ? thickFogTex : sodiumFogTex,
transparent: true, opacity: 0.2 + Math.random() * 0.2
});
var fs = new THREE.Sprite(fMat);
fs.position.set(Math.random() * 40 - 18, 0.2 + Math.random() * 2.0, Math.random() * 25 - 3);
var fsc = 6 + Math.random() * 14;
fs.scale.set(fsc, fsc * 0.28, 1);
cpScene.add(fs);
fogSprites.push({
sprite: fs, baseX: fs.position.x,
drift: 0.002 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.003,
swayAmt: 0.5 + Math.random() * 1.2
});
}

// ============================================================
// NEON BLUE LADDER — two rails + cross rungs up the central gap
// ============================================================
var LADDER_X    = 0.0;
var RAIL_SEP    = 0.32;
var LADDER_Z    = TOWER_R + 0.4;
var RUNG_COUNT  = STOREYS + 2;
var RUNG_SPACING = STOREY_H;

// Base neon material — shared by rails
var neonMat = new THREE.MeshStandardMaterial({
color: 0x001833,
emissive: new THREE.Color(0x00aaff),
emissiveIntensity: 2.2,
roughness: 0.15,
metalness: 0.0,
fog: false
});

// LEFT RAIL
var leftRail = new THREE.Mesh(
new THREE.BoxGeometry(0.055, TOWER_H + 2, 0.055),
neonMat
);
leftRail.position.set(-RAIL_SEP, (TOWER_H + 2) / 2 + 0.5, LADDER_Z);
cpScene.add(leftRail);

// RIGHT RAIL
var rightRail = new THREE.Mesh(
new THREE.BoxGeometry(0.055, TOWER_H + 2, 0.055),
neonMat
);
rightRail.position.set(RAIL_SEP, (TOWER_H + 2) / 2 + 0.5, LADDER_Z);
cpScene.add(rightRail);

// RUNGS — flat boxes spanning between the rails, clearly visible face-on
var rungMeshes = [];
for (var rung = 0; rung < RUNG_COUNT; rung++) {
var ry = 0.8 + rung * RUNG_SPACING;
var rungMat = neonMat.clone();
var rungMesh = new THREE.Mesh(
new THREE.BoxGeometry(RAIL_SEP * 2, 0.07, 0.07),
rungMat
);
rungMesh.position.set(0, ry, LADDER_Z);
cpScene.add(rungMesh);
rungMeshes.push(rungMesh);
}

// Travelling pulse light
var pulseLight = new THREE.PointLight(0x00aaff, 0.0, 7);
cpScene.add(pulseLight);

// Soft base glow pooling at the bottom
var ladderBaseGlow = new THREE.PointLight(0x0055cc, 0.5, 10);
ladderBaseGlow.position.set(0, 1.5, LADDER_Z + 1);
cpScene.add(ladderBaseGlow);

// ============================================================
// ANIMATION
// ============================================================
var cpClock = new THREE.Clock();
var avBlinkPhase = 0;

function cpAnimate() {
cpAnimId = requestAnimationFrame(cpAnimate);
var t = cpClock.getElapsedTime();

// --- UPLIGHTING — slow breathing, like a building being dramatic ---
var upBreath = 0.96 + Math.sin(t * 0.18) * 0.03;
upLight1.intensity = 1.8 * upBreath;
upLight2.intensity = 1.5 * upBreath;
upLight3.intensity = 1.0 * upBreath;

// --- AVIATION LIGHT — slow red blink, every ~4 seconds ---
avBlinkPhase += 0.016;
var avCycle = Math.sin(avBlinkPhase * 0.8);
var avOn = avCycle > 0.85;
avLight.intensity = avOn ? (avCycle - 0.85) * 12 : 0;
warningLight.material.emissiveIntensity = avOn ? 0.8 + (avCycle - 0.85) * 4 : 0.08;

// --- WINDOW GLOW PULSE (very slow, nearly static) ---
for (var wgi = 0; wgi < windowGlows.length; wgi++) {
windowGlows[wgi].intensity = 0.15 + Math.sin(t * 0.08 + wgi * 0.9) * 0.04;
}

// --- NEON LADDER PULSE ---
// A bright pulse travels upward continuously, looping from bottom to top
var PULSE_SPEED = 4.5;
var pulsePos = (t * PULSE_SPEED) % (RUNG_COUNT + 4);
var pulseY   = 0.8 + pulsePos * RUNG_SPACING;

// Move the travelling point light
pulseLight.position.set(LADDER_X, pulseY, LADDER_Z + 0.8);

// Each rung brightness: peak when pulse is at that rung, fades off quickly
for (var ri = 0; ri < rungMeshes.length; ri++) {
var dist = Math.abs(ri - pulsePos);
var brightness = Math.max(0, 1.0 - dist * 0.55);
// Base flicker on the neon — slow, like a real tube
var neonFlicker = 0.88 + Math.sin(t * 1.4 + ri * 0.3) * 0.06
+ Math.sin(t * 3.1 + ri * 0.7) * 0.03;
rungMeshes[ri].material.emissiveIntensity = (0.5 + brightness * 1.8) * neonFlicker;
}

// Spine pulses with overall neon flicker
var spineFlicker = 0.9 + Math.sin(t * 1.2) * 0.05 + Math.sin(t * 2.8) * 0.03;
leftRail.material.emissiveIntensity  = 1.0 * spineFlicker;
rightRail.material.emissiveIntensity = 1.0 * spineFlicker;

// The pulse light intensity peaks at the centre of the travel
pulseLight.intensity = 1.2 + Math.sin(t * 1.8) * 0.2;

// Base glow breathes slowly
ladderBaseGlow.intensity = 0.35 + Math.sin(t * 0.4) * 0.12;

// --- FOG DRIFT ---
for (var fdi = 0; fdi < fogSprites.length; fdi++) {
var f = fogSprites[fdi];
f.sway += f.swaySpeed;
f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
f.baseX += f.drift;
if (f.baseX > 22) f.baseX = -18;
}

cpRenderer.render(cpScene, cpCamera);
}

cpAnimate();

// Vignette
var cpVig = document.createElement('div');
cpVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
cpWrap.appendChild(cpVig);

// Datestamp
var cpDate = document.createElement('div');
cpDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
cpDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(232,120,24,0.55);pointer-events:none;z-index:9003;';
cpWrap.appendChild(cpDate);

// Location
var cpLoc = document.createElement('div');
cpLoc.textContent = 'CENTRE POINT, NEW OXFORD STREET, LONDON';
cpLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.4);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
cpWrap.appendChild(cpLoc);

// Button: "CLIMB IT"
var cpBtn = document.createElement('div');
cpBtn.textContent = 'CLIMB IT';
cpBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(200,170,100,0.85);border:1px solid rgba(200,170,100,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
setTimeout(function() { cpBtn.style.opacity = '1'; }, 2500);
cpBtn.addEventListener('mouseenter', function() {
cpBtn.style.color = 'rgba(230,200,120,0.95)';
cpBtn.style.borderColor = 'rgba(200,170,100,0.6)';
});
cpBtn.addEventListener('mouseleave', function() {
cpBtn.style.color = 'rgba(200,170,100,0.85)';
cpBtn.style.borderColor = 'rgba(200,170,100,0.3)';
});
cpBtn.addEventListener('click', function() {
cpWrap.style.transition = 'opacity 1.5s ease';
cpWrap.style.opacity = '0';
setTimeout(function() {
if (cpAnimId) cancelAnimationFrame(cpAnimId);
cpAnimId = null;
if (cpWrap.parentNode) cpWrap.parentNode.removeChild(cpWrap);
var TARGET = 'Centre Point';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
cpWrap.appendChild(cpBtn);

document.body.appendChild(cpWrap);
}

setInterval(function() {
var container = document.getElementById('cp-container');
if (container && !cpActive) {
initCentrePoint();
} else if (!container) {
cpActive = false;
if (cpAnimId) { cancelAnimationFrame(cpAnimId); cpAnimId = null; }
var wrap = document.getElementById('cp-wrap');
if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
}
}, 300);
})();
// ====== CHINESE FISH AND CHIPS — INLINE ======
(function() {
var fcActive = false;
var fcAnimId = null;

function initFc() {
  if (fcActive) return; fcActive = true;
  if (typeof THREE === 'undefined') {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    s.onload = function() { buildFcScene(); };
    document.head.appendChild(s);
  } else { buildFcScene(); }
}

function buildFcScene() {
  var fcWrap = document.createElement('div');
  fcWrap.id = 'fc-wrap';
  fcWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';

  // ============================================================
  // SCENE SETUP
  // ============================================================
  var scene = new THREE.Scene();
  scene.background = new THREE.Color(0x080810);
  scene.fog = new THREE.Fog(0x080810, 5, 38);

  var camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 200);

  // ============================================================
  // LAYOUT — Light angle from the left
  // ============================================================
  camera.position.set(-3.5, 3.8, 15);
  camera.lookAt(1.0, 4.0, 0);

  var renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
  renderer.toneMappingExposure = 0.65;
  fcWrap.appendChild(renderer.domElement);

  window.addEventListener('resize', function() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // ============================================================
  // MATERIALS
  // ============================================================
  var brickMat = new THREE.MeshStandardMaterial({ color: 0x7a5a48, roughness: 0.85 });
  var darkBrick = new THREE.MeshStandardMaterial({ color: 0x5a3a2a, roughness: 0.9 });
  var creamPaint = new THREE.MeshStandardMaterial({ color: 0xd8d0b8, roughness: 0.75 });
  var shopRed = new THREE.MeshStandardMaterial({ color: 0x8a1818, roughness: 0.6 });
  var darkRed = new THREE.MeshStandardMaterial({ color: 0x5a1010, roughness: 0.7 });
  var goldTrim = new THREE.MeshStandardMaterial({ color: 0xc8a840, roughness: 0.35, metalness: 0.3 });
  var brightGold = new THREE.MeshStandardMaterial({ color: 0xd4b850, roughness: 0.3, metalness: 0.4 });
  var tileMat = new THREE.MeshStandardMaterial({ color: 0xc8d8d0, roughness: 0.5 });
  var whiteTile = new THREE.MeshStandardMaterial({ color: 0xe8e8e0, roughness: 0.45 });
  var whiteTrim = new THREE.MeshStandardMaterial({ color: 0xe8e4dc, roughness: 0.7 });
  var creamTrim = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.75 });
  var blackMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.5 });
  var redPaint = new THREE.MeshStandardMaterial({ color: 0xaa2020, roughness: 0.6 });
  var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.9 });
  var roadMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.85 });
  var sillMat = new THREE.MeshStandardMaterial({ color: 0xdcd4c8, roughness: 0.7 });
  var windowFrame = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.6 });
  var pipeMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7 });
  var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.3 });
  var woodMat = new THREE.MeshStandardMaterial({ color: 0x3a2a1a, roughness: 0.8 });
  var chromeMat = new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.2, metalness: 0.6 });
  var formicaMat = new THREE.MeshStandardMaterial({ color: 0xd8c8a0, roughness: 0.4 });

  // ============================================================
  // HELPERS
  // ============================================================
  function makeCanvasTexture(w, h, drawFunc) {
    var c = document.createElement('canvas');
    c.width = w; c.height = h;
    var cx = c.getContext('2d');
    drawFunc(cx, w, h);
    var tex = new THREE.CanvasTexture(c);
    tex.minFilter = THREE.LinearFilter;
    return tex;
  }

  function placeMesh(group, geo, mat, x, y, z) {
    var m = new THREE.Mesh(geo, mat);
    m.position.set(x, y, z);
    group.add(m);
    return m;
  }

  // ============================================================
  // GROUND
  // ============================================================
  var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
  ground.rotation.x = -Math.PI / 2;
  ground.receiveShadow = true;
  scene.add(ground);

  var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
  road.rotation.x = -Math.PI / 2;
  road.position.set(0, -0.01, 10);
  road.receiveShadow = true;
  scene.add(road);

  // Wet road surface (reflective — picks up the bright chippy glow)
  var wetMat = new THREE.MeshStandardMaterial({
    color: 0x1a1a1a, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.35
  });
  var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(16, 16), wetMat);
  wetRoad.rotation.x = -Math.PI / 2;
  wetRoad.position.set(0, 0.01, 8);
  scene.add(wetRoad);

  // Road centre dashes
  for (var rli = -6; rli < 20; rli += 2.5) {
    var roadLine = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 1.5),
      new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.7, transparent: true, opacity: 0.25 }));
    roadLine.rotation.x = -Math.PI / 2;
    roadLine.position.set(0, 0.02, rli);
    scene.add(roadLine);
  }

  // ============================================================
  // THE CHINESE FISH & CHIPS
  // ============================================================
  var shop = new THREE.Group();

  // ---- BUILDING BODY ----
  // Simple 3-storey brick building. Narrower than the pubs — about 6 units wide.
  // The chippy is the ground floor; upper floors are residential flats.
  var buildingBody = new THREE.Mesh(new THREE.BoxGeometry(6, 11, 6), brickMat);
  buildingBody.position.set(0.5, 5.5, -3);
  shop.add(buildingBody);

  // Facade panel (slightly different tone)
  placeMesh(shop, new THREE.BoxGeometry(6.02, 11, 0.06), darkBrick, 0.5, 5.5, 0.03);

  // Side wall (visible at angle)
  var sideWall = new THREE.Mesh(new THREE.PlaneGeometry(6, 11),
    new THREE.MeshStandardMaterial({ color: 0x6a4a38, roughness: 0.88 }));
  sideWall.position.set(-2.49, 5.5, -3);
  sideWall.rotation.y = Math.PI / 2;
  shop.add(sideWall);

  // Mortar coursework hints
  for (var bri = 0.5; bri < 11; bri += 0.35) {
    if (Math.random() > 0.35) {
      placeMesh(shop, new THREE.PlaneGeometry(6.01, 0.015),
        new THREE.MeshStandardMaterial({ color: 0xb09888, roughness: 0.9, transparent: true, opacity: 0.18 }),
        0.5, bri, 0.05);
    }
  }

  // ---- UPPER FLOOR WINDOWS (residential — simple sash windows) ----
  // 2 rows of 3 windows
  var upWinXs = [-0.8, 0.8, 2.4];
  for (var row = 0; row < 2; row++) {
    for (var col = 0; col < 3; col++) {
      var uwx = upWinXs[col];
      var uwy = 6.5 + row * 3;
      var uwLit = (row === 0 && col === 1); // One warm window lit upstairs
      // Brick reveal
      placeMesh(shop, new THREE.BoxGeometry(0.95, 1.55, 0.04),
        new THREE.MeshStandardMaterial({ color: 0x4a2a1a, roughness: 0.9 }), uwx, uwy, 0.04);
      // Frame
      placeMesh(shop, new THREE.BoxGeometry(0.85, 1.45, 0.05), windowFrame, uwx, uwy, 0.06);
      placeMesh(shop, new THREE.BoxGeometry(0.72, 1.32, 0.03), windowFrame, uwx, uwy, 0.09);
      // Glass
      var uwGlassCol = uwLit ? 0xffd699 : 0x334466;
      var uwGlassOp = uwLit ? 0.35 : 0.12;
      placeMesh(shop, new THREE.PlaneGeometry(0.68, 1.28),
        new THREE.MeshBasicMaterial({ color: uwGlassCol, transparent: true, opacity: uwGlassOp }),
        uwx, uwy, 0.11);
      // Sash bar
      placeMesh(shop, new THREE.BoxGeometry(0.75, 0.04, 0.04), windowFrame, uwx, uwy + 0.1, 0.11);
      // Glazing bars
      placeMesh(shop, new THREE.BoxGeometry(0.02, 1.28, 0.02), windowFrame, uwx, uwy, 0.12);
      placeMesh(shop, new THREE.BoxGeometry(0.68, 0.02, 0.02), windowFrame, uwx, uwy + 0.35, 0.12);
      placeMesh(shop, new THREE.BoxGeometry(0.68, 0.02, 0.02), windowFrame, uwx, uwy - 0.35, 0.12);
      // Sill
      placeMesh(shop, new THREE.BoxGeometry(0.95, 0.07, 0.16), sillMat, uwx, uwy - 0.78, 0.13);
      // Lintel
      placeMesh(shop, new THREE.BoxGeometry(0.95, 0.1, 0.05),
        new THREE.MeshStandardMaterial({ color: 0x8a5a48, roughness: 0.8 }), uwx, uwy + 0.78, 0.08);
    }
  }

  // String course between floors
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.1, 0.14), whiteTrim, 0.5, 5.6, 0.12);
  // Upper lip projection
  placeMesh(shop, new THREE.BoxGeometry(6.12, 0.04, 0.17), whiteTrim, 0.5, 5.66, 0.14);
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.03, 0.05),
    new THREE.MeshStandardMaterial({ color: 0x4a3a2a, roughness: 0.9 }), 0.5, 5.53, 0.08);
  // Side return
  placeMesh(shop, new THREE.BoxGeometry(0.14, 0.1, 0.3), whiteTrim, -2.49, 5.6, -0.05);
  // Second string course (between 2nd and 3rd floor)
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.08, 0.1), whiteTrim, 0.5, 8.7, 0.1);

  // Top cornice (heavy, projecting)
  placeMesh(shop, new THREE.BoxGeometry(6.18, 0.18, 0.35), whiteTrim, 0.5, 11.08, 0.18);
  // Second cornice layer
  placeMesh(shop, new THREE.BoxGeometry(6.22, 0.1, 0.4), whiteTrim, 0.5, 10.95, 0.2);
  // Underside
  placeMesh(shop, new THREE.BoxGeometry(6.18, 0.06, 0.38), creamTrim, 0.5, 10.88, 0.2);
  // Dentils (closer together for richness)
  for (var di = -2.3; di <= 3.3; di += 0.25) {
    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.08, 0.04), whiteTrim, di, 10.82, 0.18);
  }
  // Moulding band below dentils
  placeMesh(shop, new THREE.BoxGeometry(6.15, 0.04, 0.08), creamTrim, 0.5, 10.75, 0.14);

  // Simple parapet / roof
  var roofMat = new THREE.MeshStandardMaterial({ color: 0x2a2a30, roughness: 0.85 });
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.8, 3), roofMat, 0.5, 11.6, -1.5);
  // Chimneys
  var chimMat = new THREE.MeshStandardMaterial({ color: 0x7a5a48, roughness: 0.85 });
  placeMesh(shop, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -1, 12.75, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.55, 0.08, 0.55), chimMat, -1, 13.55, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, -1.15, 13.7, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, -0.85, 13.7, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, 2, 12.75, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.55, 0.08, 0.55), chimMat, 2, 13.55, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, 1.85, 13.7, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, 2.15, 13.7, -2);

  // ---- RED & GOLD PAINTED FASCIA ----
  // The fascia board — deep red with gold lettering
  var fasciaC = document.createElement('canvas');
  fasciaC.width = 768; fasciaC.height = 96;
  var fctx = fasciaC.getContext('2d');
  // Deep red background
  fctx.fillStyle = '#8a1818';
  fctx.fillRect(0, 0, 768, 96);
  // Gold border — double line
  fctx.strokeStyle = '#c8a840'; fctx.lineWidth = 3;
  fctx.strokeRect(5, 5, 758, 86);
  fctx.strokeStyle = '#a08830'; fctx.lineWidth = 1;
  fctx.strokeRect(10, 10, 748, 76);
  // Shop name in gold
  fctx.fillStyle = '#d8b840';
  fctx.font = 'bold 40px Georgia, serif';
  fctx.textAlign = 'center';
  fctx.fillText('Chinese, Fish and Chips', 384, 52);
  // Decorative gold rule below
  fctx.strokeStyle = '#b09830'; fctx.lineWidth = 1;
  fctx.beginPath(); fctx.moveTo(140, 62); fctx.lineTo(628, 62); fctx.stroke();
  // "OPEN LATE" centred below
  fctx.font = 'bold 16px Georgia, serif';
  fctx.fillStyle = '#e0c860';
  fctx.fillText('OPEN  LATE', 384, 80);
  // "FISH RESTAURANT" left side
  fctx.font = '13px Georgia, serif';
  fctx.fillStyle = '#c8a840';
  fctx.textAlign = 'left';
  fctx.fillText('FISH RESTAURANT', 22, 80);
  // "TAKE AWAY" right side
  fctx.textAlign = 'right';
  fctx.fillText('TAKE AWAY', 746, 80);

  var fasciaTex = new THREE.CanvasTexture(fasciaC);
  var fascia = new THREE.Mesh(new THREE.BoxGeometry(6.0, 0.8, 0.18),
    new THREE.MeshBasicMaterial({ map: fasciaTex }));
  fascia.position.set(0.5, 4.2, 0.35);
  shop.add(fascia);

  // Fascia board physical depth — red painted surround
  placeMesh(shop, new THREE.BoxGeometry(6.05, 0.82, 0.06), shopRed, 0.5, 4.2, 0.24);
  // Top cap — gold trim
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.06, 0.24), goldTrim, 0.5, 4.63, 0.33);
  // Second gold beading below top cap
  placeMesh(shop, new THREE.BoxGeometry(6.08, 0.03, 0.2), brightGold, 0.5, 4.58, 0.32);
  // Bottom cap — gold trim
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.06, 0.24), goldTrim, 0.5, 3.77, 0.33);
  // Side returns (red with gold edge)
  placeMesh(shop, new THREE.BoxGeometry(0.06, 0.82, 0.22), shopRed, -2.5, 4.2, 0.32);
  placeMesh(shop, new THREE.BoxGeometry(0.06, 0.82, 0.22), shopRed, 3.5, 4.2, 0.32);
  placeMesh(shop, new THREE.BoxGeometry(0.03, 0.82, 0.04), goldTrim, -2.52, 4.2, 0.44);
  placeMesh(shop, new THREE.BoxGeometry(0.03, 0.82, 0.04), goldTrim, 3.52, 4.2, 0.44);
  // Corbel brackets under fascia (decorative supports)
  for (var cbi = -2.0; cbi <= 3.0; cbi += 2.5) {
    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.25, 0.1), shopRed, cbi, 3.65, 0.3);
    placeMesh(shop, new THREE.BoxGeometry(0.06, 0.08, 0.12), goldTrim, cbi, 3.58, 0.32);
  }

  // ---- FASCIA SPOTLIGHTS (angled down, like Lord Chippy) ----
  var fasciaLamps = [];
  for (var flx = -1.5; flx <= 2.5; flx += 2.0) {
    // Spotlight housing
    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.08, 0.15), blackMat, flx, 4.72, 0.4);
    var spotCone = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.06, 0.12, 6),
      new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5 }));
    spotCone.position.set(flx, 4.68, 0.5);
    spotCone.rotation.x = 0.5;
    shop.add(spotCone);
    // Spot glow
    var spotGlow = new THREE.Mesh(new THREE.SphereGeometry(0.03, 4, 4),
      new THREE.MeshBasicMaterial({ color: 0xffeedd }));
    spotGlow.position.set(flx, 4.65, 0.55);
    shop.add(spotGlow);
    var spotLight = new THREE.PointLight(0xffeedd, 0.6, 5);
    spotLight.position.set(flx, 4.5, 0.7);
    spotLight.userData.baseIntensity = 0.6;
    shop.add(spotLight);
    fasciaLamps.push(spotLight);
  }

  // ---- GROUND FLOOR: THE CHIPPY SHOPFRONT ----
  // This is the heart of the scene — spare, bright, glowing

  // Tiled surround / stall riser (cream tiles with gold accent strip, very 1970s)
  placeMesh(shop, new THREE.BoxGeometry(6.02, 0.6, 0.12), whiteTile, 0.5, 0.3, 0.22);
  // Gold accent strip at top of tiles
  placeMesh(shop, new THREE.BoxGeometry(6.04, 0.035, 0.04), goldTrim, 0.5, 0.62, 0.29);
  // Tile grid lines (vertical)
  for (var tx = -2.2; tx <= 3.2; tx += 0.2) {
    placeMesh(shop, new THREE.BoxGeometry(0.008, 0.6, 0.008),
      new THREE.MeshStandardMaterial({ color: 0xb0b0a8, roughness: 0.6 }), tx, 0.3, 0.29);
  }
  // Tile grid lines (horizontal)
  for (var ty = 0.08; ty <= 0.55; ty += 0.12) {
    placeMesh(shop, new THREE.BoxGeometry(6.0, 0.008, 0.008),
      new THREE.MeshStandardMaterial({ color: 0xb0b0a8, roughness: 0.6 }), 0.5, ty, 0.29);
  }
  // Red kickboard below tiles
  placeMesh(shop, new THREE.BoxGeometry(6.02, 0.08, 0.12), darkRed, 0.5, -0.02, 0.22);

  // Red painted frame around the whole shopfront
  placeMesh(shop, new THREE.BoxGeometry(6.02, 3.1, 0.1), shopRed, 0.5, 2.15, 0.2);
  // Inner reveal (darker)
  placeMesh(shop, new THREE.BoxGeometry(5.8, 2.9, 0.08), darkRed, 0.5, 2.15, 0.24);
  // Gold pinstripe outline around shopfront opening
  placeMesh(shop, new THREE.BoxGeometry(5.85, 0.025, 0.03), goldTrim, 0.5, 3.62, 0.29);
  placeMesh(shop, new THREE.BoxGeometry(5.85, 0.025, 0.03), goldTrim, 0.5, 0.65, 0.29);
  placeMesh(shop, new THREE.BoxGeometry(0.025, 2.97, 0.03), goldTrim, -2.42, 2.15, 0.29);
  placeMesh(shop, new THREE.BoxGeometry(0.025, 2.97, 0.03), goldTrim, 3.42, 2.15, 0.29);

  // ==== THE BIG WINDOWS — the main event ====
  // Two large plate glass windows flanking a centre door
  // These are BRIGHTLY lit from inside — the warm glow of the chippy

  // LEFT WINDOW (larger)
  var leftWinGlass = new THREE.Mesh(new THREE.PlaneGeometry(2.3, 2.5),
    new THREE.MeshBasicMaterial({ color: 0xffe8b0, transparent: true, opacity: 0.65 }));
  leftWinGlass.position.set(-0.7, 2.0, 0.35);
  shop.add(leftWinGlass);
  // Window frame
  placeMesh(shop, new THREE.BoxGeometry(2.4, 2.6, 0.05), shopRed, -0.7, 2.0, 0.28);
  placeMesh(shop, new THREE.BoxGeometry(2.32, 2.52, 0.03), darkRed, -0.7, 2.0, 0.31);
  // Mullion (vertical divider in middle of window)
  placeMesh(shop, new THREE.BoxGeometry(0.04, 2.5, 0.05), shopRed, -0.7, 2.0, 0.36);
  // Transom (horizontal bar about 2/3 up)
  placeMesh(shop, new THREE.BoxGeometry(2.3, 0.04, 0.05), shopRed, -0.7, 2.8, 0.36);

  // RIGHT WINDOW
  var rightWinGlass = new THREE.Mesh(new THREE.PlaneGeometry(2.3, 2.5),
    new THREE.MeshBasicMaterial({ color: 0xffe8b0, transparent: true, opacity: 0.65 }));
  rightWinGlass.position.set(1.7, 2.0, 0.35);
  shop.add(rightWinGlass);
  placeMesh(shop, new THREE.BoxGeometry(2.4, 2.6, 0.05), shopRed, 1.7, 2.0, 0.28);
  placeMesh(shop, new THREE.BoxGeometry(2.32, 2.52, 0.03), darkRed, 1.7, 2.0, 0.31);
