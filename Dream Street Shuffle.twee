placeMesh(pub, new THREE.BoxGeometry(0.02, 1.4, 0.02), darkTimber, w1x - 0.18, 5.5, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.02, 1.4, 0.02), darkTimber, w1x + 0.18, 5.5, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.7, 0.02, 0.02), darkTimber, w1x, 5.5, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.7, 0.02, 0.02), darkTimber, w1x, 5.15, 0.34);
placeMesh(pub, new THREE.BoxGeometry(0.7, 0.02, 0.02), darkTimber, w1x, 5.85, 0.34);
// Stone sill below
placeMesh(pub, new THREE.BoxGeometry(0.9, 0.07, 0.14), sillMat, w1x, 4.75, 0.3);
// Timber lintel above
placeMesh(pub, new THREE.BoxGeometry(0.9, 0.1, 0.1), darkTimber, w1x, 6.28, 0.28);
}

// ---- HERCULES FIGURE (mounted between upper floors) ----
var hercBody = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.06, 0.5, 6), goldMat);
hercBody.position.set(1.25, 7.5, 0.35);
pub.add(hercBody);
