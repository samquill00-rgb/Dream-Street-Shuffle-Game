    var o2 = ac.createOscillator(); o2.type='triangle';
    o2.frequency.value = 1400;
    var g2 = ac.createGain();
    g2.gain.setValueAtTime(0, now);
    g2.gain.linearRampToValueAtTime(0.04, now+0.005);
    g2.gain.exponentialRampToValueAtTime(0.001, now+0.12);
    o2.connect(g2); g2.connect(ac.destination);
    o2.start(now); o2.stop(now+0.13);
      });
  }
  // Pen scratch — short scratchy noise (writing in the notebook)
  function penScratch() {
    _play(function(ac) {
    var dur = 0.55, now = ac.currentTime;
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    // Multi-pulse noise — sounds like the back-and-forth of nib on paper
    for (var i = 0; i < bufLen; i++) {
      var t = i / ac.sampleRate;
      var env = Math.exp(-Math.pow((t - 0.1) / 0.18, 2)) * (0.6 + 0.4 * Math.sin(t * 38));
      d[i] = (Math.random()*2-1) * env;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var f = ac.createBiquadFilter(); f.type='bandpass';
    f.frequency.value = 2400; f.Q.value = 1.2;
    var g = ac.createGain(); g.gain.value = 0.22;
    src.connect(f); f.connect(g); g.connect(ac.destination);
    src.start(now);
      });
  }
  // Heartbeat — two soft thuds, deep
  function heartbeat(beats) {
    _play(function(ac) {
    beats = beats || 3;
    var now = ac.currentTime;
    var t0 = now;
    // Steady rhythm — even spacing between beats.
    for (var b = 0; b < beats; b++) {
      var interval = 0.85;
      [0, 0.18].forEach(function(off, idx) {
        var t = t0 + off;
        var o = ac.createOscillator(); o.type='sine';
        o.frequency.setValueAtTime(120, t);
        o.frequency.exponentialRampToValueAtTime(70, t+0.13);
        var g = ac.createGain();
        var amp = idx === 0 ? 0.28 : 0.20;
        g.gain.setValueAtTime(0.001, t);
        g.gain.linearRampToValueAtTime(amp, t+0.012);
        g.gain.exponentialRampToValueAtTime(0.001, t+0.16);
        o.connect(g); g.connect(ac.destination);
        o.start(t); o.stop(t+0.18);
      });
      t0 += interval;
    }
      });
  }
  // Paper rustle — slow, spacious page turn.
  // Soft attack (gentle lift), long decay (settles into silence), papery
  // mid-range rather than hissy highs. A subtle low whump under it gives
  // the page some physical weight as it's grasped and folded over.
  function pageRustle() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Main rustle — slow envelope, band-passed into a papery range
    var dur = 1.1;
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) {
      var t = i / ac.sampleRate;
      var attack = Math.min(1, t / 0.10);            // ~100ms gentle rise
      var decay = Math.exp(-t / 0.45);                // long, settling tail
      d[i] = (Math.random()*2-1) * attack * decay * 0.42;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var hp = ac.createBiquadFilter(); hp.type='highpass';
    hp.frequency.value = 700; hp.Q.value = 0.7;
    var lp = ac.createBiquadFilter(); lp.type='lowpass';
    lp.frequency.value = 5200; lp.Q.value = 0.5;
    var g = ac.createGain(); g.gain.value = 0.32;
    src.connect(hp); hp.connect(lp); lp.connect(g); g.connect(ac.destination);
    src.start(now);
    // Low whump under the rustle — page being lifted from the spine.
    var o = ac.createOscillator(); o.type='sine';
    o.frequency.setValueAtTime(105, now);
    o.frequency.exponentialRampToValueAtTime(55, now + 0.32);
    var og = ac.createGain();
    og.gain.setValueAtTime(0, now);
    og.gain.linearRampToValueAtTime(0.09, now + 0.05);
    og.gain.exponentialRampToValueAtTime(0.001, now + 0.42);
    o.connect(og); og.connect(ac.destination);
    o.start(now); o.stop(now + 0.45);
      });
  }
  // Page shuffle — 4-5 layered rustles at slightly different pitches and
  // offsets, so it sounds like several pages riffling past each other rather
  // than a single sheet being turned. Used by the critic widget.
  function pageShuffle() {
    _play(function(ac) {
      var now = ac.currentTime;
      var bursts = 4 + Math.floor(Math.random() * 2); // 4 or 5
      for (var b = 0; b < bursts; b++) {
        var burstDur = 0.16 + Math.random() * 0.10;
        var bufLen = Math.floor(ac.sampleRate * burstDur);
        var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
        var d = buf.getChannelData(0);
        // Sharper attack, faster decay than pageRustle — short paper slip
        var decayTau = 0.045 + Math.random() * 0.025;
        for (var i = 0; i < bufLen; i++) {
          var env = Math.exp(-i / (ac.sampleRate * decayTau));
          // brief rise at the start so each slip has a tiny "scrape" attack
          var attack = Math.min(1, i / (ac.sampleRate * 0.005));
          d[i] = (Math.random()*2-1) * env * attack * 0.55;
        }
        var src = ac.createBufferSource(); src.buffer = buf;
        // Vary filter centre per burst — each "page" reads as a different sheet
        var hp = ac.createBiquadFilter(); hp.type='highpass';
        hp.frequency.value = 1400 + Math.random() * 1200; // 1400-2600 Hz
        hp.Q.value = 0.9 + Math.random() * 0.8;
        // Light low-pass on top to cut harshness
        var lp = ac.createBiquadFilter(); lp.type='lowpass';
        lp.frequency.value = 7000 + Math.random() * 2500;
        // Per-burst gain — make first burst loudest, taper slightly
        var g = ac.createGain();
        g.gain.value = (0.42 - b * 0.04) * (0.85 + Math.random() * 0.3);
        src.connect(hp); hp.connect(lp); lp.connect(g); g.connect(ac.destination);
        var startOffset = b * (0.07 + Math.random() * 0.06); // 70-130ms gaps
        src.start(now + startOffset);
      }
      // Subtle low thump under the whole shuffle — the book settling under
      // the thumb. Very quiet, gives the rustle some physical weight.
      var thumpDur = 0.18;
      var tBufLen = Math.floor(ac.sampleRate * thumpDur);
      var tBuf = ac.createBuffer(1, tBufLen, ac.sampleRate);
      var td = tBuf.getChannelData(0);
      for (var j = 0; j < tBufLen; j++) {
        var tEnv = Math.exp(-j / (ac.sampleRate * 0.035));
        td[j] = (Math.random()*2-1) * tEnv * 0.4;
      }
      var tSrc = ac.createBufferSource(); tSrc.buffer = tBuf;
      var tlp = ac.createBiquadFilter(); tlp.type='lowpass';
      tlp.frequency.value = 280;
      var tg = ac.createGain(); tg.gain.value = 0.22;
      tSrc.connect(tlp); tlp.connect(tg); tg.connect(ac.destination);
      tSrc.start(now + 0.02);
    });
  }
  // Glass smash — sharp noise burst, high frequency content, with a
  // convolution-reverb tail so it sounds like the glass broke in a pub
  // room rather than a vacuum.
  function glassSmash() {
    _play(function(ac) {
    var dur = 0.7, now = ac.currentTime;

    // ── Synthetic reverb impulse response (stereo) ─────────────────
    // ~1.6s exponential-decay noise IR — gives the smash a natural
    // room tail. Pre-baked per-call so we don't carry state.
    var revDur = 1.6;
    var irLen = Math.floor(ac.sampleRate * revDur);
    var ir = ac.createBuffer(2, irLen, ac.sampleRate);
    for (var ch = 0; ch < 2; ch++) {
      var data = ir.getChannelData(ch);
      for (var i = 0; i < irLen; i++) {
        var tt = i / ac.sampleRate;
        var decay = Math.pow(1 - tt / revDur, 2.4);
        data[i] = (Math.random() * 2 - 1) * decay;
      }
    }
    var conv = ac.createConvolver(); conv.buffer = ir;
    // Light high-cut on the wet path — keeps the reverb from sounding harsh
    var wetCut = ac.createBiquadFilter(); wetCut.type = 'lowpass';
    wetCut.frequency.value = 5500;
    var wet = ac.createGain(); wet.gain.value = 0.55;
    var dry = ac.createGain(); dry.gain.value = 0.85;
    conv.connect(wetCut); wetCut.connect(wet); wet.connect(ac.destination);
    dry.connect(ac.destination);

    // ── Smash core (noise burst) ──────────────────────────────────
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) {
      var t = i / ac.sampleRate;
      var env = Math.exp(-t * 6) + Math.exp(-t * 16) * 0.6;
      d[i] = (Math.random()*2-1) * env;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var f = ac.createBiquadFilter(); f.type='highpass';
    f.frequency.value = 2000; f.Q.value = 0.7;
    var g = ac.createGain(); g.gain.value = 0.5;
    src.connect(f); f.connect(g); g.connect(dry); g.connect(conv);
    src.start(now);
    // ── Shimmery tinkles on top — broken-glass sparkle ────────────
    for (var k = 0; k < 5; k++) {
      var t0 = now + 0.08 + Math.random() * 0.4;
      var o = ac.createOscillator(); o.type='triangle';
      o.frequency.value = 3200 + Math.random() * 2200;
      var og = ac.createGain();
      og.gain.setValueAtTime(0, t0);
      og.gain.linearRampToValueAtTime(0.06, t0+0.005);
      og.gain.exponentialRampToValueAtTime(0.001, t0+0.18);
      o.connect(og); og.connect(dry); og.connect(conv);
      o.start(t0); o.stop(t0+0.2);
    }
      });
  }
  // Match strike — quick scratch then warm flame whoosh
  function matchStrike() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Scratch (short noisy burst, mid-band)
    var scrDur = 0.12;
    var bufLen = Math.floor(ac.sampleRate * scrDur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) {
      var t = i / ac.sampleRate;
      var env = Math.exp(-t * 12) * (0.7 + 0.3 * Math.sin(t * 90));
      d[i] = (Math.random()*2-1) * env;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var sf = ac.createBiquadFilter(); sf.type='bandpass';
    sf.frequency.value = 2400; sf.Q.value = 1.5;
    var sg = ac.createGain(); sg.gain.value = 0.4;
    src.connect(sf); sf.connect(sg); sg.connect(ac.destination);
    src.start(now);
    // Flame whoosh (low-frequency noise, fade in then out)
    var whoDur = 0.6, whoStart = now + 0.08;
    var wbufLen = Math.floor(ac.sampleRate * whoDur);
    var wbuf = ac.createBuffer(1, wbufLen, ac.sampleRate);
    var wd = wbuf.getChannelData(0);
    for (var j = 0; j < wbufLen; j++) wd[j] = (Math.random()*2-1) * 0.5;
    var wsrc = ac.createBufferSource(); wsrc.buffer = wbuf;
    var wf = ac.createBiquadFilter(); wf.type='lowpass';
    wf.frequency.value = 600; wf.Q.value = 1;
    var wg = ac.createGain();
    wg.gain.setValueAtTime(0, whoStart);
    wg.gain.linearRampToValueAtTime(0.18, whoStart + 0.1);
    wg.gain.exponentialRampToValueAtTime(0.001, whoStart + whoDur);
    wsrc.connect(wf); wf.connect(wg); wg.connect(ac.destination);
    wsrc.start(whoStart); wsrc.stop(whoStart + whoDur);
      });
  }
  // Coin flip — quick rising-falling tone (spinning) then small landing tink
  function coinFlip() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Tinny coin: high-frequency metallic pings with very fast attack and
    // short decay. Each ping is a brief noise transient (the tap) plus
    // a high-frequency ring with inharmonic partials (the metal singing).
    var jingles = [
      { t: 0.00, base: 4200, amp: 0.06 },
      { t: 0.07, base: 4600, amp: 0.05 },
      { t: 0.16, base: 3900, amp: 0.055 },
      { t: 0.27, base: 4900, amp: 0.045 },
      { t: 0.40, base: 4300, amp: 0.05 },
      { t: 0.54, base: 4500, amp: 0.04 }
    ];
    jingles.forEach(function(j) {
      var t = now + j.t;
      // Tiny noise transient — the metallic "tap"
      var nLen = Math.floor(ac.sampleRate * 0.004);
      var nbuf = ac.createBuffer(1, nLen, ac.sampleRate);
      var nd = nbuf.getChannelData(0);
      for (var k = 0; k < nLen; k++) nd[k] = (Math.random()*2-1) * Math.exp(-k/nLen * 6);
      var nsrc = ac.createBufferSource(); nsrc.buffer = nbuf;
      var nf = ac.createBiquadFilter(); nf.type='highpass'; nf.frequency.value = 3500;
      var ng = ac.createGain(); ng.gain.value = j.amp * 0.35;
      nsrc.connect(nf); nf.connect(ng); ng.connect(ac.destination);
      nsrc.start(t);
      // High metallic ring — fast attack, fast decay (~80ms)
      [1, 1.94, 3.36, 5.12].forEach(function(ratio, idx) {
        var o = ac.createOscillator(); o.type='sine';
        o.frequency.value = j.base * ratio;
        var g = ac.createGain();
        var amp = j.amp / (idx + 1);
        g.gain.setValueAtTime(0.001, t);
        g.gain.linearRampToValueAtTime(amp, t + 0.001);
        g.gain.exponentialRampToValueAtTime(0.001, t + 0.09);
        o.connect(g); g.connect(ac.destination);
        o.start(t); o.stop(t + 0.10);
      });
    });
    // Landing — tinny triple-tap as the coin bounces and settles
    var landTimes = [0.92, 0.98, 1.02];
    landTimes.forEach(function(off, i) {
      var t0 = now + off;
      [4400, 5800, 7200].forEach(function(freq, idx) {
        var o = ac.createOscillator(); o.type='sine';
        o.frequency.value = freq + Math.random() * 250;
        var g = ac.createGain();
        var amp = (idx === 0 ? 0.05 : (idx === 1 ? 0.03 : 0.015)) * (1 - i * 0.35);
        g.gain.setValueAtTime(0.001, t0);
        g.gain.linearRampToValueAtTime(amp, t0 + 0.001);
        g.gain.exponentialRampToValueAtTime(0.001, t0 + 0.12);
        o.connect(g); g.connect(ac.destination);
        o.start(t0); o.stop(t0 + 0.13);
      });
    });
      });
  }
  // Door creak then a tiny pub-bell ding
  function doorCreak() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Creak: low-mid filtered noise with frequency wobble
    var crkDur = 0.7;
    var bufLen = Math.floor(ac.sampleRate * crkDur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) {
      var t = i / ac.sampleRate;
      var env = Math.exp(-Math.pow((t - 0.3) / 0.22, 2));
      d[i] = (Math.random()*2-1) * env * 0.5;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var f = ac.createBiquadFilter(); f.type='bandpass';
    f.frequency.setValueAtTime(280, now);
    f.frequency.linearRampToValueAtTime(420, now + crkDur);
    f.Q.value = 4;
    var g = ac.createGain(); g.gain.value = 0.3;
    src.connect(f); f.connect(g); g.connect(ac.destination);
    src.start(now);
    // Bell ding at ~0.6s in (when door is fully open)
    var t0 = now + 0.6;
    [1100, 1650].forEach(function(freq, idx) {
      var o = ac.createOscillator(); o.type='sine'; o.frequency.value = freq;
      var og = ac.createGain();
      var amp = idx === 0 ? 0.07 : 0.045;
      og.gain.setValueAtTime(0, t0);
      og.gain.linearRampToValueAtTime(amp, t0 + 0.005);
      og.gain.exponentialRampToValueAtTime(0.001, t0 + 0.9);
      o.connect(og); og.connect(ac.destination);
      o.start(t0); o.stop(t0 + 1.0);
    });
      });
  }
  // Quick swing door with a brass bell ping — Trisha's after-hours feel:
  // a light wood-on-wood thump (the door pushes open), then a clean
  // double-bell ring as the brass hits the strike plate.
  function doorSwingBell() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Thump: short low-mid noise burst with a brief lowpass squeeze.
      var thLen = Math.floor(ac.sampleRate * 0.18);
      var thBuf = ac.createBuffer(1, thLen, ac.sampleRate);
      var td = thBuf.getChannelData(0);
      for (var i = 0; i < thLen; i++) {
        var env = Math.exp(-i / (ac.sampleRate * 0.04));
        td[i] = (Math.random() * 2 - 1) * env;
      }
      var thSrc = ac.createBufferSource(); thSrc.buffer = thBuf;
      var thLp  = ac.createBiquadFilter(); thLp.type = 'lowpass';
      thLp.frequency.value = 240; thLp.Q.value = 0.9;
      var thG = ac.createGain(); thG.gain.value = 0.42;
      thSrc.connect(thLp); thLp.connect(thG); thG.connect(ac.destination);
      thSrc.start(now);
      // Brass bell — two close ringing sines with a tiny detune, started
      // ~120ms after the thump.
      var bt = now + 0.12;
      [1620, 2440].forEach(function(freq, idx) {
        var o = ac.createOscillator(); o.type = 'sine';
        o.frequency.value = freq * (1 + (Math.random() - 0.5) * 0.004);
        var og = ac.createGain();
        var amp = idx === 0 ? 0.16 : 0.10;
        og.gain.setValueAtTime(0.0001, bt);
        og.gain.linearRampToValueAtTime(amp, bt + 0.004);
        og.gain.exponentialRampToValueAtTime(0.0008, bt + 0.85);
        o.connect(og); og.connect(ac.destination);
        o.start(bt); o.stop(bt + 0.95);
      });
      // A second softer ping ~150ms later, like the bell rebounds.
      var bt2 = bt + 0.15;
      var o2 = ac.createOscillator(); o2.type = 'sine';
      o2.frequency.value = 2480;
      var o2g = ac.createGain();
      o2g.gain.setValueAtTime(0.0001, bt2);
      o2g.gain.linearRampToValueAtTime(0.06, bt2 + 0.004);
      o2g.gain.exponentialRampToValueAtTime(0.0006, bt2 + 0.5);
      o2.connect(o2g); o2g.connect(ac.destination);
      o2.start(bt2); o2.stop(bt2 + 0.55);
    });
  }
  // Velvet curtain at Ronnie Scott's — no creak, no bell. Just a soft
  // muffled "wuff" as the heavy fabric passes you, with a hint of cloth
  // rustle on top. The signature "you have entered a different room."
  function doorThud() {
    _play(function(ac) {
      var now = ac.currentTime;
      // Low woofy thud — sine sweeping down + filtered noise body.
      var thOsc = ac.createOscillator(); thOsc.type = 'sine';
      thOsc.frequency.setValueAtTime(120, now);
      thOsc.frequency.exponentialRampToValueAtTime(48, now + 0.45);
      var thG = ac.createGain();
      thG.gain.setValueAtTime(0.0001, now);
      thG.gain.exponentialRampToValueAtTime(0.42, now + 0.025);
      thG.gain.exponentialRampToValueAtTime(0.0001, now + 0.6);
      thOsc.connect(thG); thG.connect(ac.destination);
      thOsc.start(now); thOsc.stop(now + 0.65);
