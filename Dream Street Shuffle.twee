// ---- CHIMNEYS ----
var chimMat = new THREE.MeshStandardMaterial({ color: 0xa09080, roughness: 0.85 });
placeMesh(pub, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -0.5, 13.5, -2);
placeMesh(pub, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, 3.0, 13.5, -2);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, -0.5, 14.3, -2);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, 3.0, 14.3, -2);

// ---- HANGING PUB SIGN (on bracket projecting from facade) ----
var signTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  cx.fillStyle = '#1a1510';
  cx.fillRect(0, 0, w, h);
  cx.strokeStyle = '#c0a040'; cx.lineWidth = 3;
  cx.strokeRect(5, 5, w - 10, h - 10);
  cx.fillStyle = '#c8a840';
  cx.font = 'bold 14px Georgia'; cx.textAlign = 'center';
  cx.fillText('PILLARS', w/2, 38);
  cx.fillText('OF', w/2, 58);
  cx.fillText('HERCULES', w/2, 78);
  cx.font = '9px Georgia';
  cx.fillText('FREE HOUSE', w/2, 105);
});
var signMat = new THREE.MeshStandardMaterial({ map: signTex, roughness: 0.5, side: THREE.DoubleSide });
var hangSign = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.8), signMat);
hangSign.position.set(3.6, 3.8, 1.8);
pub.add(hangSign);
// Bracket arm
var bracketMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
placeMesh(pub, new THREE.BoxGeometry(1.4, 0.04, 0.04), bracketMat, 3.2, 4.25, 1.0);
placeMesh(pub, new THREE.BoxGeometry(0.04, 0.5, 0.04), bracketMat, 3.6, 4.05, 1.8);
// Decorative scrollwork on bracket (simple curved suggestion)
placeMesh(pub, new THREE.BoxGeometry(0.5, 0.03, 0.03), bracketMat, 2.8, 4.1, 1.0);

// ---- DRAINPIPE on right edge of building ----
placeMesh(pub, new THREE.CylinderGeometry(0.04, 0.04, 12, 6), pipeMat, 4.0, 6, 0.3);
placeMesh(pub, new THREE.BoxGeometry(0.12, 0.05, 0.12), pipeMat, 4.0, 3.5, 0.3);
placeMesh(pub, new THREE.BoxGeometry(0.12, 0.05, 0.12), pipeMat, 4.0, 8.0, 0.3);

// Warm interior glow spilling from pub windows
var pubGlow = new THREE.PointLight(0xffd080, 1.2, 10);
pubGlow.position.set(2.0, 1.5, 2);
pub.add(pubGlow);

// Second interior glow (fills out the ground floor)
var pubGlow2 = new THREE.PointLight(0xffd060, 0.6, 8);
pubGlow2.position.set(3.0, 1.5, 1.5);
pub.add(pubGlow2);

// Third interior glow (deeper warmth)
