.5" opacity="0.3"/><rect x="140" y="48" width="3" height="29" fill="#503828" opacity="0.25"/><rect x="350" y="42" width="3" height="35" fill="#503828" opacity="0.2"/><path d="M348,42 L356,42" stroke="#503828" stroke-width="0.8" opacity="0.15"/><circle cx="180" cy="82" r="0.8" fill="#d4600a" opacity="0.25"/><circle cx="320" cy="80" r="0.6" fill="#c84a08" opacity="0.2"/><circle cx="160" cy="84" r="0.5" fill="#ff8020" opacity="0.15"/><circle cx="340" cy="83" r="0.7" fill="#d4600a" opacity="0.2"/><rect x="0" y="0" width="500" height="95" fill="url(#cpTopFade)"/><rect x="0" y="0" width="500" height="95" fill="url(#cpFade)"/></svg>
<div class="dream-sequence">
You stay for an hour or forever.

Her pyre burns down while you're close and all through the night, the body in its flames transforms, hanging the Lily-of-the-Valley on your nose that desires it; on the path of an asymptote, to something infinitesimally-not-her.

Close now to dawn, then again very close to the dawn, you hear three lines:

<em>(print: $alba1)
(print: $alba2)
(print: $alba3)</em>

This is the poem, whole, but you can't take it with you.

Polybius: What do you mean by England? Why do you damn your country with its name?

[[Wake suddenly|The Interval]]
</div>

:: Success: Trisha's {"position":"2100,1450","size":"100,100"}
As you walk in you see a woman who was a friend of yours years ago, who somehow keeps some part in your affections. Her voice reminds you somebody else you used to see in Soho, who was a friend of John St. John's, when you were all much younger than this. Soho is hers now; she knows all the bouncers. In you go.

[[Trisha's|Trisha's]]

:: Talk to the Artists {"position":"500,650","size":"100,100"}
<svg class="french-rule" viewBox="0 0 300 44" width="100%" height="44" preserveAspectRatio="none"><defs><linearGradient id="frAmb" x1="0" x2="1"><stop offset="0%" stop-color="#a06010" stop-opacity="0"/><stop offset="10%" stop-color="#b07020" stop-opacity="0.6"/><stop offset="50%" stop-color="#c88020" stop-opacity="0.72"/><stop offset="90%" stop-color="#b07020" stop-opacity="0.6"/><stop offset="100%" stop-color="#a06010" stop-opacity="0"/></linearGradient><linearGradient id="frLn" x1="0" x2="1"><stop offset="0%" stop-color="#c8a86a" stop-opacity="0"/><stop offset="10%" stop-color="#c8a86a" stop-opacity="0.95"/><stop offset="90%" stop-color="#c8a86a" stop-opacity="0.95"/><stop offset="100%" stop-color="#c8a86a" stop-opacity="0"/></linearGradient></defs><rect x="0" y="16" width="300" height="22" fill="url(#frAmb)"/><line x1="0" y1="16" x2="300" y2="16" stroke="url(#frLn)" stroke-width="2"/><line x1="0" y1="38" x2="300" y2="38" stroke="url(#frLn)" stroke-width="2"/><rect x="61" y="21" width="8" height="16" rx="1" fill="#002395"/><rect x="63" y="17" width="4" height="6" rx="1" fill="#002395"/><rect x="79" y="19" width="9" height="18" rx="1" fill="#f0f0f0"/><rect x="81" y="16" width="5" height="5" rx="1" fill="#f0f0f0"/><rect x="97" y="20" width="7" height="17" rx="1" fill="#ed2939"/><rect x="99" y="17" width="3" height="5" rx="1" fill="#ed2939"/><rect x="197" y="21" width="8" height="16" rx="1" fill="#002395"/><rect x="199" y="17" width="4" height="6" rx="1" fill="#002395"/><rect x="215" y="19" width="9" height="18" rx="1" fill="#f0f0f0"/><rect x="217" y="16" width="5" height="5" rx="1" fill="#f0f0f0"/><rect x="233" y="20" width="7" height="17" rx="1" fill="#ed2939"/><rect x="235" y="17" width="3" height="5" rx="1" fill="#ed2939"/><polygon points="150,20 155,27 150,34 145,27" fill="#c8a86a" opacity="0.8"/><polygon points="150,22 153,27 150,32 147,27" fill="#a06010" opacity="0.85"/></svg>

You move towards their table, floating, as it were, a thumb's-width above the brown, oak floor.

They do not look up. You're about to bottle it when somebody speaks your name.

Among them is a face you recognise and he's greeting you now. He is a Spaniard from El Rocío, in Andalusia, named Benito de los Juncales del Este. He painted you and Ashton Granger once, when you were lovers, years ago in Cordoba.

<div class="verse">
My mediaeval knees lack health until they bend,<br>
But in that woman, in that household where<br>
Honour had lived so long, all lacking found.<br>
Childless I thought, 'My children may find here<br>
Deep-rooted things,' but never foresaw its end,<br>
And now that end has come I have not wept;<br>
No fox can foul the lair the badger swept.
</div>

You think of this, from Spenser and from Yeats, as you say hello.

[[Sit with him|The Spanish Artist]]

<svg class="french-rule" viewBox="0 0 300 24" width="100%" height="24" preserveAspectRatio="none"><defs><linearGradient id="frC" x1="0" x2="1"><stop offset="0%" stop-color="#c8a86a" stop-opacity="0"/><stop offset="45%" stop-color="#c8a86a" stop-opacity="0.55"/><stop offset="100%" stop-color="#c8a86a" stop-opacity="0"/></linearGradient><linearGradient id="frD" x1="0" x2="1"><stop offset="0%" stop-color="#c8a86a" stop-opacity="0"/><stop offset="45%" stop-color="#c8a86a" stop-opacity="0.28"/><stop offset="100%" stop-color="#c8a86a" stop-opacity="0"/></linearGradient></defs><line x1="0" y1="7" x2="300" y2="7" stroke="url(#frD)" stroke-width="0.5"/><line x1="0" y1="12" x2="300" y2="12" stroke="url(#frC)" stroke-width="1.2"/><svg x="140" y="0" width="20" height="24" viewBox="-12 -2 24 26" preserveAspectRatio="xMidYMid meet"><g fill="#c8a86a" opacity="0.75"><path d="M0,15 C-3,10 -4,2 0,-1 C4,2 3,10 0,15Z"/><path d="M-1,13 C-4,10 -8,5 -9,3 C-9,5 -8,6 -6,5 C-3,8 -1,11 0,13Z"/><path d="M1,13 C4,10 8,5 9,3 C9,5 8,6 6,5 C3,8 1,11 0,13Z"/><rect x="-8" y="14" width="16" height="2.5" rx="0.5"/><ellipse cx="0" cy="20" rx="2.5" ry="2"/></g></svg></svg>

:: Talk to the critic {"position":"500,1100","size":"100,100"}
<div class="pillars-scene">
<!-- Left broken pillar — Piranesi/Decline & Fall style -->
<svg class="pillar left" viewBox="0 0 34 280" preserveAspectRatio="xMidYMax meet"><defs><linearGradient id="pf" x1="0" x2="0" y1="0" y2="1"><stop offset="0%"   stop-color="#8ac8dc" stop-opacity="0.72"/><stop offset="60%"  stop-color="#8ac8dc" stop-opacity="0.42"/><stop offset="100%" stop-color="#8ac8dc" stop-opacity="0"/></linearGradient></defs><!-- Two-step plinth base --><rect x="1"  y="252" width="32" height="8"  fill="none" stroke="url(#pf)" stroke-width="1.1"/><rect x="4"  y="246" width="26" height="7"  fill="none" stroke="url(#pf)" stroke-width="1"/><!-- Shaft edges (slight taper: 24px wide at top, 26px at base) --><line x1="5"  y1="246" x2="6"  y2="88" stroke="url(#pf)" stroke-width="1.1"/><line x1="29" y1="246" x2="28" y2="88" stroke="url(#pf)" stroke-width="1.1"/><!-- Drum course bands every 22px --><line x1="5.3" y1="110" x2="28.7" y2="110" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="132" x2="28.5" y2="132" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="154" x2="28.5" y2="154" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="176" x2="28.5" y2="176" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="198" x2="28.5" y2="198" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="220" x2="28.5" y2="220" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="242" x2="28.5" y2="242" stroke="url(#pf)" stroke-width="0.65"/><!-- Faint fluting --><line x1="10" y1="88" x2="10" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="14" y1="88" x2="14" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="17" y1="88" x2="17" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="20" y1="88" x2="20" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="24" y1="88" x2="24" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><!-- Echinus (curved capital swell) --><path d="M6,88 Q5,78 3,72 L31,72 Q29,78 28,88" fill="none" stroke="url(#pf)" stroke-width="1.1"/><!-- Abacus slab — CRACKED, left portion collapsed inward --><!-- Right surviving portion: tilting down-left --><path d="M12,72 L32,68 L33,63 L13,66 Z" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.6"/><!-- Left fallen piece: a slab lying at an angle, partly off the shaft --><path d="M2,74 L-2,70 L8,67 L11,72 Z" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.45"/><!-- Fracture line across shaft top --><path d="M6,88 L9,83 L13,87 L17,80 L21,86 L25,79 L28,88" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.55"/><!-- A fallen drum section leaning against the shaft at ~1/3 height --><path d="M1,168 L3,160 L9,162 L9,170 L3,172 Z" fill="none" stroke="#8ac8dc" stroke-width="0.85" opacity="0.32"/><!-- Crack on shaft face --><path d="M13,130 L15,142 L12,150" fill="none" stroke="#8ac8dc" stroke-width="0.5" opacity="0.28"/><!-- Rubble at base --><path d="M3,255  L9,255  L10,260 L2,260 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.8" opacity="0.28"/><path d="M21,257 L28,257 L29,262 L20,261 Z" fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.22"/><path d="M13,260 L18,259 L19,264 L12,263 Z" fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.2"/></svg>
<!-- Right pillar — same shape, scaleX(-1) mirrors it so break faces inward -->
<svg class="pillar right" viewBox="0 0 34 280" preserveAspectRatio="xMidYMax meet"><defs><linearGradient id="pf2" x1="0" x2="0" y1="0" y2="1"><stop offset="0%"   stop-color="#8ac8dc" stop-opacity="0.72"/><stop offset="60%"  stop-color="#8ac8dc" stop-opacity="0.42"/><stop offset="100%" stop-color="#8ac8dc" stop-opacity="0"/></linearGradient></defs><rect x="1"  y="252" width="32" height="8"  fill="none" stroke="url(#pf2)" stroke-width="1.1"/><rect x="4"  y="246" width="26" height="7"  fill="none" stroke="url(#pf2)" stroke-width="1"/><!-- Shorter shaft: top at y=130 instead of y=88 — this pillar more ruined --><line x1="5"  y1="246" x2="6"  y2="130" stroke="url(#pf2)" stroke-width="1.1"/><line x1="29" y1="246" x2="28" y2="130" stroke="url(#pf2)" stroke-width="1.1"/><line x1="5.5" y1="152" x2="28.5" y2="152" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="174" x2="28.5" y2="174" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="196" x2="28.5" y2="196" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="218" x2="28.5" y2="218" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="240" x2="28.5" y2="240" stroke="url(#pf2)" stroke-width="0.65"/><line x1="10" y1="130" x2="10" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="14" y1="130" x2="14" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="17" y1="130" x2="17" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="20" y1="130" x2="20" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="24" y1="130" x2="24" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><!-- Echinus at top of shorter shaft --><path d="M6,130 Q5,120 3,114 L31,114 Q29,120 28,130" fill="none" stroke="url(#pf2)" stroke-width="1.1"/><!-- This column: abacus has COLLAPSED entirely — jagged stump and tilted block --><path d="M3,114 L6,107 L10,112 L14,104 L18,110 L22,102 L27,108 L31,114" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.6"/><!-- Large fallen capital block --><path d="M2,106 L-3,98 L14,94 L17,104 Z" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.5"/><!-- Fracture running down shaft --><path d="M6,130 L9,125 L13,129 L17,122 L21,128 L25,121 L28,130" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.55"/><path d="M9,142 L11,158 L8,164" fill="none" stroke="#8ac8dc" stroke-width="0.5" opacity="0.28"/><!-- Fallen drum leaning against shaft --><path d="M1,215 L3,207 L9,209 L9,217 L3,219 Z" fill="none" stroke="#8ac8dc" stroke-width="0.85" opacity="0.3"/><!-- Rubble at base --><path d="M3,255 L9,255 L10,260 L2,260 Z"    fill="none" stroke="#8ac8dc" stroke-width="0.8" opacity="0.28"/><path d="M22,257 L29,257 L30,262 L21,261 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.22"/><path d="M11,260 L17,259 L18,264 L10,263 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.2"/></svg>
<!-- Lattice pub window at top -->
<svg class="pillars-lattice" viewBox="0 0 300 36" width="100%" height="36" preserveAspectRatio="none"><defs><linearGradient id="latEdge" x1="0" x2="1"><stop offset="0%"   stop-color="#7ab8cc" stop-opacity="0"/><stop offset="15%"  stop-color="#7ab8cc" stop-opacity="0.55"/><stop offset="85%"  stop-color="#7ab8cc" stop-opacity="0.55"/><stop offset="100%" stop-color="#7ab8cc" stop-opacity="0"/></linearGradient><pattern id="dLat" x="0" y="0" width="14" height="24" patternUnits="userSpaceOnUse"><path d="M7,0 L14,12 L7,24 L0,12 Z" fill="none" stroke="#7ab8cc" stroke-width="0.7" opacity="0.48"/></pattern><mask id="latMask"><rect x="0" y="0" width="300" height="36" fill="url(#latEdge)"/></mask></defs><rect x="0" y="0" width="300" height="36" fill="url(#dLat)" mask="url(#latMask)"/><line x1="0" y1="34" x2="300" y2="34" stroke="url(#latEdge)" stroke-width="1.2"/></svg>

You meet him, at the bar with a big scotch in one hand and a fag in the other.

He's getting a round in: what do you order?

[[Gin and Bitter Lemon|Gin and bitter lemon]]
</div>

:: Talk to the intimidating agent {"position":"1400,700","size":"100,100"}
(set: $confidence to $confidence + 12)\
(set: $sobriety to $sobriety + 8)
'You write, too?' she says, having never written anything in her life that anyone's read and looks over your shoulder.

You leave and as you go, she presses something small into your palm.

Via the gents, the night sharpens. Things seem possible again.

As you leave, you remember, wholly and as a single thought: Ronnie Scott's, you had forgotten it was there.
(set: $knowsRonnies to true)
<span class="guided-link">[[You remember that Ronnie Scott's is open and close.|Ronnie Scott's]]</span>
[[Back to Dean Street|Dean Street]]

