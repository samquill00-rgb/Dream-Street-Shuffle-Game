var streetLampLights = [];

function createLamp(x, z) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
var pm = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.07, 5, 6), postMat);
pm.position.set(0, 2.5, 0); g.add(pm);
var lampH = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.4, 0.3), postMat);
lampH.position.set(0.3, 5, 0); g.add(lampH);
var lampArm = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.06, 0.06), postMat);
lampArm.position.set(0.15, 5, 0); g.add(lampArm);
var light = new THREE.PointLight(0xffdda0, 0.6, 15);
light.position.set(0.3, 4.8, 0);
light.castShadow = true;
g.add(light);
streetLampLights.push(light);
// Glow sprite
var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(255, 220, 150, 0.8)');
grad.addColorStop(0.3, 'rgba(255, 200, 100, 0.3)');
grad.addColorStop(1, 'rgba(255, 180, 80, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: glowTex, transparent: true, opacity: 0.5 }));
glowSprite.position.set(0.3, 5, 0);
glowSprite.scale.set(3, 3, 1);
g.add(glowSprite);
g.position.set(x, 0, z);
scene.add(g);
}

createLamp(-4, 3.5);
createLamp(5, 3.5);
createLamp(0, 10);

// ============================================================
// SILHOUETTES OF PEOPLE IN PUB WINDOWS
// ============================================================
var silhouettes = [];

function makeSilhouetteTex(seed) {
return makeCanvasTexture(256, 256, function(cx, w, h) {
// Warm amber interior glow background
var bg = cx.createRadialGradient(w/2, h * 0.4, 10, w/2, h * 0.5, w);
bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
cx.fillStyle = bg;
cx.fillRect(0, 0, w, h);

var figureCount = 1 + Math.floor(seed * 2.5);
for (var f = 0; f < figureCount; f++) {
var fx = (w / (figureCount + 1)) * (f + 1);
var baseY = h * 0.98;
var headR = 14 + seed * 6;
var shoulderW = 35 + seed * 15;

cx.fillStyle = 'rgba(10, 5, 0, 0.85)';

// Body
cx.beginPath();
cx.moveTo(fx - shoulderW / 2, baseY - h * 0.35);
cx.lineTo(fx + shoulderW / 2, baseY - h * 0.35);
cx.lineTo(fx + shoulderW / 2 + 8, baseY);
cx.lineTo(fx - shoulderW / 2 - 8, baseY);
cx.closePath();
cx.fill();

// Shoulders
cx.beginPath();
cx.ellipse(fx, baseY - h * 0.38, shoulderW / 2 + 5, 14, 0, 0, Math.PI, true);
cx.fill();

// Neck
cx.fillRect(fx - 6, baseY - h * 0.48, 12, h * 0.1);

// Head
cx.beginPath();
cx.arc(fx + (f - 1) * 4, baseY - h * 0.52, headR, 0, Math.PI * 2);
cx.fill();

// Raised arm with pint
if ((seed > 0.4 && f === 0) || (seed > 0.6 && f === 1)) {
cx.fillStyle = 'rgba(10, 5, 0, 0.8)';
cx.beginPath();
cx.moveTo(fx + shoulderW / 2, baseY - h * 0.38);
cx.lineTo(fx + shoulderW / 2 + 12, baseY - h * 0.6);
cx.lineTo(fx + shoulderW / 2 + 22, baseY - h * 0.6);
cx.lineTo(fx + shoulderW / 2 + 10, baseY - h * 0.35);
cx.closePath();
cx.fill();
cx.fillRect(fx + shoulderW / 2 + 8, baseY - h * 0.7, 16, 22);
cx.fillStyle = 'rgba(180, 130, 40, 0.4)';
cx.fillRect(fx + shoulderW / 2 + 10, baseY - h * 0.68, 12, 14);
}
}
});
}

// Ground floor pub window silhouettes (facing +Z)
var winPositions = [0.5, 1.2, 1.9, 2.6, 3.3];
var winSeeds = [0.3, 0.7, 0.5, 0.8, 0.2];
for (var i = 0; i < winPositions.length; i++) {
var sTex = makeSilhouetteTex(winSeeds[i]);
var sMat = new THREE.MeshBasicMaterial({
map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.45, 1.8), sMat);
sPlane.position.set(winPositions[i], 1.7, 0.58);
pub.add(sPlane);
silhouettes.push({
mesh: sPlane,
baseX: winPositions[i],
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.3 + Math.random() * 0.4,
swayAmt: 0.015 + Math.random() * 0.02
});
}

