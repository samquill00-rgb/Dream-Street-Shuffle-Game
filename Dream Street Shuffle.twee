    f2.frequency.value = 720; f2.Q.value = 3.0;          // mid whistle
    var f3 = ac.createBiquadFilter(); f3.type='lowpass';
    f3.frequency.value = 3200; f3.Q.value = 0.7;         // high sibilance
    var g1 = ac.createGain(); g1.gain.value = 0.60;
    var g2 = ac.createGain(); g2.gain.value = 0.68;
    var g3 = ac.createGain(); g3.gain.value = 0.30;
    var g = ac.createGain();
