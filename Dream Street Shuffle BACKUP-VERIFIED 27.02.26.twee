      <div class="chippy-light bottom"></div>
      <svg class="chippy-tube" viewBox="0 0 300 18" width="100%" height="18" preserveAspectRatio="none">
        <defs>
          <filter id="fgA" x="-20%" y="-120%" width="140%" height="400%">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        <!-- Cold blue outer glow -->
        <rect x="14" y="1" width="272" height="16" rx="6" fill="rgba(180,210,255,0.22)" filter="url(#fgA)"/>
        <!-- Tube body — harsh cold white with blue tint -->
        <rect x="16" y="4" width="268" height="10" rx="4" fill="rgba(215,230,255,0.96)"/>
        <!-- Bright core stripe -->
        <rect x="18" y="6" width="264" height="4" rx="2" fill="rgba(240,248,255,1.0)"/>
        <!-- End caps — grey metal -->
        <rect x="12"  y="3" width="7" height="12" rx="2" fill="rgba(130,135,145,0.75)"/>
        <rect x="281" y="3" width="7" height="12" rx="2" fill="rgba(130,135,145,0.75)"/>
        <!-- Faint internal line suggesting the fluorescent tube -->
        <line x1="22" y1="9" x2="278" y2="9" stroke="rgba(200,220,255,0.4)" stroke-width="0.7"/>
      </svg>
(set: $hadChippy to true)\
(set: $confidence to $confidence + 20)\
(set: $sobriety to $sobriety + 25)\
(click-replace: ?lily1)[<span class="lily-glimpse lily-fade">That must be her, as tall as the Amazon; her joints articulate how you remember.</span>]\
For a few minutes, you are nobody. You have no manuscript. You owe nothing to anyone.
The warmth spreads through you. The fog lifts, just a little.
