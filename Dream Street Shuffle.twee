  placeMesh(shop, new THREE.BoxGeometry(0.6, 0.02, 0.3),
    new THREE.MeshStandardMaterial({ color: 0x2a2a1a, roughness: 0.9 }), 0.5, 0.04, 0.55);

  // ---- A-BOARD OUTSIDE (chalkboard) ----
  var aBoardMat = new THREE.MeshStandardMaterial({ color: 0x3a2a1a, roughness: 0.8 });
  // Legs
  var abLeg1 = new THREE.Mesh(new THREE.BoxGeometry(0.03, 0.65, 0.3), aBoardMat);
  abLeg1.position.set(2.65, 0.33, 1.3); abLeg1.rotation.z = 0.07; shop.add(abLeg1);
  var abLeg2 = new THREE.Mesh(new THREE.BoxGeometry(0.03, 0.65, 0.3), aBoardMat);
  abLeg2.position.set(2.95, 0.33, 1.3); abLeg2.rotation.z = -0.07; shop.add(abLeg2);
  // Board
  var aBoardTex = makeCanvasTexture(96, 128, function(cx, w, h) {
    cx.fillStyle = '#0a0a0a'; cx.fillRect(0, 0, w, h);
