  // Pub murmur — pink noise filtered through two bandpass filters tuned to
  // the human voice formants (F1 ~600Hz, F2 ~1500Hz), with rhythmic amplitude
  // modulation baked into the buffer. Sounds like distant chatter rather than
  // hiss.
  function ambientPub() {
    _play(function(ac) {
    if (_ambient && _ambient.kind === 'pub') return;
    _stopAmbient();
    var now = ac.currentTime;
    // Long buffer (8s) so the loop point isn't obvious
    var bufLen = Math.floor(ac.sampleRate * 8.0);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    var b0=0, b1=0, b2=0;
    for (var i = 0; i < bufLen; i++) {
      var w = Math.random()*2-1;
      b0 = 0.99*b0 + 0.07*w;
      b1 = 0.96*b1 + 0.10*w;
      b2 = 0.85*b2 + 0.12*w;
      // Rhythmic amplitude modulation — voices coming and going.
      // Two low-frequency sines at incommensurate rates so there's no obvious pulse.
      var ti = i / ac.sampleRate;
      var rhythm = 0.45 + 0.35 * Math.sin(ti * 1.7) + 0.20 * Math.sin(ti * 0.83 + 1.3);
      if (rhythm < 0.15) rhythm = 0.15;
