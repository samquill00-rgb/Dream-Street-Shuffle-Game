var pipeGroup = new THREE.Group();
scene.add(pipeGroup);

var pipe1 = cyl(pipeGroup, 0.04, 0.04, roomLength - 2, 8, pipeMat, -halfW + 0.15, roomHeight - 0.3, 0);
pipe1.rotation.x = Math.PI / 2;

var pipe2 = cyl(pipeGroup, 0.05, 0.05, roomLength - 4, 8, pipeMat, halfW - 0.2, 1.0, -1);
pipe2.rotation.x = Math.PI / 2;

cyl(pipeGroup, 0.04, 0.04, roomHeight, 8, ironMat, halfW - 0.15, roomHeight / 2, 3);

box(pipeGroup, 0.3, 0.3, 0.5, ironMat, halfW - 0.25, roomHeight - 0.5, 1);
cyl(pipeGroup, 0.08, 0.08, 0.6, 8, ironMat, halfW - 0.15, roomHeight - 0.5, 0.3);

var cp;
for (cp = -6; cp < 7; cp += 4) {
var cpipe = cyl(pipeGroup, 0.02, 0.02, roomWidth * 0.6, 6, wireMat, 0, roomHeight - 0.15, cp);
cpipe.rotation.z = Math.PI / 2;
}

// ============================================================
// LIGHT BULB
// ============================================================
var bulbGroup = new THREE.Group();
scene.add(bulbGroup);

var wireGeo = new THREE.CylinderGeometry(0.005, 0.005, 1.0, 4);
