var row, col;
for (row = 0; row < 5; row++) {
for (col = 0; col < 10; col++) {
var tx = col * 26 + (row % 2 === 0 ? 0 : 13);
var ty = row * 26 + 5;
cx.fillStyle = '#3a0a0a';
cx.beginPath();
cx.arc(tx + 13, ty + 13, 4, 0, Math.PI * 2);
cx.fill();
cx.strokeStyle = '#4a1212';
cx.lineWidth = 0.8;
cx.beginPath();
cx.moveTo(tx, ty + 13);
cx.lineTo(tx + 13, ty);
cx.lineTo(tx + 26, ty + 13);
cx.lineTo(tx + 13, ty + 26);
cx.closePath();
cx.stroke();
}
}
});
