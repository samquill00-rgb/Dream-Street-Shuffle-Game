placeMesh(pub, new THREE.CylinderGeometry(0.04, 0.04, 3.5, 6), pipeMat, alleyX + alleyWidth/2 - 0.15, 1.75, 0.35);
// Pipe bracket
placeMesh(pub, new THREE.BoxGeometry(0.12, 0.06, 0.15), pipeMat, alleyX + alleyWidth/2 - 0.15, 2.5, 0.3);

// Cobblestone texture hint in alley (darker stripes)
for (var cobZ = 0; cobZ >= -4; cobZ -= 0.6) {
var cobble = new THREE.Mesh(new THREE.PlaneGeometry(alleyWidth - 0.2, 0.08),
new THREE.MeshStandardMaterial({ color: 0x0c0a08, roughness: 0.9 }));
cobble.rotation.x = -Math.PI / 2;
cobble.position.set(alleyX, 0.025, cobZ);
pub.add(cobble);
}

// Faint silhouette figure in the alley
var figC = document.createElement('canvas');
figC.width = 32; figC.height = 64;
var figCtx = figC.getContext('2d');
figCtx.fillStyle = 'rgba(10,8,8,0.5)';
figCtx.beginPath(); figCtx.ellipse(16, 8, 5, 6, 0, 0, Math.PI * 2); figCtx.fill();
figCtx.fillRect(12, 14, 8, 28);
figCtx.fillRect(10, 42, 5, 18);
figCtx.fillRect(17, 42, 5, 18);
var figTex = new THREE.CanvasTexture(figC);
var figure = new THREE.Sprite(new THREE.SpriteMaterial({
map: figTex, transparent: true, depthWrite: false
}));
figure.scale.set(0.5, 1.0, 1);
figure.position.set(alleyX, 1.0, -1.5);
pub.add(figure);

// Graffiti hint on alley wall (subtle)
