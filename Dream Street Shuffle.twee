  new THREE.MeshStandardMaterial({ color: 0xb0a888, roughness: 0.8 }));
leftSubCornice.position.set(-6, 13.82, 0.15);
leftBuilding.add(leftSubCornice);
// String courses between floors — windows at y=4.5, 7.5, 10.5; strings between at y=6, 9, 12
