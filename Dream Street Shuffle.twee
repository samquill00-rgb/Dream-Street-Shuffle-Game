// ============================================================
// ANIMATION LOOP
// ============================================================
var clock = new THREE.Clock();

function phAnimate() {
phAnimId = requestAnimationFrame(phAnimate);
var t = clock.getElapsedTime();

// Very subtle light breathing
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;

for (var i = 0; i < lampLightsOnPub.length; i++) {
var ll = lampLightsOnPub[i];
ll.intensity = ll.userData.baseIntensity * breath;
}

for (var i = 0; i < streetLampLights.length; i++) {
streetLampLights[i].intensity = 0.6 * breath;
}

pubGlow.intensity = 0.8 * breath;
pubGlow2.intensity = 0.4 * breath;
doorLight.intensity = 0.6 * breath;
alleyLight.intensity = 0.12 * breath;
alleyLight2.intensity = 0.08 * breath;

// Silhouettes sway gently
for (var i = 0; i < silhouettes.length; i++) {
var s = silhouettes[i];
s.mesh.position.x = s.baseX + Math.sin(t * s.swaySpeed * 0.5 + s.swayPhase) * s.swayAmt * 0.5;
}

// Film grain
phGrainFrame++;
if (phGrainFrame % 3 === 0) {
var imgData = phGrainCtx.createImageData(256, 256);
var d = imgData.data;
for (var i = 0; i < d.length; i += 4) {
var v = Math.random() * 255;
d[i] = d[i+1] = d[i+2] = v;
d[i+3] = 255;
}
phGrainCtx.putImageData(imgData, 0, 0);
}

renderer.render(scene, camera);
}

// Create vignette overlay
var phVig = document.createElement('div');
phVig.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9001;pointer-events:none;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
phWrap.appendChild(phVig);

// Film grain overlay
var phGrain = document.createElement('canvas');
phGrain.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;opacity:0.02;mix-blend-mode:overlay;';
phGrain.width = 256; phGrain.height = 256;
phWrap.appendChild(phGrain);
var phGrainCtx = phGrain.getContext('2d');
var phGrainFrame = 0;

// Colorwash overlay
var phWash = document.createElement('div');
phWash.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;background:linear-gradient(180deg, rgba(10,8,25,0.3) 0%, rgba(5,5,15,0.08) 30%, rgba(5,5,15,0.08) 60%, rgba(5,3,2,0.4) 100%);';
phWrap.appendChild(phWash);

// Datestamp
var phDate = document.createElement('div');
phDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
phDate.style.cssText = 'position:fixed;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.4);pointer-events:none;z-index:9003;';
phWrap.appendChild(phDate);

// Location
var phLoc = document.createElement('div');
phLoc.textContent = 'GREEK STREET NORTH, SOHO';
phLoc.style.cssText = 'position:fixed;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;';
phWrap.appendChild(phLoc);

phAnimate();

// Button: "GO TO THE PILLARS"
var phBtn = document.createElement('div');
phBtn.textContent = 'GO TO THE PILLARS';
phBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(200,170,100,0.85);border:1px solid rgba(200,170,100,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
// Show button after delay
setTimeout(function() { phBtn.style.opacity = '1'; }, 2500);
// Hover effects
phBtn.addEventListener('mouseenter', function() {
phBtn.style.color = 'rgba(230,200,120,0.95)';
phBtn.style.borderColor = 'rgba(200,170,100,0.6)';
});
phBtn.addEventListener('mouseleave', function() {
phBtn.style.color = 'rgba(200,170,100,0.85)';
phBtn.style.borderColor = 'rgba(200,170,100,0.3)';
});
// Click handler - fade out and navigate
phBtn.addEventListener('click', function() {
phWrap.style.transition = 'opacity 1.5s ease';
phWrap.style.opacity = '0';
setTimeout(function() {
if (phAnimId) cancelAnimationFrame(phAnimId);
phAnimId = null;
if (phWrap.parentNode) phWrap.parentNode.removeChild(phWrap);
// Navigate to target passage
var TARGET = 'Entering The Pillars of Hercules';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
phWrap.appendChild(phBtn);

document.body.appendChild(phWrap);
}

// Watch for ph-container
setInterval(function() {
var container = document.getElementById('ph-container');
if (container && !phActive) {
initPillars();
} else if (!container) {
phActive = false;
if (phAnimId) { cancelAnimationFrame(phAnimId); phAnimId = null; }
var wrap = document.getElementById('ph-wrap');
if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
}
}, 300);
})();

// ====== LACKLAND'S OFFICE SCENE — INLINE ======
(function() {
var loActive = false;
var loAnimId = null;
var loWrap = null;
var loVig = null;
var loGrain = null;
var loGrainCtx = null;
var loGrainFrame = 0;
var loWash = null;
var loDate = null;
var loLoc = null;
var loBtn = null;

function initLackland() {
if (loActive) return;
loActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildLOScene(); };
document.head.appendChild(s);
} else {
buildLOScene();
}
}

function buildLOScene() {
// Create full-screen overlay wrapper
loWrap = document.createElement('div');
loWrap.id = 'lo-wrap';
loWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x04040a);
scene.fog = new THREE.Fog(0x04040a, 4, 22);

var camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.set(2.8, 2.0, 6.5);
camera.lookAt(0, 2.8, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 0.54;
loWrap.appendChild(renderer.domElement);

window.addEventListener('resize', function() {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================
var stuccoTex = makeCanvasTexture(512, 1024, function(cx, w, h) {
cx.fillStyle = '#d5ccb8';
cx.fillRect(0, 0, w, h);
var sootWash = cx.createLinearGradient(0, 0, 0, h);
sootWash.addColorStop(0, 'rgba(50, 45, 35, 0.15)');
sootWash.addColorStop(0.1, 'rgba(60, 55, 45, 0.05)');
sootWash.addColorStop(0.5, 'rgba(0, 0, 0, 0)');
sootWash.addColorStop(0.85, 'rgba(50, 45, 30, 0.08)');
sootWash.addColorStop(1, 'rgba(40, 35, 25, 0.2)');
cx.fillStyle = sootWash;
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(90, 85, 70, 0.06)';
cx.lineWidth = 2;
for (var rs = 0; rs < 20; rs++) {
cx.beginPath();
var rx = Math.random() * w;
cx.moveTo(rx, 0);
for (var ry = 0; ry < h; ry += 30) {
rx += (Math.random() - 0.5) * 4;
cx.lineTo(rx, ry);
}
cx.stroke();
}
cx.fillStyle = 'rgba(160, 150, 130, 0.08)';
for (var pc = 0; pc < 6; pc++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 30 + Math.random() * 60, 20 + Math.random() * 40, Math.random(), 0, Math.PI * 2);
cx.fill();
}
});
var creamStucco = new THREE.MeshStandardMaterial({ map: stuccoTex, roughness: 0.85 });
var darkStucco = new THREE.MeshStandardMaterial({ color: 0xb0a890, roughness: 0.85 });
var sootBrick = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x3a2a22, roughness: 0.9 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x6b3a2a, roughness: 0.85 });
var greyStone = new THREE.MeshStandardMaterial({ color: 0x9a9488, roughness: 0.75 });
var whiteStone = new THREE.MeshStandardMaterial({ color: 0xc8c0b0, roughness: 0.7 });
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#555550';
cx.fillRect(0, 0, w, h);
var flagRows = [
{ y: 0, h: 128 },
{ y: 128, h: 110 },
{ y: 238, h: 140 },
{ y: 378, h: 134 }
];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var slabs = (ri % 2 === 0) ? [0, 200, 380] : [0, 260, 420];
for (var si = 0; si < slabs.length; si++) {
var sx = slabs[si];
var sw = (si < slabs.length - 1) ? slabs[si + 1] - sx : w - sx;
var tone = 60 + Math.random() * 25;
cx.fillStyle = 'rgb(' + tone + ',' + tone + ',' + (tone - 3) + ')';
cx.fillRect(sx + 2, row.y + 2, sw - 4, row.h - 4);
cx.fillStyle = 'rgba(80, 78, 72, 0.06)';
for (var sp = 0; sp < 8; sp++) {
cx.beginPath();
cx.ellipse(sx + Math.random() * sw, row.y + Math.random() * row.h, 10 + Math.random() * 25, 5 + Math.random() * 12, Math.random(), 0, Math.PI * 2);
cx.fill();
}
}
}
cx.strokeStyle = 'rgba(25, 22, 18, 0.6)';
cx.lineWidth = 3;
for (var ri = 0; ri < flagRows.length; ri++) {
cx.beginPath();
cx.moveTo(0, flagRows[ri].y);
cx.lineTo(w, flagRows[ri].y);
cx.stroke();
}
var vertLines1 = [200, 380];
var vertLines2 = [260, 420];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var vlines = (ri % 2 === 0) ? vertLines1 : vertLines2;
for (var vi = 0; vi < vlines.length; vi++) {
cx.beginPath();
cx.moveTo(vlines[vi], row.y);
cx.lineTo(vlines[vi], row.y + row.h);
cx.stroke();
}
}
cx.fillStyle = 'rgba(15, 12, 8, 0.25)';
for (var ri = 0; ri < flagRows.length; ri++) {
cx.fillRect(0, flagRows[ri].y - 1, w, 4);
}
cx.fillStyle = 'rgba(30, 28, 22, 0.2)';
for (var st = 0; st < 8; st++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 8 + Math.random() * 20, 6 + Math.random() * 15, Math.random() * Math.PI, 0, Math.PI * 2);
cx.fill();
}
cx.fillStyle = 'rgba(90, 88, 82, 0.35)';
for (var gm = 0; gm < 5; gm++) {
cx.beginPath();
cx.arc(Math.random() * w, Math.random() * h, 2 + Math.random() * 4, 0, Math.PI * 2);
cx.fill();
}
cx.fillStyle = 'rgba(35, 35, 38, 0.12)';
for (var dp = 0; dp < 3; dp++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 25 + Math.random() * 40, 20 + Math.random() * 30, Math.random(), 0, Math.PI * 2);
cx.fill();
}
});
var pavementMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.9 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x151515, roughness: 0.85 });
var kerbMat = new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.8 });
var paveMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.85 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a8070, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.2, metalness: 0.3 });
var warmGlass = new THREE.MeshStandardMaterial({ color: 0x2a1505, roughness: 0.3, emissive: 0xe87818, emissiveIntensity: 0.12 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.4 });
var doorTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#1a4a2a';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(10, 50, 22, 0.4)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 4) {
cx.beginPath();
cx.moveTo(gx, 0);
cx.lineTo(gx + (Math.random() - 0.5) * 2, h);
cx.stroke();
}
cx.fillStyle = 'rgba(12, 40, 18, 0.3)';
for (var k = 0; k < 5; k++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 6 + Math.random() * 8, 3 + Math.random() * 4, Math.random() * Math.PI, 0, Math.PI * 2);
cx.fill();
}
cx.fillStyle = 'rgba(35, 80, 45, 0.15)';
cx.fillRect(0, 0, 8, h);
cx.fillRect(w - 8, 0, 8, h);
cx.fillRect(0, 0, w, 6);
cx.fillRect(0, h - 6, w, 6);
cx.fillStyle = 'rgba(20, 30, 15, 0.25)';
for (var sc = 0; sc < 12; sc++) {
cx.fillRect(Math.random() * w, h - 20 - Math.random() * 60, 15 + Math.random() * 25, 1 + Math.random() * 2);
}
cx.fillStyle = 'rgba(30, 50, 25, 0.08)';
cx.fillRect(0, 0, w, h * 0.15);
cx.fillStyle = 'rgba(15, 35, 18, 0.06)';
cx.fillRect(0, h * 0.85, w, h * 0.15);
});
var racingGreen = new THREE.MeshStandardMaterial({ map: doorTex, roughness: 0.5, metalness: 0.05 });
var panelTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#143820';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(8, 40, 16, 0.35)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 5) {
cx.beginPath();
cx.moveTo(gx, 0);
cx.lineTo(gx + (Math.random() - 0.5) * 2, h);
cx.stroke();
}
var panelShadow = cx.createLinearGradient(0, 0, 0, h);
panelShadow.addColorStop(0, 'rgba(5, 15, 8, 0.2)');
panelShadow.addColorStop(0.3, 'rgba(5, 15, 8, 0)');
panelShadow.addColorStop(1, 'rgba(5, 15, 8, 0.05)');
cx.fillStyle = panelShadow;
cx.fillRect(0, 0, w, h);
});
var racingGreenDark = new THREE.MeshStandardMaterial({ map: panelTex, roughness: 0.55, metalness: 0.05 });
var brassMat = new THREE.MeshStandardMaterial({
color: 0xb8922a, roughness: 0.25, metalness: 0.85
});
var brassMatDull = new THREE.MeshStandardMaterial({
color: 0x8a7020, roughness: 0.4, metalness: 0.7
});

// ============================================================
// HELPERS
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
scene.add(m);
return m;
}

// ============================================================
// GROUND
// ============================================================
var pavement = new THREE.Mesh(new THREE.PlaneGeometry(40, 40), paveMat);
pavement.rotation.x = -Math.PI / 2;
pavement.receiveShadow = true;
scene.add(pavement);

var road = new THREE.Mesh(new THREE.PlaneGeometry(40, 7), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 6);
road.receiveShadow = true;
scene.add(road);

var kerb = new THREE.Mesh(new THREE.BoxGeometry(30, 0.15, 0.15), kerbMat);
kerb.position.set(0, 0.075, 2.5);
scene.add(kerb);

var raisedPave = new THREE.Mesh(new THREE.BoxGeometry(30, 0.12, 3), paveMat);
raisedPave.position.set(0, 0.06, 1);
raisedPave.receiveShadow = true;
scene.add(raisedPave);

var wetMat = new THREE.MeshStandardMaterial({
color: 0x1a1a1a, roughness: 0.12, metalness: 0.5, transparent: true, opacity: 0.3
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(12, 6), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(1, 0.01, 5);
scene.add(wetRoad);

