// Lantern glass panels — using a slightly tapered box shape
// The glass glows with warm ginger from inside
var gingerGlassMat = new THREE.MeshStandardMaterial({
  color: 0x4a2005, roughness: 0.2, transparent: true, opacity: 0.7,
  emissive: 0xe87818, emissiveIntensity: 1.4
});

// Four glass panels forming the lantern
var panelGeo = new THREE.PlaneGeometry(0.32, 0.55);

var panelFront = new THREE.Mesh(panelGeo, gingerGlassMat);
panelFront.position.set(0, 5.6, 0.18);
heroLamp.add(panelFront);

var panelBack = new THREE.Mesh(panelGeo, gingerGlassMat);
panelBack.position.set(0, 5.6, -0.18);
panelBack.rotation.y = Math.PI;
heroLamp.add(panelBack);

var panelLeft = new THREE.Mesh(panelGeo, gingerGlassMat);
panelLeft.position.set(-0.18, 5.6, 0);
panelLeft.rotation.y = Math.PI / 2;
heroLamp.add(panelLeft);

var panelRight = new THREE.Mesh(panelGeo, gingerGlassMat);
panelRight.position.set(0.18, 5.6, 0);
panelRight.rotation.y = -Math.PI / 2;
