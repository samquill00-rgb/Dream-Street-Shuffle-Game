// Shared fog textures
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(160, 155, 145, 0.22)');
  grad.addColorStop(0.4, 'rgba(130, 125, 115, 0.1)');
  grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(120, 115, 105, 0.12)');
  grad.addColorStop(0.6, 'rgba(100, 95, 85, 0.05)');
  grad.addColorStop(1, 'rgba(80, 75, 65, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});
var gingerFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(232, 120, 24, 0.3)');
  grad.addColorStop(0.25, 'rgba(220, 100, 18, 0.18)');
  grad.addColorStop(0.55, 'rgba(200, 80, 12, 0.08)');
  grad.addColorStop(1, 'rgba(160, 55, 8, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

