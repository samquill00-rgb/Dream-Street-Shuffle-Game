:: Shana Reads [venue-trishas] {"position":"900,1700","size":"100,100"}
{
(set: _albaCount to 0)(if: $alba contains $alba1)[(set: _albaCount to _albaCount + 1)](if: $alba contains $alba2)[(set: _albaCount to _albaCount + 1)](if: $alba contains $alba3)[(set: _albaCount to _albaCount + 1)]

<!-- Numeral lookup. Roman numerals for every card the spread can land on. -->
(set: _numerals to (dm:
"The Fool", "O", "The Magician", "I", "The High Priestess", "II",
"The Empress", "III", "The Hierophant", "V", "The Lovers", "VI",
"The Chariot", "VII", "Strength", "VIII", "The Hermit", "IX",
"Wheel of Fortune", "X", "Justice", "XI", "Death", "XIII",
"Temperance", "XIV", "The Devil", "XV", "The Tower", "XVI",
"The Star", "XVII", "The Moon", "XVIII", "The Sun", "XIX",
"Judgement", "XX", "The World", "XXI"
))

<!-- Each card is drawn from a weighted pool — stats still steer the result
     (stronger conditions add more copies of that card) but the player no
     longer gets the exact same spread twice with similar stats. The base
     pool keeps a couple of free-floating options for variation. -->

<!-- CARD 1 — where you've come from. NEVER the Hanged Man. -->
(set: _p1 to (a: "The Fool", "The Hermit"))
(if: $metRed is true)[(set: _p1 to _p1 + (a: "The Magician", "The Magician"))]
(if: $metDavy is true)[(set: _p1 to _p1 + (a: "The Hierophant", "The Hierophant"))]
(if: $haunts contains $haunt4)[(set: _p1 to _p1 + (a: "The Lovers", "The Lovers", "The Lovers"))]
(if: $hadPhoneCall is true)[(set: _p1 to _p1 + (a: "The Empress", "The Empress", "The Empress"))]
(if: $haunts's length >= 11)[(set: _p1 to _p1 + (a: "The World", "The World", "The World", "The World", "The World"))]
(set: _c1 to _p1's (random: 1, _p1's length))
(set: _c1n to _numerals's (_c1))

<!-- CARD 2 — where you are. NEVER the Hanged Man. -->
(set: _p2 to (a: "Wheel of Fortune", "Wheel of Fortune"))
(if: $sobriety < 30)[(set: _p2 to _p2 + (a: "The Devil", "The Devil", "The Devil", "The Devil", "The Devil"))]
(if: $confidence < 30)[(set: _p2 to _p2 + (a: "The Tower", "The Tower", "The Tower", "The Tower", "The Tower"))]
(if: $wasBeaten is true)[(set: _p2 to _p2 + (a: "Death", "Death", "Death", "Death"))]
(if: $hasMissingPage is true and $returnedPage is false)[(set: _p2 to _p2 + (a: "The Magician", "The Magician", "The Magician"))]
(if: $haunts contains $haunt5)[(set: _p2 to _p2 + (a: "The Chariot", "The Chariot", "The Chariot"))]
(if: $visitedCarthage is true)[(set: _p2 to _p2 + (a: "The Moon", "The Moon", "The Moon"))]
(set: _c2 to _p2's (random: 1, _p2's length))
(set: _c2n to _numerals's (_c2))

<!-- CARD 3 — what awaits. NEVER the Hanged Man. -->
(set: _p3 to (a: "Strength", "Wheel of Fortune"))
(if: _albaCount >= 3)[(set: _p3 to _p3 + (a: "The Star", "The Star", "The Star", "The Star", "The Star", "The Star"))]
(if: $haunts's length >= 12)[(set: _p3 to _p3 + (a: "The Sun", "The Sun", "The Sun", "The Sun", "The Sun"))]
(if: $haunts's length >= 9)[(set: _p3 to _p3 + (a: "Judgement", "Judgement", "Judgement", "Judgement"))]
(if: $hasLiver is true)[(set: _p3 to _p3 + (a: "Temperance", "Temperance", "Temperance"))]
(if: $tookLily5 is true)[(set: _p3 to _p3 + (a: "The High Priestess", "The High Priestess", "The High Priestess"))]
(if: $returnedPage is true)[(set: _p3 to _p3 + (a: "Justice", "Justice", "Justice"))]
(set: _c3 to _p3's (random: 1, _p3's length))
(set: _c3n to _numerals's (_c3))

<!-- Deduplicate so no two cards are the same. Strength is only in c3's pool
     and Wheel is in both c2 and c3 — so falling back to Strength is safe. -->
(if: _c2 is _c1)[(set: _c2 to "Wheel of Fortune")(set: _c2n to "X")]
(if: _c3 is _c1 or _c3 is _c2)[(set: _c3 to "Strength")(set: _c3n to "VIII")]

