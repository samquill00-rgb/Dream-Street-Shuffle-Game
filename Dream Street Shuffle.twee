        rd[i] = (Math.random() * 2 - 1) * Math.exp(-t * 4);
      }
      var rSrc = ac.createBufferSource(); rSrc.buffer = rBuf;
      var rBp = ac.createBiquadFilter(); rBp.type = 'bandpass';
      rBp.frequency.value = 1800; rBp.Q.value = 1.4;
      var rG = ac.createGain(); rG.gain.value = 0.18;
