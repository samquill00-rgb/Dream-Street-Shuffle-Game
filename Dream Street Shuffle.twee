placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), whiteTrim, -0.5, 1.55, 0.36);
placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), whiteTrim, -0.5, 1.9, 0.36);
