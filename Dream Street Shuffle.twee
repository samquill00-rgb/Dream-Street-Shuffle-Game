  function doorShopBell() {
    _play(function(ac) {
      var now = ac.currentTime;
      var pings = [
        { t: 0.00, freqs: [2640, 3960], amp: 0.14 },
        { t: 0.14, freqs: [2620, 3920], amp: 0.10 },
        { t: 0.28, freqs: [2660, 3980], amp: 0.07 },
        { t: 0.46, freqs: [2640, 3940], amp: 0.05 }
      ];
      pings.forEach(function(p) {
        var bt = now + p.t;
        p.freqs.forEach(function(freq, idx) {
          var o = ac.createOscillator(); o.type = 'sine';
          o.frequency.value = freq * (1 + (Math.random() - 0.5) * 0.006);
          var og = ac.createGain();
