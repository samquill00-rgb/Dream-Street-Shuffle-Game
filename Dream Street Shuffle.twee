var moon2 = new THREE.Mesh(new THREE.PlaneGeometry(0.55, 0.55),
  new THREE.MeshBasicMaterial({ map: moonTex2, transparent: true, depthWrite: false, fog: false }));
moon2.position.set(-22, 9.3, 6.8);
moon2.rotation.y = Math.PI / 2;
scene.add(moon2);
var moon3 = new THREE.Mesh(new THREE.PlaneGeometry(0.6, 0.6),
  new THREE.MeshBasicMaterial({ map: moonTex3, transparent: true, depthWrite: false, fog: false }));
moon3.position.set(-28, 8.2, -4.1);
moon3.rotation.y = Math.PI / 2;
scene.add(moon3);

// ---- STARS ----
var celStarTex = makeCanvasTexture(32, 32, function(cx, w, h) {
  var sGrad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  sGrad.addColorStop(0, 'rgba(255,255,255,1)');
  sGrad.addColorStop(0.12, 'rgba(255,255,255,0.9)');
  sGrad.addColorStop(0.35, 'rgba(255,255,255,0.2)');
  sGrad.addColorStop(1, 'rgba(255,255,255,0)');
  cx.fillStyle = sGrad; cx.fillRect(0, 0, w, h);
});
var starCols = [
  new THREE.Color(1.0, 1.0, 1.0),
  new THREE.Color(0.78, 0.87, 1.0),
  new THREE.Color(1.0, 0.95, 0.72),
  new THREE.Color(1.0, 0.78, 0.42),
  new THREE.Color(1.0, 0.55, 0.55),
  new THREE.Color(0.7, 0.7, 1.0),
  new THREE.Color(0.82, 1.0, 0.88),
];
var celStars = [];
for (var csi = 0; csi < 140; csi++) {
  var csMat = new THREE.SpriteMaterial({
    map: celStarTex,
    color: starCols[Math.floor(Math.random() * starCols.length)],
    transparent: true,
    opacity: 0.5 + Math.random() * 0.5
  });
  csMat.fog = false;
  var csSpr = new THREE.Sprite(csMat);
  csSpr.position.set(-15 - Math.random() * 45, 5 + Math.random() * 10, (Math.random() - 0.5) * 30);
  var csS = 0.2 + Math.random() * 0.65;
  csSpr.scale.set(csS, csS, 1);
  scene.add(csSpr);
  celStars.push({ spr: csSpr, baseOp: csMat.opacity, twSpd: 0.4 + Math.random() * 2.8, twOff: Math.random() * Math.PI * 2 });
}
for (var hsi = 0; hsi < 18; hsi++) {
  var hsMat = new THREE.SpriteMaterial({
    map: celStarTex,
    color: starCols[Math.floor(Math.random() * starCols.length)],
    transparent: true,
    opacity: 0.85 + Math.random() * 0.15
  });
  hsMat.fog = false;
  var hsSpr = new THREE.Sprite(hsMat);
  hsSpr.position.set(-15 - Math.random() * 40, 6 + Math.random() * 10, (Math.random() - 0.5) * 25);
  var hsS = 0.65 + Math.random() * 1.0;
  hsSpr.scale.set(hsS, hsS, 1);
  scene.add(hsSpr);
  celStars.push({ spr: hsSpr, baseOp: hsMat.opacity, twSpd: 0.2 + Math.random() * 1.2, twOff: Math.random() * Math.PI * 2 });
}

// ============================================================
// LIGHTING
// ============================================================
scene.add(new THREE.AmbientLight(0x1a1a2a, 0.11));

var moonLight = new THREE.DirectionalLight(0x4455aa, 0.12);
moonLight.position.set(5, 20, 10);
moonLight.castShadow = true;
scene.add(moonLight);

var fillLight = new THREE.DirectionalLight(0x2233aa, 0.05);
fillLight.position.set(-5, 10, -5);
scene.add(fillLight);

// ============================================================
// FOG VOLUMES (4 layers with individual drift)
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
  grad.addColorStop(0, 'rgba(180, 170, 155, 0.25)');
  grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.12)');
  grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});

var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
  grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
  grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
  grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});

var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
  grad.addColorStop(0, 'rgba(200, 160, 100, 0.12)');
  grad.addColorStop(0.5, 'rgba(180, 140, 80, 0.05)');
  grad.addColorStop(1, 'rgba(150, 120, 60, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// Layer 1: Ground-hugging thick fog
for (var i = 0; i < 50; i++) {
  var fogMat = new THREE.SpriteMaterial({ map: thickFogTex, transparent: true, opacity: 0.18 + Math.random() * 0.18 });
  var fogSprite = new THREE.Sprite(fogMat);
  fogSprite.position.set(Math.random() * 40 - 15, 0.3 + Math.random() * 2, Math.random() * 30 - 5);
  var s = 5 + Math.random() * 12;
  fogSprite.scale.set(s, s * 0.35, 1);
  scene.add(fogSprite);
  fogSprites.push({
    sprite: fogSprite,
    baseX: fogSprite.position.x,
    drift: 0.002 + Math.random() * 0.006,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.001 + Math.random() * 0.004,
    swayAmt: 0.4 + Math.random() * 1.0
  });
}

// Layer 2: Mid-height fog
for (var i = 0; i < 30; i++) {
  var midFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.1 + Math.random() * 0.12 });
  var midFog = new THREE.Sprite(midFogMat);
  midFog.position.set(Math.random() * 35 - 12, 2 + Math.random() * 6, Math.random() * 30 - 5);
  var ms = 6 + Math.random() * 14;
  midFog.scale.set(ms, ms * 0.3, 1);
  scene.add(midFog);
  fogSprites.push({
    sprite: midFog,
    baseX: midFog.position.x,
    drift: 0.001 + Math.random() * 0.004,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.0008 + Math.random() * 0.003,
    swayAmt: 0.5 + Math.random() * 1.5
  });
}

// Layer 3: Warm tinted fog near building
for (var i = 0; i < 15; i++) {
  var warmFogMat = new THREE.SpriteMaterial({ map: warmFogTex, transparent: true, opacity: 0.12 + Math.random() * 0.1 });
  var warmFog = new THREE.Sprite(warmFogMat);
  warmFog.position.set(Math.random() * 10 - 3, 0.5 + Math.random() * 3, 1 + Math.random() * 6);
  var ws = 4 + Math.random() * 8;
  warmFog.scale.set(ws, ws * 0.3, 1);
  scene.add(warmFog);
  fogSprites.push({
    sprite: warmFog,
    baseX: warmFog.position.x,
    drift: 0.001 + Math.random() * 0.003,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.001 + Math.random() * 0.003,
    swayAmt: 0.3 + Math.random() * 0.8
  });
}

// Layer 4: High wisps
for (var i = 0; i < 12; i++) {
  var highFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.06 + Math.random() * 0.08 });
  var highFog = new THREE.Sprite(highFogMat);
  highFog.position.set(Math.random() * 30 - 10, 8 + Math.random() * 8, Math.random() * 20 - 5);
  var hs = 10 + Math.random() * 15;
  highFog.scale.set(hs, hs * 0.2, 1);
  scene.add(highFog);
  fogSprites.push({
    sprite: highFog,
    baseX: highFog.position.x,
    drift: 0.003 + Math.random() * 0.005,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.0005 + Math.random() * 0.002,
    swayAmt: 1.0 + Math.random() * 2.0
  });
}

// ============================================================
// ANIMATION LOOP
// ============================================================
var clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  var t = clock.getElapsedTime();

  // Fog sprite drift (each sprite has individual drift and sway)
  for (var i = 0; i < fogSprites.length; i++) {
    var f = fogSprites[i];
    f.sway += f.swaySpeed;
    f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
    f.baseX += f.drift;
    if (f.baseX > 25) f.baseX = -25;
  }

  // ---- PUDDLE SHIMMER ANIMATION ----
  for (var pi = 0; pi < scene.children.length; pi++) {
    var child = scene.children[pi];
    if (child.userData && child.userData.puddleIndex !== undefined) {
      var shimmerAmount = 0.3 + Math.sin(t * 3.0 + child.userData.puddleIndex) * 0.05;
      child.material.opacity = shimmerAmount;
    }
  }

  // Neon sign flicker (dual frequency sine waves for authentic neon buzz)
  var neonFlicker = Math.sin(t * 3.5) * 0.1 + Math.sin(t * 7.2) * 0.05;
  neonLight.intensity = 1.2 + neonFlicker;

  // Green neon flicker (slightly different frequency)
  neonLightGreen.intensity = 0.3 + Math.sin(t * 4.1) * 0.06 + Math.sin(t * 8.5) * 0.03;

  // Street lamp flicker
  lampLight1.intensity = 0.7 + Math.sin(t * 2.2) * 0.08;
  lampLight2.intensity = 0.7 + Math.sin(t * 2.0 + 1.0) * 0.08;

  // Camera subtle breathing
  var camBreath = Math.sin(t * 0.3) * 0.03 + Math.sin(t * 0.17) * 0.02;
  camera.position.y = 1.7 + camBreath;
  camera.position.x = 8 + Math.sin(t * 0.08) * 0.04;

  // ---- CELESTIAL ANIMATION ----
  for (var csti = 0; csti < celStars.length; csti++) {
    var cst = celStars[csti];
    cst.spr.material.opacity = cst.baseOp * (0.62 + Math.sin(t * cst.twSpd + cst.twOff) * 0.38);
  }
  galaxyMesh.rotation.z = 0.35 + t * 0.0022;
  nebula1.position.z = -2 + Math.sin(t * 0.038) * 0.3;
  nebula2.position.y = 8 + Math.sin(t * 0.055) * 0.2;
  nebula3.rotation.z = Math.sin(t * 0.024) * 0.04;
  nebula4.position.z = -7 + Math.sin(t * 0.041 + 1.0) * 0.22;
  milkyPlane.material.opacity = 0.88 + Math.sin(t * 0.065) * 0.06;
  moon1.position.y = 9 + Math.sin(t * 0.11) * 0.9;
  moon1.position.z = -2 + Math.cos(t * 0.11) * 2.5;
  moon2.position.y = 10 + Math.sin(t * 0.085 + 1.2) * 0.65;
  moon2.position.z = 5 + Math.cos(t * 0.085 + 1.2) * 1.8;
  moon3.position.y = 9 + Math.sin(t * 0.13 + Math.PI) * 0.78;
  moon3.position.z = -2 + Math.cos(t * 0.13 + Math.PI) * 2.1;

    renderer.render(scene, camera);
}

animate();

document.body.appendChild(rsWrap);

// ============================================================
// VIGNETTE EFFECT
// ============================================================
rsVig = document.createElement('canvas');
rsVig.width = 256; rsVig.height = 256;
var vigCtx = rsVig.getContext('2d');
var vigGrad = vigCtx.createRadialGradient(128, 128, 0, 128, 128, 180);
vigGrad.addColorStop(0, 'rgba(0,0,0,0)');
vigGrad.addColorStop(1, 'rgba(0,0,0,0.6)');
vigCtx.fillStyle = vigGrad;
vigCtx.fillRect(0, 0, 256, 256);

// ============================================================
// GRAIN EFFECT
// ============================================================
rsGrain = document.createElement('canvas');
rsGrain.width = 512; rsGrain.height = 512;
rsGrainCtx = rsGrain.getContext('2d');

// ============================================================
// DATE STAMP & LOCATION LABEL
// ============================================================
rsDate = document.createElement('div');
rsDate.id = 'rs-datestamp';
rsDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.55);pointer-events:none;z-index:9001;';
rsDate.textContent = '23.11.73';
rsWrap.appendChild(rsDate);

rsLoc = document.createElement('div');
rsLoc.id = 'rs-location';
rsLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New", monospace;color:rgba(200,180,140,0.4);letter-spacing:2px;pointer-events:none;z-index:9001;';
rsLoc.textContent = "RONNIE'S, FRITH STREET, SOHO";
rsWrap.appendChild(rsLoc);

// ============================================================
// ENTER BUTTON
// ============================================================
rsBtn = document.createElement('div');
rsBtn.id = 'rs-enter-btn';
rsBtn.style.cssText = 'position:absolute;bottom:45px;left:50%;transform:translateX(-50%);font:14px monospace;color:rgba(200,140,100,0.7);cursor:pointer;user-select:none;z-index:9001;';
rsBtn.textContent = '·';
rsBtn.addEventListener('mouseover', function() { rsBtn.style.color = 'rgba(255,160,100,0.95)'; });
rsBtn.addEventListener('mouseout', function() { rsBtn.style.color = 'rgba(200,140,100,0.7)'; });
rsBtn.addEventListener('click', function() {
  rsAnimId = null;
  rsActive = false;
  rsWrap.remove();
  var cont = document.getElementById('rs-container');
  if (cont) { var lk = cont.parentElement.querySelector('tw-link'); if (lk) lk.click(); }
});
rsWrap.appendChild(rsBtn);

// ============================================================
// ANIMATION LOOP WITH EFFECTS
// ============================================================
var animFrame = 0;
function renderRS() {
  rsAnimId = requestAnimationFrame(renderRS);
  
  renderer.render(scene, camera);
  
  // Vignette overlay
  var vCtx = rsWrap.getContext ? null : document.createElement('canvas');
  var tempCanvas = document.createElement('canvas');
  tempCanvas.width = rsWrap.clientWidth;
  tempCanvas.height = rsWrap.clientHeight;
  var tCtx = tempCanvas.getContext('2d');
  
  // Grain effect
  animFrame++;
  rsGrainFrame = (rsGrainFrame + 1) % 8;
  if (rsGrainFrame === 0) {
    for (var gy = 0; gy < rsGrain.height; gy++) {
      for (var gx = 0; gx < rsGrain.width; gx++) {
        var v = Math.floor(Math.random() * 256);
        rsGrainCtx.fillStyle = 'rgba(' + v + ',' + v + ',' + v + ',0.03)';
        rsGrainCtx.fillRect(gx, gy, 1, 1);
      }
    }
  }
}

renderRS();

}

// ============================================================
// CONTAINER WATCHER — polls for appear/disappear
// ============================================================
setInterval(function() {
  var cont = document.getElementById('rs-container');
  if (cont && !rsActive) {
    initRonnieScotts();
  } else if (!cont) {
    if (rsAnimId !== null) { cancelAnimationFrame(rsAnimId); rsAnimId = null; }
    rsActive = false;
    if (rsWrap && rsWrap.parentNode) { rsWrap.remove(); }
  }
}, 300);

})();

// ====== COPPER'S LAIR SCENE — INLINE ======
(function() {
var clActive = false;
var clAnimId = null;

function initCoppersLair() {
if (clActive) return;
clActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildCLScene(); };
document.head.appendChild(s);
} else {
buildCLScene();
}
}

function buildCLScene() {
var clWrap = document.createElement('div');
clWrap.id = 'cl-wrap';
clWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#06060a;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x06060a);
scene.fog = new THREE.Fog(0x05050a, 5, 26);

var camera = new THREE.PerspectiveCamera(54, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.set(0.3, 1.5, 8.5);
camera.lookAt(0, 1.4, -6);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.45;
clWrap.appendChild(renderer.domElement);

window.addEventListener('resize', function() {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================
var concreteMat = new THREE.MeshStandardMaterial({ color: 0x5a5850, roughness: 0.95 });
var concreteFloor = new THREE.MeshStandardMaterial({ color: 0x3a3835, roughness: 0.95 });
var concreteDark = new THREE.MeshStandardMaterial({ color: 0x484540, roughness: 0.9 });
var ceilingMat = new THREE.MeshStandardMaterial({ color: 0x4a4038, roughness: 0.9 });
var woodBeam = new THREE.MeshStandardMaterial({ color: 0x6a4a2a, roughness: 0.85 });
var darkWood = new THREE.MeshStandardMaterial({ color: 0x3a2515, roughness: 0.8 });
var pipeMat = new THREE.MeshStandardMaterial({ color: 0x555550, roughness: 0.6, metalness: 0.3 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7, metalness: 0.4 });
var wireMat = new THREE.MeshStandardMaterial({ color: 0x888878, roughness: 0.7 });
var bulbGlass = new THREE.MeshStandardMaterial({
color: 0xeeeee8, roughness: 0.2, emissive: 0xccbbaa, emissiveIntensity: 0.55,
transparent: true, opacity: 0.9
});
var silhouetteMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.9 });
var tableMat = new THREE.MeshStandardMaterial({ color: 0x2a2018, roughness: 0.85 });

// ============================================================
// HELPERS
// ============================================================
function box(group, w, h, d, mat, x, y, z) {
var geo = new THREE.BoxGeometry(w, h, d);
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
m.castShadow = true;
m.receiveShadow = true;
group.add(m);
return m;
}

function cyl(group, rTop, rBot, h, segs, mat, x, y, z) {
var geo = new THREE.CylinderGeometry(rTop, rBot, h, segs);
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
m.castShadow = true;
m.receiveShadow = true;
group.add(m);
return m;
}

function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

// ============================================================
// ROOM DIMENSIONS
// ============================================================
var roomLength = 20;
var roomWidth = 6;
var roomHeight = 2.8;
var halfW = roomWidth / 2;
var halfL = roomLength / 2;

// ============================================================
// FLOOR
// ============================================================
var floorGroup = new THREE.Group();
scene.add(floorGroup);

var floorTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#3a3835';
cx.fillRect(0, 0, w, h);
var i;
for (i = 0; i < 200; i++) {
var px = Math.random() * w;
var py = Math.random() * h;
var shade = Math.floor(Math.random() * 20) + 45;
cx.fillStyle = 'rgba(' + shade + ',' + shade + ',' + (shade - 5) + ',0.4)';
cx.fillRect(px, py, Math.random() * 30 + 5, Math.random() * 30 + 5);
}
for (i = 0; i < 8; i++) {
cx.strokeStyle = 'rgba(30,28,25,0.5)';
cx.lineWidth = 0.5 + Math.random();
cx.beginPath();
cx.moveTo(Math.random() * w, Math.random() * h);
cx.lineTo(Math.random() * w, Math.random() * h);
cx.stroke();
}
});
var floorMatTex = new THREE.MeshStandardMaterial({ map: floorTex, roughness: 0.95 });
var floor = new THREE.Mesh(new THREE.PlaneGeometry(roomWidth, roomLength), floorMatTex);
floor.rotation.x = -Math.PI / 2;
floor.position.set(0, 0, 0);
floor.receiveShadow = true;
floorGroup.add(floor);

// ============================================================
// WALLS
// ============================================================
var wallGroup = new THREE.Group();
scene.add(wallGroup);

function makeBlockWallTex(w, h) {
return makeCanvasTexture(w, h, function(cx, cw, ch) {
cx.fillStyle = '#585550';
cx.fillRect(0, 0, cw, ch);
var blockH = 32;
var blockW = 64;
var row, col, ox;
for (row = 0; row < ch / blockH + 1; row++) {
ox = (row % 2 === 0) ? 0 : blockW / 2;
for (col = -1; col < cw / blockW + 1; col++) {
var bx = col * blockW + ox;
var by = row * blockH;
var shade = 75 + Math.floor(Math.random() * 20);
cx.fillStyle = 'rgb(' + shade + ',' + (shade - 2) + ',' + (shade - 5) + ')';
cx.fillRect(bx + 1, by + 1, blockW - 2, blockH - 2);
cx.strokeStyle = 'rgba(40,38,35,0.7)';
cx.lineWidth = 1.5;
cx.strokeRect(bx, by, blockW, blockH);
}
}
var i;
for (i = 0; i < 30; i++) {
cx.fillStyle = 'rgba(50,45,35,' + (Math.random() * 0.3) + ')';
cx.beginPath();
cx.arc(Math.random() * cw, Math.random() * ch, Math.random() * 30 + 5, 0, Math.PI * 2);
cx.fill();
}
var d;
for (d = 0; d < 6; d++) {
var dx = 40 + Math.random() * (cw - 80);
var dWidth = 3 + Math.random() * 5;
var dLen = ch * (0.4 + Math.random() * 0.6);
var grd = cx.createLinearGradient(dx, 0, dx, dLen);
grd.addColorStop(0, 'rgba(20,18,12,0.85)');
grd.addColorStop(0.3, 'rgba(25,20,14,0.7)');
grd.addColorStop(0.7, 'rgba(20,18,12,0.4)');
grd.addColorStop(1, 'rgba(20,18,12,0)');
cx.fillStyle = grd;
cx.beginPath();
cx.moveTo(dx - dWidth/2, 0);
cx.quadraticCurveTo(dx + dWidth, dLen * 0.3, dx - dWidth * 0.3, dLen * 0.6);
cx.quadraticCurveTo(dx + dWidth * 0.5, dLen * 0.85, dx, dLen);
cx.lineTo(dx + dWidth, dLen);
cx.quadraticCurveTo(dx + dWidth * 1.5, dLen * 0.85, dx + dWidth * 1.3, dLen * 0.6);
cx.quadraticCurveTo(dx - dWidth * 0.5, dLen * 0.3, dx + dWidth/2, 0);
cx.closePath();
cx.fill();
cx.fillStyle = 'rgba(80,75,65,0.2)';
cx.fillRect(dx - dWidth/2, 0, dWidth, 8);
}
});
}

var leftWallTex = makeBlockWallTex(512, 256);
var leftWallMat = new THREE.MeshStandardMaterial({ map: leftWallTex, roughness: 0.9 });
var leftWall = new THREE.Mesh(new THREE.PlaneGeometry(roomLength, roomHeight), leftWallMat);
leftWall.position.set(-halfW, roomHeight / 2, 0);
leftWall.rotation.y = Math.PI / 2;
leftWall.receiveShadow = true;
wallGroup.add(leftWall);

var rightWallTex = makeBlockWallTex(512, 256);
var rightWallMat = new THREE.MeshStandardMaterial({ map: rightWallTex, roughness: 0.9 });
var rightWall = new THREE.Mesh(new THREE.PlaneGeometry(roomLength, roomHeight), rightWallMat);
rightWall.position.set(halfW, roomHeight / 2, 0);
rightWall.rotation.y = -Math.PI / 2;
rightWall.receiveShadow = true;
wallGroup.add(rightWall);

var farWallTex = makeBlockWallTex(512, 256);
var farWallMat = new THREE.MeshStandardMaterial({ map: farWallTex, roughness: 0.9 });
var farWall = new THREE.Mesh(new THREE.PlaneGeometry(roomWidth, roomHeight), farWallMat);
farWall.position.set(0, roomHeight / 2, -halfL);
farWall.receiveShadow = true;
wallGroup.add(farWall);

var nearWall = new THREE.Mesh(new THREE.PlaneGeometry(roomWidth, roomHeight), concreteMat);
nearWall.position.set(0, roomHeight / 2, halfL);
nearWall.rotation.y = Math.PI;
nearWall.receiveShadow = true;
wallGroup.add(nearWall);

// ============================================================
// CEILING
// ============================================================
var ceilGroup = new THREE.Group();
scene.add(ceilGroup);

var ceilingTex = makeCanvasTexture(512, 256, function(cx, cw, ch) {
cx.fillStyle = '#4a4038';
cx.fillRect(0, 0, cw, ch);
var i;
for (i = 0; i < 15; i++) {
cx.fillStyle = 'rgba(60,50,35,' + (Math.random() * 0.3 + 0.1) + ')';
cx.beginPath();
cx.ellipse(Math.random() * cw, Math.random() * ch, Math.random() * 50 + 20, Math.random() * 20 + 10, 0, 0, Math.PI * 2);
cx.fill();
}
});
var ceilMatTex = new THREE.MeshStandardMaterial({ map: ceilingTex, roughness: 0.9, side: THREE.DoubleSide });
var ceiling = new THREE.Mesh(new THREE.PlaneGeometry(roomWidth, roomLength), ceilMatTex);
ceiling.rotation.x = Math.PI / 2;
ceiling.position.set(0, roomHeight, 0);
ceiling.receiveShadow = true;
ceilGroup.add(ceiling);

// ============================================================
// JOISTS
// ============================================================
var joistGroup = new THREE.Group();
scene.add(joistGroup);

var jz;
for (jz = -halfL + 1; jz <= halfL - 1; jz += 1.8) {
box(joistGroup, roomWidth - 0.2, 0.12, 0.08, woodBeam, 0, roomHeight - 0.06, jz);
}
box(joistGroup, 0.15, 0.2, roomLength - 0.4, woodBeam, -1.5, roomHeight - 0.1, 0);
box(joistGroup, 0.15, 0.2, roomLength - 0.4, woodBeam, 1.5, roomHeight - 0.1, 0);

// ============================================================
// SUPPORT POSTS
