clLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
clWrap.appendChild(clLoc);

// Button
var clBtn = document.createElement('div');
clBtn.textContent = "COPPER'S LAIR";
clBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(180,170,150,0.85);border:1px solid rgba(180,170,150,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
setTimeout(function() { clBtn.style.opacity = '1'; }, 2500);
clBtn.addEventListener('mouseenter', function() {
clBtn.style.color = 'rgba(210,200,170,0.95)';
clBtn.style.borderColor = 'rgba(180,170,150,0.6)';
});
clBtn.addEventListener('mouseleave', function() {
clBtn.style.color = 'rgba(180,170,150,0.85)';
clBtn.style.borderColor = 'rgba(180,170,150,0.3)';
});
clBtn.addEventListener('click', function() {
clWrap.style.transition = 'opacity 1.5s ease';
clWrap.style.opacity = '0';
setTimeout(function() {
if (clAnimId) cancelAnimationFrame(clAnimId);
clAnimId = null;
if (clWrap.parentNode) clWrap.parentNode.removeChild(clWrap);
var TARGET = "Turn to Copper";
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
clWrap.appendChild(clBtn);

document.body.appendChild(clWrap);
}

setInterval(function() {
var container = document.getElementById('cl-container');
if (container && !clActive) {
initCoppersLair();
} else if (!container) {
clActive = false;
if (clAnimId) { cancelAnimationFrame(clAnimId); clAnimId = null; }
window._dssDisposeWrap('cl-wrap');
}
}, 300);
})();
// ====== TRISHA'S SCENE — INLINE ======
(function() {
var tsActive = false;
var tsAnimId = null;

function initTrishas() {
if (tsActive) return;
tsActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildTSScene(); };
document.head.appendChild(s);
} else {
buildTSScene();
}
}

function buildTSScene() {
var tsWrap = document.createElement('div');
tsWrap.id = 'ts-wrap';
tsWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#05040a;';

var scene = new THREE.Scene();
scene.background = new THREE.Color(0x05040a);
scene.fog = new THREE.FogExp2(0x05040a, 0.09);

var camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.set(-0.6, 3.0, 7.0);
camera.lookAt(0, 2.4, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.68;
tsWrap.appendChild(renderer.domElement);
window._dssBindScene('ts-wrap', scene, renderer, camera);

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat); m.position.set(x, y, z); scene.add(m); return m;
}

function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

// Red London brick
var brickTex = makeCanvasTexture(512, 1024, function(cx, w, h) {
cx.fillStyle='#3e2820'; cx.fillRect(0,0,w,h);
var brickH=18, mortarW=3, brickW=54;
for (var row=0; row<Math.ceil(h/(brickH+mortarW)); row++) {
var by=row*(brickH+mortarW), offset=(row%2===0)?0:brickW/2;
for (var bx=-brickW; bx<w+brickW; bx+=brickW+mortarW) {
var xb=bx+offset, r=90+Math.floor(Math.random()*30), g=42+Math.floor(Math.random()*18), b=28+Math.floor(Math.random()*14);
cx.fillStyle='rgb('+r+','+g+','+b+')'; cx.fillRect(xb,by,brickW,brickH);
cx.fillStyle='rgba('+(r+12)+','+(g+8)+','+(b+4)+',0.18)'; cx.fillRect(xb+2,by+2,brickW-4,brickH-4);
}
cx.fillStyle='rgba(48,38,30,0.65)'; cx.fillRect(0,by+brickH,w,mortarW);
}
for (var row=0; row<Math.ceil(h/(brickH+mortarW)); row++) {
var by=row*(brickH+mortarW), offset=(row%2===0)?0:brickW/2;
for (var bx=-brickW; bx<w+brickW; bx+=brickW+mortarW) { cx.fillStyle='rgba(48,38,30,0.55)'; cx.fillRect(bx+offset-1,by,mortarW,brickH); }
}
var soot=cx.createLinearGradient(0,0,0,h);
soot.addColorStop(0,'rgba(8,5,3,0.45)'); soot.addColorStop(0.12,'rgba(10,6,3,0.20)');
soot.addColorStop(0.5,'rgba(8,5,2,0.10)'); soot.addColorStop(0.88,'rgba(8,5,2,0.14)'); soot.addColorStop(1,'rgba(6,4,2,0.38)');
cx.fillStyle=soot; cx.fillRect(0,0,w,h);
cx.strokeStyle='rgba(16,10,6,0.12)'; cx.lineWidth=2;
for (var rs=0; rs<28; rs++) { cx.beginPath(); var rxs=Math.random()*w; cx.moveTo(rxs,0); for (var rys=0; rys<h; rys+=22) { rxs+=(Math.random()-0.5)*3; cx.lineTo(rxs,rys); } cx.stroke(); }
cx.fillStyle='rgba(15,10,6,0.16)';
for (var dp=0;dp<7;dp++){cx.beginPath();cx.ellipse(Math.random()*w,h*0.55+Math.random()*h*0.45,30+Math.random()*55,20+Math.random()*35,Math.random(),0,Math.PI*2);cx.fill();}
cx.fillStyle='rgba(22,35,12,0.18)'; cx.fillRect(0,h*0.91,w,h*0.09);
});
// Pavement
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle='#2e2818'; cx.fillRect(0,0,w,h);
var flagRows=[{y:0,h:130},{y:130,h:115},{y:245,h:135},{y:380,h:132}];
for (var ri=0;ri<flagRows.length;ri++){
var row=flagRows[ri], slabs=(ri%2===0)?[0,195,375]:[0,255,415];
for (var si=0;si<slabs.length;si++){
var sx=slabs[si], sw=(si<slabs.length-1)?slabs[si+1]-sx:w-sx;
var tone=32+Math.random()*16; cx.fillStyle='rgb('+(tone)+','+(tone-4)+','+(tone-10)+')'; cx.fillRect(sx+2,row.y+2,sw-4,row.h-4);
}
cx.strokeStyle='rgba(16,13,8,0.72)'; cx.lineWidth=3; cx.beginPath(); cx.moveTo(0,row.y); cx.lineTo(w,row.y); cx.stroke();
}
cx.fillStyle='rgba(18,15,9,0.28)';
for (var st=0;st<14;st++){cx.beginPath();cx.ellipse(Math.random()*w,Math.random()*h,10+Math.random()*28,7+Math.random()*18,Math.random()*Math.PI,0,Math.PI*2);cx.fill();}
var ref=cx.createLinearGradient(0,0,w,0);
ref.addColorStop(0,'rgba(0,0,0,0)'); ref.addColorStop(0.25,'rgba(180,110,30,0.06)'); ref.addColorStop(0.45,'rgba(200,130,40,0.10)'); ref.addColorStop(0.65,'rgba(180,110,30,0.06)'); ref.addColorStop(1,'rgba(0,0,0,0)');
cx.fillStyle=ref; cx.fillRect(0,0,w,h);
});
// Door texture
var blackDoorTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle='#0c0c0e'; cx.fillRect(0,0,w,h);
cx.strokeStyle='rgba(20,20,24,0.45)'; cx.lineWidth=1;
for (var gx=0;gx<w;gx+=3+Math.random()*4){cx.beginPath();cx.moveTo(gx,0);cx.lineTo(gx+(Math.random()-0.5)*2,h);cx.stroke();}
cx.fillStyle='rgba(30,28,35,0.15)'; cx.fillRect(0,0,10,h);
cx.fillStyle='rgba(18,16,14,0.35)';
for (var sc=0;sc<10;sc++){cx.fillRect(Math.random()*w,h-18-Math.random()*55,12+Math.random()*22,1+Math.random()*2);}
});
// White stone doorcase
var whiteStoneTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle='#c2baa8'; cx.fillRect(0,0,w,h);
cx.strokeStyle='rgba(140,130,110,0.08)'; cx.lineWidth=1;
for (var rs=0;rs<12;rs++){cx.beginPath();var rxs=Math.random()*w;cx.moveTo(rxs,0);for (var rys=0;rys<h;rys+=40){rxs+=(Math.random()-0.5)*3;cx.lineTo(rxs,rys);}cx.stroke();}
var sh=cx.createLinearGradient(0,h*0.75,0,h); sh.addColorStop(0,'rgba(60,50,35,0)'); sh.addColorStop(1,'rgba(60,50,35,0.22)');
cx.fillStyle=sh; cx.fillRect(0,0,w,h);
cx.strokeStyle='rgba(100,90,75,0.12)'; cx.lineWidth=0.7;
for (var cr=0;cr<8;cr++){cx.beginPath();cx.moveTo(Math.random()*w,Math.random()*h);cx.lineTo(Math.random()*w,Math.random()*h);cx.stroke();}
});
// Awning sign
var awningSignTex = makeCanvasTexture(512, 256, function(cx, w, h) {
cx.fillStyle='#080808'; cx.fillRect(0,0,w,h);
var glow=cx.createRadialGradient(w/2,h/2,0,w/2,h/2,w*0.55);
glow.addColorStop(0,'rgba(180,110,20,0.18)'); glow.addColorStop(1,'rgba(0,0,0,0)');
cx.fillStyle=glow; cx.fillRect(0,0,w,h);
cx.font='italic bold 62px Georgia, serif'; cx.textAlign='center'; cx.textBaseline='middle';
cx.fillStyle='#c8981e'; cx.fillText("Trisha's",w/2,h*0.38);
cx.strokeStyle='rgba(180,140,30,0.55)'; cx.lineWidth=1.5;
cx.beginPath(); cx.moveTo(w*0.28,h*0.56); cx.lineTo(w*0.72,h*0.56); cx.stroke();
cx.font='small-caps 22px Georgia, serif'; cx.fillStyle='rgba(190,148,40,0.80)'; cx.fillText('Est. 1839',w/2,h*0.70);
});

// Materials
var facadeBrick  = new THREE.MeshStandardMaterial({ map:brickTex, roughness:0.92 });
var paveMat      = new THREE.MeshStandardMaterial({ map:paveTex, roughness:0.88 });
var roadMat      = new THREE.MeshStandardMaterial({ color:0x0c0c0a, roughness:0.9 });
var kerbMat      = new THREE.MeshStandardMaterial({ color:0x383632, roughness:0.88 });
var blackDoorMat = new THREE.MeshStandardMaterial({ map:blackDoorTex, roughness:0.28, metalness:0.12 });
var whiteStoneMat= new THREE.MeshStandardMaterial({ map:whiteStoneTex, roughness:0.80 });
var brassMat     = new THREE.MeshStandardMaterial({ color:0xb08828, roughness:0.22, metalness:0.88 });
var brassMatDull = new THREE.MeshStandardMaterial({ color:0x806018, roughness:0.45, metalness:0.65 });
var ironMat      = new THREE.MeshStandardMaterial({ color:0x161614, roughness:0.65, metalness:0.38 });
var awningBlack  = new THREE.MeshStandardMaterial({ color:0x080808, roughness:0.55, side:THREE.DoubleSide });
var awningSign   = new THREE.MeshStandardMaterial({ map:awningSignTex, roughness:0.50, side:THREE.FrontSide });
var blackPanelMat= new THREE.MeshStandardMaterial({ color:0x0e0e10, roughness:0.38, metalness:0.08 });
var lanternGlass = new THREE.MeshStandardMaterial({ color:0x1a0c02, roughness:0.2, emissive:0xd47010, emissiveIntensity:0.9 });
var darkBrick    = new THREE.MeshStandardMaterial({ color:0x1e1410, roughness:0.92 });
var fanlightMat  = new THREE.MeshStandardMaterial({ color:0x0a0a10, roughness:0.2, metalness:0.2, emissive:0xc87818, emissiveIntensity:0.05 });

// Building
placeMesh(new THREE.BoxGeometry(8,9,0.28), facadeBrick, 0,4.0,0);
placeMesh(new THREE.BoxGeometry(8,3.5,0.28), facadeBrick, 0,9.25,0);
placeMesh(new THREE.BoxGeometry(0.3,12,4), darkBrick, -4.15,4.5,-1.8);
placeMesh(new THREE.BoxGeometry(0.3,12,4), darkBrick,  4.15,4.5,-1.8);
// Doorcase
placeMesh(new THREE.BoxGeometry(0.32,3.6,0.18), whiteStoneMat, -0.72,2.25,0.15);
placeMesh(new THREE.BoxGeometry(0.32,3.6,0.18), whiteStoneMat,  0.72,2.25,0.15);
placeMesh(new THREE.BoxGeometry(1.82,0.30,0.22), whiteStoneMat, 0,4.08,0.14);
placeMesh(new THREE.BoxGeometry(0.36,0.22,0.20), whiteStoneMat, -0.72,0.46,0.15);
placeMesh(new THREE.BoxGeometry(0.36,0.22,0.20), whiteStoneMat,  0.72,0.46,0.15);
// Door
var tsDoor = new THREE.Mesh(new THREE.BoxGeometry(1.08,2.55,0.07), blackDoorMat);
tsDoor.position.set(0,1.90,0.19); scene.add(tsDoor);
var pW=0.38, pH=0.62, pD=0.025;
var panelOffsets=[[-0.24,2.90],[0.24,2.90],[-0.24,2.15],[0.24,2.15],[-0.24,1.38],[0.24,1.38]];
for (var pi=0;pi<panelOffsets.length;pi++){
var pm=new THREE.Mesh(new THREE.BoxGeometry(pW,pH,pD), blackPanelMat); pm.position.set(panelOffsets[pi][0],panelOffsets[pi][1],0.225); scene.add(pm);
}
var lbMesh=new THREE.Mesh(new THREE.BoxGeometry(0.28,0.055,0.045), brassMat); lbMesh.position.set(-0.08,1.62,0.228); scene.add(lbMesh);
var knob=new THREE.Mesh(new THREE.SphereGeometry(0.045,8,8), brassMat); knob.position.set(0.36,1.90,0.235); scene.add(knob);
placeMesh(new THREE.BoxGeometry(0.06,0.16,0.018), brassMatDull, 0.36,1.90,0.222);
var num57Tex=makeCanvasTexture(64,48,function(cx,w,h){cx.fillStyle='#0c0c0e';cx.fillRect(0,0,w,h);cx.font='bold 26px Georgia, serif';cx.fillStyle='rgba(180,145,55,0.85)';cx.textAlign='center';cx.textBaseline='middle';cx.fillText('57',w/2,h/2);});
placeMesh(new THREE.PlaneGeometry(0.16,0.12), new THREE.MeshStandardMaterial({map:num57Tex,roughness:0.5}), 0.0,2.52,0.226);
// Fanlight
placeMesh(new THREE.BoxGeometry(0.96,0.28,0.06), fanlightMat, 0,3.34,0.19);
placeMesh(new THREE.BoxGeometry(0.96,0.022,0.065), blackPanelMat, 0,3.34,0.20);
placeMesh(new THREE.BoxGeometry(0.022,0.28,0.065), blackPanelMat, 0,3.34,0.20);
// Awning
var awningPoints=[];
for (var i=0;i<=14;i++){var t=(i/14)*Math.PI*0.5;awningPoints.push(new THREE.Vector2(Math.sin(t)*1.05,Math.cos(t)*0.68));}
var awningDome=new THREE.Mesh(new THREE.LatheGeometry(awningPoints,20), awningBlack);
awningDome.rotation.x=Math.PI; awningDome.scale.set(1.0,1.0,0.85); awningDome.position.set(0,4.42,0.52); scene.add(awningDome);
var awningUnder=new THREE.Mesh(new THREE.CircleGeometry(1.02,20),new THREE.MeshStandardMaterial({color:0x1a0c02,emissive:0xc06010,emissiveIntensity:0.30,side:THREE.DoubleSide}));
awningUnder.rotation.x=-Math.PI/2; awningUnder.scale.set(1.0,0.85,1.0); awningUnder.position.set(0,4.42,0.52); scene.add(awningUnder);
var awningFace=new THREE.Mesh(new THREE.PlaneGeometry(1.85,0.88), awningSign);
awningFace.position.set(0,4.75,1.10); awningFace.rotation.x=-0.25; scene.add(awningFace);
placeMesh(new THREE.BoxGeometry(2.12,0.10,0.015), awningBlack, 0,4.42,1.08);
// Wall lantern
var bracket=new THREE.Mesh(new THREE.BoxGeometry(0.32,0.04,0.04), ironMat); bracket.position.set(-0.95,3.55,0.40); scene.add(bracket);
var bracketV=new THREE.Mesh(new THREE.BoxGeometry(0.04,0.28,0.04), ironMat); bracketV.position.set(-1.08,3.44,0.40); scene.add(bracketV);
placeMesh(new THREE.BoxGeometry(0.20,0.28,0.20), ironMat, -1.09,3.22,0.40);
placeMesh(new THREE.BoxGeometry(0.16,0.22,0.16), lanternGlass, -1.09,3.22,0.40);
placeMesh(new THREE.BoxGeometry(0.24,0.06,0.24), ironMat, -1.09,3.37,0.40);
placeMesh(new THREE.CylinderGeometry(0.08,0.10,0.06,8), ironMat, -1.09,3.07,0.40);
var houseNumTex=makeCanvasTexture(64,80,function(cx,w,h){cx.clearRect(0,0,w,h);cx.font='bold 36px Georgia, serif';cx.fillStyle='rgba(210,195,165,0.90)';cx.textAlign='center';cx.textBaseline='middle';cx.fillText('57',w/2,h/2);});
placeMesh(new THREE.PlaneGeometry(0.22,0.28),new THREE.MeshStandardMaterial({map:houseNumTex,roughness:0.6,transparent:true}),-1.55,3.10,0.16);
// Steps
placeMesh(new THREE.BoxGeometry(1.30,0.12,0.40), whiteStoneMat, 0,0.40,0.38);
placeMesh(new THREE.BoxGeometry(1.45,0.10,0.55), whiteStoneMat, 0,0.30,0.58);
// Pavement & road
var pave=new THREE.Mesh(new THREE.PlaneGeometry(9,4.5), paveMat); pave.rotation.x=-Math.PI/2; pave.position.set(0,0.35,2.8); scene.add(pave);
placeMesh(new THREE.BoxGeometry(9,0.14,0.14), kerbMat, 0,0.35,5.0);
var road=new THREE.Mesh(new THREE.PlaneGeometry(14,8), roadMat); road.rotation.x=-Math.PI/2; road.position.set(0,0.28,8.5); scene.add(road);
var groundFill=new THREE.Mesh(new THREE.PlaneGeometry(9,2.2), paveMat); groundFill.rotation.x=-Math.PI/2; groundFill.position.set(0,0.35,0.5); scene.add(groundFill);

// Lighting
scene.add(new THREE.AmbientLight(0x060510, 0.22));
var moon=new THREE.DirectionalLight(0x1a1830, 0.10); moon.position.set(3,10,6); scene.add(moon);
var tsLanternLight=new THREE.PointLight(0xd4780e,2.2,7.5,1.8); tsLanternLight.position.set(-1.09,3.18,0.88); tsLanternLight.castShadow=true; scene.add(tsLanternLight);
var awningGlow=new THREE.PointLight(0xd49018,0.80,4.0,2.0); awningGlow.position.set(0,4.20,0.90); scene.add(awningGlow);
var doorGlow=new THREE.PointLight(0xc07010,0.25,3.0,2.0); doorGlow.position.set(0,2.0,0.0); scene.add(doorGlow);

// Rain
var rainCount=400;
var rainPositions=new Float32Array(rainCount*6);
var rainVel=new Float32Array(rainCount);
for (var ri=0;ri<rainCount;ri++){
var rxr=(Math.random()-0.5)*14, ryr=Math.random()*12, rzr=Math.random()*9-1, lenr=0.08+Math.random()*0.08;
rainPositions[ri*6]=rxr; rainPositions[ri*6+1]=ryr; rainPositions[ri*6+2]=rzr;
rainPositions[ri*6+3]=rxr-0.02; rainPositions[ri*6+4]=ryr-lenr; rainPositions[ri*6+5]=rzr;
rainVel[ri]=0.06+Math.random()*0.05;
}
var rainGeo=new THREE.BufferGeometry();
rainGeo.setAttribute('position',new THREE.BufferAttribute(rainPositions,3));
var rain=new THREE.LineSegments(rainGeo,new THREE.LineBasicMaterial({color:0x8899aa,transparent:true,opacity:0.18})); scene.add(rain);

// Animation
function tsAnimate() {
tsAnimId=requestAnimationFrame(tsAnimate);
var rp=rainGeo.attributes.position.array;
for (var ri=0;ri<rainCount;ri++){
var drop=rainVel[ri]; rp[ri*6+1]-=drop; rp[ri*6+4]-=drop; rp[ri*6]-=drop*0.10; rp[ri*6+3]-=drop*0.10;
if (rp[ri*6+4]<0.2){
var rxr=(Math.random()-0.5)*14, ryr=11+Math.random()*2, rzr=Math.random()*9-1, lenr=0.08+Math.random()*0.08;
rp[ri*6]=rxr; rp[ri*6+1]=ryr; rp[ri*6+2]=rzr; rp[ri*6+3]=rxr-0.02; rp[ri*6+4]=ryr-lenr; rp[ri*6+5]=rzr;
}
}
rainGeo.attributes.position.needsUpdate=true;
var flicker=1.0+Math.sin(Date.now()*0.0031)*0.04+Math.sin(Date.now()*0.0077)*0.02;
tsLanternLight.intensity=2.2*flicker;
renderer.render(scene,camera);
}
tsAnimate();

// Overlays
var tsVig=document.createElement('div');
tsVig.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 25%, rgba(0,0,0,0.65) 100%);';
tsWrap.appendChild(tsVig);
var tsWash=document.createElement('div');
tsWash.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;background:linear-gradient(180deg, rgba(8,8,20,0.35) 0%, rgba(5,5,12,0.1) 30%, rgba(5,5,12,0.1) 60%, rgba(8,5,3,0.35) 100%);';
tsWrap.appendChild(tsWash);
var tsLoc=document.createElement('div');
tsLoc.textContent='GREEK STREET, SOHO';
tsLoc.style.cssText='position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
tsWrap.appendChild(tsLoc);
var tsBtn=document.createElement('div');
tsBtn.textContent="TRISHA'S";
tsBtn.style.cssText='position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(212,165,116,0.85);border:1px solid rgba(212,165,116,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
setTimeout(function(){tsBtn.style.opacity='1';},2500);
tsBtn.addEventListener('mouseenter',function(){tsBtn.style.color='rgba(230,195,150,0.95)';tsBtn.style.borderColor='rgba(212,165,116,0.6)';});
tsBtn.addEventListener('mouseleave',function(){tsBtn.style.color='rgba(212,165,116,0.85)';tsBtn.style.borderColor='rgba(212,165,116,0.3)';});
tsBtn.addEventListener('click',function(){
tsWrap.style.transition='opacity 1.5s ease'; tsWrap.style.opacity='0';
setTimeout(function(){
if (tsAnimId) cancelAnimationFrame(tsAnimId); tsAnimId=null;
if (tsWrap.parentNode) tsWrap.parentNode.removeChild(tsWrap);
var TARGET="Failure: Trisha's";
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else { var links=document.querySelectorAll('tw-link, .enchantment-link'); for (var i=0;i<links.length;i++){if (links[i].textContent.trim()==='·'){links[i].click();break;}} }
},1500);
});
tsWrap.appendChild(tsBtn);
document.body.appendChild(tsWrap);
}

setInterval(function(){
var container=document.getElementById('ts-container');
if (container && !tsActive) {
initTrishas();
} else if (!container) {
tsActive=false;
if (tsAnimId) { cancelAnimationFrame(tsAnimId); tsAnimId=null; }
window._dssDisposeWrap('ts-wrap');
}
},300);
})();
// ====== CENTRE POINT SCENE — INLINE ======
(function() {
var cpActive = false;
var cpAnimId = null;

function initCentrePoint() {
if (cpActive) return;
cpActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildCPScene(); };
document.head.appendChild(s);
} else {
buildCPScene();
}
}

function buildCPScene() {
var cpWrap = document.createElement('div');
cpWrap.id = 'cp-wrap';
cpWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#060810;';

// ============================================================
// HELPERS (defined first — used by materials below)
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
cpScene.add(m);
return m;
}

// ============================================================
// SCENE SETUP
// ============================================================
var cpScene = new THREE.Scene();
cpScene.background = new THREE.Color(0x060810);
cpScene.fog = new THREE.Fog(0x060810, 45, 220);

var cpCamera = new THREE.PerspectiveCamera(82, window.innerWidth / window.innerHeight, 0.1, 300);
cpCamera.position.set(0.6, 1.2, 5.0);
cpCamera.lookAt(0.3, 28, -2);

var cpRenderer;
try {
  cpRenderer = new THREE.WebGLRenderer({ antialias: true });
  cpRenderer.setSize(window.innerWidth, window.innerHeight);
  cpRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  cpRenderer.shadowMap.enabled = true;
  cpRenderer.shadowMap.type = THREE.PCFSoftShadowMap;
  cpRenderer.toneMapping = THREE.ACESFilmicToneMapping;
  cpRenderer.toneMappingExposure = 0.55;
  cpWrap.appendChild(cpRenderer.domElement);
  window._dssBindScene('cp-wrap', cpScene, cpRenderer, cpCamera);
} catch (e) {
  /* WebGL unavailable (Chrome's GPU process is unhealthy or too many contexts
     are active). Skip the 3D ladder; build a plain fallback so the player can
     still click CLIMB IT and progress through to the ending. The fallback uses
     the same CLIMB IT button styling created further down so it visually
     matches; we just stop the WebGL pipeline here. */
  console.warn('[DSS] WebGL unavailable for Centre Point — falling back to plain CLIMB IT button.', e);
  var fbCaption = document.createElement('div');
  fbCaption.textContent = 'Every man and every woman is a star.';
  fbCaption.style.cssText = 'position:fixed;bottom:110px;left:0;right:0;text-align:center;font-family:"Playfair Display",Georgia,serif;font-size:14px;color:#f5d070;letter-spacing:0.18em;text-transform:uppercase;pointer-events:none;z-index:9003;white-space:nowrap;text-shadow:0 0 8px rgba(245,208,112,0.55),0 0 16px rgba(245,208,112,0.25),0 0 2px rgba(8,6,4,0.95);';
  cpWrap.appendChild(fbCaption);
  var fbBtn = document.createElement('div');
  fbBtn.textContent = 'CLIMB IT';
  fbBtn.style.cssText = 'position:fixed;bottom:40px;left:50%;transform:translateX(-50%);padding:16px 42px;font:bold 20px "Courier New",monospace;color:rgba(255,255,250,1);border:2px solid rgba(255,252,232,1);letter-spacing:5px;cursor:pointer;z-index:9004;background:rgba(255,236,176,0.22);box-shadow:0 0 18px rgba(255,240,180,0.55),0 0 42px rgba(255,228,148,0.35),inset 0 0 14px rgba(255,248,212,0.25);text-shadow:0 0 8px rgba(255,255,255,1),0 0 18px rgba(255,252,220,1),0 0 36px rgba(255,236,168,0.85),0 0 58px rgba(255,220,140,0.55),0 0 2px rgba(8,6,4,0.85);';
  fbBtn.addEventListener('click', function() {
    var links = document.querySelectorAll('tw-link, .enchantment-link');
    for (var i = 0; i < links.length; i++) {
      if (links[i].textContent.trim() === '·') { links[i].click(); break; }
    }
  });
  cpWrap.appendChild(fbBtn);
  document.body.appendChild(cpWrap);
  return;
}

// ============================================================
// MATERIALS
// ============================================================

// Centre Point's distinctive off-white precast concrete panels
// with a slightly grainy aggregate finish — Portland stone dust mixed in
var concreteTex = makeCanvasTexture(512, 512, function(cx, w, h) {
// Base off-white — not pure white, slightly warm and aged
cx.fillStyle = '#cdc8bc';
cx.fillRect(0, 0, w, h);
// Aggregate texture — fine pebbled surface
for (var i = 0; i < 3000; i++) {
var gx = Math.random() * w;
var gy = Math.random() * h;
var gr = 0.8 + Math.random() * 1.8;
var tone = 150 + Math.random() * 60;
cx.fillStyle = 'rgba(' + tone + ',' + (tone-5) + ',' + (tone-10) + ',0.35)';
cx.beginPath();
cx.arc(gx, gy, gr, 0, Math.PI * 2);
cx.fill();
}
// Pollution staining — London grime running down from the top
var soot = cx.createLinearGradient(0, 0, 0, h);
soot.addColorStop(0,   'rgba(40, 38, 32, 0.18)');
soot.addColorStop(0.2, 'rgba(40, 38, 32, 0.08)');
soot.addColorStop(0.6, 'rgba(0,0,0,0)');
soot.addColorStop(1,   'rgba(40, 38, 32, 0.06)');
cx.fillStyle = soot;
cx.fillRect(0, 0, w, h);
// Rain streak staining
cx.strokeStyle = 'rgba(80, 75, 65, 0.05)';
cx.lineWidth = 1.5;
for (var rs = 0; rs < 18; rs++) {
cx.beginPath();
var rx = Math.random() * w;
cx.moveTo(rx, 0);
for (var ry = 0; ry < h; ry += 25) {
rx += (Math.random() - 0.5) * 3;
cx.lineTo(rx, ry);
}
cx.stroke();
}
});
var concreteMat = new THREE.MeshStandardMaterial({
map: concreteTex, roughness: 0.88, metalness: 0.0
});

// The dark recessed concrete between the honeycomb cells
var recessMat = new THREE.MeshStandardMaterial({
color: 0x1a1a18, roughness: 0.92
});

// Dark glass in the honeycomb windows — slightly reflective, 1973 tinted glass
var darkGlassTex = makeCanvasTexture(128, 128, function(cx, w, h) {
cx.fillStyle = '#080c10';
cx.fillRect(0, 0, w, h);
// Faint reflection — sky and light caught in the glass
var refl = cx.createLinearGradient(0, 0, w, h);
refl.addColorStop(0,   'rgba(60, 70, 90, 0.25)');
refl.addColorStop(0.4, 'rgba(20, 25, 35, 0.10)');
refl.addColorStop(1,   'rgba(5, 8, 12, 0.05)');
cx.fillStyle = refl;
cx.fillRect(0, 0, w, h);
});
var darkGlass = new THREE.MeshStandardMaterial({
map: darkGlassTex, roughness: 0.15, metalness: 0.55,
color: 0x0a0e14
});

// A few windows warmly lit — offices working late
var warmGlass = new THREE.MeshStandardMaterial({
color: 0x1a0c02, roughness: 0.3,
emissive: 0xd07020, emissiveIntensity: 0.28
});

// Very faintly lit window — fluorescent strip light, cold
var coldGlass = new THREE.MeshStandardMaterial({
color: 0x080c10, roughness: 0.3,
emissive: 0x8090b0, emissiveIntensity: 0.08
});

// Ground pavement
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#484840';
cx.fillRect(0, 0, w, h);
// Concrete paving slabs
cx.strokeStyle = 'rgba(20, 18, 14, 0.55)';
cx.lineWidth = 3;
for (var gx = 0; gx <= w; gx += 128) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx, h); cx.stroke();
}
for (var gy = 0; gy <= h; gy += 128) {
cx.beginPath(); cx.moveTo(0, gy); cx.lineTo(w, gy); cx.stroke();
}
// Surface grime and oil stains
cx.fillStyle = 'rgba(25, 22, 16, 0.15)';
for (var st = 0; st < 12; st++) {
cx.beginPath();
cx.ellipse(Math.random()*w, Math.random()*h, 10+Math.random()*30, 6+Math.random()*18, Math.random()*Math.PI, 0, Math.PI*2);
cx.fill();
}
});
var paveMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.92 });

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), paveMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
cpScene.add(ground);

// ============================================================
// CENTRE POINT TOWER
// ============================================================
// The building is a cylindrical-ish tower with a hexagonal/faceted
// plan. Each face of the tower has the distinctive deep-set honeycomb
// window grid: horizontal bands of precast concrete framing
// large trapezoidal glazed bays.
//
// We build it as a CylinderGeometry core (the structural mass)
// then tile the honeycomb facade panels onto the visible faces.

var tower = new THREE.Group();

// ----- CORE SHAFT -----
// 34-storey tower. In 1973 it dominated the Tottenham Court Road skyline.
// Scale: ~0.7 units per storey, so total ~24 units tall.
var STOREYS = 34;
var STOREY_H = 0.72;
var TOWER_H = STOREYS * STOREY_H;
var TOWER_R = 2.8;

// Octagonal core — the structural body
var coreGeo = new THREE.CylinderGeometry(TOWER_R, TOWER_R + 0.2, TOWER_H, 8, 1);
var core = new THREE.Mesh(coreGeo, recessMat);
core.position.set(0, TOWER_H / 2, 0);
tower.add(core);

// ----- HONEYCOMB FACADE PANELS -----
// Centre Point's signature: each storey has deep-set concrete ribs
// forming a diamond/hexagonal grid on the facade.
// We'll tile this on the front 3 faces of the octagon.

// Each honeycomb cell: a concrete surround (thick, projected forward)
// with a recessed glass pane inside.
// Cell dimensions roughly: 0.65 wide × 0.68 tall

var CELL_W = 0.62;
var CELL_H = 0.66;
var PANEL_DEPTH = 0.18;
var GLASS_INSET = 0.12;

// The angled faces of the octagon — we'll cover faces at angles:
// 0° (front), ±45° (front-flanks), and partially ±90° (sides)
var facadeAngles = [0, -45, 45, -90, 90];
var facadeWidths = [5.0, 3.5, 3.5, 2.2, 2.2];

// Random seed for consistent window lighting
var winStates = [];
for (var w = 0; w < 2000; w++) {
var r = Math.random();
winStates.push(r < 0.08 ? 'warm' : r < 0.13 ? 'cold' : 'dark');
}

var warmWindows = [];
var winIdx = 0;

facadeAngles.forEach(function(angleDeg, fi) {
var angleRad = angleDeg * Math.PI / 180;
var fWidth   = facadeWidths[fi];

// Position of this face: on the surface of the octagon
var faceDist = TOWER_R * Math.cos(Math.PI / 8);

var cols = Math.floor(fWidth / CELL_W);
var rows = STOREYS;

for (var row = 0; row < rows; row++) {
for (var col = 0; col < cols; col++) {

// Local position on the face
var lx = (col - (cols - 1) / 2) * CELL_W;
var ly = (row + 0.5) * CELL_H + 0.5;

// Odd rows offset by half a cell — the honeycomb stagger
if (row % 2 === 1) lx += CELL_W * 0.5;

// Concrete surround (the rib frame around each cell)
var surroundGeo = new THREE.BoxGeometry(CELL_W - 0.04, CELL_H - 0.04, PANEL_DEPTH);
var surround = new THREE.Mesh(surroundGeo, concreteMat);

// Glass pane — inset behind the surround
var glassState = winStates[winIdx % winStates.length];
winIdx++;
var glassMat = (glassState === 'warm') ? warmGlass :
(glassState === 'cold') ? coldGlass : darkGlass;

var glassGeo = new THREE.BoxGeometry(CELL_W * 0.72, CELL_H * 0.78, 0.04);
var glass = new THREE.Mesh(glassGeo, glassMat);
glass.position.z = -GLASS_INSET;

// The horizontal rib — a thin bar across the bottom of each cell
var ribGeo = new THREE.BoxGeometry(CELL_W, 0.06, PANEL_DEPTH + 0.04);
var rib = new THREE.Mesh(ribGeo, concreteMat);
rib.position.y = -(CELL_H / 2) + 0.03;

// Group the cell
var cell = new THREE.Group();
cell.add(surround);
cell.add(glass);
cell.add(rib);

// Position on the face, rotated to sit on the correct face of octagon
cell.position.set(lx, ly, faceDist);
cell.rotation.y = -angleRad;

// Rotate so x-axis aligns with the face
var worldPos = new THREE.Vector3();
var cosA = Math.cos(angleRad);
var sinA = Math.sin(angleRad);
cell.position.set(
lx * cosA - 0 * sinA,
ly,
lx * sinA + faceDist * cosA
);

if (glassState === 'warm') {
warmWindows.push({ x: cell.position.x, y: ly, z: cell.position.z });
}

tower.add(cell);
}
}
});

// ----- PODIUM / BASE -----
// The building sits on a broad podium at street level
var podiumGeo = new THREE.BoxGeometry(7, 2.0, 7);
var podium = new THREE.Mesh(podiumGeo, concreteMat);
podium.position.set(0, 1.0, 0);
tower.add(podium);

// Podium overhang / colonnade edge
var overhangGeo = new THREE.BoxGeometry(8.2, 0.25, 8.2);
var overhang = new THREE.Mesh(overhangGeo, concreteMat);
overhang.position.set(0, 2.1, 0);
tower.add(overhang);

// Colonnade pillars around the base
for (var pi = 0; pi < 8; pi++) {
var pa = (pi / 8) * Math.PI * 2;
var px = Math.sin(pa) * 3.8;
var pz = Math.cos(pa) * 3.8;
var pillarGeo = new THREE.CylinderGeometry(0.15, 0.18, 2.2, 8);
var pillar = new THREE.Mesh(pillarGeo, concreteMat);
pillar.position.set(px, 1.1, pz);
tower.add(pillar);
}

// ----- ROOF / CROWN -----
// The top of Centre Point has a distinctive recessed plant-room and
// a parapet with a slightly different profile
var roofSlab = new THREE.Mesh(
new THREE.CylinderGeometry(TOWER_R + 0.1, TOWER_R + 0.1, 0.4, 8),
concreteMat
);
roofSlab.position.set(0, TOWER_H + 0.2, 0);
tower.add(roofSlab);

// Plant room on roof
var plantRoom = new THREE.Mesh(
new THREE.BoxGeometry(3.5, 2.5, 3.5),
recessMat
);
plantRoom.position.set(0, TOWER_H + 1.65, 0);
tower.add(plantRoom);

// Roof parapet
var parapet = new THREE.Mesh(
new THREE.CylinderGeometry(TOWER_R + 0.3, TOWER_R + 0.3, 0.3, 8),
concreteMat
);
parapet.position.set(0, TOWER_H + 0.55, 0);
tower.add(parapet);

// Aviation warning light on top
var warningLight = new THREE.Mesh(
new THREE.SphereGeometry(0.12, 8, 6),
new THREE.MeshStandardMaterial({
color: 0x400000, roughness: 0.3,
emissive: 0xff2000, emissiveIntensity: 0.6
})
);
warningLight.position.set(0, TOWER_H + 3.2, 0);
tower.add(warningLight);

cpScene.add(tower);

// ============================================================
// LOWER BUILDING / PODIUM CONTEXT — the smaller block at the base
// ============================================================
// Centre Point had a lower surrounding block — shops, service access
var lowerBlock = new THREE.Mesh(
new THREE.BoxGeometry(10, 5.5, 8),
concreteMat
);
lowerBlock.position.set(0, 2.75, -3.5);
cpScene.add(lowerBlock);

// A few windows on the lower block
for (var lb = 0; lb < 6; lb++) {
var lwx = -3.5 + lb * 1.4;
var lwGlass = (Math.random() < 0.3) ? warmGlass : darkGlass;
var lwin = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.9, 0.06), lwGlass);
lwin.position.set(lwx, 3.8, 0.5);
cpScene.add(lwin);
}

// ============================================================
// SKY — night sky with a faint sodium glow on the horizon
// ============================================================
// Sky dome
var skyGeo = new THREE.SphereGeometry(150, 16, 8);
var skyTex = makeCanvasTexture(512, 256, function(cx, w, h) {
// Very dark blue-black night sky
var skyGrad = cx.createLinearGradient(0, 0, 0, h);
skyGrad.addColorStop(0,    '#030408');
skyGrad.addColorStop(0.5,  '#060810');
skyGrad.addColorStop(0.75, '#0c0e18');
skyGrad.addColorStop(0.85, '#1a1008');
skyGrad.addColorStop(1,    '#2a1a08');
cx.fillStyle = skyGrad;
cx.fillRect(0, 0, w, h);
// Stars — faint
cx.fillStyle = 'rgba(255,255,255,0.7)';
for (var s = 0; s < 180; s++) {
var sx = Math.random() * w;
var sy = Math.random() * h * 0.7;
var sr = 0.4 + Math.random() * 0.8;
cx.beginPath();
cx.arc(sx, sy, sr, 0, Math.PI * 2);
cx.fill();
}
});
var skyMat = new THREE.MeshBasicMaterial({ map: skyTex, side: THREE.BackSide });
var sky = new THREE.Mesh(skyGeo, skyMat);
cpScene.add(sky);

// ============================================================
// STARS
// ============================================================
var starTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var g = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
g.addColorStop(0,    'rgba(255,255,255,0.95)');
g.addColorStop(0.12, 'rgba(255,255,255,0.6)');
g.addColorStop(0.4,  'rgba(200,210,255,0.15)');
g.addColorStop(1,    'rgba(0,0,0,0)');
cx.fillStyle = g;
cx.fillRect(0, 0, w, h);
});

for (var si = 0; si < 220; si++) {
var sMat = new THREE.SpriteMaterial({
map: starTex, transparent: true,
opacity: 0.3 + Math.random() * 0.7,
fog: false
});
var sSpr = new THREE.Sprite(sMat);
var sTheta = Math.random() * Math.PI * 2;
var sPhi   = 0.05 + Math.random() * 0.45;
var sDist  = 90 + Math.random() * 30;
sSpr.position.set(
Math.sin(sTheta) * Math.sin(sPhi) * sDist,
Math.cos(sPhi)   * sDist * 0.6 + 15,
Math.cos(sTheta) * Math.sin(sPhi) * sDist - 20
);
var sSz = 0.4 + Math.random() * 1.1;
sSpr.scale.set(sSz, sSz, 1);
cpScene.add(sSpr);
}

// ============================================================
// TOWER UPLIGHTING — dramatic uplights on the base washing the concrete
// ============================================================
var upLight1 = new THREE.SpotLight(0xfff0d0, 1.8, 35, Math.PI / 7, 0.5);
upLight1.position.set(-3, 0.5, 4.5);
upLight1.target.position.set(-1, 15, 0);
cpScene.add(upLight1);
cpScene.add(upLight1.target);

var upLight2 = new THREE.SpotLight(0xfff0d0, 1.5, 35, Math.PI / 7, 0.5);
upLight2.position.set(3, 0.5, 4.5);
upLight2.target.position.set(1, 15, 0);
cpScene.add(upLight2);
cpScene.add(upLight2.target);

var upLight3 = new THREE.SpotLight(0xffe8b0, 1.0, 40, Math.PI / 8, 0.6);
upLight3.position.set(0, 0.5, 5.5);
upLight3.target.position.set(0, 22, 0);
cpScene.add(upLight3);
cpScene.add(upLight3.target);

// ============================================================
// WARM WINDOW GLOW LIGHTS
// ============================================================
// Add a few point lights near the warmly lit windows
var windowGlows = [];
var glowSubset = warmWindows.slice(0, 8);
glowSubset.forEach(function(ww) {
var wl = new THREE.PointLight(0xd07020, 0.18, 3.5);
wl.position.set(ww.x * 0.85, ww.y, ww.z * 0.85 + 0.5);
cpScene.add(wl);
windowGlows.push(wl);
});

// ============================================================
// AVIATION WARNING LIGHT — animated red blink
// ============================================================
var avLight = new THREE.PointLight(0xff2000, 0.0, 20);
avLight.position.set(0, TOWER_H + 3.3, 0);
cpScene.add(avLight);

// ============================================================
// AMBIENT + MOON
// ============================================================
cpScene.add(new THREE.AmbientLight(0x05060e, 0.12));

var moonLight = new THREE.DirectionalLight(0x1a2255, 0.06);
moonLight.position.set(-8, 30, 10);
cpScene.add(moonLight);

// ============================================================
// FOG SPRITES — ground-level murk
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0,   'rgba(130,125,115,0.28)');
grad.addColorStop(0.5, 'rgba(100, 95, 85,0.12)');
grad.addColorStop(1,   'rgba(70, 65, 55, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var sodiumFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0,   'rgba(220,110,20,0.22)');
grad.addColorStop(0.4, 'rgba(190, 85,14,0.10)');
grad.addColorStop(1,   'rgba(140, 55, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

for (var fi = 0; fi < 50; fi++) {
var fMat = new THREE.SpriteMaterial({
map: (fi < 35) ? thickFogTex : sodiumFogTex,
transparent: true, opacity: 0.2 + Math.random() * 0.2
});
var fs = new THREE.Sprite(fMat);
fs.position.set(Math.random() * 40 - 18, 0.2 + Math.random() * 2.0, Math.random() * 25 - 3);
var fsc = 6 + Math.random() * 14;
fs.scale.set(fsc, fsc * 0.28, 1);
cpScene.add(fs);
fogSprites.push({
sprite: fs, baseX: fs.position.x,
drift: 0.002 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.003,
swayAmt: 0.5 + Math.random() * 1.2
});
}

// ============================================================
// NEON BLUE LADDER — two rails + cross rungs up the central gap
// ============================================================
var LADDER_X    = 0.0;
var RAIL_SEP    = 0.32;
var LADDER_Z    = TOWER_R + 0.4;
var RUNG_COUNT  = STOREYS + 2;
var RUNG_SPACING = STOREY_H;

// Base neon material — shared by rails
var neonMat = new THREE.MeshStandardMaterial({
color: 0x001833,
emissive: new THREE.Color(0x00aaff),
emissiveIntensity: 2.2,
roughness: 0.15,
metalness: 0.0,
fog: false
});

// LEFT RAIL
var leftRail = new THREE.Mesh(
new THREE.BoxGeometry(0.055, TOWER_H + 2, 0.055),
neonMat
);
leftRail.position.set(-RAIL_SEP, (TOWER_H + 2) / 2 + 0.5, LADDER_Z);
cpScene.add(leftRail);

// RIGHT RAIL
var rightRail = new THREE.Mesh(
new THREE.BoxGeometry(0.055, TOWER_H + 2, 0.055),
neonMat
);
rightRail.position.set(RAIL_SEP, (TOWER_H + 2) / 2 + 0.5, LADDER_Z);
cpScene.add(rightRail);

// RUNGS — flat boxes spanning between the rails, clearly visible face-on
var rungMeshes = [];
for (var rung = 0; rung < RUNG_COUNT; rung++) {
var ry = 0.8 + rung * RUNG_SPACING;
var rungMat = neonMat.clone();
var rungMesh = new THREE.Mesh(
new THREE.BoxGeometry(RAIL_SEP * 2, 0.07, 0.07),
rungMat
);
rungMesh.position.set(0, ry, LADDER_Z);
cpScene.add(rungMesh);
rungMeshes.push(rungMesh);
}

// Travelling pulse light
var pulseLight = new THREE.PointLight(0x00aaff, 0.0, 7);
cpScene.add(pulseLight);

// Soft base glow pooling at the bottom
var ladderBaseGlow = new THREE.PointLight(0x0055cc, 0.5, 10);
ladderBaseGlow.position.set(0, 1.5, LADDER_Z + 1);
cpScene.add(ladderBaseGlow);

// ============================================================
// ANIMATION
// ============================================================
var cpClock = new THREE.Clock();
var avBlinkPhase = 0;

function cpAnimate() {
cpAnimId = requestAnimationFrame(cpAnimate);
var t = cpClock.getElapsedTime();

// --- UPLIGHTING — slow breathing, like a building being dramatic ---
var upBreath = 0.96 + Math.sin(t * 0.18) * 0.03;
upLight1.intensity = 1.8 * upBreath;
upLight2.intensity = 1.5 * upBreath;
upLight3.intensity = 1.0 * upBreath;

// --- AVIATION LIGHT — slow red blink, every ~4 seconds ---
avBlinkPhase += 0.016;
var avCycle = Math.sin(avBlinkPhase * 0.8);
var avOn = avCycle > 0.85;
avLight.intensity = avOn ? (avCycle - 0.85) * 12 : 0;
warningLight.material.emissiveIntensity = avOn ? 0.8 + (avCycle - 0.85) * 4 : 0.08;

// --- WINDOW GLOW PULSE (very slow, nearly static) ---
for (var wgi = 0; wgi < windowGlows.length; wgi++) {
windowGlows[wgi].intensity = 0.15 + Math.sin(t * 0.08 + wgi * 0.9) * 0.04;
}

// --- NEON LADDER PULSE ---
// A bright pulse travels upward continuously, looping from bottom to top
var PULSE_SPEED = 4.5;
var pulsePos = (t * PULSE_SPEED) % (RUNG_COUNT + 4);
var pulseY   = 0.8 + pulsePos * RUNG_SPACING;

// Move the travelling point light
pulseLight.position.set(LADDER_X, pulseY, LADDER_Z + 0.8);

// Each rung brightness: peak when pulse is at that rung, fades off quickly
for (var ri = 0; ri < rungMeshes.length; ri++) {
var dist = Math.abs(ri - pulsePos);
var brightness = Math.max(0, 1.0 - dist * 0.55);
// Base flicker on the neon — slow, like a real tube
var neonFlicker = 0.88 + Math.sin(t * 1.4 + ri * 0.3) * 0.06
+ Math.sin(t * 3.1 + ri * 0.7) * 0.03;
rungMeshes[ri].material.emissiveIntensity = (0.5 + brightness * 1.8) * neonFlicker;
}

// Spine pulses with overall neon flicker
var spineFlicker = 0.9 + Math.sin(t * 1.2) * 0.05 + Math.sin(t * 2.8) * 0.03;
leftRail.material.emissiveIntensity  = 1.0 * spineFlicker;
rightRail.material.emissiveIntensity = 1.0 * spineFlicker;

// The pulse light intensity peaks at the centre of the travel
pulseLight.intensity = 1.2 + Math.sin(t * 1.8) * 0.2;

// Base glow breathes slowly
ladderBaseGlow.intensity = 0.35 + Math.sin(t * 0.4) * 0.12;

// --- FOG DRIFT ---
for (var fdi = 0; fdi < fogSprites.length; fdi++) {
var f = fogSprites[fdi];
f.sway += f.swaySpeed;
f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
f.baseX += f.drift;
if (f.baseX > 22) f.baseX = -18;
}

cpRenderer.render(cpScene, cpCamera);
}

cpAnimate();

// Vignette
var cpVig = document.createElement('div');
cpVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
cpWrap.appendChild(cpVig);

// Datestamp

// Caption — Crowley's Thelemic line, sitting ABOVE the CLIMB IT button.
// Styled to match the "There is no part of me that is not of the Gods"
// quote that appears after the liver-eating: Playfair Display caps, gold,
// no italic. Caption bottom (≈130px) sits clear above the button at ≈88px.
var cpLoc = document.createElement('div');
cpLoc.textContent = 'Every man and every woman is a star.';
cpLoc.style.cssText = 'position:fixed;bottom:110px;left:0;right:0;text-align:center;font-family:"Playfair Display",Georgia,serif;font-size:14px;color:#f5d070;letter-spacing:0.18em;text-transform:uppercase;pointer-events:none;z-index:9003;white-space:nowrap;text-shadow:0 0 8px rgba(245,208,112,0.55),0 0 16px rgba(245,208,112,0.25),0 0 2px rgba(8,6,4,0.95);opacity:0;transition:opacity 3.5s ease;';
cpWrap.appendChild(cpLoc);
setTimeout(function() { cpLoc.style.opacity = '1'; }, 2600);

// Button: "CLIMB IT" — brightened from rgba(248,212,128) to a near-white
// gold so it reads as a clear, glowing call-to-action against the dark
// city scene rather than a muted text-link.
var cpBtn = document.createElement('div');
cpBtn.textContent = 'CLIMB IT';
cpBtn.style.cssText = 'position:fixed;bottom:40px;left:50%;transform:translateX(-50%);padding:16px 42px;font:bold 20px "Courier New",monospace;color:rgba(255,255,250,1);border:2px solid rgba(255,252,232,1);letter-spacing:5px;cursor:pointer;z-index:9004;background:rgba(255,236,176,0.22);box-shadow:0 0 18px rgba(255,240,180,0.55),0 0 42px rgba(255,228,148,0.35),inset 0 0 14px rgba(255,248,212,0.25);opacity:0;transition:opacity 5.5s ease;text-shadow:0 0 8px rgba(255,255,255,1),0 0 18px rgba(255,252,220,1),0 0 36px rgba(255,236,168,0.85),0 0 58px rgba(255,220,140,0.55),0 0 2px rgba(8,6,4,0.85);';
setTimeout(function() { cpBtn.style.opacity = '1'; }, 3500);
cpBtn.addEventListener('mouseenter', function() {
cpBtn.style.color = 'rgba(255,252,232,1)';
cpBtn.style.borderColor = 'rgba(255,248,212,1)';
});
cpBtn.addEventListener('mouseleave', function() {
cpBtn.style.color = 'rgba(255,244,200,1)';
cpBtn.style.borderColor = 'rgba(255,232,160,0.95)';
});
cpBtn.addEventListener('click', function() {
// Freeze the canvas animation immediately so the 3D scene doesn't keep
// moving while it fades — kills the perceptual "second flash" some
// players were seeing as the snap-cut at end-of-fade.
if (cpAnimId) { cancelAnimationFrame(cpAnimId); cpAnimId = null; }
cpWrap.style.transition = 'opacity 0.6s ease';
cpWrap.style.opacity = '0';
setTimeout(function() {
if (cpWrap.parentNode) cpWrap.parentNode.removeChild(cpWrap);
// Approach Centre Point's hidden tw-link now targets Alba Complete /
// Alba Incomplete directly (the Centre Point router passage was
// bypassed). Click the first "·" link in the document.
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}, 650);
});
cpWrap.appendChild(cpBtn);

document.body.appendChild(cpWrap);
}

setInterval(function() {
var container = document.getElementById('cp-container');
if (container && !cpActive) {
initCentrePoint();
} else if (!container) {
cpActive = false;
if (cpAnimId) { cancelAnimationFrame(cpAnimId); cpAnimId = null; }
window._dssDisposeWrap('cp-wrap');
}
}, 300);
})();
// ====== CHINESE FISH AND CHIPS — INLINE ======
(function() {
var fcActive = false;
var fcAnimId = null;

function initFc() {
  if (fcActive) return; fcActive = true;
  if (typeof THREE === 'undefined') {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    s.onload = function() { buildFcScene(); };
    document.head.appendChild(s);
  } else { buildFcScene(); }
}

function buildFcScene() {
  var fcWrap = document.createElement('div');
  fcWrap.id = 'fc-wrap';
  fcWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';

  // ============================================================
  // SCENE SETUP
  // ============================================================
  var scene = new THREE.Scene();
  scene.background = new THREE.Color(0x080810);
  scene.fog = new THREE.Fog(0x080810, 5, 38);

  var camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 200);

  // ============================================================
  // LAYOUT — eye-level off-axis: looking down Greek Street toward
  // the chippy, which sits at the end of a receding row of shops.
  // ============================================================
  camera.position.set(-6.5, 1.7, 14);
  camera.lookAt(1.2, 3.2, -1);

  var renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
  renderer.toneMappingExposure = 0.65;
  fcWrap.appendChild(renderer.domElement);
  window._dssBindScene('fc-wrap', scene, renderer, camera);

  // ============================================================
  // MATERIALS
  // ============================================================
  // Grimy brick — running bond, mortar courses, soot streaks, damp
  // patches, lichen, old paste-up ghost. Front-facade only.
  var brickFaceTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#6f4f3a'; cx.fillRect(0, 0, w, h);
    var bH = 14, bW = 32;
    for (var by = 0; by < h; by += bH) {
      var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var bx = -bW; bx < w + bW; bx += bW) {
        var px = bx + rowOff;
        var r = 95 + Math.floor(Math.random() * 50);
        var g = 60 + Math.floor(Math.random() * 35);
        var b = 45 + Math.floor(Math.random() * 30);
        if (Math.random() > 0.94) { r -= 40; g -= 32; b -= 22; }
        if (Math.random() > 0.96) { r += 30; g += 18; b += 10; }
        cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
        cx.fillStyle = 'rgba(20,12,6,' + (0.05 + Math.random() * 0.10).toFixed(3) + ')';
        cx.fillRect(px + 1, by + bH - 3, bW - 2, 2);
      }
    }
    cx.fillStyle = 'rgba(170, 145, 115, 0.32)';
    for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
    cx.fillStyle = 'rgba(160, 135, 105, 0.22)';
    for (var hyy = 0; hyy < h; hyy += bH) {
      var ro = ((Math.floor(hyy / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var hxx = ro; hxx < w; hxx += bW) cx.fillRect(hxx, hyy, 1.4, bH);
    }
    // Vertical soot streaks
    for (var ss = 0; ss < 5; ss++) {
      var sx = Math.random() * w;
      var sxw = 12 + Math.random() * 30;
      var sg = cx.createLinearGradient(sx, 0, sx, h);
      sg.addColorStop(0, 'rgba(8, 6, 4, 0.55)');
      sg.addColorStop(0.3, 'rgba(12, 10, 6, 0.32)');
      sg.addColorStop(0.7, 'rgba(18, 14, 9, 0.12)');
      sg.addColorStop(1, 'rgba(22, 18, 10, 0)');
      cx.fillStyle = sg; cx.fillRect(sx - sxw / 2, 0, sxw, h);
    }
    // Damp / green patches (low-down)
    for (var d = 0; d < 5; d++) {
      var dx = Math.random() * w;
      var dy = h * 0.45 + Math.random() * h * 0.55;
      var dr = 30 + Math.random() * 50;
      var dg2 = cx.createRadialGradient(dx, dy, 0, dx, dy, dr);
      dg2.addColorStop(0, 'rgba(60, 75, 55, 0.32)');
      dg2.addColorStop(0.5, 'rgba(50, 60, 45, 0.16)');
      dg2.addColorStop(1, 'rgba(40, 50, 40, 0)');
      cx.fillStyle = dg2; cx.fillRect(dx - dr, dy - dr, dr * 2, dr * 2);
    }
    // Lichen splatters
    for (var lp = 0; lp < 14; lp++) {
      var lx = Math.random() * w, ly = Math.random() * h;
      var lr = 5 + Math.random() * 12;
      cx.fillStyle = 'rgba(95, 105, 60, ' + (0.10 + Math.random() * 0.18).toFixed(3) + ')';
      cx.beginPath(); cx.ellipse(lx, ly, lr, lr * 0.55, Math.random() * Math.PI, 0, Math.PI * 2); cx.fill();
    }
    // Top soot wash (chimney run-off)
    var topG = cx.createLinearGradient(0, 0, 0, h * 0.45);
    topG.addColorStop(0, 'rgba(18, 12, 8, 0.42)');
    topG.addColorStop(1, 'rgba(18, 12, 8, 0)');
    cx.fillStyle = topG; cx.fillRect(0, 0, w, h * 0.45);
    // Faded paste-up poster ghost
    cx.fillStyle = 'rgba(220, 200, 160, 0.08)';
    cx.fillRect(w * 0.12, h * 0.42, w * 0.18, h * 0.13);
    cx.fillStyle = 'rgba(180, 160, 120, 0.05)';
    cx.fillRect(w * 0.13, h * 0.43, w * 0.16, h * 0.11);
    // A few bright highlight bricks (paint-fleck or sunlight remnant)
    for (var hl = 0; hl < 8; hl++) {
      var hbx = Math.floor(Math.random() * (w / bW)) * bW;
      var hby = Math.floor(Math.random() * (h / bH)) * bH;
      cx.fillStyle = 'rgba(220, 195, 150, ' + (0.10 + Math.random() * 0.15).toFixed(3) + ')';
      cx.fillRect(hbx + 1, hby + 1, bW - 2, 2);
    }
  });
  brickFaceTex.wrapS = brickFaceTex.wrapT = THREE.RepeatWrapping;
  brickFaceTex.repeat.set(2, 4);
  var brickMat = new THREE.MeshStandardMaterial({ map: brickFaceTex, roughness: 0.92 });

  // Darker brick variant for façade panel — same texture, tinted darker
  var brickFaceTex2 = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#54382a'; cx.fillRect(0, 0, w, h);
    var bH = 14, bW = 32;
    for (var by = 0; by < h; by += bH) {
      var rowOff = ((Math.floor(by / bH)) % 2 === 0) ? 0 : bW / 2;
      for (var bx = -bW; bx < w + bW; bx += bW) {
        var px = bx + rowOff;
        var r = 75 + Math.floor(Math.random() * 40);
        var g = 45 + Math.floor(Math.random() * 28);
        var b = 32 + Math.floor(Math.random() * 22);
        if (Math.random() > 0.94) { r -= 28; g -= 22; b -= 16; }
        cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
        cx.fillRect(px + 1, by + 1, bW - 2, bH - 2);
      }
    }
    cx.fillStyle = 'rgba(140, 115, 90, 0.22)';
    for (var hy = 0; hy < h; hy += bH) cx.fillRect(0, hy, w, 1);
    // Heavy soot below window-line area
    var topG = cx.createLinearGradient(0, 0, 0, h);
    topG.addColorStop(0, 'rgba(10, 6, 4, 0.45)');
    topG.addColorStop(0.5, 'rgba(15, 10, 6, 0.18)');
    topG.addColorStop(1, 'rgba(20, 14, 8, 0.06)');
    cx.fillStyle = topG; cx.fillRect(0, 0, w, h);
  });
  brickFaceTex2.wrapS = brickFaceTex2.wrapT = THREE.RepeatWrapping;
  brickFaceTex2.repeat.set(2, 4);
  var darkBrick = new THREE.MeshStandardMaterial({ map: brickFaceTex2, roughness: 0.95 });

  var creamPaint = new THREE.MeshStandardMaterial({ color: 0xd8d0b8, roughness: 0.75 });
  var shopRed = new THREE.MeshStandardMaterial({ color: 0x8a1818, roughness: 0.6 });
  var darkRed = new THREE.MeshStandardMaterial({ color: 0x5a1010, roughness: 0.7 });
  var goldTrim = new THREE.MeshStandardMaterial({ color: 0xc8a840, roughness: 0.35, metalness: 0.3 });
  var brightGold = new THREE.MeshStandardMaterial({ color: 0xd4b850, roughness: 0.3, metalness: 0.4 });
  var tileMat = new THREE.MeshStandardMaterial({ color: 0xc8d8d0, roughness: 0.5 });
  var whiteTile = new THREE.MeshStandardMaterial({ color: 0xe8e8e0, roughness: 0.45 });
  var whiteTrim = new THREE.MeshStandardMaterial({ color: 0xe8e4dc, roughness: 0.7 });
  var creamTrim = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.75 });
  var blackMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.5 });
  var redPaint = new THREE.MeshStandardMaterial({ color: 0xaa2020, roughness: 0.6 });

  // Pavement — slabs with cracks, gum, wet patches
  var paveFaceTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#3a3a36'; cx.fillRect(0, 0, w, h);
    var sw = 128, sh = 96;
    cx.strokeStyle = 'rgba(18, 18, 16, 0.55)'; cx.lineWidth = 1.4;
    for (var sy = 0; sy < h; sy += sh) {
      var off = ((sy / sh) % 2 === 0) ? 0 : sw / 2;
      for (var sx = -sw; sx < w + sw; sx += sw) {
        var bxp = sx + off;
        var sg = 48 + Math.floor(Math.random() * 28);
        cx.fillStyle = 'rgba(' + sg + ',' + sg + ',' + (sg - 4) + ',' + (0.32 + Math.random() * 0.3).toFixed(3) + ')';
        cx.fillRect(bxp, sy, sw, sh);
        cx.strokeRect(bxp, sy, sw, sh);
      }
    }
    cx.strokeStyle = 'rgba(15, 15, 12, 0.55)'; cx.lineWidth = 0.9;
    for (var c2 = 0; c2 < 7; c2++) {
      cx.beginPath();
      cx.moveTo(Math.random() * w, Math.random() * h);
      cx.lineTo(Math.random() * w, Math.random() * h);
      cx.stroke();
    }
    // Gum and fag-ends
    for (var fe = 0; fe < 60; fe++) {
      cx.fillStyle = 'rgba(180, 175, 165, ' + (0.15 + Math.random() * 0.22).toFixed(3) + ')';
      cx.beginPath(); cx.arc(Math.random() * w, Math.random() * h, 1.0 + Math.random() * 1.6, 0, Math.PI * 2); cx.fill();
    }
    // Wet patches
    for (var wp = 0; wp < 5; wp++) {
      var wpx = Math.random() * w, wpy = Math.random() * h;
      var wpr = 35 + Math.random() * 60;
      var wpg = cx.createRadialGradient(wpx, wpy, 0, wpx, wpy, wpr);
      wpg.addColorStop(0, 'rgba(72, 78, 80, 0.35)');
      wpg.addColorStop(1, 'rgba(72, 78, 80, 0)');
      cx.fillStyle = wpg; cx.fillRect(wpx - wpr, wpy - wpr, wpr * 2, wpr * 2);
    }
  });
  paveFaceTex.wrapS = paveFaceTex.wrapT = THREE.RepeatWrapping;
  paveFaceTex.repeat.set(4, 4);
  var pavementMat = new THREE.MeshStandardMaterial({ map: paveFaceTex, roughness: 0.88 });

  // Road — tarmac with aggregate, cracks, repair patches, tar-seal,
  // oil stains, faded white line.
  var roadFaceTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    cx.fillStyle = '#1c1c1c'; cx.fillRect(0, 0, w, h);
    // Aggregate speckle
    for (var p = 0; p < 4200; p++) {
      var pg = 25 + Math.floor(Math.random() * 70);
      cx.fillStyle = 'rgba(' + pg + ',' + pg + ',' + pg + ',0.42)';
      cx.fillRect(Math.random() * w, Math.random() * h, 1.5, 1.5);
    }
    // Repair patches (lighter rectangular tarmac)
    for (var rp = 0; rp < 6; rp++) {
      var rx = Math.random() * w, ry = Math.random() * h;
      var rwd = 50 + Math.random() * 100, rht = 35 + Math.random() * 70;
      cx.fillStyle = 'rgba(78, 78, 78, ' + (0.16 + Math.random() * 0.22).toFixed(3) + ')';
      cx.fillRect(rx, ry, rwd, rht);
      // patch border (lighter edge)
      cx.strokeStyle = 'rgba(100, 100, 100, 0.18)'; cx.lineWidth = 0.6;
      cx.strokeRect(rx, ry, rwd, rht);
    }
    // Cracks (jagged)
    cx.strokeStyle = 'rgba(8, 8, 8, 0.8)'; cx.lineWidth = 1.2;
    for (var c = 0; c < 10; c++) {
      cx.beginPath();
      var cx0 = Math.random() * w, cy0 = Math.random() * h;
      cx.moveTo(cx0, cy0);
      var ang = Math.random() * Math.PI * 2, len = 30 + Math.random() * 80;
      cx.lineTo(cx0 + Math.cos(ang) * len, cy0 + Math.sin(ang) * len);
      cx.lineTo(cx0 + Math.cos(ang + 0.4) * len * 1.4, cy0 + Math.sin(ang + 0.4) * len * 1.4);
      cx.stroke();
    }
    // Tar-seal lines (wandering black sealant over cracks)
    cx.strokeStyle = 'rgba(0, 0, 0, 0.9)'; cx.lineWidth = 2.6;
    for (var tm = 0; tm < 5; tm++) {
      cx.beginPath();
      var tx = Math.random() * w, ty = Math.random() * h;
      cx.moveTo(tx, ty);
      for (var ts = 0; ts < 5; ts++) {
        tx += (Math.random() - 0.5) * 30;
        ty += 8 + Math.random() * 16;
        cx.lineTo(tx, ty);
      }
      cx.stroke();
    }
    // Faded white centre line
    cx.fillStyle = 'rgba(220, 220, 200, 0.5)';
    cx.fillRect(w * 0.5 - 2, h * 0.3, 4, h * 0.4);
    cx.fillStyle = 'rgba(220, 220, 200, 0.18)';
    cx.fillRect(w * 0.5 - 2, h * 0.05, 4, h * 0.2);
    cx.fillRect(w * 0.5 - 2, h * 0.75, 4, h * 0.2);
    // Oil / dirt blotches
    for (var os = 0; os < 4; os++) {
      var ox = Math.random() * w, oy = Math.random() * h;
      var orr = 8 + Math.random() * 18;
      var og = cx.createRadialGradient(ox, oy, 0, ox, oy, orr);
      og.addColorStop(0, 'rgba(0, 0, 0, 0.62)');
      og.addColorStop(0.7, 'rgba(15, 12, 5, 0.22)');
      og.addColorStop(1, 'rgba(15, 12, 5, 0)');
      cx.fillStyle = og; cx.fillRect(ox - orr, oy - orr, orr * 2, orr * 2);
    }
  });
  roadFaceTex.wrapS = roadFaceTex.wrapT = THREE.RepeatWrapping;
  roadFaceTex.repeat.set(1, 8);
  var roadMat = new THREE.MeshStandardMaterial({ map: roadFaceTex, roughness: 0.78, metalness: 0.18 });
  var sillMat = new THREE.MeshStandardMaterial({ color: 0xdcd4c8, roughness: 0.7 });
  var windowFrame = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.6 });
  var pipeMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7 });
  var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.3 });
  var woodMat = new THREE.MeshStandardMaterial({ color: 0x3a2a1a, roughness: 0.8 });
  var chromeMat = new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.2, metalness: 0.6 });
  var formicaMat = new THREE.MeshStandardMaterial({ color: 0xd8c8a0, roughness: 0.4 });

  // ============================================================
  // HELPERS
  // ============================================================
  function makeCanvasTexture(w, h, drawFunc) {
    var c = document.createElement('canvas');
    c.width = w; c.height = h;
    var cx = c.getContext('2d');
    drawFunc(cx, w, h);
    var tex = new THREE.CanvasTexture(c);
    tex.minFilter = THREE.LinearFilter;
    return tex;
  }

  function placeMesh(group, geo, mat, x, y, z) {
    var m = new THREE.Mesh(geo, mat);
    m.position.set(x, y, z);
    group.add(m);
    return m;
  }

  // ============================================================
  // GROUND
  // ============================================================
  var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
  ground.rotation.x = -Math.PI / 2;
  ground.receiveShadow = true;
  scene.add(ground);

  var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
  road.rotation.x = -Math.PI / 2;
  road.position.set(0, -0.01, 10);
  road.receiveShadow = true;
  scene.add(road);

  // Wet road surface (reflective — picks up the bright chippy glow)
  var wetMat = new THREE.MeshStandardMaterial({
    color: 0x1a1a1a, roughness: 0.1, metalness: 0.6, transparent: true, opacity: 0.35
  });
  var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(16, 16), wetMat);
  wetRoad.rotation.x = -Math.PI / 2;
  wetRoad.position.set(0, 0.01, 8);
  scene.add(wetRoad);

  // Road centre dashes
  for (var rli = -6; rli < 20; rli += 2.5) {
    var roadLine = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 1.5),
      new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.7, transparent: true, opacity: 0.25 }));
    roadLine.rotation.x = -Math.PI / 2;
    roadLine.position.set(0, 0.02, rli);
    scene.add(roadLine);
  }

  // ============================================================
  // THE CHINESE FISH & CHIPS
  // ============================================================
  var shop = new THREE.Group();

  // ---- BUILDING BODY ----
  // Simple 3-storey brick building. Narrower than the pubs — about 6 units wide.
  // The chippy is the ground floor; upper floors are residential flats.
  var buildingBody = new THREE.Mesh(new THREE.BoxGeometry(6, 11, 6), brickMat);
  buildingBody.position.set(0.5, 5.5, -3);
  shop.add(buildingBody);

  // Facade panel (slightly different tone)
  placeMesh(shop, new THREE.BoxGeometry(6.02, 11, 0.06), darkBrick, 0.5, 5.5, 0.03);

  // Side wall (visible at angle)
  var sideWall = new THREE.Mesh(new THREE.PlaneGeometry(6, 11),
    new THREE.MeshStandardMaterial({ color: 0x6a4a38, roughness: 0.88 }));
  sideWall.position.set(-2.49, 5.5, -3);
  sideWall.rotation.y = Math.PI / 2;
  shop.add(sideWall);

  // Mortar coursework hints
  for (var bri = 0.5; bri < 11; bri += 0.35) {
    if (Math.random() > 0.35) {
      placeMesh(shop, new THREE.PlaneGeometry(6.01, 0.015),
        new THREE.MeshStandardMaterial({ color: 0xb09888, roughness: 0.9, transparent: true, opacity: 0.18 }),
        0.5, bri, 0.05);
    }
  }

  // ---- UPPER FLOOR WINDOWS (residential — simple sash windows) ----
  // 2 rows of 3 windows. One warm-lit (row 0 col 1) and one red-lit
  // brothel-style upper-floor window (row 1 col 2) — same recipe as
  // Lackland's office: emissive redGlass + red point light.
  var upWinXs = [-0.8, 0.8, 2.4];
  var redBrothelGlass = new THREE.MeshStandardMaterial({
    color: 0x4a0505, roughness: 0.2, emissive: 0xff1515, emissiveIntensity: 0.7
  });
  for (var row = 0; row < 2; row++) {
    for (var col = 0; col < 3; col++) {
      var uwx = upWinXs[col];
      var uwy = 6.5 + row * 3;
      var uwLit = (row === 0 && col === 1);
      var uwRed = (row === 1 && col === 2); // top-right = red light
      // Brick reveal
      placeMesh(shop, new THREE.BoxGeometry(0.95, 1.55, 0.04),
        new THREE.MeshStandardMaterial({ color: 0x4a2a1a, roughness: 0.9 }), uwx, uwy, 0.04);
      // Frame
      placeMesh(shop, new THREE.BoxGeometry(0.85, 1.45, 0.05), windowFrame, uwx, uwy, 0.06);
      placeMesh(shop, new THREE.BoxGeometry(0.72, 1.32, 0.03), windowFrame, uwx, uwy, 0.09);
      // Glass
      if (uwRed) {
        placeMesh(shop, new THREE.BoxGeometry(0.68, 1.28, 0.03), redBrothelGlass, uwx, uwy, 0.11);
      } else {
        var uwGlassCol = uwLit ? 0xffd699 : 0x334466;
        var uwGlassOp = uwLit ? 0.35 : 0.12;
        placeMesh(shop, new THREE.PlaneGeometry(0.68, 1.28),
          new THREE.MeshBasicMaterial({ color: uwGlassCol, transparent: true, opacity: uwGlassOp }),
          uwx, uwy, 0.11);
      }
      // Sash bar
      placeMesh(shop, new THREE.BoxGeometry(0.75, 0.04, 0.04), windowFrame, uwx, uwy + 0.1, 0.11);
      // Glazing bars
      placeMesh(shop, new THREE.BoxGeometry(0.02, 1.28, 0.02), windowFrame, uwx, uwy, 0.12);
      placeMesh(shop, new THREE.BoxGeometry(0.68, 0.02, 0.02), windowFrame, uwx, uwy + 0.35, 0.12);
      placeMesh(shop, new THREE.BoxGeometry(0.68, 0.02, 0.02), windowFrame, uwx, uwy - 0.35, 0.12);
      // Sill
      placeMesh(shop, new THREE.BoxGeometry(0.95, 0.07, 0.16), sillMat, uwx, uwy - 0.78, 0.13);
      // Lintel
      placeMesh(shop, new THREE.BoxGeometry(0.95, 0.1, 0.05),
        new THREE.MeshStandardMaterial({ color: 0x8a5a48, roughness: 0.8 }), uwx, uwy + 0.78, 0.08);
    }
  }
  // Red point light spilling out of the brothel window
  var redBrothelLight = new THREE.PointLight(0xff2020, 0.7, 7);
  // shop is positioned at (0,0,0); upper window col 2 is at uwx=2.4
  // row 1 puts it at uwy = 6.5 + 1*3 = 9.5; spilling forward to z ≈ 1.3
  redBrothelLight.position.set(2.4, 9.5, 1.3);
  scene.add(redBrothelLight);

  // String course between floors
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.1, 0.14), whiteTrim, 0.5, 5.6, 0.12);
  // Upper lip projection
  placeMesh(shop, new THREE.BoxGeometry(6.12, 0.04, 0.17), whiteTrim, 0.5, 5.66, 0.14);
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.03, 0.05),
    new THREE.MeshStandardMaterial({ color: 0x4a3a2a, roughness: 0.9 }), 0.5, 5.53, 0.08);
  // Side return
  placeMesh(shop, new THREE.BoxGeometry(0.14, 0.1, 0.3), whiteTrim, -2.49, 5.6, -0.05);
  // Second string course (between 2nd and 3rd floor)
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.08, 0.1), whiteTrim, 0.5, 8.7, 0.1);

  // Top cornice (heavy, projecting)
  placeMesh(shop, new THREE.BoxGeometry(6.18, 0.18, 0.35), whiteTrim, 0.5, 11.08, 0.18);
  // Second cornice layer
  placeMesh(shop, new THREE.BoxGeometry(6.22, 0.1, 0.4), whiteTrim, 0.5, 10.95, 0.2);
  // Underside
  placeMesh(shop, new THREE.BoxGeometry(6.18, 0.06, 0.38), creamTrim, 0.5, 10.88, 0.2);
  // Dentils (closer together for richness)
  for (var di = -2.3; di <= 3.3; di += 0.25) {
    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.08, 0.04), whiteTrim, di, 10.82, 0.18);
  }
  // Moulding band below dentils
  placeMesh(shop, new THREE.BoxGeometry(6.15, 0.04, 0.08), creamTrim, 0.5, 10.75, 0.14);

  // Simple parapet / roof
  var roofMat = new THREE.MeshStandardMaterial({ color: 0x2a2a30, roughness: 0.85 });
  placeMesh(shop, new THREE.BoxGeometry(6.1, 0.8, 3), roofMat, 0.5, 11.6, -1.5);
  // Chimneys
  var chimMat = new THREE.MeshStandardMaterial({ color: 0x7a5a48, roughness: 0.85 });
  placeMesh(shop, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -1, 12.75, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.55, 0.08, 0.55), chimMat, -1, 13.55, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, -1.15, 13.7, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, -0.85, 13.7, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, 2, 12.75, -2);
  placeMesh(shop, new THREE.BoxGeometry(0.55, 0.08, 0.55), chimMat, 2, 13.55, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, 1.85, 13.7, -2);
  placeMesh(shop, new THREE.CylinderGeometry(0.06, 0.07, 0.3, 6), chimMat, 2.15, 13.7, -2);

  // ---- RED & GOLD PAINTED FASCIA ----
  // The fascia board — deep red with gold lettering
  var fasciaC = document.createElement('canvas');
  fasciaC.width = 768; fasciaC.height = 96;
  var fctx = fasciaC.getContext('2d');
  // Deep red background
  fctx.fillStyle = '#8a1818';
  fctx.fillRect(0, 0, 768, 96);
  // Gold border — double line
  fctx.strokeStyle = '#c8a840'; fctx.lineWidth = 3;
  fctx.strokeRect(5, 5, 758, 86);
  fctx.strokeStyle = '#a08830'; fctx.lineWidth = 1;
  fctx.strokeRect(10, 10, 748, 76);
  // Shop name in gold
  fctx.fillStyle = '#d8b840';
  fctx.font = 'bold 40px Georgia, serif';
  fctx.textAlign = 'center';
  fctx.fillText('Chinese, Fish and Chips', 384, 52);
  // Decorative gold rule below
  fctx.strokeStyle = '#b09830'; fctx.lineWidth = 1;
  fctx.beginPath(); fctx.moveTo(140, 62); fctx.lineTo(628, 62); fctx.stroke();
  // "OPEN LATE" centred below
  fctx.font = 'bold 16px Georgia, serif';
  fctx.fillStyle = '#e0c860';
  fctx.fillText('OPEN  LATE', 384, 80);
  // "FISH RESTAURANT" left side
  fctx.font = '13px Georgia, serif';
  fctx.fillStyle = '#c8a840';
  fctx.textAlign = 'left';
  fctx.fillText('FISH RESTAURANT', 22, 80);
  // "TAKE AWAY" right side
  fctx.textAlign = 'right';
  fctx.fillText('TAKE AWAY', 746, 80);

  var fasciaTex = new THREE.CanvasTexture(fasciaC);
  var fascia = new THREE.Mesh(new THREE.BoxGeometry(6.0, 0.8, 0.18),
    new THREE.MeshBasicMaterial({ map: fasciaTex }));
