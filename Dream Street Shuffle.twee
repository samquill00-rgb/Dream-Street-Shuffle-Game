var workingGlow = new THREE.PointLight(0xc08030, 0.0, 3);
workingGlow.position.set(2.2, 1.8, 0.6);
scene.add(workingGlow);

scene.add(building);

var leftNeighbour = new THREE.Mesh(new THREE.BoxGeometry(6, 15, 2), sootBrick);
leftNeighbour.position.set(-6.5, 7.5, -1);
leftNeighbour.castShadow = true;
scene.add(leftNeighbour);

for (var row = 0; row < 3; row++) {
var wx = -6.5;
var wy = 5 + row * 3.2;
var wf = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.2, 0.06), windowFrame);
wf.position.set(wx, wy, 0.02);
scene.add(wf);
var wg = new THREE.Mesh(new THREE.BoxGeometry(0.55, 1.0, 0.04), (row === 1) ? warmGlass : darkGlass);
wg.position.set(wx, wy, 0.04);
scene.add(wg);
}

var rightNeighbour = new THREE.Mesh(new THREE.BoxGeometry(6, 13, 2), redBrick);
rightNeighbour.position.set(6.5, 6.5, -1);
rightNeighbour.castShadow = true;
scene.add(rightNeighbour);

for (var row = 0; row < 3; row++) {
for (var col = 0; col < 2; col++) {
var wx2 = 5.5 + col * 2;
var wy2 = 4.5 + row * 3;
var wf2 = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.2, 0.06), windowFrame);
wf2.position.set(wx2, wy2, 0.02);
scene.add(wf2);
var wg2 = new THREE.Mesh(new THREE.BoxGeometry(0.55, 1.0, 0.04), (row === 0 && col === 1) ? warmGlass : darkGlass);
wg2.position.set(wx2, wy2, 0.04);
scene.add(wg2);
}
}

var acrossRoad = new THREE.Mesh(new THREE.BoxGeometry(20, 12, 2), sootBrick);
acrossRoad.position.set(0, 6, 12);
scene.add(acrossRoad);

var chimMat = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.85 });
placeMesh(new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -1, 14.75, -0.5);
placeMesh(new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, -1, 15.55, -0.5);
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.3, 6), chimMat, -1, 15.8, -0.5);
placeMesh(new THREE.BoxGeometry(0.5, 1.8, 0.5), chimMat, 2, 14.9, -0.5);
placeMesh(new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, 2, 15.85, -0.5);

var lampLights = [];

function createStreetlamp(x, z, intensity) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });

g.add(new THREE.Mesh(new THREE.CylinderGeometry(0.18, 0.28, 0.4, 8), postMat).translateY(0.2));
g.add(new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.1, 4.5, 6), postMat).translateY(2.45));
g.add(new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.4, 0.3), postMat).translateY(4.9));

var glassGeo = new THREE.BoxGeometry(0.22, 0.3, 0.22);
var glassMat = new THREE.MeshStandardMaterial({
color: 0x4a2005, roughness: 0.2, transparent: true, opacity: 0.7,
emissive: 0xe87818, emissiveIntensity: 0.6
});
g.add(new THREE.Mesh(glassGeo, glassMat).translateY(4.9));

var light = new THREE.PointLight(0xe87818, intensity || 0.8, 15);
light.position.set(0, 4.8, 0);
light.castShadow = true;
g.add(light);
lampLights.push(light);

var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.8)');
grad.addColorStop(0.3, 'rgba(200, 90, 15, 0.3)');
grad.addColorStop(1, 'rgba(140, 50, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var glow = new THREE.Sprite(new THREE.SpriteMaterial({
map: glowTex, transparent: true, opacity: 0.6
}));
glow.position.set(0, 4.9, 0);
glow.scale.set(3.5, 3.5, 1);
g.add(glow);

g.position.set(x, 0, z);
scene.add(g);
return light;
}

var doorLamp = createStreetlamp(2.5, 2.5, 1.0);
createStreetlamp(-5, 2.5, 0.25);
createStreetlamp(10, 2.5, 0.15);

var bollardMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.7, metalness: 0.3 });
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.7, 6), bollardMat, 1.8, 0.47, 2.2);
placeMesh(new THREE.SphereGeometry(0.1, 6, 4), bollardMat, 1.8, 0.85, 2.2);

var drainMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.7, metalness: 0.4 });
placeMesh(new THREE.BoxGeometry(0.5, 0.02, 0.35), drainMat, -1.5, 0.01, 2.8);

var binMat = new THREE.MeshStandardMaterial({ color: 0x555555, roughness: 0.6, metalness: 0.3 });
var bin = new THREE.Mesh(new THREE.CylinderGeometry(0.22, 0.26, 0.75, 8), binMat);
bin.position.set(-3.8, 0.5, 1.2);
scene.add(bin);
var lid = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.25, 0.03, 8), binMat);
lid.position.set(-3.8, 0.9, 1.2);
lid.rotation.z = 0.08;
scene.add(lid);

for (var i = 0; i < 3; i++) {
var stump = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.025, 0.25, 6), ironMat);
stump.position.set(-1.5 + i * 0.3, 0.25, 0.5);
scene.add(stump);
}

var silhouettes = [];

function makeSilhouetteTex(seed) {
return makeCanvasTexture(256, 256, function(cx, w, h) {
var bg = cx.createRadialGradient(w/2, h*0.4, 10, w/2, h*0.5, w);
bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
cx.fillStyle = bg;
cx.fillRect(0, 0, w, h);

cx.fillStyle = 'rgba(10, 5, 0, 0.85)';
var fx = w/2 + (seed - 0.5) * 30;
var baseY = h * 0.98;
cx.beginPath();
cx.moveTo(fx - 20, baseY - h*0.35);
cx.lineTo(fx + 20, baseY - h*0.35);
cx.lineTo(fx + 28, baseY);
cx.lineTo(fx - 28, baseY);
cx.closePath();
cx.fill();
cx.beginPath();
cx.ellipse(fx, baseY - h*0.38, 25, 12, 0, 0, Math.PI, true);
cx.fill();
cx.fillRect(fx - 5, baseY - h*0.48, 10, h*0.1);
cx.beginPath();
cx.arc(fx, baseY - h*0.52, 14, 0, Math.PI * 2);
cx.fill();
});
}

function addSilhouette(x, y, z, seed) {
var sTex = makeSilhouetteTex(seed);
var sMat = new THREE.MeshBasicMaterial({
map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 1.0), sMat);
sPlane.position.set(x, y, z);
scene.add(sPlane);
silhouettes.push({
mesh: sPlane,
baseX: x, baseY: y,
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.2 + Math.random() * 0.3,
swayAmt: 0.012 + Math.random() * 0.015
});
}

addSilhouette(-5.5, 8.2, 0.04, 0.6);

for (var i = 0; i < 10; i++) {
var puddleMat = new THREE.MeshStandardMaterial({
color: 0x111115, roughness: 0.08, metalness: 0.7, transparent: true, opacity: 0.3
});
var puddle = new THREE.Mesh(new THREE.CircleGeometry(0.25 + Math.random() * 0.7, 16), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(Math.random() * 10 - 4, 0.015, 2 + Math.random() * 5);
scene.add(puddle);
}

var doorPuddleMat = new THREE.MeshStandardMaterial({
color: 0x1a1208, roughness: 0.05, metalness: 0.8, transparent: true, opacity: 0.4,
emissive: 0xe87818, emissiveIntensity: 0.06
});
var doorPuddle = new THREE.Mesh(new THREE.CircleGeometry(1.0, 20), doorPuddleMat);
doorPuddle.rotation.x = -Math.PI / 2;
doorPuddle.position.set(1.5, 0.015, 3.5);
scene.add(doorPuddle);

scene.add(new THREE.AmbientLight(0x060610, 0.08));

var moonLight = new THREE.DirectionalLight(0x1a2255, 0.03);
moonLight.position.set(5, 18, -3);
moonLight.castShadow = true;
scene.add(moonLight);

var fanlightGlow = new THREE.PointLight(0xc08030, 0.15, 4);
fanlightGlow.position.set(0, 3.2, 0.5);
scene.add(fanlightGlow);

var doorSpot = new THREE.SpotLight(0xe8a040, 1.2, 10, Math.PI / 5, 0.6);
doorSpot.position.set(2.5, 5.5, 3.5);
doorSpot.target.position.set(0, 1.8, 0.1);
doorSpot.castShadow = true;
scene.add(doorSpot);
scene.add(doorSpot.target);

var doorFill = new THREE.PointLight(0xd09040, 0.15, 5);
doorFill.position.set(-2, 3.5, 2.5);
scene.add(doorFill);

var brassHighlight = new THREE.PointLight(0xffe0a0, 0.25, 2.5);
brassHighlight.position.set(0.2, 1.6, 1.0);
scene.add(brassHighlight);

var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(140, 135, 125, 0.32)');
grad.addColorStop(0.4, 'rgba(110, 105, 95, 0.15)');
grad.addColorStop(1, 'rgba(80, 75, 65, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(100, 95, 85, 0.18)');
grad.addColorStop(0.6, 'rgba(80, 75, 65, 0.08)');
grad.addColorStop(1, 'rgba(60, 55, 45, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var gingerFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.3)');
grad.addColorStop(0.3, 'rgba(210, 95, 18, 0.15)');
grad.addColorStop(0.6, 'rgba(180, 70, 12, 0.06)');
grad.addColorStop(1, 'rgba(140, 50, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

for (var i = 0; i < 60; i++) {
var fogMat = new THREE.SpriteMaterial({
map: thickFogTex, transparent: true,
opacity: 0.3 + Math.random() * 0.25
});
var fog = new THREE.Sprite(fogMat);
fog.position.set(Math.random() * 40 - 15, 0.1 + Math.random() * 1.8, Math.random() * 30 - 5);
var s = 5 + Math.random() * 12;
fog.scale.set(s, s * 0.3, 1);
scene.add(fog);
fogSprites.push({
sprite: fog, baseX: fog.position.x,
drift: 0.001 + Math.random() * 0.002,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.0005 + Math.random() * 0.002,
swayAmt: 0.2 + Math.random() * 0.4
});
}

for (var i = 0; i < 15; i++) {
var mfMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.06 + Math.random() * 0.06
});
var mf = new THREE.Sprite(mfMat);
mf.position.set(Math.random() * 30 - 10, 2 + Math.random() * 4, 3 + Math.random() * 20);
var ms = 5 + Math.random() * 12;
mf.scale.set(ms, ms * 0.3, 1);
scene.add(mf);
fogSprites.push({
sprite: mf, baseX: mf.position.x,
drift: 0.0015 + Math.random() * 0.003,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.0025,
swayAmt: 0.25 + Math.random() * 0.6
});
}

for (var i = 0; i < 25; i++) {
var gfMat = new THREE.SpriteMaterial({
map: gingerFogTex, transparent: true,
opacity: 0.2 + Math.random() * 0.2
});
var gf = new THREE.Sprite(gfMat);
gf.position.set(2.5 + (Math.random() - 0.5) * 10, 0.3 + Math.random() * 5, 2.5 + (Math.random() - 0.5) * 8);
var gs = 2 + Math.random() * 6;
gf.scale.set(gs, gs * 0.45, 1);
scene.add(gf);
fogSprites.push({
sprite: gf, baseX: gf.position.x,
drift: 0.001 + Math.random() * 0.002,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.002,
swayAmt: 0.15 + Math.random() * 0.25
});
}

for (var i = 0; i < 10; i++) {
var wMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true,
opacity: 0.04 + Math.random() * 0.05
});
var w = new THREE.Sprite(wMat);
w.position.set(Math.random() * 30 - 10, 8 + Math.random() * 7, 4 + Math.random() * 15);
w.scale.set(7 + Math.random() * 12, 2 + Math.random() * 3, 1);
scene.add(w);
fogSprites.push({
sprite: w, baseX: w.position.x,
drift: 0.002 + Math.random() * 0.004,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.0015 + Math.random() * 0.003,
swayAmt: 0.3 + Math.random() * 0.75
});
}

var clock = new THREE.Clock();

function loAnimate() {
loAnimId = requestAnimationFrame(loAnimate);
var t = clock.getElapsedTime();

for (var i = 0; i < lampLights.length; i++) {
var baseInt = (i === 0) ? 1.2 : (i === 1) ? 0.5 : 0.3;
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;
lampLights[i].intensity = baseInt * breath;
}

fanlightGlow.intensity = 0.25 + Math.sin(t * 0.12) * 0.02;

var doorBreath = 0.95 + Math.sin(t * 0.25) * 0.03;
doorSpot.intensity = 1.5 * doorBreath;
doorFill.intensity = 0.4 * doorBreath;
brassHighlight.intensity = 0.3 * doorBreath;

brassMat.emissive = brassMat.emissive || new THREE.Color(0x4a3008);
brassMat.emissiveIntensity = 0.05 * doorBreath;

signLight.intensity = 0.25 + Math.sin(t * 0.2) * 0.02;

for (var i = 0; i < silhouettes.length; i++) {
var s = silhouettes[i];
s.swayPhase += s.swaySpeed * 0.016;
s.mesh.position.x = s.baseX + Math.sin(s.swayPhase) * s.swayAmt * 0.5;
s.mesh.position.y = s.baseY + Math.sin(s.swayPhase * 0.7) * 0.002;
}

var wFlicker = Math.sin(t * 0.4) * 0.3 + Math.sin(t * 1.1) * 0.2 + Math.sin(t * 0.17) * 0.5;
wFlicker = Math.max(0, wFlicker);
curtainMatR.emissiveIntensity = 0.1 + wFlicker * 0.35;
workingGlow.intensity = 0.08 + wFlicker * 0.4;

var wFlickerGFL = Math.sin(t * 0.28) * 0.4 + Math.sin(t * 0.75) * 0.2 + Math.sin(t * 0.13) * 0.4;
wFlickerGFL = Math.max(0, wFlickerGFL);
curtainMatL.emissiveIntensity = 0.1 + wFlickerGFL * 0.35;
workingGlowGFL.intensity = 0.08 + wFlickerGFL * 0.4;

var wFlicker1F = Math.sin(t * 0.35) * 0.35 + Math.sin(t * 0.9) * 0.25 + Math.sin(t * 0.22) * 0.4;
wFlicker1F = Math.max(0, wFlicker1F);
workingGlass1F.emissiveIntensity = 0.15 + wFlicker1F * 0.35;
workingGlow1F.intensity = 0.1 + wFlicker1F * 0.5;

doorPuddleMat.emissiveIntensity = 0.04 + Math.sin(t * 1.7) * 0.02;

loGrainFrame++;
if (loGrainFrame % 3 === 0) {
var imgData = loGrainCtx.createImageData(256, 256);
var d = imgData.data;
for (var i = 0; i < d.length; i += 4) {
var v = Math.random() * 255;
d[i] = d[i+1] = d[i+2] = v;
d[i+3] = 255;
}
loGrainCtx.putImageData(imgData, 0, 0);
}

renderer.render(scene, camera);
}

loAnimate();

loVig = document.createElement('div');
loVig.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9001;pointer-events:none;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
loWrap.appendChild(loVig);

loGrain = document.createElement('canvas');
loGrain.width = 256;
loGrain.height = 256;
loGrainCtx = loGrain.getContext('2d');
var grainImg = new Image();
grainImg.src = loGrain.toDataURL();
var grainDiv = document.createElement('div');
grainDiv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9002;pointer-events:none;background-image:url(' + loGrain.toDataURL() + ');background-size:256px 256px;opacity:0.02;mix-blend-mode:overlay;';
loWrap.appendChild(grainDiv);

loWash = document.createElement('div');
loWash.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9002;pointer-events:none;background:linear-gradient(180deg, rgba(10,8,25,0.3) 0%, rgba(5,5,15,0.08) 30%, rgba(5,5,15,0.08) 60%, rgba(5,3,2,0.4) 100%);';
loWrap.appendChild(loWash);

loLoc = document.createElement('div');
loLoc.textContent = "LACKLAND'S OFFICE, WARDOUR STREET, SOHO";
loLoc.style.cssText = 'position:fixed;bottom:18px;left:50%;transform:translateX(-50%);font:12px \"Courier New\",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;';
loWrap.appendChild(loLoc);

loBtn = document.createElement('div');
loBtn.textContent = 'ENTER LACKLAND\'S OFFICE';
// Ginger-Light style: transparent dark background, coloured text +
// border, no infill. Hover brightens text and border.
loBtn.style.cssText = [
  'position:fixed', 'bottom:60px', 'left:50%', 'transform:translateX(-50%)',
  'font:13px "Courier New",monospace',
  'color:rgba(232,180,80,0.85)',
  'letter-spacing:4px', 'cursor:pointer', 'padding:12px 28px',
  'border:1px solid rgba(232,180,80,0.3)',
  'background:rgba(0,0,0,0.4)',
  'z-index:9004', 'white-space:nowrap',
  'opacity:0', 'transition:opacity 1.5s ease, color 0.3s ease, border-color 0.3s ease'
].join(';');
setTimeout(function() { loBtn.style.opacity = '1'; }, 1800);
loBtn.addEventListener('mouseenter', function() {
  this.style.color = 'rgba(255,210,120,0.95)';
  this.style.borderColor = 'rgba(232,180,80,0.6)';
});
loBtn.addEventListener('mouseleave', function() {
  this.style.color = 'rgba(232,180,80,0.85)';
  this.style.borderColor = 'rgba(232,180,80,0.3)';
});
loBtn.addEventListener('click', function() {
loWrap.style.transition = 'opacity 1.5s ease';
loWrap.style.opacity = '0';
setTimeout(function() {
if (loAnimId) { cancelAnimationFrame(loAnimId); loAnimId = null; }
if (loWrap.parentNode) loWrap.parentNode.removeChild(loWrap);
var TARGET = 'Martin Lackland\'s Office';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
loWrap.appendChild(loBtn);

document.body.appendChild(loWrap);
}

setInterval(function() {
var container = document.getElementById('lo-container');
if (container && !loActive) {
initLackland();
} else if (!container) {
loActive = false;
if (loAnimId) { cancelAnimationFrame(loAnimId); loAnimId = null; }
window._dssDisposeWrap('lo-wrap');
}
}, 300);
})();
// ====== CECIL COURT APPROACH — IFRAME FULLSCREEN ======
(function() {
var ccActive = false;
var ccWrap = null;
function initCecilCourt() {
if (ccActive) return;
ccActive = true;
ccWrap = document.createElement('div');
ccWrap.id = 'cc-wrap';
ccWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';
var ccFrame = document.createElement('iframe');
ccFrame.src = 'cecil-court-3d-static.html';
ccFrame.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;';
ccWrap.appendChild(ccFrame);
var ccVig = document.createElement('div');
ccVig.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9001;pointer-events:none;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.55) 100%);';
ccWrap.appendChild(ccVig);
var ccBtn = document.createElement('div');
ccBtn.textContent = 'ENTER CECIL COURT';
ccBtn.style.cssText = [
  'position:fixed','bottom:60px','left:50%','transform:translateX(-50%)',
  'font:13px "Courier New",monospace','color:rgba(232,120,24,0.85)',
  'letter-spacing:4px','cursor:pointer','padding:12px 28px',
  'border:1px solid rgba(232,120,24,0.3)','background:rgba(0,0,0,0.4)',
  'z-index:9004','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
setTimeout(function() { ccBtn.style.opacity = '1'; }, 1500);
ccBtn.addEventListener('mouseenter', function() {
  this.style.color = 'rgba(255,160,50,0.95)';
  this.style.borderColor = 'rgba(232,120,24,0.6)';
});
ccBtn.addEventListener('mouseleave', function() {
  this.style.color = 'rgba(232,120,24,0.85)';
  this.style.borderColor = 'rgba(232,120,24,0.3)';
});
ccBtn.addEventListener('click', function() {
ccWrap.style.transition = 'opacity 1.5s ease';
ccWrap.style.opacity = '0';
setTimeout(function() {
if (ccWrap && ccWrap.parentNode) ccWrap.parentNode.removeChild(ccWrap);
var TARGET = 'Cecil Court';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '\u00b7') { links[i].click(); break; }
}
}
}, 1500);
});
ccWrap.appendChild(ccBtn);
document.body.appendChild(ccWrap);
}
setInterval(function() {
var container = document.getElementById('cc-approach');
if (container && !ccActive) {
initCecilCourt();
} else if (!container) {
ccActive = false;
var wrap = document.getElementById('cc-wrap');
if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
}
}, 300);
})();
// ====== CARTHAGE COAST — INLINE ======
(function() {
var caActive = false;
var caAnimId = null;

function initCa() {
  if (caActive) return; caActive = true;
  if (typeof THREE === 'undefined') {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    s.onload = function() { buildCaScene(); };
    document.head.appendChild(s);
  } else { buildCaScene(); }
}

function buildCaScene() {
  var caWrap = document.createElement('div');
  caWrap.id = 'ca-wrap';
  caWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';

  // ============================================================
  // HELPERS
  // ============================================================
  function makeCanvasTexture(w, h, drawFunc) {
    var c = document.createElement('canvas');
    c.width = w; c.height = h;
    var cx = c.getContext('2d');
    drawFunc(cx, w, h);
    var tex = new THREE.CanvasTexture(c);
    tex.minFilter = THREE.LinearFilter;
    return tex;
  }

  // ============================================================
  // SCENE SETUP
  // ============================================================
  var scene = new THREE.Scene();
  scene.background = new THREE.Color(0x12202e);
  scene.fog = new THREE.FogExp2(0x8a6840, 0.015);

  var camera = new THREE.PerspectiveCamera(62, window.innerWidth / window.innerHeight, 0.1, 200);
  camera.position.set(12, 5.5, 5);
  camera.lookAt(0, 1.2, -12);

  var renderer = new THREE.WebGLRenderer({ antialias: true });
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 0.85;
  caWrap.appendChild(renderer.domElement);
  window._dssBindScene('ca-wrap', scene, renderer, camera);

  // ============================================================
  // MATERIALS — rich canvas textures like Cecil Court
  // ============================================================

  // STONE TEXTURE — individual blocks with mortar, weathering, lichen
  var stoneTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    // Mortar base
    cx.fillStyle = '#8a7848';
    cx.fillRect(0, 0, w, h);
    // Draw individual stone blocks — irregular sizes
    var blockH = 40;
    var mortarW = 3;
    var blockY = 0;
    while (blockY < h + blockH) {
      var blockX = 0;
      var offset = (Math.floor(blockY / blockH) % 2 === 0) ? 0 : 35;
      while (blockX < w + 80) {
        var bw = 50 + Math.random() * 40;
        var bh = blockH - mortarW;
        // Each block a different shade of warm golden stone
        var base = 160 + Math.random() * 50;
        var warmth = Math.random() * 20;
        cx.fillStyle = 'rgb(' + Math.floor(base + warmth) + ',' + Math.floor(base * 0.85 + warmth * 0.5) + ',' + Math.floor(base * 0.55) + ')';
        // Slightly irregular edges
        cx.beginPath();
        cx.moveTo(blockX + offset + (Math.random() - 0.5) * 2, blockY + (Math.random() - 0.5) * 1);
        cx.lineTo(blockX + offset + bw + (Math.random() - 0.5) * 2, blockY + (Math.random() - 0.5) * 1);
        cx.lineTo(blockX + offset + bw + (Math.random() - 0.5) * 2, blockY + bh + (Math.random() - 0.5) * 1);
        cx.lineTo(blockX + offset + (Math.random() - 0.5) * 2, blockY + bh + (Math.random() - 0.5) * 1);
        cx.closePath();
        cx.fill();
        // Surface variation within each block
        if (Math.random() > 0.5) {
          cx.fillStyle = 'rgba(120, 100, 60, 0.12)';
          cx.beginPath();
          cx.ellipse(blockX + offset + bw * 0.5, blockY + bh * 0.5,
            bw * 0.3, bh * 0.3, Math.random(), 0, Math.PI * 2);
          cx.fill();
        }
        blockX += bw + mortarW;
      }
      blockY += blockH;
    }
    // Weathering — darker patches where rain has stained
    var weatherGrad = cx.createLinearGradient(0, 0, 0, h);
    weatherGrad.addColorStop(0, 'rgba(60, 40, 20, 0.25)');
    weatherGrad.addColorStop(0.4, 'rgba(80, 60, 30, 0.08)');
    weatherGrad.addColorStop(1, 'rgba(50, 35, 15, 0.2)');
    cx.fillStyle = weatherGrad;
    cx.fillRect(0, 0, w, h);
    // Vertical water streaks
    for (var ws = 0; ws < 6; ws++) {
      var sx = Math.random() * w;
      cx.fillStyle = 'rgba(60, 45, 20, 0.15)';
      cx.fillRect(sx, 0, 2 + Math.random() * 5, h);
    }
    // Dry lichen patches — pale ochre / sun-bleached grey, not green
    for (var lp = 0; lp < 20; lp++) {
      cx.fillStyle = 'rgba(150, 130, 80, ' + (0.07 + Math.random() * 0.1) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        8 + Math.random() * 20, 6 + Math.random() * 15,
        Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Cracks
    cx.strokeStyle = 'rgba(50, 35, 15, 0.2)';
    cx.lineWidth = 1;
    for (var ci = 0; ci < 12; ci++) {
      cx.beginPath();
      cx.moveTo(Math.random() * w, Math.random() * h);
      var cx2 = Math.random() * w, cy2 = Math.random() * h;
      cx.lineTo(cx2, cy2);
      cx.lineTo(cx2 + (Math.random() - 0.5) * 30, cy2 + Math.random() * 30);
      cx.stroke();
    }
  });
  var warmStone = new THREE.MeshStandardMaterial({ map: stoneTex, roughness: 0.82 });

  // PALE STONE — for capitals, lintels
  var paleStoneTex = makeCanvasTexture(256, 256, function(cx, w, h) {
    cx.fillStyle = '#dcc888';
    cx.fillRect(0, 0, w, h);
    for (var i = 0; i < 200; i++) {
      var tone = 180 + Math.floor(Math.random() * 50);
      cx.fillStyle = 'rgba(' + tone + ',' + (tone - 5) + ',' + (tone - 25) + ', 0.2)';
      cx.beginPath();
      cx.arc(Math.random() * w, Math.random() * h, 2 + Math.random() * 6, 0, Math.PI * 2);
      cx.fill();
    }
    for (var ci = 0; ci < 5; ci++) {
      cx.strokeStyle = 'rgba(100, 80, 40, 0.12)';
      cx.lineWidth = 0.8;
      cx.beginPath();
      cx.moveTo(Math.random() * w, Math.random() * h);
      cx.lineTo(Math.random() * w, Math.random() * h);
      cx.stroke();
    }
  });
  var paleStone = new THREE.MeshStandardMaterial({ map: paleStoneTex, roughness: 0.75 });

  // LINTEL STONE — pale cream base with horizontal carved bands (moulding
  // top/bottom), vertical rain-staining, lichen, hairline cracks. Used for
  // the entablature lintels above both colonnades so they read as worked
  // stone, not unfinished slabs.
  var lintelTex = makeCanvasTexture(512, 128, function(cx, w, h) {
    cx.fillStyle = '#d6c082';
    cx.fillRect(0, 0, w, h);
    // Surface tone variation
    for (var pp = 0; pp < 250; pp++) {
      var t = 170 + Math.floor(Math.random() * 60);
      cx.fillStyle = 'rgba(' + t + ',' + (t - 12) + ',' + (t - 35) + ',' + (0.10 + Math.random() * 0.14) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        4 + Math.random() * 14, 3 + Math.random() * 9, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Top moulding band — chiseled chamfer (darker stripe at the top edge)
    var topGrad = cx.createLinearGradient(0, 0, 0, h * 0.16);
    topGrad.addColorStop(0, 'rgba(80, 60, 30, 0.4)');
    topGrad.addColorStop(0.6, 'rgba(120, 95, 50, 0.18)');
    topGrad.addColorStop(1, 'rgba(180, 150, 90, 0)');
    cx.fillStyle = topGrad;
    cx.fillRect(0, 0, w, h * 0.16);
    // Fine carved line under the top moulding
    cx.strokeStyle = 'rgba(60, 45, 22, 0.55)';
    cx.lineWidth = 1.5;
    cx.beginPath();
    cx.moveTo(0, h * 0.17);
    cx.lineTo(w, h * 0.17);
    cx.stroke();
    // Bottom moulding band
    var botGrad = cx.createLinearGradient(0, h * 0.84, 0, h);
    botGrad.addColorStop(0, 'rgba(180, 150, 90, 0)');
    botGrad.addColorStop(0.5, 'rgba(120, 95, 50, 0.2)');
    botGrad.addColorStop(1, 'rgba(70, 50, 25, 0.45)');
    cx.fillStyle = botGrad;
    cx.fillRect(0, h * 0.84, w, h * 0.16);
    cx.strokeStyle = 'rgba(60, 45, 22, 0.55)';
    cx.lineWidth = 1.5;
    cx.beginPath();
    cx.moveTo(0, h * 0.83);
    cx.lineTo(w, h * 0.83);
    cx.stroke();
    // Vertical rain stains
    for (var rs = 0; rs < 9; rs++) {
      var rsx = Math.random() * w;
      var rsw = 4 + Math.random() * 14;
      var rsg = cx.createLinearGradient(rsx, 0, rsx, h);
      rsg.addColorStop(0, 'rgba(40, 30, 15, 0.35)');
      rsg.addColorStop(0.5, 'rgba(50, 38, 18, 0.15)');
      rsg.addColorStop(1, 'rgba(60, 45, 22, 0.05)');
      cx.fillStyle = rsg;
      cx.fillRect(rsx - rsw / 2, 0, rsw, h);
    }
    // Lichen patches
    for (var lp = 0; lp < 14; lp++) {
      cx.fillStyle = 'rgba(' + (140 + Math.floor(Math.random() * 40)) + ',' + (120 + Math.floor(Math.random() * 30)) + ',70,' + (0.08 + Math.random() * 0.12) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        6 + Math.random() * 14, 4 + Math.random() * 9, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Hairline cracks
    cx.strokeStyle = 'rgba(45, 30, 12, 0.4)';
    cx.lineWidth = 0.6;
    for (var ck = 0; ck < 8; ck++) {
      cx.beginPath();
      var ckx = Math.random() * w;
      var cky = h * 0.2 + Math.random() * h * 0.6;
      cx.moveTo(ckx, cky);
      for (var seg = 0; seg < 4; seg++) {
        ckx += (Math.random() - 0.5) * 30;
        cky += (Math.random() - 0.5) * 10;
        cx.lineTo(ckx, cky);
      }
      cx.stroke();
    }
    // Chips and broken corners
    for (var ch = 0; ch < 6; ch++) {
      var chx = Math.random() * w;
      var edgeChoice = Math.random();
      var chy = edgeChoice > 0.5 ? Math.random() * h * 0.08 : h - Math.random() * h * 0.08;
      cx.fillStyle = 'rgba(50, 35, 18, 0.35)';
      cx.beginPath();
      cx.ellipse(chx, chy, 3 + Math.random() * 6, 2 + Math.random() * 4, 0, 0, Math.PI * 2);
      cx.fill();
    }
  });
  var lintelMat = new THREE.MeshStandardMaterial({ map: lintelTex, roughness: 0.8 });

  // GROUND TEXTURE — sandy earth with pebbles, broken tiles, dry grass tufts
  var groundTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    // Sandy base
    cx.fillStyle = '#c8a868';
    cx.fillRect(0, 0, w, h);
    // Variation patches — different shades of sand
    for (var p = 0; p < 80; p++) {
      var base = 160 + Math.random() * 50;
      cx.fillStyle = 'rgba(' + Math.floor(base + 10) + ',' + Math.floor(base * 0.85) + ',' + Math.floor(base * 0.5) + ', 0.25)';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        15 + Math.random() * 40, 10 + Math.random() * 30,
        Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Small pebbles
    for (var pb = 0; pb < 150; pb++) {
      var pTone = 100 + Math.floor(Math.random() * 80);
      cx.fillStyle = 'rgb(' + pTone + ',' + Math.floor(pTone * 0.9) + ',' + Math.floor(pTone * 0.7) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        1 + Math.random() * 3, 1 + Math.random() * 2,
        Math.random(), 0, Math.PI * 2);
      cx.fill();
    }
    // Broken terracotta tile fragments
    for (var tf = 0; tf < 12; tf++) {
      cx.fillStyle = 'rgba(180, 100, 60, ' + (0.15 + Math.random() * 0.15) + ')';
      var tx = Math.random() * w, ty = Math.random() * h;
      cx.beginPath();
      cx.moveTo(tx, ty);
      cx.lineTo(tx + 5 + Math.random() * 15, ty + (Math.random() - 0.5) * 8);
      cx.lineTo(tx + (Math.random() - 0.5) * 10, ty + 4 + Math.random() * 12);
      cx.closePath();
      cx.fill();
    }
    // Dry grass tufts — sun-bleached straw streaks
    for (var gr = 0; gr < 30; gr++) {
      cx.strokeStyle = 'rgba(' + (140 + Math.floor(Math.random() * 40)) + ',' + (115 + Math.floor(Math.random() * 35)) + ',55, 0.22)';
      cx.lineWidth = 1;
      var gx = Math.random() * w, gy = Math.random() * h;
      for (var gb = 0; gb < 3; gb++) {
        cx.beginPath();
        cx.moveTo(gx + (Math.random() - 0.5) * 4, gy);
        cx.lineTo(gx + (Math.random() - 0.5) * 8, gy - 4 - Math.random() * 8);
        cx.stroke();
      }
    }
    // Damp/dark patches near bottom (waterline)
    cx.fillStyle = 'rgba(80, 60, 30, 0.15)';
    cx.fillRect(0, h * 0.75, w, h * 0.25);
  });
  var sandMat = new THREE.MeshStandardMaterial({ map: groundTex, roughness: 0.9 });

  // SEA TEXTURE — wave bands with specular highlights and sunset reflection
  var seaTex = makeCanvasTexture(512, 512, function(cx, w, h) {
    // Deep blue-green base
    cx.fillStyle = '#1a5888';
    cx.fillRect(0, 0, w, h);
    // Horizontal wave bands — each slightly different
    for (var y = 0; y < h; y += 2) {
      var waveAlpha = 0.02 + Math.sin(y * 0.06) * 0.02 + Math.sin(y * 0.15) * 0.01;
      var blueShift = Math.sin(y * 0.03) * 20;
      cx.fillStyle = 'rgba(' + Math.floor(80 + blueShift) + ',' + Math.floor(160 + blueShift) + ',' + Math.floor(200 + blueShift * 0.5) + ',' + waveAlpha + ')';
      cx.fillRect(0, y, w, 2);
    }
    // Specular dashes — white-ish bright flecks
    for (var sp = 0; sp < 300; sp++) {
      var sx = Math.random() * w, sy = Math.random() * h;
      cx.fillStyle = 'rgba(200, 230, 255, ' + (0.01 + Math.random() * 0.05) + ')';
      cx.fillRect(sx, sy, 3 + Math.random() * 18, 1);
    }
    // Golden sunset reflection path — centre column
    var sunRef = cx.createRadialGradient(w * 0.42, h * 0.3, 0, w * 0.42, h * 0.5, w * 0.35);
    sunRef.addColorStop(0, 'rgba(240, 180, 80, 0.15)');
    sunRef.addColorStop(0.4, 'rgba(220, 150, 60, 0.06)');
    sunRef.addColorStop(1, 'rgba(180, 120, 40, 0)');
    cx.fillStyle = sunRef;
    cx.fillRect(0, 0, w, h);
    // Darker deeper water at top (far horizon)
    var depthGrad = cx.createLinearGradient(0, 0, 0, h);
    depthGrad.addColorStop(0, 'rgba(10, 30, 60, 0.3)');
    depthGrad.addColorStop(0.5, 'rgba(10, 30, 60, 0.05)');
    depthGrad.addColorStop(1, 'rgba(10, 30, 60, 0)');
    cx.fillStyle = depthGrad;
    cx.fillRect(0, 0, w, h);
  });
  var seaMat = new THREE.MeshStandardMaterial({
    map: seaTex, roughness: 0.6, metalness: 0.05,
    emissive: 0x183858, emissiveIntensity: 0.1
  });

  // COLUMN TEXTURE — fluted effect with vertical grooves
  var columnTex = makeCanvasTexture(256, 512, function(cx, w, h) {
    cx.fillStyle = '#c8b070';
    cx.fillRect(0, 0, w, h);
    // Vertical fluting — alternating light/dark bands
    for (var x = 0; x < w; x += 12) {
      var shade = Math.sin(x * 0.26) * 0.08;
      cx.fillStyle = 'rgba(0, 0, 0, ' + (0.05 + Math.abs(shade)) + ')';
      cx.fillRect(x, 0, 5, h);
    }
    // Horizontal drum joints
    for (var jy = 0; jy < h; jy += 100 + Math.random() * 50) {
      cx.fillStyle = 'rgba(60, 45, 20, 0.2)';
      cx.fillRect(0, jy, w, 3);
    }
    // Weathering
    for (var wp = 0; wp < 15; wp++) {
      cx.fillStyle = 'rgba(90, 70, 35, 0.1)';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h, 10 + Math.random() * 20, 8 + Math.random() * 15, 0, 0, Math.PI * 2);
      cx.fill();
    }
    // Dry lichen near base — straw/grey, sun-bleached
    cx.fillStyle = 'rgba(140, 120, 70, 0.12)';
    cx.fillRect(0, h * 0.8, w, h * 0.2);
  });
  var columnMat = new THREE.MeshStandardMaterial({ map: columnTex, roughness: 0.78 });

  // Simple materials for variety
  var darkStone = new THREE.MeshStandardMaterial({ color: 0x907840, roughness: 0.92 });
  var rubbleMat = new THREE.MeshStandardMaterial({ color: 0xb8a068, roughness: 0.95 });
  var darkRubble = new THREE.MeshStandardMaterial({ color: 0x8a7048, roughness: 0.95 });
  var wetSandMat = new THREE.MeshStandardMaterial({ color: 0xb8a060, roughness: 0.35, metalness: 0.2 });
  var mossyMat = new THREE.MeshStandardMaterial({ color: 0x584c20, roughness: 0.9 });
  var terracotta = new THREE.MeshStandardMaterial({ color: 0xb87848, roughness: 0.85 });
  // Sun-bleached desert palette — no English greens
  var darkLeaf = new THREE.MeshStandardMaterial({ color: 0x4a4220, roughness: 0.85 });
  var midLeaf = new THREE.MeshStandardMaterial({ color: 0x625830, roughness: 0.8 });
  var paleLeaf = new THREE.MeshStandardMaterial({ color: 0x7a6c40, roughness: 0.82 });
  var trunkMat = new THREE.MeshStandardMaterial({ color: 0x5a4028, roughness: 0.9 });
  var ironMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.6, metalness: 0.4 });

  // ============================================================
  // SKY DOME — painted sunset with definite sun disc
  // ============================================================
  var skyTex = makeCanvasTexture(1024, 1024, function(cx, w, h) {
    var grad = cx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0.0,  '#0a1840');
    grad.addColorStop(0.08, '#142050');
    grad.addColorStop(0.18, '#1e3070');
    grad.addColorStop(0.28, '#2a4888');
    grad.addColorStop(0.36, '#3a6098');
    grad.addColorStop(0.42, '#6888a8');
    grad.addColorStop(0.48, '#98a098');
    grad.addColorStop(0.53, '#c8a868');
    grad.addColorStop(0.58, '#e09840');
    grad.addColorStop(0.63, '#e88030');
    grad.addColorStop(0.68, '#e06820');
    grad.addColorStop(0.74, '#c84818');
    grad.addColorStop(0.82, '#982810');
    grad.addColorStop(0.90, '#681808');
    grad.addColorStop(1.0,  '#280808');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);

    // CLOUD BANDS — multi-coloured, painted on the dome
    // High cirrus — wispy pale blue
    cx.globalAlpha = 0.1;
    for (var i = 0; i < 18; i++) {
      cx.fillStyle = '#8aa8c8';
      cx.beginPath();
      cx.ellipse(Math.random() * w, h * 0.1 + Math.random() * h * 0.15, 100 + Math.random() * 350, 2 + Math.random() * 4, Math.random() * 0.3, 0, Math.PI * 2);
      cx.fill();
    }

    // Mid clouds — purple and grey masses
    cx.globalAlpha = 0.18;
    for (var i = 0; i < 22; i++) {
      var purpleOrGrey = Math.random();
      if (purpleOrGrey > 0.6) cx.fillStyle = '#6a5080';
      else if (purpleOrGrey > 0.3) cx.fillStyle = '#5a5878';
      else cx.fillStyle = '#4a5068';
      cx.beginPath();
      cx.ellipse(Math.random() * w, h * 0.28 + Math.random() * h * 0.14, 80 + Math.random() * 280, 10 + Math.random() * 25, Math.random() * 0.2, 0, Math.PI * 2);
      cx.fill();
    }

    // Pink-gold lit band — the magical sunset transition
    cx.globalAlpha = 0.28;
    for (var i = 0; i < 30; i++) {
      var pinkOrGold = Math.random();
      if (pinkOrGold > 0.6) cx.fillStyle = '#f0b860';
      else if (pinkOrGold > 0.3) cx.fillStyle = '#e8a0a0';
      else cx.fillStyle = '#f0c870';
      cx.beginPath();
      cx.ellipse(Math.random() * w, h * 0.44 + Math.random() * h * 0.12, 60 + Math.random() * 280, 8 + Math.random() * 18, Math.random() * 0.15, 0, Math.PI * 2);
      cx.fill();
    }

    // Fire clouds near horizon
    cx.globalAlpha = 0.25;
    for (var i = 0; i < 25; i++) {
      cx.fillStyle = Math.random() > 0.5 ? '#f08030' : '#d04828';
      cx.beginPath();
      cx.ellipse(Math.random() * w, h * 0.58 + Math.random() * h * 0.12, 50 + Math.random() * 220, 6 + Math.random() * 16, Math.random() * 0.2, 0, Math.PI * 2);
      cx.fill();
    }

    // Dark silhouette clouds — backlit by the sun
    cx.globalAlpha = 0.15;
    for (var i = 0; i < 15; i++) {
      cx.fillStyle = '#2a1508';
      cx.beginPath();
      cx.ellipse(Math.random() * w, h * 0.62 + Math.random() * h * 0.1, 60 + Math.random() * 200, 10 + Math.random() * 22, 0, 0, Math.PI * 2);
      cx.fill();
    }
    cx.globalAlpha = 1.0;

    // DEFINITE SUN DISC
    var sunX = w * 0.42, sunY = h * 0.66;
    // Large outer glow
    var glow = cx.createRadialGradient(sunX, sunY, 0, sunX, sunY, w * 0.35);
    glow.addColorStop(0, 'rgba(255, 240, 180, 0.55)');
    glow.addColorStop(0.08, 'rgba(255, 220, 140, 0.4)');
    glow.addColorStop(0.2, 'rgba(255, 180, 80, 0.2)');
    glow.addColorStop(0.45, 'rgba(240, 140, 50, 0.06)');
    glow.addColorStop(1, 'rgba(200, 100, 30, 0)');
    cx.fillStyle = glow;
    cx.fillRect(0, 0, w, h);
    // Bright sun core
    var disc = cx.createRadialGradient(sunX, sunY, 0, sunX, sunY, 28);
    disc.addColorStop(0, 'rgba(255, 255, 245, 0.98)');
    disc.addColorStop(0.2, 'rgba(255, 245, 210, 0.9)');
    disc.addColorStop(0.5, 'rgba(255, 220, 150, 0.65)');
    disc.addColorStop(0.8, 'rgba(255, 190, 100, 0.3)');
    disc.addColorStop(1, 'rgba(255, 160, 60, 0)');
    cx.fillStyle = disc;
    cx.fillRect(0, 0, w, h);

    // Stars in the dark upper sky
    for (var s = 0; s < 50; s++) {
      var sx = Math.random() * w, sy = Math.random() * h * 0.3;
      cx.fillStyle = 'rgba(' + (200 + Math.floor(Math.random() * 55)) + ',' + (200 + Math.floor(Math.random() * 55)) + ',255,' + (0.25 + Math.random() * 0.5) + ')';
      cx.beginPath();
      cx.arc(sx, sy, 0.5 + Math.random() * 1.2, 0, Math.PI * 2);
      cx.fill();
    }
  });
  var skyMat = new THREE.MeshBasicMaterial({ map: skyTex, side: THREE.BackSide, fog: false });
  var skyDome = new THREE.Mesh(new THREE.SphereGeometry(90, 32, 32), skyMat);
  scene.add(skyDome);

  // ============================================================
  // GROUND — sandy shore that ENDS at the waterline
  // ============================================================
  // Main beach — stops at z=-5 (the dry beach area)
  var ground = new THREE.Mesh(new THREE.PlaneGeometry(120, 30), sandMat);
  ground.rotation.x = -Math.PI / 2;
  ground.position.set(0, 0, 10);
  ground.receiveShadow = true;
  scene.add(ground);

  // Wet sand strip — the dark damp sand just above the waterline
  var wetStrip = new THREE.Mesh(new THREE.PlaneGeometry(120, 4), wetSandMat);
  wetStrip.rotation.x = -Math.PI / 2;
  wetStrip.position.set(0, -0.01, -7);
  scene.add(wetStrip);

  // Dark damp patches on the sand
  for (var dp = 0; dp < 10; dp++) {
    var dpMat = new THREE.MeshStandardMaterial({
      color: 0xa08848, roughness: 0.7, transparent: true, opacity: 0.3
    });
    var patch = new THREE.Mesh(new THREE.PlaneGeometry(1.5 + Math.random() * 3, 1 + Math.random() * 2), dpMat);
    patch.rotation.x = -Math.PI / 2;
    patch.position.set(-10 + Math.random() * 20, 0.01, -2 + Math.random() * 10);
    patch.rotation.z = Math.random() * Math.PI;
    scene.add(patch);
  }

  // ============================================================
  // SEA — clear layered progression from shore to horizon
  // ============================================================
  // The waterline is at z=-9. Everything south of that is water.
  var shallowSeaMat = new THREE.MeshStandardMaterial({
    color: 0x2898b0, roughness: 0.55, metalness: 0.05,
    emissive: 0x205060, emissiveIntensity: 0.08
  });
  var deepSeaMat = new THREE.MeshStandardMaterial({
    color: 0x143868, roughness: 0.6, metalness: 0.05,
    emissive: 0x0a2040, emissiveIntensity: 0.06
  });

  // Surf zone — very shallow turquoise water at the beach edge (z=-9 to z=-12)
  var surfZoneMat = new THREE.MeshStandardMaterial({
    color: 0x48b8c8, roughness: 0.5, metalness: 0.05,
    emissive: 0x306870, emissiveIntensity: 0.08
  });
  var surfZone = new THREE.Mesh(new THREE.PlaneGeometry(120, 4), surfZoneMat);
  surfZone.rotation.x = -Math.PI / 2;
  surfZone.position.set(0, -0.08, -11);
  scene.add(surfZone);

  // Shallow sea (z=-12 to z=-20)
  var shallowSea = new THREE.Mesh(new THREE.PlaneGeometry(120, 10), shallowSeaMat);
  shallowSea.rotation.x = -Math.PI / 2;
  shallowSea.position.set(0, -0.12, -18);
  scene.add(shallowSea);

  // Main sea with texture (z=-20 to z=-50)
  var sea = new THREE.Mesh(new THREE.PlaneGeometry(120, 30), seaMat);
  sea.rotation.x = -Math.PI / 2;
  sea.position.set(0, -0.18, -38);
  scene.add(sea);

  // Deep sea to horizon (z=-50 to z=-90)
  var deepSea = new THREE.Mesh(new THREE.PlaneGeometry(120, 40), deepSeaMat);
  deepSea.rotation.x = -Math.PI / 2;
  deepSea.position.set(0, -0.22, -73);
  scene.add(deepSea);

  // ============================================================
  // HILL-FOOT BEACH — a bright sandy crescent at the base of the headland,
  // raised above the surrounding planes so it pops as a clear beach band
  // between the hill and the water.
  // ============================================================
  // Bright pale sand — deliberately lighter than the surrounding ground so
  // the beach reads as its own band of shore
  var beachMat = new THREE.MeshStandardMaterial({
    color: 0xe8d098, roughness: 0.95
  });
  var dampBeachMat = new THREE.MeshStandardMaterial({
    color: 0xb89868, roughness: 0.55, metalness: 0.1
  });
  // Main beach band — long, wide strip running along the hill foot, raised
  // above the surf plane and the ground plane so it's clearly visible.
  // Angled to follow the curve of the coastline receding to the left.
  var hillBeach = new THREE.Mesh(new THREE.PlaneGeometry(22, 4.5), beachMat);
  hillBeach.rotation.x = -Math.PI / 2;
  hillBeach.rotation.z = 0.22;
  hillBeach.position.set(-10, 0.05, -7.6);
  scene.add(hillBeach);
  // Wider damp-sand band — overlap with main beach on the inland side, extend
  // out into the surf to form the wet lapping zone
  var hillDampBeach = new THREE.Mesh(new THREE.PlaneGeometry(22, 2.6), dampBeachMat);
  hillDampBeach.rotation.x = -Math.PI / 2;
  hillDampBeach.rotation.z = 0.22;
  hillDampBeach.position.set(-10, 0.025, -9.6);
  scene.add(hillDampBeach);
  // Curving back-section — the beach turns to the LEFT/back as the hill
  // recedes; a more steeply angled strip continues the shore around the hill
  var hillBeach2 = new THREE.Mesh(new THREE.PlaneGeometry(10, 3.0), beachMat);
  hillBeach2.rotation.x = -Math.PI / 2;
  hillBeach2.rotation.z = 0.55;
  hillBeach2.position.set(-19, 0.05, -10.0);
  scene.add(hillBeach2);
  var hillDampBeach2 = new THREE.Mesh(new THREE.PlaneGeometry(10, 1.6), dampBeachMat);
  hillDampBeach2.rotation.x = -Math.PI / 2;
  hillDampBeach2.rotation.z = 0.55;
  hillDampBeach2.position.set(-19.5, 0.025, -11.3);
  scene.add(hillDampBeach2);
  // Subtle scattered sand highlights — a few brighter patches catching the
  // setting sun on top of the beach surface
  var sunlitSandMat = new THREE.MeshStandardMaterial({
    color: 0xfae2a8, roughness: 0.85, transparent: true, opacity: 0.55
  });
  for (var bsh = 0; bsh < 8; bsh++) {
    var bshSize = 1.4 + Math.random() * 2.5;
    var bshPatch = new THREE.Mesh(
      new THREE.PlaneGeometry(bshSize, bshSize * (0.4 + Math.random() * 0.4)),
      sunlitSandMat
    );
    bshPatch.rotation.x = -Math.PI / 2;
    bshPatch.rotation.z = Math.random() * Math.PI;
    var bshX = -20 + Math.random() * 14;
    var bshZ = -7 - Math.random() * 3.5;
    bshPatch.position.set(bshX, 0.07, bshZ);
    scene.add(bshPatch);
  }

  // ============================================================
  // SHORELINE NATURALS — wet pebbles, driftwood, seaweed wash. Breaks up
  // the hard beach/sea edge so the transition reads as a natural shore
  // rather than two coloured planes meeting at a line.
  // ============================================================
  // Wet pebbles — small dark stones in the wet zone where the water laps
  var pebbleMatA = new THREE.MeshStandardMaterial({ color: 0x3a2e20, roughness: 0.45, metalness: 0.1 });
  var pebbleMatB = new THREE.MeshStandardMaterial({ color: 0x281c12, roughness: 0.4, metalness: 0.15 });
  var pebbleMatC = new THREE.MeshStandardMaterial({ color: 0x4a3a24, roughness: 0.5, metalness: 0.08 });
  for (var pbi = 0; pbi < 90; pbi++) {
    var pbSize = 0.08 + Math.random() * 0.22;
    var pbMatChoice = Math.random();
    var pbMat = pbMatChoice < 0.4 ? pebbleMatA : (pbMatChoice < 0.75 ? pebbleMatB : pebbleMatC);
    var pbGeo = Math.random() > 0.5
      ? new THREE.DodecahedronGeometry(pbSize * 0.5, 0)
      : new THREE.IcosahedronGeometry(pbSize * 0.5, 0);
    var pebble = new THREE.Mesh(pbGeo, pbMat);
    // Concentrated along the wet/surf transition; scattered up into dry sand
    var pbX = -16 + Math.random() * 32;
    var beachBias = Math.random();
    var pbZ = beachBias < 0.6
      ? (-7 - Math.random() * 4)   // wet zone (most)
      : (-5 + Math.random() * 4);  // up into dry sand (some)
    pebble.position.set(pbX, pbSize * 0.18 - 0.06, pbZ);
    pebble.scale.set(1.0 + Math.random() * 0.4, 0.5 + Math.random() * 0.35, 0.85 + Math.random() * 0.35);
    pebble.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, (Math.random() - 0.5) * 0.5);
    scene.add(pebble);
  }

  // Driftwood — pale weathered branches washed up along the tide line
  var driftwoodMat = new THREE.MeshStandardMaterial({ color: 0x8a7252, roughness: 0.95 });
  var driftDarkMat = new THREE.MeshStandardMaterial({ color: 0x4a3a28, roughness: 0.95 });
  var driftData = [
    [-3, -8, 1.2, 0.07, 0.3],
    [4, -7.5, 0.9, 0.06, -0.5],
    [-9, -8.5, 1.5, 0.08, 0.8],
    [11, -8, 0.7, 0.05, 0.2],
    [0, -7.2, 0.5, 0.04, -0.3],
    [-13, -9, 1.0, 0.06, 1.1],
    [7, -9.5, 0.8, 0.05, 0.6]
  ];
  for (var dwi = 0; dwi < driftData.length; dwi++) {
    var dw = driftData[dwi];
    var driftMat = dwi % 3 === 0 ? driftDarkMat : driftwoodMat;
    var drift = new THREE.Mesh(
      new THREE.CylinderGeometry(dw[3], dw[3] * 1.15, dw[2], 5),
      driftMat
    );
    drift.rotation.z = Math.PI / 2;
    drift.rotation.y = dw[4];
    drift.position.set(dw[0], -0.04, dw[1]);
    scene.add(drift);
    // Small forked branches
    if (Math.random() > 0.5) {
      var fork = new THREE.Mesh(
        new THREE.CylinderGeometry(dw[3] * 0.55, dw[3] * 0.7, dw[2] * 0.5, 4),
        driftMat
      );
      fork.rotation.z = Math.PI / 2;
      fork.rotation.y = dw[4] + 0.6;
      fork.position.set(dw[0] + Math.cos(dw[4]) * dw[2] * 0.4, -0.03, dw[1] + Math.sin(dw[4]) * dw[2] * 0.4);
      scene.add(fork);
    }
  }

  // Seaweed / kelp — dark wet wash patches at the tide line (low planes)
  var kelpMat = new THREE.MeshStandardMaterial({
    color: 0x2a3018, roughness: 0.85, transparent: true, opacity: 0.55
  });
  var kelpMatDark = new THREE.MeshStandardMaterial({
    color: 0x1a2010, roughness: 0.9, transparent: true, opacity: 0.45
  });
  for (var kli = 0; kli < 18; kli++) {
    var kSize = 0.5 + Math.random() * 1.3;
    var kelp = new THREE.Mesh(
      new THREE.PlaneGeometry(kSize, kSize * (0.35 + Math.random() * 0.45)),
      Math.random() > 0.5 ? kelpMat : kelpMatDark
    );
    kelp.rotation.x = -Math.PI / 2;
    kelp.rotation.z = Math.random() * Math.PI;
    var kX = -15 + Math.random() * 30;
    // Strung along the wet sand / surf transition
    var kZ = -7.5 - Math.random() * 4;
    kelp.position.set(kX, 0.005, kZ);
    scene.add(kelp);
  }

  // Wet-sand variation patches — darker damp areas that vary the colour
  // of the beach so it isn't a single flat tone
  var wetPatchMat = new THREE.MeshStandardMaterial({
    color: 0x7a5a30, roughness: 0.7, metalness: 0.1,
    transparent: true, opacity: 0.45
  });
  for (var wsp = 0; wsp < 14; wsp++) {
    var wspSize = 1.2 + Math.random() * 2.8;
    var wspPatch = new THREE.Mesh(
      new THREE.PlaneGeometry(wspSize, wspSize * (0.4 + Math.random() * 0.45)),
      wetPatchMat
    );
    wspPatch.rotation.x = -Math.PI / 2;
    wspPatch.rotation.z = Math.random() * Math.PI;
    var wspX = -15 + Math.random() * 30;
    var wspZ = -6.5 - Math.random() * 3.5;
    wspPatch.position.set(wspX, 0.007, wspZ);
    scene.add(wspPatch);
  }

  // ============================================================
  // WAVE SURFACE — vertex-displaced overlay for subtle swell
  // ============================================================
  var waveGeo = new THREE.PlaneGeometry(120, 55, 60, 28);
  var waveBase = [];
  var _wp = waveGeo.attributes.position;
  for (var wi = 0; wi < _wp.count; wi++) {
    waveBase.push({
      x: _wp.getX(wi),
      y: _wp.getY(wi),
      phase: (wi * 13.37) % (Math.PI * 2)
    });
  }
  var waveMat = new THREE.MeshStandardMaterial({
    color: 0x3a7ea5, roughness: 0.45, metalness: 0.15,
    transparent: true, opacity: 0.55,
    emissive: 0x1a3858, emissiveIntensity: 0.08
  });
  var waveSurface = new THREE.Mesh(waveGeo, waveMat);
  waveSurface.rotation.x = -Math.PI / 2;
  waveSurface.position.set(0, -0.1, -42);
  scene.add(waveSurface);

  // ============================================================
  // DISTANT SAILS — trireme silhouettes on horizon
  // ============================================================
  var sailTex = makeCanvasTexture(128, 96, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.fillStyle = 'rgba(32,24,18,0.92)';
    cx.beginPath();
    cx.moveTo(w * 0.12, h * 0.72);
    cx.lineTo(w * 0.88, h * 0.72);
    cx.lineTo(w * 0.80, h * 0.86);
    cx.lineTo(w * 0.20, h * 0.86);
    cx.closePath();
    cx.fill();
    cx.strokeStyle = 'rgba(48,36,24,0.9)';
    cx.lineWidth = 2;
    cx.beginPath();
    cx.moveTo(w * 0.5, h * 0.72);
    cx.lineTo(w * 0.5, h * 0.14);
    cx.stroke();
    cx.beginPath();
    cx.moveTo(w * 0.22, h * 0.22);
    cx.lineTo(w * 0.78, h * 0.22);
    cx.stroke();
    var sailGrad = cx.createLinearGradient(0, h * 0.22, 0, h * 0.72);
    sailGrad.addColorStop(0, 'rgba(210,175,120,0.85)');
    sailGrad.addColorStop(1, 'rgba(160,120,80,0.80)');
    cx.fillStyle = sailGrad;
    cx.beginPath();
    cx.moveTo(w * 0.22, h * 0.22);
    cx.lineTo(w * 0.78, h * 0.22);
    cx.lineTo(w * 0.72, h * 0.70);
    cx.lineTo(w * 0.28, h * 0.70);
    cx.closePath();
    cx.fill();
  });
  var sailDefs = [
    { x: -24, z: -68, s: 2.2 },
    { x:  20, z: -78, s: 1.7 },
    { x:  38, z: -62, s: 1.4 }
  ];
  var sailSprites = [];
  for (var si = 0; si < sailDefs.length; si++) {
    var sd = sailDefs[si];
    var slMat = new THREE.SpriteMaterial({
      map: sailTex, transparent: true, opacity: 0.82,
      depthWrite: false
    });
    var slSprite = new THREE.Sprite(slMat);
    slSprite.scale.set(sd.s, sd.s * 0.75, 1);
    var baseY = -0.15 + sd.s * 0.35;
    slSprite.position.set(sd.x, baseY, sd.z);
    sailSprites.push({
      sprite: slSprite,
      baseX: sd.x,
      baseY: baseY,
      driftSpeed: 0.04 + Math.random() * 0.03,
      bobPhase: Math.random() * Math.PI * 2
    });
    scene.add(slSprite);
  }

  // ============================================================
  // SEABIRDS — gliding silhouettes in the sky
  // ============================================================
  var birdTex = makeCanvasTexture(64, 32, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.strokeStyle = 'rgba(28,20,14,0.88)';
    cx.lineWidth = 2.5;
    cx.lineCap = 'round';
    cx.beginPath();
    cx.moveTo(w * 0.08, h * 0.72);
    cx.quadraticCurveTo(w * 0.30, h * 0.22, w * 0.50, h * 0.56);
    cx.quadraticCurveTo(w * 0.70, h * 0.22, w * 0.92, h * 0.72);
    cx.stroke();
  });
  var birds = [];
  for (var bi = 0; bi < 12; bi++) {
    var bdMat = new THREE.SpriteMaterial({
      map: birdTex, transparent: true, opacity: 0.7,
      depthWrite: false
    });
    var bdSprite = new THREE.Sprite(bdMat);
    var bdSize = 0.45 + Math.random() * 0.5;
    bdSprite.scale.set(bdSize, bdSize * 0.5, 1);
    var bdY = 3.5 + Math.random() * 4.5;
    var bdZ = -28 - Math.random() * 40;
    bdSprite.position.set(-30 + Math.random() * 60, bdY, bdZ);
    birds.push({
      sprite: bdSprite,
      baseY: bdY,
      baseZ: bdZ,
      speed: 0.25 + Math.random() * 0.4,
      dir: Math.random() > 0.5 ? 1 : -1,
      bobPhase: Math.random() * Math.PI * 2,
      bobSpeed: 0.6 + Math.random() * 0.7,
      zPhase: Math.random() * Math.PI * 2
    });
    scene.add(bdSprite);
  }

  // ============================================================
  // FOAM — on the surf zone, clearly on top of the water
  // ============================================================
  // Foam spray texture
  var foamSprayTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    for (var fb = 0; fb < 80; fb++) {
      var fx = w * 0.15 + Math.random() * w * 0.7;
      var fy = h * 0.15 + Math.random() * h * 0.7;
      var fr = 2 + Math.random() * 8;
      var bright = 200 + Math.floor(Math.random() * 55);
      cx.fillStyle = 'rgba(' + bright + ',' + (bright - 5) + ',' + (bright - 20) + ',' + (0.3 + Math.random() * 0.5) + ')';
      cx.beginPath();
      cx.arc(fx, fy, fr, 0, Math.PI * 2);
      cx.fill();
    }
    var fade = cx.createRadialGradient(w/2, h/2, w * 0.2, w/2, h/2, w * 0.5);
    fade.addColorStop(0, 'rgba(0,0,0,0)');
    fade.addColorStop(1, 'rgba(0,0,0,1)');
    cx.globalCompositeOperation = 'destination-out';
    cx.fillStyle = fade;
    cx.fillRect(0, 0, w, h);
    cx.globalCompositeOperation = 'source-over';
  });

  // FOAM LINES — angled to follow the coastline
  // The coast curves back on the left toward the hill/cliffs
  // Centre-right section runs roughly east-west
  // Left section angles back (more negative z) toward the cliffs

  var foamMat = new THREE.MeshStandardMaterial({
    color: 0xf0e8d0, roughness: 0.4, transparent: true, opacity: 0.6,
    emissive: 0xe8e0c8, emissiveIntensity: 0.08
  });
  // Main foam — centre-right segment
  var foam = new THREE.Mesh(new THREE.PlaneGeometry(25, 2.5), foamMat);
  foam.rotation.x = -Math.PI / 2;
  foam.position.set(5, -0.04, -9);
  scene.add(foam);
  // Main foam — left segment, angled back toward the hill
  var foamL = new THREE.Mesh(new THREE.PlaneGeometry(14, 2.5), foamMat.clone());
  foamL.rotation.x = -Math.PI / 2;
  foamL.rotation.z = 0.45;  // angled to follow coastline curving back
  foamL.position.set(-6, -0.04, -10.5);
  scene.add(foamL);

  // Secondary foam — wash further up the beach
  var foam2Mat = new THREE.MeshStandardMaterial({
    color: 0xe8e0c8, roughness: 0.5, transparent: true, opacity: 0.35
  });
  // Centre-right
  var foam2 = new THREE.Mesh(new THREE.PlaneGeometry(25, 1.5), foam2Mat);
  foam2.rotation.x = -Math.PI / 2;
  foam2.position.set(5, -0.02, -7.5);
  scene.add(foam2);
  // Left angled
  var foam2L = new THREE.Mesh(new THREE.PlaneGeometry(12, 1.5), foam2Mat.clone());
  foam2L.rotation.x = -Math.PI / 2;
  foam2L.rotation.z = 0.45;
  foam2L.position.set(-5, -0.02, -9);
  scene.add(foam2L);

  // Scattered foam patches — concentrated on the left half of the coastline
  // where the rocky headland breaks the surf. Right side stays mostly open
  // water with just light lapping foam, so the bay reads as calm.
  var foamPatches = [];
  for (var fp = 0; fp < 18; fp++) {
    var fpMat = new THREE.SpriteMaterial({
      map: foamSprayTex, transparent: true,
      opacity: 0.18 + Math.random() * 0.18,
      depthWrite: true,
      alphaTest: 0.05
    });
    var fpSprite = new THREE.Sprite(fpMat);
    var fpSize = 1.5 + Math.random() * 2.5;
    fpSprite.scale.set(fpSize, fpSize * 0.22, 1);
    // Bias forward — keep patches close to where the actual water lapping
    // is happening, in front of the hill (not buried inside it)
    var fpX = -10 + Math.random() * (fp < 14 ? 18 : 22);
    var coastZ = -8 - Math.max(0, (-fpX - 2)) * 0.3;
    var fpZ = coastZ - Math.random() * 2;
    fpSprite.position.set(fpX, -0.06, fpZ);
    scene.add(fpSprite);
    foamPatches.push({
      sprite: fpSprite,
      baseX: fpX,
      baseZ: fpZ,
      phase: Math.random() * Math.PI * 2,
      speed: 0.3 + Math.random() * 0.5,
      baseOpacity: fpMat.opacity
    });
  }

  // Lapping foam — centre-right segment
  var lappingFoamMat = new THREE.MeshStandardMaterial({
    color: 0xf8f0e0, roughness: 0.3, transparent: true, opacity: 0.55,
    emissive: 0xf0e8d0, emissiveIntensity: 0.1
  });
  var lappingFoam = new THREE.Mesh(new THREE.PlaneGeometry(22, 0.8), lappingFoamMat);
  lappingFoam.rotation.x = -Math.PI / 2;
  lappingFoam.position.set(5, -0.03, -8.5);
  scene.add(lappingFoam);
  // Lapping foam — left angled segment
  var lappingFoamL = new THREE.Mesh(new THREE.PlaneGeometry(12, 0.8), lappingFoamMat.clone());
  lappingFoamL.rotation.x = -Math.PI / 2;
  lappingFoamL.rotation.z = 0.45;
  lappingFoamL.position.set(-5, -0.03, -10);
  scene.add(lappingFoamL);

  // Third foam line — further out
  var foam3Mat = new THREE.MeshStandardMaterial({ color: 0xe0d8c0, roughness: 0.5, transparent: true, opacity: 0.25 });
  var foam3 = new THREE.Mesh(new THREE.PlaneGeometry(22, 0.8), foam3Mat);
  foam3.rotation.x = -Math.PI / 2;
  foam3.position.set(5, -0.09, -12);
  scene.add(foam3);
  var foam3L = new THREE.Mesh(new THREE.PlaneGeometry(10, 0.8), foam3Mat.clone());
  foam3L.rotation.x = -Math.PI / 2;
  foam3L.rotation.z = 0.45;
  foam3L.position.set(-5, -0.09, -13);
  scene.add(foam3L);

  // Golden reflection path on sea — single sun reflection streak
  var reflectionMat = new THREE.MeshStandardMaterial({
    color: 0xe8b040, roughness: 0.2, metalness: 0.3,
    transparent: true, opacity: 0.18
  });
  var reflection = new THREE.Mesh(new THREE.PlaneGeometry(5, 40), reflectionMat);
  reflection.rotation.x = -Math.PI / 2;
  reflection.position.set(-3, -0.15, -35);
  scene.add(reflection);

  // ============================================================
  // COLUMN BUILDER — creates detailed ruin columns
  // ============================================================
  function buildColumn(x, z, totalHeight, broken, lean) {
    var g = new THREE.Group();
    // Base plinth — square with moulding
    var bw = 1.1;
    var base1 = new THREE.Mesh(new THREE.BoxGeometry(bw, 0.3, bw), warmStone);
    base1.position.set(0, 0.15, 0);
    g.add(base1);
    var base2 = new THREE.Mesh(new THREE.BoxGeometry(bw * 0.9, 0.15, bw * 0.9), paleStone);
    base2.position.set(0, 0.38, 0);
    g.add(base2);
    // Torus moulding at base
    var torus = new THREE.Mesh(new THREE.CylinderGeometry(0.48, 0.52, 0.12, 16), paleStone);
    torus.position.set(0, 0.52, 0);
    g.add(torus);

    // Drum segments — each slightly different diameter
    var drumY = 0.58;
    var drumCount = Math.max(2, Math.floor(totalHeight / 1.2));
    var drumH = (totalHeight - 0.58) / drumCount;
    for (var d = 0; d < drumCount; d++) {
      var topR = 0.36 - d * 0.008;
      var botR = 0.38 - d * 0.008;
      if (broken && d === drumCount - 1) {
        // Broken top — shorter, ragged
        drumH = drumH * (0.3 + Math.random() * 0.5);
      }
      var drum = new THREE.Mesh(
        new THREE.CylinderGeometry(topR, botR, drumH, 16),
        columnMat
      );
      drum.position.set(0, drumY + drumH / 2, 0);
      g.add(drum);
      // Joint disc between drums
      if (d < drumCount - 1) {
        var joint = new THREE.Mesh(
          new THREE.CylinderGeometry(botR + 0.02, botR + 0.02, 0.04, 16),
          darkStone
        );
        joint.position.set(0, drumY + drumH, 0);
        g.add(joint);
      }
      drumY += drumH;
    }

    // Capital — if not broken
    if (!broken) {
      var capBase = new THREE.Mesh(
        new THREE.CylinderGeometry(0.5, 0.34, 0.3, 16),
        paleStone
      );
      capBase.position.set(0, drumY + 0.15, 0);
      g.add(capBase);
      var abacus = new THREE.Mesh(
        new THREE.BoxGeometry(1.05, 0.15, 1.05),
        paleStone
      );
      abacus.position.set(0, drumY + 0.38, 0);
      g.add(abacus);
    } else {
      // Jagged break — 2–3 small irregular stone chunks on top of the stub
      var chunkCount = 2 + Math.floor(Math.random() * 2);
      for (var ck = 0; ck < chunkCount; ck++) {
        var cs = 0.12 + Math.random() * 0.2;
        var chunk = new THREE.Mesh(
          new THREE.DodecahedronGeometry(cs * 0.5, 0),
          Math.random() > 0.5 ? columnMat : darkStone
        );
        var cAng = Math.random() * Math.PI * 2;
        var cR = 0.08 + Math.random() * 0.2;
        chunk.position.set(Math.cos(cAng) * cR, drumY + cs * 0.35, Math.sin(cAng) * cR);
        chunk.scale.set(1.0 + Math.random() * 0.3, 0.6 + Math.random() * 0.3, 0.9 + Math.random() * 0.3);
        chunk.rotation.set(
          (Math.random() - 0.5) * 0.8,
          Math.random() * Math.PI,
          (Math.random() - 0.5) * 0.9
        );
        g.add(chunk);
      }
      if (Math.random() > 0.5) {
        var shard = new THREE.Mesh(
          new THREE.BoxGeometry(0.14, 0.22, 0.14),
          columnMat
        );
        shard.position.set((Math.random() - 0.5) * 0.25, drumY + 0.11, (Math.random() - 0.5) * 0.25);
        shard.rotation.z = (Math.random() - 0.5) * 0.35;
        shard.rotation.x = (Math.random() - 0.5) * 0.25;
        g.add(shard);
      }
    }

    if (lean) g.rotation.z = lean;
    g.position.set(x, 0, z);
    scene.add(g);
    return g;
  }

  // ============================================================
  // RUINS — LEFT COLONNADE (row of columns along a platform)
  // ============================================================
  var leftPlatform = new THREE.Mesh(new THREE.BoxGeometry(12, 0.5, 3.5), warmStone);
  leftPlatform.position.set(-6, 0.25, -2);
  scene.add(leftPlatform);
  var leftStep = new THREE.Mesh(new THREE.BoxGeometry(12.5, 0.25, 4), darkStone);
  leftStep.position.set(-6, 0.05, -2);
  scene.add(leftStep);
  // Top cornice — thin dark strip running along the front lip of the platform
  var leftCornice = new THREE.Mesh(new THREE.BoxGeometry(12.1, 0.06, 0.15), darkStone);
  leftCornice.position.set(-6, 0.48, -0.2);
  scene.add(leftCornice);
  var leftBaseMould = new THREE.Mesh(new THREE.BoxGeometry(12.05, 0.04, 0.1), paleStone);
  leftBaseMould.position.set(-6, 0.04, -0.18);
  scene.add(leftBaseMould);
  // Steps at front
  var stepMat = new THREE.MeshStandardMaterial({ map: stoneTex, roughness: 0.85 });
  for (var si = 0; si < 2; si++) {
    var step = new THREE.Mesh(new THREE.BoxGeometry(12, 0.15, 0.6), stepMat);
    step.position.set(-6, 0.08 + si * 0.15, -0.2 + si * 0.6);
    scene.add(step);
  }

  // Left colonnade — 5 columns in a row, evenly spaced along z=-3
  // Some intact, some broken — this is a ruin after all
  buildColumn(-10, -3, 5.8, false, 0);
  buildColumn(-8, -3, 5.8, false, 0);
  buildColumn(-6, -3, 5.8, false, 0.01);
  buildColumn(-4, -3, 4.0, true, 0);    // broken
  buildColumn(-2, -3, 2.5, true, -0.03); // very broken

  // Entablature connecting the standing columns — carved stone lintel
  var leftLintel = new THREE.Mesh(new THREE.BoxGeometry(7.0, 0.4, 0.7), lintelMat);
  leftLintel.position.set(-8, 6.35, -3);
  scene.add(leftLintel);
  // Moulding strip on top
  var leftMould = new THREE.Mesh(new THREE.BoxGeometry(7.2, 0.12, 0.8), darkStone);
  leftMould.position.set(-8, 6.6, -3);
  scene.add(leftMould);

  // Fallen column drums on the ground (from the broken ones)
  var fd1 = new THREE.Mesh(new THREE.CylinderGeometry(0.36, 0.36, 1.5, 16), columnMat);
  fd1.rotation.z = Math.PI / 2; fd1.position.set(-3, 0.36, -1.5);
  scene.add(fd1);
  var fd2 = new THREE.Mesh(new THREE.CylinderGeometry(0.32, 0.32, 1.2, 16), columnMat);
  fd2.rotation.z = Math.PI / 2; fd2.rotation.y = 0.4; fd2.position.set(-1.5, 0.32, -2);
  scene.add(fd2);
  // Fallen capital
  var fc1 = new THREE.Mesh(new THREE.CylinderGeometry(0.48, 0.34, 0.3, 16), paleStone);
  fc1.rotation.x = 0.3; fc1.rotation.z = 0.8; fc1.position.set(-3.5, 0.22, -1);
  scene.add(fc1);

  // Low wall behind columns
  var wall1 = new THREE.Mesh(new THREE.BoxGeometry(10, 1.2, 0.55), warmStone);
  wall1.position.set(-6, 0.85, -4.2);
  scene.add(wall1);
  var wall1top = new THREE.Mesh(new THREE.BoxGeometry(6, 0.5, 0.55), darkStone);
  wall1top.position.set(-7, 1.5, -4.2);
  scene.add(wall1top);

  // ============================================================
  // RUINS — CENTRE (wall with arch doorway) — pulled forward to z=-1.3 so
  // the wall stands clearly IN FRONT of the colonnades (which are at z=-3)
  // rather than intersecting them. Still on the platform (which extends
  // forward to z=-0.25), so the wall remains seated on stone.
  // ============================================================
  var CENTRE_Z = -1.3;
  var centreWallL = new THREE.Mesh(new THREE.BoxGeometry(2.15, 3.5, 0.8), warmStone);
  centreWallL.position.set(-0.675, 1.75, CENTRE_Z);
  scene.add(centreWallL);
  var centreWallR = new THREE.Mesh(new THREE.BoxGeometry(2.15, 3.5, 0.8), warmStone);
  centreWallR.position.set(2.675, 1.75, CENTRE_Z);
  scene.add(centreWallR);
  // Broken top — individual blocks
  var cTop1 = new THREE.Mesh(new THREE.BoxGeometry(1.4, 0.6, 0.8), warmStone);
  cTop1.position.set(-0.5, 3.8, CENTRE_Z);
  scene.add(cTop1);
  var cTop2 = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.45, 0.8), darkStone);
  cTop2.position.set(2.3, 3.72, CENTRE_Z);
  scene.add(cTop2);

  // Arch — pilasters + lintel
  var archPilL = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.6, 0.85), warmStone);
  archPilL.position.set(0, 0.8, CENTRE_Z);
  scene.add(archPilL);
  var archPilLbreak = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.3, 0.6), darkStone);
  archPilLbreak.position.set(-0.1, 1.72, CENTRE_Z);
  archPilLbreak.rotation.z = -0.08;
  scene.add(archPilLbreak);
  // Fallen chunk on the ground — pulled slightly forward too
  var archPilLfallen = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.45, 0.7), warmStone);
  archPilLfallen.position.set(-0.6, 0.22, CENTRE_Z + 0.6);
  archPilLfallen.rotation.y = -0.4;
  archPilLfallen.rotation.z = 0.15;
  scene.add(archPilLfallen);
  var archPilR = new THREE.Mesh(new THREE.BoxGeometry(0.8, 2.8, 0.85), warmStone);
  archPilR.position.set(2, 1.4, CENTRE_Z);
  scene.add(archPilR);
  // Voussoir arch
  var archCX = 1, archCY = 2.8, archR = 1.0;
  var vThick = 0.38, vWide = 0.44, vDepth = 0.9, N_V = 9;
  for (var vi = 0; vi < N_V; vi++) {
    if (vi >= N_V - 2) continue;
    var theta = Math.PI * (vi + 0.5) / N_V;
    var rMid = archR + vThick / 2;
    var vx = archCX + Math.cos(theta) * rMid;
    var vy = archCY + Math.sin(theta) * rMid;
    var isKey = (vi === Math.floor(N_V / 2));
    var vMat = isKey ? paleStone : (vi % 2 === 0 ? warmStone : paleStone);
    var voussoir = new THREE.Mesh(
      new THREE.BoxGeometry(vWide, vThick * (isKey ? 1.15 : 1.0), vDepth),
      vMat
    );
    voussoir.position.set(vx, vy, CENTRE_Z);
    voussoir.rotation.z = theta - Math.PI / 2;
    scene.add(voussoir);
  }
  // Thin moulding ring around the outer edge of the arch — follows the curve
  for (var mi = 0; mi < N_V - 2; mi++) {
    var mTheta = Math.PI * (mi + 0.5) / N_V;
    var mR = archR + vThick + 0.05;
    var mMould = new THREE.Mesh(
      new THREE.BoxGeometry(vWide, 0.08, vDepth + 0.05),
      darkStone
    );
    mMould.position.set(archCX + Math.cos(mTheta) * mR, archCY + Math.sin(mTheta) * mR, CENTRE_Z);
    mMould.rotation.z = mTheta - Math.PI / 2;
    scene.add(mMould);
  }
  // Three fallen voussoirs near the broken left pilaster — storytelling
  var fv1 = new THREE.Mesh(new THREE.BoxGeometry(vWide, vThick, vDepth), warmStone);
  fv1.position.set(-0.9, 0.22, CENTRE_Z + 0.7);
  fv1.rotation.set(0.12, 0.4, 0.28);
  scene.add(fv1);
  var fv2 = new THREE.Mesh(new THREE.BoxGeometry(vWide, vThick, vDepth), paleStone);
  fv2.position.set(-1.45, 0.21, CENTRE_Z + 1.0);
  fv2.rotation.set(-0.08, -0.55, -0.22);
  scene.add(fv2);
  var fv3 = new THREE.Mesh(new THREE.BoxGeometry(vWide * 0.85, vThick * 0.9, vDepth * 0.9), warmStone);
  fv3.position.set(-0.5, 0.18, CENTRE_Z + 1.1);
  fv3.rotation.set(0.2, 0.15, -0.35);
  scene.add(fv3);

  // ============================================================
  // RUINS — RIGHT COLONNADE (matching row on the other side)
  // ============================================================
  var rightPlatform = new THREE.Mesh(new THREE.BoxGeometry(10, 0.5, 3.5), warmStone);
  rightPlatform.position.set(7, 0.25, -2);
  scene.add(rightPlatform);
  var rightStep = new THREE.Mesh(new THREE.BoxGeometry(10.5, 0.25, 4), darkStone);
  rightStep.position.set(7, 0.05, -2);
  scene.add(rightStep);
  // Top cornice + base moulding — matches the left platform
  var rightCornice = new THREE.Mesh(new THREE.BoxGeometry(10.1, 0.06, 0.15), darkStone);
  rightCornice.position.set(7, 0.48, -0.2);
  scene.add(rightCornice);
  var rightBaseMould = new THREE.Mesh(new THREE.BoxGeometry(10.05, 0.04, 0.1), paleStone);
  rightBaseMould.position.set(7, 0.04, -0.18);
  scene.add(rightBaseMould);

  // Right colonnade — 4 columns in a row at z=-3, evenly spaced
  buildColumn(4, -3, 3.0, true, 0.04);  // broken short — visible next to centre arch
  buildColumn(6, -3, 4.5, false, 0);    // lowered
  buildColumn(8, -3, 5.2, false, 0.02);
  buildColumn(10, -3, 3.8, true, 0);  // broken

  // Entablature connecting right columns — rests on top of column capitals
  var rightLintel = new THREE.Mesh(new THREE.BoxGeometry(3.5, 0.35, 0.7), lintelMat);
  rightLintel.position.set(7, 5.85, -3);
  scene.add(rightLintel);
  // Moulding strip just below lintel
  var rightMould = new THREE.Mesh(new THREE.BoxGeometry(3.7, 0.1, 0.8), darkStone);
  rightMould.position.set(7, 5.62, -3);
  scene.add(rightMould);

  // CARVED XCIII INSCRIPTION — "93" in Roman numerals, chiseled into the right
  // end of the right-hand lintel. Someone scratched it in centuries ago and
  // the elements have softened the strokes. (Connects to Inis O'Flatterly's
  // missing page 93.)
  var inscriptionTex = makeCanvasTexture(256, 96, function(cx, w, h) {
    // Base — match the lintel stone colour so the decal blends seamlessly
    cx.fillStyle = '#d6c082';
    cx.fillRect(0, 0, w, h);
    // Surface tone variation
    for (var pp = 0; pp < 60; pp++) {
      var t = 170 + Math.floor(Math.random() * 60);
      cx.fillStyle = 'rgba(' + t + ',' + (t - 12) + ',' + (t - 35) + ',' + (0.08 + Math.random() * 0.14) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        3 + Math.random() * 9, 2 + Math.random() * 6, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Carve the strokes — each stroke is a deep shadow with a soft inner
    // gradient. Drawn as a translucent dark stroke first (deep recess),
    // then a thinner middle (catches light at the bottom edge of the chisel).
    cx.save();
    cx.translate(w * 0.5, h * 0.55);
    cx.font = 'bold 60px Georgia, "Times New Roman", serif';
    cx.textAlign = 'center';
    cx.textBaseline = 'middle';
    // Deep shadow — darker recess inside each letter
    cx.fillStyle = 'rgba(35, 22, 8, 0.78)';
    cx.fillText('XCIII', 0, 0);
    // Subtle highlight along the upper-left edge of each carved stroke
    cx.fillStyle = 'rgba(240, 210, 150, 0.18)';
    cx.fillText('XCIII', -1, -1);
    cx.restore();
    // Re-erode the inscription — make some chips/gaps so the carving feels
    // weathered and ancient, not freshly cut
    for (var er = 0; er < 12; er++) {
      cx.fillStyle = 'rgba(214, 192, 130, 0.85)';
      cx.beginPath();
      cx.ellipse(w * 0.2 + Math.random() * w * 0.6, h * 0.3 + Math.random() * h * 0.5,
        2 + Math.random() * 4, 1.5 + Math.random() * 3, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Light vertical staining over the inscription (rain from above)
    for (var rs2 = 0; rs2 < 3; rs2++) {
      var rsx2 = w * 0.3 + Math.random() * w * 0.4;
      var rsg2 = cx.createLinearGradient(rsx2, 0, rsx2, h);
      rsg2.addColorStop(0, 'rgba(40, 30, 15, 0.25)');
      rsg2.addColorStop(1, 'rgba(60, 45, 22, 0.08)');
      cx.fillStyle = rsg2;
      cx.fillRect(rsx2 - 4, 0, 8, h);
    }
  });
  var inscriptionMat = new THREE.MeshStandardMaterial({
    map: inscriptionTex, roughness: 0.85, transparent: true
  });
  // Decal plane attached to the FRONT of the right lintel, biased to the
  // right end. Slightly forward (z) so it sits proud of the lintel face.
  var inscriptionPlane = new THREE.Mesh(
    new THREE.PlaneGeometry(0.95, 0.3),
    inscriptionMat
  );
  // rightLintel front face is at z = -3 + 0.7/2 = -2.65; put the decal at -2.645
  inscriptionPlane.position.set(8.05, 5.85, -2.645);
  scene.add(inscriptionPlane);

  // Fallen drum from the broken right column
  var fd3 = new THREE.Mesh(new THREE.CylinderGeometry(0.34, 0.34, 1.3, 16), columnMat);
  fd3.rotation.z = Math.PI / 2; fd3.rotation.y = -0.3; fd3.position.set(11, 0.34, -1.5);
  scene.add(fd3);

  // ============================================================
  // JAGGED WALL TOPS — scatter of broken blocks to break the silhouettes
  // ============================================================
  function scatterBrokenTop(startX, endX, topY, zPos, depth, count, seed) {
    for (var bi = 0; bi < count; bi++) {
      var t = (bi + 0.5) / count;
      var r1 = ((seed * 137 + bi * 53) % 97) / 97;
      var r2 = ((seed * 211 + bi * 79) % 89) / 89;
      var r3 = ((seed * 313 + bi * 41) % 83) / 83;
      var r4 = ((seed * 419 + bi * 29) % 71) / 71;
      var bw = 0.25 + r1 * 0.45;
      var bh = 0.12 + r2 * 0.42;
      var bd = depth * (0.7 + r3 * 0.35);
      var bx = startX + t * (endX - startX) + (r4 - 0.5) * 0.25;
      var block = new THREE.Mesh(
        new THREE.BoxGeometry(bw, bh, bd),
        r1 > 0.5 ? warmStone : paleStone
      );
      block.position.set(bx, topY + bh / 2, zPos + (r3 - 0.5) * 0.08);
      block.rotation.z = (r2 - 0.5) * 0.35;
      block.rotation.y = (r4 - 0.5) * 0.2;
      scene.add(block);
      if (r2 > 0.6) {
        var chip = new THREE.Mesh(
          new THREE.BoxGeometry(bw * 0.4, bh * 0.5, bd * 0.6),
          darkStone
        );
        chip.position.set(bx + (r3 - 0.5) * bw * 0.4, topY + bh * 0.25, zPos);
        chip.rotation.z = (r1 - 0.5) * 0.6;
        scene.add(chip);
      }
    }
  }
  scatterBrokenTop(-1.7, -0.5, 3.5, CENTRE_Z, 0.8, 5, 7);
  scatterBrokenTop(2.6, 3.7, 3.5, CENTRE_Z, 0.8, 5, 13);
  scatterBrokenTop(-10.8, -1.2, 1.45, -4.2, 0.55, 11, 23);
  scatterBrokenTop(-9.8, -4.2, 1.75, -4.2, 0.55, 7, 29);

  // ============================================================
  // GROUND CLUTTER — Cecil Court style detail
  // ============================================================
  // Scattered rubble — organic dodecahedra, each one uniquely scaled and rotated
  for (var rb = 0; rb < 25; rb++) {
    var rbs = 0.15 + Math.random() * 0.5;
    var rbMesh = new THREE.Mesh(
      new THREE.DodecahedronGeometry(rbs * 0.5, 0),
      Math.random() > 0.3 ? rubbleMat : darkRubble
    );
    rbMesh.position.set(-12 + Math.random() * 24, rbs * 0.15, -6 + Math.random() * 14);
    rbMesh.scale.set(1.0 + Math.random() * 0.5, 0.55 + Math.random() * 0.5, 0.85 + Math.random() * 0.4);
    rbMesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, (Math.random() - 0.5) * 0.6);
    scene.add(rbMesh);
  }

  // Broken terracotta pot fragments
  for (var pot = 0; pot < 6; pot++) {
    var potGeo = new THREE.CylinderGeometry(0.15 + Math.random() * 0.2, 0.2 + Math.random() * 0.15,
      0.25 + Math.random() * 0.3, 8, 1, true, 0, Math.PI * (0.8 + Math.random() * 0.8));
    var potMesh = new THREE.Mesh(potGeo, terracotta);
    potMesh.position.set(-10 + Math.random() * 20, 0.1 + Math.random() * 0.1, -5 + Math.random() * 12);
    potMesh.rotation.z = (Math.random() - 0.5) * 0.5;
    potMesh.rotation.y = Math.random() * Math.PI * 2;
    scene.add(potMesh);
  }

  // Scattered flat stone fragments (like broken tiles)
  for (var frag = 0; frag < 15; frag++) {
    var fw = 0.1 + Math.random() * 0.3;
    var fragMesh = new THREE.Mesh(
      new THREE.BoxGeometry(fw, 0.04, fw * (0.5 + Math.random())),
      Math.random() > 0.5 ? terracotta : rubbleMat
    );
    fragMesh.rotation.x = -Math.PI / 2 + (Math.random() - 0.5) * 0.2;
    fragMesh.position.set(-10 + Math.random() * 20, 0.02, -5 + Math.random() * 12);
    fragMesh.rotation.z = Math.random() * Math.PI;
    scene.add(fragMesh);
  }

  // Dry scrub patches on the ground — sun-bleached ground cover, not moss
  for (var mp = 0; mp < 8; mp++) {
    var mossSize = 0.4 + Math.random() * 0.8;
    var mossPatch = new THREE.Mesh(
      new THREE.PlaneGeometry(mossSize, mossSize * (0.6 + Math.random() * 0.5)),
      new THREE.MeshStandardMaterial({ color: 0x6a5832, roughness: 0.9, transparent: true, opacity: 0.35 })
    );
    mossPatch.rotation.x = -Math.PI / 2;
    mossPatch.position.set(-8 + Math.random() * 16, 0.01, -4 + Math.random() * 10);
    mossPatch.rotation.z = Math.random() * Math.PI;
    scene.add(mossPatch);
  }

  // ============================================================
  // TREES & VEGETATION — canvas-textured foliage
  // ============================================================

  // LEAF CLUSTER TEXTURES — painted foliage with transparency
  function makeLeafClusterTex(baseR, baseG, baseB) {
    return makeCanvasTexture(128, 128, function(cx, w, h) {
      cx.clearRect(0, 0, w, h);
      // Paint many small overlapping leaf shapes
      for (var i = 0; i < 60; i++) {
        var lx = w * 0.2 + Math.random() * w * 0.6;
        var ly = h * 0.2 + Math.random() * h * 0.6;
        var lr = 8 + Math.random() * 18;
        // Vary the green — some darker, some lighter, some yellowed
        var rShift = Math.floor((Math.random() - 0.5) * 30);
        var gShift = Math.floor((Math.random() - 0.5) * 25);
        var bShift = Math.floor((Math.random() - 0.5) * 15);
        var r = Math.max(0, Math.min(255, baseR + rShift));
        var g = Math.max(0, Math.min(255, baseG + gShift));
        var b = Math.max(0, Math.min(255, baseB + bShift));
        cx.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',' + (0.5 + Math.random() * 0.4) + ')';
        // Leaf shape — small ellipse rotated
        cx.save();
        cx.translate(lx, ly);
        cx.rotate(Math.random() * Math.PI);
        cx.beginPath();
        cx.ellipse(0, 0, lr, lr * 0.5, 0, 0, Math.PI * 2);
        cx.fill();
        cx.restore();
      }
      // Soft edge fade — circular falloff so cluster blends naturally
      var fade = cx.createRadialGradient(w/2, h/2, w * 0.2, w/2, h/2, w * 0.5);
      fade.addColorStop(0, 'rgba(0,0,0,0)');
      fade.addColorStop(1, 'rgba(0,0,0,1)');
      cx.globalCompositeOperation = 'destination-out';
      cx.fillStyle = fade;
      cx.fillRect(0, 0, w, h);
      cx.globalCompositeOperation = 'source-over';
      // Highlights — sun catching individual leaves. Pushed warm (more red,
      // less blue) so they read as golden-hour glints, not silver.
      for (var hi = 0; hi < 12; hi++) {
        var hx = w * 0.25 + Math.random() * w * 0.5;
        var hy = h * 0.25 + Math.random() * h * 0.5;
        cx.fillStyle = 'rgba(' + Math.min(255, baseR + 70) + ',' + Math.min(255, baseG + 40) + ',' + Math.min(255, baseB + 10) + ', 0.28)';
        cx.beginPath();
        cx.arc(hx, hy, 3 + Math.random() * 6, 0, Math.PI * 2);
        cx.fill();
      }
    });
  }

  // North-African coast at golden hour. Three shadow tiers:
  //  - DARK: deep sage in shadow
  //  - MID:  slightly warmer mid-tone
  //  - PALE: leaves catching the setting sun — properly GOLD, not silver-mint
  var darkLeafTex = makeLeafClusterTex(62, 62, 32);
  var midLeafTex  = makeLeafClusterTex(108, 92, 45);
  var paleLeafTex = makeLeafClusterTex(195, 150, 62);
  var autumnLeafTex = makeLeafClusterTex(175, 110, 45);
  // Dedicated bush textures — denser than tree-cluster textures (less radial
  // fade, harder edges) so scrub reads as a solid mass instead of a soft puff
  function makeBushClusterTex(baseR, baseG, baseB) {
    return makeCanvasTexture(128, 128, function(cx, w, h) {
      cx.clearRect(0, 0, w, h);
      // Many small overlapping leaf shapes — denser packing than tree clusters
      for (var i = 0; i < 90; i++) {
        var lx = w * 0.18 + Math.random() * w * 0.64;
        var ly = h * 0.18 + Math.random() * h * 0.64;
        var lr = 7 + Math.random() * 14;
        var rShift = Math.floor((Math.random() - 0.5) * 26);
        var gShift = Math.floor((Math.random() - 0.5) * 22);
        var bShift = Math.floor((Math.random() - 0.5) * 12);
        var r = Math.max(0, Math.min(255, baseR + rShift));
        var g = Math.max(0, Math.min(255, baseG + gShift));
        var b = Math.max(0, Math.min(255, baseB + bShift));
        cx.fillStyle = 'rgba(' + r + ',' + g + ',' + b + ',' + (0.85 + Math.random() * 0.13) + ')';
        cx.save();
        cx.translate(lx, ly);
        cx.rotate(Math.random() * Math.PI);
        cx.beginPath();
        cx.ellipse(0, 0, lr, lr * 0.5, 0, 0, Math.PI * 2);
        cx.fill();
        cx.restore();
      }
      // Hard-edged radial mask — keeps the bush silhouette sharp instead of fuzzy
      var fade = cx.createRadialGradient(w/2, h/2, w * 0.32, w/2, h/2, w * 0.46);
      fade.addColorStop(0, 'rgba(0,0,0,0)');
      fade.addColorStop(0.85, 'rgba(0,0,0,0.5)');
      fade.addColorStop(1, 'rgba(0,0,0,1)');
      cx.globalCompositeOperation = 'destination-out';
      cx.fillStyle = fade;
      cx.fillRect(0, 0, w, h);
      cx.globalCompositeOperation = 'source-over';
      // Warm sun-catch highlights on top — golden hour
      for (var hi = 0; hi < 14; hi++) {
        var hx = w * 0.25 + Math.random() * w * 0.5;
        var hy = h * 0.22 + Math.random() * h * 0.35; // upper half catches light
        cx.fillStyle = 'rgba(' + Math.min(255, baseR + 80) + ',' + Math.min(255, baseG + 55) + ',' + Math.min(255, baseB + 18) + ',' + (0.18 + Math.random() * 0.18) + ')';
        cx.beginPath();
        cx.arc(hx, hy, 3 + Math.random() * 6, 0, Math.PI * 2);
        cx.fill();
      }
    });
  }
  var bushLeafTex = makeBushClusterTex(55, 55, 28);
  var bushLeafTexB = makeBushClusterTex(82, 75, 36);

  function makeLeafSpriteMat(tex, opacity) {
    return new THREE.SpriteMaterial({
      map: tex, transparent: true, opacity: opacity || 0.85,
      depthWrite: false
    });
  }

  // BARK TEXTURE — rough, knotty Mediterranean bark
  var barkTex = makeCanvasTexture(128, 256, function(cx, w, h) {
    cx.fillStyle = '#4a3420';
    cx.fillRect(0, 0, w, h);
    // Vertical bark furrows
    for (var fx = 0; fx < w; fx += 6 + Math.random() * 4) {
      var shade = 0.05 + Math.random() * 0.15;
      cx.fillStyle = 'rgba(0,0,0,' + shade + ')';
      cx.fillRect(fx, 0, 2 + Math.random() * 3, h);
    }
    // Lighter ridges between furrows
    for (var rx = 0; rx < w; rx += 8 + Math.random() * 6) {
      cx.fillStyle = 'rgba(100,70,40,' + (0.1 + Math.random() * 0.15) + ')';
      cx.fillRect(rx, 0, 1 + Math.random() * 2, h);
    }
    // Knots
    for (var k = 0; k < 3; k++) {
      cx.fillStyle = 'rgba(30,18,8,0.3)';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h, 5 + Math.random() * 8, 4 + Math.random() * 6, 0, 0, Math.PI * 2);
      cx.fill();
    }
    // Lichen patches
    for (var lp = 0; lp < 4; lp++) {
      cx.fillStyle = 'rgba(70,85,45,' + (0.08 + Math.random() * 0.1) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h, 6 + Math.random() * 12, 4 + Math.random() * 8, 0, 0, Math.PI * 2);
      cx.fill();
    }
  });
  var barkMat = new THREE.MeshStandardMaterial({ map: barkTex, roughness: 0.9 });

  // PALM BARK — ringed texture
  var palmBarkTex = makeCanvasTexture(128, 256, function(cx, w, h) {
    cx.fillStyle = '#5a4428';
    cx.fillRect(0, 0, w, h);
    // Horizontal ring scars from old fronds
    for (var ry = 0; ry < h; ry += 12 + Math.random() * 8) {
      cx.fillStyle = 'rgba(30,20,10,' + (0.15 + Math.random() * 0.15) + ')';
      cx.fillRect(0, ry, w, 3 + Math.random() * 3);
      // Lighter line above each scar
      cx.fillStyle = 'rgba(100,75,45,' + (0.1 + Math.random() * 0.1) + ')';
      cx.fillRect(0, ry - 2, w, 2);
    }
    // Fibrous texture
    for (var fb = 0; fb < 30; fb++) {
      cx.strokeStyle = 'rgba(80,55,30,0.08)';
      cx.lineWidth = 1;
      cx.beginPath();
      cx.moveTo(Math.random() * w, Math.random() * h);
      cx.lineTo(Math.random() * w, Math.random() * h);
      cx.stroke();
    }
  });
  var palmBarkMat = new THREE.MeshStandardMaterial({ map: palmBarkTex, roughness: 0.85 });

  // PALM FROND TEXTURE — long feathered leaf shape
  var frondTex = makeCanvasTexture(64, 256, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    // Central spine
    cx.strokeStyle = 'rgba(25,38,12,0.7)';
    cx.lineWidth = 2;
    cx.beginPath();
    cx.moveTo(w/2, h);
    cx.lineTo(w/2, 0);
    cx.stroke();
    // Leaflets radiating from spine
    for (var ly = h * 0.05; ly < h * 0.95; ly += 4) {
      var leafLen = (w/2 - 4) * (1.0 - Math.pow((ly / h - 0.5) * 2, 2));
      if (leafLen < 2) continue;
      var greenVar = Math.floor(Math.random() * 30);
      cx.fillStyle = 'rgba(' + (18 + greenVar) + ',' + (35 + greenVar) + ',' + (10 + Math.floor(greenVar * 0.2)) + ',' + (0.6 + Math.random() * 0.3) + ')';
      // Left leaflet
      cx.beginPath();
      cx.moveTo(w/2, ly);
      cx.lineTo(w/2 - leafLen, ly - 2);
      cx.lineTo(w/2 - leafLen * 0.7, ly + 1);
      cx.closePath();
      cx.fill();
      // Right leaflet
      cx.beginPath();
      cx.moveTo(w/2, ly);
      cx.lineTo(w/2 + leafLen, ly - 2);
      cx.lineTo(w/2 + leafLen * 0.7, ly + 1);
      cx.closePath();
      cx.fill();
    }
  });

  // CEDAR TREE — tall conical shape with layered horizontal branches
  // Cedars of Lebanon / Atlas cedars — iconic Mediterranean silhouette
  function makeCedar(x, z, height, lean) {
    var g = new THREE.Group();
    // Thick trunk
    var trunk = new THREE.Mesh(
      new THREE.CylinderGeometry(0.12, 0.22, height * 0.75, 8),
      barkMat
    );
    trunk.position.set(0, height * 0.375, 0);
    g.add(trunk);
    // Exposed roots at base
    for (var rt = 0; rt < 3; rt++) {
      var rAngle = (rt / 3) * Math.PI * 2 + Math.random() * 0.5;
      var root = new THREE.Mesh(
        new THREE.CylinderGeometry(0.02, 0.06, 0.5, 4),
        barkMat
      );
      root.position.set(Math.cos(rAngle) * 0.18, 0.15, Math.sin(rAngle) * 0.18);
      root.rotation.z = Math.cos(rAngle) * 0.6;
      root.rotation.x = Math.sin(rAngle) * 0.6;
      g.add(root);
    }
    // Layered horizontal branch platforms — cedar's distinctive flat layers.
    // Cedar leaves are characteristically dark — use dark + mid textures only,
    // no pale golden (which would read as fluffy puffs). Fewer sprites per
    // layer so the cedar reads as a clear silhouette, not a fog.
    var texes = [darkLeafTex, darkLeafTex, midLeafTex];
    var layerCount = 4 + Math.floor(Math.random() * 2);
    for (var layer = 0; layer < layerCount; layer++) {
      var layerY = height * 0.38 + (layer / layerCount) * height * 0.58;
      var layerSpread = (1.0 - layer / layerCount * 0.55) * height * 0.55;
      // Branch arm for each layer
      var brAngle = Math.random() * Math.PI * 2;
      var brLen = layerSpread * 0.4;
      var branch = new THREE.Mesh(
        new THREE.CylinderGeometry(0.02, 0.04, brLen, 4),
        barkMat
      );
      branch.position.set(Math.cos(brAngle) * brLen * 0.3, layerY, Math.sin(brAngle) * brLen * 0.3);
      branch.rotation.z = Math.cos(brAngle) * 0.5;
      branch.rotation.x = Math.sin(brAngle) * 0.5;
      g.add(branch);
      // Fewer foliage sprites — denser, more opaque
      var spriteCount = 3 + Math.floor(Math.random() * 2);
      for (var si = 0; si < spriteCount; si++) {
        var tex = texes[Math.floor(Math.random() * texes.length)];
        var lSprite = new THREE.Sprite(makeLeafSpriteMat(tex, 0.9 + Math.random() * 0.08));
        var cSize = layerSpread * (0.55 + Math.random() * 0.45);
        lSprite.scale.set(cSize, cSize * 0.45, 1);
        lSprite.position.set(
          (Math.random() - 0.5) * layerSpread * 0.7,
          layerY + (Math.random() - 0.5) * 0.2,
          (Math.random() - 0.5) * layerSpread * 0.6
        );
        g.add(lSprite);
      }
    }
    // Top crown — pointed
    var topSprite = new THREE.Sprite(makeLeafSpriteMat(darkLeafTex, 0.85));
    topSprite.scale.set(height * 0.2, height * 0.3, 1);
    topSprite.position.set(0, height * 0.9, 0);
    g.add(topSprite);

    if (lean) g.rotation.z = lean;
    g.position.set(x, 0, z);
    scene.add(g);
    return g;
  }

  // OLIVE TREE — gnarled trunk, wide spreading silver-green canopy
  function makeOlive(x, z, height, spread, lean) {
    var g = new THREE.Group();
    // Gnarled thick trunk — olive trunks are twisted and wide
    var trunk = new THREE.Mesh(
      new THREE.CylinderGeometry(0.1, 0.2, height * 0.5, 8),
      barkMat
    );
    trunk.position.set(0, height * 0.25, 0);
    if (lean) trunk.rotation.z = lean;
    g.add(trunk);
    // Main forking branches — olives split into 2-3 thick limbs
    var forkCount = 2 + Math.floor(Math.random() * 2);
    for (var fk = 0; fk < forkCount; fk++) {
      var fkAngle = (fk / forkCount) * Math.PI * 2 + Math.random() * 0.8;
      var fkLen = height * 0.3 + Math.random() * height * 0.15;
      var fork = new THREE.Mesh(
        new THREE.CylinderGeometry(0.03, 0.08, fkLen, 5),
        barkMat
      );
      fork.position.set(
        Math.cos(fkAngle) * 0.15,
        height * 0.4 + Math.random() * height * 0.1,
        Math.sin(fkAngle) * 0.15
      );
      fork.rotation.z = Math.cos(fkAngle) * 0.5;
      fork.rotation.x = Math.sin(fkAngle) * 0.5;
      g.add(fork);
      // Sub-branches
      for (var sb = 0; sb < 2; sb++) {
        var sbAngle = fkAngle + (Math.random() - 0.5) * 1.5;
        var subBranch = new THREE.Mesh(
          new THREE.CylinderGeometry(0.01, 0.025, fkLen * 0.5, 4),
          barkMat
        );
        subBranch.position.set(
          Math.cos(fkAngle) * fkLen * 0.3 + Math.cos(sbAngle) * 0.1,
          height * 0.5 + fkLen * 0.3,
          Math.sin(fkAngle) * fkLen * 0.3 + Math.sin(sbAngle) * 0.1
        );
        subBranch.rotation.z = Math.cos(sbAngle) * 0.7;
        subBranch.rotation.x = Math.sin(sbAngle) * 0.7;
        g.add(subBranch);
      }
    }
    // Silver-olive foliage — base silver-sage with golden highlights catching
    // the sun. Fewer clusters than before, more opaque, less puffy stacking.
    var oliveTex = makeLeafClusterTex(120, 112, 70);
    var texes = [oliveTex, oliveTex, midLeafTex, autumnLeafTex];
    var clusterCount = 7 + Math.floor(Math.random() * 4);
    for (var ci = 0; ci < clusterCount; ci++) {
      var tex = texes[Math.floor(Math.random() * texes.length)];
      var lSprite = new THREE.Sprite(makeLeafSpriteMat(tex, 0.88 + Math.random() * 0.10));
      var cSize = spread * (0.7 + Math.random() * 0.6);
      lSprite.scale.set(cSize, cSize * (0.6 + Math.random() * 0.35), 1);
      lSprite.position.set(
        (Math.random() - 0.5) * spread * 1.0,
        height * 0.42 + Math.random() * spread * 0.7,
        (Math.random() - 0.5) * spread * 0.75
      );
      g.add(lSprite);
    }
    g.position.set(x, 0, z);
    scene.add(g);
    return g;
  }

  // PALM TREE BUILDER — ringed trunk + billboarded frond canopy.
  // Flat-plane fronds were reading edge-on as harsh sticks ("antenna with
  // ferns") when the camera was offset; sprite-based fronds always face the
  // camera so the palm reads as a leafy crown from any angle.
  // Palm-frond sprite texture — a fan of leaflets on a central spine, faded
  // at the root so multiple sprites blend into one canopy.
  var palmFrondTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    var midY = h * 0.95; // frond root at the bottom-centre of the texture
    var midX = w * 0.5;
    var leafletCount = 22;
    for (var s = 0; s < 2; s++) {
      // s=0 leftward sweep, s=1 rightward sweep
      var dir = s === 0 ? -1 : 1;
      for (var li = 0; li < leafletCount; li++) {
        var t = li / (leafletCount - 1); // 0..1 from spine-root outward
        // Position along the spine curve (curving outward and upward)
        var spineX = midX + dir * t * (w * 0.45);
        var spineY = midY - Math.pow(t, 0.85) * h * 0.78;
        // Leaflet length tapers toward tip
        var lLen = (1 - Math.pow(t, 1.4)) * 24 + 4;
        // Leaflet angle — splayed outward from spine
        var spineAngle = Math.atan2(-(h * 0.78) * 1.1 * Math.pow(t, -0.15) || -1, dir * w * 0.45);
        var lAngle = spineAngle + dir * 0.5;
        var rShift = Math.floor(Math.random() * 55);
        // Mediterranean palm at golden hour. The rShift skew means many
        // leaflets get sun-warmed amber (high R, mod G, low B); others stay
        // in cool sage shadow. Reads as gold sunlight raking the canopy.
        var r = 110 + rShift;
        var g2 = 108 + Math.floor(rShift * 0.5);
        var b = 45 + Math.floor(rShift * 0.12);
        cx.strokeStyle = 'rgba(' + r + ',' + g2 + ',' + b + ',' + (0.75 + Math.random() * 0.2) + ')';
        cx.lineWidth = 1.6 + Math.random() * 0.9;
        cx.lineCap = 'round';
        cx.beginPath();
        cx.moveTo(spineX, spineY);
        cx.lineTo(spineX + Math.cos(lAngle) * lLen,
                  spineY + Math.sin(lAngle) * lLen);
        cx.stroke();
      }
    }
    // Spine on top
    cx.strokeStyle = 'rgba(80, 72, 38, 0.85)';
    cx.lineWidth = 2.4;
    cx.lineCap = 'round';
    cx.beginPath();
    cx.moveTo(midX, midY);
    cx.quadraticCurveTo(midX - w * 0.05, midY - h * 0.5, midX, h * 0.08);
    cx.stroke();
    // Soft alpha fade around root so multiple sprites can overlap cleanly
    var fade = cx.createRadialGradient(midX, midY, 2, midX, midY, w * 0.18);
    fade.addColorStop(0, 'rgba(0,0,0,1)');
    fade.addColorStop(1, 'rgba(0,0,0,0)');
    cx.globalCompositeOperation = 'destination-out';
    cx.fillStyle = fade;
    cx.fillRect(0, 0, w, h);
    cx.globalCompositeOperation = 'source-over';
  });

  // Coconut/seed cluster texture — a small bunch of round fruit
  var palmFruitTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    for (var fr = 0; fr < 8; fr++) {
      var fx = w * 0.35 + Math.random() * w * 0.3;
      var fy = h * 0.35 + Math.random() * h * 0.3;
      var fr2 = 4 + Math.random() * 3;
      var shade = 60 + Math.floor(Math.random() * 25);
      cx.fillStyle = 'rgb(' + shade + ',' + (shade - 10) + ',' + Math.floor(shade * 0.4) + ')';
      cx.beginPath();
      cx.arc(fx, fy, fr2, 0, Math.PI * 2);
      cx.fill();
      // tiny highlight
      cx.fillStyle = 'rgba(180, 150, 80, 0.4)';
      cx.beginPath();
      cx.arc(fx - 1, fy - 1, fr2 * 0.35, 0, Math.PI * 2);
      cx.fill();
    }
  });

  function makePalm(x, z, height, lean) {
    var g = new THREE.Group();
    var trunk = new THREE.Mesh(
      new THREE.CylinderGeometry(0.06, 0.13, height, 8),
      palmBarkMat
    );
    trunk.position.set(0, height / 2, 0);
    trunk.rotation.z = lean || 0.06;
    g.add(trunk);
    // Slight crown swell — gives the trunk top a fatter base for the canopy
    var crownShaft = new THREE.Mesh(
      new THREE.CylinderGeometry(0.10, 0.07, 0.42, 8),
      palmBarkMat
    );
    crownShaft.position.set(0, height * 0.94, 0);
    g.add(crownShaft);
    // Frond sprites — radially placed around the crown, sized & angled to suggest depth
    var frondCount = 10;
    for (var f = 0; f < frondCount; f++) {
      var angle = (f / frondCount) * Math.PI * 2 + (Math.random() - 0.5) * 0.25;
      var frondLen = 2.4 + Math.random() * 1.1;
      var frondMat = new THREE.SpriteMaterial({
        map: palmFrondTex, transparent: true,
        opacity: 0.82 + Math.random() * 0.13,
        depthWrite: false
      });
      var frond = new THREE.Sprite(frondMat);
      // Sprite scale: width spans the leaflets, height is the frond length
      var sw = frondLen * 0.95;
      var sh = frondLen;
      frond.scale.set(sw, sh, 1);
      // Position the sprite ANCHOR at the crown then push outward a bit so the
      // root sits at the crown and the frond tip arcs outward.
      var radial = 0.15 + Math.random() * 0.1;
      frond.position.set(
        Math.cos(angle) * radial,
        height * 0.98 + sh * 0.34, // sprite centre is half its height above the crown
        Math.sin(angle) * radial
      );
      g.add(frond);
    }
    // Drooping outer fronds — bigger sprites that hang lower, suggesting the
    // canopy spreading out
    var droopCount = 6;
    for (var df2 = 0; df2 < droopCount; df2++) {
      var dAng = (df2 / droopCount) * Math.PI * 2 + Math.random() * 0.5;
      var dLen = 2.6 + Math.random() * 1.2;
      var dMat = new THREE.SpriteMaterial({
        map: palmFrondTex, transparent: true,
        opacity: 0.7 + Math.random() * 0.18,
        depthWrite: false
      });
      var dFrond = new THREE.Sprite(dMat);
      dFrond.scale.set(dLen * 1.05, dLen * 0.85, 1);
      // Push out further and slightly lower than upright fronds
      dFrond.position.set(
        Math.cos(dAng) * (0.55 + Math.random() * 0.3),
        height * 0.86 + Math.random() * 0.2,
        Math.sin(dAng) * (0.55 + Math.random() * 0.3)
      );
      g.add(dFrond);
    }
    // Fruit/seed cluster — adds biological detail to the crown
    if (Math.random() > 0.4) {
      var fruitAng = Math.random() * Math.PI * 2;
      var fruitMat = new THREE.SpriteMaterial({
        map: palmFruitTex, transparent: true, opacity: 0.85,
        depthWrite: false
      });
      var fruit = new THREE.Sprite(fruitMat);
      fruit.scale.set(0.5, 0.5, 1);
      fruit.position.set(
        Math.cos(fruitAng) * 0.25,
        height * 0.90,
        Math.sin(fruitAng) * 0.25
      );
      g.add(fruit);
    }
    g.position.set(x, 0, z);
    scene.add(g);
    return g;
  }

  // BUSH BUILDER — dense, low scrubby Mediterranean shrub. Fewer, fully
  // opaque sprites with the sharper-edged bush texture so the bush reads
  // as a single solid mass, not a stack of translucent puffs.
  function makeBush(x, z, size) {
    var g = new THREE.Group();
    var texes = [bushLeafTex, bushLeafTex, bushLeafTexB];
    var count = 3 + Math.floor(Math.random() * 2);
    for (var i = 0; i < count; i++) {
      var tex = texes[Math.floor(Math.random() * texes.length)];
      var bSprite = new THREE.Sprite(makeLeafSpriteMat(tex, 0.95));
      var bs = size * (0.85 + Math.random() * 0.5);
      bSprite.scale.set(bs, bs * (0.6 + Math.random() * 0.35), 1);
      bSprite.position.set(
        (Math.random() - 0.5) * size * 0.5,
        bs * 0.32 + Math.random() * size * 0.18,
        (Math.random() - 0.5) * size * 0.35
      );
      g.add(bSprite);
    }
    for (var tw = 0; tw < 2; tw++) {
      var twig = new THREE.Mesh(
        new THREE.CylinderGeometry(0.005, 0.012, size * 0.6, 3),
        trunkMat
      );
      twig.position.set((Math.random() - 0.5) * size * 0.6, size * 0.3, (Math.random() - 0.5) * size * 0.3);
      twig.rotation.z = (Math.random() - 0.5) * 0.5;
      g.add(twig);
    }
    g.position.set(x, 0, z);
    scene.add(g);
  }

  // TALL GRASS — canvas textured tufts. Each blade starts at a randomised
  // height near the base. The bottom strip of the texture (much wider now)
  // fades to transparent so the grass dissolves into the ground rather than
  // terminating in a hard horizontal line.
  var grassTex = makeCanvasTexture(64, 128, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    for (var bl = 0; bl < 24; bl++) {
      var bx = w * 0.08 + Math.random() * w * 0.84;
      var gv = Math.floor(Math.random() * 35);
      // Dry coastal grass — much darker now so the unlit sprites don't read
      // as chalky-bright against the proper shadows on the rest of the scene
      cx.strokeStyle = 'rgba(' + (65 + gv) + ',' + (58 + gv) + ',' + (32 + Math.floor(gv * 0.3)) + ',' + (0.45 + Math.random() * 0.3) + ')';
      cx.lineWidth = 1 + Math.random() * 2;
      cx.beginPath();
      // Roots staggered across the bottom 28% of the canvas — ragged base
      var rootY = h - Math.random() * h * 0.28;
      cx.moveTo(bx, rootY);
      var tipX = bx + (Math.random() - 0.5) * 25;
      var cpX = bx + (Math.random() - 0.5) * 18;
      cx.quadraticCurveTo(cpX, h * 0.3, tipX, h * 0.05 + Math.random() * h * 0.15);
      cx.stroke();
    }
    // Aggressive fade covering the bottom 55% of the texture. The gradient
    // is smooth (no mid stop) so the dissolve is gentle all the way down.
    // Even if the sprite dips slightly below ground, the visible bottom is
    // already mostly transparent — no hard horizontal line.
    var fade = cx.createLinearGradient(0, h * 0.45, 0, h);
    fade.addColorStop(0, 'rgba(0,0,0,0)');
    fade.addColorStop(1, 'rgba(0,0,0,1)');
    cx.globalCompositeOperation = 'destination-out';
    cx.fillStyle = fade;
    cx.fillRect(0, h * 0.45, w, h * 0.55);
    cx.globalCompositeOperation = 'source-over';
  });
  var grassSpriteMat = new THREE.SpriteMaterial({
    map: grassTex, transparent: true, opacity: 0.8,
    depthWrite: false
  });

  // Place a small CLUMP of grass at (x,z): three or four staggered sprites
  // with MEANINGFULLY varied baselines so no two blades share a bottom line.
  // The sprite is raised so the texture's wide fade is well above ground,
  // dissolving any hard edge into the surrounding sand/stone.
  function placeGrassClump(x, z, baseSize) {
    var bladeCount = 3 + Math.floor(Math.random() * 3);
    for (var bi = 0; bi < bladeCount; bi++) {
      var mat = grassSpriteMat.clone();
      mat.opacity = 0.55 + Math.random() * 0.22;
      var sprite = new THREE.Sprite(mat);
      var sw = baseSize * (0.55 + Math.random() * 0.65);
      var sh = sw * (1.4 + Math.random() * 0.5);
      sprite.scale.set(sw, sh, 1);
      var ox = (Math.random() - 0.5) * baseSize * 0.55;
      var oz = (Math.random() - 0.5) * baseSize * 0.35;
      // Raise the centre so the BOTTOM of the sprite sits 0.05–0.18 ABOVE the
      // ground plane. The full fade zone is then above ground; blades appear
      // to rise from nothing rather than terminating at a clipped line.
      var liftFromGround = 0.05 + Math.random() * 0.13;
      var groundY = sh * 0.5 + liftFromGround;
      sprite.position.set(x + ox, groundY, z + oz);
      scene.add(sprite);
    }
  }

  // ---- PLACE VEGETATION ----

  // CEDARS — the big dramatic trees
  makeCedar(-12, -2, 7.0, 0.02);
  makeCedar(13, 0, 6.0, -0.02);
  makeCedar(-18, -5, 5.5, 0);

  // OLIVE TREES — gnarled, spreading, silver-green
  makeOlive(-8, 3, 3.5, 2.0, 0.05);
  makeOlive(9, 4, 3.0, 1.8, -0.04);
  makeOlive(-5, 6, 2.8, 1.6, 0);
  makeOlive(5, 7, 2.5, 1.5, 0.03);
  makeOlive(-15, 2, 3.2, 1.9, -0.03);

  // PALMS — kept away from the camera so none looms in the right-foreground.
  // The big right-foreground palm used to read as an antenna right of frame.
  makePalm(-10, -4, 6.0, 0.1);
  makePalm(-14, -3, 5.5, -0.08);
  makePalm(15, -6, 5.0, 0.06);   // pushed back from (12,-3,6.5)
  makePalm(-17, -5, 4.5, 0.15);

  // BUSHES — scattered scrub. Avoid placing them right at the camera edge
  // where their sprite edges read as cloud puffs; keep them midground+.
  makeBush(-4.5, 1.5, 1.0);
  makeBush(-7, -5, 0.9);
  makeBush(5, -5.5, 1.1);
  makeBush(-11, -0.5, 1.2);
  makeBush(3, -7, 0.7);
  makeBush(-2, -7.5, 0.85);
  makeBush(7, -6.5, 0.7);
  makeBush(-8, -6.5, 0.8);
  makeBush(11, -5, 0.6);
  makeBush(-3, -4, 0.75);

  // Tall grass — placed as natural clumps rather than single sprites
  for (var gi = 0; gi < 24; gi++) {
    var gSize = 0.6 + Math.random() * 0.8;
    placeGrassClump(-15 + Math.random() * 30, -7 + Math.random() * 6, gSize);
  }

  // Wildflowers
  for (var wf = 0; wf < 25; wf++) {
    var flowerColours = [0xe8c840, 0xd86838, 0xc848a0, 0xe8e0a0];
    var fCol = flowerColours[Math.floor(Math.random() * flowerColours.length)];
    var flower = new THREE.Mesh(
      new THREE.SphereGeometry(0.025 + Math.random() * 0.025, 4, 3),
      new THREE.MeshStandardMaterial({ color: fCol, roughness: 0.7, emissive: fCol, emissiveIntensity: 0.1 })
    );
    flower.position.set(-12 + Math.random() * 24, 0.05 + Math.random() * 0.2, -6 + Math.random() * 12);
    scene.add(flower);
  }

  // ============================================================
  // DISTANT RUINS — silhouettes along the coastline
  // ============================================================
  var distantMat = new THREE.MeshStandardMaterial({ color: 0xa08858, roughness: 0.95 });
  var farMat = new THREE.MeshStandardMaterial({ color: 0x806838, roughness: 1.0 });

  for (var di = 0; di < 6; di++) {
    var dh = 1.0 + Math.random() * 2.5;
    var dCol = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.2, dh, 8), di < 3 ? distantMat : farMat);
    dCol.position.set(-14 - di * 2.5, dh / 2, -7 - di * 1.5);
    scene.add(dCol);
  }
  var distWall1 = new THREE.Mesh(new THREE.BoxGeometry(4.5, 2.0, 0.4), distantMat);
  distWall1.position.set(-20, 1.0, -11);
  scene.add(distWall1);
  // RIGHT DISTANT WALL — detailed ruin wall with broken top, niches, and weathering
  // Main wall body — thicker with visible stone courses
  var distWall2 = new THREE.Mesh(new THREE.BoxGeometry(4.0, 2.8, 0.7), warmStone);
  distWall2.position.set(17, 1.4, -8);
  scene.add(distWall2);
  // Lower plinth — wider base step
  var rw2Plinth = new THREE.Mesh(new THREE.BoxGeometry(4.5, 0.35, 0.9), darkStone);
  rw2Plinth.position.set(17, 0.18, -8);
  scene.add(rw2Plinth);
  // Broken top — irregular blocks sticking up
  var rw2Top1 = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.5, 0.65), warmStone);
  rw2Top1.position.set(16, 3.05, -8);
  rw2Top1.rotation.z = 0.04;
  scene.add(rw2Top1);
  var rw2Top2 = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.35, 0.6), paleStone);
  rw2Top2.position.set(18.2, 2.95, -8);
  rw2Top2.rotation.z = -0.06;
  scene.add(rw2Top2);
  var rw2Top3 = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.65, 0.55), darkStone);
  rw2Top3.position.set(17.2, 3.12, -8);
  scene.add(rw2Top3);
  // Niche — recessed rectangular opening in the wall
  var rw2Niche = new THREE.Mesh(new THREE.BoxGeometry(0.9, 1.2, 0.25), darkStone);
  rw2Niche.position.set(17.3, 1.6, -7.7);
  scene.add(rw2Niche);
  // Stone course lines — horizontal grooves
  var rw2Course1 = new THREE.Mesh(new THREE.BoxGeometry(4.1, 0.06, 0.72), darkStone);
  rw2Course1.position.set(17, 1.0, -8);
  scene.add(rw2Course1);
  var rw2Course2 = new THREE.Mesh(new THREE.BoxGeometry(4.1, 0.06, 0.72), darkStone);
  rw2Course2.position.set(17, 2.0, -8);
  scene.add(rw2Course2);
  // Dry lichen stains on the wall face — pale ochre/grey, not green moss
  var rw2Moss1 = new THREE.Mesh(
    new THREE.PlaneGeometry(0.8, 0.6),
    new THREE.MeshStandardMaterial({ color: 0x70603a, roughness: 0.9, transparent: true, opacity: 0.32 })
  );
  rw2Moss1.position.set(16.2, 0.6, -7.64);
  scene.add(rw2Moss1);
  var rw2Moss2 = new THREE.Mesh(
    new THREE.PlaneGeometry(0.6, 0.4),
    new THREE.MeshStandardMaterial({ color: 0x80704a, roughness: 0.9, transparent: true, opacity: 0.3 })
  );
  rw2Moss2.position.set(18, 0.9, -7.64);
  scene.add(rw2Moss2);
  // Fallen blocks at the foot of the wall
  var rw2Fall1 = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.4, 0.5), rubbleMat);
  rw2Fall1.position.set(15.5, 0.2, -7.2);
  rw2Fall1.rotation.y = 0.4;
  rw2Fall1.rotation.z = 0.15;
  scene.add(rw2Fall1);
  var rw2Fall2 = new THREE.Mesh(new THREE.BoxGeometry(0.45, 0.35, 0.4), warmStone);
  rw2Fall2.position.set(18.5, 0.18, -7.5);
  rw2Fall2.rotation.y = -0.3;
  scene.add(rw2Fall2);
  // Distant column beside the wall
  var distCol2 = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.22, 3.2, 10), columnMat);
  distCol2.position.set(15, 1.6, -9);
  scene.add(distCol2);
  var distCol2Cap = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.2, 0.6), paleStone);
  distCol2Cap.position.set(15, 3.2, -9);
  scene.add(distCol2Cap);

  // ============================================================
  // FAR LEFT — cedars, olives, ruins, and ground detail
  // ============================================================
  // Large cedar dominating the left
  makeCedar(-14, 2, 8.0, -0.03);
  // Smaller cedar behind
  makeCedar(-17, -1, 5.5, 0.04);
  // Olive trees
  makeOlive(-13, 5, 3.2, 1.8, 0.04);
  makeOlive(-16, 7, 2.8, 1.5, -0.03);
  // Palm
  makePalm(-15, -2, 5.0, -0.12);
  // Crumbling wall fragment with plinth
  var farLeftWall = new THREE.Mesh(new THREE.BoxGeometry(3.5, 2.2, 0.6), warmStone);
  farLeftWall.position.set(-14, 1.1, -1);
  farLeftWall.rotation.y = 0.3;
  scene.add(farLeftWall);
  var farLeftWallPlinth = new THREE.Mesh(new THREE.BoxGeometry(4.0, 0.3, 0.8), darkStone);
  farLeftWallPlinth.position.set(-14, 0.15, -1);
  scene.add(farLeftWallPlinth);
  var farLeftWallTop = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.4, 0.55), darkStone);
  farLeftWallTop.position.set(-13.5, 2.4, -1);
  farLeftWallTop.rotation.z = 0.06;
  scene.add(farLeftWallTop);
  // Two columns — one broken
  buildColumn(-16, 1, 3.5, true, 0.05);
  buildColumn(-13, -3, 5.2, false, -0.02);
  // Low stone platform / foundation
  var farLeftPlatform = new THREE.Mesh(new THREE.BoxGeometry(5, 0.4, 3), darkStone);
  farLeftPlatform.position.set(-13, 0.2, 1);
  scene.add(farLeftPlatform);
  // Bushes filling gaps — kept midground+, away from camera-edge fluff
  makeBush(-13, -1, 1.0);
  makeBush(-16, -4, 0.9);
  makeBush(-18, -2, 0.8);
  makeBush(-15, -5, 1.1);
  // Tall grass clusters
  for (var gli = 0; gli < 10; gli++) {
    var glSize = 0.5 + Math.random() * 0.7;
    placeGrassClump(-12 - Math.random() * 6, -5 + Math.random() * 14, glSize);
  }
  // Rubble scatter — organic dodecahedra
  for (var rlb = 0; rlb < 10; rlb++) {
    var rlbS = 0.15 + Math.random() * 0.4;
    var rlbMesh = new THREE.Mesh(
      new THREE.DodecahedronGeometry(rlbS * 0.5, 0),
      Math.random() > 0.5 ? rubbleMat : darkRubble
    );
    rlbMesh.position.set(-12 - Math.random() * 6, rlbS * 0.12, -3 + Math.random() * 10);
    rlbMesh.scale.set(1.0 + Math.random() * 0.4, 0.55 + Math.random() * 0.35, 0.9 + Math.random() * 0.3);
    rlbMesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, (Math.random() - 0.5) * 0.5);
    scene.add(rlbMesh);
  }

  // ============================================================
  // FAR RIGHT — cedars, olives, ruins, and ground detail
  // ============================================================
  // Large cedar on the right edge
  makeCedar(17, 1, 7.5, 0.03);
  // Smaller cedar further back
  makeCedar(20, -2, 5.0, -0.04);
  // Olive trees
  makeOlive(16, 5, 3.0, 1.7, -0.04);
  makeOlive(19, 6, 2.6, 1.5, 0.03);
  makeOlive(21, 3, 2.2, 1.3, -0.02);
  // Palms — pushed further back so they don't crowd the right-foreground
  makePalm(20, -4, 5.0, -0.1);
  makePalm(23, -2, 4.0, 0.08);
  // Ruined wall with plinth and broken top
  var farRightWall = new THREE.Mesh(new THREE.BoxGeometry(3.0, 2.5, 0.6), warmStone);
  farRightWall.position.set(16, 1.25, -2);
  farRightWall.rotation.y = -0.2;
  scene.add(farRightWall);
  var farRightWallPlinth = new THREE.Mesh(new THREE.BoxGeometry(3.5, 0.3, 0.8), darkStone);
  farRightWallPlinth.position.set(16, 0.15, -2);
  scene.add(farRightWallPlinth);
  var farRightBroken = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.5, 0.55), paleStone);
  farRightBroken.position.set(16.8, 2.75, -2);
  farRightBroken.rotation.z = -0.08;
  scene.add(farRightBroken);
  // Stone course line on wall
  var frwCourse = new THREE.Mesh(new THREE.BoxGeometry(3.1, 0.06, 0.62), darkStone);
  frwCourse.position.set(16, 1.5, -2);
  scene.add(frwCourse);
  // Three columns — two standing, one broken
  buildColumn(18, -1, 5.0, false, -0.02);
  buildColumn(20, -1, 4.2, false, 0.03);
  buildColumn(22, -1, 2.5, true, 0.06);
  // Fallen column drum
  var farRightFallen = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, 1.4, 12), columnMat);
  farRightFallen.rotation.z = Math.PI / 2;
  farRightFallen.rotation.y = 0.5;
  farRightFallen.position.set(19, 0.3, 0.5);
  scene.add(farRightFallen);
  // Second ruin fragment further right — low wall stub
  var farRightStub = new THREE.Mesh(new THREE.BoxGeometry(2.0, 1.2, 0.5), warmStone);
  farRightStub.position.set(21, 0.6, 2);
  farRightStub.rotation.y = 0.4;
  scene.add(farRightStub);
  // Bushes filling gaps between trees — kept away from near-camera positions
  makeBush(19, -3, 1.0);
  makeBush(16, -5, 0.8);
  makeBush(22, -4, 0.85);
  makeBush(20, -6, 0.9);
  // Tall grass
  for (var gri = 0; gri < 10; gri++) {
    var grSize = 0.5 + Math.random() * 0.7;
    placeGrassClump(14 + Math.random() * 10, -5 + Math.random() * 14, grSize);
  }
  // Rubble scatter — organic dodecahedra
  for (var rrb = 0; rrb < 10; rrb++) {
    var rrbS = 0.15 + Math.random() * 0.4;
    var rrbMesh = new THREE.Mesh(
      new THREE.DodecahedronGeometry(rrbS * 0.5, 0),
      Math.random() > 0.5 ? rubbleMat : darkRubble
    );
    rrbMesh.position.set(14 + Math.random() * 10, rrbS * 0.12, -3 + Math.random() * 10);
    rrbMesh.scale.set(1.0 + Math.random() * 0.4, 0.55 + Math.random() * 0.35, 0.9 + Math.random() * 0.3);
    rrbMesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, (Math.random() - 0.5) * 0.5);
    scene.add(rrbMesh);
  }
  // Terracotta pot fragments
  for (var rpot = 0; rpot < 4; rpot++) {
    var rpGeo = new THREE.CylinderGeometry(0.12 + Math.random() * 0.15, 0.18 + Math.random() * 0.1,
      0.2 + Math.random() * 0.25, 8, 1, true, 0, Math.PI * (0.8 + Math.random() * 0.8));
    var rpMesh = new THREE.Mesh(rpGeo, terracotta);
    rpMesh.position.set(15 + Math.random() * 7, 0.1, -2 + Math.random() * 10);
    rpMesh.rotation.z = (Math.random() - 0.5) * 0.4;
    rpMesh.rotation.y = Math.random() * Math.PI * 2;
    scene.add(rpMesh);
  }

  // ============================================================
  // DISTANT HILL — left side, with signal fire on top
  // ============================================================
  // Hill terrain — a rounded mound in the distance on the left
  var hillTex = makeCanvasTexture(256, 256, function(cx, w, h) {
    // Earthy base
    cx.fillStyle = '#5a4828';
    cx.fillRect(0, 0, w, h);
    // Scrubby patches — dry tan, ochre and sage, no fresh greens
    for (var p = 0; p < 120; p++) {
      var tone = Math.random();
      if (tone > 0.6) cx.fillStyle = 'rgba(90,82,45,' + (0.1 + Math.random() * 0.15) + ')';
      else if (tone > 0.3) cx.fillStyle = 'rgba(110,85,45,' + (0.1 + Math.random() * 0.12) + ')';
      else cx.fillStyle = 'rgba(70,55,30,' + (0.08 + Math.random() * 0.1) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        4 + Math.random() * 15, 3 + Math.random() * 10,
        Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
    // Rocky outcrops — lighter spots
    for (var r = 0; r < 20; r++) {
      cx.fillStyle = 'rgba(120,100,65,' + (0.08 + Math.random() * 0.1) + ')';
      cx.beginPath();
      cx.ellipse(Math.random() * w, Math.random() * h,
        3 + Math.random() * 8, 2 + Math.random() * 5, 0, 0, Math.PI * 2);
      cx.fill();
    }
  });
  var hillMat = new THREE.MeshStandardMaterial({ map: hillTex, roughness: 0.95 });

  // Coastal hill system — a chain of hills extending back along the coastline
  // Camera at (12, 5.5, 5) looking at (0, 1.2, -12) can see ~x:-15 to x:+18
  // Back hills must be TALLER than front hills so they peek above

  // Main foreground hill — the closest. PYRE BURNS ON ITS CROWN (left headland).
  var hillGeo = new THREE.SphereGeometry(10, 32, 20, 0, Math.PI * 2, 0, Math.PI / 2);
  var hill = new THREE.Mesh(hillGeo, hillMat);
  hill.scale.set(1.3, 0.65, 1.1);
  hill.position.set(-16, -1.0, -14);
  scene.add(hill);

  // Second hill — further LEFT so it doesn't cover the fire at x:-14
  // Peeks above hill 1, its right edge just barely visible
  var hill2Geo = new THREE.SphereGeometry(11, 24, 16, 0, Math.PI * 2, 0, Math.PI / 2);
  var hill2 = new THREE.Mesh(hill2Geo, hillMat);
  hill2.scale.set(1.2, 0.8, 1.2);
  hill2.position.set(-26, -1.0, -19);
  scene.add(hill2);

  // Third hill — further back and left still
  var hill3Mat = new THREE.MeshStandardMaterial({ map: hillTex, roughness: 0.95, color: 0x4a3a22 });
  var hill3Geo = new THREE.SphereGeometry(10, 20, 14, 0, Math.PI * 2, 0, Math.PI / 2);
  var hill3 = new THREE.Mesh(hill3Geo, hill3Mat);
  hill3.scale.set(1.3, 0.9, 1.3);
  hill3.position.set(-33, -1.0, -25);
  scene.add(hill3);

  // Fourth hill — most distant, hazy silhouette
  var hill4Mat = new THREE.MeshStandardMaterial({ map: hillTex, roughness: 1.0, color: 0x3d3020 });
  var hill4Geo = new THREE.SphereGeometry(9, 16, 12, 0, Math.PI * 2, 0, Math.PI / 2);
  var hill4 = new THREE.Mesh(hill4Geo, hill4Mat);
  hill4.scale.set(1.4, 0.95, 1.4);
  hill4.position.set(-38, -0.8, -32);
  scene.add(hill4);

  // Lower ridge — connects the foreground hill down to the shoreline
  var ridgeGeo = new THREE.SphereGeometry(6, 20, 14, 0, Math.PI * 2, 0, Math.PI / 2);
  var ridge = new THREE.Mesh(ridgeGeo, hillMat);
  ridge.scale.set(1.4, 0.3, 1.0);
  ridge.position.set(-12, -0.5, -12);
  scene.add(ridge);

  // Displace each hill's vertices for natural ridge + shoulder character.
  // Adds: ridgeline carving (sharp creases), asymmetric peak bias, gully cuts,
  // multi-octave fine detail. Heavier amplitude than before — the half-sphere
  // is unrecognisable as a sphere by the time this finishes.
  function displaceHill(geo, amp, freq, peakBias) {
    var pos = geo.attributes.position;
    peakBias = peakBias || { x: 0, z: 0 };
    for (var vi = 0; vi < pos.count; vi++) {
      var x = pos.getX(vi), y = pos.getY(vi), z = pos.getZ(vi);
      if (y < 0.5) continue;
      // Multi-octave smooth noise — broad shoulders, mid lumps, fine crags
      var noise = Math.sin(x * freq) * Math.cos(z * freq * 1.3) * 0.7
                + Math.sin(x * freq * 2.3 + 1.7) * Math.cos(z * freq * 1.9 + 0.7) * 0.45
                + Math.sin(x * freq * 4.1 + 2.1) * Math.cos(z * freq * 3.6 + 1.1) * 0.25
                + Math.sin(x * freq * 7.7 + 0.4) * Math.cos(z * freq * 6.5) * 0.12;
      // Asymmetric ridge spine — sharp peak running across the hill
      var ridgeAngle = Math.atan2(z - peakBias.z, x - peakBias.x);
      var ridgeProfile = Math.cos(ridgeAngle * 3 + 1.1) * 0.5;
      noise += ridgeProfile;
      // Gully cuts — abs() creates sharp creases (gullies on the windward face)
      var gully = -Math.abs(Math.sin(x * freq * 1.1 + z * freq * 0.4 + 0.6)) * 0.55;
      noise += gully + 0.3;
      // Peak boost — vertices near the bias point get pushed UP for a clear summit
      var dxp = x - peakBias.x, dzp = z - peakBias.z;
      var dPeak = Math.sqrt(dxp * dxp + dzp * dzp);
      var peakBoost = Math.max(0, 1 - dPeak / 8) * 0.45;
      noise += peakBoost;
      var r = Math.sqrt(x * x + y * y + z * z);
      if (r > 0.001) {
        var nx = x / r, ny = y / r, nz = z / r;
        pos.setXYZ(vi, x + nx * noise * amp, y + ny * noise * amp, z + nz * noise * amp);
      }
    }
    pos.needsUpdate = true;
    geo.computeVertexNormals();
  }
  // Pyre-hill peak slightly off-centre to the back — the pyre sits on this summit
  displaceHill(hillGeo, 2.0, 0.20, { x: 2, z: 0 });
  displaceHill(hill2Geo, 1.8, 0.18, { x: -2, z: 0 });
  displaceHill(hill3Geo, 1.6, 0.20, { x: 0, z: 0 });
  displaceHill(hill4Geo, 1.4, 0.22, { x: 0, z: 0 });
  displaceHill(ridgeGeo, 0.9, 0.28, { x: 0, z: 0 });

  // RAGGED CLIFFS — dark rocky outcrops at the base of the hill where it meets the sea
  var cliffTex = makeCanvasTexture(256, 256, function(cx, w, h) {
    // Dark wet rock base
    cx.fillStyle = '#3a3028';
    cx.fillRect(0, 0, w, h);
    // Jagged rock strata — horizontal bands of different dark tones
    for (var sy = 0; sy < h; sy += 8 + Math.random() * 12) {
      var strata = 40 + Math.floor(Math.random() * 30);
      cx.fillStyle = 'rgba(' + strata + ',' + Math.floor(strata * 0.85) + ',' + Math.floor(strata * 0.7) + ',' + (0.2 + Math.random() * 0.3) + ')';
      cx.fillRect(0, sy, w, 4 + Math.random() * 8);
    }
    // Vertical crevices
    for (var vc = 0; vc < 15; vc++) {
      cx.strokeStyle = 'rgba(15,10,5,' + (0.15 + Math.random() * 0.2) + ')';
      cx.lineWidth = 1 + Math.random() * 2;
      cx.beginPath();
      var vx = Math.random() * w;
      cx.moveTo(vx, Math.random() * h * 0.3);
      cx.lineTo(vx + (Math.random() - 0.5) * 20, h * 0.5 + Math.random() * h * 0.3);
      cx.lineTo(vx + (Math.random() - 0.5) * 15, h);
      cx.stroke();
    }
    // Wet shine near bottom — where waves splash
    var wetGrad = cx.createLinearGradient(0, h * 0.6, 0, h);
    wetGrad.addColorStop(0, 'rgba(80,90,100,0)');
    wetGrad.addColorStop(1, 'rgba(80,90,100,0.25)');
    cx.fillStyle = wetGrad;
    cx.fillRect(0, 0, w, h);
    // Barnacle/limpet spots
    for (var bn = 0; bn < 40; bn++) {
      cx.fillStyle = 'rgba(160,150,130,' + (0.05 + Math.random() * 0.1) + ')';
      cx.beginPath();
      cx.arc(Math.random() * w, h * 0.4 + Math.random() * h * 0.5, 1 + Math.random() * 3, 0, Math.PI * 2);
      cx.fill();
    }
  });
  // Lighter weathered cliff stone — warm sandstone that catches the golden
  // hour. Tinted brighter than the previous dark wet-rock base so cliffs
  // stand out clearly against the silhouetted hill behind.
  var cliffMat = new THREE.MeshStandardMaterial({
    map: cliffTex, roughness: 0.92,
    color: 0xa07848
  });
  var darkCliffMat = new THREE.MeshStandardMaterial({
    map: cliffTex, roughness: 0.95,
    color: 0x6a5030
  });

  // ============================================================
  // ROCK BUILDER — replaces BoxGeometry cliffs with jagged, organic rock forms.
  // Heavy box subdivisions + multi-octave noise displacement. Vertices are
  // only ever pushed OUTWARD so the rock grows lumps and crags without ever
  // shrinking, and the top gets dramatic jagged spurs and notches.
  // ============================================================
  function makeRockCliff(x, z, w, h, d, rotY, rotZ, dark, seedX) {
    var geo = new THREE.BoxGeometry(w, h, d, 6, 10, 6);
    var pos = geo.attributes.position;
    var seed = ((x + 73.1) * 13.37 + (z + 19.3) * 7.71 + (seedX || 0) * 41.3);
    var sA = Math.sin(seed) * 0.5 + 1.0;
    var sB = Math.cos(seed * 1.3) * 0.4 + 1.2;
    for (var vi = 0; vi < pos.count; vi++) {
      var px = pos.getX(vi), py = pos.getY(vi), pz = pos.getZ(vi);
      // Multi-octave noise — varied frequencies for crag character
      var n1 = Math.sin(px * 1.4 * sA + seed)
             * Math.cos(pz * 1.6 * sB + seed * 1.7);
      var n2 = Math.sin(py * 1.8 + seed * 2.3) * 0.55;
      var n3 = Math.sin(px * 3.6 + py * 2.1 + seed * 0.7)
             * Math.cos(pz * 3.1 + seed * 1.1) * 0.35;
      var n4 = Math.sin(px * 7.0 + pz * 6.2 + seed) * 0.18;
      // Bias positive so rock only grows OUT, never inward (avoids shrinking)
      var disp = Math.max(0, n1 + n2 + n3 + n4) * 0.35
               + Math.abs(n4) * 0.10;
      var rXZ = Math.sqrt(px * px + pz * pz);
      if (rXZ > 0.001) {
        pos.setX(vi, px + (px / rXZ) * disp * (w * 0.6));
        pos.setZ(vi, pz + (pz / rXZ) * disp * (d * 0.6));
      }
      // Dramatic vertical jaggedness near the top — spurs and notches
      var topness = Math.max(0, py / (h * 0.5));
      if (topness > 0) {
        var topJag = Math.sin(px * 4 + pz * 3.4 + seed * 2)
                   + Math.sin(px * 8 + pz * 6 + seed * 1.5) * 0.5;
        pos.setY(vi, py + topJag * 0.32 * topness);
      }
      // Side strata — horizontal grooves like sedimentary bands
      if (Math.abs(py) < h * 0.45) {
        var strata = Math.sin(py * 6 + seed) * 0.06;
        if (rXZ > 0.001) {
          pos.setX(vi, pos.getX(vi) + (px / rXZ) * strata);
          pos.setZ(vi, pos.getZ(vi) + (pz / rXZ) * strata);
        }
      }
    }
    pos.needsUpdate = true;
    geo.computeVertexNormals();
    var rock = new THREE.Mesh(geo, dark ? darkCliffMat : cliffMat);
    rock.position.set(x, h * 0.35 - 0.3, z);
    rock.rotation.y = rotY;
    rock.rotation.z = rotZ;
    rock.castShadow = true;
    return rock;
  }

  // RAGGED CLIFFS — at the seaward edge of the hill, jutting into the surf.
  // Pulled forward (smaller z) so they jut OUT of the hill silhouette rather
  // than getting subsumed by it; mix of light & dark stone so they catch the
  // warm light and read as separate from the hill mass behind.
  var cliffRocks = [];
  var cliffData = [
    // x, z, width, height, depth, rotY, rotZ
    [-7, -9, 2.4, 5.2, 2.0, 0.2, 0.05],
    [-9, -10, 2.0, 6.4, 2.4, -0.15, 0.08],
    [-6, -8.5, 2.2, 4.2, 1.8, 0.35, -0.04],
    [-10, -10.5, 2.6, 5.6, 2.6, 0.1, -0.06],
    [-5, -8, 1.8, 3.6, 1.5, -0.25, 0.06],
    [-11, -11, 2.4, 4.6, 2.2, 0.18, -0.05],
    [-8, -9.5, 1.5, 5.4, 1.6, -0.2, 0.07],
    [-9.5, -9, 2.0, 4.0, 1.9, 0.3, -0.03],
    [-7, -10, 1.6, 4.2, 1.5, -0.3, 0.04],
    [-12, -11.5, 2.0, 3.8, 1.9, 0.12, 0.05]
  ];
  for (var ci = 0; ci < cliffData.length; ci++) {
    var cd = cliffData[ci];
    // Mostly light (catches the warm light); occasional dark for variation
    var dark = (ci % 4 === 0);
    var rock = makeRockCliff(cd[0], cd[1], cd[2], cd[3], cd[4], cd[5], cd[6],
                             dark, ci * 2.3);
    scene.add(rock);
    cliffRocks.push(rock);
  }

  // Smaller rocks and boulders at the cliff base — half submerged in the surf
  for (var cf = 0; cf < 15; cf++) {
    var cfW = 0.5 + Math.random() * 1.5;
    var cfH = 0.6 + Math.random() * 2.0;
    var cfD = 0.4 + Math.random() * 1.2;
    var cfRock = makeRockCliff(
      -5 - Math.random() * 8,
      -8.5 - Math.random() * 5,
      cfW, cfH, cfD,
      Math.random() * Math.PI,
      (Math.random() - 0.5) * 0.3,
      Math.random() < 0.4,
      cf * 5.7 + 17
    );
    // Re-anchor smaller boulders so they sit half-submerged at water level
    cfRock.position.y = cfH * 0.2 - 0.4;
    scene.add(cfRock);
  }

  // SHORELINE ROCKS — substantial rocks along the curve where the hill base
  // meets the sea. Tall enough to clearly read above water and sand: properly
  // half-emergent, with a few larger crags marking the headland's foot.
  for (var sr = 0; sr < 24; sr++) {
    var srW = 0.7 + Math.random() * 1.6;
    var srH = 0.9 + Math.random() * 1.6;
    var srD = 0.7 + Math.random() * 1.4;
    var srX = -16 + Math.random() * 14;
    var srZ = -7.5 - Math.random() * 6;
    var srRock = makeRockCliff(srX, srZ, srW, srH, srD,
      Math.random() * Math.PI,
      (Math.random() - 0.5) * 0.3,
      Math.random() < 0.4,
      sr * 7.3 + 113
    );
    // Show ~60% above ground/water — clearly visible at the hill-sea junction
    srRock.position.y = srH * 0.4 - 0.3;
    scene.add(srRock);
  }

  // Larger marker crags — a few big rocks right at the hill base showing
  // dramatic shape against the water
  var bigShoreCrags = [
    // x, z, w, h, d
    [-6, -9, 1.8, 2.4, 1.6],
    [-8, -10, 2.2, 2.8, 1.8],
    [-12, -11, 1.6, 2.2, 1.5],
    [-14, -9, 1.4, 2.0, 1.3]
  ];
  for (var bcg = 0; bcg < bigShoreCrags.length; bcg++) {
    var bcd = bigShoreCrags[bcg];
    var bcRock = makeRockCliff(bcd[0], bcd[1], bcd[2], bcd[3], bcd[4],
      bcg * 0.7, (bcg - 1.5) * 0.04,
      false, bcg * 19 + 401);
    bcRock.position.y = bcd[3] * 0.45 - 0.25;
    scene.add(bcRock);
  }

  // Stray sea boulders out in the shallow water — broken pieces fallen from
  // the cliffs over centuries, half-submerged offshore
  for (var sbr = 0; sbr < 8; sbr++) {
    var sbW = 0.6 + Math.random() * 1.1;
    var sbH = 0.5 + Math.random() * 0.9;
    var sbD = 0.6 + Math.random() * 1.0;
    var sbX = -14 + Math.random() * 10;
    var sbZ = -13 - Math.random() * 4;
    var sbRock = makeRockCliff(sbX, sbZ, sbW, sbH, sbD,
      Math.random() * Math.PI,
      (Math.random() - 0.5) * 0.5,
      Math.random() < 0.5,
      sbr * 11.1 + 233
    );
    sbRock.position.y = sbH * 0.3 - 0.38;
    scene.add(sbRock);
  }

  // RIGHT-SHORE ROCKS — quieter, but now clearly visible
  for (var rr = 0; rr < 8; rr++) {
    var rrW = 0.6 + Math.random() * 1.0;
    var rrH = 0.55 + Math.random() * 0.9;
    var rrD = 0.6 + Math.random() * 0.9;
    var rrX = 15 + Math.random() * 10;
    var rrZ = -8 - Math.random() * 5;
    var rrRock = makeRockCliff(rrX, rrZ, rrW, rrH, rrD,
      Math.random() * Math.PI,
      (Math.random() - 0.5) * 0.3,
      Math.random() < 0.4,
      rr * 4.7 + 311
    );
    rrRock.position.y = rrH * 0.35 - 0.28;
    scene.add(rrRock);
  }

  // WAVE FOAM ON CLIFFS — foam that crashes on the cliff rocks. Moved
  // forward of the hill body and depth-write enabled so the foam properly
  // gets occluded by the hill geometry (no more breakers showing through it).
  var cliffFoamSprites = [];
  for (var wf = 0; wf < 10; wf++) {
    var wfMat = new THREE.SpriteMaterial({
      map: foamSprayTex, transparent: true,
      opacity: 0.25 + Math.random() * 0.25,
      depthWrite: true,
      alphaTest: 0.05
    });
    var wfSprite = new THREE.Sprite(wfMat);
    var wfSize = 1.6 + Math.random() * 2.0;
    wfSprite.scale.set(wfSize, wfSize * 0.4, 1);
    // Tight band right at the cliff-water junction, biased forward (closer
    // to camera) so the foam is well clear of the hill body
    var wfX = -11 + Math.random() * 7;   // x: -11 to -4 (cliff-foot area)
    var wfZ = -8 + Math.random() * 1.5;  // z: -8 to -6.5 (front edge only)
    wfSprite.position.set(wfX, 0.25 + Math.random() * 0.6, wfZ);
    scene.add(wfSprite);
    cliffFoamSprites.push({
      sprite: wfSprite,
      baseX: wfX,
      baseY: wfSprite.position.y,
      baseZ: wfZ,
      phase: Math.random() * Math.PI * 2,
      speed: 0.5 + Math.random() * 0.8,
      crashSpeed: 1.5 + Math.random() * 2.5,
      crashPhase: Math.random() * Math.PI * 2,
      baseOpacity: wfMat.opacity,
      baseSize: wfSize
    });
  }

  // Rising sea mist — billowing mist plumes rising from cliff base
  var mistTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    grad.addColorStop(0, 'rgba(200, 210, 220, 0.5)');
    grad.addColorStop(0.4, 'rgba(180, 195, 210, 0.25)');
    grad.addColorStop(0.7, 'rgba(160, 175, 195, 0.08)');
    grad.addColorStop(1, 'rgba(140, 155, 175, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var cliffMistSprites = [];
  for (var mi = 0; mi < 6; mi++) {
    var miMat = new THREE.SpriteMaterial({
      map: mistTex, transparent: true,
      opacity: 0.18 + Math.random() * 0.15,
      depthWrite: true,
      alphaTest: 0.04
    });
    var miSprite = new THREE.Sprite(miMat);
    var miSize = 2.4 + Math.random() * 2.8;
    miSprite.scale.set(miSize, miSize * 0.7, 1);
    // Forward-only mist — same band as the cliff foam, well in front of the hill
    var miX = -11 + Math.random() * 7;
    var miZ = -8 + Math.random() * 1.5;
    miSprite.position.set(miX, 0.7 + Math.random() * 1.6, miZ);
    scene.add(miSprite);
    cliffMistSprites.push({
      sprite: miSprite,
      baseY: miSprite.position.y,
      baseOpacity: miMat.opacity,
      baseSize: miSize,
      riseSpeed: 0.1 + Math.random() * 0.15,
      driftPhase: Math.random() * Math.PI * 2,
      cycleSpeed: 0.3 + Math.random() * 0.5,
      cyclePhase: Math.random() * Math.PI * 2
    });
  }

  // ============================================================
  // DIDO'S PYRE — funeral pyre burning on the left headland, the focal point.
  // Distant but the visual centre of attention: stacked logs, a body silhouette,
  // dancing flames, dark smoke column rising into the sky.
  // ============================================================
  var PYRE_X = -14, PYRE_Y = 6.1, PYRE_Z = -14;
  // Distance-appropriate scale — the pyre sits across the bay so its real
  // geometry is modest (~2m wide) but the warm light and tall smoke column
  // make it dominant in the frame.
  var PS = 0.55; // pyre scale factor

  // Stone hearth — flat dark plinth so the pyre reads as built, not random embers
  var pyreHearth = new THREE.Mesh(
    new THREE.CylinderGeometry(0.9 * PS, 1.05 * PS, 0.18 * PS, 12),
    new THREE.MeshStandardMaterial({ color: 0x2a1d12, roughness: 0.95 })
  );
  pyreHearth.position.set(PYRE_X, PYRE_Y - 0.05, PYRE_Z);
  scene.add(pyreHearth);

  // Hot ember bed — glowing core
  var emberMat = new THREE.MeshStandardMaterial({
    color: 0xff5a18, roughness: 0.4,
    emissive: 0xff6020, emissiveIntensity: 1.6
  });
  var emberPile = new THREE.Mesh(new THREE.SphereGeometry(0.55 * PS, 12, 8), emberMat);
  emberPile.scale.set(1.4, 0.4, 1.2);
  emberPile.position.set(PYRE_X, PYRE_Y + 0.1, PYRE_Z);
  scene.add(emberPile);

  // Brighter inner core — molten centre
  var coreMat = new THREE.MeshStandardMaterial({
    color: 0xfff0c0, roughness: 0.3,
    emissive: 0xffd060, emissiveIntensity: 2.0
  });
  var pyreCore = new THREE.Mesh(new THREE.SphereGeometry(0.28 * PS, 10, 8), coreMat);
  pyreCore.scale.set(1.2, 0.3, 1.0);
  pyreCore.position.set(PYRE_X, PYRE_Y + 0.18, PYRE_Z);
  scene.add(pyreCore);

  // Stacked log courses — criss-cross of charred timbers
  var charredLogMat = new THREE.MeshStandardMaterial({
    color: 0x1a0e06, roughness: 0.95,
    emissive: 0x2a0e04, emissiveIntensity: 0.15
  });
  var glowingLogMat = new THREE.MeshStandardMaterial({
    color: 0x3a1a08, roughness: 0.9,
    emissive: 0xc04010, emissiveIntensity: 0.55
  });
  function pyreLog(x, y, z, len, thick, rotY, glowing) {
    var log = new THREE.Mesh(
      new THREE.CylinderGeometry(thick * PS, thick * 1.05 * PS, len * PS, 6),
      glowing ? glowingLogMat : charredLogMat
    );
    log.rotation.z = Math.PI / 2;
    log.rotation.y = rotY || 0;
    log.position.set(PYRE_X + x * PS, PYRE_Y + y * PS, PYRE_Z + z * PS);
    scene.add(log);
  }
  // Bottom course — long logs one way
  pyreLog(0, 0.03, -0.40, 3.2, 0.18, 0, true);
  pyreLog(0, 0.03,  0.40, 3.2, 0.18, 0, true);
  pyreLog(0.2, 0.03, 0.0, 3.0, 0.16, 0, false);
  // Second course — perpendicular
  pyreLog(-0.40, 0.36, 0.0, 2.6, 0.16, Math.PI / 2, true);
  pyreLog( 0.40, 0.36, 0.0, 2.6, 0.16, Math.PI / 2, true);
  // Third course
  pyreLog(0, 0.65, -0.30, 2.4, 0.14, 0, false);
  pyreLog(0, 0.65,  0.30, 2.4, 0.14, 0, true);
  // Top course — body rests on this
  pyreLog(-0.30, 0.92, 0.0, 2.0, 0.13, Math.PI / 2, false);
  pyreLog( 0.30, 0.92, 0.0, 2.0, 0.13, Math.PI / 2, false);

  // Body silhouette — dark shrouded form lying across the topmost course
  var shroudMat = new THREE.MeshStandardMaterial({
    color: 0x140a04, roughness: 0.95,
    emissive: 0x501f08, emissiveIntensity: 0.3
  });
  var shroudBody = new THREE.Mesh(
    new THREE.CylinderGeometry(0.22 * PS, 0.22 * PS, 1.6 * PS, 10),
    shroudMat
  );
  shroudBody.rotation.z = Math.PI / 2;
  shroudBody.position.set(PYRE_X, PYRE_Y + 1.18 * PS, PYRE_Z);
  scene.add(shroudBody);
  var shroudHead = new THREE.Mesh(new THREE.SphereGeometry(0.24 * PS, 10, 8), shroudMat);
  shroudHead.position.set(PYRE_X - 0.85 * PS, PYRE_Y + 1.22 * PS, PYRE_Z);
  scene.add(shroudHead);
  var shroudFoot = new THREE.Mesh(new THREE.SphereGeometry(0.20 * PS, 8, 6), shroudMat);
  shroudFoot.position.set(PYRE_X + 0.85 * PS, PYRE_Y + 1.18 * PS, PYRE_Z);
  scene.add(shroudFoot);

  // Charred fallen logs around the base of the pyre
  for (var fw = 0; fw < 6; fw++) {
    var stick = new THREE.Mesh(
      new THREE.CylinderGeometry((0.06 + Math.random() * 0.04) * PS,
        (0.07 + Math.random() * 0.04) * PS,
        (0.7 + Math.random() * 0.7) * PS, 5),
      charredLogMat
    );
    var sAng = Math.random() * Math.PI * 2;
    var sR = (1.0 + Math.random() * 0.4) * PS;
    stick.position.set(
      PYRE_X + Math.cos(sAng) * sR,
      PYRE_Y + 0.06,
      PYRE_Z + Math.sin(sAng) * sR
    );
    stick.rotation.z = Math.PI / 2 + (Math.random() - 0.5) * 0.3;
    stick.rotation.y = sAng + Math.PI / 2 + (Math.random() - 0.5) * 0.4;
    scene.add(stick);
  }

  // Flame sprites — tiny, low opacity, just a hint of orange at the base
  var flameTex = makeCanvasTexture(64, 128, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h * 0.7, 0, w/2, h * 0.4, w * 0.5);
    grad.addColorStop(0, 'rgba(255, 200, 120, 0.6)');
    grad.addColorStop(0.2, 'rgba(255, 140, 50, 0.35)');
    grad.addColorStop(0.5, 'rgba(200, 60, 15, 0.12)');
    grad.addColorStop(0.8, 'rgba(100, 20, 5, 0.04)');
    grad.addColorStop(1, 'rgba(50, 10, 0, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });

  var fireSprites = [];
  // Inner core flames — bright, white-hot at the heart of the pyre
  for (var fs = 0; fs < 5; fs++) {
    var fMat = new THREE.SpriteMaterial({
      map: flameTex, transparent: true, fog: false,
      opacity: 0.7 + Math.random() * 0.25,
      blending: THREE.AdditiveBlending
    });
    var fSprite = new THREE.Sprite(fMat);
    var fSize = (1.6 + Math.random() * 0.9) * PS;
    fSprite.scale.set(fSize * 0.65, fSize * 1.5, 1);
    fSprite.position.set(
      PYRE_X + (Math.random() - 0.5) * 0.4 * PS,
      PYRE_Y + (1.5 + Math.random() * 0.4) * PS,
      PYRE_Z + (Math.random() - 0.5) * 0.4 * PS
    );
    scene.add(fSprite);
    fireSprites.push({
      sprite: fSprite,
      baseX: fSprite.position.x,
      baseY: fSprite.position.y,
      baseZ: fSprite.position.z,
      baseSize: fSize,
      flickerSpeed: 3.0 + Math.random() * 4.5,
      flickerPhase: Math.random() * Math.PI * 2,
      swaySpeed: 1.0 + Math.random() * 2.0,
      swayPhase: Math.random() * Math.PI * 2,
      coreFlame: true
    });
  }
  // Outer licking flames — taller, softer, rising into smoke
  for (var fso = 0; fso < 6; fso++) {
    var foMat = new THREE.SpriteMaterial({
      map: flameTex, transparent: true, fog: false,
      opacity: 0.45 + Math.random() * 0.25,
      blending: THREE.AdditiveBlending
    });
    var foSprite = new THREE.Sprite(foMat);
    var foSize = (2.2 + Math.random() * 1.3) * PS;
    foSprite.scale.set(foSize * 0.55, foSize * 1.7, 1);
    foSprite.position.set(
      PYRE_X + (Math.random() - 0.5) * 0.8 * PS,
      PYRE_Y + (2.2 + Math.random() * 0.8) * PS,
      PYRE_Z + (Math.random() - 0.5) * 0.8 * PS
    );
    scene.add(foSprite);
    fireSprites.push({
      sprite: foSprite,
      baseX: foSprite.position.x,
      baseY: foSprite.position.y,
      baseZ: foSprite.position.z,
      baseSize: foSize,
      flickerSpeed: 1.8 + Math.random() * 3.0,
      flickerPhase: Math.random() * Math.PI * 2,
      swaySpeed: 0.6 + Math.random() * 1.4,
      swayPhase: Math.random() * Math.PI * 2,
      coreFlame: false
    });
  }

  // Fire point light — strong warm glow that lights the hilltop and shrouded body
  var fireLight = new THREE.PointLight(0xff6020, 7.5, 14, 1.6);
  fireLight.position.set(PYRE_X, PYRE_Y + 1.0, PYRE_Z);
  scene.add(fireLight);

  // Secondary halo light — broader, dimmer
  var fireHaloLight = new THREE.PointLight(0xff4810, 2.0, 10, 2);
  fireHaloLight.position.set(PYRE_X, PYRE_Y + 0.4, PYRE_Z);
  scene.add(fireHaloLight);

  // Rising embers — sparks lifting off the pyre
  var emberSpriteTex = makeCanvasTexture(16, 16, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    grad.addColorStop(0, 'rgba(255, 220, 140, 0.95)');
    grad.addColorStop(0.4, 'rgba(255, 140, 50, 0.6)');
    grad.addColorStop(1, 'rgba(200, 60, 10, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var emberSparks = [];
  for (var es = 0; es < 18; es++) {
    var esMat = new THREE.SpriteMaterial({
      map: emberSpriteTex, transparent: true, fog: false,
      opacity: 0.5 + Math.random() * 0.5,
      blending: THREE.AdditiveBlending, depthWrite: false
    });
    var esSprite = new THREE.Sprite(esMat);
    var esSize = (0.10 + Math.random() * 0.10) * PS;
    esSprite.scale.set(esSize, esSize, 1);
    var esOffsetX = (Math.random() - 0.5) * 0.5 * PS;
    var esOffsetZ = (Math.random() - 0.5) * 0.5 * PS;
    var esStartY = PYRE_Y + (1.0 + Math.random() * 1.4) * PS;
    esSprite.position.set(PYRE_X + esOffsetX, esStartY, PYRE_Z + esOffsetZ);
    scene.add(esSprite);
    emberSparks.push({
      sprite: esSprite,
      baseX: PYRE_X + esOffsetX,
      baseZ: PYRE_Z + esOffsetZ,
      startY: PYRE_Y + 0.8 * PS,
      maxY: PYRE_Y + (4.5 + Math.random() * 2.0) * PS,
      currentY: esStartY,
      riseSpeed: 0.5 + Math.random() * 1.0,
      swayPhase: Math.random() * Math.PI * 2,
      swaySpeed: 0.8 + Math.random() * 1.6,
      baseOpacity: esMat.opacity,
      baseSize: esSize
    });
  }

  // SMOKE — the main visual signal of the fire, big and visible
  var smokeTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    // Larger, more detailed smoke texture
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.48);
    grad.addColorStop(0, 'rgba(55, 45, 38, 0.35)');
    grad.addColorStop(0.3, 'rgba(65, 55, 45, 0.2)');
    grad.addColorStop(0.6, 'rgba(75, 65, 55, 0.08)');
    grad.addColorStop(1, 'rgba(80, 70, 60, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
    // Wispy detail inside the smoke
    for (var wi = 0; wi < 20; wi++) {
      var wx = w * 0.2 + Math.random() * w * 0.6;
      var wy = h * 0.2 + Math.random() * h * 0.6;
      cx.fillStyle = 'rgba(50,40,35,' + (0.03 + Math.random() * 0.06) + ')';
      cx.beginPath();
      cx.ellipse(wx, wy, 5 + Math.random() * 15, 4 + Math.random() * 10, Math.random() * Math.PI, 0, Math.PI * 2);
      cx.fill();
    }
  });
  var smokeSprites = [];
  // Tall climbing smoke column — the pyre's signal, visible from across the bay.
  // Dark and dense at the base, softening as it rises into the dusk sky.
  var SMOKE_COUNT = 16;
  for (var sm = 0; sm < SMOKE_COUNT; sm++) {
    var smMat = new THREE.SpriteMaterial({
      map: smokeTex, transparent: true, fog: false,
      opacity: 0.65 - sm * 0.022 + Math.random() * 0.1
    });
    // Sootier near the flame
    if (sm < 4) {
      smMat.color = new THREE.Color(0x1a1410);
    } else if (sm < 9) {
      smMat.color = new THREE.Color(0x36281e);
    }
    var smSprite = new THREE.Sprite(smMat);
    // Plume widens as it climbs
    var smSize = 1.4 + sm * 0.28 + Math.random() * 0.5;
    smSprite.scale.set(smSize, smSize * 1.35, 1);
    // Prevailing breeze drift — gently off-vertical
    var driftLean = sm * 0.22;
    smSprite.position.set(
      PYRE_X - driftLean + (Math.random() - 0.5) * 0.5,
      PYRE_Y + 1.6 + sm * 1.2 + Math.random() * 0.4,
      PYRE_Z + driftLean * 0.3 + (Math.random() - 0.5) * 0.5
    );
    scene.add(smSprite);
    smokeSprites.push({
      sprite: smSprite,
      baseX: smSprite.position.x,
      baseY: smSprite.position.y,
      baseLean: driftLean,
      driftSpeed: 0.10 + Math.random() * 0.18,
      swayPhase: Math.random() * Math.PI * 2,
      resetY: PYRE_Y + 1.6 + sm * 1.2
    });
  }

  // ============================================================
  // SUN — setting sun on the horizon, source of the warm golden light
  // ============================================================
  // Sun disc — glowing orb sitting on the horizon
  var sunTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    // Bright core fading to warm orange edge
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.48);
    grad.addColorStop(0, 'rgba(255, 120, 30, 0.8)');
    grad.addColorStop(0.15, 'rgba(230, 90, 20, 0.7)');
    grad.addColorStop(0.4, 'rgba(200, 65, 10, 0.4)');
    grad.addColorStop(0.7, 'rgba(160, 45, 5, 0.12)');
    grad.addColorStop(0.9, 'rgba(120, 30, 0, 0.03)');
    grad.addColorStop(1, 'rgba(80, 20, 0, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var sunSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: sunTex, transparent: true, fog: false,
    opacity: 0.6, blending: THREE.AdditiveBlending
  }));
  sunSprite.scale.set(6, 6, 1);
  sunSprite.position.set(-3, 2.5, -55);
  scene.add(sunSprite);

  // Sun halo — larger soft glow around the sun
  var haloTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.5);
    grad.addColorStop(0, 'rgba(220, 100, 20, 0.18)');
    grad.addColorStop(0.3, 'rgba(190, 70, 15, 0.07)');
    grad.addColorStop(0.7, 'rgba(150, 50, 10, 0.02)');
    grad.addColorStop(1, 'rgba(100, 30, 5, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var haloSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: haloTex, transparent: true, fog: false,
    opacity: 0.45, blending: THREE.AdditiveBlending
  }));
  haloSprite.scale.set(12, 12, 1);
  haloSprite.position.set(-3, 2.5, -56);
  scene.add(haloSprite);

  // ============================================================
  // CRESCENT MOON — above and to the left of the sun
  // ============================================================
  var moonTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    // Full circle — pale silver, rotated anticlockwise ~15 degrees
    cx.save();
    cx.translate(w/2, h/2);
    cx.rotate(-0.26); // ~15 degrees anticlockwise
    cx.fillStyle = 'rgba(220, 225, 240, 0.9)';
    cx.beginPath();
    cx.arc(0, 0, w * 0.35, 0, Math.PI * 2);
    cx.fill();
    // Cut out the dark part to make a crescent — offset circle, rotated with the rest
    cx.globalCompositeOperation = 'destination-out';
    cx.fillStyle = 'rgba(0, 0, 0, 1)';
    cx.beginPath();
    cx.arc(w * 0.12, 0, w * 0.3, 0, Math.PI * 2);
    cx.fill();
    cx.globalCompositeOperation = 'source-over';
    cx.restore();
    // Soft edge glow
    var moonGlow = cx.createRadialGradient(w/2, h/2, w * 0.25, w/2, h/2, w * 0.48);
    moonGlow.addColorStop(0, 'rgba(200, 210, 230, 0)');
    moonGlow.addColorStop(0.7, 'rgba(180, 195, 220, 0.06)');
    moonGlow.addColorStop(1, 'rgba(160, 180, 210, 0)');
    cx.fillStyle = moonGlow;
    cx.fillRect(0, 0, w, h);
  });
  var moonSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: moonTex, transparent: true, fog: false,
    opacity: 0.85
  }));
  moonSprite.scale.set(2.5, 2.5, 1);
  moonSprite.position.set(-7, 6.5, -50);
  scene.add(moonSprite);

  // Moonlight — subtle cool light from the crescent
  var moonLight = new THREE.PointLight(0x8090b0, 0.3, 50);
  moonLight.position.set(-7, 7, -48);
  scene.add(moonLight);

  // ============================================================
  // EARLY STARS — faint pinpoints appearing in the darkening sky
  // ============================================================
  var starTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    // Sharp bright core with soft glow
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    grad.addColorStop(0, 'rgba(255, 255, 255, 1.0)');
    grad.addColorStop(0.08, 'rgba(255, 255, 250, 0.95)');
    grad.addColorStop(0.2, 'rgba(240, 245, 255, 0.6)');
    grad.addColorStop(0.45, 'rgba(200, 220, 255, 0.2)');
    grad.addColorStop(0.7, 'rgba(160, 190, 240, 0.05)');
    grad.addColorStop(1, 'rgba(100, 140, 200, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var starPositions = [
    // Camera at (12,5.5,5) looking at (0,1.2,-12) — view centre at z:-55 is ~x:-30
    // So screen-left = x:-60 and below, screen-centre = x:-30, screen-right = x:0+
    // Stars should fill the blue upper-left sky
    // Far left of screen
    [-70, 18, -52], [-68, 22, -60], [-65, 20, -56], [-72, 17, -48],
    [-66, 24, -64], [-63, 19, -54], [-74, 21, -58], [-67, 23, -62],
    [-60, 18, -50], [-62, 22, -58],
    // Left of screen
    [-55, 20, -56], [-58, 17, -48], [-52, 23, -62], [-56, 21, -58],
    [-50, 19, -52], [-54, 24, -64], [-48, 21, -56], [-57, 18, -50],
    // Centre-left of screen
    [-45, 22, -58], [-42, 18, -50], [-40, 24, -64], [-38, 20, -54],
    [-44, 17, -48], [-36, 22, -60],
    // Near centre — a few
    [-33, 23, -62], [-30, 20, -56], [-28, 24, -66], [-31, 18, -50],
    // Just right of centre — sparse
    [-24, 21, -58], [-20, 18, -50], [-22, 23, -62],
    // Top of sky spread across
    [-60, 26, -68], [-45, 27, -72], [-35, 26, -68], [-25, 27, -70],
    [-50, 28, -74], [-70, 25, -66]
  ];
  var starSprites = [];
  for (var si = 0; si < starPositions.length; si++) {
    var sp = starPositions[si];
    var starMat = new THREE.SpriteMaterial({
      map: starTex, transparent: true, fog: false,
      opacity: 0.5 + Math.random() * 0.5,
      blending: THREE.AdditiveBlending
    });
    var star = new THREE.Sprite(starMat);
    var starSize = 0.4 + Math.random() * 0.6;
    star.scale.set(starSize, starSize, 1);
    star.position.set(sp[0], sp[1], sp[2]);
    scene.add(star);
    starSprites.push({
      sprite: star,
      baseOpacity: starMat.opacity,
      twinkleSpeed: 0.8 + Math.random() * 2.0,
      twinklePhase: Math.random() * Math.PI * 2
    });
  }

  // ============================================================
  // LIGHTING — warm golden hour with REAL shadows. Ambient & fill are kept
  // low so the sun's shadows actually read; the hemisphere light supplies
  // a cool sky/warm ground bounce so shadowed surfaces don't go pure black.
  // ============================================================
  var ambient = new THREE.AmbientLight(0x5a3e22, 0.15);
  scene.add(ambient);

  // Sky cool blue/purple, ground warm ochre — gives shadowed surfaces a
  // subtle cool tint and lit-from-above sun surfaces a slight warm uplift
  var hemi = new THREE.HemisphereLight(0x2c3878, 0x8a5a28, 0.3);
  scene.add(hemi);

  // SUN — dominant warm directional light. Lower position + bigger shadow map
  // so columns, walls and lintels cast long, sharp shadows across the scene.
  var sunLight = new THREE.DirectionalLight(0xff9a48, 1.5);
  sunLight.position.set(-12, 4, -40);
  sunLight.target.position.set(2, 0, 0);
  scene.add(sunLight.target);
  sunLight.castShadow = true;
  sunLight.shadow.mapSize.width = 2048;
  sunLight.shadow.mapSize.height = 2048;
  sunLight.shadow.camera.near = 0.5;
  sunLight.shadow.camera.far = 130;
  sunLight.shadow.camera.left = -40;
  sunLight.shadow.camera.right = 40;
  sunLight.shadow.camera.top = 25;
  sunLight.shadow.camera.bottom = -8;
  sunLight.shadow.bias = -0.0008;
  sunLight.shadow.normalBias = 0.04;
  scene.add(sunLight);

  // Soft fill — kept low so the shadow side stays clearly in shadow
  var fillLight = new THREE.DirectionalLight(0xc08030, 0.12);
  fillLight.position.set(12, 5, -30);
  scene.add(fillLight);

  var skyFill = new THREE.DirectionalLight(0x304060, 0.15);
  skyFill.position.set(0, 15, 5);
  scene.add(skyFill);

  // Horizon glow — kept modest so the shadowed side stays in shadow
  var horizonGlow = new THREE.PointLight(0xe08020, 0.5, 55);
  horizonGlow.position.set(-5, 1.0, -45);
  scene.add(horizonGlow);

  // Bounce lights kept very subtle — too much bounce flattens shadows
  var seaBounce = new THREE.PointLight(0x3050a0, 0.08, 35);
  seaBounce.position.set(0, -0.5, -20);
  scene.add(seaBounce);
  var groundBounce = new THREE.PointLight(0xa08050, 0.06, 20);
  groundBounce.position.set(2, 0.2, -2);
  scene.add(groundBounce);

  // After all geometry is built, enable shadow casting/receiving on every
  // solid mesh so the sun actually paints shadows across the scene. Done
  // via a single traversal so we don't have to touch every Mesh constructor.
  function enableSceneShadows(root) {
    root.traverse(function(obj) {
      if (!(obj instanceof THREE.Mesh)) return;
      // Skip planes that are decorative/foliage or are the sky/sea/fog —
      // these would either look wrong or kill performance
      var mat = obj.material;
      if (mat && (mat.transparent === true && (mat.opacity || 1) < 0.7)) return;
      if (mat === skyMat) return;
      if (mat === waveMat) return;
      // Receive everything; cast for solid stones, trees, ruins
      obj.receiveShadow = true;
      // Cast shadows on anything above ground that isn't a ground/water plane
      if (obj.position.y > 0.2 || (obj.geometry && obj.geometry.type !== 'PlaneGeometry')) {
        obj.castShadow = true;
      }
    });
  }
  // Defer until after the rest of the scene is fully assembled
  setTimeout(function() { enableSceneShadows(scene); }, 0);

  // ============================================================
  // FOG PLANES — Cecil Court style atmospheric layers
  // ============================================================
  var fogPlanes = [];

  // Warm golden ground haze
  var warmFogMat = new THREE.MeshBasicMaterial({
    color: 0x907040, transparent: true, opacity: 0.03,
    side: THREE.DoubleSide, depthWrite: false
  });
  for (var fi = 0; fi < 18; fi++) {
    var fMat = warmFogMat.clone();
    fMat.opacity = 0.02 + Math.random() * 0.025;
    var fogPlane = new THREE.Mesh(new THREE.PlaneGeometry(30, 5), fMat);
    fogPlane.position.set(
      (Math.random() - 0.5) * 20,
      0.5 + Math.random() * 2.5,
      -8 + fi * 1.5 + (Math.random() - 0.5) * 2
    );
    fogPlane.rotation.y = (Math.random() - 0.5) * 0.5;
    fogPlane.userData = {
      baseX: fogPlane.position.x,
      baseY: fogPlane.position.y,
      speed: 0.06 + Math.random() * 0.1,
      amplitude: 0.4 + Math.random() * 0.6,
      phase: Math.random() * Math.PI * 2
    };
    fogPlanes.push(fogPlane);
    scene.add(fogPlane);
  }

  // Sea haze — blue-grey mist over the water
  var seaHazeMat = new THREE.MeshBasicMaterial({
    color: 0x586878, transparent: true, opacity: 0.025,
    side: THREE.DoubleSide, depthWrite: false
  });
  for (var shi = 0; shi < 10; shi++) {
    var shMat = seaHazeMat.clone();
    shMat.opacity = 0.012 + Math.random() * 0.015;
    var seaHaze = new THREE.Mesh(new THREE.PlaneGeometry(35, 4), shMat);
    seaHaze.position.set(
      (Math.random() - 0.5) * 15,
      0.3 + Math.random() * 1.5,
      -15 - shi * 2.5 + Math.random()
    );
    seaHaze.rotation.y = (Math.random() - 0.5) * 0.3;
    seaHaze.userData = {
      baseX: seaHaze.position.x,
      baseY: seaHaze.position.y,
      speed: 0.04 + Math.random() * 0.08,
      amplitude: 0.3 + Math.random() * 0.5,
      phase: Math.random() * Math.PI * 2
    };
    fogPlanes.push(seaHaze);
    scene.add(seaHaze);
  }

  // Horizon glow — warm golden fog near the horizon line
  var horizFogMat = new THREE.MeshBasicMaterial({
    color: 0xb07828, transparent: true, opacity: 0.022,
    side: THREE.DoubleSide, depthWrite: false
  });
  for (var hfi = 0; hfi < 6; hfi++) {
    var hfMat = horizFogMat.clone();
    hfMat.opacity = 0.01 + Math.random() * 0.015;
    var hFog = new THREE.Mesh(new THREE.PlaneGeometry(40, 6), hfMat);
    hFog.position.set(
      (Math.random() - 0.5) * 10,
      1 + Math.random() * 3,
      -35 - hfi * 3 + Math.random() * 2
    );
    hFog.rotation.y = (Math.random() - 0.5) * 0.2;
    hFog.userData = {
      baseX: hFog.position.x,
      baseY: hFog.position.y,
      speed: 0.03 + Math.random() * 0.06,
      amplitude: 0.2 + Math.random() * 0.4,
      phase: Math.random() * Math.PI * 2
    };
    fogPlanes.push(hFog);
    scene.add(hFog);
  }

  // ============================================================
  // SEA-LEVEL MIST BAND — distinct atmospheric layer at the water surface
  // ============================================================
  var seaMistTex = makeCanvasTexture(256, 64, function(cx, w, h) {
    // Horizontal band with soft vertical falloff
    var grad = cx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0, 'rgba(140, 130, 110, 0)');
    grad.addColorStop(0.3, 'rgba(150, 140, 120, 0.12)');
    grad.addColorStop(0.5, 'rgba(160, 150, 130, 0.18)');
    grad.addColorStop(0.7, 'rgba(150, 140, 120, 0.12)');
    grad.addColorStop(1, 'rgba(140, 130, 110, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
    // Add some wispy variation
    for (var mi = 0; mi < 8; mi++) {
      var mx = Math.random() * w;
      var mw = 30 + Math.random() * 60;
      var mg = cx.createRadialGradient(mx, h/2, 0, mx, h/2, mw);
      mg.addColorStop(0, 'rgba(170, 160, 140, 0.06)');
      mg.addColorStop(1, 'rgba(150, 140, 120, 0)');
      cx.fillStyle = mg;
      cx.fillRect(0, 0, w, h);
    }
  });
  var seaMistSprites = [];
  for (var smi = 0; smi < 6; smi++) {
    var smMat = new THREE.SpriteMaterial({
      map: seaMistTex, transparent: true,
      opacity: 0.08 + Math.random() * 0.06,
      depthWrite: false
    });
    var smSprite = new THREE.Sprite(smMat);
    smSprite.scale.set(30 + Math.random() * 20, 2.5 + Math.random() * 1.5, 1);
    var smX = -15 + Math.random() * 20;
    var smZ = -14 - smi * 4 + Math.random() * 2;
    smSprite.position.set(smX, 0.5 + Math.random() * 0.8, smZ);
    scene.add(smSprite);
    seaMistSprites.push({
      sprite: smSprite,
      baseX: smX,
      driftSpeed: 0.008 + Math.random() * 0.015,
      baseOpacity: smMat.opacity,
      pulsePhase: Math.random() * Math.PI * 2
    });
  }

  // ============================================================
  // CLOUD SPRITES — bold, multi-coloured, visible
  // ============================================================
  function makeCloudTex(r, g, b, alpha) {
    return makeCanvasTexture(128, 128, function(cx, w, h) {
      var grad = cx.createRadialGradient(w/2, h * 0.55, 0, w/2, h/2, w/2);
      grad.addColorStop(0, 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')');
      grad.addColorStop(0.3, 'rgba(' + r + ',' + g + ',' + b + ',' + (alpha * 0.6) + ')');
      grad.addColorStop(0.65, 'rgba(' + r + ',' + g + ',' + b + ',' + (alpha * 0.2) + ')');
      grad.addColorStop(1, 'rgba(' + r + ',' + g + ',' + b + ',0)');
      cx.fillStyle = grad;
      cx.fillRect(0, 0, w, h);
    });
  }

  var hotPinkCloudTex = makeCloudTex(255, 80, 160, 0.55);
  var pinkCloudTex = makeCloudTex(240, 150, 150, 0.4);
  var goldCloudTex = makeCloudTex(255, 210, 110, 0.45);
  var purpleCloudTex = makeCloudTex(90, 65, 110, 0.35);
  var fireCloudTex = makeCloudTex(255, 150, 50, 0.45);

  var cloudSprites = [];

  // High purple clouds
  for (var ci = 0; ci < 12; ci++) {
    var cMat = new THREE.SpriteMaterial({
      map: purpleCloudTex, transparent: true, fog: false,
      opacity: 0.4 + Math.random() * 0.3
    });
    var cS = new THREE.Sprite(cMat);
    cS.position.set(-40 + Math.random() * 80, 20 + Math.random() * 12, -40 - Math.random() * 20);
    var cs = 18 + Math.random() * 28;
    cS.scale.set(cs, cs * 0.2, 1);
    scene.add(cS);
    cloudSprites.push({
      sprite: cS, baseX: cS.position.x, baseY: cS.position.y, baseZ: cS.position.z,
      drift: 0.003 + Math.random() * 0.005,
      swirl: Math.random() * Math.PI * 2, swirlSpeed: 0.001 + Math.random() * 0.002,
      swirlAmtX: 1.0 + Math.random() * 1.8, swirlAmtY: 0.2 + Math.random() * 0.4,
      baseScale: cs, scalePhase: Math.random() * Math.PI * 2, scalePulse: 0.0005 + Math.random() * 0.001
    });
  }

  // Mid pink and gold clouds
  for (var ci2 = 0; ci2 < 16; ci2++) {
    var tex = ci2 % 2 === 0 ? pinkCloudTex : goldCloudTex;
    var cMat2 = new THREE.SpriteMaterial({
      map: tex, transparent: true, fog: false,
      opacity: 0.45 + Math.random() * 0.3
    });
    var cS2 = new THREE.Sprite(cMat2);
    cS2.position.set(-35 + Math.random() * 70, 9 + Math.random() * 10, -30 - Math.random() * 22);
    var cs2 = 12 + Math.random() * 20;
    cS2.scale.set(cs2, cs2 * 0.18, 1);
    scene.add(cS2);
    cloudSprites.push({
      sprite: cS2, baseX: cS2.position.x, baseY: cS2.position.y, baseZ: cS2.position.z,
      drift: 0.004 + Math.random() * 0.007,
      swirl: Math.random() * Math.PI * 2, swirlSpeed: 0.0012 + Math.random() * 0.003,
      swirlAmtX: 1.2 + Math.random() * 2.2, swirlAmtY: 0.3 + Math.random() * 0.5,
      baseScale: cs2, scalePhase: Math.random() * Math.PI * 2, scalePulse: 0.0006 + Math.random() * 0.001
    });
  }

  // Low fire clouds near horizon
  for (var ci3 = 0; ci3 < 10; ci3++) {
    var cMat3 = new THREE.SpriteMaterial({
      map: fireCloudTex, transparent: true, fog: false,
      opacity: 0.5 + Math.random() * 0.3
    });
    var cS3 = new THREE.Sprite(cMat3);
    cS3.position.set(-28 + Math.random() * 56, 4 + Math.random() * 5, -32 - Math.random() * 18);
    var cs3 = 10 + Math.random() * 16;
    cS3.scale.set(cs3, cs3 * 0.16, 1);
    scene.add(cS3);
    cloudSprites.push({
      sprite: cS3, baseX: cS3.position.x, baseY: cS3.position.y, baseZ: cS3.position.z,
      drift: 0.005 + Math.random() * 0.009,
      swirl: Math.random() * Math.PI * 2, swirlSpeed: 0.0015 + Math.random() * 0.003,
      swirlAmtX: 0.8 + Math.random() * 1.4, swirlAmtY: 0.15 + Math.random() * 0.3,
      baseScale: cs3, scalePhase: Math.random() * Math.PI * 2, scalePulse: 0.0008 + Math.random() * 0.001
    });
  }

  // Bright pink thin streaks — vivid horizontal bands across the sky
  for (var ci4 = 0; ci4 < 14; ci4++) {
    var cMat4 = new THREE.SpriteMaterial({
      map: hotPinkCloudTex, transparent: true, fog: false,
      opacity: 0.55 + Math.random() * 0.3
    });
    var cS4 = new THREE.Sprite(cMat4);
    // Very wide, very flat — thin horizontal streaks
    var cs4w = 25 + Math.random() * 35;
    var cs4h = cs4w * 0.04;  // extremely thin
    cS4.scale.set(cs4w, cs4h, 1);
    cS4.position.set(
      -30 + Math.random() * 60,
      6 + Math.random() * 9,     // spread across mid-sky
      -28 - Math.random() * 20
    );
    scene.add(cS4);
    cloudSprites.push({
      sprite: cS4, baseX: cS4.position.x, baseY: cS4.position.y, baseZ: cS4.position.z,
      drift: 0.004 + Math.random() * 0.007,
      swirl: Math.random() * Math.PI * 2, swirlSpeed: 0.0008 + Math.random() * 0.0015,
      swirlAmtX: 0.5 + Math.random() * 1.0, swirlAmtY: 0.05 + Math.random() * 0.1,
      baseScale: cs4w, scalePhase: Math.random() * Math.PI * 2, scalePulse: 0.0003 + Math.random() * 0.0005
    });
  }

  // ============================================================
  // ANIMATION
  // ============================================================
  // ============================================================
  // FAKE BLOOM — larger soft glows behind bright elements
  // ============================================================
  // Moon bloom — soft cool halo behind the crescent
  var moonBloomTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.48);
    grad.addColorStop(0, 'rgba(180, 195, 230, 0.2)');
    grad.addColorStop(0.3, 'rgba(150, 170, 210, 0.08)');
    grad.addColorStop(0.7, 'rgba(120, 145, 190, 0.02)');
    grad.addColorStop(1, 'rgba(80, 110, 160, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var moonBloom = new THREE.Sprite(new THREE.SpriteMaterial({
    map: moonBloomTex, transparent: true, fog: false,
    opacity: 0.6, blending: THREE.AdditiveBlending
  }));
  moonBloom.scale.set(8, 8, 1);
  moonBloom.position.set(-7, 6.5, -51);
  scene.add(moonBloom);

  // Ember bloom — warm glow around the fire
  var emberBloomTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.48);
    grad.addColorStop(0, 'rgba(255, 100, 30, 0.2)');
    grad.addColorStop(0.3, 'rgba(220, 70, 15, 0.08)');
    grad.addColorStop(0.7, 'rgba(180, 50, 10, 0.02)');
    grad.addColorStop(1, 'rgba(120, 30, 5, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var emberBloom = new THREE.Sprite(new THREE.SpriteMaterial({
    map: emberBloomTex, transparent: true, fog: false,
    opacity: 0.5, blending: THREE.AdditiveBlending
  }));
  emberBloom.scale.set(6, 6, 1);
  emberBloom.position.set(-14, 6.4, -14.5);
  scene.add(emberBloom);

  // ============================================================
  // ATMOSPHERIC PARTICLES — dust motes in the warm light
  // ============================================================
  var dustTex = makeCanvasTexture(16, 16, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    grad.addColorStop(0, 'rgba(255, 230, 180, 0.8)');
    grad.addColorStop(0.5, 'rgba(240, 210, 160, 0.3)');
    grad.addColorStop(1, 'rgba(200, 180, 140, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var dustMotes = [];
  for (var di = 0; di < 40; di++) {
    var dMat = new THREE.SpriteMaterial({
      map: dustTex, transparent: true,
      opacity: 0.08 + Math.random() * 0.15,
      blending: THREE.AdditiveBlending, depthWrite: false
    });
    var dSprite = new THREE.Sprite(dMat);
    var dSize = 0.05 + Math.random() * 0.12;
    dSprite.scale.set(dSize, dSize, 1);
    // Scatter through the mid-air of the scene, mostly in the warm-lit area
    var dX = -12 + Math.random() * 28;
    var dY = 1.0 + Math.random() * 6;
    var dZ = -2 + Math.random() * -15;
    dSprite.position.set(dX, dY, dZ);
    scene.add(dSprite);
    dustMotes.push({
      sprite: dSprite,
      baseX: dX, baseY: dY, baseZ: dZ,
      driftX: 0.01 + Math.random() * 0.03,
      driftY: 0.005 + Math.random() * 0.015,
      floatSpeed: 0.2 + Math.random() * 0.5,
      floatPhase: Math.random() * Math.PI * 2,
      baseOpacity: dMat.opacity
    });
  }

  // ============================================================
  // FAKED WATER REFLECTIONS — inverted, wobbly, low-opacity copies below water
  // ============================================================
  // Moon reflection — stretched and softened
  var moonReflTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    grad.addColorStop(0, 'rgba(180, 195, 220, 0.4)');
    grad.addColorStop(0.3, 'rgba(150, 170, 200, 0.15)');
    grad.addColorStop(0.7, 'rgba(120, 145, 180, 0.04)');
    grad.addColorStop(1, 'rgba(80, 100, 140, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var moonRefl = new THREE.Sprite(new THREE.SpriteMaterial({
    map: moonReflTex, transparent: true, opacity: 0.25,
    blending: THREE.AdditiveBlending, depthWrite: false
  }));
  // Mirror the moon position (y:-7, 6.5, -50) down below the water plane
  moonRefl.scale.set(3.5, 5.0, 1); // stretched vertically for watery look
  moonRefl.position.set(-7, -0.6, -25);
  scene.add(moonRefl);

  // Sun reflection path — long golden streak on the water
  var sunReflTex = makeCanvasTexture(128, 32, function(cx, w, h) {
    var grad = cx.createLinearGradient(0, 0, w, 0);
    grad.addColorStop(0, 'rgba(200, 100, 20, 0)');
    grad.addColorStop(0.3, 'rgba(220, 120, 30, 0.15)');
    grad.addColorStop(0.5, 'rgba(240, 140, 40, 0.25)');
    grad.addColorStop(0.7, 'rgba(220, 120, 30, 0.15)');
    grad.addColorStop(1, 'rgba(200, 100, 20, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var sunRefl = new THREE.Sprite(new THREE.SpriteMaterial({
    map: sunReflTex, transparent: true, opacity: 0.3,
    blending: THREE.AdditiveBlending, depthWrite: false, fog: false
  }));
  sunRefl.scale.set(18, 1.5, 1);
  sunRefl.position.set(-3, -0.3, -22);
  scene.add(sunRefl);

  // Column silhouette reflections — dark smudges in the water near the columns
  var colReflTex = makeCanvasTexture(32, 64, function(cx, w, h) {
    var grad = cx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0, 'rgba(60, 50, 40, 0.2)');
    grad.addColorStop(0.4, 'rgba(50, 45, 35, 0.1)');
    grad.addColorStop(1, 'rgba(40, 35, 30, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  // A few dark reflections for the nearest visible columns
  var colReflPositions = [[-10, -5], [-8, -5], [-6, -5], [4, -5], [6, -5], [8, -5]];
  for (var cri = 0; cri < colReflPositions.length; cri++) {
    var crp = colReflPositions[cri];
    var crSprite = new THREE.Sprite(new THREE.SpriteMaterial({
      map: colReflTex, transparent: true, opacity: 0.12 + Math.random() * 0.08,
      depthWrite: false
    }));
    crSprite.scale.set(0.8, 3.0 + Math.random() * 1.5, 1);
    crSprite.position.set(crp[0], -0.5, crp[1] - 6 - Math.random() * 2);
    scene.add(crSprite);
  }

  // ============================================================
  // VIGNETTE — darkened edges for cinematic framing
  // ============================================================
  var vignetteCanvas = document.createElement('canvas');
  vignetteCanvas.width = 512; vignetteCanvas.height = 512;
  var vigCx = vignetteCanvas.getContext('2d');
  var vigGrad = vigCx.createRadialGradient(256, 256, 80, 256, 256, 360);
  vigGrad.addColorStop(0, 'rgba(0, 0, 0, 0)');
  vigGrad.addColorStop(0.5, 'rgba(0, 0, 0, 0)');
  vigGrad.addColorStop(0.75, 'rgba(5, 3, 0, 0.15)');
  vigGrad.addColorStop(0.9, 'rgba(8, 4, 0, 0.35)');
  vigGrad.addColorStop(1, 'rgba(10, 5, 0, 0.55)');
  vigCx.fillStyle = vigGrad;
  vigCx.fillRect(0, 0, 512, 512);
  var vignetteTex = new THREE.CanvasTexture(vignetteCanvas);
  var vignetteMat = new THREE.SpriteMaterial({
    map: vignetteTex, transparent: true, depthTest: false, depthWrite: false
  });
  var vignetteSprite = new THREE.Sprite(vignetteMat);
  // Attach to camera so it always fills the screen
  vignetteSprite.scale.set(4.5, 3.0, 1);
  vignetteSprite.position.set(0, 0, -1.5);
  camera.add(vignetteSprite);
  scene.add(camera);

  var clock = new THREE.Clock();

  // Store camera base for breathing
  var camBaseX = 12, camBaseY = 5.5, camBaseZ = 5;
  var lookBaseX = 0, lookBaseY = 1.2, lookBaseZ = -12;

  function caAnimate() {
    caAnimId = requestAnimationFrame(caAnimate);
    var t = clock.getElapsedTime();

    // Camera breathing — very slow, gentle drift like being alive in the scene
    var breathX = Math.sin(t * 0.08) * 0.06 + Math.sin(t * 0.13) * 0.03;
    var breathY = Math.sin(t * 0.06) * 0.04 + Math.cos(t * 0.11) * 0.02;
    var breathZ = Math.cos(t * 0.07) * 0.03;
    camera.position.set(camBaseX + breathX, camBaseY + breathY, camBaseZ + breathZ);
    // Look target drifts very slightly too — subtle parallax
    var lookDrift = Math.sin(t * 0.05) * 0.04;
    camera.lookAt(lookBaseX + lookDrift, lookBaseY + Math.sin(t * 0.04) * 0.02, lookBaseZ);

    // Sunset breathing
    var sunPulse = 1.0 + Math.sin(t * 0.12) * 0.05 + Math.sin(t * 0.31) * 0.025;
    sunLight.intensity = 1.5 * sunPulse;
    horizonGlow.intensity = 0.5 * sunPulse;

    // Sea shimmer — more visible colour shifting
    seaMat.emissiveIntensity = 0.1 + Math.sin(t * 0.4) * 0.08 + Math.sin(t * 0.9) * 0.04;
    shallowSeaMat.emissiveIntensity = 0.08 + Math.sin(t * 0.55) * 0.06;
    surfZoneMat.emissiveIntensity = 0.08 + Math.sin(t * 0.6 + 0.5) * 0.05;

    // Reflection path sway — more obvious shimmer
    reflectionMat.opacity = 0.15 + Math.sin(t * 0.4) * 0.1 + Math.sin(t * 0.85) * 0.05;
    reflection.position.x = -3 + Math.sin(t * 0.2) * 0.8;

    // Fog plane drift
    for (var fi = 0; fi < fogPlanes.length; fi++) {
      var fp = fogPlanes[fi];
      var ud = fp.userData;
      fp.position.x = ud.baseX + Math.sin(t * ud.speed + ud.phase) * ud.amplitude;
      fp.position.y = ud.baseY + Math.sin(t * ud.speed * 0.7 + ud.phase + 1) * ud.amplitude * 0.25;
    }

    // Swirling clouds
    for (var ci = 0; ci < cloudSprites.length; ci++) {
      var c = cloudSprites[ci];
      c.baseX += c.drift;
      if (c.baseX > 55) c.baseX = -50;
      c.swirl += c.swirlSpeed;
      c.sprite.position.x = c.baseX + Math.sin(c.swirl) * c.swirlAmtX;
      c.sprite.position.y = c.baseY + Math.cos(c.swirl * 0.7) * c.swirlAmtY;
      c.sprite.position.z = c.baseZ + Math.sin(c.swirl * 0.4) * 0.8;
      c.scalePhase += c.scalePulse;
      var sp = 1.0 + Math.sin(c.scalePhase) * 0.06;
      c.sprite.scale.x = c.baseScale * sp;
      c.sprite.scale.y = c.baseScale * 0.2 * sp;
    }

    // Fire animation — subtle ember glow, tiny flame hints
    for (var fsi = 0; fsi < fireSprites.length; fsi++) {
      var fs = fireSprites[fsi];
      // Very gentle — barely flickering, like a distant campfire
      var flicker = 0.85 + Math.sin(t * fs.flickerSpeed * 0.25 + fs.flickerPhase) * 0.08;
      fs.sprite.scale.y = fs.baseSize * 0.9 * flicker;
      fs.sprite.scale.x = fs.baseSize * 0.45 * (0.95 + Math.sin(t * fs.flickerSpeed * 0.3) * 0.04);
      fs.sprite.position.x = fs.baseX + Math.sin(t * fs.swaySpeed * 0.3 + fs.swayPhase) * 0.02;
      fs.sprite.material.opacity = 0.25 + flicker * 0.12;
    }
    // Fire light — steady warm glow lighting up the hilltop
    fireLight.intensity = 3.5 + Math.sin(t * 1.2) * 0.5 + Math.sin(t * 2.3) * 0.3;
    // Ember glow — very slow breathing
    emberMat.emissiveIntensity = 0.5 + Math.sin(t * 0.5) * 0.1;
    // Rising ember sparks — climb upward from the flame, swaying gently,
    // fading near the top, then teleport back down to begin again. Cycle
    // continuously so the pyre always has a stream of sparks lifting off.
    for (var esi = 0; esi < emberSparks.length; esi++) {
      var es = emberSparks[esi];
      es.currentY += es.riseSpeed * 0.016;
      es.sprite.position.y = es.currentY;
      // Gentle horizontal drift as the spark climbs
      es.sprite.position.x = es.baseX + Math.sin(t * es.swaySpeed + es.swayPhase) * 0.18;
      es.sprite.position.z = es.baseZ + Math.cos(t * es.swaySpeed * 0.7 + es.swayPhase) * 0.18;
      // Fade as the spark cools/rises
      var lifeFrac = (es.currentY - es.startY) / (es.maxY - es.startY);
      es.sprite.material.opacity = es.baseOpacity * Math.max(0, 1 - lifeFrac * lifeFrac);
      // Slight scale pulse — embers shimmer in and out
      var pulse = 0.85 + Math.sin(t * 6 + es.swayPhase) * 0.15;
      es.sprite.scale.set(es.baseSize * pulse, es.baseSize * pulse, 1);
      // Recycle when it reaches the top or dies
      if (es.currentY >= es.maxY || es.sprite.material.opacity <= 0.02) {
        es.currentY = es.startY + Math.random() * 0.4;
        es.sprite.material.opacity = es.baseOpacity;
        es.sprite.position.x = es.baseX;
        es.sprite.position.z = es.baseZ;
      }
    }
    // Smoke drift upward — the main visual signal of the fire
    for (var smi = 0; smi < smokeSprites.length; smi++) {
      var sm = smokeSprites[smi];
      sm.sprite.position.y += sm.driftSpeed * 0.016;
      sm.sprite.position.x = sm.baseX + Math.sin(t * 0.3 + sm.swayPhase) * 0.8;
      sm.sprite.material.opacity -= 0.0005;  // fades slower so smoke lingers
      sm.sprite.scale.x += 0.004;  // spreads wider as it rises
      sm.sprite.scale.y += 0.003;
      // Reset smoke when it fades or gets too high
      if (sm.sprite.material.opacity < 0.02 || sm.sprite.position.y > sm.resetY + 8) {
        sm.sprite.position.y = sm.resetY;
        sm.sprite.position.x = sm.baseX;
        sm.sprite.material.opacity = 0.28 + Math.random() * 0.18;
        var newSize = 0.8 + Math.random() * 1.0;
        sm.sprite.scale.set(newSize, newSize * 1.3, 1);
      }
    }

    // Foam waves — rolling in along the curved coastline
    var wp = Math.sin(t * 0.5);
    foamMat.opacity = 0.45 + wp * 0.25 + Math.sin(t * 1.1) * 0.1;
    foam2Mat.opacity = 0.2 + Math.sin(t * 0.5 + 1.5) * 0.18;
    // Centre-right foam advances/retreats in z
    foam.position.z = -9 + wp * 0.6;
    foam2.position.z = -7.5 + Math.sin(t * 0.5 + 1.2) * 0.5;
    // Left angled foam — same wave motion but along its angled axis
    foamL.position.z = -10.5 + wp * 0.5;
    foam2L.position.z = -9 + Math.sin(t * 0.5 + 1.2) * 0.4;
    // Left foam opacity matches right
    foamL.material.opacity = foamMat.opacity;
    foam2L.material.opacity = foam2Mat.opacity;

    // Foam patch animation — ebb and flow
    for (var fpi = 0; fpi < foamPatches.length; fpi++) {
      var fpatch = foamPatches[fpi];
      var foamWave = Math.sin(t * fpatch.speed + fpatch.phase);
      fpatch.sprite.position.z = fpatch.baseZ + foamWave * 0.8;
      fpatch.sprite.material.opacity = fpatch.baseOpacity * (0.3 + (1 + foamWave) * 0.5);
    }
    // Lapping foam advance and retreat
    var lapWave = Math.sin(t * 0.5) * 0.6 + Math.sin(t * 0.9) * 0.25;
    lappingFoam.position.z = -8.5 + lapWave;
    lappingFoamL.position.z = -10 + lapWave * 0.8;
    lappingFoamMat.opacity = 0.3 + Math.sin(t * 0.5) * 0.25;
    lappingFoamL.material.opacity = lappingFoamMat.opacity;
    // Third foam line
    var f3Wave = Math.sin(t * 0.4 + 0.8) * 0.5;
    foam3.position.z = -12 + f3Wave;
    foam3L.position.z = -13 + f3Wave * 0.8;
    foam3Mat.opacity = 0.15 + Math.sin(t * 0.4 + 0.8) * 0.15;
    foam3L.material.opacity = foam3Mat.opacity;

    // Cliff wave foam — gentle swells around rocks, misty not crashing
    for (var cfi = 0; cfi < cliffFoamSprites.length; cfi++) {
      var cf = cliffFoamSprites[cfi];
      // Gentle swell — slow sinusoidal, no sharp surge
      var swell = Math.sin(t * cf.speed * 0.5 + cf.phase) * 0.5 + 0.5;
      cf.sprite.position.z = cf.baseZ + Math.sin(t * cf.speed * 0.4 + cf.phase) * 0.3;
      cf.sprite.position.y = cf.baseY + swell * 0.3;
      cf.sprite.material.opacity = cf.baseOpacity * (0.5 + swell * 0.4);
      // Gentle breathing scale
      var breathe = 1.0 + swell * 0.25;
      cf.sprite.scale.x = cf.baseSize * breathe;
      cf.sprite.scale.y = cf.baseSize * 0.5 * breathe;
    }

    // Cliff mist — slow billowing, persistent haze
    for (var mii = 0; mii < cliffMistSprites.length; mii++) {
      var cm = cliffMistSprites[mii];
      // Slow cycle — mist drifts up gently, always partially visible
      var cycle = (t * cm.cycleSpeed * 0.5 + cm.cyclePhase) % (Math.PI * 2);
      var rise = Math.max(0, Math.sin(cycle));
      cm.sprite.position.y = cm.baseY + rise * 1.2;
      // Stays visible even at low points — persistent mist
      cm.sprite.material.opacity = cm.baseOpacity * (0.6 + rise * 0.4);
      var expand = 1.0 + rise * 0.3;
      cm.sprite.scale.set(cm.baseSize * expand, cm.baseSize * 0.7 * expand, 1);
      // Very gentle drift
      cm.sprite.position.x += Math.sin(t * 0.12 + cm.driftPhase) * 0.001;
    }

    // Tidal breathing — more noticeable
    var tide = Math.sin(t * 0.1) * 0.06;
    surfZone.position.y = -0.08 + tide;
    sea.position.y = -0.18 + tide;
    shallowSea.position.y = -0.12 + tide;
    deepSea.position.y = -0.22 + tide;
    waveSurface.position.y = -0.1 + tide;

    // Wave surface — animate vertex displacement for moving swell
    var _wposA = waveGeo.attributes.position;
    for (var wvi = 0; wvi < _wposA.count; wvi++) {
      var wb = waveBase[wvi];
      var hh = Math.sin(t * 0.55 + wb.phase + wb.x * 0.18) * 0.10
             + Math.sin(t * 0.33 + wb.y * 0.14 + wb.phase * 0.5) * 0.06
             + Math.sin(t * 0.95 + wb.x * 0.42) * 0.025;
      _wposA.setZ(wvi, hh);
    }
    _wposA.needsUpdate = true;
    waveGeo.computeVertexNormals();

    // Sail drift — very slow sideways movement with gentle bob
    for (var ssi = 0; ssi < sailSprites.length; ssi++) {
      var sls = sailSprites[ssi];
      sls.sprite.position.x = sls.baseX + t * sls.driftSpeed;
      while (sls.sprite.position.x > sls.baseX + 60) sls.sprite.position.x -= 120;
      sls.sprite.position.y = sls.baseY + Math.sin(t * 0.25 + sls.bobPhase) * 0.04;
    }

    // Seabirds — glide across the sky, bob slightly, weave in depth
    for (var bdi = 0; bdi < birds.length; bdi++) {
      var bd = birds[bdi];
      bd.sprite.position.x += bd.dir * bd.speed * 0.04;
      if (bd.sprite.position.x > 35) bd.sprite.position.x = -35;
      if (bd.sprite.position.x < -35) bd.sprite.position.x = 35;
      bd.sprite.position.y = bd.baseY + Math.sin(t * bd.bobSpeed + bd.bobPhase) * 0.35;
      bd.sprite.position.z = bd.baseZ + Math.sin(t * 0.3 + bd.zPhase) * 2.5;
    }

    // Sea mist drift — very slow lateral movement
    for (var smii = 0; smii < seaMistSprites.length; smii++) {
      var sms = seaMistSprites[smii];
      sms.sprite.position.x = sms.baseX + t * sms.driftSpeed * 5;
      // Wrap around when drifted too far
      if (sms.sprite.position.x > sms.baseX + 15) sms.sprite.position.x -= 30;
      sms.sprite.material.opacity = sms.baseOpacity * (0.7 + Math.sin(t * 0.15 + sms.pulsePhase) * 0.3);
    }

    // Bloom pulsing — gentle breathe on halos
    moonBloom.material.opacity = 0.5 + Math.sin(t * 0.3) * 0.1;
    moonBloom.scale.set(8 + Math.sin(t * 0.2) * 0.4, 8 + Math.sin(t * 0.2) * 0.4, 1);
    emberBloom.material.opacity = 0.4 + Math.sin(t * 1.0) * 0.15 + Math.sin(t * 1.8) * 0.08;
    var ebScale = 6 + Math.sin(t * 0.8) * 0.5;
    emberBloom.scale.set(ebScale, ebScale, 1);

    // Dust motes — lazy floating in warm light
    for (var dmi = 0; dmi < dustMotes.length; dmi++) {
      var dm = dustMotes[dmi];
      dm.sprite.position.x = dm.baseX + Math.sin(t * dm.driftX * 3 + dm.floatPhase) * 0.5;
      dm.sprite.position.y = dm.baseY + Math.sin(t * dm.floatSpeed + dm.floatPhase) * 0.3;
      dm.sprite.position.z = dm.baseZ + Math.cos(t * dm.driftX * 2 + dm.floatPhase) * 0.3;
      // Fade in and out gently
      var dustFade = 0.5 + Math.sin(t * dm.floatSpeed * 0.7 + dm.floatPhase) * 0.5;
      dm.sprite.material.opacity = dm.baseOpacity * dustFade;
    }

    // Water reflections — gentle wobble
    moonRefl.position.x = -7 + Math.sin(t * 0.3) * 0.15;
    moonRefl.position.y = -0.6 + Math.sin(t * 0.25) * 0.05;
    moonRefl.material.opacity = 0.2 + Math.sin(t * 0.4) * 0.06;
    moonRefl.scale.y = 5.0 + Math.sin(t * 0.6) * 0.5;
    sunRefl.position.x = -3 + Math.sin(t * 0.2) * 0.2;
    sunRefl.material.opacity = 0.25 + Math.sin(t * 0.35) * 0.08;
    sunRefl.scale.x = 18 + Math.sin(t * 0.15) * 2;

    // Star twinkling — gentle shimmer
    for (var sti = 0; sti < starSprites.length; sti++) {
      var ss = starSprites[sti];
      var twinkle = 0.7 + Math.sin(t * ss.twinkleSpeed + ss.twinklePhase) * 0.3;
      ss.sprite.material.opacity = ss.baseOpacity * twinkle;
    }

    renderer.render(scene, camera);
  }


  // ── ENTER BUTTON ── matched to the other approach-scene buttons
  // (Ginger Light, French House, etc.) — dark transparent background,
  // warm amber outline + text.
  var caBtn = document.createElement('div');
  caBtn.textContent = 'ENTER CARTHAGE';
  caBtn.style.cssText = [
    'position:fixed',
    'bottom:60px',
    'left:50%',
    'transform:translateX(-50%)',
    'font:13px "Courier New",monospace',
    'color:rgba(232,120,24,0.85)',
    'letter-spacing:4px',
    'cursor:pointer',
    'padding:12px 28px',
    'border:1px solid rgba(232,120,24,0.3)',
    'background:rgba(0,0,0,0.4)',
    'z-index:9004',
    'white-space:nowrap',
    'opacity:0',
    'transition:opacity 1.5s ease'
  ].join(';');
  setTimeout(function() { caBtn.style.opacity = '1'; }, 1500);
  caBtn.addEventListener('mouseenter', function() {
    this.style.color = 'rgba(255,160,50,0.95)';
    this.style.borderColor = 'rgba(232,120,24,0.6)';
  });
  caBtn.addEventListener('mouseleave', function() {
    this.style.color = 'rgba(232,120,24,0.85)';
    this.style.borderColor = 'rgba(232,120,24,0.3)';
  });
  caBtn.addEventListener('click', function() {
    caWrap.style.transition = 'opacity 1.5s ease';
    caWrap.style.opacity = '0';
    setTimeout(function() {
      if (caWrap && caWrap.parentNode) caWrap.parentNode.removeChild(caWrap);
      var TARGET = 'Carthage shore';
      if (window.Engine && Engine.go) { Engine.go(TARGET); }
      else {
        var links = document.querySelectorAll('tw-link, .enchantment-link');
        for (var i = 0; i < links.length; i++) {
          if (links[i].textContent.trim() === '\u00b7') { links[i].click(); break; }
        }
      }
    }, 1500);
  });
  caWrap.appendChild(caBtn);
  document.body.appendChild(caWrap);
  caAnimate();
}

setInterval(function() {
  var container = document.getElementById('carthage-approach');
  if (container && !caActive) { initCa(); }
  else if (!container) {
    caActive = false;
    if (caAnimId) { cancelAnimationFrame(caAnimId); caAnimId = null; }
    window._dssDisposeWrap('ca-wrap');
  }
}, 300);
})();
// ====== THE GREEN SEA — FULLSCREEN IFRAME ======
(function() {
var gsActive = false;
var gsWrap = null;
function initGreenSea() {
if (gsActive) return;
gsActive = true;
gsWrap = document.createElement('div');
gsWrap.id = 'gs-wrap';
gsWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';
var gsFrame = document.createElement('iframe');
gsFrame.src = 'green-sea-3d-static.html';
gsFrame.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;';
gsWrap.appendChild(gsFrame);
var vig = document.createElement('div');
vig.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9001;pointer-events:none;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.55) 100%);';
gsWrap.appendChild(vig);
var btn = document.createElement('div');
btn.textContent = 'ENTER THE GREEN SEA';
btn.style.cssText = [
  'position:fixed','bottom:60px','left:50%','transform:translateX(-50%)',
  'font:13px "Courier New",monospace','color:rgba(232,120,24,0.85)',
  'letter-spacing:4px','cursor:pointer','padding:12px 28px',
  'border:1px solid rgba(232,120,24,0.3)','background:rgba(0,0,0,0.4)',
  'z-index:9004','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
setTimeout(function() { btn.style.opacity = '1'; }, 1500);
btn.addEventListener('mouseenter', function() {
  this.style.color = 'rgba(255,160,50,0.95)';
  this.style.borderColor = 'rgba(232,120,24,0.6)';
});
btn.addEventListener('mouseleave', function() {
  this.style.color = 'rgba(232,120,24,0.85)';
  this.style.borderColor = 'rgba(232,120,24,0.3)';
});
btn.addEventListener('click', function() {
gsWrap.style.transition = 'opacity 1.5s ease';
gsWrap.style.opacity = '0';
setTimeout(function() {
if (gsWrap && gsWrap.parentNode) gsWrap.parentNode.removeChild(gsWrap);
var TARGET = 'LINE 2';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; links.length > i; i++) {
if (links[i].textContent.trim() === '\u00b7') { links[i].click(); break; }
}
}
}, 1500);
});
gsWrap.appendChild(btn);
document.body.appendChild(gsWrap);
}
setInterval(function() {
var container = document.getElementById('gs-approach');
if (container && !gsActive) {
initGreenSea();
} else if (!container) {
gsActive = false;
var wrap = document.getElementById('gs-wrap');
if (wrap && wrap.parentNode) wrap.parentNode.removeChild(wrap);
}
}, 300);
})();
// ====== COLONY ROOM SCENE — INLINE ======
(function() {
var crActive = false;
var crAnimId = null;
var crWrap = null;
var crVig = null;
var crGrain = null;
var crGrainCtx = null;
var crGrainFrame = 0;
var crWash = null;
var crDate = null;
var crLoc = null;
var crBtn = null;

function initColonyRoom() {
if (crActive) return;
crActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildCRScene(); };
document.head.appendChild(s);
} else {
buildCRScene();
}
}

function buildCRScene() {
crWrap = document.createElement('div');
crWrap.id = 'cr-wrap';
crWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#050508;overflow:hidden;';

// ============================================================
// SCENE SETUP — ALL SCENE CODE FROM COLONY ROOM HTML
// ============================================================

// ============================================================
// HELPERS (must be defined before any textures)
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
scene.add(m);
return m;
}

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x08060a);
scene.fog = new THREE.Fog(0x08060a, 4, 22);

var camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 200);
// Camera slightly above, looking down at the doors — like peering from an upper window
camera.position.set(2.0, 5.5, 6.5);
camera.lookAt(0, 1.6, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 0.75;
crWrap.appendChild(renderer.domElement);
window._dssBindScene('cr-wrap', scene, renderer, camera);

// ============================================================
// MATERIALS
// ============================================================
// Dark umbra brick — sooty London stock with mortar lines
var brickTex = makeCanvasTexture(512, 1024, function(cx, w, h) {
// Base umbra tone
cx.fillStyle = '#3a2e25';
cx.fillRect(0, 0, w, h);
// Brick rows — each brick individually coloured
var brickH = 18;
var mortarW = 3;
var brickW = 55;
for (var row = 0; row < Math.ceil(h / (brickH + mortarW)); row++) {
var by = row * (brickH + mortarW);
var offset = (row % 2 === 0) ? 0 : brickW / 2;
for (var bx = -brickW; bx < w + brickW; bx += brickW + mortarW) {
var x = bx + offset;
// Each brick gets a slightly different shade of umbra/brown
var r = 48 + Math.floor(Math.random() * 22);
var g = 36 + Math.floor(Math.random() * 16);
var b = 28 + Math.floor(Math.random() * 12);
cx.fillStyle = 'rgb(' + r + ',' + g + ',' + b + ')';
cx.fillRect(x, by, brickW, brickH);
// Subtle face variation on each brick
cx.fillStyle = 'rgba(' + (r + 10) + ',' + (g + 8) + ',' + (b + 5) + ', 0.15)';
cx.fillRect(x + 2, by + 2, brickW - 4, brickH - 4);
}
// Mortar line (horizontal)
cx.fillStyle = 'rgba(55, 48, 40, 0.6)';
cx.fillRect(0, by + brickH, w, mortarW);
}
// Vertical mortar lines
for (var row = 0; row < Math.ceil(h / (brickH + mortarW)); row++) {
var by = row * (brickH + mortarW);
var offset = (row % 2 === 0) ? 0 : brickW / 2;
for (var bx = -brickW; bx < w + brickW; bx += brickW + mortarW) {
var x = bx + offset;
cx.fillStyle = 'rgba(55, 48, 40, 0.5)';
cx.fillRect(x - 1, by, mortarW, brickH);
}
}
// Heavy soot wash — decades of London grime
var sootWash = cx.createLinearGradient(0, 0, 0, h);
sootWash.addColorStop(0, 'rgba(10, 8, 5, 0.4)');
sootWash.addColorStop(0.1, 'rgba(15, 12, 8, 0.2)');
sootWash.addColorStop(0.5, 'rgba(12, 10, 6, 0.1)');
sootWash.addColorStop(0.85, 'rgba(10, 8, 5, 0.15)');
sootWash.addColorStop(1, 'rgba(8, 6, 3, 0.35)');
cx.fillStyle = sootWash;
cx.fillRect(0, 0, w, h);
// Dark rain streaks running down the bricks — heavy water staining
cx.strokeStyle = 'rgba(18, 14, 10, 0.15)';
cx.lineWidth = 3;
for (var rs = 0; rs < 30; rs++) {
cx.beginPath();
var rx = Math.random() * w;
cx.moveTo(rx, 0);
for (var ry = 0; ry < h; ry += 20) {
rx += (Math.random() - 0.5) * 3;
cx.lineTo(rx, ry);
}
cx.stroke();
}
// Damp patches — more and darker
cx.fillStyle = 'rgba(18, 14, 10, 0.18)';
for (var dp = 0; dp < 8; dp++) {
cx.beginPath();
cx.ellipse(Math.random() * w, h * 0.5 + Math.random() * h * 0.5, 35 + Math.random() * 60, 25 + Math.random() * 40, Math.random(), 0, Math.PI * 2);
cx.fill();
}
// Green algae/moss at base of building
cx.fillStyle = 'rgba(25, 38, 15, 0.2)';
cx.fillRect(0, h * 0.9, w, h * 0.1);
for (var ag = 0; ag < 10; ag++) {
cx.fillStyle = 'rgba(28, 42, 18, 0.15)';
cx.beginPath();
cx.ellipse(Math.random() * w, h * 0.88 + Math.random() * h * 0.12, 15 + Math.random() * 30, 8 + Math.random() * 15, 0, 0, Math.PI * 2);
cx.fill();
}
// Pigeon droppings — white splatters
cx.fillStyle = 'rgba(140, 135, 120, 0.12)';
for (var pd = 0; pd < 6; pd++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h * 0.4, 3 + Math.random() * 8, 5 + Math.random() * 12, Math.random(), 0, Math.PI * 2);
cx.fill();
}
});
var facadeBrick = new THREE.MeshStandardMaterial({ map: brickTex, roughness: 0.9 });
var darkFacadeBrick = new THREE.MeshStandardMaterial({ color: 0x2a2018, roughness: 0.9 });
var sootBrick = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x3a2a22, roughness: 0.9 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x6b3a2a, roughness: 0.85 });
var greyStone = new THREE.MeshStandardMaterial({ color: 0x9a9488, roughness: 0.75 });
var whiteStone = new THREE.MeshStandardMaterial({ color: 0xa8a090, roughness: 0.75 });

// Pavement texture — dark York stone flags, browner and grimier than Portland
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#332c1e';
cx.fillRect(0, 0, w, h);
var flagRows = [
{ y: 0, h: 128 }, { y: 128, h: 110 },
{ y: 238, h: 140 }, { y: 378, h: 134 }
];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var slabs = (ri % 2 === 0) ? [0, 200, 380] : [0, 260, 420];
for (var si = 0; si < slabs.length; si++) {
var sx = slabs[si];
var sw = (si < slabs.length - 1) ? slabs[si + 1] - sx : w - sx;
var tone = 35 + Math.random() * 18;
cx.fillStyle = 'rgb(' + tone + ',' + (tone - 5) + ',' + (tone - 12) + ')';
cx.fillRect(sx + 2, row.y + 2, sw - 4, row.h - 4);
cx.fillStyle = 'rgba(60, 55, 45, 0.08)';
for (var sp = 0; sp < 10; sp++) {
cx.beginPath();
cx.ellipse(sx + Math.random() * sw, row.y + Math.random() * row.h, 10 + Math.random() * 25, 5 + Math.random() * 12, Math.random(), 0, Math.PI * 2);
cx.fill();
}
}
}
cx.strokeStyle = 'rgba(18, 15, 10, 0.7)';
cx.lineWidth = 3;
for (var ri = 0; ri < flagRows.length; ri++) {
cx.beginPath(); cx.moveTo(0, flagRows[ri].y); cx.lineTo(w, flagRows[ri].y); cx.stroke();
}
var vertLines1 = [200, 380]; var vertLines2 = [260, 420];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var vlines = (ri % 2 === 0) ? vertLines1 : vertLines2;
for (var vi = 0; vi < vlines.length; vi++) {
cx.beginPath(); cx.moveTo(vlines[vi], row.y); cx.lineTo(vlines[vi], row.y + row.h); cx.stroke();
}
}
// Deep joint grime
cx.fillStyle = 'rgba(10, 8, 5, 0.3)';
for (var ri = 0; ri < flagRows.length; ri++) { cx.fillRect(0, flagRows[ri].y - 1, w, 5); }
// Dark stains — spilled drinks, oil, old gum
cx.fillStyle = 'rgba(20, 18, 12, 0.3)';
for (var st = 0; st < 15; st++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 10 + Math.random() * 30, 8 + Math.random() * 20, Math.random() * Math.PI, 0, Math.PI * 2);
cx.fill();
}
// Old chewing gum spots
cx.fillStyle = 'rgba(50, 48, 42, 0.4)';
for (var gm = 0; gm < 12; gm++) {
cx.beginPath(); cx.arc(Math.random() * w, Math.random() * h, 2 + Math.random() * 5, 0, Math.PI * 2); cx.fill();
}
// Large damp/grimy patches
cx.fillStyle = 'rgba(22, 20, 15, 0.18)';
for (var dp = 0; dp < 6; dp++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 30 + Math.random() * 60, 25 + Math.random() * 40, Math.random(), 0, Math.PI * 2);
cx.fill();
}
// Greenish moss in cracks
cx.fillStyle = 'rgba(30, 40, 18, 0.15)';
for (var ri = 0; ri < flagRows.length; ri++) {
for (var ms = 0; ms < 3; ms++) {
cx.beginPath();
cx.ellipse(Math.random() * w, flagRows[ri].y + Math.random() * 6 - 3, 8 + Math.random() * 15, 3 + Math.random() * 4, 0, 0, Math.PI * 2);
cx.fill();
}
}
});
var paveMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.9 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x0e0e0e, roughness: 0.88 });
var kerbMat = new THREE.MeshStandardMaterial({ color: 0x3a3a38, roughness: 0.85 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0x8a8070, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a12, roughness: 0.2, metalness: 0.3 });
var warmGlass = new THREE.MeshStandardMaterial({ color: 0x2a1505, roughness: 0.3, emissive: 0xe87818, emissiveIntensity: 0.12 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.4 });

// Red door — deep oxblood red, worn and weathered
var redDoorTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#6a1a18';
cx.fillRect(0, 0, w, h);
// Wood grain
cx.strokeStyle = 'rgba(80, 20, 15, 0.4)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 4) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx + (Math.random() - 0.5) * 2, h); cx.stroke();
}
// Wear patches — paint fading
cx.fillStyle = 'rgba(90, 25, 20, 0.2)';
for (var k = 0; k < 6; k++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 8 + Math.random() * 12, 4 + Math.random() * 6, Math.random() * Math.PI, 0, Math.PI * 2);
cx.fill();
}
// Edge darkening
cx.fillStyle = 'rgba(40, 10, 8, 0.2)';
cx.fillRect(0, 0, 8, h); cx.fillRect(w - 8, 0, 8, h);
cx.fillRect(0, 0, w, 6); cx.fillRect(0, h - 6, w, 6);
// Scuffs at bottom
cx.fillStyle = 'rgba(35, 12, 10, 0.3)';
for (var sc = 0; sc < 12; sc++) {
cx.fillRect(Math.random() * w, h - 20 - Math.random() * 60, 15 + Math.random() * 25, 1 + Math.random() * 2);
}
});
var redDoorMat = new THREE.MeshStandardMaterial({ map: redDoorTex, roughness: 0.5, metalness: 0.05 });

var redPanelTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#551412';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(65, 18, 14, 0.35)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 5) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx + (Math.random() - 0.5) * 2, h); cx.stroke();
}
var panelShadow = cx.createLinearGradient(0, 0, 0, h);
panelShadow.addColorStop(0, 'rgba(8, 2, 2, 0.2)');
panelShadow.addColorStop(0.3, 'rgba(8, 2, 2, 0)');
panelShadow.addColorStop(1, 'rgba(8, 2, 2, 0.05)');
cx.fillStyle = panelShadow;
cx.fillRect(0, 0, w, h);
});
var redPanelMat = new THREE.MeshStandardMaterial({ map: redPanelTex, roughness: 0.55, metalness: 0.05 });

// Black door — near-black gloss, proper London black
var blackDoorTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#0e0e10';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(18, 18, 22, 0.4)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 4) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx + (Math.random() - 0.5) * 2, h); cx.stroke();
}
// Subtle sheen marks
cx.fillStyle = 'rgba(25, 25, 30, 0.12)';
cx.fillRect(0, 0, 8, h); cx.fillRect(w - 8, 0, 8, h);
// Scuffs at bottom
cx.fillStyle = 'rgba(20, 18, 15, 0.3)';
for (var sc = 0; sc < 10; sc++) {
cx.fillRect(Math.random() * w, h - 20 - Math.random() * 60, 12 + Math.random() * 20, 1 + Math.random() * 2);
}
});
var blackDoorMat = new THREE.MeshStandardMaterial({ map: blackDoorTex, roughness: 0.35, metalness: 0.1 });

var blackPanelTex = makeCanvasTexture(256, 512, function(cx, w, h) {
cx.fillStyle = '#0a0a0c';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(15, 15, 18, 0.3)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 3 + Math.random() * 5) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx + (Math.random() - 0.5) * 2, h); cx.stroke();
}
});
var blackPanelMat = new THREE.MeshStandardMaterial({ map: blackPanelTex, roughness: 0.4, metalness: 0.1 });

// Brass materials
var brassMat = new THREE.MeshStandardMaterial({ color: 0xb8922a, roughness: 0.25, metalness: 0.85 });
var brassMatDull = new THREE.MeshStandardMaterial({ color: 0x8a7020, roughness: 0.4, metalness: 0.7 });

// Door mould colours
var redMouldMat = new THREE.MeshStandardMaterial({ color: 0x7a2220, roughness: 0.45 });
var blackMouldMat = new THREE.MeshStandardMaterial({ color: 0x151518, roughness: 0.4, metalness: 0.08 });

// Woodframe for both doors
var woodFrameTex = makeCanvasTexture(128, 512, function(cx, w, h) {
cx.fillStyle = '#2a1e14';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(50, 35, 22, 0.5)';
cx.lineWidth = 1;
for (var gx = 0; gx < w; gx += 2 + Math.random() * 3) {
cx.beginPath(); cx.moveTo(gx, 0); cx.lineTo(gx + (Math.random() - 0.5) * 2, h); cx.stroke();
}
cx.fillStyle = 'rgba(15, 10, 5, 0.15)';
cx.fillRect(0, 0, 6, h); cx.fillRect(w - 6, 0, 6, h);
});
var woodFrameMat = new THREE.MeshStandardMaterial({ map: woodFrameTex, roughness: 0.55, metalness: 0.05 });

var capitalMat = new THREE.MeshStandardMaterial({ color: 0xb0a898, roughness: 0.72 });

// ============================================================
// GROUND
// ============================================================
var pavement = new THREE.Mesh(new THREE.PlaneGeometry(40, 40), paveMat);
pavement.rotation.x = -Math.PI / 2;
pavement.receiveShadow = true;
scene.add(pavement);

var road = new THREE.Mesh(new THREE.PlaneGeometry(40, 7), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 6);
road.receiveShadow = true;
scene.add(road);

var kerb = new THREE.Mesh(new THREE.BoxGeometry(30, 0.15, 0.15), kerbMat);
kerb.position.set(0, 0.075, 2.5);
scene.add(kerb);

var raisedPave = new THREE.Mesh(new THREE.BoxGeometry(30, 0.12, 3), paveMat);
raisedPave.position.set(0, 0.06, 1);
raisedPave.receiveShadow = true;
scene.add(raisedPave);

var wetMat = new THREE.MeshStandardMaterial({
color: 0x1a1a1a, roughness: 0.12, metalness: 0.5, transparent: true, opacity: 0.3
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(12, 6), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(1, 0.01, 5);
scene.add(wetRoad);

// ============================================================
// THE BUILDING — Georgian townhouse, Dean Street
// ============================================================
var building = new THREE.Group();

// Main facade — dark umbra brick, wider than Lackland's to hold two doors
var facade = new THREE.Mesh(new THREE.BoxGeometry(9, 14, 1.5), facadeBrick);
facade.position.set(0, 7, -0.75);
facade.castShadow = true;
building.add(facade);

// Ground floor base — slightly darker brick
var groundBase = new THREE.Mesh(new THREE.BoxGeometry(9.05, 3.5, 0.1), darkFacadeBrick);
groundBase.position.set(0, 1.75, 0.02);
building.add(groundBase);

// Rusticated ground floor grooves
var grooveMat = new THREE.MeshStandardMaterial({ color: 0x908878, roughness: 0.8 });
for (var i = 0; i < 5; i++) {
var gy = 0.5 + i * 0.7;
// Far left
var g1 = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.02, 0.08), grooveMat);
g1.position.set(-4.1, gy, 0.04); building.add(g1);
// Between left edge and left door
var g2 = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.02, 0.08), grooveMat);
g2.position.set(-2.5, gy, 0.04); building.add(g2);
// Between the two doors
var g3 = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.02, 0.08), grooveMat);
g3.position.set(0, gy, 0.04); building.add(g3);
// Between right door and right edge
var g4 = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.02, 0.08), grooveMat);
g4.position.set(2.5, gy, 0.04); building.add(g4);
// Far right
var g5 = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.02, 0.08), grooveMat);
g5.position.set(4.1, gy, 0.04); building.add(g5);
}

// String course
var stringCourse = new THREE.Mesh(new THREE.BoxGeometry(9.2, 0.2, 0.12), whiteStone);
stringCourse.position.set(0, 3.8, 0.05);
building.add(stringCourse);

// Cornice at top
var cornice = new THREE.Mesh(new THREE.BoxGeometry(9.3, 0.25, 0.2), whiteStone);
cornice.position.set(0, 13.9, 0.1);
building.add(cornice);
var corniceUnder = new THREE.Mesh(new THREE.BoxGeometry(9.2, 0.12, 0.15), greyStone);
corniceUnder.position.set(0, 13.7, 0.08);
building.add(corniceUnder);

scene.add(building);

// ============================================================
// DOOR BUILDER — builds a full Georgian 6-panel door
// ============================================================
function buildDoor(xPos, doorMat, panelMat, mouldMat, parentGroup) {
var dg = new THREE.Group();

// Door recess
var recess = new THREE.Mesh(
new THREE.BoxGeometry(1.4, 3.2, 0.3),
new THREE.MeshStandardMaterial({ color: 0x3a3530, roughness: 0.9 })
);
recess.position.set(0, 1.7, -0.05);
dg.add(recess);

// Wooden doorframe
var fL = new THREE.Mesh(new THREE.BoxGeometry(0.08, 2.9, 0.07), woodFrameMat);
fL.position.set(-0.6, 1.55, 0.06); dg.add(fL);
var fR = new THREE.Mesh(new THREE.BoxGeometry(0.08, 2.9, 0.07), woodFrameMat);
fR.position.set(0.6, 1.55, 0.06); dg.add(fR);
var fT = new THREE.Mesh(new THREE.BoxGeometry(1.28, 0.08, 0.07), woodFrameMat);
fT.position.set(0, 3.01, 0.06); dg.add(fT);
var fB = new THREE.Mesh(new THREE.BoxGeometry(1.28, 0.05, 0.07), woodFrameMat);
fB.position.set(0, 0.13, 0.06); dg.add(fB);

// Door slab
var slab = new THREE.Mesh(new THREE.BoxGeometry(1.1, 2.8, 0.08), doorMat);
slab.position.set(0, 1.55, 0.08);
slab.castShadow = true;
dg.add(slab);

// 6 panels (Georgian layout)
var pGeo1 = new THREE.BoxGeometry(0.38, 0.65, 0.03);
dg.add(new THREE.Mesh(pGeo1, panelMat).translateX(-0.22).translateY(2.55).translateZ(0.12));
dg.add(new THREE.Mesh(pGeo1, panelMat).translateX(0.22).translateY(2.55).translateZ(0.12));
var pGeo2 = new THREE.BoxGeometry(0.38, 0.45, 0.03);
dg.add(new THREE.Mesh(pGeo2, panelMat).translateX(-0.22).translateY(1.65).translateZ(0.12));
dg.add(new THREE.Mesh(pGeo2, panelMat).translateX(0.22).translateY(1.65).translateZ(0.12));
var pGeo3 = new THREE.BoxGeometry(0.38, 0.6, 0.03);
dg.add(new THREE.Mesh(pGeo3, panelMat).translateX(-0.22).translateY(0.75).translateZ(0.12));
dg.add(new THREE.Mesh(pGeo3, panelMat).translateX(0.22).translateY(0.75).translateZ(0.12));

// Panel mouldings
function addMould(cx, cy, pw, ph) {
dg.add(new THREE.Mesh(new THREE.BoxGeometry(pw + 0.06, 0.025, 0.02), mouldMat).translateX(cx).translateY(cy + ph/2 + 0.01).translateZ(0.13));
dg.add(new THREE.Mesh(new THREE.BoxGeometry(pw + 0.06, 0.025, 0.02), mouldMat).translateX(cx).translateY(cy - ph/2 - 0.01).translateZ(0.13));
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.025, ph + 0.06, 0.02), mouldMat).translateX(cx - pw/2 - 0.01).translateY(cy).translateZ(0.13));
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.025, ph + 0.06, 0.02), mouldMat).translateX(cx + pw/2 + 0.01).translateY(cy).translateZ(0.13));
}
addMould(-0.22, 2.55, 0.38, 0.65);
addMould(0.22, 2.55, 0.38, 0.65);
addMould(-0.22, 1.65, 0.38, 0.45);
addMould(0.22, 1.65, 0.38, 0.45);
addMould(-0.22, 0.75, 0.38, 0.6);
addMould(0.22, 0.75, 0.38, 0.6);

// Centre stile
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.05, 2.6, 0.02), doorMat).translateX(0).translateY(1.55).translateZ(0.12));

// Brass knob — centred
var bp = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.015, 16), brassMat);
bp.rotation.x = Math.PI / 2; bp.position.set(0, 1.55, 0.14); dg.add(bp);
var stem = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.025, 0.07, 8), brassMat);
stem.rotation.x = Math.PI / 2; stem.position.set(0, 1.55, 0.18); dg.add(stem);
var knob = new THREE.Mesh(new THREE.SphereGeometry(0.06, 16, 12), brassMat);
knob.position.set(0, 1.55, 0.24); dg.add(knob);

// Keyhole
var kEsc = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 0.01, 8), brassMatDull);
kEsc.rotation.x = Math.PI / 2; kEsc.position.set(0.3, 1.3, 0.13); dg.add(kEsc);
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.008, 0.02, 0.01), new THREE.MeshStandardMaterial({ color: 0x050505 })).translateX(0.3).translateY(1.3).translateZ(0.14));

// Letterbox
var lb = new THREE.Mesh(new THREE.BoxGeometry(0.26, 0.055, 0.015), brassMat);
lb.position.set(0, 1.1, 0.13); dg.add(lb);
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.20, 0.012, 0.02), new THREE.MeshStandardMaterial({ color: 0x0a0a05 })).translateX(0).translateY(1.1).translateZ(0.14));

// Door surround — pilasters
var pilL = new THREE.Mesh(new THREE.BoxGeometry(0.22, 3.0, 0.12), whiteStone);
pilL.position.set(-0.82, 1.6, 0.05); dg.add(pilL);
var pilR = new THREE.Mesh(new THREE.BoxGeometry(0.22, 3.0, 0.12), whiteStone);
pilR.position.set(0.82, 1.6, 0.05); dg.add(pilR);
// Bases
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.28, 0.2, 0.15), whiteStone).translateX(-0.82).translateY(0.1).translateZ(0.06));
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.28, 0.2, 0.15), whiteStone).translateX(0.82).translateY(0.1).translateZ(0.06));
// Capitals
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.14, 0.16), capitalMat).translateX(-0.82).translateY(3.18).translateZ(0.07));
dg.add(new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.14, 0.16), capitalMat).translateX(0.82).translateY(3.18).translateZ(0.07));

// Entablature
var entab = new THREE.Mesh(new THREE.BoxGeometry(2.0, 0.18, 0.18), whiteStone);
entab.position.set(0, 3.38, 0.08); dg.add(entab);
var ped = new THREE.Mesh(new THREE.BoxGeometry(2.1, 0.08, 0.2), capitalMat);
ped.position.set(0, 3.52, 0.1); dg.add(ped);

// Worn stone doorstep
var stepTex = makeCanvasTexture(512, 128, function(cx, w, h) {
cx.fillStyle = '#8a8878';
cx.fillRect(0, 0, w, h);
var wornGrad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.4);
wornGrad.addColorStop(0, 'rgba(70, 68, 60, 0.35)');
wornGrad.addColorStop(0.6, 'rgba(80, 78, 68, 0.15)');
wornGrad.addColorStop(1, 'rgba(90, 88, 78, 0)');
cx.fillStyle = wornGrad; cx.fillRect(0, 0, w, h);
cx.fillStyle = 'rgba(40, 35, 25, 0.3)';
cx.fillRect(0, 0, w, 8); cx.fillRect(0, h - 6, w, 6);
cx.fillRect(0, 0, 10, h); cx.fillRect(w - 10, 0, 10, h);
cx.strokeStyle = 'rgba(55, 50, 40, 0.2)'; cx.lineWidth = 1;
for (var sc = 0; sc < 20; sc++) {
cx.beginPath();
var sx2 = Math.random() * w;
cx.moveTo(sx2, Math.random() * h);
cx.lineTo(sx2 + 10 + Math.random() * 30, Math.random() * h);
cx.stroke();
}
cx.fillStyle = 'rgba(25, 20, 10, 0.4)';
cx.beginPath(); cx.arc(w * 0.7, h * 0.6, 3, 0, Math.PI * 2); cx.fill();
});
var stepMat = new THREE.MeshStandardMaterial({ map: stepTex, roughness: 0.8 });
dg.add(new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.1, 0.4), stepMat).translateX(0).translateY(0.05).translateZ(0.3));

dg.position.set(xPos, 0.12, 0);
parentGroup.add(dg);
return dg;
}

// ============================================================
// LEFT DOOR — oxblood red (the Colony Room entrance)
// ============================================================
var leftDoor = buildDoor(-1.5, redDoorMat, redPanelMat, redMouldMat, scene);

// Fanlight — faintest warm glow (staircase light bleeding through)
var fanlightGlassL = new THREE.MeshStandardMaterial({
color: 0x0a0808, roughness: 0.2, emissive: 0xc08030, emissiveIntensity: 0.12
});
var fanlightL = new THREE.Mesh(new THREE.BoxGeometry(1.1, 0.4, 0.05), fanlightGlassL);
fanlightL.position.set(-1.5, 3.22, 0.06); scene.add(fanlightL);
var fanlightFrameL = new THREE.Mesh(new THREE.BoxGeometry(1.15, 0.42, 0.02), windowFrame);
fanlightFrameL.position.set(-1.5, 3.22, 0.04); scene.add(fanlightFrameL);
for (var i = 0; i < 5; i++) {
var barL = new THREE.Mesh(new THREE.BoxGeometry(0.015, 0.38, 0.01), new THREE.MeshStandardMaterial({ color: 0x6a6050, roughness: 0.7 }));
barL.position.set(-1.5 - 0.4 + i * 0.2, 3.22, 0.08);
barL.rotation.z = (i - 2) * 0.12;
scene.add(barL);
}

// Number "41" — tiny, barely visible above left door
var numTex = makeCanvasTexture(128, 64, function(cx, w, h) {
cx.fillStyle = 'rgba(0,0,0,0)';
cx.fillRect(0, 0, w, h);
cx.fillStyle = '#a09880';
cx.font = 'bold 26px Georgia';
cx.textAlign = 'center'; cx.textBaseline = 'middle';
cx.fillText('41', w/2, h/2);
});
var numMat = new THREE.MeshStandardMaterial({ map: numTex, roughness: 0.5, transparent: true });
var numPlate = new THREE.Mesh(new THREE.PlaneGeometry(0.2, 0.1), numMat);
numPlate.position.set(-1.5, 3.77, 0.12); scene.add(numPlate);

// ============================================================
// RIGHT DOOR — gloss black (anonymous neighbour) — extra detail
// ============================================================
var rightDoor = buildDoor(1.5, blackDoorMat, blackPanelMat, blackMouldMat, scene);

// Iron door knocker — lion's head ring style
var knockerIron = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5, metalness: 0.6 });
// Backplate (oval)
var knockPlate = new THREE.Mesh(new THREE.CylinderGeometry(0.05, 0.05, 0.008, 12), knockerIron);
knockPlate.rotation.x = Math.PI / 2; knockPlate.position.set(1.5, 2.2, 0.28); scene.add(knockPlate);
// Ring (torus-like — approximated with a flattened cylinder)
var knockRing = new THREE.Mesh(new THREE.CylinderGeometry(0.035, 0.035, 0.01, 8), knockerIron);
knockRing.rotation.x = Math.PI / 2; knockRing.position.set(1.5, 2.14, 0.30); scene.add(knockRing);
var knockRingInner = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 0.012, 8),
new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.3 }));
knockRingInner.rotation.x = Math.PI / 2; knockRingInner.position.set(1.5, 2.14, 0.305); scene.add(knockRingInner);

// Iron boot scraper set into the stone step
var scraperMat = new THREE.MeshStandardMaterial({ color: 0x151515, roughness: 0.6, metalness: 0.5 });
var scraperArch = new THREE.Mesh(new THREE.BoxGeometry(0.18, 0.12, 0.03), scraperMat);
scraperArch.position.set(1.82, 0.18, 0.35); scene.add(scraperArch);
var scraperLegL = new THREE.Mesh(new THREE.BoxGeometry(0.02, 0.1, 0.03), scraperMat);
scraperLegL.position.set(1.73, 0.12, 0.35); scene.add(scraperLegL);
var scraperLegR = new THREE.Mesh(new THREE.BoxGeometry(0.02, 0.1, 0.03), scraperMat);
scraperLegR.position.set(1.91, 0.12, 0.35); scene.add(scraperLegR);
var scraperBlade = new THREE.Mesh(new THREE.BoxGeometry(0.14, 0.015, 0.025), scraperMat);
scraperBlade.position.set(1.82, 0.2, 0.35); scene.add(scraperBlade);

// Iron numerals "43" — small, painted white on the black door
var numTexR = makeCanvasTexture(128, 64, function(cx, w, h) {
cx.fillStyle = 'rgba(0,0,0,0)';
cx.fillRect(0, 0, w, h);
cx.fillStyle = '#c8c0b0';
cx.font = 'bold 28px Georgia';
cx.textAlign = 'center'; cx.textBaseline = 'middle';
cx.fillText('43', w/2, h/2);
});
var numMatR = new THREE.MeshStandardMaterial({ map: numTexR, roughness: 0.5, transparent: true });
var numPlateR = new THREE.Mesh(new THREE.PlaneGeometry(0.2, 0.1), numMatR);
numPlateR.position.set(1.5, 3.77, 0.12); scene.add(numPlateR);

// Worn threshold — darker scuffed strip at base of black door
var thresholdTex = makeCanvasTexture(256, 64, function(cx, w, h) {
cx.fillStyle = '#1a1815';
cx.fillRect(0, 0, w, h);
// Heavy wear marks
cx.fillStyle = 'rgba(30, 25, 18, 0.3)';
for (var tm = 0; tm < 15; tm++) {
cx.fillRect(Math.random() * w, Math.random() * h, 20 + Math.random() * 40, 2 + Math.random() * 3);
}
// Pale centre where feet have worn through
var wornGrad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.35);
wornGrad.addColorStop(0, 'rgba(60, 55, 45, 0.2)');
wornGrad.addColorStop(1, 'rgba(30, 25, 18, 0)');
cx.fillStyle = wornGrad; cx.fillRect(0, 0, w, h);
});
var thresholdMat = new THREE.MeshStandardMaterial({ map: thresholdTex, roughness: 0.85 });
var threshold = new THREE.Mesh(new THREE.BoxGeometry(1.3, 0.02, 0.15), thresholdMat);
threshold.position.set(1.5, 0.13, 0.35); scene.add(threshold);

// Fanlight — completely dark, with cobweb detail
var fanlightGlassR = new THREE.MeshStandardMaterial({ color: 0x050505, roughness: 0.3 });
var fanlightR = new THREE.Mesh(new THREE.BoxGeometry(1.1, 0.4, 0.05), fanlightGlassR);
fanlightR.position.set(1.5, 3.22, 0.06); scene.add(fanlightR);
var fanlightFrameR = new THREE.Mesh(new THREE.BoxGeometry(1.15, 0.42, 0.02), windowFrame);
fanlightFrameR.position.set(1.5, 3.22, 0.04); scene.add(fanlightFrameR);
for (var i = 0; i < 5; i++) {
var barR = new THREE.Mesh(new THREE.BoxGeometry(0.015, 0.38, 0.01), new THREE.MeshStandardMaterial({ color: 0x6a6050, roughness: 0.7 }));
barR.position.set(1.5 - 0.4 + i * 0.2, 3.22, 0.08);
barR.rotation.z = (i - 2) * 0.12;
scene.add(barR);
}
// Cobweb in corner of right fanlight
var cobwebTex = makeCanvasTexture(64, 64, function(cx, w, h) {
cx.fillStyle = 'rgba(0,0,0,0)';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(160, 155, 140, 0.25)';
cx.lineWidth = 0.5;
// Radial threads from corner
for (var a = 0; a < 6; a++) {
var angle = (a / 6) * Math.PI * 0.5;
cx.beginPath(); cx.moveTo(0, 0);
cx.lineTo(Math.cos(angle) * w * 0.8, Math.sin(angle) * h * 0.8);
cx.stroke();
}
// Spiral connectors
for (var r = 0.2; r < 0.8; r += 0.2) {
cx.beginPath();
for (var a = 0; a <= 6; a++) {
var angle = (a / 6) * Math.PI * 0.5;
var px = Math.cos(angle) * w * r;
var py = Math.sin(angle) * h * r;
if (a === 0) cx.moveTo(px, py); else cx.lineTo(px, py);
}
cx.stroke();
}
});
var cobwebMat = new THREE.MeshBasicMaterial({ map: cobwebTex, transparent: true, side: THREE.DoubleSide, depthWrite: false });
var cobweb = new THREE.Mesh(new THREE.PlaneGeometry(0.2, 0.15), cobwebMat);
cobweb.position.set(1.95, 3.38, 0.09); scene.add(cobweb);

// ============================================================
// UPPER FLOOR WINDOWS — Georgian sash
// ============================================================
function addSashWindow(x, y, lit) {
var surround = new THREE.Mesh(new THREE.BoxGeometry(0.95, 1.5, 0.08), whiteStone);
surround.position.set(x, y, 0.03); building.add(surround);
var glassMat = lit ? warmGlass : darkGlass;
var glass = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.04), glassMat);
glass.position.set(x, y, 0.05); building.add(glass);
var glazBar = new THREE.Mesh(new THREE.BoxGeometry(0.72, 0.03, 0.02), windowFrame);
glazBar.position.set(x, y + 0.1, 0.07); building.add(glazBar);
var sill = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.08, 0.15), whiteStone);
sill.position.set(x, y - 0.75, 0.06); building.add(sill);
var lintel = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.1, 0.1), whiteStone);
lintel.position.set(x, y + 0.8, 0.04); building.add(lintel);
}

// First floor — the Colony Room. 3 windows, warm amber/green glow
addSashWindow(-3, 5.5, false);
addSashWindow(0, 5.5, false);
addSashWindow(3, 5.5, false);

// Colony Room windows — warm glow overlay
var colonyGlass = new THREE.MeshStandardMaterial({
color: 0x1a1205, roughness: 0.3, emissive: 0xd8a030, emissiveIntensity: 0.2
});
var colWinL = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.045), colonyGlass);
colWinL.position.set(-3, 5.5, 0.055); building.add(colWinL);
var colWinC = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.045), colonyGlass);
colWinC.position.set(0, 5.5, 0.055); building.add(colWinC);

// Right first-floor window — slightly greenish (the Colony's famous green walls)
var colonyGreenGlass = new THREE.MeshStandardMaterial({
color: 0x0a1a08, roughness: 0.3, emissive: 0x88a838, emissiveIntensity: 0.12
});
var colWinR = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.045), colonyGreenGlass);
colWinR.position.set(3, 5.5, 0.055); building.add(colWinR);

// Point lights for Colony Room glow
var colGlowL = new THREE.PointLight(0xd8a030, 0.2, 5);
colGlowL.position.set(-3, 5.5, 1.0); scene.add(colGlowL);
var colGlowC = new THREE.PointLight(0xd8a030, 0.25, 5);
colGlowC.position.set(0, 5.5, 1.0); scene.add(colGlowC);
var colGlowR = new THREE.PointLight(0x88a838, 0.1, 4);
colGlowR.position.set(3, 5.5, 0.8); scene.add(colGlowR);

// Second floor — 3 windows, mostly dark
addSashWindow(-3, 8.5, false);
addSashWindow(0, 8.5, false);
addSashWindow(3, 8.5, false);

// One second-floor window with faint amber glow
var amberGlass2F = new THREE.MeshStandardMaterial({
color: 0x2a1805, roughness: 0.3, emissive: 0xd8a030, emissiveIntensity: 0.1
});
var amberWin2F = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.3, 0.045), amberGlass2F);
amberWin2F.position.set(0, 8.5, 0.055); building.add(amberWin2F);

// Third floor — 3 windows, all dark
addSashWindow(-3, 11.2, false);
addSashWindow(0, 11.2, false);
addSashWindow(3, 11.2, false);

// ============================================================
// SHOPFRONT BUILDER — reusable function for ground floor shops
// ============================================================
var shopFrameMat = new THREE.MeshStandardMaterial({ color: 0x162a1a, roughness: 0.55 });
var shopPilMat = new THREE.MeshStandardMaterial({ color: 0x162a1a, roughness: 0.6 });
var fasciaEdge = new THREE.MeshStandardMaterial({ color: 0x142818, roughness: 0.55 });

function buildShopfront(centreX, shopWidth, fasciaText, fasciaColor, glassTex, glassEmissive, glowColor) {
var halfW = shopWidth / 2;
// Fascia board
var fMat = new THREE.MeshStandardMaterial({ color: fasciaColor, roughness: 0.6 });
var fb = new THREE.Mesh(new THREE.BoxGeometry(shopWidth + 0.3, 0.4, 0.12), fMat);
fb.position.set(centreX, 3.15, 0.1); building.add(fb);
// Fascia text
var fNameTex = makeCanvasTexture(512, 64, function(cx, w, h) {
var fc = '#' + fasciaColor.toString(16).padStart(6, '0');
cx.fillStyle = fc; cx.fillRect(0, 0, w, h);
cx.fillStyle = 'rgba(220, 190, 100, 0.75)';
var fontSize = fasciaText.length > 20 ? 16 : fasciaText.length > 12 ? 22 : 26;
cx.font = 'bold ' + fontSize + 'px Georgia';
cx.textAlign = 'center'; cx.textBaseline = 'middle';
cx.fillText(fasciaText, w/2, h/2);
cx.fillStyle = 'rgba(0, 0, 0, 0.12)';
for (var fw = 0; fw < 6; fw++) {
cx.fillRect(Math.random() * w, Math.random() * h, 30 + Math.random() * 50, 4 + Math.random() * 8);
}
});
var fNameMat = new THREE.MeshStandardMaterial({ map: fNameTex, roughness: 0.65, emissive: 0xc0a050, emissiveIntensity: 0.08 });
var fNamePlane = new THREE.Mesh(new THREE.PlaneGeometry(shopWidth, 0.3), fNameMat);
fNamePlane.position.set(centreX, 3.15, 0.17); building.add(fNamePlane);
// Fascia moulding
building.add(new THREE.Mesh(new THREE.BoxGeometry(shopWidth + 0.35, 0.04, 0.14), fasciaEdge).translateX(centreX).translateY(3.37).translateZ(0.12));
building.add(new THREE.Mesh(new THREE.BoxGeometry(shopWidth + 0.35, 0.04, 0.14), fasciaEdge).translateX(centreX).translateY(2.93).translateZ(0.12));
// Pilasters
building.add(new THREE.Mesh(new THREE.BoxGeometry(0.14, 2.8, 0.1), shopPilMat).translateX(centreX - halfW - 0.12).translateY(1.55).translateZ(0.1));
building.add(new THREE.Mesh(new THREE.BoxGeometry(0.14, 2.8, 0.1), shopPilMat).translateX(centreX + halfW + 0.12).translateY(1.55).translateZ(0.1));
// Display window
var gMat = new THREE.MeshStandardMaterial({
map: glassTex, roughness: 0.15, metalness: 0.2,
emissive: glassEmissive, emissiveIntensity: 0.1
});
var gWin = new THREE.Mesh(new THREE.BoxGeometry(shopWidth - 0.1, 2.2, 0.02), gMat);
gWin.position.set(centreX, 1.55, 0.22); building.add(gWin);
// Frame rails
building.add(new THREE.Mesh(new THREE.BoxGeometry(shopWidth, 0.06, 0.06), shopFrameMat).translateX(centreX).translateY(2.68).translateZ(0.22));
building.add(new THREE.Mesh(new THREE.BoxGeometry(shopWidth, 0.06, 0.06), shopFrameMat).translateX(centreX).translateY(0.42).translateZ(0.22));
// Mullion
building.add(new THREE.Mesh(new THREE.BoxGeometry(0.04, 2.22, 0.04), shopFrameMat).translateX(centreX).translateY(1.55).translateZ(0.24));
// Stall riser
var srMat = new THREE.MeshStandardMaterial({ color: fasciaColor, roughness: 0.7 });
building.add(new THREE.Mesh(new THREE.BoxGeometry(shopWidth - 0.1, 0.4, 0.08), srMat).translateX(centreX).translateY(0.22).translateZ(0.2));
// Emissive backplane — soft diffuse glow behind the glass
var backGlowMat = new THREE.MeshBasicMaterial({
color: glowColor, transparent: true, opacity: 0.15, side: THREE.DoubleSide
});
var backGlow = new THREE.Mesh(new THREE.PlaneGeometry(shopWidth - 0.2, 2.0), backGlowMat);
backGlow.position.set(centreX, 1.55, 0.18); building.add(backGlow);
// Spread of dim lights behind the glass — no visible hotspot
var gLightL = new THREE.PointLight(glowColor, 0.2, 5);
gLightL.position.set(centreX - halfW * 0.5, 1.6, -0.3); scene.add(gLightL);
var gLightR = new THREE.PointLight(glowColor, 0.2, 5);
gLightR.position.set(centreX + halfW * 0.5, 1.6, -0.3); scene.add(gLightR);
var gLightTop = new THREE.PointLight(glowColor, 0.15, 4);
gLightTop.position.set(centreX, 2.4, -0.2); scene.add(gLightTop);
// Forward spill onto pavement — set back behind the glass plane
var gSpill = new THREE.PointLight(glowColor, 0.3, 6);
gSpill.position.set(centreX, 1.5, 0.15); scene.add(gSpill);
return { glassMat: gMat, backGlow: backGlowMat, lights: [gLightL, gLightR, gLightTop, gSpill] };
}

// ============================================================
// LEFT SHOP 1 — "BOOKS & PRINTS" (wider, nearest the left door)
// ============================================================
var booksGlassTex = makeCanvasTexture(512, 512, function(cx, w, h) {
// Warm lit interior — can see in
cx.fillStyle = '#2a2018'; cx.fillRect(0, 0, w, h);
// Warm pool of light from inside
var intGlow = cx.createRadialGradient(w * 0.45, h * 0.4, 20, w * 0.5, h * 0.5, w * 0.8);
intGlow.addColorStop(0, 'rgba(190, 140, 70, 0.4)');
intGlow.addColorStop(0.4, 'rgba(150, 110, 50, 0.25)');
intGlow.addColorStop(1, 'rgba(80, 55, 25, 0.1)');
cx.fillStyle = intGlow; cx.fillRect(0, 0, w, h);
// Back wall
cx.fillStyle = 'rgba(90, 70, 40, 0.3)';
cx.fillRect(w * 0.02, h * 0.02, w * 0.96, h * 0.55);
// Bookcase on back wall — shelves with coloured spines
cx.fillStyle = '#3a2a18';
cx.fillRect(w * 0.05, h * 0.05, w * 0.55, h * 0.5);
// Shelf lines
cx.fillStyle = '#4a3820';
for (var sh = 0; sh < 4; sh++) {
cx.fillRect(w * 0.05, h * 0.05 + sh * h * 0.13, w * 0.55, h * 0.015);
}
// Book spines — different colours
var spineColors = ['#8a4030', '#4a6040', '#6a5030', '#3a4a6a', '#7a6030', '#5a3028', '#3a5a3a', '#6a4a2a'];
for (var sh = 0; sh < 3; sh++) {
for (var bk = 0; bk < 10; bk++) {
cx.fillStyle = spineColors[(bk + sh * 3) % spineColors.length];
var bkw = w * 0.02 + Math.random() * w * 0.02;
cx.fillRect(w * 0.07 + bk * w * 0.05, h * 0.065 + sh * h * 0.13, bkw, h * 0.11);
}
}
// Display table in foreground — stacked books
cx.fillStyle = '#4a3520';
cx.fillRect(w * 0.1, h * 0.62, w * 0.35, h * 0.06);
// Books laid flat on table
cx.fillStyle = '#7a5535';
cx.fillRect(w * 0.12, h * 0.58, w * 0.18, h * 0.035);
cx.fillStyle = '#5a6a4a';
cx.fillRect(w * 0.15, h * 0.55, w * 0.15, h * 0.03);
// Standing open book
cx.fillStyle = '#e0d8c0';
cx.beginPath(); cx.moveTo(w * 0.6, h * 0.55); cx.lineTo(w * 0.68, h * 0.62);
cx.lineTo(w * 0.76, h * 0.55); cx.closePath(); cx.fill();
// Floor
cx.fillStyle = 'rgba(35, 28, 18, 0.4)';
cx.fillRect(0, h * 0.7, w, h * 0.3);
// Subtle glass reflection streak
cx.fillStyle = 'rgba(140, 130, 110, 0.08)';
cx.beginPath(); cx.moveTo(w * 0.72, 0); cx.lineTo(w * 0.82, 0);
cx.lineTo(w * 0.67, h); cx.lineTo(w * 0.57, h); cx.closePath(); cx.fill();
// Grime at bottom edge of glass
var grimeGrad = cx.createLinearGradient(0, h * 0.85, 0, h);
grimeGrad.addColorStop(0, 'rgba(20, 18, 12, 0)');
grimeGrad.addColorStop(1, 'rgba(30, 25, 15, 0.25)');
cx.fillStyle = grimeGrad; cx.fillRect(0, 0, w, h);
});
var shopGawains = buildShopfront(-3.7, 2.0, "GAWAIN'S GREENS", 0x1a3020, booksGlassTex, 0xc09040, 0xc09040);

// ============================================================
// LEFT SHOP 2 — The Minotaur (further left, on the neighbour building)
// ============================================================
var deliGlassTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#28180e'; cx.fillRect(0, 0, w, h);
// Warm reddish interior glow — like a candlelit trattoria
var intGlow = cx.createRadialGradient(w * 0.5, h * 0.4, 20, w * 0.5, h * 0.5, w * 0.8);
intGlow.addColorStop(0, 'rgba(200, 110, 50, 0.4)');
intGlow.addColorStop(0.4, 'rgba(160, 80, 35, 0.25)');
intGlow.addColorStop(1, 'rgba(90, 45, 20, 0.1)');
cx.fillStyle = intGlow; cx.fillRect(0, 0, w, h);
// Back wall — warm terracotta
cx.fillStyle = 'rgba(100, 60, 35, 0.3)';
cx.fillRect(w * 0.02, h * 0.02, w * 0.96, h * 0.55);
// Shelving unit on back wall with bottles and jars
cx.fillStyle = '#3a2215';
cx.fillRect(w * 0.55, h * 0.05, w * 0.4, h * 0.5);
// Shelf lines
cx.fillStyle = '#4a3020';
for (var sh = 0; sh < 4; sh++) {
cx.fillRect(w * 0.55, h * 0.05 + sh * h * 0.13, w * 0.4, h * 0.015);
}
// Bottles on shelves — different colours (wine, spirits, oils)
var bottleColors = ['#5a2018', '#2a4a2a', '#8a6a20', '#3a1a2a', '#6a5a18', '#4a2a15', '#2a3a4a', '#7a4020'];
for (var sh = 0; sh < 3; sh++) {
for (var bt = 0; bt < 6; bt++) {
cx.fillStyle = bottleColors[(bt + sh * 2) % bottleColors.length];
cx.fillRect(w * 0.57 + bt * w * 0.06, h * 0.065 + sh * h * 0.13, w * 0.025, h * 0.11);
// Bottle neck
cx.fillRect(w * 0.575 + bt * w * 0.06, h * 0.05 + sh * h * 0.13, w * 0.015, h * 0.03);
}
}
// Hanging salami and prosciutto from ceiling beam
cx.fillStyle = '#5a2518';
cx.fillRect(w * 0.1, h * 0.05, w * 0.04, h * 0.2);
cx.fillStyle = '#6a3020';
cx.fillRect(w * 0.2, h * 0.08, w * 0.035, h * 0.18);
cx.fillStyle = '#4a2015';
cx.fillRect(w * 0.32, h * 0.06, w * 0.03, h * 0.22);
// Cheese wheel on counter
cx.fillStyle = '#c0a050';
cx.beginPath(); cx.arc(w * 0.25, h * 0.62, w * 0.06, 0, Math.PI * 2); cx.fill();
cx.fillStyle = '#a08838';
cx.beginPath(); cx.arc(w * 0.25, h * 0.62, w * 0.04, 0, Math.PI * 2); cx.fill();
// Counter / display case at bottom
cx.fillStyle = 'rgba(55, 35, 20, 0.45)';
cx.fillRect(0, h * 0.68, w, h * 0.06);
// Floor
cx.fillStyle = 'rgba(40, 28, 16, 0.4)';
cx.fillRect(0, h * 0.74, w, h * 0.26);
// Subtle glass reflection streak
cx.fillStyle = 'rgba(140, 120, 90, 0.08)';
cx.beginPath(); cx.moveTo(w * 0.2, 0); cx.lineTo(w * 0.3, 0);
cx.lineTo(w * 0.15, h); cx.lineTo(w * 0.05, h); cx.closePath(); cx.fill();
// Bottom grime
var grimeGrad = cx.createLinearGradient(0, h * 0.85, 0, h);
grimeGrad.addColorStop(0, 'rgba(20, 14, 8, 0)');
grimeGrad.addColorStop(1, 'rgba(28, 20, 12, 0.25)');
cx.fillStyle = grimeGrad; cx.fillRect(0, 0, w, h);
});
var shopMinotaur = buildShopfront(-5.8, 2.2, 'THE MINOTAUR', 0x3a1518, deliGlassTex, 0xc06030, 0xc06030);

// ============================================================
// RIGHT SHOP — MR PUNCH: NEWS BOOZE AND TOBACCO
// ============================================================
var tobaccoGlassTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#25200e'; cx.fillRect(0, 0, w, h);
// Yellowish fluorescent interior glow
var intGlow = cx.createRadialGradient(w * 0.5, h * 0.35, 20, w * 0.5, h * 0.45, w * 0.8);
intGlow.addColorStop(0, 'rgba(200, 185, 90, 0.38)');
intGlow.addColorStop(0.4, 'rgba(160, 150, 65, 0.22)');
intGlow.addColorStop(1, 'rgba(90, 80, 30, 0.08)');
cx.fillStyle = intGlow; cx.fillRect(0, 0, w, h);
// Back wall
cx.fillStyle = 'rgba(85, 75, 45, 0.3)';
cx.fillRect(w * 0.02, h * 0.02, w * 0.96, h * 0.55);
// Wall shelving — full of tobacco tins, bottles, magazines
cx.fillStyle = '#3a3018';
cx.fillRect(w * 0.05, h * 0.05, w * 0.9, h * 0.5);
// Shelf lines
cx.fillStyle = '#4a3e22';
for (var sh = 0; sh < 4; sh++) {
cx.fillRect(w * 0.05, h * 0.05 + sh * h * 0.13, w * 0.9, h * 0.015);
}
// Coloured items on shelves — tins, cartons, bottles
var itemColors = ['#a03020', '#2050a0', '#c0a020', '#208040', '#a06020', '#6030a0', '#c04030', '#30a060'];
for (var sh = 0; sh < 3; sh++) {
for (var it = 0; it < 12; it++) {
cx.fillStyle = itemColors[(it + sh * 4) % itemColors.length];
var iw = w * 0.02 + Math.random() * w * 0.03;
cx.fillRect(w * 0.07 + it * w * 0.07, h * 0.065 + sh * h * 0.13, iw, h * 0.1);
}
}
// Newspaper/magazine rack at left — fanned out papers
cx.fillStyle = '#d8d0c0';
cx.fillRect(w * 0.05, h * 0.58, w * 0.25, h * 0.04);
cx.fillStyle = '#c0b8a0';
cx.fillRect(w * 0.07, h * 0.55, w * 0.2, h * 0.035);
// Headlines — coloured mastheads
cx.fillStyle = '#a02020';
cx.fillRect(w * 0.08, h * 0.555, w * 0.08, h * 0.008);
cx.fillStyle = '#1a1a6a';
cx.fillRect(w * 0.18, h * 0.585, w * 0.07, h * 0.008);
// Bottles on right side — booze section
var boozeColors = ['#3a1a10', '#1a3a1a', '#5a4a18', '#2a1a2a'];
for (var bt = 0; bt < 5; bt++) {
cx.fillStyle = boozeColors[bt % boozeColors.length];
cx.fillRect(w * 0.65 + bt * w * 0.06, h * 0.56, w * 0.03, h * 0.12);
cx.fillRect(w * 0.655 + bt * w * 0.06, h * 0.53, w * 0.02, h * 0.04);
}
// Counter at bottom
cx.fillStyle = 'rgba(55, 48, 28, 0.45)';
cx.fillRect(0, h * 0.7, w, h * 0.06);
// Floor
cx.fillStyle = 'rgba(38, 32, 18, 0.4)';
cx.fillRect(0, h * 0.76, w, h * 0.24);
// Subtle glass reflection streak
cx.fillStyle = 'rgba(130, 125, 100, 0.08)';
cx.beginPath(); cx.moveTo(w * 0.6, 0); cx.lineTo(w * 0.7, 0);
cx.lineTo(w * 0.55, h); cx.lineTo(w * 0.45, h); cx.closePath(); cx.fill();
// Bottom grime
var grimeGrad = cx.createLinearGradient(0, h * 0.85, 0, h);
grimeGrad.addColorStop(0, 'rgba(18, 15, 8, 0)');
grimeGrad.addColorStop(1, 'rgba(24, 20, 12, 0.22)');
cx.fillStyle = grimeGrad; cx.fillRect(0, 0, w, h);
});
var shopPunch = buildShopfront(3.5, 1.8, 'MR PUNCH: NEWS, BOOZE AND TOBACCO', 0x2a2015, tobaccoGlassTex, 0xb0a040, 0xb0a040);

// ============================================================
// NEIGHBOURING BUILDINGS
// ============================================================
var leftNeighbour = new THREE.Mesh(new THREE.BoxGeometry(6, 15, 2), sootBrick);
leftNeighbour.position.set(-7.5, 7.5, -1);
leftNeighbour.castShadow = true;
scene.add(leftNeighbour);

for (var row = 0; row < 3; row++) {
var wf = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.2, 0.06), windowFrame);
wf.position.set(-7.5, 5 + row * 3.2, 0.02); scene.add(wf);
var wg = new THREE.Mesh(new THREE.BoxGeometry(0.55, 1.0, 0.04), (row === 1) ? warmGlass : darkGlass);
wg.position.set(-7.5, 5 + row * 3.2, 0.04); scene.add(wg);
}

var rightNeighbour = new THREE.Mesh(new THREE.BoxGeometry(6, 13, 2), redBrick);
rightNeighbour.position.set(7.5, 6.5, -1);
rightNeighbour.castShadow = true;
scene.add(rightNeighbour);

for (var row = 0; row < 3; row++) {
for (var col = 0; col < 2; col++) {
var wx2 = 6.5 + col * 2;
var wy2 = 4.5 + row * 3;
var wf2 = new THREE.Mesh(new THREE.BoxGeometry(0.7, 1.2, 0.06), windowFrame);
wf2.position.set(wx2, wy2, 0.02); scene.add(wf2);
var wg2 = new THREE.Mesh(new THREE.BoxGeometry(0.55, 1.0, 0.04), darkGlass);
wg2.position.set(wx2, wy2, 0.04); scene.add(wg2);
}
}

// Building across the road
var acrossRoad = new THREE.Mesh(new THREE.BoxGeometry(20, 12, 2), sootBrick);
acrossRoad.position.set(0, 6, 12); scene.add(acrossRoad);

// ============================================================
// CHIMNEYS
// ============================================================
var chimMat = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.85 });
placeMesh(new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -2, 14.75, -0.5);
placeMesh(new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, -2, 15.55, -0.5);
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.3, 6), chimMat, -2, 15.8, -0.5);
placeMesh(new THREE.BoxGeometry(0.5, 1.8, 0.5), chimMat, 2, 14.9, -0.5);
placeMesh(new THREE.BoxGeometry(0.6, 0.12, 0.6), chimMat, 2, 15.85, -0.5);

// ============================================================
// STREETLAMPS
// ============================================================
var lampLights = [];

function createStreetlamp(x, z, intensity) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
g.add(new THREE.Mesh(new THREE.CylinderGeometry(0.18, 0.28, 0.4, 8), postMat).translateY(0.2));
g.add(new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.1, 4.5, 6), postMat).translateY(2.45));
g.add(new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.4, 0.3), postMat).translateY(4.9));
var glassGeo = new THREE.BoxGeometry(0.22, 0.3, 0.22);
var glassMat2 = new THREE.MeshStandardMaterial({
color: 0x4a2005, roughness: 0.2, transparent: true, opacity: 0.7,
emissive: 0xe87818, emissiveIntensity: 0.6
});
g.add(new THREE.Mesh(glassGeo, glassMat2).translateY(4.9));
var light = new THREE.PointLight(0xe87818, intensity || 0.8, 15);
light.position.set(0, 4.8, 0);
light.castShadow = true;
g.add(light);
lampLights.push(light);
var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.8)');
grad.addColorStop(0.3, 'rgba(200, 90, 15, 0.3)');
grad.addColorStop(1, 'rgba(140, 50, 8, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var glowSpr = new THREE.Sprite(new THREE.SpriteMaterial({
map: glowTex, transparent: true, opacity: 0.6
}));
glowSpr.position.set(0, 4.9, 0);
glowSpr.scale.set(3.5, 3.5, 1);
g.add(glowSpr);
g.position.set(x, 0, z);
scene.add(g);
return light;
}

var doorLamp = createStreetlamp(-3.0, 1.8, 1.0);
createStreetlamp(6.0, 1.8, 0.25);
createStreetlamp(-10, 1.8, 0.15);

// ============================================================
// STREET FURNITURE
// ============================================================
var bollardMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.7, metalness: 0.3 });
placeMesh(new THREE.CylinderGeometry(0.08, 0.1, 0.7, 6), bollardMat, 2.2, 0.47, 2.2);
placeMesh(new THREE.SphereGeometry(0.1, 6, 4), bollardMat, 2.2, 0.85, 2.2);

var drainMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.7, metalness: 0.4 });
placeMesh(new THREE.BoxGeometry(0.5, 0.02, 0.35), drainMat, -1.0, 0.01, 2.8);

// Iron railing stumps
for (var i = 0; i < 3; i++) {
var stump = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.025, 0.25, 6), ironMat);
stump.position.set(-2.5 + i * 0.3, 0.25, 0.5);
scene.add(stump);
}

// ============================================================
// DRAINPIPE — runs between the two doors, cast iron
// ============================================================
var pipeMat = new THREE.MeshStandardMaterial({ color: 0x1a1a18, roughness: 0.7, metalness: 0.35 });
// Main vertical pipe
var pipeMain = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.04, 13.5, 6), pipeMat);
pipeMain.position.set(0.15, 6.85, 0.12); scene.add(pipeMain);
// Pipe brackets
for (var pb = 0; pb < 4; pb++) {
var bracket = new THREE.Mesh(new THREE.BoxGeometry(0.12, 0.06, 0.08), pipeMat);
bracket.position.set(0.15, 1.5 + pb * 3.5, 0.06); scene.add(bracket);
}
// Hopper head (funnel) near top
var hopper = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.05, 0.2, 6), pipeMat);
hopper.position.set(0.15, 13.3, 0.12); scene.add(hopper);
// Shoe (bottom bend) at ground
var shoe = new THREE.Mesh(new THREE.BoxGeometry(0.1, 0.15, 0.12), pipeMat);
shoe.position.set(0.15, 0.18, 0.18); scene.add(shoe);

// ============================================================
// PUDDLES
// ============================================================
for (var i = 0; i < 10; i++) {
var puddleMat = new THREE.MeshStandardMaterial({
color: 0x111115, roughness: 0.08, metalness: 0.7, transparent: true, opacity: 0.3
});
var puddle = new THREE.Mesh(new THREE.CircleGeometry(0.25 + Math.random() * 0.7, 16), puddleMat);
puddle.rotation.x = -Math.PI / 2;
puddle.position.set(Math.random() * 10 - 4, 0.015, 2 + Math.random() * 5);
scene.add(puddle);
}

var doorPuddleMat = new THREE.MeshStandardMaterial({
color: 0x0e1508, roughness: 0.05, metalness: 0.8, transparent: true, opacity: 0.45,
emissive: 0x8aaa30, emissiveIntensity: 0.05
});
var doorPuddle = new THREE.Mesh(new THREE.CircleGeometry(1.2, 20), doorPuddleMat);
doorPuddle.rotation.x = -Math.PI / 2;
doorPuddle.position.set(1.5, 0.015, 3.5);
scene.add(doorPuddle);

// Gutter puddle — dirty water pooling along the kerb
var gutterPuddleMat = new THREE.MeshStandardMaterial({
color: 0x0a0c06, roughness: 0.06, metalness: 0.75, transparent: true, opacity: 0.35
});
for (var gp = 0; gp < 5; gp++) {
var gutPud = new THREE.Mesh(new THREE.CircleGeometry(0.4 + Math.random() * 0.8, 14), gutterPuddleMat);
gutPud.rotation.x = -Math.PI / 2;
gutPud.position.set(-4 + Math.random() * 10, 0.012, 2.3 + Math.random() * 0.4);
scene.add(gutPud);
}

// ============================================================
// STREET LITTER — crumpled papers, fag ends, bottle
// ============================================================
var litterMat = new THREE.MeshStandardMaterial({ color: 0xc8c0a8, roughness: 0.9 });
var darkLitterMat = new THREE.MeshStandardMaterial({ color: 0x4a4438, roughness: 0.9 });
// Crumpled newspaper pages
for (var lt = 0; lt < 4; lt++) {
var paper = new THREE.Mesh(new THREE.BoxGeometry(0.15 + Math.random() * 0.12, 0.01, 0.1 + Math.random() * 0.08), litterMat);
paper.position.set(-3 + Math.random() * 8, 0.02, 0.6 + Math.random() * 1.8);
paper.rotation.y = Math.random() * Math.PI;
paper.rotation.z = (Math.random() - 0.5) * 0.3;
scene.add(paper);
}
// Cigarette ends — tiny yellowish cylinders
var cigMat = new THREE.MeshStandardMaterial({ color: 0xc8b880, roughness: 0.8 });
for (var cg = 0; cg < 8; cg++) {
var cigEnd = new THREE.Mesh(new THREE.CylinderGeometry(0.008, 0.008, 0.04, 4), cigMat);
cigEnd.rotation.z = Math.PI / 2;
cigEnd.rotation.y = Math.random() * Math.PI;
cigEnd.position.set(-2 + Math.random() * 6, 0.015, 0.4 + Math.random() * 2.0);
scene.add(cigEnd);
}
// A bottle on its side near the kerb
var bottleMat = new THREE.MeshStandardMaterial({ color: 0x1a3a18, roughness: 0.2, metalness: 0.3, transparent: true, opacity: 0.7 });
var bottle = new THREE.Mesh(new THREE.CylinderGeometry(0.035, 0.035, 0.22, 6), bottleMat);
bottle.rotation.z = Math.PI / 2;
bottle.rotation.y = 0.4;
bottle.position.set(2.8, 0.04, 2.0);
scene.add(bottle);

// Grime strip along building base — wet staining
var grimeStripMat = new THREE.MeshStandardMaterial({
color: 0x151208, roughness: 0.95, transparent: true, opacity: 0.4
});
var grimeStrip = new THREE.Mesh(new THREE.PlaneGeometry(9.2, 0.3), grimeStripMat);
grimeStrip.position.set(0, 0.15, 0.08);
scene.add(grimeStrip);

// ============================================================
// LIGHTING — deep-night palette + cold moonlight casting shadows
// ============================================================
scene.add(new THREE.AmbientLight(0x080815, 0.10));

var moonLight = new THREE.DirectionalLight(0x5868a8, 0.30);
moonLight.position.set(6, 20, -3);
moonLight.target.position.set(0, 3, 0);
scene.add(moonLight.target);
moonLight.castShadow = true;
moonLight.shadow.mapSize.width = 2048;
moonLight.shadow.mapSize.height = 2048;
moonLight.shadow.camera.near = 0.5;
moonLight.shadow.camera.far = 55;
moonLight.shadow.camera.left = -18;
moonLight.shadow.camera.right = 18;
moonLight.shadow.camera.top = 18;
moonLight.shadow.camera.bottom = -4;
moonLight.shadow.bias = -0.0008;
moonLight.shadow.normalBias = 0.04;
scene.add(moonLight);

function enableCrSceneShadows(root) {
  root.traverse(function(obj) {
    if (!(obj instanceof THREE.Mesh)) return;
    var mat = obj.material;
    if (mat && (mat.transparent === true && (mat.opacity || 1) < 0.7)) return;
    obj.receiveShadow = true;
    if (obj.position.y > 0.2 || (obj.geometry && obj.geometry.type !== 'PlaneGeometry')) {
      obj.castShadow = true;
    }
  });
}
setTimeout(function() { enableCrSceneShadows(scene); }, 0);

// Faint warm light from left fanlight
var fanlightGlow = new THREE.PointLight(0xc08030, 0.12, 4);
fanlightGlow.position.set(-1.5, 3.3, 0.5);
scene.add(fanlightGlow);

// Spotlight on the doors from the streetlamp (now on the left)
var doorSpot = new THREE.SpotLight(0xe8a040, 1.2, 10, Math.PI / 5, 0.6);
doorSpot.position.set(-3.0, 5.5, 2.8);
doorSpot.target.position.set(0, 1.8, 0.1);
doorSpot.castShadow = true;
scene.add(doorSpot);
scene.add(doorSpot.target);

var doorFill = new THREE.PointLight(0xd09040, 0.15, 5);
doorFill.position.set(2.5, 3.5, 2.5);
scene.add(doorFill);

// Brass highlight near the knobs
var brassHighlight = new THREE.PointLight(0xffe0a0, 0.2, 2.5);
brassHighlight.position.set(0, 1.6, 1.0);
scene.add(brassHighlight);

// ============================================================
// FOG — 4-layer sprite system
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(140, 135, 125, 0.32)');
grad.addColorStop(0.4, 'rgba(110, 105, 95, 0.15)');
grad.addColorStop(1, 'rgba(80, 75, 65, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(100, 95, 85, 0.18)');
grad.addColorStop(0.6, 'rgba(80, 75, 65, 0.08)');
grad.addColorStop(1, 'rgba(60, 55, 45, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var gingerFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.3)');
grad.addColorStop(0.3, 'rgba(210, 95, 18, 0.15)');
grad.addColorStop(0.6, 'rgba(180, 70, 12, 0.06)');
grad.addColorStop(1, 'rgba(140, 50, 8, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// LAYER 1: Ground-hugging
for (var i = 0; i < 60; i++) {
var fogMat = new THREE.SpriteMaterial({
map: thickFogTex, transparent: true, opacity: 0.3 + Math.random() * 0.25
});
var fog = new THREE.Sprite(fogMat);
fog.position.set(Math.random() * 40 - 15, 0.1 + Math.random() * 1.8, Math.random() * 30 - 5);
var s = 5 + Math.random() * 12;
fog.scale.set(s, s * 0.3, 1);
scene.add(fog);
fogSprites.push({
sprite: fog, baseX: fog.position.x,
drift: 0.002 + Math.random() * 0.005,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.004,
swayAmt: 0.4 + Math.random() * 0.8
});
}

// LAYER 2: Mid-height (behind building)
for (var i = 0; i < 15; i++) {
var mfMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true, opacity: 0.06 + Math.random() * 0.06
});
var mf = new THREE.Sprite(mfMat);
mf.position.set(Math.random() * 30 - 10, 2 + Math.random() * 4, 3 + Math.random() * 20);
var ms = 5 + Math.random() * 12;
mf.scale.set(ms, ms * 0.3, 1);
scene.add(mf);
fogSprites.push({
sprite: mf, baseX: mf.position.x,
drift: 0.003 + Math.random() * 0.006,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.005,
swayAmt: 0.5 + Math.random() * 1.2
});
}

// LAYER 3a: Ginger-tinted near streetlamp (fewer than Lackland's)
for (var i = 0; i < 15; i++) {
var gfMat = new THREE.SpriteMaterial({
map: gingerFogTex, transparent: true, opacity: 0.15 + Math.random() * 0.15
});
var gf = new THREE.Sprite(gfMat);
gf.position.set(-3.0 + (Math.random() - 0.5) * 8, 0.3 + Math.random() * 5, 2.5 + (Math.random() - 0.5) * 8);
var gs = 2 + Math.random() * 5;
gf.scale.set(gs, gs * 0.45, 1);
scene.add(gf);
fogSprites.push({
sprite: gf, baseX: gf.position.x,
drift: 0.002 + Math.random() * 0.004,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.002 + Math.random() * 0.004,
swayAmt: 0.3 + Math.random() * 0.5
});
}

// LAYER 3b: Sickly yellow-green haze hugging the building facade
var greenFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(120, 140, 45, 0.22)');
grad.addColorStop(0.3, 'rgba(90, 105, 30, 0.1)');
grad.addColorStop(0.6, 'rgba(60, 75, 20, 0.04)');
grad.addColorStop(1, 'rgba(40, 50, 10, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
for (var i = 0; i < 12; i++) {
var ggfMat = new THREE.SpriteMaterial({
map: greenFogTex, transparent: true, opacity: 0.12 + Math.random() * 0.12
});
var ggf = new THREE.Sprite(ggfMat);
ggf.position.set((Math.random() - 0.5) * 8, 0.2 + Math.random() * 3, (Math.random() - 0.5) * 4 + 1.5);
var ggs = 2 + Math.random() * 5;
ggf.scale.set(ggs, ggs * 0.35, 1);
scene.add(ggf);
fogSprites.push({
sprite: ggf, baseX: ggf.position.x,
drift: 0.001 + Math.random() * 0.003,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.001 + Math.random() * 0.003,
swayAmt: 0.2 + Math.random() * 0.4
});
}

// LAYER 4: High wisps (behind building)
for (var i = 0; i < 10; i++) {
var wMat = new THREE.SpriteMaterial({
map: thinFogTex, transparent: true, opacity: 0.04 + Math.random() * 0.05
});
var wisp = new THREE.Sprite(wMat);
wisp.position.set(Math.random() * 30 - 10, 8 + Math.random() * 7, 4 + Math.random() * 15);
wisp.scale.set(7 + Math.random() * 12, 2 + Math.random() * 3, 1);
scene.add(wisp);
fogSprites.push({
sprite: wisp, baseX: wisp.position.x,
drift: 0.004 + Math.random() * 0.008,
sway: Math.random() * Math.PI * 2,
swaySpeed: 0.003 + Math.random() * 0.006,
swayAmt: 0.6 + Math.random() * 1.5
});
}

// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();

function crAnimate() {
crAnimId = requestAnimationFrame(crAnimate);
var t = clock.getElapsedTime();

// Streetlamp flicker (slow, gentle)
for (var i = 0; i < lampLights.length; i++) {
var baseInt = (i === 0) ? 1.2 : (i === 1) ? 0.5 : 0.3;
var flicker = 0.92 + Math.sin(t * (0.3 + i * 0.15)) * 0.04 + Math.sin(t * (0.7 + i * 0.2)) * 0.02;
lampLights[i].intensity = baseInt * flicker;
}

// Fanlight glow pulse
fanlightGlow.intensity = 0.12 + Math.sin(t * 0.15) * 0.02;
fanlightGlassL.emissiveIntensity = 0.12 + Math.sin(t * 0.12) * 0.03;

// Door lighting (very slow breathing)
var doorBreath = 0.95 + Math.sin(t * 0.25) * 0.03;
doorSpot.intensity = 1.5 * doorBreath;
doorFill.intensity = 0.4 * doorBreath;
brassHighlight.intensity = 0.25 * doorBreath;

// Brass emissive
brassMat.emissive = brassMat.emissive || new THREE.Color(0x4a3008);
brassMat.emissiveIntensity = 0.05 * doorBreath;

// Colony Room window glow — gentle warm pulse
var colPulse = 0.95 + Math.sin(t * 0.18) * 0.04;
colGlowL.intensity = 0.2 * colPulse;
colGlowC.intensity = 0.25 * colPulse;
colGlowR.intensity = 0.1 * colPulse;

// Fog drift
for (var i = 0; i < fogSprites.length; i++) {
var f = fogSprites[i];
f.sway += f.swaySpeed;
f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
f.baseX += f.drift;
if (f.baseX > 20) f.baseX = -15;
}

// Gawain's shop glow — diffuse warm pulse
var booksPulse = Math.sin(t * 0.12) * 0.3 + Math.sin(t * 0.4) * 0.15;
booksPulse = Math.max(0, booksPulse);
shopGawains.glassMat.emissiveIntensity = 0.12 + booksPulse * 0.1;
shopGawains.backGlow.opacity = 0.12 + booksPulse * 0.06;
for (var si = 0; si < shopGawains.lights.length; si++) {
shopGawains.lights[si].intensity = (si < 3 ? 0.18 : 0.28) + booksPulse * 0.12;
}

// The Minotaur — warmer, brighter diffuse flicker
var deliPulse = Math.sin(t * 0.18) * 0.35 + Math.sin(t * 0.55) * 0.2;
deliPulse = Math.max(0, deliPulse);
shopMinotaur.glassMat.emissiveIntensity = 0.12 + deliPulse * 0.12;
shopMinotaur.backGlow.opacity = 0.14 + deliPulse * 0.07;
for (var si = 0; si < shopMinotaur.lights.length; si++) {
shopMinotaur.lights[si].intensity = (si < 3 ? 0.2 : 0.32) + deliPulse * 0.14;
}

// MR PUNCH — diffuse yellowish flicker
var tobPulse = Math.sin(t * 0.25) * 0.3 + Math.sin(t * 0.7) * 0.18;
tobPulse = Math.max(0, tobPulse);
shopPunch.glassMat.emissiveIntensity = 0.1 + tobPulse * 0.08;
shopPunch.backGlow.opacity = 0.1 + tobPulse * 0.05;
for (var si = 0; si < shopPunch.lights.length; si++) {
shopPunch.lights[si].intensity = (si < 3 ? 0.16 : 0.25) + tobPulse * 0.1;
}

// (Silhouette animation removed)

// Puddle reflection
doorPuddleMat.emissiveIntensity = 0.04 + Math.sin(t * 1.7) * 0.02;

renderer.render(scene, camera);
}

crAnimate();

// ============================================================
// OVERLAY ELEMENTS
// ============================================================

// Vignette
crVig = document.createElement('div');
crVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
crWrap.appendChild(crVig);

// Film grain
crGrain = document.createElement('canvas');
crGrain.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;opacity:0.02;mix-blend-mode:overlay;';
crGrain.width = 256; crGrain.height = 256;
crWrap.appendChild(crGrain);
crGrainCtx = crGrain.getContext('2d');
crGrainFrame = 0;

// Colorwash
crWash = document.createElement('div');
crWash.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;background:linear-gradient(180deg, rgba(10,8,25,0.3) 0%, rgba(5,5,15,0.08) 30%, rgba(5,5,15,0.08) 60%, rgba(5,3,2,0.4) 100%);';
crWrap.appendChild(crWash);

// Datestamp

// Location
crLoc = document.createElement('div');
crLoc.textContent = 'DEAN STREET, SOHO';
crLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px "Courier New",monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
crWrap.appendChild(crLoc);

// Button
crBtn = document.createElement('div');
crBtn.textContent = 'ENTER THE COLONY ROOM';
crBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(200,170,100,0.85);border:1px solid rgba(200,170,100,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
setTimeout(function() { crBtn.style.opacity = '1'; }, 2500);
crBtn.addEventListener('mouseenter', function() {
crBtn.style.color = 'rgba(230,200,120,0.95)';
crBtn.style.borderColor = 'rgba(200,170,100,0.6)';
});
crBtn.addEventListener('mouseleave', function() {
crBtn.style.color = 'rgba(200,170,100,0.85)';
crBtn.style.borderColor = 'rgba(200,170,100,0.3)';
});
crBtn.addEventListener('click', function() {
crWrap.style.transition = 'opacity 1.5s ease';
crWrap.style.opacity = '0';
setTimeout(function() {
if (crAnimId) cancelAnimationFrame(crAnimId);
crAnimId = null;
if (crWrap.parentNode) crWrap.parentNode.removeChild(crWrap);
var TARGET = 'The Colony Room Door';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
crWrap.appendChild(crBtn);

document.body.appendChild(crWrap);
}

setInterval(function() {
var container = document.getElementById('cr-container');
if (container && !crActive) {
initColonyRoom();
} else if (!container) {
crActive = false;
if (crAnimId) { cancelAnimationFrame(crAnimId); crAnimId = null; }
window._dssDisposeWrap('cr-wrap');
}
}, 300);
})();

// ====== RONNIE SCOTT'S SCENE — INLINE ======
(function() {
var rsActive = false;
var rsAnimId = null;
var rsWrap = null;
var rsVig = null;
var rsGrain = null;
var rsGrainCtx = null;
var rsGrainFrame = 0;
var rsWash = null;
var rsDate = null;
var rsLoc = null;
var rsBtn = null;

function initRonnieScotts() {
if (rsActive) return;
rsActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildRSScene(); };
document.head.appendChild(s);
} else {
buildRSScene();
}
}

function buildRSScene() {
rsWrap = document.createElement('div');
rsWrap.id = 'rs-wrap';
rsWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#050508;overflow:hidden;';

// ============================================================
// SCENE SETUP — RONNIE SCOTT'S 3D STREET VIEW
// ============================================================

// ============================================================
// HELPERS (must be defined before any textures)
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
scene.add(m);
return m;
}

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0a12);
scene.fog = new THREE.Fog(0x0a0a12, 5, 40);

var camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT — Standing on the pavement, looking down Frith Street
// Ronnie Scott's sign visible ahead on the left, street receding
// ============================================================
camera.position.set(8, 1.7, 2.5);
camera.lookAt(-6, 2.8, 1.5);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.48;
rsWrap.appendChild(renderer.domElement);
window._dssBindScene('rs-wrap', scene, renderer, camera);

// ============================================================
// MATERIALS
// ============================================================
var darkRedBrick = new THREE.MeshStandardMaterial({ color: 0x7a3a28, roughness: 0.9 });
var medBrick = new THREE.MeshStandardMaterial({ color: 0x8a4a38, roughness: 0.85 });
var lightBrick = new THREE.MeshStandardMaterial({ color: 0x9a5a48, roughness: 0.8 });
var darkPaint = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.7 });
var blackFascia = new THREE.MeshStandardMaterial({ color: 0x0a0a0a, roughness: 0.5 });
var whiteTrim = new THREE.MeshStandardMaterial({ color: 0xe8e4dc, roughness: 0.7 });
var creamTrim = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.75 });
var sillMat = new THREE.MeshStandardMaterial({ color: 0xdcd4c8, roughness: 0.7 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0xd8d0c0, roughness: 0.6 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a15, roughness: 0.2, metalness: 0.3 });
var ironMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.3 });
var pipeMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.9 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.85 });
var metalSignBg = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.4, metalness: 0.6 });
var neonMat = new THREE.MeshStandardMaterial({ color: 0xff6600, roughness: 0.1, metalness: 0.3, emissive: 0xff4400, emissiveIntensity: 0.8 });
var woodMat = new THREE.MeshStandardMaterial({ color: 0x3a2a1a, roughness: 0.8 });
var barrelMat = new THREE.MeshStandardMaterial({ color: 0x4a3a2a, roughness: 0.8 });

// ============================================================
// HELPERS
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
  var c = document.createElement('canvas');
  c.width = w; c.height = h;
  var cx = c.getContext('2d');
  drawFunc(cx, w, h);
  var tex = new THREE.CanvasTexture(c);
  tex.minFilter = THREE.LinearFilter;
  return tex;
}

function placeMesh(group, geo, mat, x, y, z) {
  var m = new THREE.Mesh(geo, mat);
  m.position.set(x, y, z);
  group.add(m);
  return m;
}

// ============================================================
// GROUND
// ============================================================
var ground = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

var road = new THREE.Mesh(new THREE.PlaneGeometry(8, 60), roadMat);
road.rotation.x = -Math.PI / 2;
road.position.set(0, -0.01, 10);
road.receiveShadow = true;
scene.add(road);

// Wet road surface (reflective sheen)
var wetMat = new THREE.MeshStandardMaterial({
  color: 0x1a1a1a, roughness: 0.15, metalness: 0.5, transparent: true, opacity: 0.25
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(14, 14), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(0, 0.01, 8);
scene.add(wetRoad);

// Road centre line
for (var rli = -6; rli < 20; rli += 2.5) {
  var roadLine = new THREE.Mesh(new THREE.PlaneGeometry(0.12, 1.5),
    new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.7, transparent: true, opacity: 0.3 }));
  roadLine.rotation.x = -Math.PI / 2;
  roadLine.position.set(0, 0.02, rli);
  scene.add(roadLine);
}

// ============================================================
