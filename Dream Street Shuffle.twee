}

// Drain grate
var grateMat = new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.6, metalness: 0.3 });
var grate = new THREE.Mesh(new THREE.BoxGeometry(0.4, 0.02, 0.3), grateMat);
grate.position.set(0, 0.08, 3.3);
scene.add(grate);
// Grate bars
for (var gbi = -0.15; gbi <= 0.15; gbi += 0.06) {
placeMesh(scene, new THREE.BoxGeometry(0.35, 0.025, 0.015), grateMat, 0, 0.09, 3.3 + gbi);
}

// Manhole cover
var manhole = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 0.5),
new THREE.MeshStandardMaterial({ color: 0x2a2a2a, roughness: 0.5, metalness: 0.3 }));
manhole.rotation.x = -Math.PI / 2;
manhole.position.set(2, 0.015, 6.5);
scene.add(manhole);

// ---- STREET FURNITURE ----
// Bollard near pub
var bollardMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.6, metalness: 0.2 });
placeMesh(scene, new THREE.CylinderGeometry(0.06, 0.08, 0.7, 8), bollardMat, 2.5, 0.35, 3.2);
placeMesh(scene, new THREE.SphereGeometry(0.07, 6, 6), bollardMat, 2.5, 0.72, 3.2);

// Dustbin / rubbish bin
var binMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.7 });
placeMesh(scene, new THREE.CylinderGeometry(0.2, 0.18, 0.6, 8), binMat, 5.5, 0.3, 1.5);
placeMesh(scene, new THREE.CylinderGeometry(0.22, 0.22, 0.04, 8), binMat, 5.5, 0.62, 1.5);

// Post box (red, classic British)
var postBoxMat = new THREE.MeshStandardMaterial({ color: 0x8a1a1a, roughness: 0.6 });
placeMesh(scene, new THREE.CylinderGeometry(0.15, 0.15, 1.0, 8), postBoxMat, -10, 0.5, 3.0);
placeMesh(scene, new THREE.CylinderGeometry(0.17, 0.15, 0.15, 8), postBoxMat, -10, 1.05, 3.0);
// Post slot
placeMesh(scene, new THREE.BoxGeometry(0.15, 0.02, 0.04),
new THREE.MeshStandardMaterial({ color: 0x0a0a0a }), -10, 0.8, 3.16);

// ============================================================
// STREETLAMPS
// ============================================================
var streetLampLights = [];

function createLamp(x, z) {
var g = new THREE.Group();
var castIron = new THREE.MeshStandardMaterial({ color: 0x1a1a18, roughness: 0.7, metalness: 0.4 });
var warmIron = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.6, metalness: 0.3 });

// Victorian fluted column — tapers elegantly
placeMesh(g, new THREE.CylinderGeometry(0.035, 0.06, 4.2, 8), castIron, 0, 2.1, 0);
// Decorative bulge at mid-height
placeMesh(g, new THREE.CylinderGeometry(0.065, 0.065, 0.12, 8), warmIron, 0, 2.8, 0);
// Ornate base plinth (stepped)
placeMesh(g, new THREE.CylinderGeometry(0.12, 0.16, 0.15, 8), castIron, 0, 0.075, 0);
placeMesh(g, new THREE.CylinderGeometry(0.1, 0.13, 0.1, 8), castIron, 0, 0.2, 0);
placeMesh(g, new THREE.BoxGeometry(0.35, 0.06, 0.35), castIron, 0, 0.0, 0);
// Collar below lantern
placeMesh(g, new THREE.CylinderGeometry(0.055, 0.04, 0.08, 8), warmIron, 0, 4.24, 0);
// Scroll brackets (4 curved supports meeting the lantern)
for (var sb = 0; sb < 4; sb++) {
var ang = sb * Math.PI / 2;
var sx = Math.cos(ang) * 0.07;
var sz = Math.sin(ang) * 0.07;
placeMesh(g, new THREE.BoxGeometry(0.015, 0.25, 0.015), warmIron, sx, 4.4, sz);
}

// Lantern — hexagonal gas lamp housing
placeMesh(g, new THREE.CylinderGeometry(0.1, 0.12, 0.04, 6), castIron, 0, 4.28, 0);  // base plate
placeMesh(g, new THREE.CylinderGeometry(0.1, 0.1, 0.04, 6), castIron, 0, 4.72, 0);   // top plate
// Lantern frame bars (6 vertical bars)
for (var lb = 0; lb < 6; lb++) {
var la = lb * Math.PI / 3;
var lbx = Math.cos(la) * 0.1;
var lbz = Math.sin(la) * 0.1;
placeMesh(g, new THREE.BoxGeometry(0.015, 0.42, 0.015), castIron, lbx, 4.5, lbz);
}
// Crown / finial on top
placeMesh(g, new THREE.CylinderGeometry(0.0, 0.06, 0.12, 6), castIron, 0, 4.82, 0);
placeMesh(g, new THREE.SphereGeometry(0.025, 6, 4), castIron, 0, 4.9, 0);

// Warm gas flame glow inside lantern (visible through glass)
var gasGlow = new THREE.MeshBasicMaterial({ color: 0xffdd88, transparent: true, opacity: 0.7 });
// Glass panels (6 sides, warm amber)
for (var gp = 0; gp < 6; gp++) {
var ga = gp * Math.PI / 3 + Math.PI / 6;
var gpx = Math.cos(ga) * 0.085;
var gpz = Math.sin(ga) * 0.085;
var glassPanel = new THREE.Mesh(new THREE.PlaneGeometry(0.09, 0.36), gasGlow);
glassPanel.position.set(gpx, 4.5, gpz);
glassPanel.rotation.y = -ga + Math.PI / 2;
g.add(glassPanel);
}
// Inner flame (tiny bright core)
var flameMat = new THREE.MeshBasicMaterial({ color: 0xffeedd });
placeMesh(g, new THREE.SphereGeometry(0.02, 4, 4), flameMat, 0, 4.5, 0);

// Warm gas light — pools of amber on the wet street
var light = new THREE.PointLight(0xffcc70, 0.8, 18);
light.position.set(0, 4.5, 0);
light.castShadow = true;
g.add(light);
streetLampLights.push(light);

// Atmospheric halo — large soft glow around the lamp
var haloTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
grad.addColorStop(0, 'rgba(255, 210, 120, 0.6)');
grad.addColorStop(0.15, 'rgba(255, 190, 90, 0.3)');
grad.addColorStop(0.4, 'rgba(200, 150, 60, 0.08)');
grad.addColorStop(1, 'rgba(150, 100, 40, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var halo = new THREE.Sprite(new THREE.SpriteMaterial({ map: haloTex, transparent: true, opacity: 0.6 }));
halo.position.set(0, 4.5, 0);
halo.scale.set(5, 5, 1);
g.add(halo);

// Secondary smaller halo (misty diffusion — post-rain moisture in air)
var mistTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
grad.addColorStop(0, 'rgba(255, 220, 160, 0.15)');
grad.addColorStop(0.5, 'rgba(200, 170, 120, 0.05)');
grad.addColorStop(1, 'rgba(150, 120, 80, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var mist = new THREE.Sprite(new THREE.SpriteMaterial({ map: mistTex, transparent: true, opacity: 0.4 }));
mist.position.set(0, 3.5, 0);
mist.scale.set(8, 6, 1);
g.add(mist);

g.position.set(x, 0, z);
scene.add(g);
}

// Front street lamps moved far out so they don't block shop signs
createLamp(-14, 3.5);
createLamp(13, 3.5);
createLamp(3, 12);
createLamp(-10, 12);

// ============================================================
// SILHOUETTES IN PUB WINDOWS
// ============================================================
var silhouettes = [];

function makeSilhouetteTex(seed) {
return makeCanvasTexture(256, 256, function(cx, w, h) {
var bg = cx.createRadialGradient(w / 2, h * 0.4, 10, w / 2, h * 0.5, w);
bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
cx.fillStyle = bg; cx.fillRect(0, 0, w, h);

var figureCount = 1 + Math.floor(seed * 2.5);
for (var f = 0; f < figureCount; f++) {
var fx = (w / (figureCount + 1)) * (f + 1);
var baseY = h * 0.98;
var headR = 14 + seed * 6;
var shoulderW = 35 + seed * 15;

cx.fillStyle = 'rgba(10, 5, 0, 0.85)';
// Body
cx.beginPath();
cx.moveTo(fx - shoulderW / 2, baseY - h * 0.35);
cx.lineTo(fx + shoulderW / 2, baseY - h * 0.35);
cx.lineTo(fx + shoulderW / 2 + 8, baseY);
cx.lineTo(fx - shoulderW / 2 - 8, baseY);
cx.closePath(); cx.fill();
// Shoulders
cx.beginPath();
cx.ellipse(fx, baseY - h * 0.38, shoulderW / 2 + 5, 14, 0, 0, Math.PI, true);
cx.fill();
// Neck
cx.fillRect(fx - 6, baseY - h * 0.48, 12, h * 0.1);
// Head
cx.beginPath();
cx.arc(fx + (f - 1) * 4, baseY - h * 0.52, headR, 0, Math.PI * 2);
cx.fill();

// Raised arm with glass (some figures)
if ((seed > 0.4 && f === 0) || (seed > 0.6 && f === 1)) {
cx.fillStyle = 'rgba(10, 5, 0, 0.8)';
cx.beginPath();
cx.moveTo(fx + shoulderW / 2, baseY - h * 0.38);
cx.lineTo(fx + shoulderW / 2 + 12, baseY - h * 0.6);
cx.lineTo(fx + shoulderW / 2 + 22, baseY - h * 0.6);
cx.lineTo(fx + shoulderW / 2 + 10, baseY - h * 0.35);
cx.closePath(); cx.fill();
// Glass
cx.fillRect(fx + shoulderW / 2 + 8, baseY - h * 0.7, 16, 22);
cx.fillStyle = 'rgba(180, 130, 40, 0.4)';
cx.fillRect(fx + shoulderW / 2 + 10, baseY - h * 0.68, 12, 14);
}

// Cigarette smoke (some figures)
if (seed > 0.5 && f === figureCount - 1) {
cx.strokeStyle = 'rgba(120, 120, 120, 0.2)';
cx.lineWidth = 2;
cx.beginPath();
cx.moveTo(fx + headR + 5, baseY - h * 0.52);
cx.quadraticCurveTo(fx + headR + 15, baseY - h * 0.6, fx + headR + 10, baseY - h * 0.7);
cx.stroke();
}
}
});
}

// Ground floor silhouettes
var gfWinXs = [-1.75, 0.5, 2.5];
var gfSeeds = [0.7, 0.3, 0.8];
for (var i = 0; i < gfWinXs.length; i++) {
var sTex = makeSilhouetteTex(gfSeeds[i]);
var sMat = new THREE.MeshBasicMaterial({
map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 2.0), sMat);
sPlane.position.set(gfWinXs[i], 1.6, 0.28);
pub.add(sPlane);
silhouettes.push({
mesh: sPlane, baseX: gfWinXs[i],
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.3 + Math.random() * 0.4,
swayAmt: 0.015 + Math.random() * 0.02
});
}

// Also add silhouettes in 1st floor windows (upstairs bar)
for (var i = 0; i < 2; i++) {
var upTex = makeSilhouetteTex(0.4 + i * 0.3);
var upMat = new THREE.MeshBasicMaterial({
map: upTex, transparent: true, side: THREE.DoubleSide, depthWrite: false, opacity: 0.6
});
var upPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 1.5), upMat);
upPlane.position.set(winXs[i + 1], 5.2, 0.12);
pub.add(upPlane);
silhouettes.push({
mesh: upPlane, baseX: winXs[i + 1],
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.2 + Math.random() * 0.3,
swayAmt: 0.01 + Math.random() * 0.015
});
}

// ============================================================
// WALKING FIGURE (distant silhouette crossing the street)
// ============================================================
var walkerTex = makeCanvasTexture(64, 128, function(cx, w, h) {
cx.fillStyle = 'rgba(10, 8, 5, 0.7)';
// Head
cx.beginPath(); cx.arc(w / 2, 20, 8, 0, Math.PI * 2); cx.fill();
// Body
cx.fillRect(w / 2 - 8, 28, 16, 40);
// Legs
cx.fillRect(w / 2 - 8, 68, 7, 35);
cx.fillRect(w / 2 + 1, 68, 7, 35);
// Hat brim
cx.fillRect(w / 2 - 12, 13, 24, 4);
});
var walkerMat = new THREE.MeshBasicMaterial({ map: walkerTex, transparent: true, side: THREE.DoubleSide, depthWrite: false });
var walker = new THREE.Mesh(new THREE.PlaneGeometry(0.6, 1.2), walkerMat);
walker.position.set(8, 0.6, 7);
scene.add(walker);

// ============================================================
// LIGHTING
// ============================================================
// Gloomy but visible — low ambient with cold moonlight
scene.add(new THREE.AmbientLight(0x121225, 0.25));
var moonLight = new THREE.DirectionalLight(0x445599, 0.1);
moonLight.position.set(5, 20, 10);
moonLight.castShadow = true;
scene.add(moonLight);

// Cold blue fill
var fillLight = new THREE.DirectionalLight(0x2233aa, 0.05);
fillLight.position.set(-5, 10, -5);
scene.add(fillLight);

// ============================================================
// FOG VOLUMES (4 layers)
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
grad.addColorStop(0, 'rgba(180, 170, 155, 0.25)');
grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.12)');
grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});
var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
grad.addColorStop(0, 'rgba(200, 160, 100, 0.12)');
grad.addColorStop(0.5, 'rgba(180, 140, 80, 0.05)');
grad.addColorStop(1, 'rgba(150, 120, 60, 0)');
cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// Layer 1: Ground-hugging fog — much more subtle, placed BEHIND camera (z > 5)
// to avoid passing in front of the pub windows and causing flashing
for (var i = 0; i < 20; i++) {
var fogMat = new THREE.SpriteMaterial({ map: thickFogTex, transparent: true, opacity: 0.06 + Math.random() * 0.06 });
var fogSprite = new THREE.Sprite(fogMat);
// Place behind / to sides — NOT in front of pub windows
var fz = 6 + Math.random() * 20;
fogSprite.position.set(Math.random() * 40 - 15, 0.3 + Math.random() * 1.5, fz);
var s = 5 + Math.random() * 10;
fogSprite.scale.set(s, s * 0.3, 1);
scene.add(fogSprite);
fogSprites.push({ sprite: fogSprite, baseX: fogSprite.position.x, drift: 0.0005 + Math.random() * 0.001, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0005 + Math.random() * 0.001, swayAmt: 0.3 + Math.random() * 0.5 });
}

// Layer 2: Mid-height fog — fewer, further back
for (var i = 0; i < 12; i++) {
var midFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.04 + Math.random() * 0.05 });
var midFog = new THREE.Sprite(midFogMat);
midFog.position.set(Math.random() * 35 - 12, 2 + Math.random() * 5, 8 + Math.random() * 20);
var ms = 6 + Math.random() * 12;
midFog.scale.set(ms, ms * 0.25, 1);
scene.add(midFog);
fogSprites.push({ sprite: midFog, baseX: midFog.position.x, drift: 0.0003 + Math.random() * 0.001, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0004 + Math.random() * 0.001, swayAmt: 0.3 + Math.random() * 0.8 });
}

// Layer 3: Warm tinted fog — only at ground level near pub, very faint
for (var i = 0; i < 6; i++) {
var warmFogMat = new THREE.SpriteMaterial({ map: warmFogTex, transparent: true, opacity: 0.04 + Math.random() * 0.04 });
var warmFog = new THREE.Sprite(warmFogMat);
warmFog.position.set(Math.random() * 8 - 2, 0.3 + Math.random() * 1, 3 + Math.random() * 4);
var ws = 3 + Math.random() * 5;
warmFog.scale.set(ws, ws * 0.2, 1);
scene.add(warmFog);
fogSprites.push({ sprite: warmFog, baseX: warmFog.position.x, drift: 0.0003 + Math.random() * 0.0008, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0005 + Math.random() * 0.001, swayAmt: 0.2 + Math.random() * 0.4 });
}

// Layer 4: High wisps — very faint, background only
for (var i = 0; i < 6; i++) {
var highFogMat = new THREE.SpriteMaterial({ map: thinFogTex, transparent: true, opacity: 0.03 + Math.random() * 0.04 });
var highFog = new THREE.Sprite(highFogMat);
highFog.position.set(Math.random() * 30 - 10, 10 + Math.random() * 6, 10 + Math.random() * 15);
var hs = 8 + Math.random() * 12;
highFog.scale.set(hs, hs * 0.15, 1);
scene.add(highFog);
fogSprites.push({ sprite: highFog, baseX: highFog.position.x, drift: 0.001 + Math.random() * 0.002, sway: Math.random() * Math.PI * 2, swaySpeed: 0.0003 + Math.random() * 0.001, swayAmt: 0.5 + Math.random() * 1.0 });
}

// ============================================================
// FILM GRAIN (animated canvas noise)
// ============================================================
var grainCanvas = document.createElement('canvas');
grainCanvas.width = 256; grainCanvas.height = 256;
var grainCtx = grainCanvas.getContext('2d');
var grainEl = document.getElementById('grain');
grainEl.style.backgroundSize = '256px 256px';
var grainFrame = 0;

function updateGrain() {
if (++grainFrame % 3 !== 0) return; // update every 3rd frame for subtlety
var imgData = grainCtx.createImageData(256, 256);
var d = imgData.data;
for (var i = 0; i < d.length; i += 4) {
var v = Math.random() * 255;
d[i] = d[i+1] = d[i+2] = v;
d[i+3] = 255;
}
grainCtx.putImageData(imgData, 0, 0);
grainEl.style.backgroundImage = 'url(' + grainCanvas.toDataURL() + ')';
}

// ============================================================
// ENHANCED WET REFLECTIONS
// ============================================================
// Add more prominent puddle reflections near the pub
var reflectMat = new THREE.MeshStandardMaterial({
color: 0x0a0a15, roughness: 0.05, metalness: 0.8,
transparent: true, opacity: 0.18
});
var bigReflect = new THREE.Mesh(new THREE.PlaneGeometry(8, 4), reflectMat);
bigReflect.rotation.x = -Math.PI / 2;
bigReflect.position.set(0.5, 0.015, 5);
scene.add(bigReflect);

// ============================================================
// ANIMATION LOOP
// ============================================================
var clock = new THREE.Clock();
var cameraBase = { x: camera.position.x, y: camera.position.y, z: camera.position.z };
// Camera base already set above

function fhAnimate() {
fhAnimId = requestAnimationFrame(fhAnimate);
var t = clock.getElapsedTime();

// Film grain — update very infrequently to avoid flashing
if (Math.floor(t * 2) !== Math.floor((t - 0.016) * 2)) {
updateGrain();
}

// Camera is COMPLETELY STATIC — no breathing, no movement
// (Camera movement was causing light angle changes that looked like flashing)

// Fog — completely static (drift was causing flashing as fog crossed windows)
// Fog sprites stay in their initial positions for atmosphere without movement

// ALL LIGHTS COMPLETELY STATIC — no oscillation, no flicker, no breathing
// (The original oscillations were causing visible flashing in the windows)

// Silhouettes — completely static (movement was causing flashing)
// They stay in their initial positions

// Flag flutter — gentle, post-rain calm
for (var i = 0; i < flagMeshes.length; i++) {
var fm = flagMeshes[i];
fm.mesh.rotation.z = fm.baseRotZ + Math.sin(t * 0.8 + fm.phase) * 0.02;
fm.mesh.rotation.x = -0.3 + Math.sin(t * 0.5 + fm.phase) * 0.01;
}
for (var i = 0; i < bigFlagMeshes.length; i++) {
var bfm = bigFlagMeshes[i];
bfm.mesh.rotation.z = Math.sin(t * 0.6 + bfm.phase) * 0.015;
}

// Walking figure (slower, more contemplative pace)
walker.position.x = 8 - ((t * 0.15) % 20);
if (walker.position.x < -12) walker.position.x = 8;

// Hanging sign — barely moving, damp and heavy
hangSign.rotation.z = Math.sin(t * 0.3) * 0.01;

// Wet road — static reflection (no shimmer that could look like flashing)
// bigReflect stays at its initial opacity

renderer.render(scene, camera);
}

fhAnimate();

// Approach button — fades in after 1.5s
var fhBtn = document.createElement('div');
fhBtn.textContent = 'ENTER THE FRENCH';
fhBtn.style.cssText = [
'position:absolute','bottom:60px','left:50%','transform:translateX(-50%)',
'font:13px \'Courier New\',monospace','color:rgba(200,170,100,0.85)',
'letter-spacing:4px','cursor:pointer','padding:12px 28px',
'border:1px solid rgba(200,170,100,0.3)','background:rgba(0,0,0,0.4)',
'z-index:9003','white-space:nowrap','opacity:0','transition:opacity 1.5s ease'
].join(';');
fhWrap.appendChild(fhBtn);
setTimeout(function() { fhBtn.style.opacity = '1'; }, 1500);

fhBtn.addEventListener('mouseenter', function() {
this.style.color = 'rgba(230,200,120,0.95)';
this.style.borderColor = 'rgba(200,170,100,0.6)';
});
fhBtn.addEventListener('mouseleave', function() {
this.style.color = 'rgba(200,170,100,0.85)';
this.style.borderColor = 'rgba(200,170,100,0.3)';
});

fhBtn.addEventListener('click', function() {
fhWrap.style.transition = 'opacity 1.2s ease';
fhWrap.style.opacity = '0';
setTimeout(function() {
cancelAnimationFrame(fhAnimId);
fhWrap.remove();
var TARGET = 'The French';
var link = document.querySelector('tw-link[passage-name="' + TARGET + '"]');
if (!link) {
var allLinks = document.querySelectorAll('tw-passage tw-link');
for (var i = 0; i < allLinks.length; i++) {
if (allLinks[i].textContent.trim() === '\u00B7') { link = allLinks[i]; break; }
}
}
if (link) {
link.click();
} else {
var storyEl = document.querySelector('tw-story') || document.body;
var injected = document.createElement('tw-link');
injected.setAttribute('passage-name', TARGET);
injected.style.display = 'none';
storyEl.appendChild(injected);
injected.click();
storyEl.removeChild(injected);
}
}, 1200);
});
}

// Watch for fh-container
setInterval(function() {
var container = document.getElementById('fh-container');
if (container && !fhActive) {
initFrenchHouse();
} else if (!container) {
fhActive = false;
}
}, 300);
})();

// ====== COACH AND HORSES SCENE — INLINE ======
(function() {
var chActive = false;
var chAnimId = null;

function initCoachHorses() {
if (chActive) return;
chActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildCHScene(); };
document.head.appendChild(s);
} else {
buildCHScene();
}
}

function buildCHScene() {
// Full-screen overlay wrapper
var chWrap = document.createElement('div');
chWrap.id = 'ch-wrap';
chWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#050508;';

// Vignette overlay
var chVig = document.createElement('div');
chVig.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9001;background:radial-gradient(ellipse at 45% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);';
chWrap.appendChild(chVig);

// Film grain overlay
var chGrain = document.createElement('canvas');
chGrain.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;opacity:0.02;mix-blend-mode:overlay;';
chGrain.width = 256; chGrain.height = 256;
chWrap.appendChild(chGrain);
var chGrainCtx = chGrain.getContext('2d');
var chGrainFrame = 0;

// Colorwash overlay
var chWash = document.createElement('div');
chWash.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9002;background:linear-gradient(180deg, rgba(10,8,25,0.3) 0%, rgba(5,5,15,0.08) 30%, rgba(5,5,15,0.08) 60%, rgba(5,3,2,0.4) 100%);';
chWrap.appendChild(chWash);

// Datestamp
var chDate = document.createElement('div');
chDate.textContent = document.getElementById('dst-after-midnight') ? '24.11.73' : '23.11.73';
chDate.style.cssText = 'position:absolute;top:18px;right:24px;font:14px monospace;color:rgba(255,140,50,0.4);pointer-events:none;z-index:9003;';
chWrap.appendChild(chDate);

// Location label
var chLoc = document.createElement('div');
chLoc.textContent = 'GREEK STREET SOUTH, SOHO';
chLoc.style.cssText = 'position:absolute;bottom:18px;left:50%;transform:translateX(-50%);font:12px \'Courier New\',monospace;color:rgba(200,180,140,0.25);letter-spacing:2px;pointer-events:none;z-index:9003;white-space:nowrap;';
chWrap.appendChild(chLoc);

document.body.appendChild(chWrap);

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x050508);

// Depth-based fog: linear fog from near to far gives that depth-buffer look
// Objects fade into murky darkness the further they are
// Thick Soho fog — starts close, swallows everything beyond mid-distance
scene.fog = new THREE.Fog(0x050508, 3, 28);

var camera = new THREE.PerspectiveCamera(58, window.innerWidth / window.innerHeight, 0.1, 200);

// ============================================================
// LAYOUT EXPLANATION
// ============================================================
// Corner of pub at origin (0, 0, 0)
// Greek St face: runs along -Z (z=0 to z=-5), facade at x≈0 faces +X
// Romilly St face: runs along -X (x=0 to x=-9), facade at z≈0 faces +Z
// Building bodies extend BEHIND facades (into -X and -Z)
// Camera at (+X, +Z) so it sees BOTH facades from the outside
//
// From camera: Greek St face on the RIGHT, Romilly face on the LEFT,
// corner banner in the MIDDLE — just like the photo!

camera.position.set(13, 2.8, 10);
camera.lookAt(-1, 3.5, -1);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping || THREE.LinearToneMapping;
renderer.toneMappingExposure = 0.55;
chWrap.appendChild(renderer.domElement);

window.addEventListener('resize', function() {
camera.aspect = window.innerWidth / window.innerHeight;
camera.updateProjectionMatrix();
renderer.setSize(window.innerWidth, window.innerHeight);
});

// ============================================================
// MATERIALS
// ============================================================
var creamWall = new THREE.MeshStandardMaterial({ color: 0xd8cfc0, roughness: 0.85 });
var darkCream = new THREE.MeshStandardMaterial({ color: 0xc0b8a8, roughness: 0.8 });
var redFacade = new THREE.MeshStandardMaterial({ color: 0x8b1a1a, roughness: 0.6 });
var brightRed = new THREE.MeshStandardMaterial({ color: 0xcc2020, roughness: 0.5 });
var goldMat = new THREE.MeshStandardMaterial({ color: 0xc0a040, roughness: 0.3, metalness: 0.4 });
var darkWood = new THREE.MeshStandardMaterial({ color: 0x2a1505, roughness: 0.7 });
var warmGlass = new THREE.MeshStandardMaterial({ color: 0x3a2510, roughness: 0.3, emissive: 0xc89030, emissiveIntensity: 0.15 });
var pavementMat = new THREE.MeshStandardMaterial({ color: 0x3a3a3a, roughness: 0.9 });
var roadMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.85 });
var blueBrick = new THREE.MeshStandardMaterial({ color: 0x3a4a6a, roughness: 0.85 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x8b4a3a, roughness: 0.85 });
var windowFrame = new THREE.MeshStandardMaterial({ color: 0xb0a890, roughness: 0.7 });
var darkGlass = new THREE.MeshStandardMaterial({ color: 0x0a0a15, roughness: 0.2, metalness: 0.3 });

// ============================================================
// HELPER: canvas texture
// ============================================================
function makeCanvasTexture(w, h, drawFunc) {
var c = document.createElement('canvas');
c.width = w; c.height = h;
var cx = c.getContext('2d');
drawFunc(cx, w, h);
var tex = new THREE.CanvasTexture(c);
tex.minFilter = THREE.LinearFilter;
return tex;
}

function makeSign(text, opts) {
var o = opts || {};
var w = o.w || 512; var h = o.h || 128;
var bg = o.bg || '#6b0e0e'; var fg = o.fg || '#c8a840';
var fs = o.fs || 36; var ff = o.ff || 'bold Georgia';
var tex = makeCanvasTexture(w, h, function(cx, cw, ch) {
cx.fillStyle = bg; cx.fillRect(0, 0, cw, ch);
if (o.border) {
cx.strokeStyle = fg; cx.lineWidth = 4;
cx.strokeRect(6, 6, cw - 12, ch - 12);
}
cx.fillStyle = fg; cx.font = fs + 'px ' + ff;
cx.textAlign = 'center'; cx.textBaseline = 'middle';
cx.fillText(text, cw/2, ch/2);
});
return new THREE.MeshStandardMaterial({ map: tex, roughness: 0.5 });
}

// ============================================================
// GROUND
// ============================================================
var pavement = new THREE.Mesh(new THREE.PlaneGeometry(60, 60), pavementMat);
pavement.rotation.x = -Math.PI / 2;
pavement.receiveShadow = true;
scene.add(pavement);

// Greek St road (runs along Z, east of the pub)
var greekRoad = new THREE.Mesh(new THREE.PlaneGeometry(8, 40), roadMat);
greekRoad.rotation.x = -Math.PI / 2;
greekRoad.position.set(5, -0.01, -5);
greekRoad.receiveShadow = true;
scene.add(greekRoad);

// Romilly St road (runs along X, south of the pub)
var romRoad = new THREE.Mesh(new THREE.PlaneGeometry(30, 8), roadMat);
romRoad.rotation.x = -Math.PI / 2;
romRoad.position.set(-10, -0.01, 5);
romRoad.receiveShadow = true;
scene.add(romRoad);

// Wet road reflections
var wetMat = new THREE.MeshStandardMaterial({
color: 0x1a1a1a, roughness: 0.2, metalness: 0.5, transparent: true, opacity: 0.25
});
var wetRoad = new THREE.Mesh(new THREE.PlaneGeometry(20, 20), wetMat);
wetRoad.rotation.x = -Math.PI / 2;
wetRoad.position.set(3, 0.01, 3);
scene.add(wetRoad);

// ============================================================
// THE COACH & HORSES
// ============================================================
var pub = new THREE.Group();

// ----- UPPER FLOORS -----
// Greek St wing body: extends from x=-6 to x=0, z=-5 to z=0
// Facade is at x=0, facing +X
var greekBody = new THREE.Mesh(new THREE.BoxGeometry(6, 8, 5), creamWall);
greekBody.position.set(-3, 8, -2.5);
greekBody.castShadow = true;
pub.add(greekBody);

// Romilly St wing body: extends from x=-9 to x=0, z=0 to z=-6
// Facade is at z=0, facing +Z
var romBody = new THREE.Mesh(new THREE.BoxGeometry(9, 8, 6), creamWall);
romBody.position.set(-4.5, 8, -3);
romBody.castShadow = true;
pub.add(romBody);

// Corner chamfer block — wider so the banner face is prominent
var cornerBlock = new THREE.Mesh(new THREE.BoxGeometry(3, 12.5, 3), creamWall);
cornerBlock.rotation.y = Math.PI / 4;
cornerBlock.position.set(-0.2, 6.25, -0.2);
pub.add(cornerBlock);

// Red ground floor on the chamfer face
var cornerRedBlock = new THREE.Mesh(new THREE.BoxGeometry(3.05, 4, 3.05), redFacade);
cornerRedBlock.rotation.y = Math.PI / 4;
cornerRedBlock.position.set(-0.2, 2, -0.2);
pub.add(cornerRedBlock);

// ----- CORNICES -----
// Top cornice — Greek St face (at x=0.08, running along -Z)
pub.add(makeCorniceBox(0.15, 0.4, 5.5, 0.08, 12, -2.5));
// Top cornice — Romilly face (at z=0.08, running along -X)
pub.add(makeCorniceBoxZ(9.5, 0.4, 0.15, -4.5, 12, 0.08));
// Mid cornice — Greek St
pub.add(makeCorniceBox(0.15, 0.3, 5.5, 0.08, 8, -2.5));
// Mid cornice — Romilly
pub.add(makeCorniceBoxZ(9.5, 0.3, 0.15, -4.5, 8, 0.08));

function makeCorniceBox(w, h, d, x, y, z) {
var m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), darkCream);
m.position.set(x, y, z);
return m;
}
function makeCorniceBoxZ(w, h, d, x, y, z) {
var m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), darkCream);
m.position.set(x, y, z);
return m;
}

// ----- GROUND FLOOR RED FACADES -----
// Greek St facade slab (at x=0.08, facing +X)
var greekRedSlab = new THREE.Mesh(new THREE.BoxGeometry(0.15, 4, 5), redFacade);
greekRedSlab.position.set(0.08, 2, -2.5);
pub.add(greekRedSlab);

// Romilly facade slab (at z=0.08, facing +Z)
var romRedSlab = new THREE.Mesh(new THREE.BoxGeometry(9, 4, 0.15), redFacade);
romRedSlab.position.set(-4.5, 2, 0.08);
pub.add(romRedSlab);

// Ground floor fill behind facades
var gfFill1 = new THREE.Mesh(
new THREE.BoxGeometry(6, 4, 5),
new THREE.MeshStandardMaterial({ color: 0x4a1010, roughness: 0.9 })
);
gfFill1.position.set(-3, 2, -2.5);
pub.add(gfFill1);
var gfFill2 = new THREE.Mesh(
new THREE.BoxGeometry(9, 4, 6),
new THREE.MeshStandardMaterial({ color: 0x4a1010, roughness: 0.9 })
);
gfFill2.position.set(-4.5, 2, -3);
pub.add(gfFill2);

// Red ground floor on corner
var cornerRed = new THREE.Mesh(new THREE.BoxGeometry(2, 4, 2), redFacade);
cornerRed.rotation.y = Math.PI / 4;
cornerRed.position.set(-0.3, 2, -0.3);
pub.add(cornerRed);

// ----- FASCIA SIGNS -----
// Greek St fascia (face +X, at x=0.16)
var greekFascia = new THREE.Mesh(
new THREE.PlaneGeometry(4.5, 0.55),
makeSign('THE  COACH  &  HORSES', { w: 512, h: 64, fs: 28, border: true })
);
greekFascia.rotation.y = Math.PI / 2; // face +X
greekFascia.position.set(0.16, 3.7, -2.5);
pub.add(greekFascia);

// Romilly fascia (face +Z, at z=0.16)
var romFascia = new THREE.Mesh(
new THREE.PlaneGeometry(8.5, 0.55),
makeSign('THE  COACH  &  HORSES', { w: 512, h: 64, fs: 28, border: true })
);
// face +Z — default plane faces +Z, no rotation needed
romFascia.position.set(-4.5, 3.7, 0.16);
pub.add(romFascia);

// ----- RED COLUMNS -----
function addColumn(x, y, z) {
var col = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.12, 3.2, 8), brightRed);
col.position.set(x, y, z);
col.castShadow = true;
pub.add(col);
var cap = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.12, 0.15, 8), goldMat);
cap.position.set(x, y + 1.65, z);
pub.add(cap);
var base = new THREE.Mesh(new THREE.CylinderGeometry(0.12, 0.15, 0.1, 8), goldMat);
base.position.set(x, y - 1.6, z);
pub.add(base);
}

// Greek St columns (at x=0.2, spaced along -Z)
addColumn(0.2, 2, -0.8);
addColumn(0.2, 2, -1.8);
addColumn(0.2, 2, -3.2);
addColumn(0.2, 2, -4.2);

// Romilly St columns (at z=0.2, spaced along -X)
addColumn(-1.5, 2, 0.2);
addColumn(-3.0, 2, 0.2);
addColumn(-4.5, 2, 0.2);
addColumn(-6.0, 2, 0.2);
addColumn(-7.5, 2, 0.2);

// ----- UPPER FLOOR WINDOWS -----
// Greek St windows: on the +X face (at x≈0.1), spaced along -Z
function addUpperWindow(x, y, z, faceX) {
// faceX = true means window on X face, false means on Z face
var ww = 0.7, wh = 1.5;
var frameGeo, glassGeo, barGeo;
if (faceX) {
frameGeo = new THREE.BoxGeometry(0.08, wh + 0.15, ww + 0.15);
glassGeo = new THREE.BoxGeometry(0.06, wh, ww);
barGeo = new THREE.BoxGeometry(0.09, 0.05, ww);
} else {
frameGeo = new THREE.BoxGeometry(ww + 0.15, wh + 0.15, 0.08);
glassGeo = new THREE.BoxGeometry(ww, wh, 0.06);
barGeo = new THREE.BoxGeometry(ww, 0.05, 0.09);
}
pub.add(new THREE.Mesh(frameGeo, windowFrame).tap(function(m){ m.position.set(x,y,z); }));
pub.add(new THREE.Mesh(glassGeo, warmGlass).tap(function(m){ m.position.set(x,y,z); }));
pub.add(new THREE.Mesh(barGeo, windowFrame).tap(function(m){ m.position.set(x,y+0.2,z); }));
}

// Since .tap doesn't exist on Mesh, let's use a helper
function placeMesh(geo, mat, x, y, z) {
var m = new THREE.Mesh(geo, mat);
m.position.set(x, y, z);
pub.add(m);
return m;
}

function addWin(x, y, z, faceX) {
var ww = 0.7, wh = 1.5;
if (faceX) {
placeMesh(new THREE.BoxGeometry(0.08, wh+0.15, ww+0.15), windowFrame, x, y, z);
placeMesh(new THREE.BoxGeometry(0.06, wh, ww), warmGlass, x, y, z);
placeMesh(new THREE.BoxGeometry(0.09, 0.05, ww), windowFrame, x, y+0.2, z);
placeMesh(new THREE.BoxGeometry(0.09, wh, 0.05), windowFrame, x, y, z); // vertical bar
} else {
placeMesh(new THREE.BoxGeometry(ww+0.15, wh+0.15, 0.08), windowFrame, x, y, z);
placeMesh(new THREE.BoxGeometry(ww, wh, 0.06), warmGlass, x, y, z);
placeMesh(new THREE.BoxGeometry(ww, 0.05, 0.09), windowFrame, x, y+0.2, z);
placeMesh(new THREE.BoxGeometry(0.05, wh, 0.09), windowFrame, x, y, z); // vertical bar
}
}

// Greek St upper windows (face +X at x=0.1)
addWin(0.1, 6, -1.0, true);
addWin(0.1, 6, -2.5, true);
addWin(0.1, 6, -4.0, true);
addWin(0.1, 10, -1.0, true);
addWin(0.1, 10, -2.5, true);
addWin(0.1, 10, -4.0, true);

// Romilly upper windows (face +Z at z=0.1)
addWin(-1.5, 6, 0.1, false);
addWin(-3.5, 6, 0.1, false);
addWin(-5.5, 6, 0.1, false);
addWin(-7.5, 6, 0.1, false);
addWin(-1.5, 10, 0.1, false);
addWin(-3.5, 10, 0.1, false);
addWin(-5.5, 10, 0.1, false);
addWin(-7.5, 10, 0.1, false);

// ----- GROUND FLOOR PUB WINDOWS -----
function addPubWin(x, y, z, faceX) {
var ww = 0.9, wh = 2.2;
if (faceX) {
placeMesh(new THREE.BoxGeometry(0.08, wh+0.1, ww+0.1), darkWood, x, y, z);
placeMesh(new THREE.BoxGeometry(0.06, wh, ww), warmGlass, x, y, z);
} else {
placeMesh(new THREE.BoxGeometry(ww+0.1, wh+0.1, 0.08), darkWood, x, y, z);
placeMesh(new THREE.BoxGeometry(ww, wh, 0.06), warmGlass, x, y, z);
}
}

// Greek St pub windows (face +X)
addPubWin(0.16, 1.8, -1.5, true);
addPubWin(0.16, 1.8, -3.5, true);

// Romilly pub windows (face +Z)
addPubWin(-2.0, 1.8, 0.16, false);
addPubWin(-4.0, 1.8, 0.16, false);
addPubWin(-6.0, 1.8, 0.16, false);
addPubWin(-8.0, 1.8, 0.16, false);

// ----- SILHOUETTES OF PEOPLE IN PUB WINDOWS -----
// Dark figure shapes on planes just inside the windows, swaying gently
var silhouettes = [];

function makeSilhouetteTex(seed) {
return makeCanvasTexture(256, 256, function(cx, w, h) {
// Warm amber interior glow background
var bg = cx.createRadialGradient(w/2, h*0.4, 10, w/2, h*0.5, w);
bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
cx.fillStyle = bg;
cx.fillRect(0, 0, w, h);

// Bold dark silhouettes against the warm glow
var figureCount = 1 + Math.floor(seed * 2.5);
for (var f = 0; f < figureCount; f++) {
var fx = (w / (figureCount + 1)) * (f + 1);
var baseY = h * 0.98;
var headR = 14 + seed * 6;
var shoulderW = 35 + seed * 15;

cx.fillStyle = 'rgba(10, 5, 0, 0.85)';

// Body — tall trapezoid
cx.beginPath();
cx.moveTo(fx - shoulderW/2, baseY - h*0.35);
cx.lineTo(fx + shoulderW/2, baseY - h*0.35);
cx.lineTo(fx + shoulderW/2 + 8, baseY);
cx.lineTo(fx - shoulderW/2 - 8, baseY);
cx.closePath();
cx.fill();

// Shoulders — wider ellipse
cx.beginPath();
cx.ellipse(fx, baseY - h*0.38, shoulderW/2 + 5, 14, 0, 0, Math.PI, true);
cx.fill();

// Neck
cx.fillRect(fx - 6, baseY - h*0.48, 12, h*0.1);

// Head — big and clear
cx.beginPath();
cx.arc(fx + (f - 1) * 4, baseY - h*0.52, headR, 0, Math.PI * 2);
cx.fill();

// Raised arm with pint for some figures
if ((seed > 0.4 && f === 0) || (seed > 0.6 && f === 1)) {
cx.fillStyle = 'rgba(10, 5, 0, 0.8)';
// Arm going up
cx.beginPath();
cx.moveTo(fx + shoulderW/2, baseY - h*0.38);
cx.lineTo(fx + shoulderW/2 + 12, baseY - h*0.6);
cx.lineTo(fx + shoulderW/2 + 22, baseY - h*0.6);
cx.lineTo(fx + shoulderW/2 + 10, baseY - h*0.35);
cx.closePath();
cx.fill();
// Pint glass shape
cx.fillRect(fx + shoulderW/2 + 8, baseY - h*0.7, 16, 22);
// Beer in glass (lighter)
cx.fillStyle = 'rgba(180, 130, 40, 0.4)';
cx.fillRect(fx + shoulderW/2 + 10, baseY - h*0.68, 12, 14);
}
}
});
}

// Greek St pub window silhouettes (face +X, at x=0.13, slightly behind glass)
var seeds = [0.3, 0.7];
var greekWinZ = [-1.5, -3.5];
for (var i = 0; i < 2; i++) {
var sTex = makeSilhouetteTex(seeds[i]);
var sMat = new THREE.MeshBasicMaterial({
map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.85, 2.0), sMat);
sPlane.rotation.y = Math.PI / 2; // face +X
sPlane.position.set(0.12, 1.8, greekWinZ[i]);
pub.add(sPlane);
silhouettes.push({
mesh: sPlane,
baseX: 0.12,
baseZ: greekWinZ[i],
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.3 + Math.random() * 0.4,
swayAmt: 0.02 + Math.random() * 0.03
});
}

// Romilly pub window silhouettes (face +Z, at z=0.13)
var romWinX = [-2.0, -4.0, -6.0, -8.0];
var romSeeds = [0.8, 0.2, 0.6, 0.4];
for (var i = 0; i < 4; i++) {
var sTex2 = makeSilhouetteTex(romSeeds[i]);
var sMat2 = new THREE.MeshBasicMaterial({
map: sTex2, transparent: true, side: THREE.DoubleSide, depthWrite: false
});
var sPlane2 = new THREE.Mesh(new THREE.PlaneGeometry(0.85, 2.0), sMat2);
// face +Z — default orientation
sPlane2.position.set(romWinX[i], 1.8, 0.12);
pub.add(sPlane2);
silhouettes.push({
mesh: sPlane2,
baseX: romWinX[i],
baseZ: 0.12,
swayPhase: Math.random() * Math.PI * 2,
swaySpeed: 0.2 + Math.random() * 0.5,
swayAmt: 0.02 + Math.random() * 0.03
});
}

// ----- PUB DOOR (Greek St face, near corner) -----
placeMesh(new THREE.BoxGeometry(0.08, 2.5, 1.0), darkWood, 0.16, 1.25, -2.5);
placeMesh(new THREE.BoxGeometry(0.06, 1.2, 0.7), warmGlass, 0.18, 1.8, -2.5);
placeMesh(new THREE.BoxGeometry(0.06, 0.15, 0.04), goldMat, 0.2, 1.3, -2.15);

// Door light
var doorLight = new THREE.PointLight(0xc89030, 0.8, 8);
doorLight.position.set(0.5, 2, -2.5);
pub.add(doorLight);

// ----- THE BIG CORNER BANNER -----
// This is the iconic sign — tall, filling the chamfer face
// In the photo it runs from just below roof to just above ground floor
var bannerTex = makeCanvasTexture(512, 1024, function(cx, w, h) {
// Deep red background
cx.fillStyle = '#6b0e0e';
cx.fillRect(0, 0, w, h);

// Gold border — thick and ornate
cx.strokeStyle = '#c0a040';
cx.lineWidth = 10;
cx.strokeRect(18, 18, w - 36, h - 36);
// Inner border line
cx.lineWidth = 3;
cx.strokeRect(30, 30, w - 60, h - 60);

cx.fillStyle = '#c8a840';
cx.textAlign = 'center';

// Main title — large
cx.font = 'bold 52px Georgia';
cx.fillText('THE', w/2, 100);
cx.font = 'bold 64px Georgia';
cx.fillText('COACH', w/2, 175);
cx.font = 'bold 52px Georgia';
cx.fillText('&', w/2, 240);
cx.font = 'bold 64px Georgia';
cx.fillText('HORSES', w/2, 315);

// Decorative line
cx.strokeStyle = '#c0a040';
cx.lineWidth = 2;
cx.beginPath();
cx.moveTo(100, 355); cx.lineTo(w - 100, 355);
cx.stroke();

cx.fillStyle = '#c8a840';
cx.font = '28px Georgia';
cx.fillText('BUILT IN 1847', w/2, 400);

// Decorative line
cx.beginPath();
cx.moveTo(120, 430); cx.lineTo(w - 120, 430);
cx.stroke();

cx.font = 'italic 34px Georgia';
cx.fillText("NORMAN'S", w/2, 480);

cx.font = 'bold 36px Georgia';
cx.fillText('THE', w/2, 545);
cx.font = 'bold 44px Georgia';
cx.fillText("WEST END'S", w/2, 600);
cx.font = 'bold 52px Georgia';
cx.fillText('BEST', w/2, 665);
cx.fillText('KNOWN', w/2, 730);
cx.font = 'bold 60px Georgia';
cx.fillText('PUB', w/2, 810);

// Decorative line
cx.strokeStyle = '#c0a040';
cx.lineWidth = 2;
cx.beginPath();
cx.moveTo(80, 855); cx.lineTo(w - 80, 855);
cx.stroke();

cx.font = 'italic 26px Georgia';
cx.fillText('Traditional', w/2, 905);
cx.font = 'bold 30px Georgia';
cx.fillText('BEERS & LAGERS', w/2, 955);
});
var bannerMat = new THREE.MeshStandardMaterial({
map: bannerTex, roughness: 0.4, emissive: 0x6b0e0e, emissiveIntensity: 0.35,
emissiveMap: bannerTex
});
// Banner faces outward from corner at 45° — toward (+X, +Z)
// Sized to fill most of the chamfer face: 2.5 wide, 7 tall
// The chamfer face diagonal = 3 * sqrt(2)/2 ≈ 2.12, so 2.0 wide fits nicely
// Use DoubleSide so it's visible from both directions, and BasicMaterial so lighting can't hide it
var bannerMeshMat = new THREE.MeshBasicMaterial({
map: bannerTex, side: THREE.DoubleSide
});
var banner = new THREE.Mesh(new THREE.PlaneGeometry(2.2, 8.0), bannerMeshMat);
// Position clearly in front of the chamfer wall
banner.position.set(1.6, 6, 1.6);
banner.rotation.y = Math.PI / 4; // face toward camera at (+X, +Z) — NOTE: positive PI/4!
pub.add(banner);

// Strong spot light on the banner — it should glow in the fog
var bannerSpot = new THREE.SpotLight(0xffddaa, 1.2, 15, Math.PI / 5, 0.3);
bannerSpot.position.set(3, 14, 3);
bannerSpot.target.position.set(1.6, 6, 1.6);
pub.add(bannerSpot);
pub.add(bannerSpot.target);

// Second light from below to catch the lower half
var bannerSpot2 = new THREE.PointLight(0xffccaa, 0.4, 8);
bannerSpot2.position.set(1.5, 2, 1.5);
pub.add(bannerSpot2);

// ----- HANGING PUB SIGN (Greek St face) -----
var signTex = makeCanvasTexture(128, 128, function(cx, w, h) {
cx.fillStyle = '#6b0e0e';
cx.fillRect(0, 0, w, h);
cx.strokeStyle = '#c0a040'; cx.lineWidth = 3;
cx.strokeRect(5, 5, w-10, h-10);
cx.fillStyle = '#c8a840';
cx.font = 'bold 16px Georgia'; cx.textAlign = 'center';
cx.fillText('COACH', w/2, 45);
cx.fillText('&', w/2, 65);
cx.fillText('HORSES', w/2, 85);
cx.font = '10px Georgia'; cx.fillText("NORMAN'S", w/2, 108);
});
var signMat = new THREE.MeshStandardMaterial({ map: signTex, roughness: 0.5, side: THREE.DoubleSide });
var hangSign = new THREE.Mesh(new THREE.PlaneGeometry(0.9, 0.9), signMat);
hangSign.position.set(1.2, 3.8, -4.2);
pub.add(hangSign);
// Bracket
var bracketMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.8 });
placeMesh(new THREE.BoxGeometry(1.2, 0.05, 0.05), bracketMat, 0.6, 4.3, -4.2);
placeMesh(new THREE.BoxGeometry(0.05, 0.55, 0.05), bracketMat, 1.2, 4.05, -4.2);

// ----- CHIMNEYS -----
var chimMat = new THREE.MeshStandardMaterial({ color: 0xa09080, roughness: 0.85 });
placeMesh(new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -2, 12.75, -1);
placeMesh(new THREE.BoxGeometry(0.5, 1.5, 0.5), chimMat, -6, 12.75, -2);
placeMesh(new THREE.BoxGeometry(0.6, 0.15, 0.6), chimMat, -2, 13.55, -1);
placeMesh(new THREE.BoxGeometry(0.6, 0.15, 0.6), chimMat, -6, 13.55, -2);

scene.add(pub);

// ============================================================
// NEIGHBOURING BUILDINGS
// ============================================================

// --- NEXT DOOR: Building adjoining pub on Greek St (further down the street) ---
// Greek St face ends at z=-5, so this building starts right there
// In the photo this is a dark/red brick building flush against the pub
var greekNextDoor = new THREE.Group();
var gndBody = new THREE.Mesh(new THREE.BoxGeometry(6, 13, 6), redBrick);
gndBody.position.set(-3, 6.5, -8);
gndBody.castShadow = true;
greekNextDoor.add(gndBody);
// Simple windows on the face visible to camera (at x=0, facing +X)
for (var row = 0; row < 3; row++) {
for (var col = 0; col < 2; col++) {
var wm = new THREE.Mesh(new THREE.BoxGeometry(0.06, 1.2, 0.6), darkGlass);
wm.position.set(0.05, 4 + row * 3.5, -6.5 - col * 2.5);
greekNextDoor.add(wm);
var wf = new THREE.Mesh(new THREE.BoxGeometry(0.08, 1.3, 0.7), windowFrame);
wf.position.set(0.04, 4 + row * 3.5, -6.5 - col * 2.5);
greekNextDoor.add(wf);
}
}
scene.add(greekNextDoor);

// A further building down Greek St beyond that one
var greekFarB = new THREE.Mesh(
new THREE.BoxGeometry(6, 11, 8),
new THREE.MeshStandardMaterial({ color: 0x5a4a3a, roughness: 0.9 })
);
greekFarB.position.set(-3, 5.5, -15);
greekFarB.castShadow = true;
scene.add(greekFarB);

// --- NEXT DOOR: Building adjoining pub on Romilly St ---
// Romilly face ends at x=-9, so this building starts right there
