var leftString2 = new THREE.Mesh(new THREE.BoxGeometry(5.3, 0.12, 0.2), leftStringMat);
leftString2.position.set(-6, 9, 0.12);
leftBuilding.add(leftString2);
var leftString3 = new THREE.Mesh(new THREE.BoxGeometry(5.3, 0.12, 0.2), leftStringMat);
leftString3.position.set(-6, 12, 0.12);
leftBuilding.add(leftString3);
// Quoin stones at corners (alternating blocks) — more prominent
var quoinMat = new THREE.MeshStandardMaterial({ color: 0xc0b090, roughness: 0.75 });
for (var qi = 0; qi < 7; qi++) {
  var qh = qi * 2 + 1;
  var qw = (qi % 2 === 0) ? 0.4 : 0.3;
  var ql = new THREE.Mesh(new THREE.BoxGeometry(qw, 0.55, 0.12), quoinMat);
  ql.position.set(-8.4, qh, 0.08);
  leftBuilding.add(ql);
  var qr = new THREE.Mesh(new THREE.BoxGeometry(qw, 0.55, 0.12), quoinMat);
  qr.position.set(-3.55, qh, 0.08);
  leftBuilding.add(qr);
}
