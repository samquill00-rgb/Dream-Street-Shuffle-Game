      hp.type = 'highpass'; hp.frequency.value = 60; hp.Q.value = 0.5;
      var g = ac.createGain();
      g.gain.setValueAtTime(0, now);
      g.gain.linearRampToValueAtTime(TARGET, now + 2.5);
