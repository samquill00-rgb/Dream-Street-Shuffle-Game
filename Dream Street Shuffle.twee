topRing.position.set(0, 4.95, 0);
heroLamp.add(topRing);

// --- LANTERN BRACKET (scrollwork) ---
// Curved scroll arms (simplified with angled cylinders)
var scrollMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.5, metalness: 0.5 });

// Left scroll arm
var scrollL = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 0.6, 6), scrollMat);
scrollL.rotation.z = Math.PI / 4;
scrollL.position.set(-0.15, 5.15, 0);
heroLamp.add(scrollL);

// Right scroll arm
var scrollR = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 0.6, 6), scrollMat);
scrollR.rotation.z = -Math.PI / 4;
scrollR.position.set(0.15, 5.15, 0);
heroLamp.add(scrollR);

// Front and back scroll arms
var scrollF = new THREE.Mesh(new THREE.CylinderGeometry(0.02, 0.02, 0.6, 6), scrollMat);
scrollF.rotation.x = Math.PI / 4;
scrollF.position.set(0, 5.15, -0.15);
