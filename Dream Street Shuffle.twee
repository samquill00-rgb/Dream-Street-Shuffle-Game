:: The critic's judgement [venue-pillars] {"position":"300,1400","size":"100,100"}
<div class="pillars-scene">
<div class="pillars-light"></div>
<div class="pillars-smoke"></div>
<div class="pillars-dust"><span style="left:12%;bottom:18%;animation-duration:7s;animation-delay:0s;"></span><span style="left:32%;bottom:8%;animation-duration:9.5s;animation-delay:1.2s;"></span><span style="left:52%;bottom:28%;animation-duration:6.5s;animation-delay:2.8s;"></span><span style="left:72%;bottom:5%;animation-duration:11s;animation-delay:0.4s;"></span><span style="left:22%;bottom:38%;animation-duration:8.5s;animation-delay:1.8s;"></span><span style="left:82%;bottom:22%;animation-duration:10s;animation-delay:3.5s;"></span><span style="left:42%;bottom:12%;animation-duration:7.8s;animation-delay:0.8s;"></span><span style="left:62%;bottom:32%;animation-duration:9s;animation-delay:2.2s;"></span></div>
<!-- Left broken pillar — Piranesi/Decline & Fall style -->
<svg class="pillar left" viewBox="0 0 34 280" preserveAspectRatio="xMidYMax meet"><defs><linearGradient id="pf" x1="0" x2="0" y1="0" y2="1"><stop offset="0%"   stop-color="#8ac8dc" stop-opacity="0.72"/><stop offset="60%"  stop-color="#8ac8dc" stop-opacity="0.42"/><stop offset="100%" stop-color="#8ac8dc" stop-opacity="0"/></linearGradient></defs><!-- Two-step plinth base --><rect x="1"  y="252" width="32" height="8"  fill="none" stroke="url(#pf)" stroke-width="1.1"/><rect x="4"  y="246" width="26" height="7"  fill="none" stroke="url(#pf)" stroke-width="1"/><!-- Shaft edges (slight taper: 24px wide at top, 26px at base) --><line x1="5"  y1="246" x2="6"  y2="88" stroke="url(#pf)" stroke-width="1.1"/><line x1="29" y1="246" x2="28" y2="88" stroke="url(#pf)" stroke-width="1.1"/><!-- Drum course bands every 22px --><line x1="5.3" y1="110" x2="28.7" y2="110" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="132" x2="28.5" y2="132" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="154" x2="28.5" y2="154" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="176" x2="28.5" y2="176" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="198" x2="28.5" y2="198" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="220" x2="28.5" y2="220" stroke="url(#pf)" stroke-width="0.65"/><line x1="5.5" y1="242" x2="28.5" y2="242" stroke="url(#pf)" stroke-width="0.65"/><!-- Faint fluting --><line x1="10" y1="88" x2="10" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="14" y1="88" x2="14" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="17" y1="88" x2="17" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="20" y1="88" x2="20" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="24" y1="88" x2="24" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><!-- Echinus (curved capital swell) --><path d="M6,88 Q5,78 3,72 L31,72 Q29,78 28,88" fill="none" stroke="url(#pf)" stroke-width="1.1"/><!-- Abacus slab — CRACKED, left portion collapsed inward --><!-- Right surviving portion: tilting down-left --><path d="M12,72 L32,68 L33,63 L13,66 Z" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.6"/><!-- Left fallen piece: a slab lying at an angle, partly off the shaft --><path d="M2,74 L-2,70 L8,67 L11,72 Z" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.45"/><!-- Fracture line across shaft top --><path d="M6,88 L9,83 L13,87 L17,80 L21,86 L25,79 L28,88" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.55"/><!-- A fallen drum section leaning against the shaft at ~1/3 height --><path d="M1,168 L3,160 L9,162 L9,170 L3,172 Z" fill="none" stroke="#8ac8dc" stroke-width="0.85" opacity="0.32"/><!-- Crack on shaft face --><path d="M13,130 L15,142 L12,150" fill="none" stroke="#8ac8dc" stroke-width="0.5" opacity="0.28"/><!-- Rubble at base --><path d="M3,255  L9,255  L10,260 L2,260 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.8" opacity="0.28"/><path d="M21,257 L28,257 L29,262 L20,261 Z" fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.22"/><path d="M13,260 L18,259 L19,264 L12,263 Z" fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.2"/></svg>
<!-- Right pillar — same shape, scaleX(-1) mirrors it so break faces inward -->
<svg class="pillar right" viewBox="0 0 34 280" preserveAspectRatio="xMidYMax meet"><defs><linearGradient id="pf2" x1="0" x2="0" y1="0" y2="1"><stop offset="0%"   stop-color="#8ac8dc" stop-opacity="0.72"/><stop offset="60%"  stop-color="#8ac8dc" stop-opacity="0.42"/><stop offset="100%" stop-color="#8ac8dc" stop-opacity="0"/></linearGradient></defs><rect x="1"  y="252" width="32" height="8"  fill="none" stroke="url(#pf2)" stroke-width="1.1"/><rect x="4"  y="246" width="26" height="7"  fill="none" stroke="url(#pf2)" stroke-width="1"/><!-- Shorter shaft: top at y=130 instead of y=88 — this pillar more ruined --><line x1="5"  y1="246" x2="6"  y2="130" stroke="url(#pf2)" stroke-width="1.1"/><line x1="29" y1="246" x2="28" y2="130" stroke="url(#pf2)" stroke-width="1.1"/><line x1="5.5" y1="152" x2="28.5" y2="152" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="174" x2="28.5" y2="174" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="196" x2="28.5" y2="196" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="218" x2="28.5" y2="218" stroke="url(#pf2)" stroke-width="0.65"/><line x1="5.5" y1="240" x2="28.5" y2="240" stroke="url(#pf2)" stroke-width="0.65"/><line x1="10" y1="130" x2="10" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="14" y1="130" x2="14" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="17" y1="130" x2="17" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="20" y1="130" x2="20" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><line x1="24" y1="130" x2="24" y2="245" stroke="#8ac8dc" stroke-width="0.3" opacity="0.22"/><!-- Echinus at top of shorter shaft --><path d="M6,130 Q5,120 3,114 L31,114 Q29,120 28,130" fill="none" stroke="url(#pf2)" stroke-width="1.1"/><!-- This column: abacus has COLLAPSED entirely — jagged stump and tilted block --><path d="M3,114 L6,107 L10,112 L14,104 L18,110 L22,102 L27,108 L31,114" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.6"/><!-- Large fallen capital block --><path d="M2,106 L-3,98 L14,94 L17,104 Z" fill="none" stroke="#8ac8dc" stroke-width="1" opacity="0.5"/><!-- Fracture running down shaft --><path d="M6,130 L9,125 L13,129 L17,122 L21,128 L25,121 L28,130" fill="none" stroke="#8ac8dc" stroke-width="0.9" opacity="0.55"/><path d="M9,142 L11,158 L8,164" fill="none" stroke="#8ac8dc" stroke-width="0.5" opacity="0.28"/><!-- Fallen drum leaning against shaft --><path d="M1,215 L3,207 L9,209 L9,217 L3,219 Z" fill="none" stroke="#8ac8dc" stroke-width="0.85" opacity="0.3"/><!-- Rubble at base --><path d="M3,255 L9,255 L10,260 L2,260 Z"    fill="none" stroke="#8ac8dc" stroke-width="0.8" opacity="0.28"/><path d="M22,257 L29,257 L30,262 L21,261 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.22"/><path d="M11,260 L17,259 L18,264 L10,263 Z"  fill="none" stroke="#8ac8dc" stroke-width="0.7" opacity="0.2"/></svg>
<!-- Lattice pub window at top -->
<svg class="pillars-lattice" viewBox="0 0 300 36" width="100%" height="36" preserveAspectRatio="none"><defs><linearGradient id="latEdge" x1="0" x2="1"><stop offset="0%"   stop-color="#7ab8cc" stop-opacity="0"/><stop offset="15%"  stop-color="#7ab8cc" stop-opacity="0.55"/><stop offset="85%"  stop-color="#7ab8cc" stop-opacity="0.55"/><stop offset="100%" stop-color="#7ab8cc" stop-opacity="0"/></linearGradient><pattern id="dLat" x="0" y="0" width="42" height="24" patternUnits="userSpaceOnUse"><path d="M7,0 L14,12 L7,24 L0,12 Z" fill="rgba(160,35,25,0.26)" stroke="#5a96aa" stroke-width="1" stroke-linejoin="round"/><path d="M21,0 L28,12 L21,24 L14,12 Z" fill="rgba(185,215,235,0.07)" stroke="#5a96aa" stroke-width="1" stroke-linejoin="round"/><path d="M35,0 L42,12 L35,24 L28,12 Z" fill="rgba(28,108,52,0.22)" stroke="#5a96aa" stroke-width="1" stroke-linejoin="round"/></pattern><mask id="latMask"><rect x="0" y="0" width="300" height="36" fill="url(#latEdge)"/></mask></defs><rect x="0" y="0" width="300" height="36" fill="url(#dLat)" mask="url(#latMask)"/><line x1="0" y1="34" x2="300" y2="34" stroke="url(#latEdge)" stroke-width="1.2"/></svg>
(set: $confidence to ($statLoss: $confidence, 9))
<span id="critBookTitle" style="display:none">(print: $bookTitle)</span>
He pulls //(print: $bookTitle)// close.

<div class="critic-book-widget">
<div class="critic-book-stage">
<div class="critic-book-base"></div>
<div class="critic-book-flip" id="critBookFlip"></div>
</div>
<div class="critic-book-narrate" id="critBookNarrate">He sets it on the table and opens it.</div>
<button class="critic-book-turn" id="critBookTurn" style="display:none;" aria-hidden="true">He turns the page.</button>
</div>

<div class="critic-aftermath" id="critAftermath">

//America, you think of new-found-land.//

You say you've not, thank him, and make to leave when he calls you back.

'When you're next in Cecil Court, look for Inis O'Flatterly. Quare fellow, knows a lot about books. I think he'd like to meet you. He's been trying to get to Carthage, on his way to The Pillars of Hercules.(if: $metSalvu is false)[ And if you see Copper, tell him I said hello.]'

(if: $knowsCopperWord is false and $metSalvu is false)[<div class="item-box critic-deferred-motes" data-motes="1">
<div class="item-header">⚿ PASSWORD LEARNED</div>
<div class="item-name">"I said hello"</div>
<div class="item-note">It&#39;s saved in your notebook <span class="item-note-arrow">&#8593;</span></div>
</div>
(set: $knowsCopperWord to true)]
(set: $knowsCecilCourt to true)

[[Try Dean Street again|Dean Street]]
</div>

<script>
(function(){
  // Page-turn narration is from the player's POV — they're sitting still,
  // watching him read. Each click advances time ("Wait."), narration
  // describes HIS action. Final click delivers the verdict; the aftermath
  // (with the password item-box) only then fades in, and the motes for
  // that item-box wait until after the aftermath has settled — they read
  // as the moment of "filing it away," not as paperwork mid-conversation.
  var page = 0;
  var lines = [
    "He reads a page in the middle.",
    "He turns to another page and reads there too.",
    "He skips ahead, scans a third.",
    "He sets the book down. 'Not for me,' he says. 'Have you tried America?'"
  ];
  // Direction per click — flicks back and forth to match the narration's
  // "middle → another → ahead → put down" rhythm. Forward = right page
  // lifts to the left (normal turn). Back = left page lifts to the right.
  var directions = ['forward', 'back', 'forward', 'back'];
  var btn = document.getElementById('critBookTurn');
  var narr = document.getElementById('critBookNarrate');
  var flip = document.getElementById('critBookFlip');
  var aftermath = document.getElementById('critAftermath');
  if (!btn || !narr || !flip || !aftermath) return;
  // Generate a fresh per-page text pattern so each turned page reads as a
  // different page of the manuscript. Picks one of four rhythms — dense
  // prose, airy/dialogue, prose with paragraph breaks, or section heading
  // — so the pages aren't a uniform pattern of dashes. The SVG is 78×96
  // and sits with 18px top + bottom margins inside the 132px-tall base,
  // so the text doesn't run to the page edges.
  function _genPageTextSVG() {
    var rhythm = Math.floor(Math.random() * 4);
    var rows = [];
    var allYs = [4, 16, 28, 40, 52, 64, 76, 88];
    function rowDashes(y, opts) {
      opts = opts || {};
      var startX = opts.indent || 0;
      var endX = (opts.endShort != null) ? opts.endShort : 78;
      var minW = opts.minW || 4, maxW = opts.maxW || 12;
      var minGap = opts.minGap || 2, maxGap = opts.maxGap || 4;
      var x = startX;
      while (x < endX) {
        var w = minW + Math.floor(Math.random() * (maxW - minW + 1));
        if (x + w > endX) w = endX - x;
        if (w < 2) break;
        rows.push('<rect x="' + x + '" y="' + y + '" width="' + w + '" height="1.4"/>');
        x += w + minGap + Math.floor(Math.random() * (maxGap - minGap + 1));
      }
    }
    if (rhythm === 0) {
      // DENSE PROSE — full rows, narrow gaps. Continuous block of writing.
      allYs.forEach(function(y){ rowDashes(y, {minW:4, maxW:12, minGap:2, maxGap:4}); });
    } else if (rhythm === 1) {
      // AIRY / DIALOGUE — wider dashes, big gaps; some rows skipped (whitespace).
      allYs.forEach(function(y){
        if (Math.random() < 0.25) return; // 25% chance of empty row
        rowDashes(y, {minW:6, maxW:18, minGap:6, maxGap:14});
      });
    } else if (rhythm === 2) {
      // PARAGRAPH BREAKS — dense, but 2-3 rows end short, and the next row
      // is indented (paragraph start).
      var breakIdxs = [];
      var n = 2 + Math.floor(Math.random() * 2);
      while (breakIdxs.length < n) {
        var idx = 1 + Math.floor(Math.random() * (allYs.length - 2));
        if (breakIdxs.indexOf(idx) < 0) breakIdxs.push(idx);
      }
      allYs.forEach(function(y, i){
        var indent = (breakIdxs.indexOf(i - 1) >= 0) ? 8 + Math.floor(Math.random() * 6) : 0;
        var endShort = (breakIdxs.indexOf(i) >= 0) ? 30 + Math.floor(Math.random() * 30) : 78;
        rowDashes(y, {indent:indent, endShort:endShort, minW:4, maxW:12, minGap:2, maxGap:4});
      });
    } else {
      // SECTION HEADING — short centered title at top, blank row, then dense body.
      var headW = 18 + Math.floor(Math.random() * 16);
      var headX = Math.floor((78 - headW) / 2);
      rows.push('<rect x="' + headX + '" y="4" width="' + headW + '" height="1.4"/>');
      // y=16 stays blank (whitespace under the heading)
      [28, 40, 52, 64, 76, 88].forEach(function(y){
        rowDashes(y, {minW:4, maxW:12, minGap:2, maxGap:4});
      });
    }
    return '<svg xmlns="http://www.w3.org/2000/svg" width="78" height="96"><g fill="rgba(40,28,16,0.62)">' + rows.join('') + '</g></svg>';
  }
  function _setPageText(el, svg, side) {
    // side: 'right' (default — anchored to right:18, used on the flip) or
    // 'left' (anchored to left:18, used on the base). Both base and flip
    // are 132px tall and start at stage y=18; placing the 96px-tall text
    // at top:18 within each leaves matching 18px top/bottom margins.
    var cls = 'critic-page-text' + (side === 'left' ? '-left' : '');
    var overlay = el.querySelector('.' + cls);
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.className = cls;
      var anchor = (side === 'left') ? 'left:18px' : 'right:18px';
      overlay.style.cssText = 'position:absolute;top:18px;' + anchor + ';width:78px;height:96px;background-repeat:no-repeat;background-size:78px 96px;opacity:0.78;pointer-events:none;backface-visibility:hidden;transition:opacity 0.35s ease;';
      el.appendChild(overlay);
    }
    overlay.style.backgroundImage = "url(\"data:image/svg+xml;utf8," + encodeURIComponent(svg) + "\")";
  }
  // Initial left + right page text. Two distinct rhythms, generated fresh
  // so each player sees a different opening spread.
  var _stageEl = flip.parentNode;
  var _base = _stageEl.querySelector('.critic-book-base');
  var _currentLeftSVG = _genPageTextSVG();
  var _currentPageSVG = _genPageTextSVG();
  if (_base) _setPageText(_base, _currentLeftSVG, 'left');
  _setPageText(flip, _currentPageSVG);
  function doTurn(){
    if (page >= lines.length) return;
    // Soft single-page rustle, not the busy 4-5 burst shuffle. The critic
    // is reading deliberately, not riffling.
    if (window.dssAudio && window.dssAudio.pageRustle) window.dssAudio.pageRustle();
    // Clean up any spawned pages from earlier clicks so the DOM doesn't
    // grow without bound. The original right-page (id=critBookFlip)
    // stays put — it's the visible right page underneath.
    var stage = flip.parentNode;
    var oldFlips = stage.querySelectorAll('.critic-book-flip');
    for (var k = 0; k < oldFlips.length; k++) {
      if (oldFlips[k].id !== 'critBookFlip') stage.removeChild(oldFlips[k]);
    }
    // One deliberate page-turn. 0.6s — quick but readable, alternating
    // direction so the spread flicks back and forth as the narration
    // describes him moving through the manuscript.
    var dir = directions[page] || 'forward';
    var isBackward = (dir === 'back');
    var freshPage = document.createElement('div');
    freshPage.className = 'critic-book-flip';
    freshPage.style.transition = 'transform 0.3s cubic-bezier(0.45, 0.05, 0.4, 1)';
    if (isBackward) {
      // Left page lifts at its outer edge and swings rightward over the
      // spine. transform-origin: right center pins the spine; rotateY
      // ends at +178° (mirror of the forward flip).
      freshPage.style.left = '0';
      freshPage.style.transformOrigin = 'right center';
      freshPage.style.boxShadow = '2px 0 6px rgba(0,0,0,0.22)';
    }
    // The spawned page carries the CURRENT text on its visible face —
    // left-anchored when going back, right-anchored when going forward.
    _setPageText(freshPage, isBackward ? _currentLeftSVG : _currentPageSVG, isBackward ? 'left' : 'right');
    stage.appendChild(freshPage);
    // Generate two NEW pages — one for the left, one for the right —
    // so each turn reveals a fresh spread. The new right text goes on the
    // static flip (revealed once the spawn passes 90° via backface-hidden).
    // The new left text gets a brief opacity fade so its change feels
    // less abrupt — the user's eye is on the flipping page anyway.
    _currentPageSVG = _genPageTextSVG();
    _setPageText(flip, _currentPageSVG);
    if (_base) {
      var leftOverlay = _base.querySelector('.critic-page-text-left');
      if (leftOverlay) leftOverlay.style.opacity = '0';
      setTimeout(function(){
        _currentLeftSVG = _genPageTextSVG();
        _setPageText(_base, _currentLeftSVG, 'left');
        var ov = _base.querySelector('.critic-page-text-left');
        if (ov) ov.style.opacity = '0.78';
      }, 110);
    }
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        freshPage.style.transform = isBackward ? 'rotateY(178deg)' : 'rotateY(-178deg)';
      });
    });
    // Narration timing: let the flip finish (0.6s) plus a brief settle
    // (~0.15s) before the verdict-fragment floats up. ~0.75s per beat.
    narr.style.opacity = '0';
    setTimeout(function(){
      narr.textContent = lines[page];
      narr.style.opacity = '1';
      page++;
      if (page >= lines.length) {
        // He's just said "He sets the book down." — close the book visually
        // before the verdict lands, so the close motion reads as the act of
        // setting it down. Aftermath fades in after the close finishes.
        closeBook();
        setTimeout(function(){
          aftermath.classList.add('revealed');
          setTimeout(function(){
            var box = aftermath.querySelector('.critic-deferred-motes');
            if (box && window.dssSpawnMotes) {
              box.removeAttribute('data-motes');
              window.dssSpawnMotes(box, 'item-mote', 18, { noScroll: true });
            }
          }, 500);
        }, 850);
      } else {
        // Schedule the next page turn — enough silence to let the
        // narration read, but not so long the scene drifts.
        setTimeout(doTurn, 1200);
      }
    }, 375);
  }
  function closeBook(){
    var stage = flip.parentNode;
    // Strip any leftover spawned flip pages from the back-and-forth turns.
    var oldFlips = stage.querySelectorAll('.critic-book-flip');
    for (var k = 0; k < oldFlips.length; k++) {
      if (oldFlips[k].id !== 'critBookFlip') stage.removeChild(oldFlips[k]);
    }
    if (window.dssAudio && window.dssAudio.pageRustle) window.dssAudio.pageRustle();
    // Fade page text on both halves so nothing cream shows through the close.
    var flipText = flip.querySelector('.critic-page-text');
    if (flipText) flipText.style.opacity = '0';
    if (_base) {
      var baseText = _base.querySelector('.critic-page-text-left');
      if (baseText) baseText.style.opacity = '0';
    }
    // Reuse the existing right-page element as the final shutting page so
    // we don't have two flipping things competing for the spread. The page
    // flips left (closing motion) and is then hidden outright — so the
    // final state is just the leather closed-book block from .book-closed.
    flip.style.transition = 'transform 0.4s cubic-bezier(0.45, 0.05, 0.4, 1)';
    flip.style.transform = 'rotateY(-178deg)';
    setTimeout(function(){
      flip.style.display = 'none';
      stage.classList.add('book-closed');
    }, 380);
  }
  // Initial settle — give the player a beat with the open book and the
  // opening narration before the first turn begins.
  setTimeout(doTurn, 850);
})();
</script>
</div>

:: The novelist [venue-french] {"position":"700,550","size":"100,100"}
(display: "French Rule SVG h60")
(set: $confidence to ($statLoss: $confidence, 9))
He's been reading it for longer than is comfortable for either of you.

At last, he pushes it back and asks: 'Is this yours?'

Before you can answer, he says, 'I don't know.'

