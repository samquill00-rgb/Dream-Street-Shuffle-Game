:: You speak to the poet [outdoor] {"position":"1400,450","size":"100,100"}
(set: $metRed to true)\
<!-- Ginger light -->
<div class="ginger-lamp-wrap">
<svg width="60" height="110" viewBox="0 0 60 110"><ellipse cx="30" cy="33" rx="40" ry="30" fill="rgba(200,100,5,0.10)"/><ellipse cx="30" cy="31" rx="24" ry="18" fill="rgba(220,130,10,0.18)"/><ellipse cx="30" cy="29" rx="13" ry="10" fill="rgba(255,190,60,0.22)"/><polygon points="27,2 30,0 33,2 32,7 28,7" fill="rgba(60,38,4,0.96)"/><path d="M13,7 Q30,4 47,7 L44,13 L16,13 Z" fill="rgba(60,38,4,0.96)"/><path d="M16,13 L44,13 L40,44 L20,44 Z" fill="rgba(130,75,8,0.45)" stroke="rgba(90,52,4,0.65)" stroke-width="1"/><path d="M19,15 L41,15 L37,42 L23,42 Z" fill="rgba(255,165,35,0.42)"/><ellipse cx="30" cy="29" rx="7" ry="10" fill="rgba(255,232,130,0.55)"/><ellipse cx="30" cy="27" rx="3" ry="4" fill="rgba(255,250,210,0.68)"/><rect x="22" y="44" width="16" height="6" rx="2.5" fill="rgba(60,38,4,0.96)"/><rect x="27" y="50" width="6" height="60" rx="2" fill="rgba(45,28,3,0.90)"/></svg>
</div>
<div class="ginger-scene">
<div class="ginger-light"></div>
'Red!' you say. He looks up, at first, then towards you without looking at you.

'What's the trouble, cock?'

'I need to sell a book.'

'Don't look so merly. Things turn up.'

You don't understand and smiling and then retreating, you strike, in the nifty, brisket air, a vein of his perfume, which you recognise, because you once loved a woman who wore the very same, as lily-of-the-valley.

[[Walk on|LINE 1]]
</div>

:: header header [header] {"position":"700,50","size":"100,100"}
<!-- BACK-FILL: heal $knowsCecilCourt on EVERY passage. Older saves from
     before the (set:) was added in The critic's judgement may have
     $metCritic=true with $knowsCecilCourt=false. -->
(unless: $knowsCecilCourt is a boolean)[(set: $knowsCecilCourt to false)]
(if: $metCritic is true and $knowsCecilCourt is false)[(set: $knowsCecilCourt to true)]
(set: _hideStats to (a: "White page", "Black page", "Title", "Start", "The Night Ahead", "Name Your Book", "A Doorway on Dean Street", "Dawn", "Dawn Approach White", "Dawn Approach Black", "Alba Complete", "Alba Incomplete", "Approach Centre Point", "The Fetch", "PP Pong", "Fight starts", "Fight Round 1", "Fight Round 2", "Fight Round 3", "Fight R1 Back", "Fight R1 Block", "Fight R1 Duck", "Fight R2 Catch", "Fight R2 Counter", "Fight R2 Slip", "Fight R3 Clinch", "Fight R3 Headon", "Fight R3 Weave", "Fight Victory", "Fight Defeat"))
(if: $returns is a number and $returns >= 1 and not (_hideStats contains (passage:)'s name))[(set: _saved to (savegame: "auto", "Auto save"))]\
(unless: _hideStats contains (passage:)'s name)[\
(if: $confidence is a number and $confidence < 0)[(set: $confidence to 0)](if: $confidence is a number and $confidence > 100)[(set: $confidence to 100)](if: $sobriety is a number and $sobriety < 0)[(set: $sobriety to 0)](if: $sobriety is a number and $sobriety > 100)[(set: $sobriety to 100)]\
(unless: $alba is an array)[(set: $alba to (a:))]\
(unless: $haunts is an array)[(set: $haunts to (a:))]\
<!-- BACK-FILL: heal saves made before the StoryInit [startup] fix.
     If $haunt1 isn't a string, StoryInit never ran (old [init] tag),
     so all $hauntN are 0 and $haunts may contain 0s. Reset both. -->
(unless: $haunt1 is a string)[(set: $haunt1 to "The Sketch")(set: $haunt2 to "The Refusal")(set: $haunt3 to "The Beast")(set: $haunt4 to "The Debt")(set: $haunt5 to "The Game")(set: $haunt6 to "The Delivery")(set: $haunt7 to "The Head")(set: $haunt8 to "The Wound")(set: $haunt9 to "The Sorting")(set: $haunt10 to "The Feeding")(set: $haunt11 to "The Spread")(set: $haunt12 to "The Crown")(set: $haunts to (a:))]\
(if: $haunts is an array)[\
(if: $haunts's length >= 12)[(enchant: ?page, (css: "background: linear-gradient(180deg, #1a1e28 0%, #252a3a 50%, #1a1e28 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 9)[(enchant: ?page, (css: "background: linear-gradient(180deg, #171a20 0%, #212430 50%, #171a20 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 6)[(enchant: ?page, (css: "background: linear-gradient(180deg, #141418 0%, #1e1e28 50%, #141418 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 3)[(enchant: ?page, (css: "background: linear-gradient(180deg, #171516 0%, #252224 50%, #171516 100%); background-attachment: fixed"))]
]\
(if: (passage:)'s name is "Maritime interlude")[(enchant: ?passage, (css: "animation: dssDrunkMid 9.5s ease-in-out infinite; transform-origin: 50% 30%;"))]\
<div class="stat-bars">
