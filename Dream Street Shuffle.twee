  }
  // Salt and vinegar (bigger bottles)
  placeMesh(shop, new THREE.CylinderGeometry(0.03, 0.025, 0.2, 5),
    new THREE.MeshStandardMaterial({ color: 0xd0d0c0, roughness: 0.5 }), -0.1, 1.55, 0.05);
  placeMesh(shop, new THREE.CylinderGeometry(0.03, 0.025, 0.2, 5),
    new THREE.MeshStandardMaterial({ color: 0x5a3a1a, roughness: 0.5 }), 0.1, 1.55, 0.05);

  // ---- GOLD NUMBER "7" above fascia ----
  var numTex = makeCanvasTexture(48, 48, function(cx, w, h) {
