:: Stay in Carthage {"position":"100,1950","size":"100,100"}
<svg class="carthage-pyre" viewBox="0 0 500 95" width="100%" height="95" preserveAspectRatio="none"><defs><radialGradient id="cpGlow" cx="50%" cy="85%" r="70%"><stop offset="0%" stop-color="#d4600a" stop-opacity="0.4"/><stop offset="30%" stop-color="#c84a08" stop-opacity="0.2"/><stop offset="60%" stop-color="#401808" stop-opacity="0.08"/><stop offset="100%" stop-color="#0a0a12" stop-opacity="0"/></radialGradient><linearGradient id="cpTopFade" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#0a0a12" stop-opacity="1"/><stop offset="35%" stop-color="#0a0a12" stop-opacity="0.6"/><stop offset="60%" stop-color="#0a0a12" stop-opacity="0"/><stop offset="100%" stop-color="#0a0a12" stop-opacity="0"/></linearGradient><linearGradient id="cpFade" x1="0" x2="1"><stop offset="0%" stop-color="#0a0a12" stop-opacity="1"/><stop offset="8%" stop-color="#0a0a12" stop-opacity="0"/><stop offset="92%" stop-color="#0a0a12" stop-opacity="0"/><stop offset="100%" stop-color="#0a0a12" stop-opacity="1"/></linearGradient><linearGradient id="cpGround" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3a2010" stop-opacity="0.5"/><stop offset="100%" stop-color="#1a0a08" stop-opacity="0.3"/></linearGradient></defs><rect x="0" y="77" width="500" height="18" fill="url(#cpGround)"/><rect x="0" y="0" width="500" height="95" fill="url(#cpGlow)"/><rect x="195" y="77" width="110" height="6" rx="1" fill="#3a2818" opacity="0.6"/><rect x="205" y="72" width="90" height="6" rx="1" fill="#4a3020" opacity="0.5"/><rect x="215" y="67" width="70" height="6" rx="1" fill="#5a3828" opacity="0.45"/><path d="M220,67 Q210,50 225,28 Q230,40 240,18 Q248,35 250,8 Q255,30 262,14 Q268,38 275,22 Q280,45 285,67Z" fill="#8a2800" opacity="0.35"/><path d="M225,67 Q218,48 232,22 Q238,36 245,10 Q250,28 255,6 Q260,25 268,16 Q272,40 278,67Z" fill="#c04808" opacity="0.45"/><path d="M230,67 Q224,45 237,18 Q242,32 248,8 Q253,28 258,12 Q264,35 270,67Z" fill="#d4600a" opacity="0.5"/><path d="M235,67 Q230,42 242,20 Q246,34 