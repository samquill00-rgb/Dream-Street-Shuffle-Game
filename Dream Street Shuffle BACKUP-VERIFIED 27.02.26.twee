        <line x1="5.5" y1="196" x2="28.5" y2="196" stroke="url(#pf2)" stroke-width="0.65"/>
        <line x1="5.5" y1="218" x2="28.5" y2="218" stroke="url(#pf2)" stroke-width="0.65"/>
