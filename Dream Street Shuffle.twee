});

// Window area: 3 columns x 6 rows of small panes with mullions
// Each side gets a large glass panel + red mullion grid overlay
var glassH = 1.2;
var glassW = 0.72;
var mullionMat = phoneRedMat;

function addPhoneWindowSide(faceAxis, offset, rotY) {
  // Main glass panel
  var glass = new THREE.Mesh(new THREE.PlaneGeometry(glassW, glassH), phoneGlassBright);
  glass.position.set(
    faceAxis === 'x' ? offset : 0,
    1.4,
    faceAxis === 'z' ? offset : 0
  );
  glass.rotation.y = rotY;
  phoneBox.add(glass);

  // Horizontal mullions (5 bars creating 6 rows)
  for (var mh = 0; mh < 5; mh++) {
    var hBar = new THREE.Mesh(new THREE.BoxGeometry(
      faceAxis === 'z' ? 0.76 : 0.025,
      0.02,
      faceAxis === 'x' ? 0.76 : 0.025
    ), mullionMat);
    hBar.position.set(
      faceAxis === 'x' ? offset * 1.02 : 0,
      0.9 + mh * 0.24,
      faceAxis === 'z' ? offset * 1.02 : 0
    );
    phoneBox.add(hBar);
  }
  // Vertical mullions (2 bars creating 3 columns)
  for (var mv = 0; mv < 2; mv++) {
    var vOff = -0.12 + mv * 0.24;
    var vBar = new THREE.Mesh(new THREE.BoxGeometry(
      faceAxis === 'z' ? 0.02 : 0.025,
      glassH,
      faceAxis === 'x' ? 0.02 : 0.025
    ), mullionMat);
    vBar.position.set(
      faceAxis === 'x' ? offset * 1.02 : vOff,
      1.4,
      faceAxis === 'z' ? offset * 1.02 : vOff
    );
    phoneBox.add(vBar);
  }
}

