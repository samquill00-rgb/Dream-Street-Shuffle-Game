0.8, 1.6, 0.65);
// Glazing bar on door glass
placeMesh(pub, new THREE.BoxGeometry(0.02, 1.0, 0.02), mahogany, 0.8, 1.6, 0.69);
placeMesh(pub, new THREE.BoxGeometry(0.6, 0.02, 0.02), mahogany, 0.8, 1.6, 0.69);
// Fanlight / transom above door
