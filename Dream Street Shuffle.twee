placeMesh(pub, new THREE.BoxGeometry(0.48, 0.03, 0.04), mahogany, px, 1.5, 0.63);
placeMesh(pub, new THREE.BoxGeometry(0.48, 0.03, 0.04), mahogany, px, 2.0, 0.63);
// Vertical glazing bar in each panel
