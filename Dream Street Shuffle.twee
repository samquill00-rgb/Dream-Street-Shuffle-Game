<svg class="dst-an-top" style="position:absolute;top:0;left:0;width:100%;pointer-events:none;z-index:1;opacity:0.78;" viewBox="0 0 420 68" preserveAspectRatio="xMidYMin meet" aria-hidden="true"><defs><linearGradient id="dstAnFadeL" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="white"/><stop offset="50%" stop-color="white"/><stop offset="85%" stop-color="white" stop-opacity="0.3"/><stop offset="100%" stop-color="black"/></linearGradient><linearGradient id="dstAnFadeR" x1="1" y1="0" x2="0" y2="0"><stop offset="0%" stop-color="white"/><stop offset="50%" stop-color="white"/><stop offset="85%" stop-color="white" stop-opacity="0.3"/><stop offset="100%" stop-color="black"/></linearGradient><mask id="dstAnMaskL" maskUnits="userSpaceOnUse" x="0" y="0" width="210" height="68"><rect x="0" y="0" width="210" height="68" fill="url(#dstAnFadeL)"/></mask><mask id="dstAnMaskR" maskUnits="userSpaceOnUse" x="210" y="0" width="210" height="68"><rect x="210" y="0" width="210" height="68" fill="url(#dstAnFadeR)"/></mask><g id="dstAnLily"><!-- Main stem --><path d="M40,-4 Q45,8 52,20 Q60,34 72,42 Q88,52 110,56 Q135,60 165,58 Q185,54 210,48" fill="none" stroke="#6a94c8" stroke-width="3.5" stroke-linecap="round"/><path d="M72,42 Q68,50 62,58 Q58,64 54,72" fill="none" stroke="#6a94c8" stroke-width="2.8" stroke-linecap="round"/><!-- Left leaf --><path d="M38,-2 Q28,6 18,18 Q10,30 8,40 Q6,50 14,56 Q24,60 36,54 Q46,46 50,34 Q52,24 48,14 Q44,6 38,-2 Z" fill="#2a4878" fill-opacity="0.28" stroke="#6a94c8" stroke-width="3.2" stroke-linejoin="round"/><path d="M38,-2 Q30,14 22,30 Q16,42 14,56" fill="none" stroke="#6a94c8" stroke-width="2" opacity="0.6"/><path d="M30,10 Q24,14 18,20" fill="none" stroke="#6a94c8" stroke-width="1.2" opacity="0.35"/><path d="M26,22 Q20,28 14,34" fill="none" stroke="#6a94c8" stroke-width="1.2" opacity="0.3"/><path d="M22,34 Q18,40 14,46" fill="none" stroke="#6a94c8" stroke-width="1" opacity="0.25"/><!-- Right leaf --><path d="M44,0 Q56,8 66,20 Q74,32 76,42 Q78,52 72,58 Q62,64 50,60 Q42,54 40,44 Q38,34 40,22 Q42,12 44,0 Z" fill="#1e3860" fill-opacity="0.22" stroke="#6a94c8" stroke-width="3.2" stroke-linejoin="round"/><path d="M44,0 Q56,16 66,32 Q72,44 72,58" fill="none" stroke="#6a94c8" stroke-width="2" opacity="0.55"/><path d="M50,10 Q58,16 64,22" fill="none" stroke="#6a94c8" stroke-width="1.2" opacity="0.3"/><path d="M54,22 Q62,28 68,34" fill="none" stroke="#6a94c8" stroke-width="1.2" opacity="0.28"/><path d="M58,34 Q66,40 72,46" fill="none" stroke="#6a94c8" stroke-width="1" opacity="0.22"/><!-- Flower 1 --><path d="M80,38 Q76,42 72,50 Q70,56 74,60 Q78,64 84,62 Q90,58 88,50 Q86,42 80,38 Z" fill="#c0d8ec" fill-opacity="0.45" stroke="#6a94c8" stroke-width="2.8" stroke-linejoin="round"/><path d="M76,50 L80,60" fill="none" stroke="#6a94c8" stroke-width="1.2" opacity="0.4"/><path d="M84,48 L82,60" fill="none" stroke="#6a94c8" stroke-width="1" opacity="0.35"/><path d="M80,38 Q82,34 86,30 Q90,26 92,22" fill="none" stroke="#6a94c8" stroke-width="2.2" stroke-linecap="round"/><!-- Flower 2 --><path d="M102,34 Q98,38 96,44 Q94,50 98,54 Q102,56 106,52 Q110,48 108,42 Q106,36 102,34 Z" fill="#b0ccdc" fill-opacity="0.4" stroke="#6a94c8" stroke-width="2.6" stroke-linejoin="round"/><path d="M100,44 L100,54" fill="none" stroke="#6a94c8" stroke-width="1" opacity="0.35"/><path d="M102,34 Q104,30 108,26" fill="none" stroke="#6a94c8" stroke-width="2" stroke-linecap="round"/><!-- Flower 3 --><path d="M126,30 Q122,34 120,40 Q118,46 122,48 Q126,50 130,46 Q132,40 130,34 Q128,30 126,30 Z" fill="#a8c4dc" fill-opacity="0.35" stroke="#6a94c8" stroke-width="2.4" stroke-linejoin="round"/><path d="M126,30 Q128,26 132,22" fill="none" stroke="#6a94c8" stroke-width="1.8" stroke-linecap="round"/><!-- Flower 4 --><path d="M152,26 Q148,30 148,36 Q150,40 154,38 Q158,34 156,28 Q154,26 152,26 Z" fill="#a0bcd8" fill-opacity="0.3" stroke="#6a94c8" stroke-width="2.2" stroke-linejoin="round"/><path d="M152,26 Q154,22 158,18" fill="none" stroke="#6a94c8" stroke-width="1.6" stroke-linecap="round"/><!-- Flower 5 --><path d="M170,22 Q168,26 168,30 Q170,34 174,30 Q176,26 172,22 Z" fill="#98b4d4" fill-opacity="0.28" stroke="#6a94c8" stroke-width="2" stroke-linejoin="round"/><path d="M170,22 Q172,18 176,14" fill="none" stroke="#6a94c8" stroke-width="1.4" stroke-linecap="round"/><!-- Small leaf --><path d="M110,56 Q118,52 124,56 Q128,62 122,66 Q114,68 110,62 Q108,58 110,56 Z" fill="#2e4a78" fill-opacity="0.18" stroke="#6a94c8" stroke-width="2" stroke-linejoin="round" opacity="0.6"/><!-- Background lead --><path d="M0,20 Q10,18 20,22 Q30,26 36,30" fill="none" stroke="#6a94c8" stroke-width="1.5" opacity="0.25"/><path d="M0,50 Q8,46 16,48 Q24,52 30,50" fill="none" stroke="#6a94c8" stroke-width="1.3" opacity="0.2"/><path d="M160,58 Q172,54 186,56 Q200,60 210,56" fill="none" stroke="#6a94c8" stroke-width="1.4" opacity="0.15"/></g></defs><use href="#dstAnLily" mask="url(#dstAnMaskL)"/><g mask="url(#dstAnMaskR)" transform="translate(420,0) scale(-1,1)"><use href="#dstAnLily"/></g></svg>
<!-- Drifting petals — lily-of-the-valley petals sway and rotate as they
     drift down the page. Two drift patterns alternate so the motion feels
     organic rather than synchronised. -->
<div class="dst-drip" style="left:24%;animation-name:dst-petal-drift-a;animation-duration:22s;animation-delay:-3s;"><svg width="12" height="17" viewBox="0 0 12 17"><path d="M6,1 Q2,5 1.5,9 Q2,14 6,16 Q10,14 10.5,9 Q10,5 6,1 Z" fill="#b8d0e4" opacity="0.30" stroke="#7aa8d8" stroke-width="0.4" stroke-opacity="0.42"/><path d="M6,3 Q6,9 6,14" stroke="#7aa8d8" stroke-width="0.4" fill="none" opacity="0.32"/></svg></div>
<div class="dst-drip" style="left:72%;animation-name:dst-petal-drift-b;animation-duration:25s;animation-delay:-15s;"><svg width="13" height="19" viewBox="0 0 13 19"><path d="M6.5,1 Q2,5 1.5,10 Q2,16 6.5,18 Q11,16 11.5,10 Q11,5 6.5,1 Z" fill="#c0d8ec" opacity="0.32" stroke="#7aa8d8" stroke-width="0.5" stroke-opacity="0.42"/><path d="M6.5,3 Q6.5,10 6.5,16" stroke="#7aa8d8" stroke-width="0.5" fill="none" opacity="0.33"/></svg></div>
<div style="position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;z-index:1;">
<div style="text-align:center;color:#d4c4b0;">
<div style="font-family:'Playfair Display',Georgia,serif;font-size:3em;letter-spacing:0.15em;line-height:1.2;animation:dst-titleGlow 6s ease-in-out infinite;">DREAM STREET<br>SHUFFLE</div>
<div style="font-family:'Crimson Text',Georgia,serif;font-size:1.05em;margin-top:1em;color:#a08060;letter-spacing:0.08em;animation:dst-breathe 8s ease-in-out infinite;">by Three Blue Posts</div>
<div class="title-begin" style="margin-top:1.6em;font-size:1.6em;">[[BEGIN|Start]]</div>
(if: (savedgames:) contains "auto")[<div id="dss-continue-link" class="title-begin" style="margin-top:5.5em;font-size:0.8em;opacity:0.8;display:none;">(link: "(CONTINUE WHERE I LEFT OFF)")[(loadgame: "auto")]</div>]<script>
/* Belt-and-braces gate: Harlowe's (savedgames:) sometimes reports stale or
   phantom slots. Only reveal the Continue link if the localStorage row
   for the auto save actually exists for THIS story (matched by IFID). */
(function(){
  var slot = document.getElementById('dss-continue-link');
  if (!slot) return;
  var ifid = 'E3F7C9E2-3617-469A-AE5C-210AFB87B930';
  var found = false;
  try {
    for (var i = 0; i < localStorage.length; i++) {
      var k = localStorage.key(i) || '';
      if (k.indexOf('Saved Game') === -1) continue;
      if (k.toLowerCase().indexOf('auto') === -1) continue;
      if (ifid && k.indexOf(ifid) === -1) continue;
      var v = localStorage.getItem(k);
      if (v && v.length > 50) { found = true; break; }
    }
  } catch (e) {}
  if (found) slot.style.display = '';
})();
</script>
</div>
</div>
</div>
<script>
(function(){
  var raf;
  var t0 = performance.now();
  var PI2 = Math.PI * 2;
  function tick(now){
    var b1 = document.getElementById('dss-b1');
    if(!b1){ cancelAnimationFrame(raf); return; }
    var t = (now - t0) * 0.001;
    var b2 = document.getElementById('dss-b2');
    var b3 = document.getElementById('dss-b3');
    var s1 = document.getElementById('dss-s1');
    var s2 = document.getElementById('dss-s2');
    var s3 = document.getElementById('dss-s3');
    b1.style.opacity = 0.18 + 0.82 * (0.5 + 0.5 * Math.sin(PI2 * t / 8));
    b2.style.opacity = 0.15 + 0.85 * (0.5 + 0.5 * Math.sin(PI2 * t / 11 + 2.1));
    b3.style.opacity = 0.20 + 0.80 * (0.5 + 0.5 * Math.sin(PI2 * t / 14 + 4.2));
    if(s1) s1.style.opacity = 0.4  + 0.6  * (0.5 + 0.5 * Math.sin(PI2 * t / 8));
    if(s2) s2.style.opacity = 0.35 + 0.65 * (0.5 + 0.5 * Math.sin(PI2 * t / 11 + 2.1));
    if(s3) s3.style.opacity = 0.38 + 0.62 * (0.5 + 0.5 * Math.sin(PI2 * t / 14 + 4.2));
    raf = requestAnimationFrame(tick);
  }
  raf = requestAnimationFrame(tick);
})();
</script>

