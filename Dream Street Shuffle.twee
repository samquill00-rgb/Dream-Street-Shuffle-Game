<!-- ═══════════════════════════════════════════════════════════════════
     ASYMPTOTIC STAT MACROS — replaces fixed ± deltas with proportional
     changes so low stats can recover meaningfully and high stats fall
     hard. Gains scale with HEADROOM (100 - current); losses scale with
     CURRENT. N is the old fixed-delta value, now read as a "percent
     intensity" (so the old "+ 10" becomes "($statGain: $stat, 10)" —
     a 10% headroom gain). Results are clamped to 0..100 and rounded
     so the stat bar shows clean integers.
     ═══════════════════════════════════════════════════════════════════ -->
(set: $statGain to (macro: num-type _v, num-type _n, [(output-data: (round: (min: 100, _v + (100 - _v) * (_n / 50))))]))
(set: $statLoss to (macro: num-type _v, num-type _n, [(output-data: (round: (max: 0, _v - _v * (_n / 50))))]))

:: UserScript [script]

// ====== ASYMPTOTIC STAT HELPERS (JS) ======
// Mirror the Harlowe $statGain / $statLoss macros so any JS-side stat
// bump (notebook buttons, minigame scoring, etc.) lands on the same curve
// as passage-level changes. Keep the /50 divisor identical to the macros;
// if the macro divisor changes, change here too.
window.dssStatGain = function(v, n) {
  if (typeof v !== 'number' || typeof n !== 'number') return v;
  return Math.round(Math.min(100, v + (100 - v) * (n / 50)));
};
window.dssStatLoss = function(v, n) {
  if (typeof v !== 'number' || typeof n !== 'number') return v;
  return Math.round(Math.max(0, v - v * (n / 50)));
};

// ====== PENTANGLE REVEAL ON MAP ======
// Opens the notebook (if not already open), switches to MAP tab, and triggers
// the pentagram + lily-of-the-valley animation drawn over the Soho map.
window.dssRevealPentangleOnMap = function() {
  function openMap() {
    var page = document.querySelector('.nb-page');
    if (!page) return false;
    // Make sure the queue includes 'map' so nbSwitchTab will fire the animation
    var queue = page.dataset.pentangleQueue || '';
    if (queue.indexOf('map') < 0) {
      queue = queue ? (queue + ',map') : 'map';
      page.dataset.pentangleQueue = queue;
    }
    var mapTab = page.querySelector('.nb-tab[data-tab="map"]');
    if (mapTab && window.nbSwitchTab) { window.nbSwitchTab(mapTab); return true; }
    return false;
  }
  if (openMap()) return;
  // Notebook isn't open yet — click the link, then open map after dialog renders
  var nbLink = document.querySelector('.notebook-link tw-link, .notebook-link a, .notebook-link');
  if (nbLink) {
    if (nbLink.tagName === 'TW-LINK' || nbLink.tagName === 'A') nbLink.click();
    else { var inner = nbLink.querySelector('tw-link, a'); if (inner) inner.click(); }
  }
  // Poll briefly for the notebook to appear
  var tries = 0;
  var iv = setInterval(function() {
    tries++;
    if (openMap() || tries > 30) clearInterval(iv);
  }, 80);
};

// Legacy: kept for direct testing only — the small screen overlay isn't the main reveal.
window.dssShowPentangleOverlay = function() {
  if (document.getElementById('dss-pentangle-overlay')) return;

  // 5 lily groups arranged at the points of a point-up pentagram (centre 150,150 radius 50)
  var ROT = [180, 108, 36, 324, 252];
  var lilyContent = '<line x1="0" y1="0" x2="0" y2="32" stroke="#9a8a68" stroke-width="1.1" stroke-linecap="round" opacity="0.7"/>'
    + '<path d="M -7,38 C -7,32 -3,30 0,30 C 3,30 7,32 7,38 C 7,46 4,52 0,52 C -4,52 -7,46 -7,38 Z" fill="#e8e2d4" stroke="#9a8a68" stroke-width="0.8" opacity="0.92"/>'
    + '<path d="M -3,38 C -3,34 -1.5,33 0,33 C 1.5,33 3,34 3,38 C 3,42 1.5,46 0,46 C -1.5,46 -3,42 -3,38 Z" fill="#f5f0e6" stroke="none" opacity="0.55"/>';

  var lilies = '';
  for (var i = 0; i < 5; i++) {
    lilies += '<g class="dss-pent-lily dss-pent-lily-' + (i + 1) + '" transform="translate(150,150) rotate(' + ROT[i] + ')" opacity="0">' + lilyContent + '</g>';
  }

  var html = '<div id="dss-pentangle-overlay" style="position:fixed;top:0;left:0;width:100vw;height:100vh;display:flex;align-items:center;justify-content:center;z-index:99999;pointer-events:none;background:rgba(0,0,0,0.55);opacity:0;transition:opacity 0.7s ease;">'
    + '<svg width="340" height="340" viewBox="0 0 300 300" style="max-width:80vw;max-height:80vh;overflow:visible;">'
    + '<polygon class="dss-pent-star" points="150,100 179.4,190.5 102.5,134.6 197.6,134.6 120.6,190.5" fill="none" stroke="#d4a574" stroke-width="1.1" opacity="0" style="transition:opacity 0.8s 0.3s ease;"/>'
    + '<circle class="dss-pent-glow" cx="150" cy="150" r="78" fill="none" stroke="#d4a574" stroke-width="0.4" opacity="0" style="transition:opacity 1.0s 0.4s ease;"/>'
    + lilies
    + '</svg></div>';

  var wrap = document.createElement('div');
  wrap.innerHTML = html;
  var overlay = wrap.firstChild;
  document.body.appendChild(overlay);

  // Fade in everything
  requestAnimationFrame(function() {
    overlay.style.opacity = '1';
    var lils = overlay.querySelectorAll('.dss-pent-lily');
    lils.forEach(function(g, i) {
      g.style.transition = 'opacity 0.6s ease ' + (0.1 + i * 0.08) + 's';
      g.style.opacity = '1';
    });
    var poly = overlay.querySelector('.dss-pent-star');
    if (poly) poly.style.opacity = '0.78';
    var glow = overlay.querySelector('.dss-pent-glow');
    if (glow) glow.style.opacity = '0.45';
  });

  // Fade out
  setTimeout(function() {
    overlay.style.opacity = '0';
  }, 3300);

  // Remove from DOM
  setTimeout(function() {
    if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
  }, 4100);
};

// ====== BROWSER BACK BUTTON (PLAYTESTING) ======
var _dssLastPassage = '';
setInterval(function() {
  var p = document.querySelector('tw-passage[data-name]');
  var name = p ? p.getAttribute('data-name') : '';
  if (name && name !== _dssLastPassage) {
    _dssLastPassage = name;
    window.history.pushState({ dss: 1 }, '');
  }
}, 150);
window.addEventListener('popstate', function() {
  // Find whichever sidebar icon triggers undo
  var icons = document.querySelectorAll('tw-icon');
  for (var i = 0; i < icons.length; i++) {
    var t = icons[i].getAttribute('title') || icons[i].getAttribute('aria-label') || '';
    if (/undo/i.test(t)) { icons[i].click(); return; }
  }
  // Fallback: first icon in sidebar is usually undo
  var first = document.querySelector('tw-sidebar tw-icon');
  if (first) first.click();
});

// ====== AUDIO — Web Audio synth (no external files) ======
// Lazy-init AudioContext on first sound. Browsers block autoplay until the
// user has interacted with the page; clicking BEGIN counts, so by the time
// any of these fire we should have permission.
window.dssAudio = (function() {
  var ctx = null;
  function getCtx() {
    if (!ctx) {
      var AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) return null;
      try { ctx = new AC(); } catch(e) { return null; }
    }
    if (ctx.state === 'suspended') { try { ctx.resume(); } catch(e) {} }
    return ctx;
  }
  // Keep the audio context alive on every user interaction.
  // Without this, browsers may suspend the context between sounds, and
  // one-shot effects (coin, item pickup, etc.) can be silently dropped
  // because their scheduled times slip into the past during suspension.
  function _prime() {
    if (ctx && ctx.state === 'suspended') {
      try { ctx.resume(); } catch(e) {}
    }
  }
  ['click','touchstart','keydown','pointerdown'].forEach(function(ev) {
    try {
      document.addEventListener(ev, _prime, { capture: true, passive: true });
    } catch(e) {
      document.addEventListener(ev, _prime, true);
    }
  });
  // ====== MUTE STATE ======
  // Master mute toggle. When true: _play() short-circuits (no SFX), musicGain
  // is forced to 0, any active ambient bed is silenced.
  // Every new session starts UNMUTED — sound is the default. The mute toggle
  // is per-session; we don't persist it (and we proactively clear any legacy
  // localStorage entry from earlier builds that did persist it).
  var _muted = false;
  try { localStorage.removeItem('dssMuted'); } catch(e) {}
  function isMuted() { return _muted; }
  function setMuted(b) {
    _muted = !!b;
    var ac = ctx; // Use existing context only — don't force-create one to mute.
    if (ac) {
      // Music bed
      if (typeof musicGain !== 'undefined' && musicGain) {
        try {
          musicGain.gain.cancelScheduledValues(ac.currentTime);
          musicGain.gain.setValueAtTime(_muted ? 0 : MUSIC_VOLUME_BASE, ac.currentTime);
        } catch(e) {}
      }
      // Ambient bed (wind, traffic, fire) — already-playing loops.
      if (typeof _ambient !== 'undefined' && _ambient && _ambient.g) {
        try {
          _ambient.g.gain.cancelScheduledValues(ac.currentTime);
          // Read current value before mute so we can restore (best effort).
          if (_muted) {
            _ambient._preMute = _ambient.g.gain.value;
            _ambient.g.gain.setValueAtTime(0, ac.currentTime);
          } else {
            var restore = (typeof _ambient._preMute === 'number') ? _ambient._preMute : 0.06;
            _ambient.g.gain.setValueAtTime(restore, ac.currentTime);
          }
        } catch(e) {}
      }
      // Venue ambient beds (pub, club, etc.) — already-playing field recordings.
      if (typeof _ambientBeds !== 'undefined' && _ambientBeds) {
        for (var bi = 0; bi < _ambientBeds.length; bi++) {
          var _b = _ambientBeds[bi];
          if (!_b.gain) continue;
          try {
            _b.gain.gain.cancelScheduledValues(ac.currentTime);
            if (_b.duckTimer) { clearTimeout(_b.duckTimer); _b.duckTimer = null; }
            _b.gain.gain.setValueAtTime(_muted ? 0 : _b.volume, ac.currentTime);
          } catch(e) {}
        }
      }
    }
    // Notify any UI button listening for state changes.
    try {
      var btn = document.getElementById('dss-mute-btn');
      if (btn) btn.setAttribute('data-muted', _muted ? '1' : '0');
    } catch(e) {}
  }
  // Helper: only schedule audio when the context is actually running.
  // If it's still suspending, wait for the resume promise then run.
  function _play(fn) {
    if (_muted) return;
    var ac = getCtx(); if (!ac) return;
    // Fire-and-forget resume; don't wait for the promise (some browsers hang).
    if (ac.state === 'suspended') {
      try { ac.resume(); } catch(e) {}
    }
    // Duck the background music + any venue ambient beds so the SFX cuts through clearly
    try { _duckMusic(); } catch(e) {}
    try { _duckAllBeds(); } catch(e) {}
    try { fn(ac); }
    catch(e) { if (window.console && console.error) console.error('dssAudio:', e); }
  }
  // Soft pour — filtered noise, gentle envelope
  function pour() {
    _play(function(ac) {
    var dur = 0.95, now = ac.currentTime;
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) d[i] = (Math.random()*2-1) * 0.5;
    var src = ac.createBufferSource(); src.buffer = buf;
    var f = ac.createBiquadFilter(); f.type='lowpass';
    f.frequency.setValueAtTime(900, now);
    f.frequency.exponentialRampToValueAtTime(380, now+dur);
    f.Q.value = 2;
    var g = ac.createGain();
    g.gain.setValueAtTime(0, now);
    g.gain.linearRampToValueAtTime(0.18, now+0.06);
    g.gain.exponentialRampToValueAtTime(0.001, now+dur);
    src.connect(f); f.connect(g); g.connect(ac.destination);
    src.start(now); src.stop(now+dur);
      });
  }
  // ── HOLD-DRIVEN STREAMS (piss / retch) ──────────────────────────────
  // Each returns a controller { stop() } so the SpewPopup can start the
  // sound on mousedown and stop it on mouseup. Two layers: filtered noise
  // for the liquid splatter, plus a low oscillator for body weight (gut
  // gurgle on retch, dull thump on piss).
  function _startStream(opts) {
    if (_muted) return { stop: function(){} };
    var ac = getCtx(); if (!ac) return { stop: function(){} };
    if (ac.state === 'suspended') { try { ac.resume(); } catch(e) {} }
    var now = ac.currentTime;
    // Looping white-noise buffer — 2s of noise on loop reads as endless splatter
    var bufLen = Math.floor(ac.sampleRate * 2);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) d[i] = (Math.random()*2-1) * 0.55;
    var src = ac.createBufferSource(); src.buffer = buf; src.loop = true;
    // Bandpass — centre frequency carries the character
    var bp = ac.createBiquadFilter(); bp.type = 'bandpass';
    bp.frequency.value = opts.bpFreq; bp.Q.value = opts.bpQ;
    // Slow LFO on filter frequency — gentle splatter wobble
    var lfo = ac.createOscillator(); lfo.type = 'sine';
    lfo.frequency.value = opts.wobbleHz;
    var lfoGain = ac.createGain(); lfoGain.gain.value = opts.wobbleAmt;
    lfo.connect(lfoGain); lfoGain.connect(bp.frequency);
    // Master gain — ramp in on start, ramp out on stop
    var g = ac.createGain();
    g.gain.setValueAtTime(0, now);
    g.gain.linearRampToValueAtTime(opts.peakGain, now + 0.08);
    src.connect(bp); bp.connect(g); g.connect(ac.destination);
    src.start(now); lfo.start(now);
    // Optional low-frequency body — gut rumble (retch) or splash thud (piss)
    var bodyOsc = null, bodyGain = null, bodyLfo = null;
    if (opts.bodyFreq) {
      bodyOsc = ac.createOscillator(); bodyOsc.type = opts.bodyType || 'sine';
      bodyOsc.frequency.value = opts.bodyFreq;
      bodyGain = ac.createGain();
      bodyGain.gain.setValueAtTime(0, now);
      bodyGain.gain.linearRampToValueAtTime(opts.bodyGain, now + 0.12);
      // Body wobble — gut churning
      if (opts.bodyWobbleHz) {
        bodyLfo = ac.createOscillator(); bodyLfo.type = 'sine';
        bodyLfo.frequency.value = opts.bodyWobbleHz;
        var bodyLfoGain = ac.createGain();
        bodyLfoGain.gain.value = opts.bodyWobbleAmt || 6;
        bodyLfo.connect(bodyLfoGain); bodyLfoGain.connect(bodyOsc.frequency);
        bodyLfo.start(now);
      }
      bodyOsc.connect(bodyGain); bodyGain.connect(ac.destination);
      bodyOsc.start(now);
    }
    // Optional one-shot onset — the heave that kicks off a retch
    if (opts.onset) {
      var oDur = 0.22;
      var oBufLen = Math.floor(ac.sampleRate * oDur);
      var oBuf = ac.createBuffer(1, oBufLen, ac.sampleRate);
      var od = oBuf.getChannelData(0);
      for (var k = 0; k < oBufLen; k++) {
        var oEnv = Math.exp(-k / (ac.sampleRate * 0.06));
        od[k] = (Math.random()*2-1) * oEnv * 0.65;
      }
      var oSrc = ac.createBufferSource(); oSrc.buffer = oBuf;
      var oLp = ac.createBiquadFilter(); oLp.type = 'lowpass';
      oLp.frequency.value = 420;
      var oG = ac.createGain(); oG.gain.value = 0.32;
      oSrc.connect(oLp); oLp.connect(oG); oG.connect(ac.destination);
      oSrc.start(now);
    }
    var stopped = false;
    return {
      stop: function() {
        if (stopped) return; stopped = true;
        var t = ac.currentTime;
        try {
          g.gain.cancelScheduledValues(t);
          g.gain.setValueAtTime(g.gain.value, t);
          g.gain.linearRampToValueAtTime(0.0001, t + 0.18);
        } catch(e) {}
        if (bodyGain) {
          try {
            bodyGain.gain.cancelScheduledValues(t);
            bodyGain.gain.setValueAtTime(bodyGain.gain.value, t);
            bodyGain.gain.linearRampToValueAtTime(0.0001, t + 0.18);
          } catch(e) {}
        }
        setTimeout(function() {
          try { src.stop(); } catch(e) {}
          try { lfo.stop(); } catch(e) {}
          if (bodyOsc) { try { bodyOsc.stop(); } catch(e) {} }
          if (bodyLfo) { try { bodyLfo.stop(); } catch(e) {} }
        }, 220);
      }
    };
  }
  function startPissStream() {
    // Higher splatter (stream hitting pavement/door), light thud body
    return _startStream({
      bpFreq: 1100, bpQ: 1.4,
      wobbleHz: 3.2, wobbleAmt: 240,
      peakGain: 0.20,
      bodyFreq: 110, bodyType: 'sine', bodyGain: 0.06,
      bodyWobbleHz: 2.4, bodyWobbleAmt: 18,
      onset: false
    });
  }
  function startRetchStream() {
    // Wetter, lower-pitched splash (liquid into water), with a gut gurgle
    // and a brief throaty heave onset.
    return _startStream({
      bpFreq: 620, bpQ: 2.4,
      wobbleHz: 4.5, wobbleAmt: 180,
      peakGain: 0.22,
      bodyFreq: 85, bodyType: 'sawtooth', bodyGain: 0.05,
      bodyWobbleHz: 5.5, bodyWobbleAmt: 28,
      onset: true
    });
  }
  // Short sip / gulp — low warble
  function sip() {
    _play(function(ac) {
    var now = ac.currentTime;
    var o = ac.createOscillator(); o.type='sine';
    o.frequency.setValueAtTime(170, now);
    o.frequency.exponentialRampToValueAtTime(75, now+0.18);
    var g = ac.createGain();
    g.gain.setValueAtTime(0, now);
    g.gain.linearRampToValueAtTime(0.16, now+0.02);
    g.gain.exponentialRampToValueAtTime(0.001, now+0.22);
    o.connect(g); g.connect(ac.destination);
    o.start(now); o.stop(now+0.25);
      });
  }
  // Old-school British phone ring — two short pulses, ~1.5s repeats
  function phoneRing(rings) {
    _play(function(ac) {
    rings = rings || 2;
    var now = ac.currentTime;
    for (var r = 0; r < rings; r++) {
      var t0 = now + r * 2.0;
      // Each "ring" is the British double-pulse: brrring brrring
      [0, 0.4].forEach(function(off) {
        var t = t0 + off;
        [440, 480].forEach(function(freq) {
          var o = ac.createOscillator(); o.type='sine'; o.frequency.value=freq;
          var g = ac.createGain();
          g.gain.setValueAtTime(0.001, t);
          g.gain.linearRampToValueAtTime(0.14, t+0.03);
          g.gain.setValueAtTime(0.14, t+0.32);
          g.gain.exponentialRampToValueAtTime(0.001, t+0.38);
          o.connect(g); g.connect(ac.destination);
          o.start(t); o.stop(t+0.4);
        });
      });
    }
      });
  }
  // Typewriter key tick — short metallic click. Slight pitch variation per call.
  // Optional `vol` argument (default 0.18) lets callers pass a quieter version,
  // e.g. the ALBA reveal typewriter uses a softer click.
  function typewriterTick(vol) {
    _play(function(ac) {
    var now = ac.currentTime;
    // Mechanical click: short noise burst with bandpass filter, tiny pitch jitter.
    // Tighter envelope + explicit stop so rapid typing doesn't leave a tail.
    var dur = 0.02;
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    // Soft 0.8ms attack + 1.5ms release tapered to zero — eliminates
    // BOTH onset and offset transients. Without the release, the
    // exponential decay still has ~0.7% amplitude at 20ms, so the
    // src.stop() snaps it to zero and creates a low-frequency click.
    var attackSamples = Math.floor(ac.sampleRate * 0.0008);
    var releaseSamples = Math.floor(ac.sampleRate * 0.0015);
    for (var i = 0; i < bufLen; i++) {
      var attack = i < attackSamples ? (i / attackSamples) : 1;
      var release = (bufLen - i) < releaseSamples ? ((bufLen - i) / releaseSamples) : 1;
      var env = attack * release * Math.exp(-i / (ac.sampleRate * 0.004));
      d[i] = (Math.random()*2-1) * env;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    // Two-stage highpass — first knocks out sub-bass, second runs after
    // the bandpass to catch any low-frequency ringing the resonant
    // bandpass introduces. Combined ~36dB/octave below 700Hz.
    var hp1 = ac.createBiquadFilter(); hp1.type='highpass';
    hp1.frequency.value = 700; hp1.Q.value = 0.9;
    var f = ac.createBiquadFilter(); f.type='bandpass';
    f.frequency.value = 1800 + Math.random()*600;
    f.Q.value = 4;
    var hp2 = ac.createBiquadFilter(); hp2.type='highpass';
    hp2.frequency.value = 700; hp2.Q.value = 0.7;
    var g = ac.createGain(); g.gain.value = (typeof vol === 'number' ? vol : 0.18);
    src.connect(hp1); hp1.connect(f); f.connect(hp2); hp2.connect(g); g.connect(ac.destination);
    src.start(now); src.stop(now + dur + 0.005);
      });
  }
  // Typewriter clack — a heavy single strike for the dramatic "NAME YOUR
  // BOOK" moment at the end of The Night Ahead's typewriter.
  //   1. Heavy noise burst — hammer/ribbon/paper smack
  //   2. Low boom — type bar slamming through paper
  // (Previously had a typewriter bell ding chained on; removed at Dr Quill's
  // request — it competed with the moment.)
  function typewriterClack() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Layer 1: heavy noise burst — the keys hammering paper
    var dur = 0.18;
    var bufLen = Math.floor(ac.sampleRate * dur);
    var buf = ac.createBuffer(1, bufLen, ac.sampleRate);
    var d = buf.getChannelData(0);
    for (var i = 0; i < bufLen; i++) {
      var env = Math.exp(-i / (ac.sampleRate * 0.030));
      d[i] = (Math.random()*2-1) * env;
    }
    var src = ac.createBufferSource(); src.buffer = buf;
    var f = ac.createBiquadFilter(); f.type='bandpass';
    f.frequency.value = 1100;
    f.Q.value = 2.5;
    var g = ac.createGain(); g.gain.value = 0.75;
    src.connect(f); f.connect(g); g.connect(ac.destination);
    src.start(now);
    // Layer 2: low boom — the type bar slamming the platen
    var o = ac.createOscillator(); o.type='sine';
    o.frequency.setValueAtTime(140, now);
    o.frequency.exponentialRampToValueAtTime(55, now+0.10);
    var og = ac.createGain();
    og.gain.setValueAtTime(0, now);
    og.gain.linearRampToValueAtTime(0.55, now+0.005);
    og.gain.exponentialRampToValueAtTime(0.001, now+0.16);
    o.connect(og); og.connect(ac.destination);
    o.start(now); o.stop(now+0.17);
      });
  }
  // Item placed on table — soft thud + tiny resonance
  function itemFound() {
    _play(function(ac) {
    var now = ac.currentTime;
    // Low thump
    var o = ac.createOscillator(); o.type='sine';
    o.frequency.setValueAtTime(110, now);
    o.frequency.exponentialRampToValueAtTime(60, now+0.18);
    var g = ac.createGain();
    g.gain.setValueAtTime(0, now);
    g.gain.linearRampToValueAtTime(0.22, now+0.015);
    g.gain.exponentialRampToValueAtTime(0.001, now+0.22);
    o.connect(g); g.connect(ac.destination);
    o.start(now); o.stop(now+0.25);
