32 13 238 27 Q244 42 250 27 Q256 12 262 27 Q268 42 274 27 Q280 12 286 27" fill="none" stroke="url(#phCd)" stroke-width="2" stroke-linecap="round"/><!-- cord connectors --><circle cx="110" cy="27" r="2" fill="#6a2820" opacity="0.4"/><circle cx="190" cy="27" r="2" fill="#6a2820" opacity="0.4"/><!-- handset --><g transform="translate(150,27) rotate(-12)"><path d="M-22 0 C-22,-8 -14,-9 -12,-5 C-10,-2 -6,-2 0,-2 C6,-2 10,-2 12,-5 C14,-9 22,-8 22,0 C22,8 14,9 12,5 C10,2 6,2 0,2 C-6,2 -10,2 -12,5 C-14,9 -22,8 -22,0 Z" fill="url(#phHd)" opacity="0.62"/><circle cx="-16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="-16" cy="0" r="1" fill="#1a0808" opacity="0.22"/><circle cx="16" cy="-1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="1.5" r="1.2" fill="#1a0808" opacity="0.3"/><circle cx="16" cy="0" r="1" fill="#1a0808" opacity="0.22"/></g></svg>

<div class="phone-type" style="--d:0.3s;--t:0.8s">The phone rings behind the bar.</div>\
<div class="phone-type" style="--d:1.4s;--t:0.35s">It's Aoife.</div>\
<div class="phone-type phone-her" style="--d:2.1s;--t:1.6s">'The heating's gone. Will you be home soon? She won't leave-off crying.'</div>\
<div class="phone-type phone-you" style="--d:4.0s;--t:0.45s">'Later tonight.'</div>\
<div class="phone-type phone-her" style="--d:4.8s;--t:0.35s">'Much later?'</div>\
<div class="phone-type phone-you" style="--d:5.5s;--t:0.7s">'Yes. Goodnight. I love you.'</div>\
<div class="phone-type" style="--d:6.8s;--t:1.3s">Through the fumes, vapours and drink, you recognise a man.</div>

<svg class="phone-rule" viewBox="0 0 300 55" width="100%" height="55" preserveAspectRatio="none"><defs><filter id="phBl2"><feGaussianBlur stdDeviation="5"/></filter><linearGradient id="phCd2" x1="0" x2="1"><stop offset="0%" stop-color="#5a2818" stop-opacity="0"/><stop offset="20%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="50%" stop-color="#8a4030" stop-opacity="0.62"/><stop offset="80%" stop-color="#7a3828" stop-opacity="0.48"/><stop offset="100%" stop-color="#5a2818" stop-opacity="0"/></linearGradient><linearGradient id="phHd2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#4a1812"/><stop offset="40%" stop-color="#7a2e20"/><stop offset="100%" stop-color="#5a2018"/></linearGradient><radialGradient id="phGw2" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#c08040" stop-opacity="0.12"/><stop offset="100%" stop-color="#c08040" stop-opacity="0"/></radialGradient></defs><!-- smoke wisps --><ellipse cx="165" cy="28" rx="52" ry="16" fill="#a08060" opacity="0.06" filter="url(#phBl2)"/><ellipse cx="110" cy="24" rx="40" ry="13" fill="#907050" opacity="0.05" filter="url(#phBl2)"/><ellipse cx="150" cy="27" rx="95" ry="24" fill="url(#phGw2)"/><!-- cord shadow --><path d="M14 29 Q20 44 26 29 Q32 14 38 29 Q44 44 50 29 Q56 14 62 29 Q68 42 74 29 Q79 18 84 29 Q89 36 94 29 Q98 24 102 29 Q105 32 108 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><path d="M192 29 Q195 32 198 29 Q202 24 206 29 Q211 36 216 29 Q221 18 226 29 Q232 42 238 29 Q244 14 250 29 Q256 44 262 29 Q268 14 274 29 Q280 44 286 29" fill="none" stroke="rgba(40,18,12,0.12)" stroke-width="3" stroke-linecap="round"/><!-- coiled cord left --><path d="M14 27 Q20 42 26 27 Q32 12 38 27 Q44 42 50 27 Q56 12 62 27 Q68 40 74 27 Q79 16 84 27 Q89 34 94 27 Q98 22 102 27 Q105 30 108 27" fill="none" stroke="url(#phCd2)" stroke-width="2" stroke-linecap="round"/><!-- coiled cord right --><path d="M192 27 Q195 30 198 27 Q202 22 206 27 Q211 34 216 27 Q221 16 226 27 Q232