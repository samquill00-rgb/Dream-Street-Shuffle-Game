var heroLamp = new THREE.Group();

// --- POST ---
// Ornate fluted base
var baseSkirt = new THREE.Mesh(new THREE.CylinderGeometry(0.22, 0.35, 0.5, 8), ironMat);
baseSkirt.position.set(0, 0.25, 0);
