// Secondary softer ginger fill — bigger radius for fog bleed
var gingerFill = new THREE.PointLight(0xd46812, 1.2, 35);
gingerFill.position.set(0, 5.2, 0);
heroLamp.add(gingerFill);

// Third ginger wash — very wide, very soft, bleeds deep into fog
var gingerWash = new THREE.PointLight(0xc0580e, 0.5, 50);
gingerWash.position.set(0, 4.5, 0);
heroLamp.add(gingerWash);

// Glow sprite — the visible halo in the fog
var gingerGlowTex = makeCanvasTexture(128, 128, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(232, 120, 24, 0.95)');
grad.addColorStop(0.15, 'rgba(220, 100, 18, 0.6)');
grad.addColorStop(0.4, 'rgba(200, 80, 12, 0.22)');
grad.addColorStop(0.7, 'rgba(170, 60, 8, 0.07)');
grad.addColorStop(1, 'rgba(140, 45, 5, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var gingerGlow = new THREE.Sprite(new THREE.SpriteMaterial({
map: gingerGlowTex, transparent: true, opacity: 0.85
}));
gingerGlow.position.set(0, 5.6, 0);
gingerGlow.scale.set(8, 8, 1);
heroLamp.add(gingerGlow);

// Smaller inner glow — brighter core
var innerGlowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
grad.addColorStop(0, 'rgba(255, 155, 40, 1)');
grad.addColorStop(0.3, 'rgba(240, 125, 25, 0.55)');
grad.addColorStop(1, 'rgba(232, 120, 24, 0)');
cx.fillStyle = grad;
cx.fillRect(0, 0, w, h);
});
var innerGlow = new THREE.Sprite(new THREE.SpriteMaterial({
map: innerGlowTex, transparent: true, opacity: 0.9
}));
innerGlow.position.set(0, 5.6, 0);
innerGlow.scale.set(2.5, 2.5, 1);
heroLamp.add(innerGlow);

// Downward cone of light on the pavement
var downSpot = new THREE.SpotLight(0xe87818, 2.0, 16, Math.PI / 3.5, 0.5);
downSpot.position.set(0, 5.3, 0);
downSpot.target.position.set(0, 0, 0);
heroLamp.add(downSpot);
heroLamp.add(downSpot.target);

// Position the hero lamp at the corner
heroLamp.position.set(-3.5, 0, -3.5);
scene.add(heroLamp);

// ============================================================
// SECONDARY STREETLAMPS (dimmer, fading into fog)
// ============================================================
var lampLights = [gingerLight]; // include hero light for animation

function createDistantLamp(x, z, intensity) {
var g = new THREE.Group();
var postMat = new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.8 });
// Simplified post
placeMeshG(g, new THREE.CylinderGeometry(0.06, 0.1, 4.8, 6), postMat, 0, 2.4, 0);
placeMeshG(g, new THREE.BoxGeometry(0.35, 0.35, 0.35), postMat, 0, 5, 0);
// Light
var light = new THREE.PointLight(0xe87818, intensity || 0.4, 12);
light.position.set(0, 4.8, 0);
g.add(light);
lampLights.push(light);
// Dim glow sprite
var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({
map: gingerGlowTex, transparent: true, opacity: 0.3
}));
glowSprite.position.set(0, 5, 0);
glowSprite.scale.set(2.5, 2.5, 1);
g.add(glowSprite);
g.position.set(x, 0, z);
scene.add(g);
}

// Along Dean Street fading north
createDistantLamp(-5.5, -12, 0.35);
createDistantLamp(-5.5, -22, 0.2);

// Along Greek Street fading east
createDistantLamp(10, -5.5, 0.3);
createDistantLamp(20, 5.5, 0.2);

// One across the road
createDistantLamp(5.5, 5, 0.25);

