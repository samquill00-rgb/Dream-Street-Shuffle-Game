farFill.position.set(0, 2.2, -halfL + 0.5);
scene.add(farFill);

var rimLight = new THREE.PointLight(0x506080, 0.4, 8, 2);
rimLight.position.set(0.3, 1.2, -halfL + 3.5);
scene.add(rimLight);

var floorGlow = new THREE.PointLight(0x182030, 0.2, 6, 2);
floorGlow.position.set(0, 0.05, -halfL + 4);
scene.add(floorGlow);

// ============================================================
// TABLE
// ============================================================
var tableGroup = new THREE.Group();
