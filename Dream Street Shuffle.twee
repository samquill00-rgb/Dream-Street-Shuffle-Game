hercArm.position.set(1.25, 7.6, 0.35);
pub.add(hercArm);

// ---- PLANTER BOX (overflowing greenery above fascia) ----
var planterBoxMat = new THREE.MeshStandardMaterial({ color: 0x2a2018, roughness: 0.8 });
var planterBox = new THREE.Mesh(new THREE.BoxGeometry(5.6, 0.35, 0.5), planterBoxMat);
planterBox.position.set(1.25, 4.0, 0.5);
