placeMesh(pub, new THREE.BoxGeometry(0.18, 3.2, 0.35), mahogany, 4.0, 1.6, 0.6);
placeMesh(pub, new THREE.BoxGeometry(4.3, 0.18, 0.35), mahogany, 2.0, 3.15, 0.6);

// ---- Kickboard / plinth at very bottom of mahogany section ----
placeMesh(pub, new THREE.BoxGeometry(4.3, 0.3, 0.12), mahoganyDark, 2.0, 0.15, 0.65);

// Multiple ornate Victorian window panels — with richer detail
for (var px = 0.5; px <= 3.5; px += 0.7) {
