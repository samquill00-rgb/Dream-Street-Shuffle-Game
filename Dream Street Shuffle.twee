    new THREE.MeshBasicMaterial({ color: 0xffe8b0, transparent: true, opacity: 0.55 }));
  doorGlass.position.set(0.5, 1.95, 0.34);
  shop.add(doorGlass);
  // Door frame
  placeMesh(shop, new THREE.BoxGeometry(0.04, 2.5, 0.04), shopRed, 0.1, 1.85, 0.34);
  placeMesh(shop, new THREE.BoxGeometry(0.04, 2.5, 0.04), shopRed, 0.9, 1.85, 0.34);
  placeMesh(shop, new THREE.BoxGeometry(0.85, 0.04, 0.04), shopRed, 0.5, 3.12, 0.34);
  // Door glazing bars
  placeMesh(shop, new THREE.BoxGeometry(0.02, 2.0, 0.02), whiteTrim, 0.5, 1.95, 0.36);
  placeMesh(shop, new THREE.BoxGeometry(0.7, 0.02, 0.02), whiteTrim, 0.5, 1.95, 0.36);
  // Door push bar (chrome)
  placeMesh(shop, new THREE.BoxGeometry(0.4, 0.03, 0.06), chromeMat, 0.5, 1.5, 0.38);
  // Door handle
  placeMesh(shop, new THREE.BoxGeometry(0.04, 0.1, 0.05), chromeMat, 0.75, 1.5, 0.38);
  // ---- Worn stone step in front of the door ----
  // Light grey scuffed stone, two layers (a slight chamfered front
  // edge), plus a small worn-down depression where feet have stepped.
  var stepStoneTex = makeCanvasTexture(256, 96, function(cx, w, h) {
    // Base stone
    cx.fillStyle = '#9a958a'; cx.fillRect(0, 0, w, h);
    // Variegated stone tone
    for (var sn = 0; sn < 500; sn++) {
      var sg = 130 + Math.floor(Math.random() * 50);
      cx.fillStyle = 'rgba(' + sg + ',' + sg + ',' + (sg - 6) + ',0.32)';
      cx.fillRect(Math.random() * w, Math.random() * h, 1.5, 1.5);
    }
    // Worn depression down the middle (foot-traffic wear)
    var wear = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w * 0.45);
    wear.addColorStop(0, 'rgba(70, 66, 60, 0.40)');
    wear.addColorStop(0.5, 'rgba(80, 76, 70, 0.20)');
    wear.addColorStop(1, 'rgba(100, 96, 90, 0)');
    cx.fillStyle = wear; cx.fillRect(0, 0, w, h);
    // Edge dirt
    cx.fillStyle = 'rgba(35, 30, 22, 0.35)';
    cx.fillRect(0, 0, w, 6); cx.fillRect(0, h - 6, w, 6);
    cx.fillRect(0, 0, 8, h); cx.fillRect(w - 8, 0, 8, h);
    // Scuff scratches
    cx.strokeStyle = 'rgba(60, 55, 45, 0.22)';
    cx.lineWidth = 0.9;
    for (var sk = 0; sk < 18; sk++) {
      cx.beginPath();
      var skx = Math.random() * w;
      cx.moveTo(skx, Math.random() * h);
      cx.lineTo(skx + 10 + Math.random() * 30, Math.random() * h);
      cx.stroke();
    }
    // Cigarette burn
    cx.fillStyle = 'rgba(25, 18, 8, 0.6)';
    cx.beginPath(); cx.arc(w * 0.78, h * 0.55, 2.5, 0, Math.PI * 2); cx.fill();
    // A few dark stains
    for (var st = 0; st < 4; st++) {
      cx.fillStyle = 'rgba(35, 28, 18, ' + (0.15 + Math.random() * 0.18).toFixed(3) + ')';
      cx.beginPath();
      cx.ellipse(40 + Math.random() * (w - 80), 20 + Math.random() * (h - 40),
        6 + Math.random() * 12, 3 + Math.random() * 6, Math.random(), 0, Math.PI * 2);
      cx.fill();
    }
  });
  var stepMat = new THREE.MeshStandardMaterial({ map: stepStoneTex, roughness: 0.85 });
  // Main step block (a proper threshold the camera can see)
  var stepBlock = new THREE.Mesh(new THREE.BoxGeometry(1.1, 0.18, 0.45), stepMat);
  stepBlock.position.set(0.5, 0.09, 0.55);
  shop.add(stepBlock);
  // Chamfered front lip (thinner band on top edge)
  placeMesh(shop, new THREE.BoxGeometry(1.12, 0.04, 0.06), stepMat, 0.5, 0.20, 0.77);
  // Side cheek pieces (small triangular shoulders flanking the step)
  placeMesh(shop, new THREE.BoxGeometry(0.08, 0.18, 0.30), stepMat, -0.05, 0.09, 0.50);
  placeMesh(shop, new THREE.BoxGeometry(0.08, 0.18, 0.30), stepMat, 1.05, 0.09, 0.50);

  // ---- "OPEN" SIGN ON DOOR (neon-style) ----
  var openSignTex = makeCanvasTexture(128, 48, function(cx, w, h) {
    cx.fillStyle = '#000000'; cx.fillRect(0, 0, w, h);
    cx.strokeStyle = '#333333'; cx.lineWidth = 2; cx.strokeRect(2, 2, w - 4, h - 4);
    // Neon red "OPEN"
    cx.shadowColor = '#ff3030'; cx.shadowBlur = 8;
    cx.fillStyle = '#ff4040';
    cx.font = 'bold 28px Arial, sans-serif';
    cx.textAlign = 'center';
    cx.fillText('OPEN', w / 2, 34);
    cx.shadowBlur = 0;
  });
  var openSign = new THREE.Mesh(new THREE.PlaneGeometry(0.4, 0.15),
    new THREE.MeshBasicMaterial({ map: openSignTex }));
  openSign.position.set(0.5, 2.8, 0.37);
  shop.add(openSign);

  // ---- WINDOW SIGNS & INTERIOR DETAILS ----
  // "FISH & CHIPS" neon in left window
  var neonFishTex = makeCanvasTexture(256, 64, function(cx, w, h) {
    cx.fillStyle = 'rgba(0,0,0,0)';
    cx.clearRect(0, 0, w, h);
    // Neon blue glow
    cx.shadowColor = '#40a0ff'; cx.shadowBlur = 12;
    cx.fillStyle = '#60c0ff';
    cx.font = 'bold 32px Arial, sans-serif';
    cx.textAlign = 'center';
    cx.fillText('FISH & CHIPS', w / 2, 40);
    cx.shadowBlur = 0;
  });
  var neonFish = new THREE.Mesh(new THREE.PlaneGeometry(1.8, 0.4),
    new THREE.MeshBasicMaterial({ map: neonFishTex, transparent: true }));
  neonFish.position.set(-0.7, 2.9, 0.38);
  shop.add(neonFish);
  // Neon blue glow light
  var neonBlueLight = new THREE.PointLight(0x40a0ff, 0.3, 3);
  neonBlueLight.position.set(-0.7, 2.9, 0.6);
  shop.add(neonBlueLight);

  // "MENU" prices board in right window
  var menuTex = makeCanvasTexture(192, 256, function(cx, w, h) {
    cx.fillStyle = '#101010'; cx.fillRect(0, 0, w, h);
    cx.strokeStyle = '#555555'; cx.lineWidth = 1; cx.strokeRect(4, 4, w - 8, h - 8);
    cx.fillStyle = '#f0e0b0';
    cx.font = 'bold 16px Arial'; cx.textAlign = 'center';
    cx.fillText('MENU', w / 2, 28);
    cx.strokeStyle = '#606050'; cx.beginPath(); cx.moveTo(30, 35); cx.lineTo(w - 30, 35); cx.stroke();
    cx.font = '12px Arial'; cx.textAlign = 'left';
    var items = [
      ['Cod & Chips', '32p'],
      ['Haddock & Chips', '35p'],
      ['Plaice & Chips', '38p'],
      ['Chicken & Chips', '30p'],
      ['Pie & Chips', '25p'],
      ['Chips', '12p'],
      ['Mushy Peas', '8p'],
      ['Pickled Egg', '5p'],
      ['Cup of Tea', '6p']
    ];
    for (var mi = 0; mi < items.length; mi++) {
      var iy = 55 + mi * 22;
      cx.fillStyle = '#e0d0a0';
      cx.fillText(items[mi][0], 15, iy);
      cx.textAlign = 'right';
      cx.fillText(items[mi][1], w - 15, iy);
      cx.textAlign = 'left';
    }
  });
  var menuBoard = new THREE.Mesh(new THREE.PlaneGeometry(0.65, 0.85),
    new THREE.MeshBasicMaterial({ map: menuTex }));
  menuBoard.position.set(2.2, 2.4, 0.37);
  shop.add(menuBoard);

  // ---- INTERIOR VISIBLE THROUGH WINDOWS ----
  // Formica counter (visible behind glass)
  placeMesh(shop, new THREE.BoxGeometry(4.5, 0.8, 0.4), formicaMat, 0.5, 1.0, -0.2);
  // Counter top (darker)
  placeMesh(shop, new THREE.BoxGeometry(4.6, 0.04, 0.5),
    new THREE.MeshStandardMaterial({ color: 0x8a7a5a, roughness: 0.4 }), 0.5, 1.42, -0.15);
  // Glass sneeze guard on counter
  var sneeze = new THREE.Mesh(new THREE.PlaneGeometry(3.5, 0.5),
    new THREE.MeshBasicMaterial({ color: 0xffeedd, transparent: true, opacity: 0.15 }));
  sneeze.position.set(0.5, 1.7, -0.1);
  shop.add(sneeze);
  // Chrome rail on sneeze guard
  placeMesh(shop, new THREE.BoxGeometry(3.5, 0.02, 0.02), chromeMat, 0.5, 1.95, -0.1);

  // Back wall (bright white tile — the fluorescent-lit interior)
  placeMesh(shop, new THREE.BoxGeometry(5.5, 3.5, 0.1),
    new THREE.MeshStandardMaterial({ color: 0xf0ece0, roughness: 0.5 }), 0.5, 2.0, -0.8);

  // ---- FLUORESCENT LIGHT STRIP inside (visible through glass) ----
  var fluoro = new THREE.Mesh(new THREE.BoxGeometry(3.5, 0.06, 0.15),
    new THREE.MeshBasicMaterial({ color: 0xf0f0e8 }));
  fluoro.position.set(0.5, 3.4, -0.3);
  shop.add(fluoro);
  // Second strip
  var fluoro2 = new THREE.Mesh(new THREE.BoxGeometry(2.5, 0.06, 0.15),
    new THREE.MeshBasicMaterial({ color: 0xeeeee0 }));
  fluoro2.position.set(0.5, 3.4, -0.6);
  shop.add(fluoro2);

  // ---- BRIGHT INTERIOR LIGHTING — THE KEY FEATURE ----
  // Multiple strong warm lights to make this glow like a beacon
  var interiorLight1 = new THREE.PointLight(0xffe8c0, 1.5, 10);
  interiorLight1.position.set(0.5, 2.5, 0.5);
  shop.add(interiorLight1);
  var interiorLight2 = new THREE.PointLight(0xffe0b0, 1.0, 8);
  interiorLight2.position.set(-0.7, 2.0, 0.3);
  shop.add(interiorLight2);
  var interiorLight3 = new THREE.PointLight(0xffe0b0, 1.0, 8);
  interiorLight3.position.set(1.7, 2.0, 0.3);
  shop.add(interiorLight3);
  var doorSpill = new THREE.PointLight(0xffd880, 0.8, 6);
  doorSpill.position.set(0.5, 1.5, 1.5);
  shop.add(doorSpill);
  // Strong warm spill onto pavement
  var pavementSpill = new THREE.PointLight(0xffd060, 0.6, 8);
  pavementSpill.position.set(0.5, 0.3, 3.0);
  shop.add(pavementSpill);
  // Upward glow on fascia from windows
  var fasciaGlow = new THREE.PointLight(0xffe8c0, 0.4, 4);
  fasciaGlow.position.set(0.5, 3.5, 0.8);
  shop.add(fasciaGlow);

  // ---- ELECTRIC FLY-KILLER mounted high inside the left window ----
  // Classic 1970s chippy fixture, positioned just behind the front
  // glass so the violet-blue glow reads clearly from outside. Uses
  // additive blending so it shines through the warm window tint
  // rather than getting washed yellow.
  // Casing (visible silhouette behind the tube)
  placeMesh(shop, new THREE.BoxGeometry(0.85, 0.32, 0.10),
    new THREE.MeshStandardMaterial({ color: 0x2a2a2c, roughness: 0.65, metalness: 0.25 }),
    -1.0, 2.85, 0.10);
  // Grille (slatted dark front strips)
  for (var fkbar = 0; fkbar < 5; fkbar++) {
    placeMesh(shop, new THREE.BoxGeometry(0.78, 0.018, 0.015),
      new THREE.MeshStandardMaterial({ color: 0x1a1a1c, roughness: 0.7, metalness: 0.3 }),
      -1.0, 2.74 + fkbar * 0.06, 0.15);
  }
  // The blue UV tube — additive blending so it punches through the
  // warm window glass.
  var fkTubeMat = new THREE.MeshBasicMaterial({
    color: 0x6a90ff,
    blending: THREE.AdditiveBlending,
    transparent: true, opacity: 1.0, depthWrite: false
  });
  var fkTube = new THREE.Mesh(new THREE.PlaneGeometry(0.72, 0.18), fkTubeMat);
  fkTube.position.set(-1.0, 2.85, 0.17);
  shop.add(fkTube);
  // Brighter inner core (bluish-white)
  var fkCoreMat = new THREE.MeshBasicMaterial({
    color: 0xcad8ff,
    blending: THREE.AdditiveBlending,
    transparent: true, opacity: 1.0, depthWrite: false
  });
  var fkCore = new THREE.Mesh(new THREE.PlaneGeometry(0.65, 0.06), fkCoreMat);
  fkCore.position.set(-1.0, 2.85, 0.18);
  shop.add(fkCore);
  // Outer soft halo sprite to bloom the glow
  var fkHaloTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, w / 2);
    grad.addColorStop(0, 'rgba(120, 160, 255, 0.95)');
    grad.addColorStop(0.4, 'rgba(80, 120, 255, 0.35)');
    grad.addColorStop(1, 'rgba(60, 100, 255, 0)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });
  var fkHalo = new THREE.Sprite(new THREE.SpriteMaterial({
    map: fkHaloTex, transparent: true, opacity: 0.85,
    blending: THREE.AdditiveBlending, depthWrite: false
  }));
  fkHalo.position.set(-1.0, 2.85, 0.19);
  fkHalo.scale.set(1.3, 0.5, 1);
  shop.add(fkHalo);
  // Point light spilling cool blue forward
  var flyKillerGlow = new THREE.PointLight(0x4060ff, 0.55, 3.5);
  flyKillerGlow.position.set(-1.0, 2.7, -0.2);
  shop.add(flyKillerGlow);
  // Bluish wash on the back wall behind the unit (suggests halo
  // on the white tile — even though the unit itself is at the front)
  placeMesh(shop, new THREE.PlaneGeometry(1.4, 0.7),
    new THREE.MeshBasicMaterial({ color: 0x4060c8, transparent: true, opacity: 0.22 }),
    -1.0, 2.85, -0.78);

  // ---- CHINESE CHARACTERS on fascia (gold) ----
  // Traditional characters: 魚 (yú, "fish") on the left, 薯 (shǔ,
  // "potato/chip") on the right. Traditional script — fits a 70s
  // Soho chippy run by a Hong Kong family.
  function makeChiCharTex(glyph) {
    return makeCanvasTexture(64, 64, function(cx, w, h) {
      cx.clearRect(0, 0, w, h);
      cx.shadowColor = '#c8a840'; cx.shadowBlur = 4;
      cx.fillStyle = '#d4b850';
      cx.font = 'bold 52px "PingFang TC", "Heiti TC", "Microsoft JhengHei", "Songti TC", serif';
      cx.textAlign = 'center';
      cx.textBaseline = 'middle';
      cx.fillText(glyph, w / 2, h / 2 + 2);
      cx.shadowBlur = 0;
    });
  }
  var chiCharTexL = makeChiCharTex('魚');
  var chiCharTexR = makeChiCharTex('薯');
  var chiCharL = new THREE.Mesh(new THREE.PlaneGeometry(0.35, 0.35),
    new THREE.MeshBasicMaterial({ map: chiCharTexL, transparent: true }));
  chiCharL.position.set(-2.1, 4.2, 0.48);
  shop.add(chiCharL);
  var chiCharR = new THREE.Mesh(new THREE.PlaneGeometry(0.35, 0.35),
    new THREE.MeshBasicMaterial({ map: chiCharTexR, transparent: true }));
  chiCharR.position.set(3.1, 4.2, 0.48);
  shop.add(chiCharR);

  // ---- NEON FISH SHAPE (decorative neon on fascia) ----
  // A simple neon fish outline — red neon glow
  var neonFishShape = makeCanvasTexture(128, 64, function(cx, w, h) {
    cx.clearRect(0, 0, w, h);
    cx.shadowColor = '#ff3030'; cx.shadowBlur = 10;
    cx.strokeStyle = '#ff5050'; cx.lineWidth = 3;
    // Simple fish shape
    cx.beginPath();
    cx.moveTo(20, h / 2);
    cx.quadraticCurveTo(w / 2, 8, w - 30, h / 2);
    cx.quadraticCurveTo(w / 2, h - 8, 20, h / 2);
    cx.stroke();
    // Tail
    cx.beginPath();
    cx.moveTo(w - 30, h / 2);
    cx.lineTo(w - 10, 12);
    cx.lineTo(w - 10, h - 12);
    cx.closePath();
    cx.stroke();
    // Eye
    cx.beginPath();
    cx.arc(35, h / 2, 4, 0, Math.PI * 2);
    cx.stroke();
    cx.shadowBlur = 0;
  });
  // Left fish neon
  var neonFishL = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.4),
    new THREE.MeshBasicMaterial({ map: neonFishShape, transparent: true }));
  neonFishL.position.set(-1.8, 4.2, 0.48);
  shop.add(neonFishL);
  // Right fish (mirrored)
  var neonFishR = new THREE.Mesh(new THREE.PlaneGeometry(0.8, 0.4),
    new THREE.MeshBasicMaterial({ map: neonFishShape, transparent: true }));
  neonFishR.position.set(2.8, 4.2, 0.48);
  neonFishR.scale.x = -1;
  shop.add(neonFishR);
  // Red neon glow from fish
  var neonRedL = new THREE.PointLight(0xff3030, 0.15, 2);
  neonRedL.position.set(-1.8, 4.2, 0.6);
  shop.add(neonRedL);
  var neonRedR = new THREE.PointLight(0xff3030, 0.15, 2);
  neonRedR.position.set(2.8, 4.2, 0.6);
  shop.add(neonRedR);

  // ---- DRAINPIPES ----
  // Left drainpipe
  placeMesh(shop, new THREE.CylinderGeometry(0.04, 0.04, 11, 6), pipeMat, -2.4, 5.5, 0.15);
  for (var pbh = 2; pbh < 11; pbh += 2.2) {
