});
var puddlePos = [[1, 5, 2.0, 1.2], [-2, 6, 1.5, 0.8], [3, 7.5, 1.8, 1.0], [-1, 9, 2.2, 1.3], [5, 6, 1.2, 0.6], [-3, 8, 1.0, 0.7]];
