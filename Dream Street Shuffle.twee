="7" height="22" rx="1" fill="#f0f0f0"/><rect x="85" y="20" width="5" height="20" rx="1" fill="#ed2939"/><rect x="210" y="20" width="6" height="20" rx="1" fill="#002395"/><rect x="221" y="19" width="7" height="22" rx="1" fill="#f0f0f0"/><rect x="233" y="20" width="5" height="20" rx="1" fill="#ed2939"/></g><path d="M20,10 Q20,8 22,8 L28,8 Q30,8 30,10" fill="none" stroke="#c8a86a" stroke-width="0.8" opacity="0.5"/><path d="M270,10 Q270,8 272,8 L278,8 Q280,8 280,10" fill="none" stroke="#c8a86a" stroke-width="0.8" opacity="0.5"/><path d="M20,50 Q20,52 22,52 L28,52 Q30,52 30,50" fill="none" stroke="#c8a86a" stroke-width="0.8" opacity="0.5"/><path d="M270,50 Q270,52 272,52 L278,52 Q280,52 280,50" fill="none" stroke="#c8a86a" stroke-width="0.8" opacity="0.5"/></svg>
(set: $confidence to $confidence - 18)
He's been reading it for longer than is comfortable for either of you.

At last, he pushes it back and asks: 'Is this yours?'

Before you can answer, he says, 'I don't know.'

(if: not ($haunts contains $haunt2))[(if: $hauntExplained is false)[(set: $hauntExplained to true)
<div class="lore-box">
<strong>⟡ HAUNTS ⟡</strong>

Tonight, Soho will mark you. Here, in our mutual dream, we call these marks 'haunts'. You'll gather them as you wander the night and its stages. Seek them: you'll need them to get out.
</div>]
(set: $haunts to $haunts + (a: $haunt2))
(set: $exploredSinceFrench to false)
<div class="haunt-box">
<div class="haunt-header">⟡ HAUNT COLLECTED ⟡</div>
<div class="haunt-name">THE REFUSAL</div>
<div class="haunt-description">Chin up, lad, there's always poetry.</div>
</div>]

