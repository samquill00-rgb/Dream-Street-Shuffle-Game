// ============================================================
// FOG VOLUMES — thick Soho pea-souper atmosphere
// ============================================================
var thickFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(180, 170, 155, 0.25)');
  grad.addColorStop(0.4, 'rgba(150, 140, 130, 0.12)');
  grad.addColorStop(1, 'rgba(120, 110, 100, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});
var thinFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(140, 135, 125, 0.15)');
  grad.addColorStop(0.6, 'rgba(120, 115, 105, 0.06)');
  grad.addColorStop(1, 'rgba(100, 95, 85, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});
var warmFogTex = makeCanvasTexture(128, 128, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(200, 160, 100, 0.12)');
  grad.addColorStop(0.5, 'rgba(180, 140, 80, 0.05)');
  grad.addColorStop(1, 'rgba(150, 120, 60, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});

var fogSprites = [];

// LAYER 1: Thick ground-hugging fog banks
for (var i = 0; i < 45; i++) {
  var fogMat = new THREE.SpriteMaterial({
    map: thickFogTex, transparent: true,
    opacity: 0.2 + Math.random() * 0.2
  });
  var fogSprite = new THREE.Sprite(fogMat);
  fogSprite.position.set(
    Math.random() * 40 - 15,
    0.3 + Math.random() * 2,
    Math.random() * 30 - 5
  );
  var s = 5 + Math.random() * 12;
  fogSprite.scale.set(s, s * 0.35, 1);
  scene.add(fogSprite);
  fogSprites.push({
    sprite: fogSprite,
    baseX: fogSprite.position.x,
    drift: 0.002 + Math.random() * 0.006,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.001 + Math.random() * 0.004,
    swayAmt: 0.4 + Math.random() * 1.0
  });
}

// LAYER 2: Mid-height fog
for (var i = 0; i < 25; i++) {
  var midFogMat = new THREE.SpriteMaterial({
    map: thinFogTex, transparent: true,
    opacity: 0.12 + Math.random() * 0.12
  });
  var midFog = new THREE.Sprite(midFogMat);
  midFog.position.set(
    Math.random() * 35 - 12,
    2 + Math.random() * 6,
    Math.random() * 30 - 5
  );
  var ms = 6 + Math.random() * 14;
  midFog.scale.set(ms, ms * 0.3, 1);
  scene.add(midFog);
  fogSprites.push({
    sprite: midFog,
    baseX: midFog.position.x,
    drift: 0.001 + Math.random() * 0.004,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.0008 + Math.random() * 0.003,
    swayAmt: 0.5 + Math.random() * 1.5
  });
}

// LAYER 3: Warm-tinted fog near the pub (catches pub light)
for (var i = 0; i < 12; i++) {
  var warmFogMat = new THREE.SpriteMaterial({
    map: warmFogTex, transparent: true,
    opacity: 0.15 + Math.random() * 0.1
  });
  var warmFog = new THREE.Sprite(warmFogMat);
  warmFog.position.set(
    Math.random() * 10 - 3,
    0.5 + Math.random() * 3,
    1 + Math.random() * 6
  );
  var ws = 4 + Math.random() * 8;
  warmFog.scale.set(ws, ws * 0.3, 1);
  scene.add(warmFog);
  fogSprites.push({
    sprite: warmFog,
    baseX: warmFog.position.x,
    drift: 0.001 + Math.random() * 0.003,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.001 + Math.random() * 0.003,
    swayAmt: 0.3 + Math.random() * 0.8
  });
}

// LAYER 4: High wisps (above buildings)
for (var i = 0; i < 10; i++) {
  var highFogMat = new THREE.SpriteMaterial({
    map: thinFogTex, transparent: true,
    opacity: 0.08 + Math.random() * 0.08
  });
  var highFog = new THREE.Sprite(highFogMat);
  highFog.position.set(
    Math.random() * 30 - 10,
    8 + Math.random() * 8,
    Math.random() * 20 - 5
  );
  var hs = 10 + Math.random() * 15;
  highFog.scale.set(hs, hs * 0.2, 1);
  scene.add(highFog);
  fogSprites.push({
    sprite: highFog,
    baseX: highFog.position.x,
    drift: 0.003 + Math.random() * 0.005,
    sway: Math.random() * Math.PI * 2,
    swaySpeed: 0.0005 + Math.random() * 0.002,
    swayAmt: 1.0 + Math.random() * 2.0
  });
}

// ============================================================
// ANIMATION LOOP
// ============================================================
var clock = new THREE.Clock();

function phAnimate() {
  phAnimId = requestAnimationFrame(phAnimate);
  var t = clock.getElapsedTime();

  // Fog drift
  for (var i = 0; i < fogSprites.length; i++) {
    var f = fogSprites[i];
    f.sway += f.swaySpeed;
    f.sprite.position.x = f.baseX + Math.sin(f.sway) * f.swayAmt;
    f.baseX += f.drift;
    // Wrap fog that drifts too far
    if (f.baseX > 25) f.baseX = -25;
  }

  // Flickering pub lights
  for (var i = 0; i < lampLightsOnPub.length; i++) {
    var ll = lampLightsOnPub[i];
    ll.intensity = ll.userData.baseIntensity + Math.sin(t * 3 + i) * 0.08 + Math.sin(t * 7.3 + i * 2) * 0.04;
  }

  // Street lamp flicker (dual-frequency for naturalistic gas flicker)
  for (var i = 0; i < streetLampLights.length; i++) {
    var base = streetLampLights[i].userData.baseIntensity || 3;
    streetLampLights[i].intensity = base + Math.sin(t * 2.5 + i * 1.5) * 0.15 + Math.sin(t * 5.7 + i * 3) * 0.08;
  }

  // Pub interior glow pulse
  pubGlow.intensity = 1.2 + Math.sin(t * 1.5) * 0.18;
  pubGlow2.intensity = 0.6 + Math.sin(t * 1.8 + 0.5) * 0.1;
  pubGlow3.intensity = 0.35 + Math.sin(t * 2.0 + 1.0) * 0.06;
  doorLight.intensity = 0.8 + Math.sin(t * 2.2) * 0.12;
  pavementSpill.intensity = 0.3 + Math.sin(t * 1.2) * 0.05;

  // Silhouette sway
  for (var i = 0; i < silhouettes.length; i++) {
    var s = silhouettes[i];
    s.mesh.position.x = s.baseX + Math.sin(t * s.swaySpeed + s.swayPhase) * s.swayAmt;
  }

  // Alley light flicker (subtle, eerie)
  alleyLight.intensity = 0.25 + Math.sin(t * 1.8) * 0.05 + Math.sin(t * 4.1) * 0.03;
  alleyLight2.intensity = 0.15 + Math.sin(t * 2.5 + 1) * 0.03;
  alleyEndGlow.intensity = 1.2 + Math.sin(t * 0.8) * 0.15;
  alleyEndGlow2.intensity = 0.6 + Math.sin(t * 1.1 + 0.5) * 0.08;

  renderer.render(scene, camera);
}
// ---- ENTRY BUTTON ----
var phBtn = document.createElement('div');
phBtn.textContent = 'GO TO THE PILLARS';
phBtn.style.cssText = 'position:fixed;bottom:60px;left:50%;transform:translateX(-50%);padding:14px 36px;font:16px "Courier New",monospace;color:rgba(200,170,100,0.85);border:1px solid rgba(200,170,100,0.3);letter-spacing:4px;cursor:pointer;z-index:9004;background:transparent;opacity:0;transition:opacity 2s ease;';
// Show button after delay
setTimeout(function() { phBtn.style.opacity = '1'; }, 2500);
// Hover effects
phBtn.addEventListener('mouseenter', function() {
phBtn.style.color = 'rgba(230,200,120,0.95)';
phBtn.style.borderColor = 'rgba(200,170,100,0.6)';
});
phBtn.addEventListener('mouseleave', function() {
phBtn.style.color = 'rgba(200,170,100,0.85)';
phBtn.style.borderColor = 'rgba(200,170,100,0.3)';
});
// Click handler - fade out and navigate
phBtn.addEventListener('click', function() {
phWrap.style.transition = 'opacity 1.5s ease';
phWrap.style.opacity = '0';
setTimeout(function() {
if (phAnimId) cancelAnimationFrame(phAnimId);
phAnimId = null;
if (phWrap.parentNode) phWrap.parentNode.removeChild(phWrap);
// Navigate to target passage
var TARGET = 'Entering The Pillars of Hercules';
if (window.Engine && Engine.go) { Engine.go(TARGET); }
else {
var links = document.querySelectorAll('tw-link, .enchantment-link');
for (var i = 0; i < links.length; i++) {
if (links[i].textContent.trim() === '·') { links[i].click(); break; }
}
}
}, 1500);
});
phWrap.appendChild(phBtn);

document.body.appendChild(phWrap);
phAnimate();
}

// Watch for ph-container
setInterval(function() {
var container = document.getElementById('ph-container');
if (container && !phActive) {
initPillars();
} else if (!container) {
phActive = false;
if (phAnimId) { cancelAnimationFrame(phAnimId); phAnimId = null; }
window._dssDisposeWrap('ph-wrap');
}
}, 300);
})();


// ====== LACKLAND'S OFFICE SCENE — INLINE ======
(function() {
var loActive = false;
var loAnimId = null;
var loWrap = null;
var loVig = null;
var loGrain = null;
var loGrainCtx = null;
var loGrainFrame = 0;
var loWash = null;
var loDate = null;
var loLoc = null;
var loBtn = null;

function initLackland() {
if (loActive) return;
loActive = true;
if (typeof THREE === 'undefined') {
var s = document.createElement('script');
s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
s.onload = function() { buildLOScene(); };
document.head.appendChild(s);
} else {
buildLOScene();
}
}

function buildLOScene() {
// Create full-screen overlay wrapper
loWrap = document.createElement('div');
loWrap.id = 'lo-wrap';
loWrap.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:9000;background:#040408;overflow:hidden;';

// ============================================================
// SCENE SETUP
// ============================================================
var scene = new THREE.Scene();
scene.background = new THREE.Color(0x04040a);
scene.fog = new THREE.Fog(0x04040a, 4, 22);

var camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.set(2.8, 2.0, 6.5);
camera.lookAt(0, 2.8, 0);

var renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 0.54;
loWrap.appendChild(renderer.domElement);
window._dssBindScene('lo-wrap', scene, renderer, camera);

// ============================================================
// MATERIALS
// ============================================================
var stuccoTex = makeCanvasTexture(512, 1024, function(cx, w, h) {
cx.fillStyle = '#d5ccb8';
cx.fillRect(0, 0, w, h);
var sootWash = cx.createLinearGradient(0, 0, 0, h);
sootWash.addColorStop(0, 'rgba(50, 45, 35, 0.15)');
sootWash.addColorStop(0.1, 'rgba(60, 55, 45, 0.05)');
sootWash.addColorStop(0.5, 'rgba(0, 0, 0, 0)');
sootWash.addColorStop(0.85, 'rgba(50, 45, 30, 0.08)');
sootWash.addColorStop(1, 'rgba(40, 35, 25, 0.2)');
cx.fillStyle = sootWash;
cx.fillRect(0, 0, w, h);
cx.strokeStyle = 'rgba(90, 85, 70, 0.06)';
cx.lineWidth = 2;
for (var rs = 0; rs < 20; rs++) {
cx.beginPath();
var rx = Math.random() * w;
cx.moveTo(rx, 0);
for (var ry = 0; ry < h; ry += 30) {
rx += (Math.random() - 0.5) * 4;
cx.lineTo(rx, ry);
}
cx.stroke();
}
cx.fillStyle = 'rgba(160, 150, 130, 0.08)';
for (var pc = 0; pc < 6; pc++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 30 + Math.random() * 60, 20 + Math.random() * 40, Math.random(), 0, Math.PI * 2);
cx.fill();
}
});
var creamStucco = new THREE.MeshStandardMaterial({ map: stuccoTex, roughness: 0.85 });
var darkStucco = new THREE.MeshStandardMaterial({ color: 0xb0a890, roughness: 0.85 });
var sootBrick = new THREE.MeshStandardMaterial({ color: 0x2a2520, roughness: 0.9 });
var darkBrick = new THREE.MeshStandardMaterial({ color: 0x3a2a22, roughness: 0.9 });
var redBrick = new THREE.MeshStandardMaterial({ color: 0x6b3a2a, roughness: 0.85 });
var greyStone = new THREE.MeshStandardMaterial({ color: 0x9a9488, roughness: 0.75 });
var whiteStone = new THREE.MeshStandardMaterial({ color: 0xc8c0b0, roughness: 0.7 });
var paveTex = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#555550';
cx.fillRect(0, 0, w, h);
var flagRows = [
{ y: 0, h: 128 },
{ y: 128, h: 110 },
{ y: 238, h: 140 },
{ y: 378, h: 134 }
];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var slabs = (ri % 2 === 0) ? [0, 200, 380] : [0, 260, 420];
for (var si = 0; si < slabs.length; si++) {
var sx = slabs[si];
var sw = (si < slabs.length - 1) ? slabs[si + 1] - sx : w - sx;
var tone = 60 + Math.random() * 25;
cx.fillStyle = 'rgb(' + tone + ',' + tone + ',' + (tone - 3) + ')';
cx.fillRect(sx + 2, row.y + 2, sw - 4, row.h - 4);
cx.fillStyle = 'rgba(80, 78, 72, 0.06)';
for (var sp = 0; sp < 8; sp++) {
cx.beginPath();
cx.ellipse(sx + Math.random() * sw, row.y + Math.random() * row.h, 10 + Math.random() * 25, 5 + Math.random() * 12, Math.random(), 0, Math.PI * 2);
cx.fill();
}
}
}
cx.strokeStyle = 'rgba(25, 22, 18, 0.6)';
cx.lineWidth = 3;
for (var ri = 0; ri < flagRows.length; ri++) {
cx.beginPath();
cx.moveTo(0, flagRows[ri].y);
cx.lineTo(w, flagRows[ri].y);
cx.stroke();
}
var vertLines1 = [200, 380];
var vertLines2 = [260, 420];
for (var ri = 0; ri < flagRows.length; ri++) {
var row = flagRows[ri];
var vlines = (ri % 2 === 0) ? vertLines1 : vertLines2;
for (var vi = 0; vi < vlines.length; vi++) {
cx.beginPath();
cx.moveTo(vlines[vi], row.y);
cx.lineTo(vlines[vi], row.y + row.h);
cx.stroke();
}
}
cx.fillStyle = 'rgba(15, 12, 8, 0.25)';
for (var ri = 0; ri < flagRows.length; ri++) {
cx.fillRect(0, flagRows[ri].y - 1, w, 4);
}
cx.fillStyle = 'rgba(30, 28, 22, 0.2)';
for (var st = 0; st < 8; st++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 8 + Math.random() * 20, 6 + Math.random() * 15, Math.random() * Math.PI, 0, Math.PI * 2);
cx.fill();
}
cx.fillStyle = 'rgba(90, 88, 82, 0.35)';
for (var gm = 0; gm < 5; gm++) {
cx.beginPath();
cx.arc(Math.random() * w, Math.random() * h, 2 + Math.random() * 4, 0, Math.PI * 2);
cx.fill();
}
cx.fillStyle = 'rgba(35, 35, 38, 0.12)';
for (var dp = 0; dp < 3; dp++) {
cx.beginPath();
cx.ellipse(Math.random() * w, Math.random() * h, 25 + Math.random() * 40, 20 + Math.random() * 30, Math.random(), 0, Math.PI * 2);
cx.fill();
}
});
var pavementMat = new THREE.MeshStandardMaterial({ map: paveTex, roughness: 0.9 });
// Road — grimy tarmac with aggregate, cracks, repair patches, tar-seal
var roadFaceTexLo = makeCanvasTexture(512, 512, function(cx, w, h) {
cx.fillStyle = '#181818'; cx.fillRect(0, 0, w, h);
for (var p = 0; p < 4200; p++) {
var pg = 25 + Math.floor(Math.random() * 70);
cx.fillStyle = 'rgba(' + pg + ',' + pg + ',' + pg + ',0.42)';
cx.fillRect(Math.random() * w, Math.random() * h, 1.5, 1.5);
}
for (var rp = 0; rp < 6; rp++) {
var rx = Math.random() * w, ry = Math.random() * h;
var rwd = 50 + Math.random() * 100, rht = 35 + Math.random() * 70;
cx.fillStyle = 'rgba(72, 72, 72, ' + (0.16 + Math.random() * 0.22).toFixed(3) + ')';
cx.fillRect(rx, ry, rwd, rht);
cx.strokeStyle = 'rgba(100, 100, 100, 0.18)'; cx.lineWidth = 0.6;
cx.strokeRect(rx, ry, rwd, rht);
}
cx.strokeStyle = 'rgba(6, 6, 6, 0.8)'; cx.lineWidth = 1.2;
for (var c = 0; c < 10; c++) {
cx.beginPath();
var cx0 = Math.random() * w, cy0 = Math.random() * h;
cx.moveTo(cx0, cy0);
var ang = Math.random() * Math.PI * 2, len = 30 + Math.random() * 80;
cx.lineTo(cx0 + Math.cos(ang) * len, cy0 + Math.sin(ang) * len);
cx.lineTo(cx0 + Math.cos(ang + 0.4) * len * 1.4, cy0 + Math.sin(ang + 0.4) * len * 1.4);
cx.stroke();
}
cx.strokeStyle = 'rgba(0, 0, 0, 0.9)'; cx.lineWidth = 2.6;
for (var tm = 0; tm < 5; tm++) {
cx.beginPath();
var tx = Math.random() * w, ty = Math.random() * h;
cx.moveTo(tx, ty);
for (var ts = 0; ts < 5; ts++) {
tx += (Math.random() - 0.5) * 30;
ty += 8 + Math.random() * 16;
cx.lineTo(tx, ty);
}
cx.stroke();
}
cx.fillStyle = 'rgba(220, 220, 200, 0.5)';
cx.fillRect(w * 0.5 - 2, h * 0.3, 4, h * 0.4);
cx.fillStyle = 'rgba(220, 220, 200, 0.18)';
cx.fillRect(w * 0.5 - 2, h * 0.05, 4, h * 0.2);
cx.fillRect(w * 0.5 - 2, h * 0.75, 4, h * 0.2);
for (var os = 0; os < 4; os++) {
var ox = Math.random() * w, oy = Math.random() * h;
var orr = 8 + Math.random() * 18;
var og = cx.createRadialGradient(ox, oy, 0, ox, oy, orr);
og.addColorStop(0, 'rgba(0, 0, 0, 0.62)');
og.addColorStop(0.7, 'rgba(15, 12, 5, 0.22)');
og.addColorStop(1, 'rgba(15, 12, 5, 0)');
cx.fillStyle = og; cx.fillRect(ox - orr, oy - orr, orr * 2, orr * 2);
}
});
roadFaceTexLo.wrapS = roadFaceTexLo.wrapT = THREE.RepeatWrapping;
roadFaceTexLo.repeat.set(1, 8);
var roadMat = new THREE.MeshStandardMaterial({ map: roadFaceTexLo, roughness: 0.78, metalness: 0.15 });
