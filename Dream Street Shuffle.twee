    lfo.connect(lfoG); lfoG.connect(f.frequency);
    lfo.start(now);
    src.connect(f); f.connect(g); g.connect(ac.destination);
    src.start(now);
    _ambient = { src: src, g: g, kind: 'dream', lfo: lfo };
      });
  }
  function ambientOff() { _stopAmbient(); }
  function ambientCut() { _stopAmbient(0); }
  // ====== FARNELL-STYLE PROCEDURAL MODELS ======
  // British telephone bell — two iron gongs, magnetic clapper alternates
  // between them at ~25 Hz. Each gong rings with several inharmonic modes.
  // Modelled after Farnell, "Designing Sound" ch. on the telephone bell.
  // Tracks scheduled oscillators in _phoneBellNodes so stopPhoneBell()
  // can kill an in-flight bell when the passage changes.
  var _phoneBellNodes = [];
  function stopPhoneBell() {
    _phoneBellNodes.forEach(function(node) {
      try { if (node.stop) node.stop(); } catch(e) {}
      try { node.disconnect(); } catch(e) {}
    });
    _phoneBellNodes = [];
  }
  function phoneBell(rings) {
    stopPhoneBell();
    _play(function(ac) {
    rings = rings || 2;
    var now = ac.currentTime;
    function strike(t, gongA) {
      // Two gongs of slightly different size — each has 3 inharmonic partials
      var partials = gongA
        ? [{ f: 1380, a: 0.10, d: 0.18 },
           { f: 2050, a: 0.06, d: 0.13 },
           { f: 3120, a: 0.03, d: 0.09 }]
        : [{ f: 1620, a: 0.10, d: 0.18 },
           { f: 2410, a: 0.06, d: 0.13 },
           { f: 3580, a: 0.03, d: 0.09 }];
      partials.forEach(function(p) {
        var o = ac.createOscillator(); o.type='sine';
        // Tiny pitch drift so each strike isn't identical
        o.frequency.value = p.f * (1 + (Math.random()-0.5) * 0.006);
        var g = ac.createGain();
        g.gain.setValueAtTime(0.001, t);
        g.gain.linearRampToValueAtTime(p.a, t + 0.001);
        g.gain.exponentialRampToValueAtTime(0.001, t + p.d);
        o.connect(g); g.connect(ac.destination);
