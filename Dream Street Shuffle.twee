(set: _ll to "<path d='M 0,0 C 0.5,5 0,10 0,15' fill='none' stroke='#9aa888' stroke-width='1.0' stroke-linecap='round' opacity='0.85'/><path d='M 0,15 C -5,14 -6,16 -8,20 C -4,17 4,17 8,20 C 6,16 5,14 0,15' fill='#8a9678' opacity='0.65' stroke='#5a6850' stroke-width='0.35'/><path d='M 0,15 C -8,16 -12,22 -12,31 C -12,38 -11,43 -11,46 Q -12,50 -10,53 Q -8,56 -5.5,53 Q -3.5,56 -1.5,53 Q 0,56 1.5,53 Q 3.5,56 5.5,53 Q 8,56 10,53 Q 12,50 11,46 C 11,43 12,38 12,31 C 12,22 8,16 0,15 Z' fill='#f5f0e2' stroke='none' opacity='0.35'/><path d='M 0,15 C -8,16 -12,22 -12,31 C -12,38 -11,43 -11,46 Q -12,50 -10,53 Q -8,56 -5.5,53 Q -3.5,56 -1.5,53 Q 0,56 1.5,53 Q 3.5,56 5.5,53 Q 8,56 10,53 Q 12,50 11,46 C 11,43 12,38 12,31 C 12,22 8,16 0,15 Z' fill='none' stroke='#9a8868' stroke-width='0.45' opacity='0.7'/><path d='M 0,20 C -6,21 -7,26 -7,33 C -7,40 -3,46 0,46 C 3,46 7,40 7,33 C 7,26 6,21 0,20 Z' fill='#fbfaf3' stroke='none' opacity='0.14'/><path d='M 0,17 Q 0,35 0,52' fill='none' stroke='#a08868' stroke-width='0.38' opacity='0.68' stroke-linecap='round'/><path d='M -2,17 Q -3,34 -3.5,52' fill='none' stroke='#a08868' stroke-width='0.34' opacity='0.62' stroke-linecap='round'/><path d='M 2,17 Q 3,34 3.5,52' fill='none' stroke='#a08868' stroke-width='0.34' opacity='0.62' stroke-linecap='round'/><path d='M -5,17 Q -7,34 -8,51' fill='none' stroke='#a08868' stroke-width='0.34' opacity='0.6' stroke-linecap='round'/><path d='M 5,17 Q 7,34 8,51' fill='none' stroke='#a08868' stroke-width='0.34' opacity='0.6' stroke-linecap='round'/><path d='M -7.5,18 Q -10,32 -10.5,49' fill='none' stroke='#b09878' stroke-width='0.3' opacity='0.5' stroke-linecap='round'/><path d='M 7.5,18 Q 10,32 10.5,49' fill='none' stroke='#b09878' stroke-width='0.3' opacity='0.5' stroke-linecap='round'/><circle cx='-1.5' cy='49' r='0.6' fill='#7a6438' opacity='0.65'/><circle cx='1.5' cy='49' r='0.6' fill='#7a6438' opacity='0.65'/><circle cx='0' cy='50' r='0.5' fill='#7a6438' opacity='0.62'/>")(set: _pv to "<div class='cent