"none" stroke="#0a0a0a" stroke-width="1" opacity="0.22"/><!-- Flower 1 --><path d="M80,38 Q76,42 72,50 Q70,56 74,60 Q78,64 84,62 Q90,58 88,50 Q86,42 80,38 Z" fill="#d4cdb8" fill-opacity="0.35" stroke="#0a0a0a" stroke-width="2.8" stroke-linejoin="round"/><path d="M76,50 L80,60" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.4"/><path d="M84,48 L82,60" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.35"/><path d="M80,38 Q82,34 86,30 Q90,26 92,22" fill="none" stroke="#0a0a0a" stroke-width="2.2" stroke-linecap="round"/><!-- Flower 2 --><path d="M102,34 Q98,38 96,44 Q94,50 98,54 Q102,56 106,52 Q110,48 108,42 Q106,36 102,34 Z" fill="#c8c0a8" fill-opacity="0.3" stroke="#0a0a0a" stroke-width="2.6" stroke-linejoin="round"/><path d="M100,44 L100,54" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.35"/><path d="M102,34 Q104,30 108,26" fill="none" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round"/><!-- Flower 3 --><path d="M126,30 Q122,34 120,40 Q118,46 122,48 Q126,50 130,46 Q132,40 130,34 Q128,30 126,30 Z" fill="#d0c8b0" fill-opacity="0.25" stroke="#0a0a0a" stroke-width="2.4" stroke-linejoin="round"/><path d="M126,30 Q128,26 132,22" fill="none" stroke="#0a0a0a" stroke-width="1.8" stroke-linecap="round"/><!-- Flower 4 --><path d="M152,26 Q148,30 148,36 Q150,40 154,38 Q158,34 156,28 Q154,26 152,26 Z" fill="#c4bca4" fill-opacity="0.2" stroke="#0a0a0a" stroke-width="2.2" stroke-linejoin="round"/><path d="M152,26 Q154,22 158,18" fill="none" stroke="#0a0a0a" stroke-width="1.6" stroke-linecap="round"/><!-- Flower 5 --><path d="M170,22 Q168,26 168,30 Q170,34 174,30 Q176,26 172,22 Z" fill="#beb6a0" fill-opacity="0.18" stroke="#0a0a0a" stroke-width="2" stroke-linejoin="round"/><path d="M170,22 Q172,18 176,14" fill="none" stroke="#0a0a0a" stroke-width="1.4" stroke-linecap="round"/><!-- Small leaf --><path d="M110,56 Q118,52 124,56 Q128,62 122,66 Q114,68 110,62 Q108,58 110,56 Z" fill="#2a5c22" fill-opacity="0.12" stroke="#0a0a0a" stroke-width="2" stroke-linejoin="round" opacity="0.6"/><!-- Background lead --><path d="M0,20 Q10,18 20,22 Q30,26 36,30" fill="none" stroke="#0a0a0a" stroke-width="1.5" opacity="0.18"/><path d="M0,50 Q8,46 16,48 Q24,52 30,50" fill="none" stroke="#0a0a0a" stroke-width="1.3" opacity="0.14"/><path d="M160,58 Q172,54 186,56 Q200,60 210,56" fill="none" stroke="#0a0a0a" stroke-width="1.4" opacity="0.1"/></g></svg>
<div class="stat-group">
(set: _confClass to "")(set: _confGhost to "")(set: _confPct to "")(set: _confDelta to "")(if: $prevConfidence is a number)[(if: $confidence > $prevConfidence)[(set: _confClass to " bar-flash-up")(set: _confGhost to "<span class='bar-ghost bar-ghost-gain' style='width:" + (text: $prevConfidence) + "%'></span>")(set: _confPct to " pct-gain")(set: _confDelta to "<span class='stat-delta delta-gain'>+" + (text: $confidence - $prevConfidence) + "</span>")](else-if: $confidence < $prevConfidence)[(set: _confClass to " bar-flash-down")(set: _confGhost to "<span class='bar-ghost bar-ghost-loss' style='width:" + (text: $prevConfidence) + "%'></span>")(set: _confPct to " pct-loss")(set: _confDelta to "<span class='stat-delta delta-loss'>" + (text: $confidence - $prevConfidence) + "</span>")]]
(set: _sobClass to "")(set: _sobGhost to "")(set: _sobPct to "")(set: _sobDelta to "")(if: $prevSobriety is a number)[(if: $sobriety > $prevSobriety)[(set: _sobClass to " bar-flash-up")(set: _sobGhost to "<span class='bar-ghost bar-ghost-gain' style='width:" + (text: $prevSobriety) + "%'></span>")(set: _sobPct to " pct-gain")(set: _sobDelta to "<span class='stat-delta delta-gain'>+" + (text: $sobriety - $prevSobriety) + "</span>")](else-if: $sobriety < $prevSobriety)[(set: _sobClass to " bar-flash-down")(set: _sobGhost to "<span class='bar-ghost bar-ghost-loss' style='width:" + (text: $prevSobriety) + "%'></span>")(set: _sobPct to " pct-loss")(set: _sobDelta to "<span class='stat-delta delta-loss'>" + (text: $sobriety - $prevSobriety) + "</span>")]]
<div class="stat-row">
(if: $haunts's length >= 12)[<span class="stat-label stat-label-opus">OPUS</span>](else:)[<span class="stat-label">MORALE</span>]
<span class="stat-bar">(if: $haunts's length >= 12)[(print: "<span class='bar-fill bar-opus' style='width:100%'></span>")](else:)[(print: _confGhost)(if: $confidence >= 50)[(print: "<span class='bar-fill bar-good" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")](else-if: $confidence >= 25)[(print: "<span class='bar-fill bar-warning" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")](else:)[(print: "<span class='bar-fill bar-danger" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")]](print: _confDelta)</span>
(if: $haunts's length >= 12)[(print: "<span class='stat-pct pct-opus'>100%</span>")](else:)[(print: "<span class='stat-pct" + _confPct + "'>" + (text: $confidence) + "%</span>")]
</div>
<div class="stat-row">
(if: $haunts's length >= 12)[<span class="stat-label stat-label-opus">STATE</span>](else:)[<span class="stat-label">SOBRIETY</span>]
<span class="stat-bar">(if: $haunts's length >= 12)[(print: "<span class='bar-fill bar-opus' style='width:100%'></span>")](else:)[(print: _sobGhost)(if: $sobriety >= 50)[(print: "<span class='bar-fill bar-good" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")](else-if: $sobriety >= 25)[(print: "<span class='bar-fill bar-warning" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")](else:)[(print: "<span class='bar-fill bar-danger" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")]](print: _sobDelta)</span>
(if: $haunts's length >= 12)[(print: "<span class='stat-pct pct-opus'>100%</span>")](else:)[(print: "<span class='stat-pct" + _sobPct + "'>" + (text: $sobriety) + "%</span>")]
</div>
</div>
<div class="alba-strip">
<span class="stat-label">ALBA</span>
<span class="alba-jewels">(set: _j1 to "alba-jewel")(if: $alba contains $alba1)[(set: _j1 to _j1 + " alba-jewel-filled")](set: _j2 to "alba-jewel")(if: $alba contains $alba2)[(set: _j2 to _j2 + " alba-jewel-filled")](set: _j3 to "alba-jewel")(if: $alba contains $alba3)[(set: _j3 to _j3 + " alba-jewel-filled")](print: "<span class='" + _j1 + "'></span><span class='" + _j2 + "'></span><span class='" + _j3 + "'></span>")</span>
<span class="alba-count">(set: _ac to 0)(if: $alba contains $alba1)[(set: _ac to _ac + 1)](if: $alba contains $alba2)[(set: _ac to _ac + 1)](if: $alba contains $alba3)[(set: _ac to _ac + 1)](print: _ac)/3</span>
</div>
<div class="alba-hint">(if: _ac is 1)[One line is caught. Two more still to find.](else-if: _ac is 2)[Two lines, now. The third always close.](else-if: _ac >= 3)[The Alba is complete. Centre Point waits.]</div>
(if: $hasLiver is true and ($confidence is a number and $sobriety is a number) and ($confidence < 10 or $sobriety < 10))[<div class="liver-hint">'You're running on fumes. Remember: Shelley's liver in your notebook.'</div>]
(set: _backHide to (a: "Title", "Start", "The Night Ahead", "Name Your Book", "Dawn", "White page", "Black page", "Dawn Approach White", "Dawn Approach Black", "Alba Complete", "Alba Incomplete", "PP Pong", "Ride Jeffrey Bernard's cow", "Fight starts", "Fight Round 1", "Fight Round 2", "Fight Round 3", "Fight Victory", "Fight Defeat", "The phone call", "Lily phone call 1", "The dual ring", "After the call", "After Aoife"))
<div class="header-links">(unless: _backHide contains (passage:)'s name)[<div class="back-one-link">(link-undo: "← BACK")</div>]
<div class="notebook-link">(link-repeat: "NOTEBOOK")[(display: "Build Notebook")]</div>
</div>
</div>
(unless: $prevCigsTonight is a number)[(set: $prevCigsTonight to ($cigsTonight + 0))]\
(if: $cigsTonight is a number and $cigsTonight > $prevCigsTonight)[<script>if(window.startBurningCigarette)window.startBurningCigarette();</script>]\
(set: $prevCigsTonight to $cigsTonight)\
(set: $prevConfidence to $confidence)(set: $prevSobriety to $sobriety)
(if: $afterMidnight is true)[<span id="dst-after-midnight" style="display:none"></span>]
]

:: Build Notebook {"position":"500,50","size":"100,100"}
{
