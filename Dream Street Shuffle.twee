  color: 0x222228, roughness: 0.12, metalness: 0.55, transparent: true, opacity: 0.25
});
var wetPave = new THREE.Mesh(new THREE.PlaneGeometry(30, 4), wetPaveMat);
wetPave.rotation.x = -Math.PI / 2;
wetPave.position.set(0, 0.08, 2);
scene.add(wetPave);

// ============================================================
