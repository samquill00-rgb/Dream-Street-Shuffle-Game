}
// Trailing ivy below the planter
for (var iv = -0.8; iv <= 3.5; iv += 0.9) {
  var ivy = new THREE.Mesh(new THREE.BoxGeometry(0.12, 0.3 + Math.random() * 0.3, 0.05),
    new THREE.MeshStandardMaterial({ color: 0x1a4a0a, roughness: 0.9 }));
  ivy.position.set(iv, 3.65 - Math.random() * 0.1, 0.55);
  pub.add(ivy);
}

// ---- CREAM FASCIA "No7 PILLARS OF HERCULES No7" ----
var fasciaC = document.createElement('canvas');
fasciaC.width = 640; fasciaC.height = 64;
var fctx = fasciaC.getContext('2d');
// Cream background
fctx.fillStyle = '#e8dcc8';
fctx.fillRect(0, 0, 640, 64);
// Dark border top and bottom
fctx.fillStyle = '#3a1a10';
fctx.fillRect(0, 0, 640, 4);
fctx.fillRect(0, 60, 640, 4);
// Dark red/maroon text
fctx.fillStyle = '#6a1a10';
fctx.font = 'bold 30px Georgia, serif';
fctx.textAlign = 'center';
fctx.fillText('No7    PILLARS  OF  HERCULES    No7', 320, 42);
// Pointing hand decorations
fctx.font = '22px Georgia, serif';
fctx.fillText('\u261E', 120, 42);
fctx.fillText('\u261C', 520, 42);

var fasciaTex = new THREE.CanvasTexture(fasciaC);
var fascia = new THREE.Mesh(new THREE.BoxGeometry(5.4, 0.5, 0.18),
  new THREE.MeshBasicMaterial({ map: fasciaTex }));
fascia.position.set(1.25, 3.55, 0.5);
pub.add(fascia);

// ---- SMALL VICTORIAN LAMPS on fascia ----
var lampLightsOnPub = [];
for (var lx = -1.0; lx <= 3.5; lx += 4.5) {
  var lampBracket = new THREE.Mesh(new THREE.BoxGeometry(0.06, 0.3, 0.2),
    new THREE.MeshStandardMaterial({ color: 0x1a1a18, roughness: 0.8 }));
  lampBracket.position.set(lx, 3.75, 0.6);
  pub.add(lampBracket);
  var lampGlobe = new THREE.Mesh(new THREE.SphereGeometry(0.08, 6, 6),
    new THREE.MeshBasicMaterial({ color: 0xffe8aa, transparent: true, opacity: 0.8 }));
  lampGlobe.position.set(lx, 3.95, 0.7);
  pub.add(lampGlobe);
  var lampL = new THREE.PointLight(0xffd080, 0.5, 5);
  lampL.position.set(lx, 3.95, 0.8);
  lampL.userData.baseIntensity = 0.5;
  pub.add(lampL);
  lampLightsOnPub.push(lampL);
}

// ---- DARK MAROON AWNING below fascia ----
var awning = new THREE.Mesh(new THREE.BoxGeometry(4.5, 0.25, 0.5),
  new THREE.MeshStandardMaterial({ color: 0x4a1015, roughness: 0.7 }));
awning.position.set(1.5, 3.15, 0.7);
pub.add(awning);

// ---- RICH MAHOGANY PUB ENTRANCE (right side of ground floor) ----
// The pub front extends from the alley right edge to the right of the building
var pubFront = new THREE.Mesh(new THREE.BoxGeometry(5.2, 3.2, 0.3), mahoganyDark);
pubFront.position.set(1.5, 1.6, 0.45);
pub.add(pubFront);

// Ornate mahogany frame around entrance
placeMesh(pub, new THREE.BoxGeometry(0.18, 3.2, 0.35), mahogany, -1.05, 1.6, 0.6);
placeMesh(pub, new THREE.BoxGeometry(0.18, 3.2, 0.35), mahogany, 4.0, 1.6, 0.6);
placeMesh(pub, new THREE.BoxGeometry(5.3, 0.18, 0.35), mahogany, 1.5, 3.15, 0.6);

// ---- Kickboard / plinth at very bottom of mahogany section ----
placeMesh(pub, new THREE.BoxGeometry(5.3, 0.3, 0.12), mahoganyDark, 1.5, 0.15, 0.65);

// ---- VICTORIAN PUB GROUND FLOOR — proper window bays and door ----
// Layout: [left bay] [door] [right bay 1] [right bay 2]
// Pub front runs from x=-1.05 to x=4.0

// Helper: create a proper pub window bay
function createWindowBay(cx, bayW, bayH, yBase) {
  var glassH = bayH - 0.5; // glass area (above kickboard)
  var glassY = yBase + 0.25 + glassH / 2;
  var kickY = yBase + 0.17;

  // Warm glass glow (the lit interior)
  var bayGlass = new THREE.Mesh(new THREE.PlaneGeometry(bayW - 0.12, glassH),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.7 }));
  bayGlass.position.set(cx, glassY, 0.63);
  pub.add(bayGlass);

  // Outer frame (mahogany surround)
  placeMesh(pub, new THREE.BoxGeometry(0.06, bayH, 0.08), mahogany, cx - bayW/2, yBase + bayH/2, 0.62);
  placeMesh(pub, new THREE.BoxGeometry(0.06, bayH, 0.08), mahogany, cx + bayW/2, yBase + bayH/2, 0.62);
  placeMesh(pub, new THREE.BoxGeometry(bayW + 0.06, 0.06, 0.08), mahogany, cx, yBase + bayH, 0.62);
  placeMesh(pub, new THREE.BoxGeometry(bayW + 0.06, 0.06, 0.08), mahogany, cx, yBase + 0.5, 0.62);

  // Vertical glazing bars (dividing bay into 3 panes)
  var paneW = bayW / 3;
  placeMesh(pub, new THREE.BoxGeometry(0.03, glassH, 0.04), mahogany, cx - paneW / 2 - paneW / 6, glassY, 0.66);
  placeMesh(pub, new THREE.BoxGeometry(0.03, glassH, 0.04), mahogany, cx + paneW / 2 + paneW / 6, glassY, 0.66);

  // Horizontal glazing bars (2 rows for traditional 3×3 grid effect)
  var thirdH = glassH / 3;
  placeMesh(pub, new THREE.BoxGeometry(bayW - 0.12, 0.03, 0.04), mahogany, cx, glassY - thirdH / 2, 0.66);
  placeMesh(pub, new THREE.BoxGeometry(bayW - 0.12, 0.03, 0.04), mahogany, cx, glassY + thirdH / 2, 0.66);

  // Solid kickboard panel below glass
  placeMesh(pub, new THREE.BoxGeometry(bayW - 0.08, 0.4, 0.06), mahoganyDark, cx, kickY, 0.62);
  // Kickboard moulding
  placeMesh(pub, new THREE.BoxGeometry(bayW - 0.04, 0.04, 0.04), mahogany, cx, yBase + 0.38, 0.64);
}

// Left window bay (between alley and door)
createWindowBay(-0.3, 1.2, 2.6, 0.3);

// ---- PUB DOOR (central) ----
var doorX = 0.7;
// Door frame
placeMesh(pub, new THREE.BoxGeometry(0.95, 2.7, 0.1), mahoganyDark, doorX, 1.35, 0.62);
// Lower door panels (solid wood, recessed)
placeMesh(pub, new THREE.BoxGeometry(0.34, 0.65, 0.04),
  new THREE.MeshStandardMaterial({ color: 0x301510, roughness: 0.8 }), doorX - 0.15, 0.65, 0.68);
placeMesh(pub, new THREE.BoxGeometry(0.34, 0.65, 0.04),
  new THREE.MeshStandardMaterial({ color: 0x301510, roughness: 0.8 }), doorX + 0.15, 0.65, 0.68);
// Upper door glass (warm glow from inside)
placeMesh(pub, new THREE.BoxGeometry(0.7, 1.1, 0.06),
  new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.65 }),
  doorX, 1.6, 0.66);
// Glazing bars on door glass (cross pattern)
placeMesh(pub, new THREE.BoxGeometry(0.03, 1.1, 0.02), mahogany, doorX, 1.6, 0.7);
placeMesh(pub, new THREE.BoxGeometry(0.7, 0.03, 0.02), mahogany, doorX, 1.6, 0.7);
// Fanlight above door
placeMesh(pub, new THREE.BoxGeometry(0.95, 0.3, 0.06),
  new THREE.MeshBasicMaterial({ color: 0xffd080, transparent: true, opacity: 0.5 }),
  doorX, 2.55, 0.66);
placeMesh(pub, new THREE.BoxGeometry(0.98, 0.04, 0.04), mahogany, doorX, 2.38, 0.67);
// Brass door handle
placeMesh(pub, new THREE.BoxGeometry(0.04, 0.14, 0.06), goldMat, doorX + 0.28, 1.2, 0.72);
// Door step (stone)
placeMesh(pub, new THREE.BoxGeometry(1.1, 0.08, 0.3), sillMat, doorX, 0.04, 0.8);

// Right window bays (two bays to the right of the door)
createWindowBay(1.8, 1.2, 2.6, 0.3);
createWindowBay(3.1, 1.2, 2.6, 0.3);

// Decorative brackets under awning
for (var bx = -0.3; bx <= 3.5; bx += 1.3) {
  placeMesh(pub, new THREE.BoxGeometry(0.06, 0.35, 0.06), mahogany, bx, 3.0, 0.7);
}

// Brick base/step running along the ground floor
var brickBase = new THREE.Mesh(new THREE.BoxGeometry(5.3, 0.12, 0.5),
  new THREE.MeshStandardMaterial({ color: 0x6a3028, roughness: 0.85 }));
brickBase.position.set(1.5, 0.06, 0.7);
pub.add(brickBase);

// ---- THE ALLEYWAY (left side — the distinctive passage) ----
// Dark archway cut into the building — narrow passage through to another street
var alleyWidth = 2.2;
var alleyX = -2.2; // centre of alley

// Alley void — built from individual planes so glow can show through
// Back wall (the far end of tunnel — receives the glow light)
var alleyDarkMat = new THREE.MeshStandardMaterial({ color: 0x14120e, roughness: 0.88 });
var alleyBackWall = new THREE.Mesh(new THREE.PlaneGeometry(alleyWidth, 3.5), alleyDarkMat);
alleyBackWall.position.set(alleyX, 1.75, -3.5);
pub.add(alleyBackWall);

// Alley ceiling (keeps it enclosed/tunnel-like)
var alleyCeiling = new THREE.Mesh(new THREE.PlaneGeometry(alleyWidth, 6), alleyDarkMat);
alleyCeiling.rotation.x = Math.PI / 2;
alleyCeiling.position.set(alleyX, 3.5, -1.5);
pub.add(alleyCeiling);

// Alley walls — grimy dark brick
var alleyWallR = new THREE.Mesh(new THREE.PlaneGeometry(6, 3.5),
  new THREE.MeshStandardMaterial({ color: 0x282018, roughness: 0.9 }));
alleyWallR.position.set(alleyX + alleyWidth / 2, 1.75, -2.5);
alleyWallR.rotation.y = -Math.PI / 2;
pub.add(alleyWallR);

var alleyWallL = new THREE.Mesh(new THREE.PlaneGeometry(6, 3.5),
  new THREE.MeshStandardMaterial({ color: 0x2a2220, roughness: 0.9 }));
alleyWallL.position.set(alleyX - alleyWidth / 2, 1.75, -2.5);
alleyWallL.rotation.y = Math.PI / 2;
pub.add(alleyWallL);

// Alley floor (dark wet cobbles)
var alleyFloor = new THREE.Mesh(new THREE.PlaneGeometry(alleyWidth, 6),
  new THREE.MeshStandardMaterial({ color: 0x141210, roughness: 0.7 }));
alleyFloor.rotation.x = -Math.PI / 2;
alleyFloor.position.set(alleyX, 0.02, -2.5);
pub.add(alleyFloor);

// Upper floors overhang the alley
var overhang = new THREE.Mesh(new THREE.BoxGeometry(alleyWidth + 0.4, 9, 7), whitePlaster);
overhang.position.set(alleyX, 8.25, -3.5);
pub.add(overhang);

// Timber on the overhang facade — richer framing
placeMesh(pub, new THREE.BoxGeometry(alleyWidth + 0.2, 0.15, 0.12), darkTimber, alleyX, 3.7, 0.22);
placeMesh(pub, new THREE.BoxGeometry(0.14, 9, 0.12), darkTimber, alleyX - alleyWidth / 2, 8, 0.22);
placeMesh(pub, new THREE.BoxGeometry(0.14, 9, 0.12), darkTimber, alleyX + alleyWidth / 2, 8, 0.22);
// Extra horizontal beams on overhang
placeMesh(pub, new THREE.BoxGeometry(alleyWidth + 0.1, 0.1, 0.08), darkTimber, alleyX, 7.0, 0.2);
placeMesh(pub, new THREE.BoxGeometry(alleyWidth + 0.1, 0.1, 0.08), darkTimber, alleyX, 9.5, 0.2);

// Overhang windows (smaller, above the alley) — with sills
for (var owy = 5; owy <= 10; owy += 2.5) {
  var owGlass = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 0.8),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: 0.2 }));
  owGlass.position.set(alleyX, owy, 0.32);
  pub.add(owGlass);
  placeMesh(pub, new THREE.BoxGeometry(0.6, 0.9, 0.04), darkTimber, alleyX, owy, 0.28);
  // Glazing bars
  placeMesh(pub, new THREE.BoxGeometry(0.02, 0.8, 0.02), darkTimber, alleyX, owy, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.5, 0.02, 0.02), darkTimber, alleyX, owy, 0.34);
  // Sill
  placeMesh(pub, new THREE.BoxGeometry(0.7, 0.05, 0.1), sillMat, alleyX, owy - 0.45, 0.3);
}

// Overhead beam at alley entrance (lintel across the opening)
placeMesh(pub, new THREE.BoxGeometry(alleyWidth + 0.3, 0.2, 0.5), darkTimber, alleyX, 3.55, 0.1);

// Dim light deep in alley (mysterious) — brighter to see detail
var alleyLight = new THREE.PointLight(0x8888aa, 0.25, 10);
alleyLight.position.set(alleyX, 2.5, -3.5);
pub.add(alleyLight);

// Second faint light closer to entrance (cold)
var alleyLight2 = new THREE.PointLight(0x667799, 0.15, 6);
alleyLight2.position.set(alleyX, 2, -0.5);
pub.add(alleyLight2);

// Distant glow at the far end of the tunnel
var alleyEndGlow = new THREE.PointLight(0x99aacc, 1.2, 12);
alleyEndGlow.position.set(alleyX, 1.8, -2.0);
pub.add(alleyEndGlow);

// Second end-of-tunnel light (higher up, illuminates ceiling/walls)
var alleyEndGlow2 = new THREE.PointLight(0x8899bb, 0.6, 8);
alleyEndGlow2.position.set(alleyX, 2.5, -1.5);
pub.add(alleyEndGlow2);

// Glow sprite visible through the tunnel mouth
var alleyGlowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
  var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
  grad.addColorStop(0, 'rgba(180, 200, 240, 0.7)');
  grad.addColorStop(0.2, 'rgba(150, 170, 220, 0.4)');
  grad.addColorStop(0.45, 'rgba(110, 130, 180, 0.15)');
  grad.addColorStop(1, 'rgba(60, 70, 100, 0)');
  cx.fillStyle = grad;
  cx.fillRect(0, 0, w, h);
});
var alleyGlowSprite = new THREE.Sprite(new THREE.SpriteMaterial({
  map: alleyGlowTex, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false
}));
alleyGlowSprite.position.set(alleyX, 1.5, -0.5);
alleyGlowSprite.scale.set(1.8, 2.0, 1);
pub.add(alleyGlowSprite);

// Drainpipe running down the right edge of the alley opening
var pipeMat = new THREE.MeshStandardMaterial({ color: 0x2a2a28, roughness: 0.7 });
placeMesh(pub, new THREE.CylinderGeometry(0.04, 0.04, 3.5, 6), pipeMat, alleyX + alleyWidth/2 - 0.15, 1.75, 0.35);
// Pipe bracket
placeMesh(pub, new THREE.BoxGeometry(0.12, 0.06, 0.15), pipeMat, alleyX + alleyWidth/2 - 0.15, 2.5, 0.3);

// Cobblestone texture hint in alley (darker stripes)
for (var cobZ = 0; cobZ >= -4; cobZ -= 0.6) {
  var cobble = new THREE.Mesh(new THREE.PlaneGeometry(alleyWidth - 0.2, 0.08),
    new THREE.MeshStandardMaterial({ color: 0x0c0a08, roughness: 0.9 }));
  cobble.rotation.x = -Math.PI / 2;
  cobble.position.set(alleyX, 0.025, cobZ);
  pub.add(cobble);
}

// Faint silhouette figure in the alley
