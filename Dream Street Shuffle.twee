var pillarGeo = new THREE.BoxGeometry(0.08, 1.7, 0.08);
var pillarPositions = [
  [-0.42, 1.15, -0.42], [0.42, 1.15, -0.42],
  [-0.42, 1.15, 0.42], [0.42, 1.15, 0.42]
];
for (var pi = 0; pi < pillarPositions.length; pi++) {
  var pillar = new THREE.Mesh(pillarGeo, phoneRedMat);
  pillar.position.set(pillarPositions[pi][0], pillarPositions[pi][1], pillarPositions[pi][2]);
  pillar.castShadow = true;
  phoneBox.add(pillar);
}

// --- SOLID LOWER PANELS (below windows) ---
var lowerPanelH = 0.5;
// Front and back
var lowerFB = new THREE.BoxGeometry(0.76, lowerPanelH, 0.04);
placeMeshG(phoneBox, lowerFB, phoneRedMat, 0, 0.55, 0.44);
placeMeshG(phoneBox, lowerFB, phoneRedMat, 0, 0.55, -0.44);
// Sides
var lowerLR = new THREE.BoxGeometry(0.04, lowerPanelH, 0.76);
placeMeshG(phoneBox, lowerLR, phoneRedMat, -0.44, 0.55, 0);
placeMeshG(phoneBox, lowerLR, phoneRedMat, 0.44, 0.55, 0);

// --- WINDOW GLASS (18-pane pattern per side) ---
var phoneGlass = new THREE.MeshStandardMaterial({
  color: 0x0a0a15, roughness: 0.12, metalness: 0.25,
  emissive: 0xe87818, emissiveIntensity: 0.04
});
var phoneGlassBright = new THREE.MeshStandardMaterial({
  color: 0x0a0a15, roughness: 0.12, metalness: 0.25,
  emissive: 0xe87818, emissiveIntensity: 0.08
});

// Window area: 3 columns x 6 rows of small panes with mullions
// Each side gets a large glass panel + red mullion grid overlay
var glassH = 1.2;
var glassW = 0.72;
var mullionMat = phoneRedMat;

function addPhoneWindowSide(faceAxis, offset, rotY) {
  // Main glass panel
  var glass = new THREE.Mesh(new THREE.PlaneGeometry(glassW, glassH), phoneGlassBright);
  glass.position.set(
    faceAxis === 'x' ? offset : 0,
    1.4,
    faceAxis === 'z' ? offset : 0
  );
  glass.rotation.y = rotY;
  phoneBox.add(glass);

  // Horizontal mullions (5 bars creating 6 rows)
  for (var mh = 0; mh < 5; mh++) {
    var hBar = new THREE.Mesh(new THREE.BoxGeometry(
      faceAxis === 'z' ? 0.76 : 0.025,
      0.02,
      faceAxis === 'x' ? 0.76 : 0.025
    ), mullionMat);
    hBar.position.set(
      faceAxis === 'x' ? offset * 1.02 : 0,
      0.9 + mh * 0.24,
      faceAxis === 'z' ? offset * 1.02 : 0
    );
    phoneBox.add(hBar);
  }
  // Vertical mullions (2 bars creating 3 columns)
  for (var mv = 0; mv < 2; mv++) {
    var vOff = -0.12 + mv * 0.24;
    var vBar = new THREE.Mesh(new THREE.BoxGeometry(
      faceAxis === 'z' ? 0.02 : 0.025,
      glassH,
      faceAxis === 'x' ? 0.02 : 0.025
    ), mullionMat);
    vBar.position.set(
      faceAxis === 'x' ? offset * 1.02 : vOff,
      1.4,
      faceAxis === 'z' ? offset * 1.02 : vOff
    );
    phoneBox.add(vBar);
  }
}

addPhoneWindowSide('z', 0.455, 0);           // front
// Back is a solid panel (no glass on the rear of a real K6) — dark, unlit
var backPanelMat = new THREE.MeshStandardMaterial({ color: 0x3a0808, roughness: 0.8, metalness: 0.0 });
var backPanel = new THREE.Mesh(new THREE.BoxGeometry(0.76, 1.7, 0.06), backPanelMat);
backPanel.position.set(0, 1.15, -0.45);
phoneBox.add(backPanel);
addPhoneWindowSide('x', -0.455, Math.PI/2);   // left
addPhoneWindowSide('x', 0.455, -Math.PI/2);   // right

// --- ENTABLATURE (band above windows) ---
var entab = new THREE.Mesh(new THREE.BoxGeometry(0.98, 0.1, 0.98), phoneRedMat);
entab.position.set(0, 2.05, 0);
phoneBox.add(entab);

// --- TELEPHONE signs on entablature (all four sides) ---
