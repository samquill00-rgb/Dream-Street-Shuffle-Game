for (var bi = 0; bi < beamHeights.length; bi++) {
  var beam = new THREE.Mesh(new THREE.BoxGeometry(5.8, 0.18, 0.15), darkTimber);
  beam.position.set(1.25, beamHeights[bi], 0.22);
  pub.add(beam);
}

// ---- VERTICAL TIMBER POSTS ----
// 5 evenly-spaced structural posts (matching guide: edges + centre + quarters)
var postXs = [-1.3, 0.0, 1.25, 2.5, 3.8];
for (var pi = 0; pi < postXs.length; pi++) {
  // Lower section (1st + 2nd floor)
  var post1 = new THREE.Mesh(new THREE.BoxGeometry(0.15, 5.6, 0.15), darkTimber);
  post1.position.set(postXs[pi], 6.5, 0.22);
  pub.add(post1);
  // Upper section (3rd floor)
  var post2 = new THREE.Mesh(new THREE.BoxGeometry(0.15, 2.8, 0.15), darkTimber);
  post2.position.set(postXs[pi], 11, 0.22);
  pub.add(post2);
}

// ---- DECORATIVE X-BRACES (Tudor cross pattern) ----
// Placed only at the outer bays and one central — clean, orderly layout
function addXBrace(cx, cy, w, h) {
  var diagLen = Math.sqrt(w * w + h * h);
  var d1 = new THREE.Mesh(new THREE.BoxGeometry(0.08, diagLen, 0.1), darkTimber);
  d1.position.set(cx, cy, 0.22);
  d1.rotation.z = Math.atan2(w, h);
  pub.add(d1);
  var d2 = new THREE.Mesh(new THREE.BoxGeometry(0.08, diagLen, 0.1), darkTimber);
  d2.position.set(cx, cy, 0.22);
  d2.rotation.z = -Math.atan2(w, h);
  pub.add(d2);
}
// 2nd floor: X-braces in outer bays only
addXBrace(-0.65, 8.2, 0.8, 2.0);
addXBrace(3.15, 8.2, 0.8, 2.0);
// 3rd floor: X-braces in outer bays + one central
addXBrace(-0.65, 11, 0.8, 2.5);
addXBrace(3.15, 11, 0.8, 2.5);
addXBrace(1.25, 11, 1.0, 2.5);

// ---- DIAMOND PATTERN TIMBER (decorative panels between windows) ----
function addDiamond(cx, cy, size) {
  var d = new THREE.Mesh(new THREE.BoxGeometry(0.06, size * 1.4, 0.08), darkTimber);
  d.position.set(cx, cy, 0.24);
  d.rotation.z = Math.PI / 4;
  pub.add(d);
  var d2 = new THREE.Mesh(new THREE.BoxGeometry(0.06, size * 1.4, 0.08), darkTimber);
  d2.position.set(cx, cy, 0.24);
  d2.rotation.z = -Math.PI / 4;
  pub.add(d2);
}
// Diamonds only in the inner bays (between the X-braces) — 4 total
addDiamond(0.6, 8.2, 0.6);
addDiamond(1.9, 8.2, 0.6);
addDiamond(0.6, 11, 0.6);
addDiamond(1.9, 11, 0.6);

// ---- UPPER FLOOR WINDOWS (leaded glass style) ----
var sillMat = new THREE.MeshStandardMaterial({ color: 0xc8c0b0, roughness: 0.8 });

// 2nd floor windows — with sills, lintels, and glazing bars
for (var w2x = -0.2; w2x <= 2.8; w2x += 1.0) {
  var isLit = Math.random() < 0.6;
  // Glass glow
  var w2 = new THREE.Mesh(new THREE.PlaneGeometry(0.65, 1.2),
    new THREE.MeshBasicMaterial({ color: 0xffd699, transparent: true, opacity: isLit ? 0.45 : 0.2 }));
  w2.position.set(w2x, 10.8, 0.32);
  pub.add(w2);
  // Timber frame
  var w2f = new THREE.Mesh(new THREE.BoxGeometry(0.75, 1.3, 0.04), darkTimber);
  w2f.position.set(w2x, 10.8, 0.28);
  pub.add(w2f);
  // Glazing bars (leaded glass pattern — 2 vertical, 2 horizontal)
  placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x - 0.15, 10.8, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.02, 1.2, 0.02), darkTimber, w2x + 0.15, 10.8, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 10.5, 0.34);
  placeMesh(pub, new THREE.BoxGeometry(0.65, 0.02, 0.02), darkTimber, w2x, 11.1, 0.34);
  // Stone sill below
  placeMesh(pub, new THREE.BoxGeometry(0.85, 0.06, 0.12), sillMat, w2x, 10.15, 0.3);
  // Timber lintel above
  placeMesh(pub, new THREE.BoxGeometry(0.85, 0.08, 0.1), darkTimber, w2x, 11.45, 0.28);
}

