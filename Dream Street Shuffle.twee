  function carHorn() {
    _play(function(ac) {
      var now = ac.currentTime;
      var dur = 0.25 + Math.random() * 0.35;
      var f1 = 440 + (Math.random() - 0.5) * 30;
      var f2 = f1 * 1.26; // major third
