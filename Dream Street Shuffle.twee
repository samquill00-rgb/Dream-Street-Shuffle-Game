:: Lily SVG {"position":"400,50","size":"100,100"}
(set: _bells to 5 - $lilyCount)\
(set: _sobrClass to (cond: $sobriety < 20, ' lily-drowning', $sobriety < 40, ' lily-fading', $sobriety < 60, ' lily-dimming', ''))\
(set: _svgHTML to '<div class="lily-prompt' + _sobrClass + '"><svg class="lily-icon-svg lily-bells-' + (text: _bells) + '" viewBox="0 0 85 95" ><path d="M16 90 Q14 58, 20 38 Q28 16, 45 6 Q56 -2, 66 4 Q72 8, 70 16" fill="none" stroke="#7a9a6a" stroke-width="1.5" stroke-linecap="round"/><path d="M16 90 Q4 65, 10 45 Q14 56, 18 72 Z" fill="#5a7a4a" opacity="0.7"/><path d="M16 90 Q26 66, 24 48 Q20 56, 17 72 Z" fill="#6a8a5a" opacity="0.6"/><g class="lily-bell-1"><path d="M69 14 Q70 18, 68 22" fill="none" stroke="#7a9a6a" stroke-width="1" opacity="0.6"/><path d="M68 22 Q64 25, 63 30 Q66 32, 68 30 Q71 32, 73 30 Q72 25, 68 22 Z" fill="#e8ddd0" opacity="0.5"/></g><g class="lily-bell-2"><path d="M62 6 Q64 12, 62 16" fill="none" stroke="#7a9a6a" stroke-width="1" opacity="0.6"/><path d="M62 16 Q58 19, 57 24 Q60 26, 63 24 Q66 26, 68 24 Q67 19, 63 16 Z" fill="#e8ddd0" opacity="0.55"/><circle cx="62" cy="24" r="0.5" fill="#d4b8e0" opacity="0.3"/></g><g class="lily-bell-3"><path d="M52 6 Q54 14, 55 18" fill="none" stroke="#7a9a6a" stroke-width="1" opacity="0.6"/><path d="M55 18 Q50 22, 49 28 Q52 30, 56 28 Q60 30, 62 28 Q61 22, 57 18 Z" fill="#e8ddd0" opacity="0.65"/><circle cx="55" cy="28" r="0.5" fill="#d4b8e0" opacity="0.4"/></g><g class="lily-bell-4"><path d="M42 12 Q44 22, 46 28" fill="none" stroke="#7a9a6a" stroke-width="1" opacity="0.6"/><path d="M46 28 Q41 32, 40 38 Q43 40, 47 39 Q51 40, 53 38 Q52 32, 48 28 Z" fill="#e8ddd0" opacity="0.85"/><circle cx="46" cy="38" r="0.7" fill="#d4b8e0" opacity="0.5"/></g><g class="lily-bell-5"><path d="M34 22 Q36 32, 37 38" fill="none" stroke="#7a9a6a" stroke-width="1" opacity="0.6"/><path d="M37 38 Q32 42, 31 48 Q34 50, 38 49 Q42 50, 44 48 Q43 42, 39 38 Z" fill="#e8ddd0" opacity="0.75"/><circle cx="37" cy="48" r="0.6" fill="#d4b8e0" opacity="0.4"/></g></svg></div>')\
(print: _svgHTML)

