addDiamond(3.1, 6.0, 0.35);
addDiamond(1.25, 8.2, 0.4);
addDiamond(-0.4, 10.5, 0.35);
addDiamond(3.1, 10.5, 0.35);

// ---- UPPER FLOOR WINDOWS (leaded glass style) ----
