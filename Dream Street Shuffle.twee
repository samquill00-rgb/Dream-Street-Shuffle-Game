:: You speak to the poet {"position":"1400,450","size":"100,100"}
(set: $metRed to true)\
<!-- Ginger light -->
<div class="ginger-lamp-wrap">
<svg width="60" height="110" viewBox="0 0 60 110"><ellipse cx="30" cy="33" rx="40" ry="30" fill="rgba(200,100,5,0.10)"/><ellipse cx="30" cy="31" rx="24" ry="18" fill="rgba(220,130,10,0.18)"/><ellipse cx="30" cy="29" rx="13" ry="10" fill="rgba(255,190,60,0.22)"/><polygon points="27,2 30,0 33,2 32,7 28,7" fill="rgba(60,38,4,0.96)"/><path d="M13,7 Q30,4 47,7 L44,13 L16,13 Z" fill="rgba(60,38,4,0.96)"/><path d="M16,13 L44,13 L40,44 L20,44 Z" fill="rgba(130,75,8,0.45)" stroke="rgba(90,52,4,0.65)" stroke-width="1"/><path d="M19,15 L41,15 L37,42 L23,42 Z" fill="rgba(255,165,35,0.42)"/><ellipse cx="30" cy="29" rx="7" ry="10" fill="rgba(255,232,130,0.55)"/><ellipse cx="30" cy="27" rx="3" ry="4" fill="rgba(255,250,210,0.68)"/><rect x="22" y="44" width="16" height="6" rx="2.5" fill="rgba(60,38,4,0.96)"/><rect x="27" y="50" width="6" height="60" rx="2" fill="rgba(45,28,3,0.90)"/></svg>
</div>
<div class="ginger-scene">
<div class="ginger-light"></div>
'Red!' you say. He looks up at first, then towards you without looking at you.

'I need to sell a book.'

'Sell yourself,' he says. 'Things turn up.'

You understand.

As you turn, you strike, in the cool and marbling air, a vein of his perfume, which you recognise, because you once loved a woman who wore that scent, as lily-of-the-valley.

<div class="lily-window">
<span class="lily-thought">And with it, her risen face:</span>
<div class="quest-box"><em>That is not natural in an age like this,<br>
Being high and solitary and most stern</em></div>
<span class="lily-thought">A little earthquake in the heart upsets the world and you are twenty-one again, walking with her on your arm through the rain on St. Giles, past the funfair, before so very much went so far wrong.</span>(set: $confidence to $confidence - 12)
</div>

[[Walk on|LINE 1]]
</div>

:: header header [header] {"position":"700,50","size":"100,100"}
(set: _hideStats to (a: "White page", "Black page", "Title", "Start", "The Night Ahead", "Name Your Book", "A Doorway on Dean Street", "Dawn", "PP Pong", "Fight starts", "Fight Round 1", "Fight Round 2", "Fight Round 3", "Fight R1 Back", "Fight R1 Block", "Fight R1 Duck", "Fight R2 Catch", "Fight R2 Counter", "Fight R2 Slip", "Fight R3 Clinch", "Fight R3 Headon", "Fight R3 Weave", "Fight Victory", "Fight Defeat"))
(unless: _hideStats contains (passage:)'s name)[\
(if: $confidence is a number and $confidence < 0)[(set: $confidence to 0)](if: $confidence is a number and $confidence > 100)[(set: $confidence to 100)](if: $sobriety is a number and $sobriety < 0)[(set: $sobriety to 0)](if: $sobriety is a number and $sobriety > 100)[(set: $sobriety to 100)]\
(if: $haunts is an array)[\
(if: $haunts's length >= 8)[(enchant: ?page, (css: "background: linear-gradient(180deg, #1a1e28 0%, #252a3a 50%, #1a1e28 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 6)[(enchant: ?page, (css: "background: linear-gradient(180deg, #171a20 0%, #212430 50%, #171a20 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 4)[(enchant: ?page, (css: "background: linear-gradient(180deg, #141418 0%, #1e1e28 50%, #141418 100%); background-attachment: fixed"))]\
(else-if: $haunts's length >= 2)[(enchant: ?page, (css: "background: linear-gradient(180deg, #171516 0%, #252224 50%, #171516 100%); background-attachment: fixed"))]
]\
<div class="stat-bars">
<svg class="header-lily" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 210 68" preserveAspectRatio="xMinYMid slice" aria-hidden="true"><defs><linearGradient id="hlFade" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="white"/><stop offset="50%" stop-color="white"/><stop offset="80%" stop-color="white" stop-opacity="0.3"/><stop offset="100%" stop-color="black"/></linearGradient><mask id="hlMask"><rect x="0" y="0" width="210" height="68" fill="url(#hlFade)"/></mask></defs><g mask="url(#hlMask)"><!-- Main stem --><path d="M40,-4 Q45,8 52,20 Q60,34 72,42 Q88,52 110,56 Q135,60 165,58 Q185,54 210,48" fill="none" stroke="#0a0a0a" stroke-width="3.5" stroke-linecap="round"/><path d="M72,42 Q68,50 62,58 Q58,64 54,72" fill="none" stroke="#0a0a0a" stroke-width="2.8" stroke-linecap="round"/><!-- Left leaf --><path d="M38,-2 Q28,6 18,18 Q10,30 8,40 Q6,50 14,56 Q24,60 36,54 Q46,46 50,34 Q52,24 48,14 Q44,6 38,-2 Z" fill="#2a5c22" fill-opacity="0.22" stroke="#0a0a0a" stroke-width="3.2" stroke-linejoin="round"/><!-- Left leaf veins --><path d="M38,-2 Q30,14 22,30 Q16,42 14,56" fill="none" stroke="#0a0a0a" stroke-width="2" opacity="0.6"/><path d="M30,10 Q24,14 18,20" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.35"/><path d="M26,22 Q20,28 14,34" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.3"/><path d="M22,34 Q18,40 14,46" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.25"/><!-- Right leaf --><path d="M44,0 Q56,8 66,20 Q74,32 76,42 Q78,52 72,58 Q62,64 50,60 Q42,54 40,44 Q38,34 40,22 Q42,12 44,0 Z" fill="#1e4a18" fill-opacity="0.18" stroke="#0a0a0a" stroke-width="3.2" stroke-linejoin="round"/><!-- Right leaf veins --><path d="M44,0 Q56,16 66,32 Q72,44 72,58" fill="none" stroke="#0a0a0a" stroke-width="2" opacity="0.55"/><path d="M50,10 Q58,16 64,22" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.3"/><path d="M54,22 Q62,28 68,34" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.28"/><path d="M58,34 Q66,40 72,46" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.22"/><!-- Flower 1 --><path d="M80,38 Q76,42 72,50 Q70,56 74,60 Q78,64 84,62 Q90,58 88,50 Q86,42 80,38 Z" fill="#d4cdb8" fill-opacity="0.35" stroke="#0a0a0a" stroke-width="2.8" stroke-linejoin="round"/><path d="M76,50 L80,60" fill="none" stroke="#0a0a0a" stroke-width="1.2" opacity="0.4"/><path d="M84,48 L82,60" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.35"/><path d="M80,38 Q82,34 86,30 Q90,26 92,22" fill="none" stroke="#0a0a0a" stroke-width="2.2" stroke-linecap="round"/><!-- Flower 2 --><path d="M102,34 Q98,38 96,44 Q94,50 98,54 Q102,56 106,52 Q110,48 108,42 Q106,36 102,34 Z" fill="#c8c0a8" fill-opacity="0.3" stroke="#0a0a0a" stroke-width="2.6" stroke-linejoin="round"/><path d="M100,44 L100,54" fill="none" stroke="#0a0a0a" stroke-width="1" opacity="0.35"/><path d="M102,34 Q104,30 108,26" fill="none" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round"/><!-- Flower 3 --><path d="M126,30 Q122,34 120,40 Q118,46 122,48 Q126,50 130,46 Q132,40 130,34 Q128,30 126,30 Z" fill="#d0c8b0" fill-opacity="0.25" stroke="#0a0a0a" stroke-width="2.4" stroke-linejoin="round"/><path d="M126,30 Q128,26 132,22" fill="none" stroke="#0a0a0a" stroke-width="1.8" stroke-linecap="round"/><!-- Flower 4 --><path d="M152,26 Q148,30 148,36 Q150,40 154,38 Q158,34 156,28 Q154,26 152,26 Z" fill="#c4bca4" fill-opacity="0.2" stroke="#0a0a0a" stroke-width="2.2" stroke-linejoin="round"/><path d="M152,26 Q154,22 158,18" fill="none" stroke="#0a0a0a" stroke-width="1.6" stroke-linecap="round"/><!-- Flower 5 --><path d="M170,22 Q168,26 168,30 Q170,34 174,30 Q176,26 172,22 Z" fill="#beb6a0" fill-opacity="0.18" stroke="#0a0a0a" stroke-width="2" stroke-linejoin="round"/><path d="M170,22 Q172,18 176,14" fill="none" stroke="#0a0a0a" stroke-width="1.4" stroke-linecap="round"/><!-- Small leaf --><path d="M110,56 Q118,52 124,56 Q128,62 122,66 Q114,68 110,62 Q108,58 110,56 Z" fill="#2a5c22" fill-opacity="0.12" stroke="#0a0a0a" stroke-width="2" stroke-linejoin="round" opacity="0.6"/><!-- Background lead --><path d="M0,20 Q10,18 20,22 Q30,26 36,30" fill="none" stroke="#0a0a0a" stroke-width="1.5" opacity="0.18"/><path d="M0,50 Q8,46 16,48 Q24,52 30,50" fill="none" stroke="#0a0a0a" stroke-width="1.3" opacity="0.14"/><path d="M160,58 Q172,54 186,56 Q200,60 210,56" fill="none" stroke="#0a0a0a" stroke-width="1.4" opacity="0.1"/></g></svg>
<div class="stat-group">
(set: _confClass to "")(set: _confGhost to "")(set: _confPct to "")(if: $prevConfidence is a number)[(if: $confidence > $prevConfidence)[(set: _confClass to " bar-flash-up")(set: _confGhost to "<span class='bar-ghost bar-ghost-gain' style='width:" + (text: $prevConfidence) + "%'></span>")(set: _confPct to " pct-gain")](else-if: $confidence < $prevConfidence)[(set: _confClass to " bar-flash-down")(set: _confGhost to "<span class='bar-ghost bar-ghost-loss' style='width:" + (text: $prevConfidence) + "%'></span>")(set: _confPct to " pct-loss")]]
(set: _sobClass to "")(set: _sobGhost to "")(set: _sobPct to "")(if: $prevSobriety is a number)[(if: $sobriety > $prevSobriety)[(set: _sobClass to " bar-flash-up")(set: _sobGhost to "<span class='bar-ghost bar-ghost-gain' style='width:" + (text: $prevSobriety) + "%'></span>")(set: _sobPct to " pct-gain")](else-if: $sobriety < $prevSobriety)[(set: _sobClass to " bar-flash-down")(set: _sobGhost to "<span class='bar-ghost bar-ghost-loss' style='width:" + (text: $prevSobriety) + "%'></span>")(set: _sobPct to " pct-loss")]]
<div class="stat-row">
<span class="stat-label">MORALE</span>
<span class="stat-bar">(print: _confGhost)(if: $confidence >= 50)[(print: "<span class='bar-fill bar-good" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")](else-if: $confidence >= 25)[(print: "<span class='bar-fill bar-warning" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")](else:)[(print: "<span class='bar-fill bar-danger" + _confClass + "' style='width:" + (text: $confidence) + "%'></span>")]</span>
(print: "<span class='stat-pct" + _confPct + "'>" + (text: $confidence) + "%</span>")
</div>
<div class="stat-row">
<span class="stat-label">SOBRIETY</span>
<span class="stat-bar">(print: _sobGhost)(if: $sobriety >= 50)[(print: "<span class='bar-fill bar-good" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")](else-if: $sobriety >= 25)[(print: "<span class='bar-fill bar-warning" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")](else:)[(print: "<span class='bar-fill bar-danger" + _sobClass + "' style='width:" + (text: $sobriety) + "%'></span>")]</span>
(print: "<span class='stat-pct" + _sobPct + "'>" + (text: $sobriety) + "%</span>")
</div>
</div>
<div class="header-links"><div class="notebook-link">(link-repeat: "NOTEBOOK")[(display: "Build Notebook")]</div>
</div>
</div>
(set: $prevConfidence to $confidence)(set: $prevSobriety to $sobriety)
(if: $afterMidnight is true)[<span id="dst-after-midnight" style="display:none"></span>]
]

:: Build Notebook {"position":"500,50","size":"100,100"}
{
(set: _fHere to (passage:)'s tags contains "venue-french")(set: _fVisited to false)\
(if: $visited contains "French")[(if: $visited's French is true)[(set: _fVisited to true)]]\
(set: _pHere to (passage:)'s name contains "Pillars")(set: _pVisited to false)\
(if: $visited contains "Pillars")[(if: $visited's Pillars is true)[(set: _pVisited to true)]]\
(set: _cHere to (passage:)'s tags contains "venue-colony")(set: _cVisited to false)\
(if: $visited contains "Colony")[(if: $visited's Colony is true)[(set: _cVisited to true)]]\
(set: _rHere to (passage:)'s tags contains "venue-ronnies")(set: _rVisited to false)\
(if: $visited contains "Ronnies")[(if: $visited's Ronnies is true)[(set: _rVisited to true)]]\
(set: _tHere to (passage:)'s tags contains "venue-trishas")(set: _tVisited to false)\
(if: $visited contains "Trishas")[(if: $visited's Trishas is true)[(set: _tVisited to true)]]\
(set: _lHere to (passage:)'s name contains "Lackland")(set: _lVisited to $knowsLackland is true)\
(set: _eHere to (passage:)'s name contains "Cecil Court")(set: _eVisited to $knowsCecilCourt is true)\
(set: _hHere to (passage:)'s tags contains "venue-coach")(set: _hVisited to false)\
(if: $cowDone is true)[(set: _hVisited to true)]\
(set: _gHere to (passage:)'s name contains "Corner of Dean")(set: _gVisited to true)\
(set: _m to "<div class='soho-map'><svg viewBox='0 0 560 700' preserveAspectRatio='xMidYMid meet'>")(set: _m to _m + "<defs><filter id='vg' x='-50%' y='-50%' width='200%' height='200%'><feGaussianBlur stdDeviation='4' result='b'/><feMerge><feMergeNode in='b'/><feMergeNode in='b'/><feMergeNode in='SourceGraphic'/></feMerge></filter><radialGradient id='lp'><stop offset='0%' stop-color='rgba(212,165,116,0.35)'/><stop offset='100%' stop-color='rgba(212,165,116,0)'/></radialGradient><linearGradient id='fg' x1='0' y1='0' x2='0' y2='1'><stop offset='0%' stop-color='rgba(30,28,25,0.4)'/><stop offset='30%' stop-color='rgba(10,9,8,0)'/><stop offset='75%' stop-color='rgba(10,9,8,0)'/><stop offset='100%' stop-color='rgba(30,28,25,0.5)'/></linearGradient><linearGradient id='fg2' x1='0' y1='0' x2='1' y2='0'><stop offset='0%' stop-color='rgba(30,28,25,0.35)'/><stop offset='20%' stop-color='rgba(10,9,8,0)'/><stop offset='80%' stop-color='rgba(10,9,8,0)'/><stop offset='100%' stop-color='rgba(30,28,25,0.35)'/></linearGradient><pattern id='bw' width='6' height='6' patternUnits='userSpaceOnUse'><rect width='2' height='2' x='1' y='1' fill='rgba(180,155,110,0.06)'/><rect width='2' height='2' x='4' y='4' fill='rgba(180,155,110,0.04)'/></pattern></defs>")(set: _m to _m + "<rect width='560' height='700' fill='#110e0a'/><rect width='560' height='700' fill='url(#bw)'/>")(set: _m to _m + "<text x='280' y='28' text-anchor='middle' fill='rgba(212,165,116,0.85)' font-family='Playfair Display,Georgia,serif' font-size='16' letter-spacing='8'>SOHO &#183; 1973</text>")(set: _m to _m + "<text x='490' y='40' text-anchor='middle' fill='rgba(212,165,116,0.40)' font-family='Playfair Display,Georgia,serif' font-size='8' letter-spacing='1'>&#9650; CENTRE POINT</text>")(set: _m to _m + "<rect x='300' y='58' width='160' height='62' rx='3' fill='rgba(35,55,30,0.45)' stroke='rgba(60,80,50,0.4)' stroke-width='0.5'/><circle cx='340' cy='80' r='6' fill='rgba(40,65,30,0.55)'/><circle cx='370' cy='85' r='5' fill='rg