strip1.position.set(0.19, 5.6, 0.19);
heroLamp.add(strip1);
var strip2 = new THREE.Mesh(stripGeo, ironMat);
strip2.position.set(-0.19, 5.6, 0.19);
heroLamp.add(strip2);
var strip3 = new THREE.Mesh(stripGeo, ironMat);
strip3.position.set(0.19, 5.6, -0.19);
heroLamp.add(strip3);
var strip4 = new THREE.Mesh(stripGeo, ironMat);
strip4.position.set(-0.19, 5.6, -0.19);
