// STREETLAMPS
// ============================================================
var streetLampLights = [];

function createLamp(x, z) {
  var g = new THREE.Group();
  var iron = new THREE.MeshLambertMaterial({ color: 0x2a2a28 });

  // Ornate stepped base
  var base1 = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.38, 0.2, 8), iron);
  base1.position.set(0, 0.1, 0); g.add(base1);
  var base2 = new THREE.Mesh(new THREE.CylinderGeometry(0.22, 0.28, 0.15, 8), iron);
  base2.position.set(0, 0.275, 0); g.add(base2);
  var base3 = new THREE.Mesh(new THREE.CylinderGeometry(0.15, 0.22, 0.1, 8), iron);
  base3.position.set(0, 0.4, 0); g.add(base3);

  // Fluted post (tapers upward)
  var post = new THREE.Mesh(new THREE.CylinderGeometry(0.055, 0.09, 3.6, 8), iron);
  post.position.set(0, 2.25, 0); g.add(post);

  // Decorative collar
  var collar = new THREE.Mesh(new THREE.CylinderGeometry(0.12, 0.08, 0.15, 8), iron);
  collar.position.set(0, 4.1, 0); g.add(collar);

  // Lamp housing — bottom, glass, top cone, finial
  var housingBot = new THREE.Mesh(new THREE.CylinderGeometry(0.22, 0.15, 0.12, 6), iron);
  housingBot.position.set(0, 4.25, 0); g.add(housingBot);
  var housingMid = new THREE.Mesh(new THREE.CylinderGeometry(0.2, 0.22, 0.35, 6),
    new THREE.MeshLambertMaterial({ color: 0x3a3a38 }));
  housingMid.position.set(0, 4.5, 0); g.add(housingMid);
  var housingTop = new THREE.Mesh(new THREE.ConeGeometry(0.2, 0.2, 6), iron);
  housingTop.position.set(0, 4.8, 0); g.add(housingTop);
  var finial = new THREE.Mesh(new THREE.SphereGeometry(0.04, 6, 6), iron);
  finial.position.set(0, 4.95, 0); g.add(finial);

  // Glass globe
  var globe = new THREE.Mesh(new THREE.SphereGeometry(0.14, 10, 10),
    new THREE.MeshBasicMaterial({ color: 0xffe8aa, transparent: true, opacity: 0.85 }));
  globe.position.set(0, 4.5, 0); g.add(globe);

  // Light
  var light = new THREE.PointLight(0xffd080, 1.2, 12);
  light.position.set(0, 4.5, 0);
  light.castShadow = true;
  light.userData.baseIntensity = 1.2;
  g.add(light);
  streetLampLights.push(light);

  // Glow sprite
  var glowTex = makeCanvasTexture(64, 64, function(cx, w, h) {
    var grad = cx.createRadialGradient(w/2, h/2, 0, w/2, h/2, w/2);
    grad.addColorStop(0, 'rgba(255, 214, 153, 0.45)');
    grad.addColorStop(0.4, 'rgba(255, 200, 130, 0.12)');
    grad.addColorStop(1, 'rgba(255, 180, 100, 0)');
    cx.fillStyle = grad;
    cx.fillRect(0, 0, w, h);
  });
  var glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: glowTex, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false
  }));
  glowSprite.position.set(0, 4.5, 0);
  glowSprite.scale.set(5, 5, 1);
  g.add(glowSprite);

  // Light pool on ground
  var pool = new THREE.Mesh(new THREE.PlaneGeometry(5, 5),
    new THREE.MeshBasicMaterial({ color: 0xffd080, transparent: true, opacity: 0.04 }));
  pool.rotation.x = -Math.PI / 2; pool.position.set(0, 0.03, 0); g.add(pool);

  g.position.set(x, 0, z);
  scene.add(g);
}

createLamp(-4, 3.5);
createLamp(5, 3.5);
createLamp(0, 10);

// ============================================================
// SILHOUETTES OF PEOPLE IN PUB WINDOWS
// ============================================================
var silhouettes = [];

function makeSilhouetteTex(seed) {
  return makeCanvasTexture(256, 256, function(cx, w, h) {
    // Warm amber interior glow background
    var bg = cx.createRadialGradient(w/2, h * 0.4, 10, w/2, h * 0.5, w);
    bg.addColorStop(0, 'rgba(200, 140, 50, 0.5)');
    bg.addColorStop(0.5, 'rgba(160, 100, 30, 0.3)');
    bg.addColorStop(1, 'rgba(80, 50, 15, 0.15)');
    cx.fillStyle = bg;
    cx.fillRect(0, 0, w, h);

    var figureCount = 1 + Math.floor(seed * 2.5);
    for (var f = 0; f < figureCount; f++) {
      var fx = (w / (figureCount + 1)) * (f + 1);
      var baseY = h * 0.98;
      var headR = 14 + seed * 6;
      var shoulderW = 35 + seed * 15;

      cx.fillStyle = 'rgba(10, 5, 0, 0.85)';

      // Body
      cx.beginPath();
      cx.moveTo(fx - shoulderW / 2, baseY - h * 0.35);
      cx.lineTo(fx + shoulderW / 2, baseY - h * 0.35);
      cx.lineTo(fx + shoulderW / 2 + 8, baseY);
      cx.lineTo(fx - shoulderW / 2 - 8, baseY);
      cx.closePath();
      cx.fill();

      // Shoulders
      cx.beginPath();
      cx.ellipse(fx, baseY - h * 0.38, shoulderW / 2 + 5, 14, 0, 0, Math.PI, true);
      cx.fill();

      // Neck
      cx.fillRect(fx - 6, baseY - h * 0.48, 12, h * 0.1);

      // Head
      cx.beginPath();
      cx.arc(fx + (f - 1) * 4, baseY - h * 0.52, headR, 0, Math.PI * 2);
      cx.fill();

      // Raised arm with pint
      if ((seed > 0.4 && f === 0) || (seed > 0.6 && f === 1)) {
        cx.fillStyle = 'rgba(10, 5, 0, 0.8)';
        cx.beginPath();
        cx.moveTo(fx + shoulderW / 2, baseY - h * 0.38);
        cx.lineTo(fx + shoulderW / 2 + 12, baseY - h * 0.6);
        cx.lineTo(fx + shoulderW / 2 + 22, baseY - h * 0.6);
        cx.lineTo(fx + shoulderW / 2 + 10, baseY - h * 0.35);
        cx.closePath();
        cx.fill();
        cx.fillRect(fx + shoulderW / 2 + 8, baseY - h * 0.7, 16, 22);
        cx.fillStyle = 'rgba(180, 130, 40, 0.4)';
        cx.fillRect(fx + shoulderW / 2 + 10, baseY - h * 0.68, 12, 14);
      }
    }
  });
}

// Ground floor pub window silhouettes (facing +Z) — one per window bay
var winPositions = [-0.3, 1.8, 3.1];
var winSeeds = [0.3, 0.7, 0.5];
for (var i = 0; i < winPositions.length; i++) {
  var sTex = makeSilhouetteTex(winSeeds[i]);
  var sMat = new THREE.MeshBasicMaterial({
    map: sTex, transparent: true, side: THREE.DoubleSide, depthWrite: false
  });
  var sPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.9, 1.8), sMat);
  sPlane.position.set(winPositions[i], 1.7, 0.6);
  pub.add(sPlane);
  silhouettes.push({
    mesh: sPlane,
    baseX: winPositions[i],
    swayPhase: Math.random() * Math.PI * 2,
    swaySpeed: 0.3 + Math.random() * 0.4,
    swayAmt: 0.015 + Math.random() * 0.02
  });
}

