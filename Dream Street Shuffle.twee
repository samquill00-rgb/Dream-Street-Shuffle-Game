:: Dawn Rule SVG top {"position":"3000,2700","size":"100,100"}
<!-- Sol — Ripley's-Wheel style sun rising at dawn. 12 rays at 30° intervals:
     9 long tapered wedges + 3 short rays at 12/4/8 o'clock (equilateral
     triangle = alchemical fire sigil, hidden in Sol). Concentric rings +
     central dot. Warm dawn palette rather than the wheel's gold. -->
<svg class="dawn-rule" viewBox="0 0 400 110" width="100%" height="110" preserveAspectRatio="xMidYMid meet"><defs><linearGradient id="dwRuleG" x1="0" x2="1"><stop offset="0%" stop-color="#b89a82" stop-opacity="0"/><stop offset="15%" stop-color="#caa890" stop-opacity="0.65"/><stop offset="50%" stop-color="#e4c4a4" stop-opacity="0.95"/><stop offset="85%" stop-color="#caa890" stop-opacity="0.65"/><stop offset="100%" stop-color="#b89a82" stop-opacity="0"/></linearGradient><radialGradient id="dwSunHalo" cx="50%" cy="50%" r="55%"><stop offset="0%" stop-color="#f4d4b0" stop-opacity="0.55"/><stop offset="55%" stop-color="#d4a890" stop-opacity="0.22"/><stop offset="100%" stop-color="#a08078" stop-opacity="0"/></radialGradient></defs><!-- Soft halo glow behind the sun --><ellipse cx="200" cy="50" rx="72" ry="44" fill="url(#dwSunHalo)"/><!-- Horizon --><line x1="20" y1="88" x2="380" y2="88" stroke="url(#dwRuleG)" stroke-width="0.6"/><line x1="20" y1="90.4" x2="380" y2="90.4" stroke="url(#dwRuleG)" stroke-width="1.4"/><line x1="20" y1="93.2" x2="380" y2="93.2" stroke="url(#dwRuleG)" stroke-width="0.3" opacity="0.55"/><!-- SOL: 12 rays, 9 long tapered wedges + 3 short rays at 12/4/8 o'clock --><g class="dawn-sol"><!-- Long rays (tapered triangles) --><path d="M 210.732 35.412 L 217 20.556 L 207.268 33.412 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 216.588 42.732 L 229.444 33 L 214.588 39.268 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 218 52 L 234 50 L 218 48 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 207.268 66.588 L 217 79.444 L 210.732 64.588 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 198 68 L 200 84 L 202 68 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 189.268 64.588 L 183 79.444 L 192.732 66.588 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 182 48 L 166 50 L 182 52 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 185.412 39.268 L 170.556 33 L 183.412 42.732 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><path d="M 192.732 33.412 L 183 20.556 L 189.268 35.412 Z" fill="#ecceae" fill-opacity="0.78" stroke="#ecceae" stroke-width="0.5" opacity="0.92" stroke-linejoin="round"/><!-- Short rays at 12 / 4 / 8 o'clock --><line x1="200" y1="32" x2="200" y2="26" stroke="#ecceae" stroke-width="1.0" opacity="0.85" stroke-linecap="round"/><line x1="215.588" y1="59" x2="220.784" y2="62" stroke="#ecceae" stroke-width="1.0" opacity="0.85" stroke-linecap="round"/><line x1="184.412" y1="59" x2="179.216" y2="62" stroke="#ecceae" stroke-width="1.0" opacity="0.85" stroke-linecap="round"/><!-- Concentric inner rings + central dot --><circle cx="200" cy="50" r="14" fill="none" stroke="#ecceae" stroke-width="1.1" opacity="0.85"/><circle cx="200" cy="50" r="11" fill="none" stroke="#ecceae" stroke-width="0.4" opacity="0.45"/><circle cx="200" cy="50" r="2.4" fill="#f4d4b0" opacity="0.95"/></g><!-- Lily-of-the-valley flourishes on the horizon --><g transform="translate(72,88)" opacity="0.85"><path d="M0,0 Q-4,-12 -8,-26 Q-12,-18 -18,-22" fill="none" stroke="#caa890" stroke-width="0.75"/><ellipse cx="-8" cy="-26" rx="3" ry="4" fill="rgba(228,204,176,0.42)" stroke="#caa890" stroke-width="0.6"/><ellipse cx="-18" cy="-22" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.38)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="-3" cy="-13" rx="1.8" ry="2.6" fill="rgba(228,204,176,0.35)" stroke="#caa890" stroke-width="0.5"/></g><g transform="translate(328,88)" opacity="0.85"><path d="M0,0 Q4,-12 8,-26 Q12,-18 18,-22" fill="none" stroke="#caa890" stroke-width="0.75"/><ellipse cx="8" cy="-26" rx="3" ry="4" fill="rgba(228,204,176,0.42)" stroke="#caa890" stroke-width="0.6"/><ellipse cx="18" cy="-22" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.38)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="3" cy="-13" rx="1.8" ry="2.6" fill="rgba(228,204,176,0.35)" stroke="#caa890" stroke-width="0.5"/></g><polygon points="120,84 123,88 120,92 117,88" fill="#e4c4a4" opacity="0.5"/><polygon points="280,84 283,88 280,92 277,88" fill="#e4c4a4" opacity="0.5"/></svg>

:: Dawn Rule SVG eclipse {"position":"3000,2750","size":"100,100"}
<!-- Total eclipse — for the Alba Incomplete ending. The sun-occulted-by-moon
     reads the sol-luna conjunctio at its dark moment; the diamond-ring bead
     is the marriage ring the night didn't quite finish making. Stars come out;
     lilies stay warm — the world is itself. -->
<svg class="dawn-rule" viewBox="0 0 400 110" width="100%" height="110" preserveAspectRatio="xMidYMid meet"><defs><radialGradient id="eclipseCore" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#0a0510" stop-opacity="1"/><stop offset="100%" stop-color="#080308" stop-opacity="1"/></radialGradient><radialGradient id="eclipseCorona" cx="50%" cy="50%" r="55%"><stop offset="55%" stop-color="#e4c4a4" stop-opacity="0"/><stop offset="70%" stop-color="#e4c4a4" stop-opacity="0.65"/><stop offset="78%" stop-color="#caa890" stop-opacity="0.42"/><stop offset="100%" stop-color="#a08078" stop-opacity="0"/></radialGradient><radialGradient id="eclipseHalo" cx="50%" cy="50%" r="70%"><stop offset="40%" stop-color="#e4c4a4" stop-opacity="0"/><stop offset="55%" stop-color="#caa890" stop-opacity="0.20"/><stop offset="100%" stop-color="#805868" stop-opacity="0"/></radialGradient><linearGradient id="ecHorizon" x1="0" x2="1"><stop offset="0%" stop-color="#b89a82" stop-opacity="0"/><stop offset="15%" stop-color="#caa890" stop-opacity="0.55"/><stop offset="50%" stop-color="#e4c4a4" stop-opacity="0.85"/><stop offset="85%" stop-color="#caa890" stop-opacity="0.55"/><stop offset="100%" stop-color="#b89a82" stop-opacity="0"/></linearGradient></defs><g fill="#e4c4a4" opacity="0.55"><circle cx="80" cy="22" r="0.8"/><circle cx="120" cy="38" r="0.55"/><circle cx="155" cy="18" r="0.5"/><circle cx="60" cy="50" r="0.4"/><circle cx="42" cy="32" r="0.6"/><circle cx="250" cy="25" r="0.7"/><circle cx="290" cy="42" r="0.5"/><circle cx="325" cy="20" r="0.8"/><circle cx="358" cy="32" r="0.5"/><circle cx="340" cy="55" r="0.6"/></g><ellipse cx="200" cy="50" rx="68" ry="44" fill="url(#eclipseHalo)"/><circle cx="200" cy="50" r="26" fill="url(#eclipseCorona)"/><circle cx="200" cy="50" r="20" fill="url(#eclipseCore)" stroke="#3a2820" stroke-width="0.5"/><circle cx="221" cy="47" r="2.4" fill="#fff5d0" opacity="0.95"/><circle cx="221" cy="47" r="4.5" fill="#f4d4b0" opacity="0.42"/><line x1="20" y1="88" x2="380" y2="88" stroke="url(#ecHorizon)" stroke-width="0.6"/><line x1="20" y1="90.4" x2="380" y2="90.4" stroke="url(#ecHorizon)" stroke-width="1.4"/><line x1="20" y1="93.2" x2="380" y2="93.2" stroke="url(#ecHorizon)" stroke-width="0.3" opacity="0.55"/><g transform="translate(72,88)" opacity="0.85"><path d="M0,0 Q-4,-12 -8,-26 Q-12,-18 -18,-22" fill="none" stroke="#caa890" stroke-width="0.75"/><ellipse cx="-8" cy="-26" rx="3" ry="4" fill="rgba(228,204,176,0.42)" stroke="#caa890" stroke-width="0.6"/><ellipse cx="-18" cy="-22" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.38)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="-3" cy="-13" rx="1.8" ry="2.6" fill="rgba(228,204,176,0.35)" stroke="#caa890" stroke-width="0.5"/></g><g transform="translate(328,88)" opacity="0.85"><path d="M0,0 Q4,-12 8,-26 Q12,-18 18,-22" fill="none" stroke="#caa890" stroke-width="0.75"/><ellipse cx="8" cy="-26" rx="3" ry="4" fill="rgba(228,204,176,0.42)" stroke="#caa890" stroke-width="0.6"/><ellipse cx="18" cy="-22" rx="2.4" ry="3.4" fill="rgba(228,204,176,0.38)" stroke="#caa890" stroke-width="0.55"/><ellipse cx="3" cy="-13" rx="1.8" ry="2.6" fill="rgba(228,204,176,0.35)" stroke="#caa890" stroke-width="0.5"/></g><polygon points="120,84 123,88 120,92 117,88" fill="#e4c4a4" opacity="0.5"/><polygon points="280,84 283,88 280,92 277,88" fill="#e4c4a4" opacity="0.5"/></svg>

:: Dawn Rule SVG bottom {"position":"3000,2800","size":"100,100"}
<svg class="dawn-rule" viewBox="0 0 400 70" width="100%" height="70" preserveAspectRatio="xMidYMid meet"><defs><linearGradient id="dwRuleBG" x1="0" x2="1"><stop offset="0%" stop-color="#b89a82" stop-opacity="0"/><stop offset="22%" stop-color="#caa890" stop-opacity="0.55"/><stop offset="50%" stop-color="#e4c4a4" stop-opacity="0.85"/><stop offset="78%" stop-color="#caa890" stop-opacity="0.55"/><stop offset="100%" stop-color="#b89a82" stop-opacity="0"/></linearGradient></defs><!-- Twin horizontal rules --><line x1="20" y1="20" x2="380" y2="20" stroke="url(#dwRuleBG)" stroke-width="0.55"/><line x1="20" y1="22.4" x2="380" y2="22.4" stroke="url(#dwRuleBG)" stroke-width="1.2"/><!-- Long whiplash curves trailing left and right from the centre --><g fill="none" stroke="#caa890" stroke-width="0.7" opacity="0.6"><path d="M 200,22 Q 170,8 130,18 Q 90,32 60,18"/><path d="M 200,22 Q 230,8 270,18 Q 310,32 340,18"/></g><!-- Inner echo curves --><g fill="none" stroke="#caa890" stroke-width="0.35" opacity="0.35"><path d="M 200,22 Q 170,14 138,22"/><path d="M 200,22 Q 230,14 262,22"/></g><!-- Tendril spirals at the curve ends --><g fill="none" stroke="#caa890" stroke-width="0.5" opacity="0.5"><path d="M 60,18 Q 50,22 52,30 Q 60,30 58,24"/><path d="M 340,18 Q 350,22 348,30 Q 340,30 342,24"/></g><!-- Leaves at the inflection points --><g fill="rgba(168,148,116,0.28)" stroke="#caa890" stroke-width="0.4" opacity="0.85"><path d="M 130,18 Q 122,22 118,30 Q 128,28 132,22 Z"/><path d="M 270,18 Q 278,22 282,30 Q 272,28 268,22 Z"/></g><!-- Central lily-of-the-valley cluster, hanging below the rule --><g fill="rgba(228,204,176,0.40)" stroke="#caa890" stroke-width="0.55" opacity="0.85"><ellipse cx="178" cy="34" rx="2.4" ry="3.4"/><ellipse cx="186" cy="44" rx="2.2" ry="3.0"/><ellipse cx="194" cy="52" rx="2.0" ry="2.8"/><ellipse cx="200" cy="40" rx="2.8" ry="3.8"/><ellipse cx="206" cy="52" rx="2.0" ry="2.8"/><ellipse cx="214" cy="44" rx="2.2" ry="3.0"/><ellipse cx="222" cy="34" rx="2.4" ry="3.4"/></g><!-- Subtle stem lines connecting bells to the rule --><g stroke="#caa890" stroke-width="0.35" opacity="0.45" fill="none"><path d="M 178,22 Q 178,28 178,32"/><path d="M 186,22 Q 186,32 186,42"/><path d="M 194,22 Q 194,38 194,50"/><path d="M 200,22 Q 200,30 200,38"/><path d="M 206,22 Q 206,38 206,50"/><path d="M 214,22 Q 214,32 214,42"/><path d="M 222,22 Q 222,28 222,32"/></g><!-- Bell highlights --><g fill="rgba(244,224,196,0.30)"><ellipse cx="178" cy="33" rx="0.8" ry="1.2"/><ellipse cx="200" cy="39" rx="0.9" ry="1.4"/><ellipse cx="222" cy="33" rx="0.8" ry="1.2"/></g><!-- Diamond accents on either side --><polygon points="100,18 103,22 100,26 97,22" fill="#caa890" opacity="0.55"/><polygon points="300,18 303,22 300,26 297,22" fill="#caa890" opacity="0.55"/><!-- Outer terminal beads --><circle cx="52" cy="32" r="1.0" fill="#e4c4a4" opacity="0.55"/><circle cx="348" cy="32" r="1.0" fill="#e4c4a4" opacity="0.55"/></svg>

:: Ending Vines SVG {"position":"3000,2600","size":"100,100"}
<div class="ending-vines"><svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice"><defs><linearGradient id="gvWhite" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#b07820" stop-opacity="0.95"/><stop offset="50%" stop-color="#d49c38" stop-opacity="0.9"/><stop offset="100%" stop-color="#a06818" stop-opacity="0.85"/></linearGradient><linearGradient id="gvBlack" x1="0" x2="1" y1="0" y2="1"><stop offset="0%" stop-color="#d0a860" stop-opacity="0.85"/><stop offset="50%" stop-color="#f4dca0" stop-opacity="0.95"/><stop offset="100%" stop-color="#c09848" stop-opacity="0.8"/></linearGradient><filter id="evGlow" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="1.2" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter><filter id="evGlass" x="-20%" y="-20%" width="140%" height="140%"><feGaussianBlur stdDeviation="0.8" result="halo"/><feMerge><feMergeNode in="halo"/><feMergeNode in="SourceGraphic"/></feMerge></filter><radialGradient id="gvGlassW" cx="32%" cy="22%" r="80%"><stop offset="0%" stop-color="#fff4d0" stop-opacity="0.95"/><stop offset="35%" stop-color="#e8b840" stop-opacity="0.7"/><stop offset="80%" stop-color="#a06818" stop-opacity="0.5"/><stop offset="100%" stop-color="#704812" stop-opacity="0.65"/></radialGradient><radialGradient id="gvGlassB" cx="32%" cy="22%" r="80%"><stop offset="0%" stop-color="#fffaea" stop-opacity="0.98"/><stop offset="35%" stop-color="#f4dca0" stop-opacity="0.8"/><stop offset="80%" stop-color="#c09848" stop-opacity="0.55"/><stop offset="100%" stop-color="#806028" stop-opacity="0.7"/></radialGradient><radialGradient id="gvGlassPinkW" cx="32%" cy="22%" r="80%"><stop offset="0%" stop-color="#fff4f8" stop-opacity="0.95"/><stop offset="35%" stop-color="#f4a8c0" stop-opacity="0.7"/><stop offset="80%" stop-color="#b06078" stop-opacity="0.5"/><stop offset="100%" stop-color="#804050" stop-opacity="0.65"/></radialGradient><radialGradient id="gvGlassPinkB" cx="32%