    var src = ac.createBufferSource(); src.buffer = buf; src.loop = true;
    // Two bandpass filters in parallel — formant character (vowels)
    var f1 = ac.createBiquadFilter(); f1.type='bandpass';
    f1.frequency.value = 620; f1.Q.value = 1.6;
    var f2 = ac.createBiquadFilter(); f2.type='bandpass';
    f2.frequency.value = 1500; f2.Q.value = 1.9;
    var g1 = ac.createGain(); g1.gain.value = 1.0;
    var g2 = ac.createGain(); g2.gain.value = 0.55;
    var g = ac.createGain();
    g.gain.setValueAtTime(0, now);
    g.gain.linearRampToValueAtTime(0.18, now + 1.5);
    src.connect(f1); f1.connect(g1); g1.connect(g);
    src.connect(f2); f2.connect(g2); g2.connect(g);
    g.connect(ac.destination);
