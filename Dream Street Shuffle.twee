    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.25, 0.1), shopRed, cbi, 3.65, 0.3);
    placeMesh(shop, new THREE.BoxGeometry(0.06, 0.08, 0.12), goldTrim, cbi, 3.58, 0.32);
  }

  // ---- FASCIA SPOTLIGHTS (angled down, like Lord Chippy) ----
  var fasciaLamps = [];
  for (var flx = -1.5; flx <= 2.5; flx += 2.0) {
    // Spotlight housing
    placeMesh(shop, new THREE.BoxGeometry(0.08, 0.08, 0.15), blackMat, flx, 4.72, 0.4);
    var spotCone = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.06, 0.12, 6),
      new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5 }));
    spotCone.position.set(flx, 4.68, 0.5);
    spotCone.rotation.x = 0.5;
    shop.add(spotCone);
    // Spot glow
    var spotGlow = new THREE.Mesh(new THREE.SphereGeometry(0.03, 4, 4),
      new THREE.MeshBasicMaterial({ color: 0xffeedd }));
    spotGlow.position.set(flx, 4.65, 0.55);
    shop.add(spotGlow);
    var spotLight = new THREE.PointLight(0xffeedd, 0.6, 5);
    spotLight.position.set(flx, 4.5, 0.7);
    spotLight.userData.baseIntensity = 0.6;
    shop.add(spotLight);
    fasciaLamps.push(spotLight);
  }

  // ---- GROUND FLOOR: THE CHIPPY SHOPFRONT ----
  // This is the heart of the scene — spare, bright, glowing

  // Tiled surround / stall riser (cream tiles with gold accent strip, very 1970s)
  placeMesh(shop, new THREE.BoxGeometry(6.02, 0.6, 0.12), whiteTile, 0.5, 0.3, 0.22);
  // Gold accent strip at top of tiles
  placeMesh(shop, new THREE.BoxGeometry(6.04, 0.035, 0.04), goldTrim, 0.5, 0.62, 0.29);
  // Tile grid lines (vertical)
