    cx.fillStyle = '#c8a840';
    cx.font = 'bold 30px Georgia'; cx.textAlign = 'center';
    cx.fillText('7', w / 2, 35);
    cx.shadowBlur = 0;
  });
  var numPlane = new THREE.Mesh(new THREE.PlaneGeometry(0.3, 0.3),
    new THREE.MeshBasicMaterial({ map: numTex, transparent: true }));
  numPlane.position.set(0.5, 4.85, 0.22);
  shop.add(numPlane);

  // ---- WINDOW CONDENSATION (subtle — warm inside, cold out) ----
  var condenseTex = makeCanvasTexture(128, 128, function(cx, w, h) {
    var grad = cx.createLinearGradient(0, 0, 0, h);
    grad.addColorStop(0, 'rgba(200, 200, 200, 0)');
    grad.addColorStop(0.7, 'rgba(200, 200, 200, 0.03)');
    grad.addColorStop(1, 'rgba(200, 200, 200, 0.08)');
    cx.fillStyle = grad; cx.fillRect(0, 0, w, h);
  });
  var condensePlane = new THREE.Mesh(new THREE.PlaneGeometry(5.5, 2.5),
    new THREE.MeshBasicMaterial({ map: condenseTex, transparent: true }));
  condensePlane.position.set(0.5, 2.0, 0.36);
  shop.add(condensePlane);

