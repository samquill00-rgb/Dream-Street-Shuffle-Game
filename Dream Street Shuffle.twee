  new THREE.MeshBasicMaterial({ map: nebTex2, transparent: true, opacity: 0.7, depthWrite: false, fog: false }));
nebula2.position.set(-22, 8, 6);
nebula2.rotation.y = Math.PI / 2;
scene.add(nebula2);
