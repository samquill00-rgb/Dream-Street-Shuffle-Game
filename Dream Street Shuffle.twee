// ============================================================
// ANIMATION
// ============================================================
var clock = new THREE.Clock();
var baseBulbIntensity = 2.5;
var baseBulbEmissive = 0.55;
var baseGlowOpacity = 0.1;

function clAnimate() {
clAnimId = requestAnimationFrame(clAnimate);
var t = clock.getElapsedTime();

// Breathing light instead of pulsing/flickering
var breath = 0.97 + Math.sin(t * 0.4) * 0.03;
bulbLight.intensity = baseBulbIntensity * breath;
bulbGlass.emissiveIntensity = baseBulbEmissive * breath;
glowSphere.material.opacity = baseGlowOpacity * breath;

// Subtle sway
var sway = Math.sin(t * 0.4) * 0.0015;
bulbSphere.position.x = sway;
bulbLight.position.x = sway;
glowSphere.position.x = sway;
wire.position.x = sway * 0.5;

// Camera drift
camera.position.x = 0.3 + Math.sin(t * 0.12) * 0.017 + Math.sin(t * 0.5) * 0.003;
camera.position.y = 1.5 + Math.sin(t * 0.15) * 0.006 + Math.sin(t * 0.6) * 0.002;

renderer.render(scene, camera);
}

clAnimate();

