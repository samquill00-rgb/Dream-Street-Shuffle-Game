08"/><stop offset="100%" stop-color="#0a0402"/></linearGradient><linearGradient id="cpColumn" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#7a5a3a"/><stop offset="100%" stop-color="#3a2818"/></linearGradient></defs><!-- Warm glow over the scene --><rect x="0" y="0" width="500" height="95" fill="url(#cpGlow)"/><!-- Ground --><rect x="0" y="80" width="500" height="15" fill="url(#cpGround)"/><!-- Distant ruin shapes on the horizon --><path d="M140,80 L142,55 L145,58 L148,52 L152,60 L156,55 L159,80 Z" fill="#2a1810" opacity="0.55"/><path d="M338,80 L341,48 L347,53 L351,46 L355,56 L359,50 L362,80 Z" fill="#2a1810" opacity="0.5"/><path d="M168,80 L171,68 L177,72 L180,80 Z" fill="#2a1810" opacity="0.42"/><path d="M324,80 L327,71 L332,75 L336,80 Z" fill="#2a1810" opacity="0.42"/><!-- Far-left broken column with fluting --><g opacity="0.7"><rect x="78" y="32" width="6" height="48" fill="url(#cpColumn)"/><line x1="79.5" y1="34" x2="79.5" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.55"/><line x1="81" y1="34" x2="81" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.5"/><line x1="82.5" y1="34" x2="82.5" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.55"/><rect x="76" y="29" width="10" height="4" rx="0.5" fill="#806858"/><path d="M76,32 L86,29 L86,33 L76,36 Z" fill="#806858" opacity="0.6"/><!-- Fallen drum next to base --><ellipse cx="73" cy="80" rx="8" ry="2" fill="#3a2818" opacity="0.5"/><rect x="67" y="77" width="12" height="3.5" rx="0.5" fill="#806858" opacity="0.5"/><circle cx="69" cy="78.5" r="1.5" fill="#3a2010" opacity="0.65"/></g><!-- Far-right column — taller, slightly more eroded --><g opacity="0.65"><rect x="402" y="22" width="6" height="58" fill="url(#cpColumn)"/><line x1="403.5" y1="25" x2="403.5" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.55"/><line x1="405" y1="25" x2="405" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.5"/><line x1="406.5" y1="25" x2="406.5" y2="78" stroke="#1a0e06" stroke-width="0.35" opacity="0.55"/><rect x="400" y="19" width="10" height="4" rx="0.5" fill="#806858"/><!-- Crack running down --><path d="M404,38 Q406,46 404,54 Q406,62 404,70" fill="none" stroke="#0a0402" stroke-width="0.5" opacity="0.55"/><!-- Lichen patch --><ellipse cx="407" cy="50" rx="1.8" ry="3.5" fill="#3a4828" opacity="0.4"/><!-- Rubble at base --><ellipse cx="416" cy="80" rx="10" ry="2.5" fill="#3a2818" opacity="0.45"/><rect x="408" y="76" width="8" height="4" rx="0.5" fill="#806858" opacity="0.5"/><circle cx="420" cy="79" r="1.7" fill="#3a2010" opacity="0.6"/></g><!-- ============================================================ --><!--   THE PYRE — built up of charred logs, body shrouded on top      --><!-- ============================================================ --><!-- Shadow on ground --><ellipse cx="250" cy="82" rx="72" ry="3.5" fill="#0a0402" opacity="0.65"/><!-- Bottom log course (long, dark, charred) --><rect x="190" y="74" width="120" height="6" rx="1.5" fill="url(#cpLogDark)"/><rect x="190" y="74" width="120" height="2" fill="#5a2010" opacity="0.55"/><!-- Log end-grain on each end --><circle cx="192" cy="77" r="2.6" fill="#3a1408"/><circle cx="192" cy="77" r="1.6" fill="#0a0402"/><circle cx="308" cy="77" r="2.6" fill="#3a1408"/><circle cx="308" cy="77" r="1.6" fill="#0a0402"/><!-- Cross-grain split lines --><line x1="210" y1="74" x2="210" y2="80" stroke="#0a0402" stroke-width="0.4" opacity="0.6"/><line x1="232" y1="74" x2="232" y2="80" stroke="#0a0402" stroke-width="0.4" opacity="0.55"/><line x1="252" y1="74" x2="252" y2="80" stroke="#0a0402" stroke-width="0.4" opacity="0.6"/><line x1="270" y1="74" x2="270" y2="80" stroke="#0a0402" stroke-width="0.4" opacity="0.55"/><line x1="288" y1="74" x2="288" y2="80" stroke="#0a0402" stroke-width="0.4" opacity="0.6"/><!-- Second course (perpendicular, inset) --><rect x="202" y="68" width="96" height="6" rx="1" fill="url(#cpLogDark)"/><rect x="202" y="68" width="96" height="2" fill="#5a2010" opacity="0.55"/><line x1="220" y1="68" x2="220" y2="74" stroke="#0a0402" stroke-width="0.4" opacity="0.55"/><line x1="245" y1="68" x2="245" y2="74" stroke="#0a0402" stroke-width="0.4" opacity="0.55"/><line x1="275" y1="68" x2="275" y2="74" stroke="#0a0402" stroke-width="0.4" opacity="0.55"/><!-- Third course (top course, glowing — body rests on this) --><rect x="212" y="62" width="76" height="6" rx="1" fill="url(#cpLogGlow)"/><rect x="212" y="62" width="76" height="1.5" fill="#3a1408" opacity="0.5"/><line x1="232" y1="62" x2="232" y2="68" stroke="#1a0a04" stroke-width="0.4" opacity="0.65"/><line x1="252" y1="62" x2="252" y2="68" stroke="#1a0a04" stroke-width="0.4" opacity="0.65"/><line x1="270" y1="62" x2="270" y2="68" stroke="#1a0a04" stroke-width="0.4" opacity="0.65"/><!-- Glowing embers visible between top logs --><ellipse cx="240" cy="68.5" rx="3" ry="0.8" fill="#ff8030" opacity="0.85"/><ellipse cx="262" cy="68.5" rx="2.4" ry="0.7" fill="#ffa040" opacity="0.8"/><ellipse cx="252" cy="68.5" rx="1.5" ry="0.6" fill="#fff0c0" opacity="0.7"/><!-- ────────────  BODY — shrouded, lying on the top course ──────────── --><!-- Main shroud body (lying horizontal across the logs) --><path d="M210,62 Q210,56 215,55 L285,55 Q290,56 290,62 Z" fill="url(#cpShroud)"/><!-- Body subtle shadow folds --><path d="M222,57 Q226,59 234,56 Q244,59 254,56 Q264,59 274,56 Q280,59 285,57" fill="none" stroke="#3a1810" stroke-width="0.7" opacity="0.55"/><!-- Head (left end, slightly raised) --><ellipse cx="212" cy="55" rx="6" ry="4.5" fill="#1a0a04"/><ellipse cx="211" cy="54" rx="2" ry="1.5" fill="#3a1810" opacity="0.6"/><!-- Foot end --><ellipse cx="288" cy="56" rx="4" ry="3.2" fill="#1a0a04"/><!-- Funeral cloth at the top edge — darker line --><line x1="208" y1="55" x2="290" y2="55" stroke="#0a0402" stroke-width="0.6" opacity="0.85"/><!-- ────────────  FLAMES — layered, rising around body ──────────── --><!-- Outer flame envelope (broad soft glow) --><ellipse cx="250" cy="46" rx="44" ry="38" fill="url(#cpFlameCore)" opacity="0.85"/><!-- Layer 1 — deep red outer --><path d="M208,62 Q198,40 218,16 Q224,28 230,4 Q236,22 242,2 Q248,22 252,1 Q256,22 262,3 Q268,22 274,8 Q280,28 286,16 Q300,38 292,62Z" fill="#8a2800" opacity="0.62"/><!-- Layer 2 — bright orange mid --><path d="M216,62 Q208,42 224,20 Q232,32 240,10 Q245,26 250,5 Q256,26 261,10 Q267,32 274,18 Q284,36 280,62Z" fill="#c04808" opacity="0.72"/><!-- Layer 3 — orange brighter --><path d="M224,62 Q220,44 232,26 Q238,36 244,14 Q248,28 252,10 Q257,28 262,14 Q268,32 275,28 Q282,46 272,62Z" fill="#d4600a" opacity="0.78"/><!-- Layer 4 — yellow inner --><path d="M232,62 Q228,46 238,30 Q242,40 246,20 Q250,30 254,18 Q258,30 262,22 Q268,38 266,62Z" fill="#e88020" opacity="0.75"/><!-- Layer 5 — bright yellow tongue --><path d="M238,62 Q237,48 242,34 Q246,40 250,28 Q254,40 257,28 Q260,42 261,62Z" fill="#ffa040" opacity="0.68"/><!-- Layer 6 — white-hot core --><path d="M244,62 Q243,50 248,38 Q250,46 252,38 Q254,46 256,62Z" fill="#ffc868" opacity="0.62"/><!-- White-hot tip --><ellipse cx="251" cy="42" rx="2.5" ry="5.5" fill="#fff0d0" opacity="0.55"/><!-- Side wisps (left and right) --><path d="M204,62 Q198,52 205,38 Q208,48 213,52 Q210,58 214,62Z" fill="#8a2800" opacity="0.45"/><path d="M296,62 Q302,52 295,38 Q292,48 287,52 Q290,58 286,62Z" fill="#8a2800" opacity="0.45"/><!-- Small lick on far left --><path d="M212,62 Q207,55 211,46 Q214,52 215,62Z" fill="#c04808" opacity="0.5"/><path d="M288,62 Q293,55 289,46 Q286,52 285,62Z" fill="#c04808" opacity="0.5"/><!-- ────────────  RISING EMBERS — many, varied glowing sparks ──────────── --><circle cx="245" cy="6" r="1.2" fill="#ffc868" opacity="0.9"/><circle cx="245" cy="6" r="0.5" fill="#fff0d0" opacity="0.95"/><circle cx="260" cy="9" r="0.9" fill="#ff8030" opacity="0.85"/><circle cx="238" cy="11" r="1" fill="#ffa040" opacity="0.85"/><circle cx="268" cy="3" r="0.65" fill="#ffc868" opacity="0.85"/><circle cx="252" cy="2" r="0.75" fill="#fff0d0" opacity="0.9"/><circle cx="229" cy="7" r="0.7" fill="#ff8030" opacity="0.8"/><circle cx="273" cy="13" r="1.1" fill="#ffa040" opacity="0.85"/><circle cx="242" cy="18" r="0.6" fill="#ffc868" opacity="0.8"/><circle cx="257" cy="16" r="0.55" fill="#ff6020" opacity="0.8"/><circle cx="223" cy="14" r="0.45" fill="#ff8030" opacity="0.7"/><circle cx="278" cy="20" r="0.75" fill="#ffc868" opacity="0.8"/><circle cx="217" cy="22" r="0.55" fill="#ffa040" opacity="0.7"/><circle cx="285" cy="27" r="0.5" fill="#ff8030" opacity="0.65"/><circle cx="248" cy="22" r="0.45" fill="#fff0d0" opacity="0.8"/><circle cx="234" cy="29" r="0.55" fill="#ff8030" opacity="0.6"/><circle cx="266" cy="29" r="0.45" fill="#ffc868" opacity="0.6"/><circle cx="226" cy="35" r="0.35" fill="#d4600a" opacity="0.55"/><circle cx="276" cy="35" r="0.4" fill="#ff8030" opacity="0.55"/><!-- ────────────  SMOKE WISPS — drift up off the highest flames ──────────── --><path d="M248,2 Q252,-3 246,-9" fill="none" stroke="#3a2a22" stroke-width="2.2" opacity="0.4" stroke-linecap="round"/><path d="M253,4 Q258,-2 251,-12" fill="none" stroke="#3a2a22" stroke-width="1.7" opacity="0.35" stroke-linecap="round"/><path d="M255,8 Q263,2 260,-7" fill="none" stroke="#3a2a22" stroke-width="1.4" opacity="0.3" stroke-linecap="round"/><!-- ────────────  GROUND EMBERS — small glowing dots on the ground around the pyre ──────────── --><circle cx="180" cy="83" r="0.8" fill="#d4600a" opacity="0.45"/><circle cx="320" cy="81" r="0.6" fill="#c84a08" opacity="0.4"/><circle cx="200" cy="84" r="0.4" fill="#ff8030" opacity="0.35"/><circle cx="305" cy="83" r="0.7" fill="#d4600a" opacity="0.45"/><circle cx="225" cy="85" r="0.35" fill="#ff8020" opacity="0.3"/><circle cx="275" cy="84" r="0.45" fill="#ff8030" opacity="0.35"/><circle cx="160" cy="84" r="0.5" fill="#ff8020" opacity="0.25"/><circle cx="340" cy="83" r="0.7" fill="#d4600a" opacity="0.3"/><circle cx="195" cy="82" r="0.3" fill="#ffa040" opacity="0.4"/><circle cx="313" cy="84" r="0.4" fill="#ff8030" opacity="0.35"/><!-- Edge fades to blend with surrounding prose --><rect x="0" y="0" width="500" height="95" fill="url(#cpTopFade)"/><rect x="0" y="0" width="500" height="95" fill="url(#cpFade)"/></svg>
<div class="dream-sequence">
You stay for an hour or forever.

Her pyre burns down while you're close and all through the night, the body in its flames transforms, hanging the Lily-of-the-Valley on your nose that desires it; on the path of an asymptote, to something infinitesimally-not-her.

Polybius: What do you mean by England? Why do you damn your country with its name?

[[Wake suddenly|The Interval]]
</div>

:: Talk to the Artists [venue-french] {"position":"500,650","size":"100,100"}
(display: "French Rule SVG h60")

You move towards their table, suspended, as it were, a thumb's-width above the oak floor.

They do not look up. You're about to bottle it when somebody speaks your name.

Among them is a face you recognise and he's greeting you now. He is a Spaniard from El Rocío, in Andalusia, named Benito de los Juncales del Oeste. He painted you and Ashton Granger once, when you were lovers, years ago in Cordoba.

<div class="verse">
My mediaeval knees lack health until they bend,<br>
But in that woman, in that household where<br>
Honour had lived so long, all lacking found.<br>
[…]<br>
No fox can foul the lair the badger swept.
</div>

You think of this, from Spenser and from Yeats, as you say hello.

[[Sit with him|The Spanish Artist]]
(display: "French Rule SVG h24")</svg>

:: Talk to the critic [venue-pillars] {"position":"500,1100","size":"100,100"}
(set: $metCritic to true)\
