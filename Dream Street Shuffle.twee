  cx.textAlign = 'center';
  cx.textBaseline = 'middle';
  cx.letterSpacing = '4px';
  cx.fillText('TELEPHONE', w/2, h/2);
});
var telSignMat = new THREE.MeshStandardMaterial({ map: telSignTex, roughness: 0.5 });
// Front sign
